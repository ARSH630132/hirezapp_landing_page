{
  "name": "hirezapp_landing_page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "verify-tools": "node scripts/verify-tool-logic.js",
    "backend:install": "cd backend && (test -d venv || python3 -m venv venv) && venv/bin/pip install -r requirements.txt && (test -f .env || cp .env.example .env)",
    "backend:dev": "cd backend && venv/bin/uvicorn app.main:app --reload --port 8000",
    "backend:seed": "cd backend && venv/bin/python app/seed.py",
    "backend:check": "backend/venv/bin/python backend/app/test_security_utilities.py"
  },
  "dependencies": {
    "@fontsource/montserrat": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotted-map": "^3.1.0",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
