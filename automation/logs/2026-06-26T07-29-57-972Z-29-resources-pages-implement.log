{"ts":"2026-06-26T07:24:30.189Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7g4ih4t8","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/resources/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nconst RESOURCE_CATEGORIES = [\n  {\n    title: \"Theoretical Research Papers\",\n    slug: \"research\",\n    medium: \"Technical & Architecture\",\n    tag: \"ACADEMIC ARCHIVE\",\n    desc: \"Rigorous scientific research exploring cognitive modeling, multi-agent convergence, and latency optimization.\",\n    href: \"/resources/research\"\n  },\n  {\n    title: \"Technical Whitepapers\",\n    slug: \"whitepapers\",\n    medium: \"Technical & Architecture\",\n    tag: \"SYSTEM SPECIFICATIONS\",\n    desc: \"Detailed systems architectural papers detailing secure sandboxing, memory isolation, and safe execution loops.\",\n    href: \"/resources/whitepapers\"\n  },\n  {\n    title: \"Architecture Library\",\n    slug: \"architecture-library\",\n    medium: \"Technical & Architecture\",\n    tag: \"BLUEPRINTS\",\n    desc: \"Interactive visual diagrams, memory structures, and data flows of our state-of-the-art enterprise platforms.\",\n    href: \"/resources/architecture-library\"\n  },\n  {\n    title: \"Developer Documentation\",\n    slug: \"developer-docs\",\n    medium: \"Technical & Architecture\",\n    tag: \"DEVELOPER RESOURCES\",\n    desc: \"Robust API references, schema declarations, and SDK manuals for orchestrating secure agentic clusters.\",\n    href: \"/resources/developer-docs\"\n  },\n  {\n    title: \"Patterns of Intelligence\",\n    slug: \"patterns-of-intelligence\",\n    medium: \"Executive Strategy\",\n    tag: \"COGNITIVE ARCHETYPES\",\n    desc: \"A proprietary catalog of standardized enterprise intelligence patterns mapped to industry verticals.\",\n    href: \"/resources/patterns-of-intelligence\"\n  },\n  {\n    title: \"Case Studies\",\n    slug: \"case-studies\",\n    medium: \"Executive Strategy\",\n    tag: \"REAL-WORLD VERIFICATION\",\n    desc: \"In-depth studies of sovereign multi-agent integrations across audit, finance, advisory, and energy sectors.\",\n    href: \"/resources/case-studies\"\n  },\n  {\n    title: \"Market Reports\",\n    slug: \"reports\",\n    medium: \"Executive Strategy\",\n    tag: \"INTELLIGENCE BRIEFS\",\n    desc: \"Strategic reports assessing digital labor penetration, boardroom readiness, and macroeconomic AI scaling indices.\",\n    href: \"/resources/reports\"\n  },\n  {\n    title: \"Corporate Blog\",\n    slug: \"blog\",\n    medium: \"Executive Strategy\",\n    tag: \"EDITORIAL DIALOGUE\",\n    desc: \"Reflections on sovereign technology, safe deployment methodologies, and the ethics of digital workforce automation.\",\n    href: \"/resources/blog\"\n  },\n  {\n    title: \"Multimedia Keynotes\",\n    slug: \"videos\",\n    medium: \"Multimedia & Dialogue\",\n    tag: \"VIDEO KEYNOTES\",\n    desc: \"High-definition streaming captures of our technical keynotes, platform walk-throughs, and system live demonstrations.\",\n    href: \"/resources/videos\"\n  },\n  {\n    title: \"Executive Masterclasses\",\n    slug: \"webinars\",\n    medium: \"Multimedia & Dialogue\",\n    tag: \"WEBINARS & SEMINARS\",\n    desc: \"Interactive, expert-led training webinars detailing model alignment, data sovereignty, and security governance.\",\n    href: \"/resources/webinars\"\n  },\n  {\n    title: \"Global Summits & Roundtables\",\n    slug: \"events\",\n    medium: \"Multimedia & Dialogue\",\n    tag: \"EVENTS DICTIONARY\",\n    desc: \"Physical and virtual events calendar, featuring executive roundtables and developer meetups globally.\",\n    href: \"/resources/events\"\n  },\n  {\n    title: \"Boardroom Podcast\",\n    slug: \"podcasts\",\n    medium: \"Multimedia & Dialogue\",\n    tag: \"AUDIO PODCASTS\",\n    desc: \"C-suite discussions and deep technical conversations on the operationalization of secure autonomous enterprises.\",\n    href: \"/resources/podcasts\"\n  },\n  {\n    title: \"Asset Downloads\",\n    slug: \"downloads\",\n    medium: \"Technical & Architecture\",\n    tag: \"UTILITIES & FILES\",\n    desc: \"Cryptographically verified software packages, compliance checklists, and offline deployment calculators.\",\n    href: \"/resources/downloads\"\n  },\n  {\n    title: \"Corporate Newsroom\",\n    slug: \"newsroom\",\n    medium: \"Corporate\",\n    tag: \"PRESS ARCHIVE\",\n    desc: \"Official corporate press releases, engineering breakthroughs, strategic alliances, and leadership announcements.\",\n    href: \"/resources/newsroom\"\n  }\n];\n\nexport default function ResourcesPage() {\n  const [filter, setFilter] = useState(\"All\");\n  const [search, setSearch] = useState(\"\");\n  const [emailSubscribed, setEmailSubscribed] = useState(false);\n  const [email, setEmail] = useState(\"\");\n\n  const filteredCategories = useMemo(() => {\n    return RESOURCE_CATEGORIES.filter((cat) => {\n      const matchFilter = filter === \"All\" || cat.medium === filter;\n      const matchSearch = cat.title.toLowerCase().includes(search.toLowerCase()) || \n                          cat.desc.toLowerCase().includes(search.toLowerCase()) ||\n                          cat.tag.toLowerCase().includes(search.toLowerCase());\n      return matchFilter && matchSearch;\n    });\n  }, [filter, search]);\n\n  const handleSubscribe = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!email) return;\n    setEmailSubscribed(true);\n    setTimeout(() => {\n      setEmail(\"\");\n      setEmailSubscribed(false);\n    }, 4000);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Knowledge Vault\"\n        title=\"Research & Intelligence Library\"\n        highlightedWord=\"Research & Intelligence\"\n        description=\"Access institutional-grade insights, academic breakthroughs, reference architectures, and standardized cognitive paradigms engineered for sovereign enterprises.\"\n        breadcrumbs={[\n          { label: \"Home\", href: \"/\" },\n          { label: \"Resources\" }\n        ]}\n      />\n\n      {/* Featured Research Spotlight Block */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-12\">\n        <div className=\"relative rounded-[32px] border border-white/10 bg-gradient-to-b from-[#0a0a0c] to-[#040405] overflow-hidden p-8 lg:p-12\">\n          {/* Subtle glow background */}\n          <div className=\"absolute top-0 right-0 w-[50%] h-full bg-gradient-to-l from-[#009DFF]/5 via-transparent to-transparent pointer-events-none\" />\n          <div className=\"absolute top-1/2 left-1/4 -translate-y-1/2 w-[30%] aspect-square bg-[#E4000F]/5 rounded-full blur-[80px] pointer-events-none\" />\n\n          <div className=\"relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n            <div className=\"lg:col-span-7 flex flex-col justify-center\">\n              <div className=\"flex items-center gap-3 mb-6\">\n                <span className=\"px-3 py-1 text-[10px] font-mono tracking-widest text-[#E4000F] border border-[#E4000F]/20 bg-[#E4000F]/5 rounded-full font-bold uppercase\">\n                  Flagship Briefing\n                </span>\n                <span className=\"text-[11px] font-mono text-white/40\">2026 EDITION</span>\n              </div>\n              <h2 className=\"text-[24px] sm:text-[32px] lg:text-[40px] font-bold text-white tracking-tight leading-[1.15]\">\n                Sovereign Agentic Infrastructure & Core Risk Paradigms\n              </h2>\n              <p className=\"mt-4 text-[14px] sm:text-[15px] leading-[1.6] text-white/60 font-light max-w-[620px]\">\n                An extensive, multi-author institutional thesis published by our Singapore-based research group. Outlining safety loops, regulatory alignments, and empirical throughput constraints for global deployments.\n              </p>\n\n              <div className=\"mt-8 flex flex-wrap gap-4 items-center\">\n                <a\n                  href=\"/resources/research\"\n                  className=\"px-6 py-2.5 rounded-full text-[12px] font-semibold text-white bg-white/10 border border-white/10 hover:bg-white/15 transition-all uppercase tracking-wider\"\n                >\n                  Read Research Paper\n                </a>\n                <a\n                  href=\"/resources/downloads\"\n                  className=\"flex items-center gap-2 text-[11px] font-mono uppercase text-[#009DFF] hover:text-[#009DFF]/80 font-bold transition-all\"\n                >\n                  <span>Get Offline Toolkit</span>\n                  <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n                  </svg>\n                </a>\n              </div>\n            </div>\n\n            <div className=\"lg:col-span-5 flex justify-center lg:justify-end\">\n              <div className=\"w-full max-w-[340px] aspect-[4/5] rounded-[24px] border border-white/10 bg-black p-6 flex flex-col justify-between shadow-2xl relative group overflow-hidden\">\n                <div className=\"absolute top-0 left-0 w-full h-[3px] bg-gradient-to-r from-[#E4000F] via-white/10 to-[#009DFF]\" />\n                <div className=\"flex justify-between items-start\">\n                  <span className=\"text-[9px] font-mono text-white/30 tracking-widest uppercase\">GFF RESEARCH GROUP</span>\n                  <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">VOL. XXVI</span>\n                </div>\n\n                <div className=\"my-6\">\n                  <div className=\"w-8 h-[1px] bg-white/30 mb-4\" />\n                  <p className=\"text-[10px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-1\">REFERENCE SCHEMA</p>\n                  <h3 className=\"text-[18px] font-bold text-white leading-tight tracking-tight\">Sovereign Orchestration Protocols</h3>\n                  <p className=\"mt-2 text-[11px] text-white/50 font-light leading-relaxed\">\n                    Cryptographic guarantees for autonomous cross-border memory isolation under dynamic regulatory structures.\n                  </p>\n                </div>\n\n                <div className=\"pt-4 border-t border-white/5 flex items-center justify-between\">\n                  <div className=\"flex flex-col\">\n                    <span className=\"text-[8px] font-mono text-white/30\">HASH IDENTIFIER</span>\n                    <span className=\"text-[9px] font-mono text-white/50\">SHA-256: 0x8aef91c...</span>\n                  </div>\n                  <span className=\"text-[10px] font-bold text-white/80\">PDF (4.8 MB)</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Main Grid Directory Area */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 py-12\">\n        <div className=\"flex flex-col md:flex-row gap-6 items-start md:items-center justify-between border-b border-white/5 pb-8 mb-10\">\n          <div>\n            <h2 className=\"text-[24px] sm:text-[32px] font-bold text-white tracking-tight\">\n              Enterprise Knowledge Domains\n            </h2>\n            <p className=\"text-[13px] text-white/50 mt-1 font-light\">\n              Filter by operational format to explore relevant assets.\n            </p>\n          </div>\n\n          <div className=\"flex flex-wrap gap-2 items-center\">\n            {[\"All\", \"Technical & Architecture\", \"Executive Strategy\", \"Multimedia & Dialogue\", \"Corporate\"].map((medium) => (\n              <button\n                key={medium}\n                onClick={() => setFilter(medium)}\n                className={`px-3 py-1.5 rounded-full text-[10.5px] font-semibold tracking-wider transition-all uppercase ${\n                  filter === medium\n                    ? \"bg-white text-black shadow-lg\"\n                    : \"bg-white/5 text-white/60 hover:text-white border border-white/5 hover:border-white/10\"\n                }`}\n              >\n                {medium}\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Categories Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filteredCategories.map((cat) => (\n            <a\n              key={cat.slug}\n              href={cat.href}\n              className=\"group relative rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[8px] p-6 lg:p-8 flex flex-col justify-between hover:border-white/12 transition-all duration-300\"\n            >\n              <div className=\"absolute top-0 left-6 w-[30%] h-[1px] bg-gradient-to-r from-[#009DFF]/20 via-white/10 to-transparent group-hover:from-[#009DFF]/40\" />\n              <div>\n                <div className=\"flex items-center justify-between text-[9px] font-mono uppercase text-white/40 mb-4\">\n                  <span className=\"text-[#009DFF] font-bold tracking-widest\">{cat.tag}</span>\n                  <span className=\"px-2 py-0.5 rounded bg-white/5 text-[8px]\">{cat.medium}</span>\n                </div>\n                <h3 className=\"text-[18px] sm:text-[20px] font-bold text-white tracking-tight group-hover:text-[#009DFF] transition-colors flex items-center justify-between gap-3\">\n                  <span>{cat.title}</span>\n                  <svg\n                    className=\"w-4.5 h-4.5 text-white/30 group-hover:text-white group-hover:translate-x-1.5 transition-all duration-300 shrink-0\"\n                    fill=\"none\"\n                    viewBox=\"0 0 24 24\"\n                    stroke=\"currentColor\"\n                  >\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n                  </svg>\n                </h3>\n                <p className=\"mt-3 text-[13px] leading-[1.55] text-white/55 font-light\">\n                  {cat.desc}\n                </p>\n              </div>\n\n              <div className=\"mt-8 pt-4 border-t border-white/5 flex items-center justify-between text-[11px] text-white/40\">\n                <span className=\"font-mono text-[9px] uppercase tracking-wider group-hover:text-white/60 transition-colors\">Access Domain Directory →</span>\n                <span className=\"text-white/30 hover:text-white transition-colors\">VERIFIED PREVIEW</span>\n              </div>\n            </a>\n          ))}\n        </div>\n      </div>\n\n      {/* Executive Newsletter/Subscription Block */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 py-12\">\n        <div className=\"relative rounded-[28px] border border-white/5 bg-[#030304] p-8 md:p-12 overflow-hidden flex flex-col lg:flex-row items-center justify-between gap-8\">\n          <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#E4000F]/15 to-transparent\" />\n          <div className=\"max-w-[550px]\">\n            <span className=\"text-[9px] font-mono text-[#E4000F] font-bold tracking-[0.2em] uppercase\">INTELLIGENCE SYNDICATION</span>\n            <h3 className=\"text-[22px] sm:text-[28px] font-bold text-white tracking-tight mt-2 leading-snug\">\n              Subscribe to GFF Executive Briefings\n            </h3>\n            <p className=\"mt-2 text-[13px] text-white/50 font-light leading-relaxed\">\n              Receive confidential updates, theoretical breakthroughs, and pre-release whitepapers from our Singapore and India engineering centers directly in your inbox.\n            </p>\n          </div>\n\n          <form onSubmit={handleSubscribe} className=\"w-full lg:w-auto flex flex-col sm:flex-row gap-3 items-stretch sm:items-center relative z-10 shrink-0\">\n            {emailSubscribed ? (\n              <div className=\"flex items-center gap-2 bg-green-500/10 border border-green-500/20 text-green-400 px-6 py-3 rounded-full text-[12px] font-medium animate-fade-in\">\n                <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                </svg>\n                <span>Subscription Confirmed. Secured with AES-256.</span>\n              </div>\n            ) : (\n              <>\n                <input\n                  type=\"email\"\n                  placeholder=\"Enter corporate email...\"\n                  value={email}\n                  onChange={(e) => setEmail(e.target.value)}\n                  className=\"bg-black/50 border border-white/10 rounded-full px-5 py-3 text-[12px] text-white focus:outline-none focus:border-[#009DFF] w-full sm:w-[280px]\"\n                  required\n                />\n                <button\n                  type=\"submit\"\n                  className=\"px-6 py-3 rounded-full text-[12px] font-semibold text-white uppercase tracking-wider transition-all bg-[#009DFF] hover:bg-[#009DFF]/90 shrink-0\"\n                >\n                  Syndicate\n                </button>\n              </>\n            )}\n          </form>\n        </div>\n      </div>\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 py-12\">\n        <PremiumCTA\n          title=\"Looking for Specific Enterprise Reference Blueprints?\"\n          description=\"Schedule a technical deep dive with our lead architects to configure custom sandbox environments aligned with your sector's regulatory standards.\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
