3xl pointer-events-none\" />\n359 |           \n360 |           <div className=\"relative z-10 max-w-[1400px] mx-auto space-y-8\">\n361 |             <div className=\"flex flex-col lg:flex-row justify-between lg:items-end gap-4\">\n362 |               <div>\n363 |                 <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block mb-1\">\n364 |                   ENTERPRISE PROTOCOL PIPELINE\n365 |                 </span>\n366 |                 <h2 className=\"text-2xl lg:text-3xl font-bold text-white tracking-tight\">\n367 |                   The 9-Stage Sovereign Flow\n368 |                 </h2>\n369 |                 <p className=\"text-white/60 text-xs mt-1 max-w-[600px] font-light\">\n370 |                   Inspect the structured deployment milestones GFF AI utilizes to scope, configure, and operate air-gapped cognitive fleets.\n371 |                 </p>\n372 |               </div>\n373 |               <div className=\"text-xs font-mono text-[#009DFF] bg-[#009DFF]/10 px-3 py-1.5 rounded-full border border-[#009DFF]/20 self-start font-semibold\">\n374 |                 PHASE 0{activeStage.n}: {activeStage.name.toUpperCase()}\n375 |               </div>\n376 |             </div>\n377 | \n378 |             {/* Scrollable Timeline Row */}\n379 |             <div className=\"relative overflow-x-auto pb-4 scrollbar-none border-b border-white/5\">\n380 |               <div className=\"min-w-[940px] flex items-center justify-between relative px-2 py-4\">\n381 |                 <div className=\"absolute top-[38px] left-8 right-8 h-[2px] bg-white/5 z-0\" />\n382 |                 <div \n383 |                   className=\"absolute top-[38px] left-8 h-[2px] bg-gradient-to-r from-[#E4000F] to-[#009DFF] z-0 transition-all duration-500\" \n384 |                   style={{ width: `${((activeStage.n - 1) / 8) * 100}%` }} \n385 |                 />\n386 |                 \n387 |                 {JOURNEY.map((stg) => {\n388 |                   const act = activeStage.n === stg.n;\n389 |                   return (\n390 |                     <button \n391 |                       key={stg.n} \n392 |                       onClick={() => setActiveStage(stg)} \n393 |                       className=\"flex flex-col items-center relative z-10 group focus:outline-none w-[95px] shrink-0\"\n394 |                     >\n395 |                       <div className={`w-11 h-11 rounded-full border-2 flex items-center justify-center text-xs font-mono font-bold transition-all duration-300 ${\n396 |                         act \n397 |                           ? \"bg-black border-[#009DFF] text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.4)] scale-110\" \n398 |                           : stg.n < activeStage.n \n399 |                             ? \"bg-gradient-to-r from-[#E4000F] to-[#009DFF] border-transparent text-white\" \n400 |                             : \"bg-[#020202] border-white/10 text-white/40 group-hover:border-white/30\"\n401 |                       }`}>\n402 |                         {stg.n}\n403 |                       </div>\n404 |                       <span className={`text-[10px] mt-2.5 font-bold tracking-tight truncate w-full text-center transition-colors ${\n405 |                         act ? \"text-[#009DFF]\" : \"text-white/60 group-hover:text-white\"\n406 |                       }`}>\n407 |                         {stg.name}\n408 |                       </span>\n409 |                     </button>\n410 |                   );\n411 |                 })}\n412 |               </div>\n413 |             </div>\n414 | \n415 |             {/* Active Stage Details Panel */}\n416 |             <div className=\"min-h-[200px] relative\">\n417 |               <AnimatePresence mode=\"wait\">\n418 |                 <motion.div\n419 |                   key={activeStage.n}\n420 |                   initial={{ opacity: 0, x: 15 }}\n421 |                   animate={{ opacity: 1, x: 0 }}\n422 |                   exit={{ opacity: 0, x: -15 }}\n423 |                   transition={{ duration: 0.25, ease: \"easeInOut\" }}\n424 |                   className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 pt-4 w-full\"\n425 |                 >\n426 |                   <div className=\"lg:col-span-8 space-y-4\">\n427 |                     <div className=\"flex items-center gap-2 text-[11px] font-mono text-white/50\">\n428 |                       <span className=\"text-[#E4000F] font-bold\">PHASE 0{activeStage.n}</span>\n429 |                       <span>|</span>\n430 |                       <span className=\"text-[#00FF9D] font-semibold\">{activeStage.metric}</span>\n431 |                     </div>\n432 |                     <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">\n433 |                       {activeStage.name} Milestone Target\n434 |                     </h3>\n435 |                     <p className=\"text-white/70 text-xs leading-relaxed max-w-[720px] font-light\">\n436 |                       {activeStage.desc}\n437 |                     </p>\n438 |                     <div className=\"pt-2\">\n439 |                       <Link \n440 |                         href={activeStage.tool} \n441 |                         className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF]/30 transition group\"\n442 |                       >\n443 |                         <span>Launch {activeStage.btn} Helper</span>\n444 |                         <svg className=\"w-3 h-3 group-hover:translate-x-1 transition-transform text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n445 |                           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n446 |                         </svg>\n447 |                       </Link>\n448 |                     </div>\n449 |                