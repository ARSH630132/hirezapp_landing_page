rs: \"CIO\"\n270 |         },\n271 |         talk: {\n272 |           currentStep: 2,\n273 |           data: {\n274 |             desc: \"Legacy core banking orchestration with autonomous risk compliance nodes\",\n275 |             ind: \"Finance\",\n276 |             size: \"100-1000\",\n277 |             geography: \"North America\",\n278 |             urgency: \"immediate\",\n279 |             functionTeam: \"Compliance Auditing\",\n280 |             aiStage: \"Exploring\"\n281 |           },\n282 |           showResults: false\n283 |         },\n284 |         sandbox: {\n285 |           selectedIndustry: \"Banking\",\n286 |           selectedFunction: \"Knowledge Search\",\n287 |           selectedAgentType: \"Deep Reasoning / DAG\",\n288 |           searchQuery: \"reconciliation\",\n289 |           activeAgentId: \"knowledge-search\"\n290 |         },\n291 |         marketplace: {\n292 |           activeTab: \"All Patterns\",\n293 |           industryFilter: \"All Industries\",\n294 |           functionFilter: \"All Functions\",\n295 |           maturityFilter: \"All Stages\",\n296 |           platformFilter: \"All Fits\",\n297 |           searchQuery: \"Watchdog\",\n298 |           compareIds: [\"agent-01\", \"agent-02\"]\n299 |         },\n300 |         foundryStudio: {\n301 |           selectedPresetId: \"banking\",\n302 |           selectedPattern: \"hierarchical\",\n303 |           stages: [\n304 |             { id: \"node-0\", type: \"trigger\", label: \"Consensus Ledger Hook\", role: \"Sovereign Ingress\", latency: \"2ms\", isGated: false },\n305 |             { id: \"node-1\", type: \"reasoning\", label: \"Audit Verification Agent\", role: \"Verification Node\", latency: \"45ms\", isGated: false }\n306 |           ],\n307 |           knowledgeSources: [\"ledger_rules.pdf\", \"compliance_framework.txt\"]\n308 |         }\n309 |       };\n310 | \n311 |       localStorage.setItem(\"gff_local_workspace_continuity\", JSON.stringify(mockWorkspace));\n312 |   