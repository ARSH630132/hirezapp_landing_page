    title: \"Marketplace\",\n184 |     href: \"/build/marketplace\",\n185 |     desc: \"Browse and acquire pre-configured sovereign node recipes, certified third-party platform connectors, and core cognitive packages.\",\n186 |     cat: \"DEPLOYABLE REGISTRY\",\n187 |     accent: \"#EC4899\",\n188 |     output: \"Integration YAML Specs\",\n189 |     status: \"RELEASED\",\n190 |     icon: (\n191 |       <svg className=\"w-8 h-8 text-[#EC4899]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n192 |         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10\" />\n193 |       </svg>\n194 |     )\n195 |   },\n196 |   {\n197 |     title: \"Foundry Studio\",\n198 |     href: \"/build/foundry-studio\",\n199 |     desc: \"Visually assemble and edit production-grade multi-agent DAG execution layouts in our interactive workshop.\",\n200 |     cat: \"TOPOLOGY WORKSPACE\",\n201 |     accent: \"#10B981\",\n202 |     output: \"DAG Runtime Layout\",\n203 |     status: \"SIMULATOR ACTIVE\",\n204 |     icon: (\n205 |       <svg className=\"w-8 h-8 text-[#10B981]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n206 |         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m2-1v2.5M6 18l-2-1v2.5M18 18l2-1v2.5\" />\n207 |       </svg>\n208 |     )\n209 |   }\n210 | ];\n211 | \n212 | \n213 | \n214 | \n215 | export default function BuildHubPage() {\n216 |   const [activeStage, setActiveStage] = useState<Stage>(JOURNEY[1]); // Focus on AI Assessment initially\n217 |   const [activeScenarioIdx, setActiveScenarioIdx] = useState<number>(0);\n218 | \n219 |   // Local Workspace state checking\n220 |   const [workspace, setWorkspace] = useState<any>({});\