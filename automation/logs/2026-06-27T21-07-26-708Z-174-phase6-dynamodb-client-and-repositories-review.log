nce_status, \"entity_type\": \"AI_OPERATION\"\n182 |             })\n183 |             \n184 |         db_docs = db.query(DocumentItem).all()\n185 |         for d in db_docs:\n186 |             items.append({\n187 |                 \"PK\": f\"CLIENT#{d.client_id}\", \"SK\": f\"DOC#{d.id}\", \"GSI1PK\": f\"PROJ#{d.project_id or 1}\", \"GSI1SK\": f\"DOC#{d.id}\",\n188 |                 \"id\": d.id, \"client_id\": str(d.client_id), \"project_id\": d.project_id, \"title\": d.title, \"document_type\": d.document_type,\n189 |                 \"status\": d.status, \"version\": d.version, \"owner\": d.owner, \"visibility\": d.visibility, \"entity_type\": \"DOCUMENT\"\n190 |             })\n191 |             \n192 |         db_invs = db.query(Invoice).all()\n193 |         for i in db_invs:\n194 |             items.append({\n195 |                 \"PK\": f\"CLIENT#{i.client_id}\", \"SK\": f\"INV#{i.id}\", \"GSI1PK\": \"BILLING_PERIOD#2026_06\", \"GSI1SK\": f\"INV#{i.id}\",\n196 |                 \"id\": i.id, \"client_id\": str(i.client_id), \"project_id\": i.project_id, \"invoice_number\": i.invoice_number,\n197 |                 \"status\": i.status, \"amount\": i.amount, \"currency\": i.currency, \"entity_type\": \"INVOICE\"\n198 |             })\n199 |         db_tickets = db.query(SupportTicket).all()\n200 |         for t in db_tickets:\n201 |             items.append({\n202 |                 \"PK\": f\"CLIENT#{t.client_id}\", \"SK\": f\"TICKET#{t.id}\", \"GSI1PK\": f\"STATUS#{t.status.upper()}\", \"GSI1SK\": f\"TICKET#{t.id}\",\n203 |                 \"id\": t.id, \"client_id\": str(t.client_id), \"project_id\": t.project_id, \"title\": t.title, \"category\": t.category,\n204 |                 \"priority\": t.priority, \"status\": t.status, \"assigned_to\": t.assigned_to, \"created_by\": t.created_by,\n205 |                 \"description\": t.description, \"comments\": t.comments, \"entity_type\": \"SUPPORT\"\n206 |             })\n207 |             \n208 |         db_govs = db.query(GovernanceItem).all()\n209 |         for g in db_govs:\n210 |             items.append({\n211 |                 \"PK\": f\"CLIENT#{g.client_id}\", \"SK\": f\"GOV#{g.id}\", \"GSI1PK\": f\"STANDARD#EXTERNAL\", \"GSI1SK\": f\"GOV#{g.id}\",\n212 |                 \"id\": g.id, \"client_id\": str(g.client_id), \"project_id\": g.project_id, \"title\": g.title, \"severity\": g.severity,\n213 |                 \"status\": g.status, \"owner\": g.owner, \"description\": g.description, \"entity_type\": \"GOVERNANCE\"\n214 |             })\n215 |             \n216 |         if items:\n217 |             MOCK_DB[settings.DYNAMODB_ITEMS_TABLE] = items\n218 |             \n219 |         db.close()\n220 |     except Exception as e:\n221 |         logger.error(f\"Error syncing with SQLite: {e}\")\n222 | \n223 | ","success":true}],"durationMs":2}}
