 | \n438 |   // Register New Document Submit (POST metadata CRUD)\n439 |   const handleRegisterSubmit = async (e: React.FormEvent) => {\n440 |     e.preventDefault();\n441 |     if (!newTitle.trim()) return;\n442 | \n443 |     setLoading(true);\n444 |     try {\n445 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n446 |       const targetClientId = getClientIdFromClientName(newClient);\n447 | \n448 |       const res = await fetch(\"/api/v1/documents\", {\n449 |         method: \"POST\",\n450 |         headers: {\n451 |           \"Content-Type\": \"application/json\",\n452 |           \"Authorization\": `Bearer ${token}`\n453 |         },\n454 |         body: JSON.stringify({\n455 |           title: newTitle.trim(),\n456 |           client_id: targetClientId,\n457 |           project_id: newProject === \"UNASSIGNED\" ? \"\" : newProject,\n458 |           projectId: newProject === \"UNASSIGNED\" ? \"\" : newProject,\n459 |           document_type: newType,\n460 |           type: newType,\n461 |           status: newStatus,\n462 |           version: newVersion,\n463 |           owner: newOwner,\n464 |           description: newDesc || \"Custom compliance specification uploaded through interactive admin console.\",\n465 |           fileSize: newFileSize || \"1.0 MB\"\n466 |         })\n467 |       });\n468 |       const data = await res.json();\n469 |       if (data.success && data.document) {\n470 |         setIsRegisterModalOpen(false);\n471 |         showToast(`Document Registry expanded: Created ${data.document.id}`);\n472 |         setNewTitle(\"\");\n473 |         setNewDesc(\"\");\n474 |         setNewFileSize(\"1.5 MB\");\n475 |         setNewVersion(\"v1.0.0\");\n476 |         await fetchData();\n477 |       } else {\n478 |         showToast(`Failed to register document: ${data.message || \"Unknown error\"}`);\n479 |       }\n480 |     } catch (err) {\n481 |       showToast(`Error creating document in enclave registry.`);\n482 |     } finally {\n483 |       setLoading(false);\n484 |     }\n485 |   };\n486 | \n487 |   // Reset Filters helper\n488 |   const handleResetFilters = () => {\n489 |     setSearchQuery(\"\");\n490 |     setFilterClient(\"all\");\n491 |     setFilterProject(\"all\");\n492 |     setFilterType(\"all\");\n493 |     setFilterStatus(\"all\");\n494 |     setFilterOwner(\"all\");\n495 |     setFilterVersion(\"all\");\n496 |     showToast(\"Filtering workspace cleared. All registry objects displayed.\");\n497 |   };\n498 | \n499 |   // Delete document (DELETE CRUD)\n500 |   const handleDeleteDocument = async (id: string, title: string) => {\n501 |     if (confirm(`Deprovision document ${id} (\"${title}\") from administrative registry?`)) {\n502 |       setLoading(true);\n503 |       try {\n504 |         const token = localStorage.getItem(\"gff_ai_access_token\");\n505 |         const res = await fetch(`/api/v1/documents/${id}`, {\n506 |           method: \"DELETE\",\n507 |           headers: {\n508 |             \"Authorization\": `Bearer ${token}`\n509 |           }\n510 |         });\n511 |         const data = await res.json();\n512 |         if (data.success) {\n513 |           showToast(`Document ${id} unlinked and removed successfully.`);\n514 |           if (selectedDocId === id) setSelectedDocId(null);\n515 |           await fetchData();\n516 |         } else {\n517 |           showToast(`Failed to delete document: ${data.message || \"Unknown error\"}`);\n518 |         }\n519 |       } catch (err) {\n520 |         showToast(`Failed to communicate deprovisioning command.`);\n521 |       } finally {\n522 |         setLoading(false);\n523 |       }\n524 |     }\n525 |   };\n526 | \n527 |   // ==========================================\n528 |   // 5. QUERY FILTERING LOGIC\n529 |   // ==========================================\n530 |   const filteredDocuments = useMemo(() => {\n531 |     return documents.filter(doc => {\n532 |       const matchesSearch = \n533 |         doc.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\n534 |         doc.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n535 |         doc.sha256.toLowerCase().includes(searchQuery.toLowerCase()) ||\n536 |         doc.description.toLowerCase().includes(searchQuery.toLowerCase());\n537 | \n538 |       const matchesClient = filterClient === \"all\" || doc.client === filterClient;\n539 |       const matchesProject = filterProject === \"all\" || doc.projectId === filterProject;\n540 |       const matchesType = filterType === \"all\" || doc.type === filterType;\n541 |       const matchesStatus = filterStatus === \"all\" || doc.status === filterStatus;\n542 |       const matchesOwner = filterOwner === \"all\" || doc.owner === filterOwner;\n543 |       const matchesVersion = filterVersion === \"all\" || doc.version === filterVersion;\n544 | \n545 |       return (\n546 |         matchesSearch && \n547 |         matchesClient && \n548 |         matchesProject && \n549 |         matchesType && \n550 |         matchesStatus && \n551 |         matchesOwner && \n552 |         matchesVersion\n553 |       );\n554 |     });\n555 |   }, [\n556 |     documents, searchQuery, filterClient, filterProject, \n557 |     filterType, filterStatus, filterOwner, filterVersion\n558 |   ]);\n559 | \n560 |   const metrics = useMemo(() => {\n561 |     const totalCount = documents.length;\n562 |     const verifiedCount = documents.filter(d => d.status === \"Verified\").length;\n563 |     const unassignedCount = documents.filter(d => d.projectId === \"UNASSIGNED\").length;\n564 |     const integrityRate = totalCount > 0 ? ((verifiedCount / totalCount) * 100).toFixed(1) : \"100.0\";\n565 | \n566 |     return {\n567 |       totalCount,\n568 |       verifiedCount,\n569 |       unassignedCount,\n570 |       integrityRate\n571 |     };\n572 |   }, [documents]);\n573 | \n574 |   const hasActiveFilters = useMemo(() => {\n575 |     return (\n576 |       searchQuery !== \"\" ||\n577 |       filterClient !== \"all\" ||\n578 |       filterProject !== \"all\" ||\n579 |       filterType !== \"all\" ||\n580 |       filterStatus !== \"all\" ||\n581 |       filterOwner !== \"all\" ||\n582 |       filterVersion !== \"all\"\n583 |     );\n584 |   }, [searchQuery, filterClient, filterProject, filterType, filterStatus, filterOwner, filterVersion]);\n585 | \n586 |   const getStatusBadgeStyle = (status: string) => {\n587 |     switch (status) {\n588 |       case \"Verified\":\n589 |         return \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400\";\n590 |       case \"Under Review\":\n591 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-400\";\n592 |       case \"Action Required\":\n593 |         return \"border-rose-500/20 bg-rose-500/5 text-rose-400\";\n594 |       case \"Superseded\":\n595 |         return \"border-white/10 bg-white/5 text-white/50\";\n596 |       default:\n597 |         return \"border-white/15 bg-white/5 text-white/60\";\n598 |     }\n599 |   };\n600 | \n601 |   const getTypeBadgeStyle = (type: string) => {\n602 |     switch (type) {\n603 |       case \"PDF\":\n604 |         return \"border-indigo-500/20 bg-indigo-500/5 text-indigo-400\";\n605 |       case \"JSON\":\n606 |         return \"border-cyan-500/20 bg-cyan-500/5 text-cyan-400\";\n607 |       case \"YAML\":\n608 |         return \"border-purple-500/20 bg-purple-500/5 text-purple-400\";\n609 |       case \"XML\":\n610 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-500\";\n611 |       default:\n612 |         return \"border-white/10 text-white/60\";\n613 |     }\n614 |   };\n615 | \n616 |   return (\n617 |     <div className=\"space-y-6 relative min-h-screen pb-12 font-mono\">\n618 |       {/* ============================================================================ */}\n619 |       {/* HEADER SECTION */}\n620 |       {/* ============================================================================ */}\n621 |       <div className=\"flex flex-col md:flex