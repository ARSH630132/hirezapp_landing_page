px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n650 |           <div className=\"flex items-center justify-between\">\n651 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Vaulted Registries</span>\n652 |             <FileText className=\"w-4 h-4 text-[#009DFF]\" />\n653 |           </div>\n654 |           <div className=\"flex items-baseline gap-2 pt-1\">\n655 |             <span className=\"text-2xl font-bold text-white tracking-tight\">{metrics.totalCount}</span>\n656 |             <span className=\"text-[9px] text-[#00FFC2] font-bold bg-[#00FFC2]/5 border border-[#00FFC2]/15 px-1 rounded\">SECURE</span>\n657 |           </div>\n658 |           <div className=\"text-[9.5px] text-white/30 truncate\">Cryptographically sealed items</div>\n659 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#009DFF]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n660 |         </div>\n661 | \n662 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n663 |           <div className=\"flex items-center justify-between\">\n664 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Enclave Bound</span>\n665 |             <Layers className=\"w-4 h-4 text-[#00FFC2]\" />\n666 |           </div>\n667 |           <div className=\"flex items-baseline gap-2 pt-1\">\n668 |             <span className=\"text-2xl font-bold text-[#00FFC2] tracking-tight\">{metrics.totalCount - metrics.unassignedCount}</span>\n669 |             <span className=\"text-[9px] text-white/40 font-semibold\">MAPPED OBJECTS</span>\n670 |           </div>\n671 |           <div className=\"text-[9.5px] text-white/30 truncate\">Active alignment integrations</div>\n672 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#00FFC2]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n673 |         </div>\n674 | \n675 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n676 |           <div className=\"flex items-center justify-between\">\n677 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Verified Rate</span>\n678 |             <Cpu className=\"w-4 h-4 text-emerald-400\" />\n679 |           </div>\n680 |           <div className=\"flex items-baseline gap-2 pt-1\">\n681 |             <span className=\"text-2xl font-bold text-emerald-400 tracking-tight\">{metrics.integrityRate}%</span>\n682 |             <span className=\"text-[9px] text-emerald-400 bg-emerald-400/5 border border-emerald-400/20 px-1 rounded\">AUDITED</span>\n683 |           </div>\n684 |           <div className=\"text-[9.5px] text-white/30 truncate\">ISO-27001 checked standards</div>\n685 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-emerald-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n686 |         </div>\n687 | \n688 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n689 |           <div className=\"flex items-center justify-between\">\n690 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Unassigned Sandbox</span>\n691 |             <AlertTriangle className=\"w-4 h-4 text-amber-400\" />\n692 |           </div>\n693 |           <div className=\"flex items-baseline gap-2 pt-1\">\n694 |             <span className=\"text-2xl font-bold text-amber-400 tracking-tight\">{metrics.unassignedCount}</span>\n695 |             <span className=\"text-[9px] text-amber-400 bg-amber-400/5 border border-amber-400/25 px-1 rounded\">PENDING</span>\n696 |           </div>\n697 |           <div className=\"text-[9.5px] text-white/30 truncate\">Unmapped general registry files</div>\n698 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-amber-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n699 |         </div>\n700 |       </div>\n701 | \n702 |       {loading && documents.length === 0 && (\n703 |         <div className=\"flex flex-col items-center justify-center p-12 border border-white/5 rounded-xl bg-[#050505]/20 font-mono text-center\">\n704 |           <RefreshCw className=\"w-10 h-10 text-[#009DFF] mb-3 animate-spin\" />\n705 |           <h4 className=\"text-white text-sm font-bold uppercase tracking-wider\">Synchronizing Registry Vault...</h4>\n706 |           <p className=\"text-white/40 text-[11px] max-w-sm mt-1 leading-relaxed\">\n707 |             Establishing secure cryptographical tunnel to active enclave compliance indices. Please hold...\n708 |           </p>\n709 |         </div>\n710 |       )}\n711 | \n712 |       {error && (\n713 |         <div className=\"p-4 rounded-xl border border-rose-500/10 bg-rose-500/5 text-rose-400 text-xs font-mono flex items-center justify-between gap-3\">\n714 |           <div className=\"flex items-center gap-2\">\n715 |             <AlertTriangle className=\"w-4 h-4 text-rose-400 shrink-0\" />\n716 |             <span><strong>VAULT ERROR:</strong> {error}</span>\n717 |           </div>\n718 |           <button\n719 |             onClick={fetchData}\n720 |             className=\"px-3 h-7 rounded bg-rose-500/15 hover:bg-rose-500/25 border border-rose-500/20 text-[10px] text-white uppercase tracking-wider font-bold transition-all cursor-pointer\"\n721 |           >\n722 |             Retry Handshake\n723 |           </button>\n724 |         </div>\n725 |       )}\n726 | \n727 |       {/* ============================================================================ */}\n728 |       {/* SEARCH & DETAILED FILTER SYSTEM */}\n729 |       {/* ============================================================================ */}\n730 |       <div className=\"border border-white/5 rounded-xl bg-[#050505]/20 p-4 space-y-4\">\n731 |         {/* Search & Reset Row */}\n732 |         <div className=\"flex flex-col md:flex-row gap-3 items-stretch justify-between\">\n733 |           <div className=\"relative flex-1\">\n734 |             <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-white/30\" />\n735 |             <input\n736 |               type=\"text\"\n737 |               placeholder=\"Search registry by ID, title, SHA-256 hash, or technical specifications...\"\n738 |               value={searchQuery}\n739 |               onChange={(e) => setSearchQuery(e.target.value)}\n740 |               className=\"w-full h-9 pl-10 pr-4 rounded-lg border border-white/5 bg-white/[0.02] text-xs text-white outline-none focus:border-[#009DFF]/30 focus:bg-white/[0.03] transition-all\"\n741 |             />\n742 |             {searchQuery && (\n743 |               <button \n744 |                 onClick={() => setSearchQuery(\"\")}\n745 |                 className=\"absolute right-3 top-2.5 text-white/40 hover:text-white\"\n746 |               >\n747 |                 <X className=\"w-4 h-4\" />\n748 |               </button>\n749 |             )}\n750 |           </div>\n751 |           \n752 |           <div className=\"flex items-center gap-2\">\n753 |             {hasActiveFilters && (\n754 |               <button\n755 |                 onClick={handleResetFilters}\n756 |                 className=\"h-9 px-3 rounded-lg border border-white/10 hover:border-white/20 bg-white/5 text-[10.5px] text-w