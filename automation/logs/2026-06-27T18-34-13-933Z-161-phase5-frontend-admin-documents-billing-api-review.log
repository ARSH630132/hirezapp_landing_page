 throw new Error(docData.message || \"Failed to parse enclave document index.\");\n301 |         }\n302 |       } else {\n303 |         throw new Error(\"HTTP connection to document vault rejected.\");\n304 |       }\n305 |     } catch (err: any) {\n306 |       setError(err.message || \"Cryptographic registry sync failed.\");\n307 |     } finally {\n308 |       setLoading(false);\n309 |     }\n310 |   }, []);\n311 | \n312 |   useEffect(() => {\n313 |     fetchData();\n314 |   }, [fetchData]);\n315 | \n316 |   // Document registration form states\n317 |   const [newTitle, setNewTitle] = useState(\"\");\n318 |   const [newType, setNewType] = useState<\"PDF\" | \"JSON\" | \"YAML\" | \"XML\">(\"PDF\");\n319 |   const [newClient, setNewClient] = useState(CLIENTS[0]);\n320 |   const [newProject, setNewProject] = useState(\"UNASSIGNED\");\n321 |   const [newStatus, setNewStatus] = useState<\"Verified\" | \"Under Review\" | \"Action Required\">(\"Verified\");\n322 |   const [newOwner, setNewOwner] = useState(OWNERS[0]);\n323 |   const [newVersion, setNewVersion] = useState(\"v1.0.0\");\n324 |   const [newFileSize, setNewFileSize] = useState(\"1.5 MB\");\n325 |   const [newDesc, setNewDesc] = useState(\"\");\n326 | \n327 |   // Get active selected document details dynamically\n328 |   const selectedDoc = useMemo(() => {\n329 |     return documents.find(doc => doc.id === selectedDocId) || null;\n330 |   }, [documents, selectedDocId]);\n331 | \n332 |   // Sync re-assignment selector when selected document changes\n333 |   useEffect(() => {\n334 |     if (selectedDoc) {\n335 |       setAssigningProjectId(selectedDoc.projectId);\n336 |     }\n337 |   }, [selectedDoc]);\n338 | \n339 |   // Auto-dismiss toast\n340 |   useEffect(() => {\n341 |     if (toast.visible) {\n342 |       const timer = setTimeout(() => {\n343 |         setToast({ visible: false, message: \"\" });\n344 |       }, 3500);\n345 |       return () => clearTimeout(timer);\n346 |     }\n347 |   }, [toast]);\n348 | \n349 |   const showToast = (message: string) => {\n350 |     setToast({ visible: true, message });\n351 |   };\n352 | \n353 |   // ==========================================\n354 |   // 4. ACTION HANDLERS WITH BACKEND METADATA CRUD\n355 |   // ==========================================\n356 |   \n357 |   // Assign Document to Project (PATCH metadata)\n358 |   const handleAssignProject = async (docId: string, projectId: string) => {\n359 |     setLoading(true);\n360 |     try {\n361 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n362 |       const targetProj = projects.find(p => p.id === projectId);\n363 |       const targetClientId = targetProj && targetProj.id !== \"UNASSIGNED\" ? getClientIdFromClientName(targetProj.client) : undefined;\n364 | \n365 |       const res = await fetch(`/api/v1/documents/${docId}`, {\n366 |         method: \"PATCH\",\n367 |         headers: {\n368 |           \"Content-Type\": \"application/json\",\n369 |           \"Authorization\": `Bearer ${token}`\n370 |         },\n371 |         body: JSON.stringify({\n372 |           project_id: projectId === \"UNASSIGNED\" ? \"\" : projectId,\n373 |           projectId: projectId === \"UNASSIGNED\" ? \"\" : projectId,\n374 |           client_id: targetClientId\n375 |         })\n376 |       });\n377 |       const data = await res.json();\n378 |       if (data.success) {\n379 |         showToast(`Cryptographic association established: Document bound successfully.`);\n380 |         await fetchData();\n381 |       } else {\n382 |         showToast(`Failed to update project re-assignment: ${data.message || \"Unknown error\"}`);\n383 |       }\n384 |     } catch (err) {\n385 |       showToast(`Error communicating update with secure enclave.`);\n386 |     } finally {\n387 |       setLoading(false);\n388 |     }\n389 |   };\n390 | \n391 |   // Simulate secure administrator download (Audit Logs remain mock but logged)\n392 |   const handleSimulatedDownload = (docId: string, title: string) => {\n393 |     setDownloadingDocId(docId);\n394 |     setTimeout(() => {\n395 |       setDownloadingDocId(null);\n396 |       showToast(`Audit log registered: Secure admin transfer of \"${title}\" completed.`);\n397 |       alert(`[SECURE VAULT API] Administrator copy successfully transferred.\\n\\nDocument: ${title}\\nSHA-256 integrity checks completed over airgapped connection.`);\n398 |     }, 1500);\n399 |   };\n400 | \n401 |   // Toggle checklist inside drawer (PATCH metadata)\n402 |   const handleToggleCheck = async (docId: string, checkIndex: number) => {\n403 |     const doc = documents.find(d => d.id === docId);\n404 |     if (!doc) return;\n405 | \n406 |     const updatedChecks = [...doc.governanceChecks];\n407 |     updatedChecks[checkIndex] = {\n408 |       ...updatedChecks[checkIndex],\n409 |       checked: !updatedChecks[checkIndex].checked\n410 |     };\n411 | \n412 |     try {\n413 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n414 |       const res = await fetch(`/api/v1/documents/${docId}`, {\n415 |         method: \"PATCH\",\n416 |         headers: {\n417 |           \"Content-Type\": \"application/json\",\n418 |           \"Authorization\": `Bearer ${token}`\n419 |         },\n420 |         body: JSON.stringify({\n421 |           governanceChecks: updatedChecks\n422 |         })\n423 |       });\n424 |       const data = await res.json();\n425 |       if (data.success) {\n426 |         showToast(`Governance checklist updated. Audit state synchronized.`);\n427 |         setDocuments(prevDocs => \n428 |           prevDocs.map(d => d.id === docId ? { ...d, governanceChecks: updatedChecks } : d)\n429 |         );\n430 |       } else {\n431 |         showToast(`Failed to sync checklist: ${data.message || \"Unknown error\"}`);\n432 |       }\n433 |     } catch (err) {\n434 |       showToast(`Error syncing checklist with secure enclave.`);\n435 |     }\n436 |   };\n437 | \n438 |   // Register New Document Submit (POST metadata CRUD)\n439 |   const handleRegisterSubmit = async (e: React.FormEvent) => {\n440 |     e.preventDefault();\n441 |     if (!newTitle.trim()) return;\n442 | \n443 |     setLoading(true);\n444 |     try {\n445 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n446 |       const targetClientId = getClientIdFromClientName(newClient);\n447 | \n448 |       const res = await fetch(\"/api/v1/documents\", {\n449 |         method: \"POST\",\n450 |         headers: {\n451 |           \"Content-Type\": \"application/json\",\n452 |           \"Authorization\": `Bearer ${token}`\n453 |         },\n454 |         body: JSON.stringify({\n455 |           title: newTitle.trim(),\n456 |           client_id: targetClientId,\n457 |           project_id: newProject === \"UNASSIGNED\" ? \"\" : newProject,\n458 |           projectId: newProject === \"UNASSIGNED\" ? \"\" : newProject,\n459 |           document_type: newType,\n460 |           type: newType,\n461 |           status: newStatus,\n462 |           version: newVersion,\n463 |           owner: newOwner,\n464 |           description: newDesc || \"Custom compliance specification uploaded through interactive admin console.\",\n465 |           fileSize: newFileSize || \"1.0 MB\"\n466 |         })\n467 |       });\n468 |       const data = await res.json();\n469 |       if (data.success && data.document) {\n470 |         setIsRegisterModalOpen(false);\n471 |         showToast(`Document Registry expanded: Created ${data.document.id}`);\n472 |         setNewTitle(\"\");\n473 |         setNewDesc(\"\");\n474 |         setNewFileSize(\"1.5 MB\");\n475 |         setNewVersion(\"v1.0.0\");\n476 |         await fetchData();\n477 |       } else {\n478 |         showToast(`Failed to register document: ${data.message || \"Unknown error\"}`);\n479 |       }\n480 |     } catch (err) {\n481 |       showToast(`Error creating document in enclave registry.`);\n482 |     } finally {\n483 |       setLoading(false);\n484 |     }\n485 |   };\n486 | \n487 |   // Reset Filters helper\n488 |   const handleResetFilters = () => {\n489 |     setSearchQuery(\"\");\n490 |     setFilterClient(\"all\");\n491 |     setFilterProject(\"all\");\n492 |     setFilterType(\"all\");\n493 |     setFilterStatus(\"all\");\n494 |     setFilterOwner(\"all\");\n495 |     setFilterVersion(\"all\");\n496 |     showToast(\"Filtering workspace cleared. All registry objects displayed.\");\n497 |   };\n498 | \n499 |   // Delete document (DELETE CRUD)\n500 |   const handleDeleteDocument = async (id: string, title: string) => {\n501 |     if (confirm(`Deprovision document ${id} (\"${title}\") from administrative registry?`)) {\n502 |       setLoading(true);\n503 |       try {\n504 |         const token = localStorage.getItem(\"gff_ai_access_token\");\n505 |         const res = await fetch(`/api/v1/documents/${id}`, {\n506 |           method: \"DELETE\",\n507 |           headers: {\n508 |             \"Authorization\": `Bearer ${token}`\n509 |           }\n510 |         });\n511 |         const data = await res.json();\n512 |         if (data.success) {\n513 |           showToast(`Document ${id} unlinked and removed successfully.`);\n514 |           if (selectedDocId === id) setSelectedDocId(null);\n515 |           await fetchData();\n516 |         } else {\n517 |           showToast(`Failed to delete document: ${data.message || \"Unknown error\"}`);\n518 |         }\n519 |       } catch (err) {\n520 |         showToast(`Failed to communicate deprovisioning command.`);","success":true}],"durationMs":6}}
