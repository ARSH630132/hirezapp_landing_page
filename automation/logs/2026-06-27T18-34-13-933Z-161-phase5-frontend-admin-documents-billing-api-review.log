ull);\n339 | \n340 |   // Filter States\n341 |   const [searchQuery, setSearchQuery] = useState(\"\");\n342 |   const [selectedCategory, setSelectedCategory] = useState(\"\");\n343 |   const [selectedProject, setSelectedProject] = useState(\"\");\n344 |   const [selectedFormat, setSelectedFormat] = useState(\"\");\n345 |   const [selectedStatus, setSelectedStatus] = useState(\"\");\n346 |   \n347 |   const fetchDocuments = useCallback(async () => {\n348 |     setLoading(true);\n349 |     setError(null);\n350 |     try {\n351 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n352 |       if (!token) {\n353 |         setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n354 |         router.push(\"/portal/login\");\n355 |         return;\n356 |       }\n357 | \n358 |       const res = await fetch(\"/api/v1/documents\", {\n359 |         headers: {\n360 |           \"Authorization\": `Bearer ${token}`,\n361 |           \"Content-Type\": \"application/json\"\n362 |         }\n363 |       });\n364 | \n365 |       if (!res.ok) {\n366 |         throw new Error(`Enclave sync failed with status ${res.status}`);\n367 |       }\n368 | \n369 |       const data = await res.json();\n370 |       if (data.success && Array.isArray(data.documents)) {\n371 |         const mapped = data.documents.map((d: any) => mapApiDocToPortalDoc(d));\n372 |         setDocuments(mapped);\n373 |       } else {\n374 |         throw new Error(\"Handshake returned malformed enclave register.\");\n375 |       }\n376 |     } catch (err: any) {\n377 |       console.error(\"Error fetching documents:\", err);\n378 |       setError(err.message || \"Decentralized ledger handshake timed out.\");\n379 |     } finally {\n380 |       setLoading(false);\n381 |     }\n382 |   }, [router]);\n383 | \n384 |   useEffect(() => {\n385 |     fetchDocuments();\n386 |   }, [fetchDocuments]);\n387 | \n388 |   // Layout States\n389 |   const [layoutMode, setLayoutMode] = useState<\"grid\" | \"list\">(\"grid\");\n390 | \n391 |   // Drawer & Attestation Log States\n392 |   const [selectedDoc, setSelectedDoc] = useState<PortalDocument | null>(null);\n393 |   const [terminalLogs, setTerminalLogs] = useState<string[]>([]);\n394 |   const [isLogsSyncing, setIsLogsSyncing] = useState(false);\n395 |   const [copiedHash, setCopiedHash] = useState(false);\n396 | \n397 |   // Custom Toast Notification States\n398 |   const [toastMessage, setToastMessage] = useState<string | null>(null);\n399 |   const [toastType, setToastType] = useState<\"info\" | \"warning\" | \"success\" | null>(null);\n400 | \n401 |   // Trigger Toast Helper\n402 |   const showToast = (message: string, type: \"info\" | \"warning\" | \"success\" = \"info\") => {\n403 |     setToastMessage(message);\n404 |     setToastType(type);\n405 |   };\n406 | \n407 |   // Close Toast automatically after 3.5 seconds\n408 |   useEffect(() => {\n409 |     if (toastMessage) {\n410 |       const timer = setTimeout(() => {\n411 |         setToastMessage(null);\n412 |         setToastType(null);\n413 |       }, 3500);\n414 |       return () => clearTimeout(timer);\n415 |     }\n416 |   }, [toastMessage]);\n417 | \n418 |   // Terminal Handshake Log Simulator inside Drawer\n419 |   useEffect(() => {\n420 |     if (!selectedDoc) {\n421 |       setTerminalLogs([]);\n422 |       return;\n423 |     }\n424 | \n425 |     setIsLogsSyncing(true);\n426 |     setTerminalLogs([\n427 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n428 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n429 |     ]);\n430 | \n431 |     const logsArray = [\n432 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n433 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n434 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n435 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n436 |     ];\n437 | \n438 |     let timerIndex = 0;\n439 |     const interval = setInterval(() => {\n440 |       if (timerIndex < logsArray.length) {\n441 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n442 |         timerIndex++;\n443 |       } else {\n444 |         setIsLogsSyncing(false);\n445 |         clearInterval(interval);\n446 |       }\n447 |     }, 450);\n448 | \n449 |     return () => clearInterval(interval);\n450 |   }, [selectedDoc]);\n451 | \n452 |   // Copy Clipboard Helper\n453 |   const handleCopyHash = (text: string) => {\n454 |     navigator.clipboard.writeText(text);\n455 |     setCopiedHash(true);\n456 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n457 |     setTimeout(() => setCopiedHash(false), 1500);\n458 |   };\n459 | \n460 |   // Reset Filters Helper\n461 |   const handleResetFilters = () => {\n462 |     setSearchQuery(\"\");\n463 |     setSelectedCategory(\"\");\n464 |     setSelectedProject(\"\");\n465 |     setSelectedFormat(\"\");\n466 |     setSelectedStatus(\"\");\n467 |     showToast(\"All filters reset successfully.\", \"info\");\n468 |   };\n469 | \n470 |   // Simulated Actions\n471 |   const handleSimulatedDownload = (doc: PortalDocument) => {\n472 |     showToast(`DEMO SHIELD: File transfer blocked. '${doc.name}' cannot be downloaded in telemetry preview.`, \"warning\");\n473 |   };\n474 | \n475 |   const handleSimulatedUploadClick = () => {\n476 |     showToast(\"SECURE GATEWAY: Upload restricted. Local sandbox is currently in read-only audit mode.\", \"warning\");\n477 |   };\n478 | \n479 |   // Filtering Logic\n480 |   const filteredDocuments = documents.filter((doc) => {\n481 |     // 1. Text Search query (checks title, hash, id, owner)\n482 |     if (searchQuery.trim() !== \"\") {\n483 |       const query = searchQuery.toLowerCase();\n484 |       const matchText = \n485 |         doc.name.toLowerCase().includes(query) ||\n486 |         doc.id.toLowerCase().includes(query) ||\n487 |         doc.hash.toLowerCase().includes(query) ||\n488 |         doc.owner.toLowerCase().includes(query) ||\n489 |         doc.desc.toLowerCase().includes(query);\n490 |       if (!matchText) return false;\n491 |     }\n492 |     // 2. Category\n493 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n494 |     // 3. Related Project\n495 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n496 |     // 4. File Format (Type)\n497 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) return false;\n498 |     // 5. Status\n499 |     if (selectedStatus !== \"\" && doc.status !== selectedStatus) return false;\n500 | \n501 |     return true;\n502 |   });\n503 | \n504 |   // Calculate quick document statistics\n505 |   const totalSeals = documents.length;\n506 |   const activeSows = documents.filter(d => d.category === \"SOW\").length;\n507 |   const auditReports = documents.filter(d => d.category === \"Reports\" || d.category === \"Architecture\").length;\n508 |   const pendingReviews = documents.filter(d => d.status === \"Pending Review\" || d.status === \"In Review\").length;\n509 | \n510 |   const getStatusColor = (status: string) => {\n511 |     const s = status.toLowerCase();\n512 |     if (s === \"approved\" || s === \"signed\" || s === \"active\") return \"text-[#00FFC2] border-[#00FFC2]/20 bg-[#00FFC2]/5\";\n513 |     if (s === \"in review\" || s === \"pending review\") return \"text-amber-400 border-amber-400/20 bg-amber-400/5\";\n514 |     return \"text-white/40 border-white/10 bg-white/5\";\n515 |   };\n516 | \n517 |   const getFormatBadgeColor = (fmt: string) => {\n518 |     const f = fmt.toLowerCase();\n519 |     if (f === \"pdf\") return \"text-red-400 border-red-500/20 bg-red-500/5\";\n520 |     if (f === \"yaml\" || f === \"json\") return \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\";\n521 |     if (f === \"zip\") return \"text-indigo-400 border-indigo-500/20 bg-indigo-500/5\";\n522 |     return \"text-white/60 border-white/10 bg-white/5\";\n523 |   };\n524 | \n525 |   const hasActiveFilters = searchQuery !== \"\" || selectedCategory !== \"\" || selectedProject !== \"\" || selectedFormat !== \"\" || selectedStatus !== \"\";\n526 | \n527 |   return (\n528 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none relative\">\n529 |       \n530 |       {/* 1. TOAST NOTIFICATION WINDOW */}\n531 |       {toastMessage && (\n532 |         <div className=\"fixed bottom-20 lg:bottom-6 right-4 lg:right-6 z-50 animate-in fade-in slide-in-from-bottom duration-300\">\n533 |           <div className={`p-4 rounded-xl border backdrop-blur-xl shadow-2xl flex items-center gap-3 font-mono text-[12px] max-w-sm ${\n534 |             toastType === \"warning\" ? \"border-amber-500/30 bg-amber-950/70 text-amber-300\" :\n535 |             toastType === \"success\" ? \"border-[#00FFC2]/30 bg-black/80 text-[#00FFC2]\" :\n536 |             \"border-white/10 bg-black/80 text-white/80\"\n537 |           }`}>\n538 |             <Shield className={`w-4 h-4 shrink-0 ${\n539 |               toastType === \"warning\" ? \"text-amber-400\" :\n540 |               toastType === \"success\" ? \"text-[#00FFC2]\" :\n541 |               \"text-[#009DFF]\"\n542 |             }`} />\n543 |             <div>\n544 |               <span className=\"font-bold uppercase tracking-wider block text-[10px]\">\n545 |                 {toastType === \"warning\" ? \"SECURITY ALIGNMENT LOCK\" : toastType === \"success\" ? \"INTEGRITY ATTESTED\" : \"SYSTEM MESSAGE\"}\n546 |               </span>\n547 |               <p className=\"mt-0.5 font-sans leading-snug\">{toastMessage}</p>\n548 |             </div>\n549 |             <button onClick={() => setToastMessage(null)} className=\"p-0.5 text-white/40 hover:text-white rounded shrink-0 transition-colors ml-auto\">\n550 |               <X className=\"w-3.5 h-3.5\" />\n551 |             </button>\n552 |           </div>\n553 |         </div>\n554 |       )}\n555 | \n556 |       {/* 2. DEMO RESTRICTED BANNER */}\n557 |       <div className=\"border border-white/5 bg-[#050505]/30 rounded-xl px-4 py-3 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-mono text-[11px] backdrop-blur-sm\">\n558 |         <div className=\"flex items-center gap-2.5 text-white/50\">\n559 |           <Info className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n560 |           <span>\n561 |             <strong className=\"text-white/80\">AIRGAPPED DOCUMENT REPOSITORY:</strong> In alignment with SOC2 and ISO27001 policies, download and upload actions are cryptographically suspended inside client preview portals.\n562 |           </span>\n563 |         </div>\n564 |         <span className=\"text-[9.5px] text-[#009DFF] font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2.5 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n565 |           SECURE SIMULATION ACTIVE\n566 |         </span>\n567 |       </div>\n568 | \n569 |       {/* 3. BREADCRUMBED HEADER */}\n570 |       <PrivatePageHeader\n571 |         title=\"Document Repository & Seals\"\n572 |         desc=\"Access cryptographically sealed Master Service Agreements, Statements of Work, and Sovereign System Architecture Reports.\"\n573 |         badgeLabel=\"SECURE_VAULT_v2.6\"\n574 |         actions={\n575 |           <button \n576 |             onClick={handleSimulatedUploadClick}\n577 |             className=\"h-9 px-4 rounded border border-white/10 hover:border-[#009DFF]/30 hover:bg-[#009DFF]/5 text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-2 cursor-pointer bg-white/[0.01]\"\n578 |           >\n579 |             <UploadCloud className=\"w-4 h-4 text-[#009DFF]\" />\n580 |             <span>Upload Document</span>\n581 |           </button>\n582 |         }\n583 |       />\n584 | \n585 |       {/* 4. EXECUTIVE SUMMARY METRIC TILES */}\n586 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n587 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n588 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">CRYPTOGRAPHIC SEALS</span>\n589 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{totalSeals} <span className=\"text-white/20 text-sm font-sans font-normal\">Active</span></div>\n590 |           <span className=\"text-[10px] text-[#00FFC2] font-mono flex items-center gap-1\"><ShieldCheck className=\"w-3 h-3\" /> 100% Attested</span>\n591 |         </div>\n592 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n593 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">SOVEREIGN SOW CONTRACTS</span>\n594 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{activeSows} <span className=\"text-white/20 text-sm font-sans font-normal\">Stored</span></div>\n595 |           <span className=\"text-[10px] text-white/45 font-mono\">Executed and archived</span>\n596 |         </div>\n597 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n598 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">ATTESTED SYSTEM REPORTS</span>\n599 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{auditReports} <span className=\"text-white/20 text-sm font-sans font-normal\">Audits</span></div>\n600 |           <span className=\"text-[10px] text-[#009DFF] font-mono\">AMD SEV Topology Logs</span>\n601 |         </div>\n602 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n603 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">REVIEWS IN PROGRESS</span>\n604 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{pendingReviews} <span className=\"text-white/20 text-sm font-sans font-normal\">Pending</span></div>\n605 |           <span className=\"text-[10px] text-amber-400 font-mono\">Awaiting client signature</span>\n606 |         </div>\n607 |       </div>\n608 | \n609 |       {/* 5. MULTI-DIMENSIONAL SEARCH & FILTER BOARD */}\n610 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n611 |         <div className=\"flex flex-col xl:flex-row gap-4 justify-between items-stretch xl:items-center\">\n612 |           \n613 |           {/* Main Search Input */}\n614 |           <div className=\"relative flex-grow max-w-xl\">\n615 |             <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-white/30\" />\n616 |             <input \n617 |               type=\"text\" \n618 |               value={searchQuery} \n619 |               onChange={(e) => setSearchQuery(e.target.value)} \n620 |               placeholder=\"Search by title, security hash, owner, or details...\"\n621 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-10 pr-10 text-[12px] font-mono text-white placeholder-white/25 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n622 |             />\n623 |             {searchQuery && (\n624 |               <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-3.5 top-2.5 text-white/40 hover:text-white transition-colors\">\n625 |                 <X className=\"w-4 h-4\" />\n626 |               </button>\n627 |             )}\n628 |           </div>\n629 | \n630 |           {/* Controls Right Alignment: Layout Switch & Clear */}\n631 |           <div className=\"flex flex-wrap items-center gap-3 self-end xl:self-auto\">\n632 |             {hasActiveFilters && (\n633 |               <button \n634 |                 onClick={handleResetFilters}\n635 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-[11px] font-mono font-bold text-red-400 uppercase transition-all flex items-center gap-1.5 cursor-pointer\"\n636 |               >\n637 |                 <X className=\"w-3.5 h-3.5\" />\n638 |                 <span>Reset Filters</span>\n639 |               </button>\n640 |             )}\n641 | \n642 |             {/* Layout Toggler (Segmented Control style) */}\n643 |             <div className=\"flex items-center rounded-lg border border-white/5 p-1 bg-black/40\">\n644 |               <button \n645 |                 onClick={() => setLayoutMode(\"grid\")}\n646 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n647 |                   layoutMode === \"grid\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n648 |                 }`}\n649 |               >\n650 |                 <LayoutGrid className=\"w-3.5 h-3.5\" />\n651 |                 <span className=\"hidden sm:inline\">Bento Grid</span>\n652 |               </button>\n653 |               <button \n654 |                 onClick={() => setLayoutMode(\"list\")}\n655 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n656 |                   layoutMode === \"list\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n657 |                 }`}\n658 |               >\n659 |                 <List className=\"w-3.5 h-3.5\" />\n660 |                 <span className=\"hidden sm:inline\">Sovereign Ledger</span>\n661 |               </button>\n662 |             </div>\n663 | \n664 |           </div>\n665 |         </div>\n666 | \n667 |         {/* Dropdown Filters row */}\n668 |         <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 border-t border-white/5 pt-4\">\n669 |           \n670 |           {/* Category Dropdown */}\n671 |           <div className=\"space-y-1.5\">\n672 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Category</span>\n673 |             <div className=\"relative\">\n674 |               <select \n675 |                 value={selectedCategory} \n676 |                 onChange={(e) => setSelectedCategory(e.target.value)} \n677 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n678 |               >\n679 |                 <option value=\"\">ALL CATEGORIES</option>\n680 |                 {CATEGORIES.map(cat => <option key={cat} value={cat}>{cat}</option>)}\n681 |               </select>\n682 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n683 |             </div>\n684 |           </div>\n685 | \n686 |           {/* Project Dropdown */}\n687 |           <div className=\"space-y-1.5\">\n688 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Related Project</span>\n689 |             <div className=\"relative\">\n690 |               <select \n691 |                 value={selectedProject} \n692 |                 onChange={(e) => setSelectedProject(e.target.value)} \n693 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n694 |               >\n695 |                 <option value=\"\">ALL PROJECTS</option>\n696 |                 {PROJECTS.map(proj => <option key={proj} value={proj}>{proj}</option>)}\n697 |               </select>\n698 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n699 |             </div>\n700 |           </div>\n701 | \n702 |           {/* Format Dropdown */}\n703 |           <div className=\"space-y-1.5\">\n704 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Type / Format</span>\n705 |             <div className=\"relative\">\n706 |               <select \n707 |                 value={selectedFormat} \n708 |                 onChange={(e) => setSelectedFormat(e.target.value)} \n709 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n710 |               >\n711 |                 <option value=\"\">ALL FORMATS</option>\n712 |                 {FORMATS.map(fmt => <option key={fmt} value={fmt}>{fmt}</option>)}\n713 |               </select>\n714 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n715 |             </div>\n716 |           </div>\n717 | \n718 |           {/* Status Dropdown */}\n719 |           <div className=\"space-y-1.5\">\n720 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Approval Status</span>\n721 |             <div className=\"relative\">\n722 |               <select \n723 |                 value={selectedStatus} \n724 |                 onChange={(e) => setSelectedStatus(e.target.value)} \n725 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n726 |               >\n727 |                 <option value=\"\">ALL STATUSES</option>\n728 |                 {STATUSES.map(st => <option key={st} value={st}>{st}</option>)}\n729 |               </select>\n730 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n731 |             </div>\n732 |           </div>\n733 | \n734 |         </div>\n735 |       </div>\n736 | \n737 |       {/* 6. CONTENT VIEWS (CARD OR TABLE) */}\n738 |       {loading ? (\n739 |         <DocumentsSkeleton />\n740 |       ) : error ? (\n741 |         <DocumentsErrorState message={error} onRetry={fetchDocuments} />\n742 |       ) : filteredDocuments.length === 0 ? (\n743 |         \n744 |         /* Empty Search Results state */\n745 |         <div className=\"p-12 text-center rounded-2xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm max-w-xl mx-auto space-y-4\">\n746 |           <div className=\"p-4 rounded-full bg-white/[0.02] border border-white/5 inline-flex text-white/30\">\n747 |             <FolderOpen className=\"w-8 h-8\" />\n748 |           </div>\n749 |           <div className=\"space-y-1\">\n750 |             <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">No Cryptographic Seals Found</h3>\n751 |             <p className=\"text-[12.5px] text-white/40 max-w-sm mx-auto font-sans leading-relaxed\">\n752 |               Your multidimensional filter query did not match any active ledger documents or system architecture plans.\n753 |             </p>\n754 |           </div>\n755 |           <button \n756 |             onClick={handleResetFilters}\n757 |             className=\"h-9 px-4 rounded-lg bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase text-white transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)] inline-flex items-center gap-1.5\"\n758 |           >\n759 |             <RefreshCw className=\"w-3.5 h-3.5 animate-pulse\" />\n760 |             <span>Restore Master View</span>\n761 |           </button>\n762 |         </div>\n763 | \n764 |       ) : layoutMode === \"grid\" ? (\n765 |         \n766 |         /* A: BENTO GRID VIEW */\n767 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n768 |           {filteredDocuments.map((doc) => (\n769 |             <WorkspaceCard key={doc.id} className=\"flex flex-col h-[280px] justify-between border-white/[0.03] relative group hover:border-[#009DFF]/20 transition-all duration-300\">\n770 |               \n771 |               {/* Document Header details inside card */}\n772 |               <div className=\"space-y-3\">\n773 |                 <div className=\"flex justify-between items-start\">\n774 |                   <div className=\"flex items-center gap-2\">\n775 |                     <span className=\"text-[9px] font-mono font-bold bg-[#009DFF]/5 border border-[#009DFF]/20 text-[#009DFF] rounded px-1.5 py-0.5 uppercase\">\n776 |                       {doc.category}\n777 |                     </span>\n778 |                     <span className={`text-[9px] font-mono font-bold border rounded px-1.5 py-0.5 uppercase ${getStatusColor(doc.status)}`}>\n779 |                       {doc.status}\n780 |                     </span>\n781 |                   </div>\n782 |                   <span className={`text-[9px] font-mono font-bold border rounded px-1.5 py-0.5 ${getFormatBadgeColor(doc.format)}`}>\n783 |                     {doc.format}\n784 |                   </span>\n785 |                 </div>\n786 | \n787 |                 <div className=\"space-y-1\">\n788 |                   <h4 className=\"text-[13.5px] font-bold text-white tracking-tight group-hover:text-[#009DFF] transition-colors leading-snug line-clamp-2\">\n789 |                     {doc.name}\n790 |                   </h4>\n791 |                   <p className=\"text-[11.5px] text-white/40 font-sans line-clamp-2 leading-relaxed\">\n792 |                     {doc.desc}\n793 |                   </p>\n794 |                 </div>\n795 |               </div>\n796 | \n797 |               {/* Document footer & metadata specs inside card */}\n798 |               <div className=\"border-t border-white/5 pt-3 mt-4 space-y-3.5\">\n799 |                 <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/35\">\n800 |                   <div>\n801 |                     <span className=\"text-white/20 font-bold block text-[8px] uppercase\">OWNER / COMPLIANT</span>\n802 |                     <span className=\"text-white/60 truncate block mt-0.5\">{doc.owner}</span>\n803 |                   </div>\n804 |                   <div className=\"text-right\">\n805 |                     <span className=\"text-white/20 font-bold block text-[8px] uppercase\">VERSION / SIZE</span>\n806 |                     <span className=\"text-white/60 block mt-0.5\">{doc.version} ({doc.size})</span>\n807 |                   </div>\n808 |                 </div>\n809 | \n810 |                 <div className=\"grid grid-cols-2 gap-2\">\n811 |                   <button \n812 |                     onClick={() => setSelectedDoc(doc)}\n813 |                     className=\"h-8 rounded border border-white/5 hover:border-white/15 bg-white/[0.01] hover:bg-white/[0.03] text-[10.5px] font-mono font-bold text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n814 |                   >\n815 |                     <Eye className=\"w-3.5 h-3.5 text-white/50\" />\n816 |                     <span>METADATA</span>\n817 |          