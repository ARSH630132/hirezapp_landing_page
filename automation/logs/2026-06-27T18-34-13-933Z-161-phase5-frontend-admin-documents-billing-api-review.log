"Proposals\";\n226 |   } else if (titleLower.includes(\"sow\") || titleLower.includes(\"statement of work\") || titleLower.includes(\"contract\")) {\n227 |     category = \"SOW\";\n228 |   } else if (titleLower.includes(\"blueprint\") || titleLower.includes(\"architecture\") || titleLower.includes(\"topology\")) {\n229 |     category = \"Architecture\";\n230 |   } else if (titleLower.includes(\"ruleset\") || titleLower.includes(\"governance\") || titleLower.includes(\"directive\") || titleLower.includes(\"compliance\")) {\n231 |     category = \"Governance\";\n232 |   } else if (titleLower.includes(\"audit\") || titleLower.includes(\"report\")) {\n233 |     category = \"Reports\";\n234 |   } else if (titleLower.includes(\"invoice\") || titleLower.includes(\"billing\")) {\n235 |     category = \"Invoices\";\n236 |   } else if (titleLower.includes(\"meeting\") || titleLower.includes(\"notes\")) {\n237 |     category = \"Meeting Notes\";\n238 |   } else if (apiDoc.type === \"ZIP\" || titleLower.includes(\"asset\") || titleLower.includes(\"config\")) {\n239 |     category = \"Delivery Assets\";\n240 |   }\n241 | \n242 |   // Map status\n243 |   let status: any = \"Approved\";\n244 |   if (apiDoc.status === \"Verified\") {\n245 |     status = \"Approved\";\n246 |   } else if (apiDoc.status === \"Under Review\") {\n247 |     status = \"In Review\";\n248 |   } else if (apiDoc.status === \"Action Required\") {\n249 |     status = \"Pending Review\";\n250 |   } else if (apiDoc.status === \"Superseded\") {\n251 |     status = \"Archived\";\n252 |   } else {\n253 |     status = apiDoc.status || \"Approved\";\n254 |   }\n255 | \n256 |   return {\n257 |     id: apiDoc.id,\n258 |     name: apiDoc.title || apiDoc.name,\n259 |     category: category,\n260 |     format: format,\n261 |     size: apiDoc.fileSize || \"1.0 MB\",\n262 |     hash: apiDoc.sha256 || \"0xHASH\",\n263 |     uploadedAt: apiDoc.lastUpdated || new Date().toISOString(),\n264 |     project: apiDoc.client_name || \