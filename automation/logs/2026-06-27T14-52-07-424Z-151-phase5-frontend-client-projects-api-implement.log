next/server\";\n  2 | import { \n  3 |   API_MOCK_USERS, \n  4 |   API_MOCK_PROJECTS, \n  5 |   verifyJwt, \n  6 |   MockUserDbEntry, \n  7 |   ApiProject, \n  8 |   getNextProjectId, \n  9 |   getClientNameFromId, \n 10 |   getClientIdFromAssociation \n 11 | } from \"../../../../lib/api-auth\";\n 12 | \n 13 | export const runtime = \"nodejs\";\n 14 | \n 15 | function getAuthCaller(req: Request) {\n 16 |   const auth = req.headers.get(\"authorization\");\n 17 |   if (!auth?.startsWith(\"Bearer \")) {\n 18 |     return { status: 401, error: \"Unauthorized\", msg: \"Missing/malformed Authorization header.\" };\n 19 |   }\n 20 |   const decoded = verifyJwt(auth.substring(7));\n 21 |   if (!decoded?.email) {\n 22 |     return { status: 401, error: \"Unauthorized\", msg: \"Invalid/expired access token.\" };\n 23 |   }\n 24 |   const user = (API_MOCK_USERS as Record<string, MockUserDbEntry>)[decoded.email.toLowerCase().trim()];\n 25 |   if (!user) {\n 26 |     return { status: 401, error: \"Unauthorized\", msg: \"Authorized user not found.\" };\n 27 |   }\n 28 |   if (user.status === \"inactive\") {\n 29 |     return { status: 403, error: \"Forbidden\", msg: \"This account is inactive.\" };\n 30 |   }\n 31 |   return { caller: user };\n 32 | }\n 33 | \n 34 | export async function GET(req: Request) {\n 35 |   try {\n 36 |     const auth = getAuthCaller(req);\n 37 |     if (\"status\" in auth) {\n 38 |       return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n 39 |     }\n 40 |     const { caller } = auth;\n 41 | \n 42 |     const { searchParams } = new URL(req.url);\n 43 |     const clientIdFilter = searchParams.get(\"client_id\");\n 44 |     const phaseFilter = searchParams.get(\"phase\");\n 45 |     const statusFilter = searchParams.get(\"status\");\n 46 |     const healthFilter = searchParams.get(\"health\");\n 47 |     const ownerFilter = searchParams.get(\"owner\");\n 48 |     const searchQuery = searchParams.get(\"search\");\n 49 | \n 50 |     let projects = Object.values(API_MOCK_PROJECTS) as ApiProject[];\n 51 | \n 52 |     // RBAC policy logic\n 53 |     if (caller.role !== \"gff_admin\") {\n 54 |       const callerClientId = getClientIdFromAssociation(caller.clientAssociation);\n 55 |       projects = projects.filter(p => p.client_id === callerClientId);\n 56 | \n 57 |       // Enforce client boundaries\n 58 |       if (clientIdFilter && clientIdFilter !== callerClientId) {\n 59 |         return NextResponse.json(\n 60 |           { success: false, error: \"Forbidden\", message: \"Access denied to requested client's projects.\" },\n 61 |           { status: 403 }\n 62 |         );\n 63 |       }\n 64 |     } else {\n 65 |       // Admin filter\n 66 |       if (clientIdFilter) {\n 67 |         projects = projects.filter(p => p.client_id === clientIdFilter);\n 68 |       }\n 69 |     }\n 70 | \n 71 |     // Apply specific filters\n 72 |     if (phaseFilter) {\n 73 |       const q = phaseFilter.toLowerCase().trim();\n 74 |       projects = projects.filter(p => p.phase.toLowerCase().includes(q));\n 75 |     }\n 76 |     if (statusFilter) {\n 77 |       const q = statusFilter.toLowerCase().trim();\n 78 |       projects = projects.filter(p => p.status.toLowerCase().includes(q));\n 79 |     }\n 80 |     if (healthFilter) {\n 81 |       const q = healthFilter.toLowerCase().trim();\n 82 |       projects = projects.filter(p => p.health.toLowerCase().includes(q));\n 83 |     }\n 84 |     if (ownerFilter) {\n 85 |       const q = ownerFilter.toLowerCase().trim();\n 86 |       projects = projects.filter(p => p.owner.toLowerCase().includes(q));\n 87 |     }\n 88 |     if (searchQuery) {\n 89 |       const q = searchQuery.toLowerCase().trim();\n 90 |       projects = projects.filter(p => \n 91 |         p.name.toLowerCase().includes(q) || \n 92 |         p.desc.toLowerCase().includes(q) || \n 93 |         p.owner.toLowerCase().includes(q) ||\n 94 |         p.id.toLowerCase().includes(q)\n 95 |       );\n 96 |     }\n 97 | \n 98 |     return NextResponse.json({ success: true, projects });\n 99 |   } catch (err) {\n100 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n101 |   }\n102 | }\n103 | \n104 | export async function POST(req: Request) {\n105 |   try {\n106 |     const auth = getAuthCaller(req);\n107 |     if (\"status\" in auth) {\n108 |       return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n109 |     }\n110 |     const { caller } = auth;\n111 | \n112 |     // MVP constraints: admin create/update/archive only\n113 |     if (caller.role !== \"gff_admin\") {\n114 |       return NextResponse.json(\n115 |         { success: false, error: \"Forbidden\", message: \"Only administrators can create projects.\" },\n116 |         { status: 403 }\n117 |       );\n118 |     }\n119 | \n120 |     const body = await req.json().catch(() => null);\n121 |     if (!body) {\n122 |       return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid JSON body.\" }, { status: 400 });\n123 |     }\n124 | \n125 |     const { name, client_id, phase, status, health, owner, nodesCount, enclaveType, desc } = body;\n126 | \n127 |     if (!name || typeof name !== \"string\" || !name.trim()) {\n128 |       return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Missing or invalid 'name' field.\" }, { status: 400 });\n129 |     }\n130 | \n131 |     if (!client_id || typeof client_id !== \"string\" || !client_id.trim()) {\n132 |       return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Missing or invalid 'client_id' field.\" }, { status: 400 });\n133 |     }\n134 | \n135 |     const validClients = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n136 |     if (!validClients.includes(client_id)) {\n137 |       return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid 'client_id' specified.\" }, { status: 400 });\n138 |     }\n139 | \n140 |     const newProjId = getNextProjectId();\n141 |     const newProj: ApiProject = {\n142 |       id: newProjId,\n143 |       name: name.trim(),\n144 |       client_id: client_id,\n145 |       client_name: getClientNameFromId(client_id),\n146 |       phase: phase || \"Phase I: Planning\",\n147 |       status: status || \"active\",\n148 |       health: health || \"On Track\",\n149 |       owner: owner || caller.name,\n150 |       nodesCount: typeof nodesCount === \"number\" ? nodesCount : 1,\n151 |       enclaveType: enclaveType || \"Intel SGX\",\n152 |       desc: desc || \"\",\n153 |       lastUpdated: new Date().toISOString()\n154 |     };\n155 | \n156 |     (API_MOCK_PROJECTS as Record<string, ApiProject>)[newProjId] = newProj;\n157 | \n158 |     return NextResponse.json({ success: true, project: newProj }, { status: 201 });\n159 |   } catch (err) {\n160 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n161 |   }\n162 | }","success":true}],"durationMs":9}}
