 items-start font-mono text-[10px]\">\n397 |               <span className=\"text-white/45 uppercase tracking-wider\">AI Guardrails & Policies</span>\n398 |               <span className=\"text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20\">ACTIVE</span>\n399 |             </div>\n400 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n401 |               <div className=\"text-3xl font-bold text-white\">{policies.length}</div>\n402 |               <span className=\"text-[9.5px] text-white/40\">\n403 |                 {policies.filter(p => p.status === \"compliant\").length} Safe • {policies.filter(p => p.status !== \"compliant\").length} Alerts\n404 |               </span>\n405 |             </div>\n406 |           </WorkspaceCard>\n407 | \n408 |           <WorkspaceCard className={`flex flex-col justify-between h-[105px] transition-all ${pendingCount > 0 ? \"border-amber-500/20 bg-amber-500/[0.01]\" : \"\"}`}>\n409 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n410 |               <span className=\"text-white/45 uppercase tracking-wider\">Pending Interlocks</span>\n411 |               {pendingCount > 0 ? (\n412 |                 <span className=\"text-amber-400 bg-amber-400/10 px-1.5 py-0.5 rounded border border-amber-400/20 animate-pulse\">SIGN REQUIRED</span>\n413 |               ) : (\n414 |                 <span className=\"text-white/30\">ALL SIGNED</span>\n415 |               )}\n416 |             </div>\n417 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n418 |               <div className=\"text-3xl font-bold text-white\">{pendingCount}</div>\n419 |               <span className=\"text-[9.5px] text-white/40\">Awaiting client credentials</span>\n420 |             </div>\n421 |           </WorkspaceCard>\n422 |         </div>\n423 | \n424 |         {/* Dynamic Topology Flow Diagram */}\n425 |         <div className=\"lg:col-span-2\">\n426 |           <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n427 |             <style dangerouslySetInnerHTML={{ __html: `\n428 |               @keyframes flow { to { stroke-dashoffset: -20; } }\n429 |               .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n430 |             `}} />\n431 | \n432 |             <div className=\"flex-grow flex flex-col justify-between gap-4\">\n433 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n434 |                 <div className=\"flex items-center gap-1.5 font-mono text-[11px]\">\n435 |                   <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n436 |                   <span className=\"font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n437 |                 </div>\n438 |                 <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology</span>\n439 |               </div>\n440 | \n441 |               <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n442 |                 <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n443 |                   <svg className=\"w-full h-[2px] overflow-visible\">\n444 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n445 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n446 |                   </svg>\n447 |                 </div>\n448 | \n449 |                 {steps.map((st, idx) => {\n450 |                   const isActive = step === st.id;\n451 |                   const clr = \n452 |                     st.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n453 |                     st.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n454 |                     st.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n455 |                     st.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" : \"border-emerald-500/10 text-emerald-400\";\n456 |                   \n457 |                   const activeStyle = isActive \n458 |                     ? \"shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102\" \n459 |                     : \"bg-black/45 hover:border-white/10\";\n460 | \n461 |                   return (\n462 |                     <button \n463 |                       key={st.id} \n464 |                       onClick={() => setStep(st.id)}\n465 |                       className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${clr} ${activeStyle}`}\n466 |                     >\n467 |                       <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"}`}>\n468 |                         {st.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n469 |                         {st.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n470 |                         {st.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n471 |                         {st.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n472 |                         {st.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n473 |                       </div>\n474 |                       <div className=\"text-center font-mono select-none\">\n475 |                         <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n476 |                         <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">{st.id === \"step-1\" ? \"Ingress\" : st.id === \"step-2\" ? \"Guardrail\" : st.id === \"step-3\" ? \"Enclave\" : st.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}</span>\n477 |                       </div>\n478 |                     </button>\n479 |                   );\n480 |                 })}\n481 |               </div>\n482 |             </div>\n483 | \n484 |             {/* Node Telemetry Details card */}\n485 |             <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n486 |               {(() => {\n487 |                 const info = steps.find(s => s.id === step) || steps[0];\n488 |                 return (\n489 |                   <div className=\"space-y-3 h-full flex flex-col justify-between\">\n490 |                     <div className=\"space-y-1.5\">\n491 |                       <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">REALTIME METRICS</span>\n492 |                       <p className=\"text-white font-bold text-[11px] leading-tight\">{info.title}</p>\n493 |                       \n494 |                       <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n495 |                         <span className={`w-1 h-1 rounded-full ${step === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n496 |                         <span className=\"text-white/40\">Status:</span>\n497 |                         <span className={`font-bold ${step === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>{info.val}</span>\n498 |                       </div>\n499 |                       <p className=\"text-[10px] text-white/50 leading-normal pt-1\">{info.desc}</p>\n500 |                     </div>\n501 |                     \n502 |                     <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 select-none\">\n503 |                       <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n504 |                       <span>Mathematical boundary verified</span>\n505 |                     </div>\n506 |                   </div>\n507 |                 );\n508 |               })()}\n509 |             </div>\n510 | \n511 |           </div>\n512 |         </div>\n513 | \n514 |       </div>\n515 | \n516 |       {/* Dynamic Filters panel */}\n517 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#070707]/60 backdrop-blur-sm space-y-3 font-mono\">\n518 |         <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n519 |           <div className=\"flex items-center gap-1.5\">\n520 |             <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/50\" />\n521 |             <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Workspace Filters</h3>\n522 |           </div>\n523 |           {(selProj || selAgent || selStatus || selSeverity || search) && (\n524 |             <button onClick={resetAll} className=\"flex items-center gap-1 text-[10px] text-amber-500 hover:text-amber-400 cursor-pointer\">\n525 |               <RotateCcw className=\"w-3 h-3\" /> Reset Filters\n526 |             </button>\n527 |           )}\n528 |         </div>\n529 | \n530 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n531 |           \n532 |           <div>\n533 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Project Target</label>\n534 |             <select \n535 |               value={selProj} \n536 |               onChange={(e) => { setSelProj(e.target.value); triggerToast(\"Filter: Project target updated\", \"info\"); }}\n537 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n538 |             >\n539 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL PROJECTS</option>\n540 |               {projectOptions.map(p => <option key={p.id} value={p.id} className=\"bg-[#0c0c0c] text-white\">{p.name.toUpperCase()}</option>)}\n541 |             </select>\n542 |           </div>\n543 | \n544 |           <div>\n545 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Sovereign Agent</label>\n546 |             <select \n547 |               value={selAgent} \n548 |               onChange={(e) => { setSelAgent(e.target.value); triggerToast(\"Filter: Agent target updated\", \"info\"); }}\n549 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n550 |             >\n551 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL AGENTS</option>\n552 |               {agentOptions.map(a => <option key={a.id} value={a.id} className=\"bg-[#0c0c0c] text-white\">{a.name}</option>)}\n553 |             </select>\n554 |           </div>\n555 | \n556 |           <div>\n557 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Compliance State</label>\n558 |             <select \n559 |               value={selStatus} \n560 |               onChange={(e) => { setSelStatus(e.target.value); triggerToast(\"Filter: State updated\", \"info\"); }}\n561 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n562 |             >\n563 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL STATES</option>\n564 |               <option value=\"compliant\" className=\"bg-[#0c0c0c] text-green-400\">COMPLIANT</option>\n565 |               <option value=\"warning\" className=\"bg-[#0c0c0c] text-amber-400\">WARNING ALERT</option>\n566 |               <option value=\"critical\" className=\"bg-[#0c0c0c] text-red-400\">CRITICAL FAULT</option>\n567 |             </select>\n568 |           </div>\n569 | \n570 |           <div>\n571 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Risk Severity</label>\n572 |             <select \n573 |               value={selSeverity} \n574 |               onChange={(e) => { setSelSeverity(e.target.value); triggerToast(\"Filter: Severity updated\", \"info\"); }}\n575 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n576 |             >\n577 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL SEVERITIES</option>\n578 |               <option value=\"high\" className=\"bg-[#0c0c0c] text-red-400 font-bold\">HIGH RISK</option>\n579 |               <option value=\"medium\" className=\"bg-[#0c0c0c] text-amber-400\">MEDIUM RISK</option>\n580 |               <option value=\"low\" className=\"bg-[#0c0c0c] text-blue-400\">LOW RISK</option>\n581 |             </select>\n582 |           </div>\n583 | \n584 |           <div>\n585 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Log Search</label>\n586 |             <div className=\"relative\">\n587 |               <Search className=\"absolute left-2 top-2.5 w-3.5 h-3.5 text-white/35 font-mono\" />\n588 |               <input \n589 |                 type=\"text\" \n590 |                 value={search} \n591 |                 onChange={(e) => setSearch(e.target.value)}\n592 |                 placeholder=\"Search rule standard or ID...\"\n593 |                 className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] pl-7.5 pr-7 text-[10.5px] text-white outline-none focus:border-white/10\"\n594 |               />\n595 |               {search && <X className=\"absolute right-2 top-2.5 w-3.5 h-3.5 text-white/40 cursor-pointer font-mono\" onClick={() => setSearch(\"\")} />}\n596 |             </div>\n597 |           </div>\n598 | \n599 |         </div>\n600 |       </div>\n601 | \n602 |       {/* Tabs list */}\n603 |       <div className=\"space-y-4 font-mono\">\n604 |         <div className=\"flex border-b border-white/5 gap-6 select-none text-xs\">\n605 |           <button onClick={() => setTab(\"pols\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"pols\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n606 |             <span>AI Checks & Policies</span>\n607 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredPols.length}</span>\n608 |             {tab === \"pols\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n609 |           </button>\n610 |           \n611 |           <button onClick={() => setTab(\"oversight\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"oversight\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n612 |             <span>Human Oversight Interlocks</span>\n613 |             <span className={`px-1 rounded text-[9px] ${pendingCount > 0 ? \"bg-amber-400/10 text-amber-500\" : \"bg-white/5 text-white/50\"}`}>{filteredOversights.length}</span>\n614 |             {tab === \"oversight\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n615 |           </button>\n616 | \n617 |           <button onClick={() => setTab(\"docs\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"docs\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n618 |             <span>Document Ledger</span>\n619 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredDocs.length}</span>\n620 |             {tab === \"docs\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n621 |           </button>\n622 |         </div>\n623 | \n624 |         {/* Tab interiors */}\n625 |         <div className=\"space-y-3 font-mono\">\n626 |           \n627 |           {tab === \"pols\" && (\n628 |             <div className=\"space-y-3\">\n629 |               {filteredPols.length === 0 ? (\n630 |                 <div className=\"p-10 border border-dashed border-white/5 rounded-2xl text-center max-w-md mx-auto space-y-2\">\n631 |                   <ShieldAlert className=\"w-6 h-6 text-white/20 mx-auto\" />\n632 |                   <p className=\"text-white font-bold text-xs\">NO POLICIES MATCH FILTERS</p>\n633 |                   <p className=\"text-white/40 text-[10px]\">Try adjusting your active workspace filters.</p>\n634 |                 </div>\n635 |               ) : (\n636 |                 filteredPols.map(policy => {\n637 |                   const isExp = expId === policy.id;\n638 |                   return (\n639 |                     <div key={policy.id} className={`rounded-xl border transition-all ${isExp ? \"border-white/10 bg-white/[0.02]\" : \"border-white/5 bg-[#050505]/20\"}`}>\n640 |                       <div onClick={() => setExpId(isExp ? null : policy.id)} className=\"p-3.5 flex items-center justify-between gap-3 cursor-pointer text-xs select-none\">\n641 |                         <div className=\"flex items-center gap-2.5 min-w-0\">\n642 |                           {policy.status === \"compliant\" ? <CheckCircle className=\"w-4 h-4 text-[#00FFC2] shrink-0\" /> : policy.status === \"warning\" ? <AlertCircle className=\"w-4 h-4 text-amber-400 shrink-0\" /> : <ShieldAlert className=\"w-4 h-4 text-red-400 shrink-0\" />}\n643 |                           <div className=\"min-w-0\">\n644 |                             <div className=\"flex items-center gap-1.5 flex-wrap\">\n645 |                           