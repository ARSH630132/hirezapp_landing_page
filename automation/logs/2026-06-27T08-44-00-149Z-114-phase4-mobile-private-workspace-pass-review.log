sandboxed and transient.\"\n578 |               badge=\"DATA SOVEREIGNTY\"\n579 |               icon={<Database className=\"w-5 h-5 text-purple-400\" />}\n580 |               glowColor=\"purple\"\n581 |               metric={{ value: \"AES-256\", label: \"ENVELOPED ENCRYPTION\" }}\n582 |             />\n583 |           </BentoGrid>\n584 |         </div>\n585 |       </section>\n586 | \n587 |       {/* 6. PREMIUM CALL TO ACTION */}\n588 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 py-16\">\n589 |         <div className=\"w-full rounded-[24px] border border-white/5 bg-gradient-to-br from-[#0c0c0f] to-[#040405] p-8 sm:p-12 lg:p-16 relative overflow-hidden group text-center space-y-6\">\n590 |           <div className=\"absolute top-0 left-1/4 w-80 h-80 rounded-full bg-[#009DFF]/5 blur-[100px] pointer-events-none\" />\n591 |           <div className=\"absolute bottom-0 right-1/4 w-80 h-80 rounded-full bg-[#E4000F]/3 blur-[100px] pointer-events-none\" />\n592 |           \n593 |           <span className=\"inline-flex px-3 py-1 text-[11px] font-bold tracking-[0.12em] text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 rounded-full uppercase\">\n594 |             AUDIT ENCLAVE ACCESS\n595 |           </span>\n596 | \n597 |           <h2 className=\"text-[32px] sm:text-[46px] lg:text-[54px] font-bold text-white tracking-tight leading-none max-w-[800px] mx-auto\">\n598 |             Ready to Begin Sovereign Simulation?\n599 |           </h2>\n600 | \n601 |           <p className=\"text-[14px] sm:text-[16px] text-white/60 font-light max-w-[620px] mx-auto leading-relaxed font-sans\">\n602 |             If you are an authorized partner representative or executive board auditor, launch our secure sandbox gateway to simulate active workspaces.\n603 |           </p>\n604 | \n605 |           <div className=\"flex justify-center pt-4\">\n606 |             <Link \n607 |               href=\"/portal/login\"\n608 |               className=\"group relative h-12 px