ransition-colors ${\n173 |                           isActive \n174 |                             ? \"border-[#009DFF]/30 bg-[#009DFF]/10 text-[#009DFF]\" \n175 |                             : \"border-white/5 bg-white/[0.01] text-white/40 group-hover:text-white\"\n176 |                         }`}>\n177 |                           <IconComp className=\"w-4 h-4\" />\n178 |                         </div>\n179 |                         <span className=\"text-[13px] font-medium uppercase tracking-wider truncate\">{mod.name}</span>\n180 |                       </div>\n181 |                       <ChevronRight className={`w-4 h-4 shrink-0 transition-transform ${\n182 |                         isActive ? \"text-[#009DFF] translate-x-0.5\" : \"text-white/10 group-hover:text-white/30\"\n183 |                       }`} />\n184 |                     </button>\n185 |                   );\n186 |                 })}\n187 |               </div>\n188 |             </div>\n189 | \n190 |             {/* Right preview terminal screen */}\n191 |             <div className=\"lg:col-span-8\">\n192 |               <div className=\"w-full rounded-2xl border border-white/10 bg-[#050507]/90 shadow-[0_15px_50px_rgba(0,0,0,0.8)] overflow-hidden\">\n193 |                 \n194 |                 {/* Header controls bar */}\n195 |                 <div className=\"bg-[#0b0b0f] border-b border-white/5 px-4 py-3.5 flex items-center justify-between\">\n196 |                   <div className=\"flex items-center gap-1.5\">\n197 |                     <span className=\"w-2.5 h-2.5 rounded-full bg-[#E4000F]/60\" />\n198 |                     <span className=\"w-2.5 h-2.5 rounded-full bg-amber-500/60\" />\n199 |                     <span className=\"w-2.5 h-2.5 rounded-full bg-emerald-500/60\" />\n200 |                     <span className=\"text-[10px] font-mono text-white/40 ml-3 truncate select-none\">\n201 |                       gff-gateway://secure-enclave/workspace/{activeModule.id}\n202 |                     </span>\n203 |                   </div>\n204 |                   <div className=\"flex items-center gap-2\">\n205 |                     <span className=\"text-[9px] font-mono text-white/30 uppercase tracking-widest hidden sm:inline\">SHA-256 COMPLIANT</span>\n206 |                     <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n207 |                   </div>\n208 |                 </div>\n209 | \n210 |                 {/* Content */}\n211 |                 <div className=\"p-6 sm:p-8 space-y-6\">\n212 |                   \n213 |                   {/* Module Title row */}\n214 |                   <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-6\">\n215 |                     <div>\n216 |                       <span className=\"text-[10px] font-mono font-bold tracking-[0.1em] text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2.5 py-0.5 rounded uppercase\">\n217 |                         {activeModule.tag}\n218 |                       </span>\n219 |                       <h3 className=\"text-[20px] sm:text-[24px] font-bold text-white tracking-tight mt-3\">\n220 |                         {activeModule.title}\n221 |                       </h3>\n222 |                       <p className=\"text-[13px] text-white/60 font-light mt-1 max-w-[580px] leading-relaxed font-sans\">\n223 |                         {activeModule.description}\n224 |                       </p>\n225 |                     </div>\n226 | \n227 |                     <Link \n228 |                       href=\"/portal/login\" \n229 |                       className=\"shrink-0 self-start sm:self-center px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-xl text-[11px] font-mono font-bold text-white uppercase tracking-wider flex items-center gap-1.5 transition-colors group\"\n230 |                     >\n231 |                       <span>Simulate Access</span>\