                         <span className=\"text-[12.5px] text-white font-semibold mt-0.5 truncate\">{spec.value}</span>\n259 |                           </div>\n260 |                         ))}\n261 |                       </div>\n262 |                     </div>\n263 |                   </div>\n264 | \n265 |                   {/* CUSTOM WORKSPACE MOCK DEMOS */}\n266 |                   <div className=\"border border-white/5 bg-black/20 rounded-xl p-5 relative overflow-hidden\">\n267 |                     <span className=\"text-[9.5px] font-mono font-bold text-white/30 uppercase tracking-wider block mb-4\">Workspace Sandbox Preview</span>\n268 |                     \n269 |                     {activeModule.id === \"dashboard\" && (\n270 |                       <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-4 pt-1\">\n271 |                         <div className=\"p-3.5 rounded-lg border border-white/5 bg-white/[0.01] flex items-center gap-3\">\n272 |                           <Activity className=\"w-5 h-5 text-emerald-400 animate-pulse\" />\n273 |                           <div>\n274 |                             <span className=\"block text-[10px] text-white/40 uppercase font-mono\">Kernel Core</span>\n275 |                             <span className=\"text-[13px] font-bold text-white font-mono\">NOMINAL UPTIME</span>\n276 |                           </div>\n277 |                         </div>\n278 |                         <div className=\"p-3.5 rounded-lg border border-white/5 bg-white/[0.01] flex items-center gap-3\">\n279 |                           <Lock className=\"w-5 h-5 text-[#009DFF]\" />\n280 |                           <div>\n281 |                             <span className=\"block text-[10px] text-white/40 uppercase font-mono\">Socket State</span>\n282 |                             <span className=\"text-[13px] font-bold text-white font-mono\">ENCRYPTED</span>\n283 |                           </div>\n284 |                         </div>\n285 |                         <div className=\"p-3.5 rounded-lg border border-white/5 bg-white/[0.01] flex items-center gap-3\">\n286 |                           <Cpu className=\"w-5 h-5 text-[#E4000F]\" />\n287 |                           <div>\n288 |                             <span className=\"block text-[10px] text-white/40 uppercase font-mono\">Enclave Link</span>\n289 |                             <span className=\"text-[13px] font-bold text-white font-mono\">3 LIVE CLUSTERS</span>\n290 |                           </div>\n291 |                         </div>\n292 |                       </div>\n293 |                     )}\n294 | \n295 |                     {activeModule.id === \"projects\" && (\n296 |                       <div className=\"space-y-3.5 pt-1\">\n297 |                         {[\n298 |                           { name: \"Accounting Ledger Auditor Enclave\", status: \"84% Complied\", color: \"bg-[#009DFF]\" },\n299 |                           { name: \"Legal Document Redactor Engine\", status: \"62% Parsed\", color: \"bg-purple-500\" },\n300 |                           { name: \"Strategic Intelligence Index Tracker\", status: \"ACTIVE\", color: \"bg-emerald-400\" }\n301 |                         ].map((proj, i) => (\n302 |                           <div key={i} className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2 p-3 border border-white/5 rounded-lg bg-white/[0.01]\">\n303 |                             <span className=\"text-[12px] font-bold text-white truncate font-sans\">{proj.name}</span>\n304 |                             <div className=\"flex items-center gap-3 shrink-0\">\n305 |                               <span className=\"text-[10px] font-mono text-white/50\">{proj.status}</span>\n306 |                               <div className=\"w-16 h-1.5 rounded-full bg-white/5 overflow-hidden\">\n307 |                                 <div className={`h-full ${proj.color}`} style={{ width: proj.status.includes(\"%\") ? proj.status.split(\"%\")[0] + \"%\" : \"100%\" }} />\n308 |                               </div>\n309 |                             </div>\n310 |                           </div>\n311 |                         ))}\n312 |                       </div>\n313 |                     )}\n314 | \n315 |                     {activeModule.id === \"billing\" && (\n316 |                       <div className=\"overflow-x-auto pt-1\">\n317 |                         <table className=\"w-full text-left font-mono text-[11px] text-white/60\">\n318 |                           <thead>\n319 |                             <tr className=\"border-b border-white/5 text-white/40 text-[9px] uppercase\">\n320 |                               <th className=\"pb-2\">COMPUTATION ENGINE</th>\n321 |                               <th className=\"pb-2\">ALLOCATION QUANTITY</th>\n322 |                               <th className=\"pb-2 text-right\">EPOCH RATE</th>\n323 |                             </tr>\n324 |                           </thead>\n325 |                           <tbody>\n326 |                             <tr className=\"border-b border-white/5\">\n327 |                               <td className=\"py-2 text-white\">Llama-3-70B Prompt Pipeline</td>\n328 |                               <td className=\"py-2\">1,248,391 Tokens</td>\n329 |                               <td className=\"py-2 text-right text-white font-bold\">$12.48</td>\n330 |                             </tr>\n331 |                             <tr className=\"border-b border-white/5\">\n332 |                               <td className=\"py-2 text-white\">Isolated Hypervisor Sandbox Compute</td>\n333 |                               <td className=\"py-2\">14.5 Enclave Hours</td>\n334 |                               <td className=\"py-2 text-right text-white font-bold\">$29.00</td>\n335 |                             </tr>\n336 |                             <tr>\n337 |                               <td className=\"py-2 text-white\">Zero-Trust Memory Sync Pathways</td>\n338 |                               <td className=\"py-2\">Unlimited Syncs</td>\n339 |                               <td className=\"py-2 text-right text-emerald-400 font-bold\">SLA INCLUDED</td>\n340 |                             </tr>\n341 |                           </tbody>\n342 |                         </table>\n343 |                       </div>\n344 |                     )}\n345 | \n346 |                     {activeModule.id === \"support\" && (\n347 |                       <div className=\"space-y-3 pt-1\">\n348 |                         <div className=\"p-3 rounded-lg border border-white/5 bg-white/[0.01] max-w-[85%]\">\n349 |                           <span className=\"block text-[8px] font-mono text-[#009DFF] mb-1\">CLIENT AUDITOR [08:04:12]</span>\n350 |                           <p className=\"text-[11.5px] text-white/80 leading-relaxed font-sans\">We noticed an error in validating custom tools execution constraints on the eBPF sandbox interface. Please advise on policy settings.</p>\n351 |                         </div>\n352 |                         <div className=\"p-3 rounded-lg border border-[#E4000F]/10 bg-[#E4000F]/5 max-w-[85%] ml-auto text-right\">\n353 |                           <span className=\"block text-[8px] font-mono text-[#E4000F] mb-1\">GFF LEVEL IV OPERATOR [08:06:45]</span>\n354 |                           <p className=\"text-[11.5px] text-white/80 leading-relaxed font-sans text-left sm:text-right\">Acknowledge. We have successfully adjusted the eBPF hypervisor memory bounds. The policy mismatch is cleared. Reload to sync.</p>\n355 |                         </div>\n356 |                       </div>\n357 |                     )}\n358 | \n359 |                     {activeModule.id === \"documents\" && (\n360 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3 pt-1\">\n361 |                         {[\n362 |                           { name: \"GFF_AI_Sovereign_Blueprint_v4.2.