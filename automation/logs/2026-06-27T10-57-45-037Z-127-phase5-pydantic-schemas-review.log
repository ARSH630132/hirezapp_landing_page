{"ts":"2026-06-27T10:56:47.485Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"bjbvaf67","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/test_schemas_instantiation.py","new_text":"import sys\nfrom datetime import datetime\nfrom pydantic import BaseModel\n\n# Insert backend directory into path to allow imports of app\nsys.path.insert(0, './backend')\n\nfrom app.schemas.auth import LoginRequest, TokenResponse, CurrentUserResponse\nfrom app.schemas.user import UserCreate, UserUpdate, UserResponse\nfrom app.schemas.client_account import ClientAccountCreate, ClientAccountUpdate, ClientAccountResponse\nfrom app.schemas.project import ProjectCreate, ProjectUpdate, ProjectResponse\nfrom app.schemas.agent_operation import AgentOperationCreate, AgentOperationUpdate, AgentOperationResponse\nfrom app.schemas.document_item import DocumentItemCreate, DocumentItemUpdate, DocumentItemResponse\nfrom app.schemas.invoice import InvoiceCreate, InvoiceUpdate, InvoiceResponse\nfrom app.schemas.support_ticket import SupportTicketCreate, SupportTicketUpdate, SupportTicketResponse\nfrom app.schemas.governance_item import GovernanceItemCreate, GovernanceItemUpdate, GovernanceItemResponse\nfrom app.schemas.system_log import SystemLogCreate, SystemLogResponse\n\n\nclass MockORMObject:\n    \"\"\"A dummy class to simulate SQLAlchemy model instances for testing from_attributes = True.\"\"\"\n    def __init__(self, **kwargs):\n        for k, v in kwargs.items():\n            setattr(self, k, v)\n\n\ndef test_schema_instantiation():\n    print(\"Starting schema validation & instantiation tests...\\n\")\n\n    now = datetime.utcnow()\n\n    # 1. Auth Schemas\n    print(\"Testing Auth Schemas...\")\n    login_req = LoginRequest(email=\"test@gff.ai\", password=\"securepassword\")\n    token_resp = TokenResponse(access_token=\"fake-jwt-token\", role=\"gff_admin\")\n    current_user_resp = CurrentUserResponse(\n        id=1,\n        email=\"admin@gff.ai\",\n        name=\"Admin\",\n        full_name=\"GFF Admin\",\n        role=\"gff_admin\",\n        client_id=None,\n        status=\"active\",\n        is_active=True,\n        created_at=now,\n        updated_at=now\n    )\n    print(\"Auth schemas successfully instantiated.\")\n\n    # 2. User Schemas\n    print(\"Testing User Schemas...\")\n    user_create = UserCreate(email=\"user@gff.ai\", name=\"Test User\", password=\"password123\")\n    user_update = UserUpdate(role=\"client_admin\", status=\"active\")\n    \n    # Test from_attributes\n    mock_user_orm = MockORMObject(\n        id=1,\n        email=\"user@gff.ai\",\n        name=\"Test User\",\n        full_name=\"Test User Full\",\n        role=\"client_member\",\n        status=\"active\",\n        is_active=True,\n        client_id=10,\n        created_at=now,\n        updated_at=now\n    )\n    user_resp = UserResponse.model_validate(mock_user_orm)\n    assert user_resp.id == 1\n    assert user_resp.email == \"user@gff.ai\"\n    print(\"User schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 3. Client Account Schemas\n    print(\"Testing Client Account Schemas...\")\n    client_create = ClientAccountCreate(name=\"Enterprise Corp\", industry=\"Technology\", region=\"US-East\")\n    client_update = ClientAccountUpdate(status=\"inactive\")\n    mock_client_orm = MockORMObject(\n        id=10,\n        name=\"Enterprise Corp\",\n        industry=\"Technology\",\n        region=\"US-East\",\n        status=\"active\",\n        account_owner=\"John Doe\",\n        created_at=now\n    )\n    client_resp = ClientAccountResponse.model_validate(mock_client_orm)\n    assert client_resp.id == 10\n    print(\"Client Account schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 4. Project Schemas\n    print(\"Testing Project Schemas...\")\n    project_create = ProjectCreate(client_id=10, name=\"Project Alpha\", progress=25)\n    project_update = ProjectUpdate(progress=30, status=\"active\")\n    mock_project_orm = MockORMObject(\n        id=100,\n        client_id=10,\n        name=\"Project Alpha\",\n        phase=\"Phase 1\",\n        status=\"active\",\n        health=\"healthy\",\n        owner=\"Alice Smith\",\n        start_date=now,\n        target_date=now,\n        progress=25,\n        description=\"Core implementation\"\n    )\n    project_resp = ProjectResponse.model_validate(mock_project_orm)\n    assert project_resp.id == 100\n    print(\"Project schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 5. Agent Operation Schemas\n    print(\"Testing Agent Operation Schemas...\")\n    agent_create = AgentOperationCreate(client_id=10, project_id=100, name=\"Agent Sentinel\")\n    agent_update = AgentOperationUpdate(health=\"warning\")\n    mock_agent_orm = MockORMObject(\n        id=200,\n        client_id=10,\n        project_id=100,\n        name=\"Agent Sentinel\",\n        agent_type=\"Sovereign Auditor\",\n        status=\"active\",\n        health=\"healthy\",\n        owner=\"Bob Johnson\",\n        governance_status=\"compliant\",\n        last_activity_at=now\n    )\n    agent_resp = AgentOperationResponse.model_validate(mock_agent_orm)\n    assert agent_resp.id == 200\n    print(\"Agent Operation schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 6. Document Item Schemas\n    print(\"Testing Document Item Schemas...\")\n    doc_create = DocumentItemCreate(client_id=10, project_id=100, title=\"Architecture PDF\")\n    doc_update = DocumentItemUpdate(visibility=\"public\")\n    mock_doc_orm = MockORMObject(\n        id=300,\n        client_id=10,\n        project_id=100,\n        title=\"Architecture PDF\",\n        document_type=\"Specification\",\n        status=\"active\",\n        version=\"1.0.1\",\n        owner=\"Alice Smith\",\n        visibility=\"private\",\n        created_at=now\n    )\n    doc_resp = DocumentItemResponse.model_validate(mock_doc_orm)\n    assert doc_resp.id == 300\n    print(\"Document Item schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 7. Invoice Schemas\n    print(\"Testing Invoice Schemas...\")\n    invoice_create = InvoiceCreate(client_id=10, project_id=100, invoice_number=\"INV-001\", amount=50000.0)\n    invoice_update = InvoiceUpdate(status=\"paid\")\n    mock_invoice_orm = MockORMObject(\n        id=400,\n        client_id=10,\n        project_id=100,\n        invoice_number=\"INV-001\",\n        status=\"unpaid\",\n        amount=50000.0,\n        currency=\"USD\",\n        due_date=now,\n        issued_date=now\n    )\n    invoice_resp = InvoiceResponse.model_validate(mock_invoice_orm)\n    assert invoice_resp.id == 400\n    print(\"Invoice schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 8. Support Ticket Schemas\n    print(\"Testing Support Ticket Schemas...\")\n    ticket_create = SupportTicketCreate(client_id=10, project_id=100, title=\"API latency issue\")\n    ticket_update = SupportTicketUpdate(status=\"closed\")\n    mock_ticket_orm = MockORMObject(\n        id=500,\n        client_id=10,\n        project_id=100,\n        title=\"API latency issue\",\n        category=\"Technical\",\n        priority=\"high\",\n        status=\"open\",\n        assigned_to=\"Support Tier 2\",\n        created_by=\"John Doe\",\n        description=\"Increased response times observed\",\n        created_at=now\n    )\n    ticket_resp = SupportTicketResponse.model_validate(mock_ticket_orm)\n    assert ticket_resp.id == 500\n    print(\"Support Ticket schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 9. Governance Item Schemas\n    print(\"Testing Governance Item Schemas...\")\n    gov_create = GovernanceItemCreate(client_id=10, project_id=100, title=\"Audit Compliance Check\")\n    gov_update = GovernanceItemUpdate(severity=\"critical\")\n    mock_gov_orm = MockORMObject(\n        id=600,\n        client_id=10,\n        project_id=100,\n        title=\"Audit Compliance Check\",\n        severity=\"medium\",\n        status=\"active\",\n        owner=\"Compliance Officer\",\n        due_date=now,\n        description=\"Verify system logs rotation policy\"\n    )\n    gov_resp = GovernanceItemResponse.model_validate(mock_gov_orm)\n    assert gov_resp.id == 600\n    print(\"Governance Item schemas successfully instantiated and validated with ORM attributes.\")\n\n    # 10. System Log Schemas\n    print(\"Testing System Log Schemas...\")\n    log_create = SystemLogCreate(message=\"Database session initiated\", level=\"INFO\", module=\"db\")\n    mock_log_orm = MockORMObject(\n        id=700,\n        level=\"INFO\",\n        message=\"Database session initiated\",\n        module=\"db\",\n        created_at=now\n    )\n    log_resp = SystemLogResponse.model_validate(mock_log_orm)\n    assert log_resp.id == 700\n    print(\"System Log schemas successfully instantiated and validated with ORM attributes.\")\n\n    print(\"\\nAll 10 schema families (with base, create, update, and response variants) have been verified successfully!\")\n\n\nif __name__ == \"__main__\":\n    test_schema_instantiation()\n"}}}
