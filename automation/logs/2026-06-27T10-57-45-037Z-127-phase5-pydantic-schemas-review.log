 updated_at=now)\n    assert UserResponse.model_validate(u_orm).id == 1\n\n    # ClientAccount\n    ClientAccountCreate(name=\"C\")\n    ClientAccountUpdate(industry=\"I\")\n    c_orm = MockORM(id=1, name=\"C\", industry=\"I\", region=\"R\", status=\"active\", account_owner=\"O\", created_at=now)\n    assert ClientAccountResponse.model_validate(c_orm).id == 1\n\n    # Project\n    ProjectCreate(client_id=1, name=\"P\")\n    ProjectUpdate(progress=10)\n    p_orm = MockORM(id=1, client_id=1, name=\"P\", phase=\"P1\", status=\"active\", health=\"H\", owner=\"O\", start_date=now, target_date=now, progress=10, description=\"D\")\n    assert ProjectResponse.model_validate(p_orm).id == 1\n\n    # AgentOperation\n    AgentOperationCreate(client_id=1, name=\"A\")\n    AgentOperationUpdate(health=\"H\")\n    ao_orm = MockORM(id=1, client_id=1, project_id=1, name=\"A\", agent_type=\"T\", status=\"active\", health=\"H\", owner=\"O\", governance_status=\"G\", last_activity_at=now)\n    assert AgentOperationResponse.model_validate(ao_orm).id == 1\n\n    # DocumentItem\n    DocumentItemCreate(client_id=1, title=\"D\")\n    DocumentItemUpdate(status=\"S\")\n    di_orm = MockORM(id=1, client_id=1, project_id=1, title=\"D\", document_type=\"T\", status=\"active\", version=\"1\", owner=\"O\", visibility=\"V\", created_at=now)\n    assert DocumentItemResponse.model_validate(di_orm).id == 1\n\n    # Invoice\n    InvoiceCreate(client_id=1, invoice_number=\"I\", amount=10.0)\n    InvoiceUpdate(status=\"paid\")\n    i_orm = MockORM(id=1, client_id=1, project_id=1, invoice_number=\"I\", status=\"active\", amount=10.0, currency=\"USD\", due_date=now, issued_date=now)\n    assert InvoiceResponse.model_validate(i_orm).id == 1\n\n    # SupportTicket\n    SupportTicketCreate(client_id=1, title=\"T\")\n    SupportTicketUpdate(priority=\"P\")\n    st_orm = MockORM(id=1, client_id=1, project_id=1, title=\"T\", category=\"C\", priority=\"P\", status=\"open\", assigned_to=\"A\", created_by=\"C\", description=\"D\", created_at=now)\n    assert SupportTicketResponse.model_validate(st_orm).id == 1\n\n    # GovernanceItem\n    GovernanceItemCreate(client_id=1, title=\"G\")\n    GovernanceItemUpdate(severity=\"S\")\n    gi_orm = MockORM(id=1, client_id=1, project_id=1, title=\"G\", severity=\"S\", status=\"active\", owner=\"O\", due_date=now, description=\"D\")\n    assert GovernanceItemResponse.model_validate(gi_orm).id == 1\n\n    # SystemLog\n    SystemLogCreate(message=\"M\")\n    sl_orm = MockORM(id=1, level=\"INFO\", message=\"M\", module=\"sys\", created_at=now)\n    assert SystemLogResponse.model_validate(sl_orm).id == 1\n\n    print(\"Success: All Pydantic schemas created and validated successfully!\")\n\nif __name__ == \"__main__\":\n    test_all()\n"}}}
