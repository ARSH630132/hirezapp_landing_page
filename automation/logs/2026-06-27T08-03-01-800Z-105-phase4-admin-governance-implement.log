{"ts":"2026-06-27T07:55:57.766Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"sd6hcaxu","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { GuardrailLedgerTab } from \"../admin-tabs\";\n\nexport default function AdminGovernancePage() {\n  return <GuardrailLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { \n  ShieldCheck, AlertTriangle, Search, Filter, ArrowUpRight, \n  User, Briefcase, Cpu, Building2, X, Calendar, ShieldAlert, \n  Check, RotateCcw\n} from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\ninterface TimelineLog {\n  timestamp: string;\n  action: string;\n  user: string;\n}\n\ninterface Incident {\n  id: string;\n  title: string;\n  scopeType: \"client\" | \"project\" | \"agent\";\n  scopeName: string;\n  severity: \"Critical\" | \"High\" | \"Medium\" | \"Low\";\n  owner: string;\n  reviewer: string;\n  status: \"Flagged\" | \"Under Review\" | \"Remediated\" | \"Suppressed\";\n  dueDate: string;\n  desc: string;\n  complianceRule: string;\n  hash: string;\n  history: TimelineLog[];\n}\n\nconst REVIEWERS = [\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Marcus Vance\", \"Unassigned\"];\n\nconst INITIAL_INCIDENTS: Incident[] = [\n  {\n    id: \"GOV-ALRT-091\",\n    title: \"Sovereign Enclave Outbound Packet Leakage\",\n    scopeType: \"client\",\n    scopeName: \"Apex Sovereign Group\",\n    severity: \"Critical\",\n    owner: \"Alexander Mercer\",\n    reviewer: \"Dr. Sarah Vance\",\n    status: \"Under Review\",\n    dueDate: \"2026-07-01\",\n    desc: \"HSM reported anomalous outbound network packet structures originating from isolated enclave VM core. Memory blocks restricted dynamically.\",\n    complianceRule: \"ISO-27001 Section A.13.1.1 (Network Controls)\",\n    hash: \"SHA_0xFC92BA7A\",\n    history: [\n      { timestamp: \"10:22:15\", action: \"Infraction automatically registered by kernel network driver.\", user: \"System Daemon\" },\n      { timestamp: \"10:45:00\", action: \"Assigned reviewer to Dr. Sarah Vance.\", user: \"System Daemon\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-092\",\n    title: \"eBPF Telemetry Decoupled from Sandbox\",\n    scopeType: \"agent\",\n    scopeName: \"MED-CLINIC-H9\",\n    severity: \"High\",\n    owner: \"Medical Ops Lead\",\n    reviewer: \"Unassigned\",\n    status: \"Flagged\",\n    dueDate: \"2026-07-03\",\n    desc: \"Deep inference medical agent decoupled its core security logging probe. Host execution proceeding in an unverified state.\",\n    complianceRule: \"SOC2 Security CC6.8\",\n    hash: \"SHA_0x89AB12DF\",\n    history: [\n      { timestamp: \"08:14:22\", action: \"Agent health subsystem logged telemetry connection timeout.\", user: \"System Daemon\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-093\",\n    title: \"Model Prompt Injection Safety Drift\",\n    scopeType: \"project\",\n    scopeName: \"Model Guardrail Sandbox 04\",\n    severity: \"High\",\n    owner: \"Alexander Mercer\",\n    reviewer: \"Sophia Lin\",\n    status: \"Under Review\",\n    dueDate: \"2026-07-05\",\n    desc: \"Bypassed prompt-injection prevention layers during scheduled simulation test. System alignment calibration needed.\",\n    complianceRule: \"NIST AI RMF Section 3.2 (Safety Filters)\",\n    hash: \"SHA_0xDE8812CE\",\n    history: [\n      { timestamp: \"Yesterday 14:02:11\", action: \"Simulation test run triggered prompt injection bypass.\", user: \"System Daemon\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-094\",\n    title: \"Stale HSM Certified Root key\",\n    scopeType: \"client\",\n    scopeName: \"Federal Treasury Division\",\n    severity: \"Medium\",\n    owner: \"Treasury Keymaster\",\n    reviewer: \"Dr. Sarah Vance\",\n    status: \"Remediated\",\n    dueDate: \"2026-07-10\",\n    desc: \"Certified root key used for cryptographic state sealing approaching maximum 90-day expiration inside isolated HSM enclave.\",\n    complianceRule: \"NIST SP 800-57 (Key Lifecycle)\",\n    hash: \"SHA_0x11B8A092\",\n    history: [\n      { timestamp: \"2 days ago 09:00:00\", action: \"Key status expiration warning issued dynamically.\", user: \"System Daemon\" }\n    ]\n  }\n];\n\nexport default function AdminGovernancePage() {\n  const [incidents, setIncidents] = useState<Incident[]>(INITIAL_INCIDENTS);\n  const [selected, setSelected] = useState<Incident | null>(null);\n  const [search, setSearch] = useState(\"\");\n  const [activeType, setActiveType] = useState<\"all\" | \"client\" | \"project\" | \"agent\">(\"all\");\n  const [filterSeverity, setFilterSeverity] = useState<string>(\"All\");\n  const [filterStatus, setFilterStatus] = useState<string>(\"All\");\n\n  const [formReviewer, setFormReviewer] = useState(\"Unassigned\");\n  const [formStatus, setFormStatus] = useState<Incident[\"status\"]>(\"Flagged\");\n  const [formSeverity, setFormSeverity] = useState<Incident[\"severity\"]>(\"Medium\");\n  const [formDueDate, setFormDueDate] = useState(\"2026-07-01\");\n  const [toast, setToast] = useState<string | null>(null);\n\n  const stats = useMemo(() => {\n    const total = incidents.length;\n    const criticals = incidents.filter(i => (i.severity === \"Critical\" || i.severity === \"High\") && i.status !== \"Remediated\").length;\n    const unassigned = incidents.filter(i => i.reviewer === \"Unassigned\" && i.status !== \"Remediated\").length;\n    const coverage = total > 0 ? Math.round((incidents.filter(i => i.reviewer !== \"Unassigned\").length / total) * 100) : 100;\n    return { active: incidents.filter(i => i.status !== \"Remediated\" && i.status !== \"Suppressed\").length, criticals, unassigned, coverage };\n  }, [incidents]);\n\n  const filtered = useMemo(() => {\n    return incidents.filter(item => {\n      const matchesSearch = item.title.toLowerCase().includes(search.toLowerCase()) || item.scopeName.toLowerCase().includes(search.toLowerCase()) || item.id.toLowerCase().includes(search.toLowerCase());\n      const matchesType = activeType === \"all\" || item.scopeType === activeType;\n      const matchesSeverity = filterSeverity === \"All\" || item.severity === filterSeverity;\n      const matchesStatus = filterStatus === \"All\" || item.status === filterStatus;\n      return matchesSearch && matchesType && matchesSeverity && matchesStatus;\n    });\n  }, [incidents, search, activeType, filterSeverity, filterStatus]);\n\n  const handleSelect = (item: Incident) => {\n    setSelected(item);\n    setFormReviewer(item.reviewer);\n    setFormStatus(item.status);\n    setFormSeverity(item.severity);\n    setFormDueDate(item.dueDate);\n  };\n\n  const handleApply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selected) return;\n\n    const time = new Date().toLocaleTimeString(\"en-US\", { hour12: false });\n    const logs: TimelineLog[] = [];\n    if (selected.reviewer !== formReviewer) logs.push({ timestamp: time, action: `Assigned reviewer to ${formReviewer}`, user: \"Admin\" });\n    if (selected.status !== formStatus) logs.push({ timestamp: time, action: `Status changed to ${formStatus}`, user: \"Admin\" });\n    if (selected.severity !== formSeverity) logs.push({ timestamp: time, action: `Severity updated to ${formSeverity}`, user: \"Admin\" });\n\n    if (logs.length === 0) {\n      setToast(\"No changes detected.\");\n      setTimeout(() => setToast(null), 2500);\n      return;\n    }\n\n    const updated = incidents.map(item => {\n      if (item.id === selected.id) {\n        return { ...item, reviewer: formReviewer, status: formStatus, severity: formSeverity, dueDate: formDueDate, history: [...item.history, ...logs] };\n      }\n      return item;\n    });\n\n    setIncidents(updated);\n    setSelected(updated.find(item => item.id === selected.id) || null);\n    setToast(`Success: Override applied for ${selected.id}.`);\n    setTimeout(() => setToast(null), 3000);\n  };\n\n  return (\n    <div className=\"space-y-6 text-white pb-12 font-mono text-[11px] relative\">\n      \n      {toast && (\n        <div className=\"fixed top-5 right-5 z-50 p-3 rounded-lg border border-[#009DFF]/30 bg-black/90 shadow-lg text-[10px] flex items-center gap-2\">\n          <span className=\"h-2 w-2 rounded-full bg-emerald-500 animate-pulse\" />\n          <span>{toast}</span>\n        </div>\n      )}\n\n      <PrivatePageHeader \n        title=\"Oversight Guardrail Control\" \n        desc=\"Audit isolated sandbox telemetry and manage active guardrail compliance alerts.\"\n        badgeLabel=\"ADMIN CONTROL\"\n        actions={\n          <div className=\"flex gap-2\">\n            <button onClick={() => setIncidents(INITIAL_INCIDENTS)} className=\"h-8 px-3 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] uppercase cursor-pointer flex items-center gap-1\">\n              <RotateCcw className=\"w-3.5 h-3.5\" /> Reset Default\n            </button>\n            <button onClick={() => setToast(\"PDF Audit report scheduled for queue block.\")} className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] uppercase text-black font-bold flex items-center gap-1 cursor-pointer\">\n              <span>Export Audit</span> <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        }\n      />\n\n      {/* Provisional Audit Disclaimer banner - REQUIRED BY TASK */}\n      <div className=\"p-4 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 flex gap-3 items-start leading-normal\">\n        <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"font-bold uppercase text-amber-400 block mb-1\">PROVISIONAL AUDIT DISCLAIMER</span>\n          This console tracks local sandbox enclaves and simulated guardrail telemetry.\n          These operations are for pre-flight testing and <strong className=\"text-amber-200\">do not guarantee regulatory compliance</strong> under SEC, HIPAA, GDPR, or SOC2 global standards.\n        </div>\n      </div>\n\n      {/* KPI stats */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { l: \"Outstanding Anomalies\", v: `${stats.active} enclaves`, s: \"stable\" },\n          { l: \"Outstanding Criticals\", v: `${stats.criticals} alarms`, s: stats.criticals > 0 ? \"error\" : \"stable\" },\n          { l: \"Unassigned Review\", v: `${stats.unassigned} items`, s: \"warning\" },\n          { l: \"Reviewer Coverage\", v: `${stats.coverage}%`, s: \"normal\" }\n        ].map((k, idx) => (\n          <div key={idx} className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col justify-between h-[80px]\">\n            <span className=\"text-[9.5px] text-white/35 uppercase\">{k.l}</span>\n            <div className=\"text-sm font-bold flex justify-between items-baseline mt-1\">\n              <span>{k.v}</span>\n              <span className={`h-1.5 w-1.5 rounded-full ${k.s === \"error\" ? \"bg-rose-500 animate-pulse\" : k.s === \"warning\" ? \"bg-amber-400\" : \"bg-emerald-500\"}`} />\n            </div>\n          </div>\n        ))}\n      </div>\n\n      {/* Filters */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n        <div className=\"flex flex-col lg:flex-row gap-3\">\n          <div className=\"relative flex-1\">\n            <Search className=\"w-3.5 h-3.5 text-white/30 absolute left-3 top-1/2 -translate-y-1/2\" />\n            <input \n              type=\"text\" \n              placeholder=\"Filter by ID, description, client...\" \n              value={search} \n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full h-8 pl-8 pr-4 rounded-lg border border-white/5 bg-black/40 text-[10.5px] text-white placeholder-white/35 focus:outline-none\"\n            />\n          </div>\n          <div className=\"flex gap-2.5\">\n            <div className=\"flex items-center gap-1.5 px-2 rounded-lg border border-white/5 bg-black/40 h-8\">\n              <span className=\"text-white/30 text-[9px] uppercase\">Severity:</span>\n              <select value={filterSeverity} onChange={(e) => setFilterSeverity(e.target.value)} className=\"bg-transparent border-none text-[10.5px] text-white focus:outline-none cursor-pointer\">\n                <option value=\"All\">All Levels</option>\n                <option value=\"Critical\">🛑 Critical</option>\n                <option value=\"High\">⚠️ High</option>\n                <option value=\"Medium\">◽ Medium</option>\n                <option value=\"Low\">◽ Low</option>\n              </select>\n            </div>\n            <div className=\"flex items-center gap-1.5 px-2 rounded-lg border border-white/5 bg-black/40 h-8\">\n              <span className=\"text-white/30 text-[9px] uppercase\">Status:</span>\n              <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className=\"bg-transparent border-none text-[10.5px] text-white focus:outline-none cursor-pointer\">\n                <option value=\"All\">All States</option>\n                <option value=\"Flagged\">Flagged</option>\n                <option value=\"Under Review\">Under Review</option>\n                <option value=\"Remediated\">Remediated</option>\n                <option value=\"Suppressed\">Suppressed</option>\n              </select>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"flex gap-1.5 border-t border-white/5 pt-3\">\n          {[\n            { id: \"all\", label: \"All Targets\" },\n            { id: \"client\", label: \"Clients\" },\n            { id: \"project\", label: \"Projects\" },\n            { id: \"agent\", label: \"Agents\" }\n          ].map(tab => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveType(tab.id as any)}\n              className={`h-7 px-3.5 rounded-md text-[9.5px] font-bold uppercase cursor-pointer ${\n                activeType === tab.id ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\" : \"border border-white/5 text-white/50 hover:text-white\"\n              }`}\n            >\n              {tab.label}\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* Grid List */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {filtered.length > 0 ? (\n          filtered.map(item => {\n            const ScopeIcon = item.scopeType === \"client\" ? Building2 : item.scopeType === \"project\" ? Briefcase : Cpu;\n            const isSelected = selected?.id === item.id;\n            return (\n              <div\n                key={item.id}\n                onClick={() => handleSelect(item)}\n                className={`p-4 rounded-xl border flex flex-col justify-between h-[210px] cursor-pointer transition-all ${\n                  isSelected \n                    ? \"border-[#009DFF] bg-[#050505]/80 shadow-[0_0_15px_rgba(0,157,255,0.05)]\" \n                    : \"border-white/5 bg-[#050505]/20 hover:border-white/15 hover:bg-[#050505]/40\"\n                }`}\n              >\n                <div className=\"space-y-2.5\">\n                  <div className=\"flex justify-between items-start\">\n                    <span className=\"text-[10px] text-white/40\">{item.id}</span>\n                    <span className={`text-[9px] px-1.5 py-0.2 rounded border uppercase font-bold ${\n                      item.severity === \"Critical\" ? \"text-rose-400 border-rose-500/20 bg-rose-500/5\" :\n                      item.severity === \"High\" ? \"text-amber-400 border-amber-500/20 bg-amber-500/5\" : \"text-blue-400 border-blue-500/20\"\n                    }`}>\n                      {item.severity}\n                    </span>\n                  </div>\n                  <div className=\"space-y-1\">\n                    <h4 className=\"text-[11.5px] font-bold leading-normal truncate\">{item.title}</h4>\n                    <div className=\"flex items-center gap-1 text-white/50 text-[10px]\">\n                      <ScopeIcon className=\"w-3 h-3 text-white/30\" />\n                      <span className=\"truncate\">{item.scopeName}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2 pt-2 border-t border-white/5\">\n                  <div className=\"grid grid-cols-2 gap-2 text-[9.5px] text-white/40\">\n                    <div>\n                      <span className=\"text-white/20 block text-[8px] uppercase\">Owner</span>\n                      <span className=\"truncate block mt-0.5\">{item.owner}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-white/20 block text-[8px] uppercase\">Reviewer</span>\n                      <span className={`truncate block mt-0.5 ${item.reviewer === \"Unassigned\" ? \"text-amber-400\" : \"text-white/60\"}`}>{item.reviewer}</span>\n                    </div>\n                  </div>\n                  <div className=\"flex justify-between items-center text-[10px]\">\n                    <span className={`px-1.5 py-0.2 rounded border ${\n                      item.status === \"Flagged\" ? \"text-rose-400 border-rose-500/10\" :\n                      item.status === \"Under Review\" ? \"text-amber-400 border-amber-500/10\" : \"text-emerald-400 border-emerald-500/10\"\n                    }`}>\n                      {item.status}\n                    </span>\n                    <span className=\"text-white/30 text-[9px]\">Due {item.dueDate}</span>\n                  </div>\n                </div>\n              </div>\n            );\n          })\n        ) : (\n          <div className=\"col-span-full py-10 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-2\">\n            <span className=\"text-[11px] font-bold text-white/40 block\">No matching telemetry anomalies found</span>\n            <button onClick={() => { setSearch(\"\"); setFilterSeverity(\"All\"); setFilterStatus(\"All\"); }} className=\"h-6 px-3 border border-white/10 hover:bg-white/5 rounded text-[9.5px] uppercase cursor-pointer\">\n              Reset Filters\n            </button>\n          </div>\n        )}\n      </div>\n\n      {/* Slider detail drawer */}\n      {selected && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSelected(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[420px] h-full bg-[#030303] border-l border-white/10 flex flex-col justify-between overflow-hidden animate-slide-in\">\n            \n            <div className=\"p-4 border-b border-white/5 space-y-2 bg-black/20\">\n              <div className=\"flex justify-between items-center\">\n                <span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME DETAILS ({selected.id})</span>\n                <button onClick={() => setSelected(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\">\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n              <h3 className=\"text-xs font-bold leading-normal text-white\">{selected.title}</h3>\n            </div>\n\n            <div className=\"flex-1 overflow-y-auto p-4 space-y-4\">\n              <div className=\"space-y-1\">\n                <span className=\"text-[8px] text-white/20 uppercase block\">Forensic Summary</span>\n                <p className=\"text-[10px] leading-relaxed text-white/70 bg-black/40 p-2.5 rounded border border-white/5\">{selected.desc}</p>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-2 text-[10px]\">\n                <div className=\"p-2 border border-white/5 rounded\">\n                  <span className=\"text-[8.5px] text-white/25 uppercase block\">Standard</span>\n                  <span className=\"font-bold truncate block\">{selected.complianceRule.split(\" \")[0]}</span>\n                </div>\n                <div className=\"p-2 border border-white/5 rounded\">\n                  <span className=\"text-[8.5px] text-white/25 uppercase block\">Hash Seal</span>\n                  <span className=\"text-[#009DFF] truncate block\">{selected.hash}</span>\n                </div>\n              </div>\n\n              {/* Local Actions Form (The main action: assign reviewer) */}\n              <form onSubmit={handleApply} className=\"space-y-3.5 border-t border-b border-white/5 py-3.5\">\n                <span className=\"text-[9.5px] text-[#009DFF] font-bold uppercase block\">Local Telemetry Overrides</span>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n                  <select\n                    value={formReviewer}\n                    onChange={(e) => setFormReviewer(e.target.value)}\n                    className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                  >\n                    {REVIEWERS.map(reviewer => (\n                      <option key={reviewer} value={reviewer}>{reviewer}</option>\n                    ))}\n                  </select>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <div className=\"space-y-1\">\n                    <label className=\"text-[8.5px] text-white/35 uppercase block\">Status</label>\n                    <select\n                      value={formStatus}\n                      onChange={(e) => setFormStatus(e.target.value as any)}\n                      className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none cursor-pointer\"\n                    >\n                      <option value=\"Flagged\">Flagged</option>\n                      <option value=\"Under Review\">Under Review</option>\n                      <option value=\"Remediated\">Remediated</option>\n                      <option value=\"Suppressed\">Suppressed</option>\n                    </select>\n                  </div>\n                  <div className=\"space-y-1\">\n                    <label className=\"text-[8.5px] text-white/35 uppercase block\">Severity</label>\n                    <select\n                      value={formSeverity}\n                      onChange={(e) => setFormSeverity(e.target.value as any)}\n                      className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none cursor-pointer\"\n                    >\n                      <option value=\"Critical\">Critical</option>\n                      <option value=\"High\">High</option>\n                      <option value=\"Medium\">Medium</option>\n                      <option value=\"Low\">Low</option>\n                    </select>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Remediation Target Due Date</label>\n                  <input\n                    type=\"date\"\n                    value={formDueDate}\n                    onChange={(e) => setFormDueDate(e.target.value)}\n                    className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none cursor-pointer\"\n                  />\n                </div>\n\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-[10px] uppercase font-bold text-black rounded flex items-center justify-center gap-1 cursor-pointer\">\n                  <span>Apply State Overrides</span> <Check className=\"w-3.5 h-3.5\" />\n                </button>\n              </form>\n\n              {/* Logs history */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[8.5px] text-white/20 uppercase block\">Audit History Trail</span>\n                <div className=\"space-y-2 border-l border-white/5 pl-2.5\">\n                  {selected.history.map((log, index) => (\n                    <div key={index} className=\"text-[9.5px] leading-relaxed\">\n                      <span className=\"text-white/30 text-[8.5px] block\">{log.timestamp} • {log.user}</span>\n                      <span className=\"text-white/60 font-bold\">{log.action}</span>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <div className=\"p-3 border-t border-white/5 bg-black/40 text-[8.5px] text-white/30 text-center\">\n              SECURE TELEMETRY ACTIVE • CLEARANCE LEVEL V AUTHORIZED\n            </div>\n\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}"}}}
