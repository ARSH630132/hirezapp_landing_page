{"ts":"2026-06-27T07:58:23.387Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"63qc6i5p","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { GuardrailLedgerTab } from \"../admin-tabs\";\n\nexport default function AdminGovernancePage() {\n  return <GuardrailLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { Search, Building2, Briefcase, Cpu, X, ShieldAlert, Check } from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\ninterface Inc { \n  id: string; \n  title: string; \n  type: \"client\" | \"project\" | \"agent\"; \n  name: string; \n  sev: \"Critical\" | \"High\" | \"Medium\"; \n  owner: string; \n  rev: string; \n  status: string; \n  desc: string; \n}\n\nconst REVS = [\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Unassigned\"];\nconst INIT: Inc[] = [\n  { id: \"GOV-091\", title: \"Enclave Outbound Leakage\", type: \"client\", name: \"Apex Sovereign Group\", sev: \"Critical\", owner: \"Alexander Mercer\", rev: \"Dr. Sarah Vance\", status: \"Under Review\", desc: \"Anomalous outbound network traffic detected from isolated enclave virtual machine. Packets restricted dynamically.\" },\n  { id: \"GOV-092\", title: \"eBPF Telemetry Decoupled\", type: \"agent\", name: \"MED-CLINIC-H9\", sev: \"High\", owner: \"Medical Ops Lead\", rev: \"Unassigned\", status: \"Flagged\", desc: \"Deep inference medical agent decoupled its logging probe. Host execution is proceeding in an unverified state.\" },\n  { id: \"GOV-093\", title: \"Model Prompt Injection Safety Drift\", type: \"project\", name: \"Model Guardrail Sandbox 04\", sev: \"High\", owner: \"Alexander Mercer\", rev: \"Sophia Lin\", status: \"Under Review\", desc: \"Bypassed prompt-injection prevention layers during scheduled simulation test run. Guardrail recalibration requested.\" }\n];\n\nexport default function AdminGovernancePage() {\n  const [list, setList] = useState<Inc[]>(INIT);\n  const [sel, setSel] = useState<Inc | null>(null);\n  const [q, setQ] = useState(\"\");\n  const [cat, setCat] = useState(\"all\");\n  const [toast, setToast] = useState<string | null>(null);\n  const [formR, setFormR] = useState(\"Unassigned\");\n  const [formS, setFormS] = useState(\"Flagged\");\n\n  const stats = useMemo(() => {\n    const unas = list.filter(i => i.rev === \"Unassigned\").length;\n    const cov = list.length > 0 ? Math.round((list.filter(i => i.rev !== \"Unassigned\").length / list.length) * 100) : 100;\n    return { unas, cov };\n  }, [list]);\n\n  const filtered = list.filter(i => (i.title.toLowerCase().includes(q.toLowerCase()) || i.id.toLowerCase().includes(q.toLowerCase()) || i.name.toLowerCase().includes(q.toLowerCase())) && (cat === \"all\" || i.type === cat));\n\n  const handleApply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!sel) return;\n    setList(list.map(i => i.id === sel.id ? { ...i, rev: formR, status: formS } : i));\n    setSel(null);\n    setToast(`Updated ${sel.id}: reviewer set to ${formR}`);\n    setTimeout(() => setToast(null), 2500);\n  };\n\n  return (\n    <div className=\"space-y-5 text-white pb-10 font-mono text-[11px] relative\">\n      {toast && (\n        <div className=\"fixed top-5 right-5 z-50 p-2.5 rounded border border-[#009DFF]/30 bg-black text-[10px] shadow-lg animate-pulse\">\n          <span>{toast}</span>\n        </div>\n      )}\n      \n      <PrivatePageHeader title=\"Oversight Guardrail Control\" desc=\"Audit isolated sandbox telemetry and manage active guardrail compliance alerts.\" badgeLabel=\"ADMIN CONTROL\" />\n      \n      <div className=\"p-3.5 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 leading-normal flex gap-2.5 items-start\">\n        <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"font-bold uppercase text-amber-400 block mb-0.5\">PROVISIONAL AUDIT DISCLAIMER</span>\n          This console tracks local sandbox enclaves and simulated telemetry. It <strong className=\"text-amber-200\">does not guarantee compliance</strong> under SEC, HIPAA, GDPR, or SOC2 global standards.\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-3 gap-3\">\n        <div className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/40\"><span>Anomalies</span><div className=\"text-xs font-bold text-emerald-400 mt-1\">{list.length} active</div></div>\n        <div className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/40\"><span>Unassigned</span><div className=\"text-xs font-bold text-amber-400 mt-1\">{stats.unas} items</div></div>\n        <div className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/40\"><span>Coverage</span><div className=\"text-xs font-bold text-[#009DFF] mt-1\">{stats.cov}%</div></div>\n      </div>\n\n      <div className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col sm:flex-row gap-3\">\n        <input placeholder=\"Search anomalies...\" value={q} onChange={e => setQ(e.target.value)} className=\"flex-1 h-8 px-2.5 rounded-lg border border-white/5 bg-black/40 text-[10.5px] text-white focus:outline-none\" />\n        <div className=\"flex gap-1\">\n          {[\"all\", \"client\", \"project\", \"agent\"].map(t => (\n            <button key={t} onClick={() => setCat(t)} className={`h-8 px-2.5 rounded text-[9px] font-bold uppercase cursor-pointer ${cat === t ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\" : \"border border-white/5 text-white/50 hover:text-white\"}`}>{t === \"all\" ? \"All\" : t + \"s\"}</button>\n          ))}\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {filtered.map(i => {\n          const Icon = i.type === \"client\" ? Building2 : i.type === \"project\" ? Briefcase : Cpu;\n          return (\n            <div key={i.id} onClick={() => { setSel(i); setFormR(i.rev); setFormS(i.status); }} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 hover:border-white/10 cursor-pointer flex flex-col justify-between h-[160px] transition-all\">\n              <div className=\"flex justify-between items-start\"><span className=\"text-white/40 text-[10px]\">{i.id}</span><span className=\"text-rose-400 border border-rose-500/20 bg-rose-500/5 px-1.5 py-0.2 rounded font-bold uppercase text-[9px]\">{i.sev}</span></div>\n              <h4 className=\"font-bold leading-normal truncate\">{i.title}</h4>\n              <div className=\"pt-2 border-t border-white/5 flex justify-between text-[10px] text-white/50\"><div className=\"flex items-center gap-1\"><Icon className=\"w-3 h-3 text-white/30\" /><span>{i.name}</span></div><span>Reviewer: {i.rev}</span></div>\n            </div>\n          );\n        })}\n      </div>\n\n      {sel && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSel(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[320px] h-full bg-[#030303] border-l border-white/10 p-4 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex justify-between items-center\"><span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME ({sel.id})</span><button onClick={() => setSel(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\"><X className=\"w-4 h-4\" /></button></div>\n              <h3 className=\"font-bold text-white text-xs leading-snug\">{sel.title}</h3>\n              <p className=\"text-[10px] text-white/75 bg-black/40 p-2 rounded border border-white/5 leading-relaxed\">{sel.desc}</p>\n              <form onSubmit={handleApply} className=\"space-y-3.5 border-t border-b border-white/5 py-3\">\n                <div>\n                  <label className=\"text-[8.5px] text-white/30 uppercase block\">Assign Reviewer</label>\n                  <select value={formR} onChange={e => setFormR(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    {REVS.map(r => <option key={r} value={r}>{r}</option>)}\n                  </select>\n                </div>\n                <div>\n                  <label className=\"text-[8.5px] text-white/30 uppercase block\">Status</label>\n                  <select value={formS} onChange={e => setFormS(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    <option value=\"Flagged\">Flagged</option>\n                    <option value=\"Under Review\">Under Review</option>\n                    <option value=\"Remediated\">Remediated</option>\n                  </select>\n                </div>\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-black uppercase font-bold text-[9.5px] rounded flex items-center justify-center gap-1 cursor-pointer\">Apply Overrides <Check className=\"w-3 h-3\" /></button>\n              </form>\n            </div>\n            <div className=\"text-center text-[8.5px] text-white/30\">SECURE LINK ACTIVE</div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
