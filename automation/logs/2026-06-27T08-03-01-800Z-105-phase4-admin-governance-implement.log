ify-between h-[130px] transition-all\">\n              <div className=\"flex justify-between items-start\"><span className=\"text-[10px] text-white/40\">{item.id}</span><span className=\"text-rose-400 border border-rose-500/20 bg-rose-500/5 px-1.5 py-0.1 rounded font-bold uppercase text-[9px]\">{item.sev}</span></div>\n              <h4 className=\"font-bold truncate text-[11.5px]\">{item.title}</h4>\n              <div className=\"pt-2 border-t border-white/5 flex justify-between text-[10px] text-white/50\"><div className=\"flex items-center gap-1\"><ScopeIcon className=\"w-3 h-3 text-white/30\" /><span>{item.name}</span></div><span>Reviewer: {item.rev}</span></div>\n            </div>\n          );\n        })}\n      </div>\n      {sel && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSel(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[320px] h-full bg-[#030303] border-l border-white/10 p-4 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex justify-between items-center\"><span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME ({sel.id})</span><button onClick={() => setSel(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\"><X className=\"w-4 h-4\" /></button></div>\n              <h3 className=\"font-bold text-white text-xs leading-snug\">{sel.title}</h3>\n              <p className=\"text-[10px] text-white/70 bg-black/40 p-2 rounded border border-white/5 leading-relaxed\">{sel.desc}</p>\n              <form onSubmit={onApply} className=\"space-y-3 border-t border-b border-white/5 py-3\">\n                <div>\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n                  <select value={rVal} onChange={e => setRVal(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    {[\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Unassigned\"].map(r => <option key={r} value={r}>{r}</option>)}\n                  </select>\n                </div>\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-black uppercase font-bold text-[9.5px] rounded flex items-center justify-center gap-1 cursor-pointer\">Apply Overrides <Check className=\"w-3.5 h-3.5\" /></button>\n              </form>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
