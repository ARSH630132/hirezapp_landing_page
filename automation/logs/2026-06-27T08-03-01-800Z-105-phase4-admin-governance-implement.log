ving the landing page untouched. I'm focusing on ensuring it meets all the specified conditions.\n\n\n"}}
{"ts":"2026-06-27T07:57:28.371Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"f8c9a6jt","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { GuardrailLedgerTab } from \"../admin-tabs\";\n\nexport default function AdminGovernancePage() {\n  return <GuardrailLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { ShieldCheck, Search, Building2, Briefcase, Cpu, X, Calendar, ShieldAlert, Check, RotateCcw } from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\ninterface Incident {\n  id: string;\n  title: string;\n  scopeType: \"client\" | \"project\" | \"agent\";\n  scopeName: string;\n  severity: \"Critical\" | \"High\" | \"Medium\" | \"Low\";\n  owner: string;\n  reviewer: string;\n  status: \"Flagged\" | \"Under Review\" | \"Remediated\";\n  dueDate: string;\n  desc: string;\n  hash: string;\n}\n\nconst REVIEWERS = [\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Marcus Vance\", \"Unassigned\"];\nconst INITIAL: Incident[] = [\n  { id: \"GOV-091\", title: \"Sovereign Enclave Outbound Packet Leakage\", scopeType: \"client\", scopeName: \"Apex Sovereign Group\", severity: \"Critical\", owner: \"Alexander Mercer\", reviewer: \"Dr. Sarah Vance\", status: \"Under Review\", dueDate: \"2026-07-01\", desc: \"HSM reported anomalous outbound network traffic. Telemetry restricted dynamically.\", hash: \"SHA_0xFC92\" },\n  { id: \"GOV-092\", title: \"eBPF Telemetry Decoupled from Sandbox\", scopeType: \"agent\", scopeName: \"MED-CLINIC-H9\", severity: \"High\", owner: \"Medical Ops Lead\", reviewer: \"Unassigned\", status: \"Flagged\", dueDate: \"2026-07-03\", desc: \"Deep inference medical agent decoupled its core security logging probe. Host execution is unverified.\", hash: \"SHA_0x89AB\" },\n  { id: \"GOV-093\", title: \"Model Prompt Injection Safety Drift\", scopeType: \"project\", scopeName: \"Model Guardrail Sandbox 04\", severity: \"High\", owner: \"Alexander Mercer\", reviewer: \"Sophia Lin\", status: \"Under Review\", dueDate: \"2026-07-05\", desc: \"Bypassed prompt-injection prevention layers during simulation test. Override flagged.\", hash: \"SHA_0xDE88\" }\n];\n\nexport default function AdminGovernancePage() {\n  const [list, setList] = useState<Incident[]>(INITIAL);\n  const [selected, setSelected] = useState<Incident | null>(null);\n  const [search, setSearch] = useState(\"\");\n  const [type, setType] = useState<\"all\" | \"client\" | \"project\" | \"agent\">(\"all\");\n  const [toast, setToast] = useState<string | null>(null);\n\n  const [formReviewer, setFormReviewer] = useState(\"Unassigned\");\n  const [formStatus, setFormStatus] = useState<Incident[\"status\"]>(\"Flagged\");\n\n  const stats = useMemo(() => {\n    const unassigned = list.filter(i => i.reviewer === \"Unassigned\").length;\n    const coverage = list.length > 0 ? Math.round((list.filter(i => i.reviewer !== \"Unassigned\").length / list.length) * 100) : 100;\n    return { active: list.length, unassigned, coverage };\n  }, [list]);\n\n  const filtered = useMemo(() => {\n    return list.filter(item => {\n      const matchSearch = item.title.toLowerCase().includes(search.toLowerCase()) || item.scopeName.toLowerCase().includes(search.toLowerCase()) || item.id.toLowerCase().includes(search.toLowerCase());\n      const matchType = type === \"all\" || item.scopeType === type;\n      return matchSearch && matchType;\n    });\n  }, [list, search, type]);\n\n  const handleSelect = (item: Incident) => {\n    setSelected(item);\n    setFormReviewer(item.reviewer);\n    setFormStatus(item.status);\n  };\n\n  const handleApply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selected) return;\n    const updated = list.map(item => {\n      if (item.id === selected.id) {\n        return { ...item, reviewer: formReviewer, status: formStatus };\n      }\n      return item;\n    });\n    setList(updated);\n    setSelected(updated.find(item => item.id === selected.id) || null);\n    setToast(`Override committed for ${selected.id}. Reviewer set to ${formReviewer}.`);\n    setTimeout(() => setToast(null), 3000);\n  };\n\n  return (\n    <div className=\"space-y-6 text-white pb-12 font-mono text-[11px] relative\">\n      {toast && (\n        <div className=\"fixed top-5 right-5 z-50 p-3 rounded-lg border border-[#009DFF]/30 bg-black shadow-lg text-[10px] flex items-center gap-2\">\n          <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse\" />\n          <span>{toast}</span>\n        </div>\n      )}\n\n      <PrivatePageHeader \n        title=\"Oversight Guardrail Control\" \n        desc=\"Audit isolated sandbox telemetry and manage active guardrail compliance alerts.\"\n        badgeLabel=\"ADMIN CONTROL\"\n        actions={\n          <div className=\"flex gap-2\">\n            <button onClick={() => setList(INITIAL)} className=\"h-8 px-3 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] uppercase cursor-pointer flex items-center gap-1\">\n              <RotateCcw className=\"w-3.5 h-3.5\" /> Reset\n            </button>\n            <button onClick={() => setToast(\"PDF Audit report sealed.\")} className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] uppercase text-black font-bold flex items-center gap-1 cursor-pointer\">\n              <span>Export Audit</span>\n            </button>\n          </div>\n        }\n      />\n\n      {/* Required provisional compliance disclaimer statement */}\n      <div className=\"p-4 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 leading-normal\">\n        <div className=\"flex gap-2.5 items-start\">\n          <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n          <div>\n            <span className=\"font-bold uppercase text-amber-400 block mb-1\">PROVISIONAL AUDIT DISCLAIMER</span>\n            This console tracks local sandbox enclaves and simulated guardrail telemetry.\n            These operations are for pre-flight testing and <strong className=\"text-amber-200\">do not guarantee regulatory compliance</strong> under SEC, HIPAA, GDPR, or SOC2 global standards.\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-3 gap-4\">\n        {[\n          { l: \"Outstanding Anomalies\", v: `${stats.active} enclaves`, c: \"text-emerald-400\" },\n          { l: \"Unassigned Review\", v: `${stats.unassigned} items`, c: \"text-amber-400\" },\n          { l: \"Reviewer Coverage\", v: `${stats.coverage}%`, c: \"text-[#009DFF]\" }\n        ].map((k, idx) => (\n          <div key={idx} className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col justify-between h-[80px]\">\n            <span className=\"text-[9.5px] text-white/35 uppercase\">{k.l}</span>\n            <div className={`text-sm font-bold mt-1 ${k.c}`}>{k.v}</div>\n          </div>\n        ))}\n      </div>\n\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n        <div className=\"flex flex-col lg:flex-row gap-3\">\n          <div className=\"relative flex-1\">\n            <Search className=\"w-3.5 h-3.5 text-white/30 absolute left-3 top-1/2 -translate-y-1/2\" />\n            <input \n              type=\"text\" \n              placeholder=\"Search anomalies by ID, description, client...\" \n              value={search} \n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full h-8 pl-8 pr-4 rounded-lg border border-white/5 bg-black/40 text-[10.5px] text-white placeholder-white/35 focus:outline-none\"\n            />\n          </div>\n          <div className=\"flex gap-1.5 items-center\">\n            {[\"all\", \"client\", \"project\", \"agent\"].map(tab => (\n              <button\n                key={tab}\n                onClick={() => setType(tab as any)}\n                className={`h-8 px-3 rounded text-[9.5px] font-bold uppercase cursor-pointer ${\n                  type === tab ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\" : \"border border-white/5 text-white/50 hover:text-white\"\n                }`}\n              >\n                {tab === \"all\" ? \"All Targets\" : tab + \"s\"}\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {filtered.length > 0 ? (\n          filtered.map(item => {\n            const ScopeIcon = item.scopeType === \"client\" ? Building2 : item.scopeType === \"project\" ? Briefcase : Cpu;\n            const isSelected = selected?.id === item.id;\n            return (\n              <div\n                key={item.id}\n                onClick={() => handleSelect(item)}\n                className={`p-4 rounded-xl border flex flex-col justify-between h-[210px] cursor-pointer transition-all ${\n                  isSelected \n                    ? \"border-[#009DFF] bg-[#050505]/80 shadow-[0_0_15px_rgba(0,157,255,0.05)]\" \n                    : \"border-white/5 bg-[#050505]/20 hover:border-white/15 hover:bg-[#050505]/40\"\n                }`}\n              >\n                <div className=\"space-y-2.5\">\n                  <div className=\"flex justify-between items-start\">\n                    <span className=\"text-[10px] text-white/40\">{item.id}</span>\n                    <span className={`text-[9px] px-1.5 py-0.2 rounded border uppercase font-bold ${\n                      item.severity === \"Critical\" ? \"text-rose-400 border-rose-500/20 bg-rose-500/5\" : \"text-amber-400 border-amber-500/20 bg-amber-500/5\"\n                    }`}>\n                      {item.severity}\n                    </span>\n                  </div>\n                  <div className=\"space-y-1\">\n                    <h4 className=\"text-[11.5px] font-bold leading-normal truncate\">{item.title}</h4>\n                    <div className=\"flex items-center gap-1 text-white/50 text-[10px]\">\n                      <ScopeIcon className=\"w-3 h-3 text-white/30\" />\n                      <span className=\"truncate\">{item.scopeName}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2 pt-2 border-t border-white/5\">\n                  <div className=\"grid grid-cols-2 gap-2 text-[9.5px] text-white/40\">\n                    <div>\n                      <span className=\"text-white/20 block text-[8px] uppercase\">Owner</span>\n                      <span className=\"truncate block mt-0.5\">{item.owner}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-white/20 block text-[8px] uppercase\">Reviewer</span>\n                      <span className={`truncate block mt-0.5 ${item.reviewer === \"Unassigned\" ? \"text-amber-400 font-bold\" : \"text-white/60\"}`}>{item.reviewer}</span>\n                    </div>\n                  </div>\n                  <div className=\"flex justify-between items-center text-[10px]\">\n                    <span className={`px-1.5 py-0.2 rounded border ${\n                      item.status === \"Flagged\" ? \"text-rose-400 border-rose-500/10\" : \"text-amber-400 border-amber-500/10\"\n                    }`}>\n                      {item.status}\n                    </span>\n                    <span className=\"text-white/30 text-[9px]\">Due {item.dueDate}</span>\n                  </div>\n                </div>\n              </div>\n            );\n          })\n        ) : (\n          <div className=\"col-span-full py-10 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-2\">\n            <span className=\"text-[11px] font-bold text-white/40 block\">No matching telemetry anomalies found</span>\n          </div>\n        )}\n      </div>\n\n      {selected && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSelected(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[380px] h-full bg-[#030303] border-l border-white/10 flex flex-col justify-between overflow-hidden\">\n            \n            <div className=\"p-4 border-b border-white/5 space-y-2 bg-black/20\">\n              <div className=\"flex justify-between items-center\">\n                <span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME ({selected.id})</span>\n                <button onClick={() => setSelected(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\">\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n              <h3 className=\"text-xs font-bold leading-normal text-white\">{selected.title}</h3>\n            </div>\n\n            <div className=\"flex-1 overflow-y-auto p-4 space-y-4\">\n              <div className=\"space-y-1\">\n                <span className=\"text-[8px] text-white/20 uppercase block\">Summary</span>\n                <p className=\"text-[10px] leading-relaxed text-white/70 bg-black/40 p-2.5 rounded border border-white/5\">{selected.desc}</p>\n              </div>\n\n              <div className=\"p-2 border border-white/5 rounded text-[10px]\">\n                <span className=\"text-[8.5px] text-white/25 uppercase block\">Seal Hash</span>\n                <span className=\"text-[#009DFF] truncate block mt-0.5\">{selected.hash}</span>\n              </div>\n\n              <form onSubmit={handleApply} className=\"space-y-3.5 border-t border-b border-white/5 py-3.5\">\n                <span className=\"text-[9.5px] text-[#009DFF] font-bold uppercase block\">Local Telemetry Overrides</span>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n                  <select\n                    value={formReviewer}\n                    onChange={(e) => setFormReviewer(e.target.value)}\n                    className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                  >\n                    {REVIEWERS.map(reviewer => (\n                      <option key={reviewer} value={reviewer}>{reviewer}</option>\n                    ))}\n                  </select>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Status</label>\n                  <select\n                    value={formStatus}\n                    onChange={(e) => setFormStatus(e.target.value as any)}\n                    className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white focus:outline-none cursor-pointer\"\n                  >\n                    <option value=\"Flagged\">Flagged</option>\n                    <option value=\"Under Review\">Under Review</option>\n                    <option value=\"Remediated\">Remediated</option>\n                  </select>\n                </div>\n\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-[10px] uppercase font-bold text-black rounded flex items-center justify-center gap-1 cursor-pointer\">\n                  <span>Apply State Overrides</span> <Check className=\"w-3.5 h-3.5\" />\n                </button>\n              </form>\n            </div>\n\n            <div className=\"p-3 border-t border-white/5 bg-black/40 text-[8.5px] text-white/30 text-center\">\n              SECURE TELEMETRY ACTIVE • CLEARANCE LEVEL V AUTHORIZED\n            </div>\n\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
