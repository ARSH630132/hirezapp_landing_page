erity: \"Critical\",\n    owner: \"Alexander Mercer\",\n    reviewer: \"Dr. Sarah Vance\",\n    status: \"Under Review\",\n    dueDate: \"2026-07-01\",\n    desc: \"Hardware security module (HSM) reported anomalous network traffic originating from isolated virtual machine. Packet structure matching database parameters. Outbound telemetry restricted dynamically.\",\n    complianceRule: \"ISO-27001 Section A.13.1.1 (Network Security Controls)\",\n    hash: \"SHA_0xFC92BA7A8D8F\",\n    timestamp: \"2 hours ago\",\n    history: [\n      { timestamp: \"10:22:15\", action: \"Infraction automatically registered by kernel network driver.\", user: \"System Daemon\" },\n      { timestamp: \"10:45:00\", action: \"Assigned reviewer to Dr. Sarah Vance.\", user: \"System Daemon\" },\n      { timestamp: \"10:50:30\", action: \"Status modified from 'Flagged' to 'Under Review'.\", user: \"Dr. Sarah Vance\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-092\",\n    title: \"eBPF Telemetry Decoupled from Sandbox\",\n    scopeType: \"agent\",\n    scopeName: \"MED-CLINIC-H9\",\n    entityId: \"agent-004\",\n    severity: \"High\",\n    owner: \"Medical Ops Lead\",\n    reviewer: \"Unassigned\",\n    status: \"Flagged\",\n    dueDate: \"2026-07-03\",\n    desc: \"Deep inference medical agent detached its kernel security logging container. Host execution is proceeding in unverified state. Automatic sandbox isolation suggested within 4 hours.\",\n    complianceRule: \"SOC2 Trust Services Criteria CC6.8\",\n    hash: \"SHA_0x89AB12DF78A1\",\n    timestamp: \"4 hours ago\",\n    history: [\n      { timestamp: \"08:14:22\", action: \"Agent health subsystem logged telemetry connection timeout.\", user: \"System Daemon\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-093\",\n    title: \"Model Prompt Injection Safety Drift\",\n    scopeType: \"project\",\n    scopeName: \"Model Guardrail Sandbox 04\",\n    entityId: \"proj-002\",\n    severity: \"High\",\n    owner: \"Alexander Mercer\",\n    reviewer: \"Sophia Lin\",\n    status: \"Under Review\",\n    dueDate: \"2026-07-05\",\n    desc: \"Simulation checks bypassed prompt-injection prevention layers. Overrides detected on SEC reporting guardrails. Prompt filters parameters modification requested.\",\n    complianceRule: \"NIST AI RMF Section 3.2 (Secure Alignments & Safety Filters)\",\n    hash: \"SHA_0xDE8812CEFCA0\",\n    timestamp: \"1 day ago\",\n    history: [\n      { timestamp: \"Yesterday 14:02:11\", action: \"Simulated penetration test bypass triggered warning.\", user: \"System Daemon\" },\n      { timestamp: \"Yesterday 15:30:00\", action: \"Assigned reviewer to Sophia Lin.\", user: \"Dr. Sarah Vance\" },\n      { timestamp: \"Yesterday 15:32:15\", action: \"Status updated to 'Under Review'.\", user: \"Sophia Lin\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-094\",\n    title: \"Stale HSM Certified Root Key\",\n    scopeType: \"client\",\n    scopeName: \"Federal Treasury Division\",\n    entityId: \"client-004\",\n    severity: \"Medium\",\n    owner: \"Treasury Keymaster\",\n    reviewer: \"Dr. Sarah Vance\",\n    status: \"Remediated\",\n    dueDate: \"2026-07-10\",\n    desc: \"Certified cryptographic root key approaching maximum 90-day expiration inside isolated HSM enclave. Automated rollover successfully triggered and verified.\",\n    complianceRule: \"NIST SP 800-57 (Key Management Lifecycle)\",\n    hash: \"SHA_0x11B8A092FECD\",\n    timestamp: \"2 days ago\",\n    history: [\n      { timestamp: \"2 days ago 09:00:00\", action: \"Key rotation warning issued dynamically.\", user: \"System Daemon\" },\n      { timestamp: \"1 day ago 16:45:00\", action: \"Admin committed rollover signing key verification. Status set to Remediated.\", user: \"Dr. Sarah Vance\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-095\",\n    title: \"Synthetic Test Identification Classification\",\n    scopeType: \"agent\",\n    scopeName: \"RETAIL-CORE-A1\",\n    entityId: \"agent-001\",\n    severity: \"Low\",\n    owner: \"System Daemon\",\n    reviewer: \"Marcus Vance\",\n    status: \"Suppressed\",\n    dueDate: \"2026-07-15\",\n    desc: \"Text trace filter detected numbers matching mock regulatory PII configuration. Checked and verified to be safe pre-flight synthetic parameters. Action suppressed.\",\n    complianceRule: \"HIPAA Security Standards Section 164.502\",\n    hash: \"SHA_0x99AA120CC9A2\",\n    timestamp: \"3 days ago\",\n    history: [\n      { timestamp: \"3 days ago 11:32:00\", action: \"Data classifier flagged potential regulatory structure.\", user: \"System Daemon\" },\n      { timestamp: \"2 days ago 10:15:00\", action: \"Admin verified synthetic generation. Status set to Suppressed.\", user: \"Marcus Vance\" }\n    ]\n  },\n  {\n    id: \"GOV-ALRT-096\",\n    title: \"Unsigned Binary Execution Attempt\",\n    scopeType: \"project\",\n    scopeName: \"Sovereign Core Sandbox 02\",\n    entityId: \"proj-001\",\n    severity: \"Critical\",\n    owner: \"Alexander Mercer\",\n    reviewer: \"Dr. Sarah Vance\",\n    status: \"Flagged\",\n    dueDate: \"2026-06-29\",\n    desc: \"Unsigned third-party module requested dynamic loading inside the secure hardware enclave. GFF security kernel blocked binary validation handshake immediately.\",\n    complianceRule: \"ISO-27001 Section A.12.5.1 (Enclave Integrity Controls)\",\n    hash: \"SHA_0x44CEBA128EFC\",\n    timestamp: \"5 hours ago\",\n    history: [\n      { timestamp: \"07:11:30\", action: \"HSM supervisor intercepted and isolated execution attempt.\", user: \"System Daemon\" }\n    ]\n  }\n];\n\nexport default function AdminGovernancePage() {\n  // State for all incidents\n  const [incidents, setIncidents] = useState<GovernanceIncident[]>(INITIAL_INCIDENTS);\n  \n  // Selected incident for detail drawer\n  const [selectedIncident, setSelectedIncident] = useState<GovernanceIncident | null>(null);\n\n  // Filter States\n  const [search, setSearch] = useState(\"\");\n  const [activeType, setActiveType] = useState<\"all\" | \"client\" | \"project\" | \"agent\">(\"all\");\n  const [filterSeverity, setFilterSeverity] = useState<\"All\" | \"Critical\" | \"High\" | \"Medium\" | \"Low\">(\"All\");\n  const [filterStatus, setFilterStatus] = useState<\"All\" | \"Flagged\" | \"Under Review\" | \"Remediated\" | \"Suppressed\">(\"All\");\n\n  // Local Action Form State\n  const [formReviewer, setFormReviewer] = useState(\"Unassigned\");\n  const [formStatus, setFormStatus] = useState<GovernanceIncident[\"status\"]>(\"Flagged\");\n  const [formSeverity, setFormSeverity] = useState<GovernanceIncident[\"severity\"]>(\"Medium\");\n  const [formDueDate, setFormDueDate] = useState(\"2026-07-01\");\n\n  // Success Notification state\n  const [toast, setToast] = useState<string | null>(null);\n\n  // Set form values on incident selection\n  const handleSelectIncident = (incident: GovernanceIncident) => {\n    setSelectedIncident(incident);\n    setFormReviewer(incident.reviewer);\n    setFormStatus(incident.status);\n    setFormSeverity(incident.severity);\n    setFormDueDate(incident.dueDate);\n  };\n\n  // Local Action Handler: Update reviewer / status / severity (simulated sandbox action)\n  const handleApplyModifications = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selectedIncident) return;\n\n    const updaterUser = \"Dr. Sarah Vance\"; // Simulated logged-in administrator\n    const timestampStr = new Date().toLocaleTimeString(\"en-US\", { hour12: false });\n    \n    // Build audit logging events\n    const newLogs: TimelineLog[] = [];\n    if (selectedIncident.reviewer !== formReviewer) {\n      newLogs.push({\n        timestamp: timestampStr,\n        action: `Assigned reviewer to ${formReviewer === \"Unassigned\" ? \"Unassigned\" : formReviewer}.`,\n        user: updaterUser\n      });\n    }\n    if (selectedIncident.status !== formStatus) {\n      newLogs.push({\n        timestamp: timestampStr,\n        action: `Status updated from '${selectedIncident.status}' to '${formStatus}'.`,\n        user: updaterUser\n      });\n    }\n    if (selectedIncident.severity !== formSeverity) {\n      newLogs.push({\n        timestamp: timestampStr,\n        action: `Severity redefined from '${selectedIncident.severity}' to '${formSeverity}'.`,\n        user: updaterUser\n      });\n    }\n    if (selectedIncident.dueDate !== formDueDate) {\n      newLogs.push({\n        timestamp: timestampStr,\n        action: `Due date rescheduled to ${formDueDate}.`,\n        user: updaterUser\n      });\n    }\n\n    if (newLogs.length === 0) {\n      // If nothing changed, just notify and exit\n      setToast(`Notice: No telemetry configurations were modified.`);\n      setTimeout(() => setToast(null), 3500);\n      return;\n    }\n\n    // Update state locally\n    const updatedIncidents = incidents.map(item => {\n      if (item.id === selectedIncident.id) {\n        return {\n          ...item,\n          reviewer: formReviewer,\n          status: formStatus,\n          severity: formSeverity,\n          dueDate: formDueDate,\n          history: [...item.history, ...newLogs]\n        };\n      }\n      return item;\n    });\n\n    setIncidents(updatedIncidents);\n    \n    // Find updated incident to synchronize the selected drawer state\n    const freshlyUpdated = updatedIncidents.find(item => item.id === selectedIncident.id) || null;\n    setSelectedIncident(freshlyUpdated);\n\n    // Show nice enterprise toast\n    setToast(`SUCCESS: Telemetry override applied. Incident ${selectedIncident.id} updated successfully.`);\n    setTimeout(() => setToast(null), 4000);\n  };\n\n  // Reset to initial demo database\n  const handleResetTelemetry = () => {\n    setIncidents(INITIAL_INCIDENTS);\n    setSelectedIncident(null);\n    setToast(\"SYSTEM NOTICE: Local governance database reset to factory telemetry defaults.\");\n    setTimeout(() => setToast(null), 3000);\n  };\n\n  // Dynamic KPI calculations\n  const stats = useMemo(() => {\n    const total = incidents.length;\n    const criticalOrHighCount = incidents.filter(i => \n      (i.severity === \"Critical\" || i.severity === \"High\") && \n      i.status !== \"Remediated\" && \n      i.status !== \"Suppressed\"\n    ).length;\n    \n    const unassignedCount = incidents.filter(i => \n      i.reviewer === \"Unassigned\" && \n      i.status !== \"Remediated\" && \n      i.status !== \"Suppressed\"\n    ).length;\n\n    const assignedWithReviewer = incidents.filter(i => i.reviewer !== \"Unassigned\").length;\n    const assignmentCoverage = total > 0 ? Math.round((assignedWithReviewer / total) * 100) : 100;\n\n    return {\n      activeAnomalies: incidents.filter(i => i.status === \"Flagged\" || i.status === \"Under Review\").length,\n      unassignedAlerts: unassignedCount,\n      criticalOutstanding: criticalOrHighCount,\n      coverageRate: assignmentCoverage\n    };\n  }, [incidents]);\n\n  // Filter and search computation\n  const filteredIncidents = useMemo(() => {\n    return incidents.filter(item => {\n      // 1. Search filter\n      const matchesSearch = \n        item.title.toLowerCase().includes(search.toLowerCase()) ||\n        item.scopeName.toLowerCase().includes(search.toLowerCase()) ||\n        item.id.toLowerCase().includes(search.toLowerCase()) ||\n        item.complianceRule.toLowerCase().includes(search.toLowerCase());\n\n      // 2. Tab Category filter\n      const matchesType = activeType === \"all\" || item.scopeType === activeType;\n\n      // 3. Severity filter\n      const matchesSeverity = filterSeverity === \"All\" || item.severity === filterSeverity;\n\n      // 4. Status filter\n      const matchesStatus = filterStatus === \"All\" || item.status === filterStatus;\n\n      return matchesSearch && matchesType && matchesSeverity && matchesStatus;\n    });\n  }, [incidents, search, activeType, filterSeverity, filterStatus]);\n\n  // Quick stat helpers for category tags\n  const typeCounts = useMemo(() => {\n    return {\n      all: incidents.length,\n      client: incidents.filter(i => i.scopeType === \"client\").length,\n      project: incidents.filter(i => i.scopeType === \"project\").length,\n      agent: incidents.filter(i => i.scopeType === \"agent\").length\n    };\n  }, [incidents]);\n\n  return (\n    <div className=\"space-y-6 text-white pb-12 select-none relative min-h-screen\">\n      \n      {/* Dynamic Toast Notification Panel */}\n      {toast && (\n        <div className=\"fixed top-5 right-5 z-50 animate-bounce duration-500 max-w-md p-4 rounded-xl border border-[#009DFF]/30 bg-[#020202]/95 backdrop-blur-md shadow-[0_0_25px_rgba(0,157,255,0.2)] text-[11px] font-mono flex items-start gap-2.5\">\n          <div className=\"h-2 w-2 rounded-full bg-emerald-500 shrink-0 mt-1 animate-pulse\" />\n          <div className=\"flex-1\">\n            <p className=\"text-white leading-normal\">{toast}</p>\n          </div>\n          <button onClick={() => setToast(null)} className=\"text-white/40 hover:text-white cursor-pointer transition-colors shrink-0\">\n            <X className=\"w-4 h-4\" />\n          </button>\n        </div>\n      )}\n\n      {/* Header Panel */}\n      <PrivatePageHeader \n        title=\"Oversight Guardrail Control\" \n        desc=\"Examine telemetry anomalies, evaluate compliance rules, and assign security reviews across active hardware sandbox layers.\"\n        badgeLabel=\"ADMIN CONSOLE\"\n        actions={\n          <div className=\"flex gap-2.5\">\n            <button \n              onClick={handleResetTelemetry}\n              className=\"h-9 px-4 rounded border border-white/5 bg-white/[0.01] text-[10.5px] font-mono font-bold uppercase tracking-wider text-white hover:bg-white/[0.04] transition-all cursor-pointer flex items-center gap-1.5\"\n            >\n              <RotateCcw className=\"w-3.5 h-3.5\" />\n              <span>Reset Defaults</span>\n            </button>\n            <button \n              onClick={() => {\n                setToast(\"SYSTEM NOTICE: Secure PDF audit trail sealed and scheduled for administrator export block.\");\n                setTimeout(() => setToast(null), 3000);\n              }}\n              className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10.5px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.25)]\"\n            >\n              <span>Export Audit Trail</span>\n              <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        }\n      />\n\n      {/* Legal & Compliance Disclaimer Banner - Crucial Rule Compliance */}\n      <div className=\"p-4 rounded-2xl border border-amber-500/15 bg-amber-500/[0.01] text-[11.5px] leading-relaxed text-amber-300/80 font-mono flex gap-3.5 items-start\">\n        <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n        <div className=\"space-y-1\">\n          <span className=\"font-bold uppercase tracking-wider text-amber-400 block text-[10.5px]\">PROVISIONAL INTEGRITY DISCLAIMER</span>\n          <p>\n            This dashboard manages and logs internal, simulated sandbox guardrail checks and telemetry audit states. \n            All reports and configurations in this console are internal indicators and <strong className=\"text-amber-200 underline\">do not guarantee regulatory compliance</strong> with SEC, HIPAA, FINRA, GDPR, or SOC2 global standards. \n            Official, certified audits are completed independently of local virtual enclaves.\n          </p>\n        </div>\n      </div>\n\n      {/* KPI Stats Block - State Dependent Calculations */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        \n        {/* Metric 1 */}\n        <div className=\"p-4 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between h-[90px]\">\n          <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase\">Active Anomalies</span>\n          <div className=\"flex items-baseline justify-between mt-1\">\n            <div className=\"text-xl font-bold tracking-tight\">{stats.activeAnomalies} enclaves</div>\n            <span className=\"text-[9.5px] font-mono text-amber-400 bg-amber-400/5 px-1.5 py-0.5 rounded border border-amber-400/10\">Active</span>\n          </div>\n        </div>\n\n        {/* Metric 2 */}\n        <div className=\"p-4 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between h-[90px]\">\n          <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase\">Outstanding Criticals</span>\n          <div className=\"flex items-baseline justify-between mt-1\">\n            <div className={`text-xl font-bold tracking-tight ${stats.criticalOutstanding > 0 ? \"text-rose-400\" : \"text-emerald-400\"}`}>\n              {stats.criticalOutstanding} ALARMS\n            </div>\n            <span className={`h-2 w-2 rounded-full ${stats.criticalOutstanding > 0 ? \"bg-rose-500 animate-pulse\" : \"bg-emerald-500\"}`} />\n          </div>\n        </div>\n\n        {/* Metric 3 */}\n        <div className=\"p-4 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between h-[90px]\">\n          <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase\">Unassigned Anomalies</span>\n          <div className=\"flex items-baseline justify-between mt-1\">\n            <div className=\"text-xl font-bold tracking-tight\">{stats.unassignedAlerts} Items</div>\n            <span className=\"text-[9.5px] text-white/40 font-mono\">Awaiting Review</span>\n          </div>\n        </div>\n\n        {/* Metric 4 */}\n        <div className=\"p-4 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between h-[90px]\">\n          <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase\">Assigned Oversight Rate</span>\n          <div className=\"flex items-baseline justify-between mt-1\">\n            <div className=\"text-xl font-bold tracking-tight text-[#009DFF]\">{stats.coverageRate}%</div>\n            <span className=\"text-[9.5px] text-white/40 font-mono\">Verified Reviews</span>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Interactive Controls & Filters */}\n      <WorkspaceCard className=\"p-5 space-y-4\">\n        \n        {/* Filter bar container */}\n        <div className=\"flex flex-col lg:flex-row gap-4 items-stretch lg:items-center justify-between pb-1\">\n          \n          {/* Search box */}\n          <div className=\"relative flex-1\">\n            <Search className=\"w-4 h-4 text-white/30 absolute left-3 top-1/2 -translate-y-1/2\" />\n            <input \n              type=\"text\"\n              placeholder=\"Search anomalies by ID, description, or regulatory framework...\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              className=\"w-full h-10 pl-9 pr-8 rounded-xl border border-white/5 bg-black/40 text-[11.5px] font-mono text-white placeholder-white/30 focus:outline-none focus:border-[#009DFF]/30 focus:bg-black/60 transition-all\"\n            />\n            {search && (\n              <button \n                onClick={() => setSearch(\"\")}\n                className=\"absolute right-3 top-1/2 -translate-y-1/2 text-white/40 hover:text-white cursor-pointer\"\n              >\n                <X className=\"w-3.5 h-3.5\" />\n              </button>\n            )}\n          </div>\n\n          {/* Selector dropdown filters */}\n          <div className=\"flex flex-wrap sm:flex-nowrap gap-2.5\">\n            \n            {/* Severity Select */}\n            <div className=\"flex items-center gap-1.5 h-10 px-2.5 rounded-xl border border-white/5 bg-black/40 text-[11px] font-mono\">\n              <span className=\"text-white/35 uppercase text-[9.5px]\">Severity:</span>\n              <select \n                value={filterSeverity} \n                onChange={(e) => setFilterSeverity(e.target.value as any)}\n                className=\"bg-transparent border-none text-white focus:outline-none pr-1 text-[11px] cursor-pointer\"\n              >\n                <option value=\"All\" className=\"bg-[#050505] text-white text-[11.5px]\">All Levels</option>\n                <option value=\"Critical\" className=\"bg-[#050505] text-rose-400 text-[11.5px]\">🛑 Critical</option>\n                <option value=\"High\" className=\"bg-[#050505] text-amber-400 text-[11.5px]\">⚠️ High</option>\n                <option value=\"Medium\" className=\"bg-[#050505] text-blue-400 text-[11.5px]\">◽ Medium</option>\n                <option value=\"Low\" className=\"bg-[#050505] text-white/50 text-[11.5px]\">◽ Low</option>\n              </select>\n            </div>\n\n            {/* Status Select */}\n            <div className=\"flex items-center gap-1.5 h-10 px-2.5 rounded-xl border border-white/5 bg-black/40 text-[11px] font-mono\">\n              <span className=\"text-white/35 uppercase text-[9.5px]\">Status:</span>\n              <select \n                value={filterStatus} \n                onChange={(e) => setFilterStatus(e.target.value as any)}\n                className=\"bg-transparent border-none text-white focus:outline-none pr-1 text-[11px] cursor-pointer\"\n              >\n                <option value=\"All\" className=\"bg-[#050505] text-white text-[11.5px]\">All States</option>\n                <option value=\"Flagged\" className=\"bg-[#050505] text-rose-400 text-[11.5px]\">Flagged</option>\n                <option value=\"Under Review\" className=\"bg-[#050505] text-amber-400 text-[11.5px]\">Under Review</option>\n                <option value=\"Remediated\" className=\"bg-[#050505] text-emerald-400 text-[11.5px]\">Remediated</option>\n                <option value=\"Suppressed\" className=\"bg-[#050505] text-white/40 text-[11.5px]\">Suppressed</option>\n              </select>\n            </div>\n\n          </div>\n\n        </div>\n\n        {/* Segmented Category Tabs */}\n        <div className=\"flex flex-wrap gap-1.5 border-b border-white/5 pb-3\">\n          {[\n            { id: \"all\", label: \"All Targets\", count: typeCounts.all },\n            { id: \"client\", label: \"Client Enclaves\", count: typeCounts.client },\n            { id: \"project\", label: \"Project Layers\", count: typeCounts.project },\n            { id: \"agent\", label: \"Agent Kernels\", count: typeCounts.agent }\n          ].map(tab => (\n            <button\n              key={tab.id}\n              onClick={() => setActiveType(tab.id as any)}\n              className={`h-8 px-3.5 rounded-lg text-[10.5px] font-mono font-bold uppercase transition-all flex items-center gap-2 cursor-pointer ${\n                activeType === tab.id \n                  ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 shadow-[0_0_10px_rgba(0,157,255,0.05)]\" \n                  : \"border border-white/5 bg-transparent text-white/50 hover:text-white hover:border-white/10\"\n              }`}\n            >\n              <span>{tab.label}</span>\n              <span className={`text-[8.5px] px-1 py-0.1 rounded ${\n                activeType === tab.id ? \"bg-[#009DFF]/20 text-[#009DFF]\" : \"bg-white/5 text-white/30\"\n              }`}>\n                {tab.count}\n              </span>\n            </button>\n          ))}\n        </div>\n\n      </WorkspaceCard>\n\n      {/* Main Board Grid - Governance Cards */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n        \n        {filteredIncidents.length > 0 ? (\n          filteredIncidents.map(incident => {\n            \n            // Scope type configuration\n            const scopeConfig = {\n              client: { label: \"Client Enclave\", icon: Building2, border: \"border-blue-500/10\", text: \"text-blue-400\" },\n              project: { label: \"Project Layer\", icon: Briefcase, border: \"border-[#009DFF]/10\", text: \"text-[#009DFF]\" },\n              agent: { label: \"Agent Kernel\", icon: Cpu, border: \"border-purple-500/10\", text: \"text-purple-400\" }\n            }[incident.scopeType];\n\n            // Severity styling\n            const severityStyles = {\n              Critical: \"text-rose-400 bg-rose-500/10 border-rose-500/20\",\n              High: \"text-amber-400 bg-amber-400/10 border-amber-400/20\",\n              Medium: \"text-blue-400 bg-blue-500/10 border-blue-500/20\",\n              Low: \"text-white/40 bg-white/5 border-white/10\"\n            }[incident.severity];\n\n            // Status styling\n            const statusStyles = {\n              Flagged: \"text-rose-400 bg-rose-500/5 border-rose-500/10\",\n              \"Under Review\": \"text-amber-400 bg-amber-400/5 border-amber-400/10\",\n              Remediated: \"text-emerald-400 bg-emerald-500/5 border-emerald-500/10\",\n              Suppressed: \"text-white/30 bg-white/[0.02] border-white/5\"\n            }[incident.status];\n\n            const ScopeIcon = scopeConfig.icon;\n            const isSelected = selectedIncident?.id === incident.id;\n\n            return (\n              <div\n                key={incident.id}\n                onClick={() => handleSelectIncident(incident)}\n                className={`group rounded-2xl p-5 border bg-[#050505]/30 backdrop-blur-sm cursor-pointer transition-all duration-300 flex flex-col justify-between h-[250px] relative overflow-hidden select-none ${\n                  isSelected \n                    ? \"border-[#009DFF] shadow-[0_0_20px_rgba(0,157,255,0.1)] bg-[#050505]/70\" \n                    : \"border-white/5 hover:border-white/15 hover:bg-[#050505]/50 hover:shadow-[0_0_15px_rgba(255,255,255,0.01)]\"\n                }`}\n              >\n                \n                {/* Background subatomic highlight line on selection */}\n                {isSelected && (\n                  <div className=\"absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-[#009DFF] to-transparent\" />\n                )}\n\n                <div className=\"space-y-3.5\">\n                  \n                  {/* Top line metadata */}\n                  <div className=\"flex justify-between items-start gap-2\">\n                    <div className=\"flex items-center gap-1.5 font-mono text-[9.5px]\">\n                      <span className=\"text-white/30\">{incident.id}</span>\n                      <span className=\"text-white/15\">•</span>\n                      <span className={scopeConfig.text}>{scopeConfig.label}</span>\n                    </div>\n                    <span className={`text-[9px] px-1.5 py-0.2 font-mono font-bold uppercase rounded border ${severityStyles}`}>\n                      {incident.severity}\n                    </span>\n                  </div>\n\n                  {/* Title & target */}\n                  <div className=\"space-y-1\">\n                    <h4 className=\"text-[12.5px] font-bold text-white tracking-wide leading-snug line-clamp-2 group-hover:text-[#009DFF] transition-colors\">\n                      {incident.title}\n                    </h4>\n                    \n                    {/* Entity link */}\n                    <div className=\"flex items-center gap-1.5 text-white/50 font-mono text-[10.5px]\">\n                      <ScopeIcon className=\"w-3.5 h-3.5 text-white/30 shrink-0\" />\n                      <span className=\"truncate max-w-[210px]\">{incident.scopeName}</span>\n                    </div>\n                  </div>\n\n                </div>\n\n                {/* Lower meta block */}\n                <div className=\"space-y-3 pt-3 border-t border-white/5\">\n                  \n                  {/* Owner & reviewer */}\n                  <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/40\">\n                    <div>\n                      <span className=\"text-white/20 uppercase text-[8.5px] block\">Oversight Owner</span>\n                      <span className=\"text-white/70 truncate block mt-0.5\">{incident.owner}</span>\n                    </div>\n                    <div>\n                      <span className=\"text-white/20 uppercase text-[8.5px] block\">Reviewer</span>\n                      <span className={`truncate block mt-0.5 ${incident.reviewer === \"Unassigned\" ? \"text-amber-400/80 font-bold\" : \"text-white/70\"}`}>\n                        {incident.reviewer}\n                      </span>\n                    </div>\n                  </div>\n\n                  {/* Status & target due date */}\n                  <div className=\"flex items-center justify-between gap-2 pt-0.5\">\n                    <span className={`text-[9.5px] px-2 py-0.5 font-mono font-bold rounded border ${statusStyles}`}>\n                      {incident.status}\n                    </span>\n\n                    <div className=\"flex items-center gap-1 text-[9.5px] font-mono text-white/30\">\n                      <Calendar className=\"w-3 h-3\" />\n                      <span>Due {incident.dueDate}</span>\n                    </div>\n                  </div>\n\n                </div>\n\n              </div>\n            );\n          })\n        ) : (\n          \n          /* Empty Search results matching constitutional premium standards */\n          <div className=\"col-span-full py-12 rounded-2xl border border-white/5 bg-[#050505]/20 flex flex-col items-center justify-center text-center space-y-4\">\n            <div className=\"h-10 w-10 rounded-full border border-white/5 bg-white/[0.02] flex items-center justify-center text-white/30\">\n              <Filter className=\"w-4 h-4 text-white/40\" />\n            </div>\n            <div className=\"space-y-1.5\">\n              <h5 className=\"text-[13px] font-bold text-white uppercase font-mono\">No telemetry anomalies found</h5>\n              <p className=\"text-[11px] text-white/45 font-mono max-w-sm\">\n                No active simulated incidents matched your selection filter parameters. Use another level or search input.\n              </p>\n            </div>\n            <button\n              onClick={() => {\n                setSearch(\"\");\n                setActiveType(\"all\");\n                setFilterSeverity(\"All\");\n                setFilterStatus(\"All\");\n              }}\n              className=\"h-8 px-4 border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.03] transition-all rounded-lg text-[10.5px] font-mono font-bold text-white uppercase cursor-pointer\"\n            >\n              Clear Search Parameters\n            </button>\n          </div>\n        )}\n\n      </div>\n\n      {/* Slide-over Detail Drawer Overlay */}\n      {selectedIncident && (\n        <div className=\"fixed inset-0 z-40 flex justify-end select-none\">\n          \n          {/* Backdrop blur */}\n          <div \n            onClick={() => setSelectedIncident(null)}\n            className=\"absolute inset-0 bg-black/60 backdrop-blur-xs transition-opacity duration-300\"\n          />\n\n          {/* Drawer body */}\n          <div className=\"relative w-full sm:w-[480px] h-full bg-[#030303] border-l border-white/10 shadow-2xl z-10 flex flex-col justify-between overflow-hidden animate-slide-in\">\n            \n            {/* Header section */}\n            <div className=\"p-5 border-b border-white/5 space-y-3.5 bg-black/20\">\n              <div className=\"flex items-center justify-between\">\n                <div className=\"flex items-center gap-2 font-mono text-[10px]\">\n                  <span className=\"text-[#009DFF] font-bold uppercase tracking-wider\">Telemetry Frame Details</span>\n                  <span className=\"text-white/20\">|</span>\n                  <span className=\"text-white/40\">{selectedIncident.id}</span>\n                </div>\n                <button \n                  onClick={() => setSelectedIncident(null)}\n                  className=\"h-7 w-7 rounded-lg hover:bg-white/5 text-white/40 hover:text-white cursor-pointer transition-colors flex items-center justify-center\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <span className=\"inline-flex rounded bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 text-[9px] font-mono font-bold uppercase text-[#009DFF]\">\n                  {selectedIncident.scopeType.toUpperCase()} INCIDENT\n                </span>\n                <h3 className=\"text-base font-bold text-white tracking-wide leading-snug\">\n                  {selectedIncident.title}\n                </h3>\n              </div>\n            </div>\n\n            {/* Content area */}\n            <div className=\"flex-1 overflow-y-auto p-5 space-y-6\">\n              \n              {/* Detailed Explanation */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[8.5px] font-mono tracking-widest text-white/20 uppercase block\">Telemetry Forensic Summary</span>\n                <p className=\"text-[11px] leading-relaxed text-white/75 font-mono bg-black/40 border border-white/5 p-3 rounded-xl\">\n                  {selectedIncident.desc}\n                </p>\n              </div>\n\n              {/* Regulatory standard details */}\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1 bg-white/[0.01] border border-white/5 p-2.5 rounded-xl\">\n                  <span className=\"text-[8.5px] font-mono tracking-widest text-white/20 uppercase block\">Standard</span>\n                  <span className=\"text-[10.5px] font-mono text-white/80 block truncate font-bold\">{selectedIncident.complianceRule.split(\" \")[0]}</span>\n                </div>\n                <div className=\"space-y-1 bg-white/[0.01] border border-white/5 p-2.5 rounded-xl\">\n                  <span className=\"text-[8.5px] font-mono tracking-widest text-white/20 uppercase block\">Cryptographic Seal</span>\n                  <span className=\"text-[10.5px] font-mono text-[#009DFF] block truncate font-bold\">{selectedIncident.hash}</span>\n                </div>\n              </div>\n\n              {/* Local Actions Form (The main action: assign reviewer + status) */}\n              <form onSubmit={handleApplyModifications} className=\"space-y-4 border-t border-b border-white/5 py-5\">\n                <span className=\"text-[10px] font-mono tracking-widest text-[#009DFF] font-bold uppercase block\">Local Governance Override Actions</span>\n\n                {/* Select Reviewer Selection */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[9.5px] font-mono text-white/40 uppercase block\">Assign Local Reviewer</label>\n                  <div className=\"relative\">\n                    <User className=\"w-3.5 h-3.5 text-white/30 absolute left-3 top-1/2 -translate-y-1/2\" />\n                    <select\n                      value={formReviewer}\n                      onChange={(e) => setFormReviewer(e.target.value)}\n                      className=\"w-full h-9 pl-8 pr-4 rounded-lg border border-white/10 bg-black text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                    >\n                      {AVAILABLE_REVIEWERS.map(reviewer => (\n                        <option key={reviewer} value={reviewer} className=\"bg-[#050505] text-white\">\n                          {reviewer}\n                        </option>\n                      ))}\n                    </select>\n                  </div>\n                  <p className=\"text-[8.5px] text-white/30 font-mono mt-0.5\">Assign an administrator to review this sandbox state audit block.</p>\n                </div>\n\n                {/* Two column dropdown selectors */}\n                <div className=\"grid grid-cols-2 gap-3.5\">\n                  \n                  {/* Local status */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"text-[9.5px] font-mono text-white/40 uppercase block\">Oversight Status</label>\n                    <select\n                      value={formStatus}\n                      onChange={(e) => setFormStatus(e.target.value as any)}\n                      className=\"w-full h-9 px-2.5 rounded-lg border border-white/10 bg-black text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                    >\n                      <option value=\"Flagged\" className=\"bg-[#050505] text-white\">Flagged</option>\n                      <option value=\"Under Review\" className=\"bg-[#050505] text-white\">Under Review</option>\n                      <option value=\"Remediated\" className=\"bg-[#050505] text-white\">Remediated</option>\n                      <option value=\"Suppressed\" className=\"bg-[#050505] text-white\">Suppressed</option>\n                    </select>\n                  </div>\n\n                  {/* Local Severity */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"text-[9.5px] font-mono text-white/40 uppercase block\">Anomalies Severity</label>\n                    <select\n                      value={formSeverity}\n                      onChange={(e) => setFormSeverity(e.target.value as any)}\n                      className=\"w-full h-9 px-2.5 rounded-lg border border-white/10 bg-black text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                    >\n                      <option value=\"Critical\" className=\"bg-[#050505] text-white\">Critical</option>\n                      <option value=\"High\" className=\"bg-[#050505] text-white\">High</option>\n                      <option value=\"Medium\" className=\"bg-[#050505] text-white\">Medium</option>\n                      <option value=\"Low\" className=\"bg-[#050505] text-white\">Low</option>\n                    </select>\n                  </div>\n\n                </div>\n\n                {/* Due Date field */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[9.5px] font-mono text-white/40 uppercase block\">Target Remediation Due Date</label>\n                  <div className=\"relative\">\n                    <Calendar className=\"w-3.5 h-3.5 text-white/30 absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none\" />\n                    <input\n                      type=\"date\"\n                      value={formDueDate}\n                      onChange={(e) => setFormDueDate(e.target.value)}\n                      className=\"w-full h-9 pl-8 pr-4 rounded-lg border border-white/10 bg-black text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/30 cursor-pointer\"\n                    />\n                  </div>\n                </div>\n\n                {/* Commit Action Buttons */}\n                <div className=\"pt-2\">\n                  <button\n                    type=\"submit\"\n                    className=\"w-full h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-mono font-bold uppercase tracking-wider text-white transition-all cursor-pointer flex items-center justify-center gap-1.5 shadow-[0_0_15px_rgba(0,157,255,0.2)]\"\n                  >\n                    <span>Apply State Modifications</span>\n                    <Check className=\"w-3.5 h-3.5\" />\n                  </button>\n                </div>\n\n              </form>\n\n              {/* Dynamic local audit logs timeline */}\n              <div className=\"space-y-3 pt-1\">\n                <span className=\"text-[8.5px] font-mono tracking-widest text-white/20 uppercase block\">Chronological Telemetry Logs</span>\n                <div className=\"space-y-2.5 relative pl-3.5 border-l border-white/5\">\n                  {selectedIncident.history.map((log, index) => (\n                    <div key={index} className=\"space-y-0.5 text-[10px] font-mono relative\">\n                      {/* Timeline dot */}\n                      <span className=\"absolute -left-[19.5px] top-1.5 h-2 w-2 rounded-full border border-black bg-white/20\" />\n                      \n                      <div className=\"flex items-center gap-1.5 text-white/30 text-[9px]\">\n                        <span>{log.timestamp}</span>\n                        <span>•</span>\n                        <span>Operator: {log.user}</span>\n                      </div>\n                      <p className=\"text-white/60 leading-normal font-bold\">{log.action}</p>\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n            </div>\n\n            {/* Footer section */}\n            <div className=\"p-4 border-t border-white/5 bg-black/40 text-[9.5px] font-mono text-white/30 text-center leading-normal\">\n              SECURE TELEMETRY LINK ACTIVE • CLEARANCE LEVEL V AUTHORIZED\n            </div>\n\n          </div>\n\n        </div>\n      )}\n\n    </div>\n  );\n}\n"}}}
