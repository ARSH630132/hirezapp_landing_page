{"ts":"2026-06-27T07:57:55.298Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"2kub9dup","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { GuardrailLedgerTab } from \"../admin-tabs\";\n\nexport default function AdminGovernancePage() {\n  return <GuardrailLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { Search, Building2, Briefcase, Cpu, X, ShieldAlert, Check } from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\ninterface Incident { id: string; title: string; scopeType: \"client\" | \"project\" | \"agent\"; scopeName: string; severity: \"Critical\" | \"High\" | \"Medium\"; owner: string; reviewer: string; status: string; dueDate: string; desc: string; hash: string; }\n\nconst REVIEWERS = [\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Unassigned\"];\nconst INITIAL: Incident[] = [\n  { id: \"GOV-091\", title: \"Sovereign Enclave Outbound Packet Leakage\", scopeType: \"client\", scopeName: \"Apex Sovereign Group\", severity: \"Critical\", owner: \"Alexander Mercer\", reviewer: \"Dr. Sarah Vance\", status: \"Under Review\", dueDate: \"2026-07-01\", desc: \"HSM reported anomalous outbound network traffic. Telemetry restricted dynamically.\", hash: \"SHA_0xFC92\" },\n  { id: \"GOV-092\", title: \"eBPF Telemetry Decoupled from Sandbox\", scopeType: \"agent\", scopeName: \"MED-CLINIC-H9\", severity: \"High\", owner: \"Medical Ops Lead\", reviewer: \"Unassigned\", status: \"Flagged\", dueDate: \"2026-07-03\", desc: \"Deep inference medical agent decoupled its core security logging probe. Host execution is unverified.\", hash: \"SHA_0x89AB\" }\n];\n\nexport default function AdminGovernancePage() {\n  const [list, setList] = useState<Incident[]>(INITIAL);\n  const [selected, setSelected] = useState<Incident | null>(null);\n  const [search, setSearch] = useState(\"\");\n  const [type, setType] = useState<\"all\" | \"client\" | \"project\" | \"agent\">(\"all\");\n  const [toast, setToast] = useState<string | null>(null);\n  const [formReviewer, setFormReviewer] = useState(\"Unassigned\");\n  const [formStatus, setFormStatus] = useState(\"Flagged\");\n\n  const stats = useMemo(() => {\n    const unassigned = list.filter(i => i.reviewer === \"Unassigned\").length;\n    const coverage = list.length > 0 ? Math.round((list.filter(i => i.reviewer !== \"Unassigned\").length / list.length) * 100) : 100;\n    return { active: list.length, unassigned, coverage };\n  }, [list]);\n\n  const filtered = list.filter(item => {\n    const matchSearch = item.title.toLowerCase().includes(search.toLowerCase()) || item.scopeName.toLowerCase().includes(search.toLowerCase()) || item.id.toLowerCase().includes(search.toLowerCase());\n    return matchSearch && (type === \"all\" || item.scopeType === type);\n  });\n\n  const handleApply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selected) return;\n    setList(list.map(item => item.id === selected.id ? { ...item, reviewer: formReviewer, status: formStatus } : item));\n    setSelected(null);\n    setToast(`Override applied. Reviewer set to ${formReviewer}.`);\n    setTimeout(() => setToast(null), 3000);\n  };\n\n  return (\n    <div className=\"space-y-6 text-white pb-12 font-mono text-[11px] relative\">\n      {toast && <div className=\"fixed top-5 right-5 z-50 p-3 rounded-lg border border-[#009DFF]/30 bg-black text-[10px]\">{toast}</div>}\n      <PrivatePageHeader title=\"Oversight Guardrail Control\" desc=\"Audit isolated sandbox telemetry and manage active guardrail compliance alerts.\" badgeLabel=\"ADMIN CONTROL\" />\n      <div className=\"p-4 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 leading-normal flex gap-2.5 items-start\">\n        <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"font-bold uppercase text-amber-400 block mb-1\">PROVISIONAL AUDIT DISCLAIMER</span>\n          This console tracks local sandbox enclaves and simulated guardrail telemetry. It <strong className=\"text-amber-200\">does not guarantee compliance</strong> under SEC, GDPR, or SOC2 standards.\n        </div>\n      </div>\n      <div className=\"grid grid-cols-3 gap-4\">\n        {[\n          { l: \"Outstanding Anomalies\", v: `${stats.active} enclaves`, c: \"text-emerald-400\" },\n          { l: \"Unassigned Review\", v: `${stats.unassigned} items`, c: \"text-amber-400\" },\n          { l: \"Reviewer Coverage\", v: `${stats.coverage}%`, c: \"text-[#009DFF]\" }\n        ].map((k, idx) => (\n          <div key={idx} className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col justify-between h-[75px]\">\n            <span className=\"text-[9.5px] text-white/35 uppercase\">{k.l}</span>\n            <div className={`text-xs font-bold mt-1 ${k.c}`}>{k.v}</div>\n          </div>\n        ))}\n      </div>\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col lg:flex-row gap-3\">\n        <input placeholder=\"Search anomalies...\" value={search} onChange={(e) => setSearch(e.target.value)} className=\"flex-1 h-8 px-3 rounded-lg border border-white/5 bg-black/40 text-[10.5px] text-white focus:outline-none\" />\n        <div className=\"flex gap-1.5\">\n          {[\"all\", \"client\", \"project\", \"agent\"].map(t => (\n            <button key={t} onClick={() => setType(t as any)} className={`h-8 px-3 rounded text-[9.5px] font-bold uppercase cursor-pointer ${type === t ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\" : \"border border-white/5\"}`}>{t === \"all\" ? \"All Targets\" : t + \"s\"}</button>\n          ))}\n        </div>\n      </div>\n      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n        {filtered.map(item => {\n          const ScopeIcon = item.scopeType === \"client\" ? Building2 : item.scopeType === \"project\" ? Briefcase : Cpu;\n          return (\n            <div key={item.id} onClick={() => { setSelected(item); setFormReviewer(item.reviewer); setFormStatus(item.status); }} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 hover:border-white/15 cursor-pointer flex flex-col justify-between h-[185px]\">\n              <div className=\"flex justify-between items-start\"><span className=\"text-[10px] text-white/40\">{item.id}</span><span className=\"text-rose-400 border border-rose-500/20 bg-rose-500/5 px-1.5 py-0.2 rounded uppercase font-bold\">{item.severity}</span></div>\n              <h4 className=\"text-[11.5px] font-bold leading-normal truncate\">{item.title}</h4>\n              <div className=\"pt-2 border-t border-white/5 flex justify-between text-[10px] text-white/50\"><div className=\"flex items-center gap-1\"><ScopeIcon className=\"w-3 h-3\" /><span>{item.scopeName}</span></div><span>Reviewer: {item.reviewer}</span></div>\n            </div>\n          );\n        })}\n      </div>\n      {selected && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSelected(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[350px] h-full bg-[#030303] border-l border-white/10 p-4 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex justify-between items-center\"><span className=\"text-[#009DFF] font-bold\">TELEMETRY FRAME ({selected.id})</span><button onClick={() => setSelected(null)}><X className=\"w-4 h-4\" /></button></div>\n              <h3 className=\"text-xs font-bold text-white\">{selected.title}</h3>\n              <p className=\"text-[10px] leading-relaxed text-white/70 bg-black/40 p-2 rounded border border-white/5\">{selected.desc}</p>\n              <form onSubmit={handleApply} className=\"space-y-3.5 border-t border-b border-white/5 py-3\">\n                <div>\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n                  <select value={formReviewer} onChange={(e) => setFormReviewer(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    {REVIEWERS.map(r => <option key={r} value={r}>{r}</option>)}\n                  </select>\n                </div>\n                <div>\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Status</label>\n                  <select value={formStatus} onChange={(e) => setFormStatus(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    <option value=\"Flagged\">Flagged</option>\n                    <option value=\"Under Review\">Under Review</option>\n                    <option value=\"Remediated\">Remediated</option>\n                  </select>\n                </div>\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-bold text-black rounded flex items-center justify-center gap-1 cursor-pointer\">Apply Overrides <Check className=\"w-3.5 h-3.5\" /></button>\n              </form>\n            </div>\n            <div className=\"text-center text-[8.5px] text-white/30\">SECURE LINK ACTIVE</div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
