{"ts":"2026-06-27T07:58:47.431Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ifx8bxle","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { GuardrailLedgerTab } from \"../admin-tabs\";\n\nexport default function AdminGovernancePage() {\n  return <GuardrailLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { Search, Building2, Briefcase, Cpu, X, ShieldAlert, Check } from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\ninterface Inc { \n  id: string; \n  title: string; \n  type: \"client\" | \"project\" | \"agent\"; \n  name: string; \n  sev: string; \n  owner: string; \n  rev: string; \n  status: string; \n  desc: string; \n}\n\nconst INIT: Inc[] = [\n  { id: \"GOV-091\", title: \"Sovereign Enclave Outbound Packet Leakage\", type: \"client\", name: \"Apex Sovereign Group\", sev: \"Critical\", owner: \"Alexander Mercer\", rev: \"Dr. Sarah Vance\", status: \"Under Review\", desc: \"HSM reported anomalous outbound network traffic. Telemetry restricted dynamically.\" },\n  { id: \"GOV-092\", title: \"eBPF Telemetry Decoupled from Sandbox\", type: \"agent\", name: \"MED-CLINIC-H9\", sev: \"High\", owner: \"Medical Ops Lead\", rev: \"Unassigned\", status: \"Flagged\", desc: \"Deep inference medical agent decoupled its logging probe. Host execution is unverified.\" },\n  { id: \"GOV-093\", title: \"Model Prompt Injection Safety Drift\", type: \"project\", name: \"Model Guardrail Sandbox 04\", sev: \"High\", owner: \"Alexander Mercer\", rev: \"Sophia Lin\", status: \"Under Review\", desc: \"Bypassed prompt-injection prevention layers during simulation test. Override flagged.\" }\n];\n\nexport default function AdminGovernancePage() {\n  const [list, setList] = useState<Inc[]>(INIT);\n  const [sel, setSel] = useState<Inc | null>(null);\n  const [q, setQ] = useState(\"\");\n  const [toast, setToast] = useState<string | null>(null);\n  const [formR, setFormR] = useState(\"Unassigned\");\n\n  const stats = useMemo(() => {\n    const unassigned = list.filter(i => i.rev === \"Unassigned\").length;\n    const coverage = list.length > 0 ? Math.round((list.filter(i => i.rev !== \"Unassigned\").length / list.length) * 100) : 100;\n    return { active: list.length, unassigned, coverage };\n  }, [list]);\n\n  const handleApply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!sel) return;\n    setList(list.map(i => i.id === sel.id ? { ...i, rev: formR } : i));\n    setSel(null);\n    setToast(`Override committed. Reviewer set to ${formR}`);\n    setTimeout(() => setToast(null), 2500);\n  };\n\n  return (\n    <div className=\"space-y-6 text-white pb-12 font-mono text-[11px] relative\">\n      {toast && (\n        <div className=\"fixed top-5 right-5 z-50 p-3 rounded-lg border border-[#009DFF]/30 bg-black shadow-lg text-[10px] flex items-center gap-2\">\n          <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse\" />\n          <span>{toast}</span>\n        </div>\n      )}\n\n      <PrivatePageHeader title=\"Oversight Guardrail Control\" desc=\"Audit isolated sandbox telemetry and manage active guardrail compliance alerts.\" badgeLabel=\"ADMIN CONTROL\" />\n\n      <div className=\"p-4 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 leading-normal flex gap-2.5 items-start\">\n        <ShieldAlert className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n        <div>\n          <span className=\"font-bold uppercase text-amber-400 block mb-1\">PROVISIONAL AUDIT DISCLAIMER</span>\n          This console tracks local sandbox enclaves and simulated guardrail telemetry. It <strong className=\"text-amber-200\">does not guarantee compliance</strong> under SEC, HIPAA, GDPR, or SOC2 global standards.\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-3 gap-4\">\n        {[\n          { l: \"Anomalies\", v: `${stats.active} enclaves`, c: \"text-emerald-400\" },\n          { l: \"Unassigned Review\", v: `${stats.unassigned} items`, c: \"text-amber-400\" },\n          { l: \"Reviewer Coverage\", v: `${stats.coverage}%`, c: \"text-[#009DFF]\" }\n        ].map((k, idx) => (\n          <div key={idx} className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col justify-between h-[80px]\">\n            <span className=\"text-[9.5px] text-white/35 uppercase\">{k.l}</span>\n            <div className={`text-sm font-bold mt-1 ${k.c}`}>{k.v}</div>\n          </div>\n        ))}\n      </div>\n\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col sm:flex-row gap-3\">\n        <div className=\"relative flex-1\">\n          <Search className=\"w-3.5 h-3.5 text-white/30 absolute left-3 top-1/2 -translate-y-1/2\" />\n          <input placeholder=\"Search anomalies...\" value={q} onChange={e => setQ(e.target.value)} className=\"w-full h-8 pl-8 pr-4 rounded-lg border border-white/5 bg-black/40 text-[10.5px] text-white focus:outline-none\" />\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n        {list.filter(i => i.title.toLowerCase().includes(q.toLowerCase()) || i.scopeName.toLowerCase().includes(q.toLowerCase()) || i.id.toLowerCase().includes(q.toLowerCase())).map(item => {\n          const ScopeIcon = item.type === \"client\" ? Building2 : item.type === \"project\" ? Briefcase : Cpu;\n          return (\n            <div key={item.id} onClick={() => { setSelected(item); setFormR(item.rev); }} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 hover:border-white/15 cursor-pointer flex flex-col justify-between h-[180px] transition-all\">\n              <div className=\"flex justify-between items-start\"><span className=\"text-[10px] text-white/40\">{item.id}</span><span className=\"text-rose-400 border border-rose-500/20 bg-rose-500/5 px-1.5 py-0.2 rounded font-bold uppercase text-[9px]\">{item.sev}</span></div>\n              <h4 className=\"text-[11.5px] font-bold leading-normal truncate\">{item.title}</h4>\n              <div className=\"pt-2 border-t border-white/5 flex justify-between text-[10px] text-white/50\"><div className=\"flex items-center gap-1\"><ScopeIcon className=\"w-3 h-3 text-white/30\" /><span>{item.name}</span></div><span>Reviewer: {item.rev}</span></div>\n            </div>\n          );\n        })}\n      </div>\n\n      {sel && (\n        <div className=\"fixed inset-0 z-40 flex justify-end\">\n          <div onClick={() => setSel(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n          <div className=\"relative w-full sm:w-[350px] h-full bg-[#030303] border-l border-white/10 p-4 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <div className=\"flex justify-between items-center\"><span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME ({sel.id})</span><button onClick={() => setSel(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\"><X className=\"w-4 h-4\" /></button></div>\n              <h3 className=\"text-xs font-bold leading-normal text-white\">{sel.title}</h3>\n              <p className=\"text-[10px] leading-relaxed text-white/70 bg-black/40 p-2.5 rounded border border-white/5 leading-relaxed\">{sel.desc}</p>\n              <form onSubmit={handleApply} className=\"space-y-3.5 border-t border-b border-white/5 py-3\">\n                <div>\n                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n                  <select value={formR} onChange={e => setFormR(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n                    {REVIEWERS.map(r => <option key={r} value={r}>{r}</option>)}\n                  </select>\n                </div>\n                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-black uppercase font-bold text-[9.5px] rounded flex items-center justify-center gap-1 cursor-pointer\">Apply Overrides <Check className=\"w-3 h-3\" /></button>\n              </form>\n            </div>\n            <div className=\"text-center text-[8.5px] text-white/30\">SECURE LINK ACTIVE</div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
