cking-widest block font-bold flex items-center gap-2\">\n453 |                             <Key className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Multi-Factor OTP Code\n454 |                           </label>\n455 |                           <div className=\"flex items-center gap-2\">\n456 |                             <div className=\"flex items-center gap-1.5 text-[9px] font-mono text-zinc-500\">\n457 |                               <span className=\"text-[#009DFF] font-semibold\">{mfaTimeRemaining}s</span>\n458 |                               <svg className=\"w-3.5 h-3.5\" viewBox=\"0 0 20 20\">\n459 |                                 <circle cx=\"10\" cy=\"10\" r=\"7\" fill=\"none\" stroke=\"#27272a\" strokeWidth=\"1.5\" />\n460 |                                 <circle \n461 |                                   cx=\"10\" \n462 |                                   cy=\"10\" \n463 |                                   r=\"7\" \n464 |                                   fill=\"none\" \n465 |                                   stroke=\"#009DFF\" \n466 |                                   strokeWidth=\"1.5\" \n467 |                                   strokeDasharray={`${2 * Math.PI * 7}`}\n468 |                                   strokeDashoffset={`${2 * Math.PI * 7 * (1 - mfaTimeRemaining / 30)}`}\n469 |                                   strokeLinecap=\"round\"\n470 |                                   className=\"transition-all duration-1000 ease-linear\"\n471 |                                 />\n472 |                               </svg>\n473 |                             </div>\n474 |                             <button\n475 |                               type=\"button\"\n476 |                               onClick={() => {\n477 |                                 logTelemetry(\"[SYS] Requested simulation OTP broadcast. Code generated: 102486\");\n478 |                                 setOtpCode(\"102486\");\n479 |                                 setError(\"\");\n480 |          