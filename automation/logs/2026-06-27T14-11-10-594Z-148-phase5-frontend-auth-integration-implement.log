              <span>FORCE DEPLOY SIMULATION</span>\n443 |                             <ArrowRight className=\"w-2.5 h-2.5 transform group-hover:translate-x-1 transition-transform text-white/40 group-hover:text-cyan-400\" />\n444 |                           </>\n445 |                         )}\n446 |                       </div>\n447 |                     </button>\n448 |                   );\n449 |                 })}\n450 |               </div>\n451 |             </div>\n452 |           </div>\n453 |         </div>\n454 |       </div>\n455 |     );\n456 |   }\n457 | \n458 |   // SCREEN 2: Clearance Insufficient / Restricted Boundary (Split-Panel Layout)\n459 |   if (!hasAccess) {\n460 |     const authorizedRoles = getAuthorizedRoles();\n461 | \n462 |     return (\n463 |       <div className=\"min-h-screen grid grid-cols-1 lg:grid-cols-12 bg-[#030303] text-white font-sans antialiased selection:bg-red-500/20 selection:text-red-300\">\n464 |         \n465 |         {/* Left Side: Real-time interactive access matrix visual timeline & logs (Desktop only) */}\n466 |         <div className=\"hidden lg:flex lg:col-span-5 border-r border-white/5 bg-[#050505]/60 flex-col justify-between p-10 font-mono\">\n467 |           <div className=\"space-y-6\">\n468 |             <div className=\"flex items-center gap-2 text-white/30 text-[9px] uppercase tracking-widest font-bold\">\n469 |               <Shield className=\"w-3.5 h-3.5 text-red-500\" />\n470 |               <span>GFF Cryptographic Firewall</span>\n471 |             </div>\n472 |             \n473 |             {/* Visual Timeline of Clearance levels */}\n474 |             <div className=\"space-y-4\">\n475 |               <div className=\"text-zinc-400 text-xs font-mono font-bold tracking-wider uppercase mb-3 flex items-center gap-2\">\n476 |                 <Shield className=\"w-4 h-4 text-zinc-400\" />\n477 |                 Active Access Matrix\n478 |               </div>\n479 |               \n480 |               <div className=\"space-y-3 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[1px] before:bg-white/10\">\n481 |                 {CLEARANCE_TIERS.map((tier) => {\n482 |                   const isCurrent = tier.roles.includes(session.role);\n483 |                   const isRouteAllowed = tier.roles.some(r => \n484 |                     type === \"portal\" \n485 |                       ? canAccessPortalSection(r as PreviewRole, activeSec) \n486 |                       : canAccessAdminSection(r as PreviewRole, activeSec)\n487 |                   );\n488 | \n489 |                   return (\n490 |                     <div key={tier.level} className={`flex gap-4 relative transition-all duration-300 ${isCurrent ? \"scale-[1.01] translate-x-0.5\" : \"\"}`}>\n491 |                       <div className=\"relative z-10 flex items-center justify-center\">\n492 |                         {isCurrent ? (\n493 |                           <div className=\"w-6 h-6 rounded-full bg-red-950/80 border border-red-500 flex items-center justify-center animate-pulse shadow-[0_0_12px_rgba(239,68,68,0.4)]\">\n494 |                             <span className=\"w-2 h-2 rounded-full bg-red-500\" />\n495 |                           </div>\n496 |                         ) : isRouteAllowed ? (\n497 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-900 border border-emerald-500/30 flex items-center justify-center\">\n498 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" />\n499 |                           </div>\n500 |                         ) : (\n501 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-950 border border-white/10 flex items-center justify-center\">\n502 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-zinc-700\" />\n503 |                           </div>\n504 |                         )}\n505 |                       </div>\n506 | \n507 |                       <div className={`flex-1 p-3.5 rounded-xl border transition-all ${\n508 |                         isCurrent \n509 |                           ? \"bg-red-500/[0.02] border-red-500/20 shadow-[0_4px_20px_rgba(239,68,68,0.05)]\" \n510 |                           : isRouteAllowed \n511 |                             ? \"bg-white/[0.01] border-white/10\" \n512 |                             : \"bg-black/40 border-white/5 opacity-40\"\n513 |                       }`}>\n514 |                         <div className=\"flex items-center justify-between\">\n515 |                           <div className=\"flex items-center gap-2\">\n516 |                             <span className=\"text-[9px] font-mono font-bold tracking-wider text-white/50\">{tier.level}</span>\n517 |                             <span className=\"text-[10px] font-bold text-white tracking-wide uppercase\">{tier.name}</span>\n518 |                           </div>\n519 |                           <div>\n520 |                             {isCurrent ? (\n521 |                               <span className=\"text-[8px] font-mono text-red-400 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-widest\">Active Identity</span>\n522 |                             ) : isRouteAllowed ? (\n523 |                               <span className=\"text-[8px] font-mono text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-widest font-semibold\">Allowed</span>\n524 |                             ) : (\n525 |                               <span className=\"text-[8px] font-mono text-white/30 bg-white/5 border border-white/10 px-2 py-0.5 rounded uppercase font-bold tracking-widest font-semibold\">Restricted</span>\n526 |                             )}\n527 |                           </div>\n528 |                         </div>\n529 |                         <div className=\"mt-1.5 text-[9.5px] text-zinc-500 leading-normal\">\n530 |                           Authorized: <span className=\"text-zinc-400 font-mono\">{tier.roles.map(r => ROLE_METADATA[r as PreviewRole]?.title).join(\", \")}</span>\n531 |                         </div>\n532 |                       </div>\n533 |                     </div>\n534 |                   );\n535 |                 })}\n536 |               </div>\n537 |             </div>\n538 |           </div>\n539 | \n540 |           {/* Telemetry log terminal */}\n541 |           <div className=\"bg-black/50 border border-white/5 rounded-xl p-4 font-mono text-[9px] text-zinc-500 space-y-1.5 shadow-inner mt-6\">\n542 |             <div className=\"flex items-center justify-between text-[8px] text-zinc-400 border-b border-white/5 pb-1.5 mb-2 select-none\">\n543 |               <span className=\"flex items-center gap-1.5\">\n544 |                 <span className=\"w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse\" />\n545 |                 SECURE TELEMETRY BUFFER\n546 |               </span>\n547 |               <span>UTC LOGS</span>\n548 |             </div>\n549 |             <div className=\"space-y-1 select-text h-[70px] overflow-hidden flex flex-col justify-end\" aria-live=\"polite\">\n550 |               {terminalLogs.map((log, idx) => (\n551 |                 <div key={idx} className={log.includes(\"WARNING\") || log.includes(\"BLOCK\") ? \"text-red-400 font-bold\" : log.includes(\"AUTHORIZED\") ? \"text-emerald-400 font-bold\" : \"text-zinc-500\"}>\n552 |                   {log}\n553 |                 </div>\n554 |               ))}\n555 |             </div>\n556 |           </div>\n557 |         </div>\n558 | \n559 |         {/* Right Side: Identity swap & fallback triggers (Interactive form) */}\n560 |         <div className=\"col-span-1 lg:col-span-7 flex flex-col justify-center p-6 md:p-12 lg:p-16 max-w-2xl mx-auto w-full\">\n561 |           <div className=\"space-y-8\">\n562 |             <div className=\"space-y-3\">\n563 |               <span className=\"text-[8px] tracking-widest font-bold uppercase px-2.5 py-1 rounded bg-red-500/10 border border-red-500/20 text-red-400 select-none\">\n564 |                 RESTRICTED SEGMENT BOUNDARY\n565 |               </span>\n566 |               <h1 className=\"text-2xl md:text-3xl font-extrabold tracking-tight text-white uppercase font-sans\">\n567 |                 Clearance Insufficient\n568 |               </h1>\n569 |               <p className=\"text-[11px] md:text-xs text-zinc-400 leading-relaxed font-sans max-w-md\">\n570 |                 Your simulated workspace identity holds <strong className=\"text-red-400 font-mono text-[10.5px] font-bold uppercase\">{session.role.toUpperCase()}</strong> authority. Your token is invalid for network segment <strong className=\"text-white\">/{type}/{activeSec}</strong>.\n571 |               </p>\n572 |             </div>\n573 | \n574 |             {/* Current token context overview */}\n575 |             <div className=\"p-4 rounded-xl border border-white/5 bg-zinc-950/40 space-y-2.5 font-mono text-[9.5px]\">\n576 |               <div className=\"text-[8px] text-zinc-500 font-bold uppercase tracking-widest flex items-center gap-1.5\">\n577 |                 <Terminal className=\"w-3.5 h-3.5 text-red-500\" />\n578 |                 Active Sandbox Session Payload\n579 |               </div>\n580 |               <div className=\"grid grid-cols-2 gap-4 p-3 bg-black/40 border border-white/5 rounded-lg text-zinc-400\">\n581 |                 <div>\n582 |                   <div className=\"text-[7.5px] text-zinc-600 font-bold\">SESSION SIGNATURE</div>\n583 |                   <div className=\"text-white font-bold truncate mt-0.5\">{session.name}</div>\n584 |                 </div>\n585 |                 <div>\n586 |                   <div className=\"text-[7.5px] text-zinc-600 font-bold\">CRYPTO AUTH CLEARANCE</div>\n587 |                   <div className=\"text-red-400 font-bold truncate mt-0.5\">{session.clearance}</div>\n588 |                 </div>\n589 |               </div>\n590 |             </div>\n591 | \n592 |             {/* Swap & Elevation options */}\n593 |             <div className=\"space-y-4\">\n594 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2 select-none\">\n595 |                 <span className=\"text-[9px] font-mono text-zinc-500 font-bold uppercase tracking-widest\">\n596 |                   Resolve Access Exception\n597 |                 </span>\n598 |                 <span className=\"text-[8px] font-mono text-emerald-400 font-semibold font-bold\">\n599 |                   AVAILABLE CLEARANCES\n600 |                 </span>\n601 |               </div>\n602 |               \n603 |               <p className=\"text-[10px] text-zinc-500 leading-relaxed\">\n604 |                 Step back to segment safety, or temporarily elevate your simulated token using one of the authorized profiles for this route segment:\n605 |               </p>\n606 | \n607 |               <div className=\"space-y-2\">\n608 |                 {authorizedRoles.length > 0 ? (\n609 |                   authorizedRoles.map((roleId) => {\n610 |                     const meta = ROLE_METADATA[roleId];\n611 |                     const isNegotiating = negotiating === roleId;\n612 | \n613 |                     return (\n614 |                       <button\n615 |                         key={roleId}\n616 |                         onClick={() => handleBypass(roleId)}\n617 |                         disabled={negotiating !== null}\n618 |                         className=\"w-full text-left p-3.5 rounded-xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all duration-300 group flex items-center justify-between cursor-pointer hover:border-white/12 disabled:opacity-45 focus-visible:outline focus-visible:outline-1 focus-visible:outline-cyan-500\"\n619 |                         style={{\n620 |                           boxShadow: isNegotiating ? `