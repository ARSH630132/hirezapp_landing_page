72 |         ...prev,\n173 |         `[KEY_NEG] Requesting cryptographic validation for role: ${negotiating.toUpperCase()}`,\n174 |         `[ZKP_VAL] Issuing Zero-Knowledge Challenge to authenticator node... [OK]`\n175 |       ]);\n176 |     }, 150);\n177 | \n178 |     const timer2 = setTimeout(() => {\n179 |       setTerminalLogs(prev => [\n180 |         ...prev,\n181 |         `[SYS_SEC] BOUNDARY TRAVERSAL AUTHORIZED. Token reissued.`,\n182 |         `[ROUTING] Stack relocation committed. Rebuilding page frame...`\n183 |       ]);\n184 |     }, 600);\n185 | \n186 |     return () => {\n187 |       clearTimeout(timer1);\n188 |       clearTimeout(timer2);\n189 |     };\n190 |   }, [negotiating]);\n191 | \n192 |   // Automatic redirect to standard login if no session is set up\n193 |   useEffect(() => {\n194 |     if (!mounted || loading || session || negotiating) return;\n195 |     const interval = setInterval(() => {\n196 |       setCountdown((p) => {\n197 |         if (p <= 1) { \n198 |           clearInterval(interval); \n199 |           router.push(type === \"admin\" ? \"/admin/login\" : \"/portal/login\"); \n200 |           return 0; \n201 |         }\n202 |         return p - 1;\n203 |       });\n204 |     }, 1000);\n205 |     return () => clearInterval(interval);\n206 |   }, [session, loading, mounted, router, negotiating, type]);\n207 | \n208 |   // Intelligent bypass helper: holds the user on the same path if the new role is authorized!\n209 |   const handleBypass = (role: PreviewRole) => {\n210 |     setNegotiating(role);\n211 |     setTimeout(() => {\n212 |       setPreviewSession(role);\n213 |       setNegotiating(null);\n214 |       \n215 |       const segments = pathname.split(\"/\");\n216 |       const sec = segments[2] || \"dashboard\";\n217 |       const allowed = type === \"portal\" ? canAccessPortalSection(role, sec) : canAccessAdminSection(role, sec);\n218 |       \n219 |       if (allowed) {\n220 |         // Refresh or traverse cleanly to the exact page they requested\n221 |         router.push(pathname);\n222 |       } else {\n223 |         // Fall back to dashboard of the respective section\n224 |         router.push(role.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n225 |       }\n226 |     }, 1000);\n227 |   };\n228 | \n229 |   // Helper to dynamically calculate which roles are authorized for the blocked section\n230 |   const getAuthorizedRoles = (): PreviewRole[] => {\n231 |     return ALL_ROLES.filter(role => \n232 |       type === \"portal\" \n233 |         ? canAccessPortalSection(role, activeSec) \n234 |         : canAccessAdminSection(role, activeSec)\n235 |     );\n236 |   };\n237 | \n238 |   if (!mounted) return <div className=\"min-h-screen bg-[#030303]\" />;\n239 | \n240 |   // Verify loading state\n241 |   if (loading) {\n242 |     return (\n243 |       <div className=\"min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n244 |         <RefreshCw className=\"w-5 h-5 text-cyan-400 animate-spin mx-auto mb-3\" />\n245 |         <p className=\"text-[10px] uppercase tracking-widest text-white/40\">Securing Local Decoupled Enclave...</p>\n246 |       </div>\n247 |     );\n248 |   }\n249 | \n250 |   // SCREEN 1: Enclave Session Expired / Authentication Required (Split-Panel Layout)\n251 |   if (!session) {\n252 |     const pct = (countdown / 5) * 100;\n253 |     const simProfiles: PreviewRole[] = [\"client_admin\", \"gff_admin\", \"gff_operator\", \"client_member\"];\n254 | \n255 |     return (\n256 |       <div className=\"min-h-screen grid grid-cols-1 lg:grid-cols-12 bg-[#030303] text-white font-sans antialiased selection:bg-cyan-500/20 selection:text-cyan-300\">\n257 |         \n258 |         {/* Left Side: Dynamic Architecture Visualization & Live Log terminal (Desktop only) */}\n259 |         <div className=\"hidden lg:flex lg:col-span-5 border-r border-white/5 bg-[#050505]/60 flex-col justify-between p-10 font-mono\">\n260 