\n116 |   useEffect(() => { setMounted(true); }, []);\n117 | \n118 |   // Sync session and access rules\n119 |   useEffect(() => {\n120 |     if (!mounted) return;\n121 |     const verify = () => {\n122 |       const s = getPreviewSession();\n123 |       setSession(s);\n124 |       const sec = pathname.split(\"/\")[2] || \"dashboard\";\n125 |       setActiveSec(sec);\n126 |       setHasAccess(type === \"portal\" ? canAccessPortalSection(s?.role || \"viewer\", sec) : canAccessAdminSection(s?.role || \"viewer\", sec));\n127 |       setLoading(false);\n128 |     };\n129 |     verify();\n130 |     window.addEventListener(\"gff_preview_session_changed\", verify);\n131 |     return () => window.removeEventListener(\"gff_preview_session_changed\", verify);\n132 |   }, [pathname, type, mounted]);\n133 | \n134 |   // Terminal logging logic for live security console simulation\n135 |   useEffect(() => {\n136 |     if (!mounted) return;\n137 |     const defaultLogs = [\n138 |       `[SYS_SEC] INITIALIZING SECURE TUNNEL PROTOCOL...`,\n139 |       `[SYS_SEC] ZONE: /${type.toUpperCase()}/${activeSec.toUpperCase()}`,\n140 |       session \n141 |         ? `[SYS_SEC] IDENT_FOUND: Simulated role holds ${session.clearance}`\n142 |         : `[SYS_SEC] WARNING: CLIENT_TOKEN_NOT_FOUND (DECOUPLED)`,\n143 |       session && !hasAccess\n144 |         ? `[SYS_SEC] ENFORCE BLOCK: INSUFFICIENT_CLEARANCE_EXCEPTION`\n145 |         : `[SYS_SEC] STANDBY: Awaiting credential matrix verification...`\n146 |     ];\n147 |     setTerminalLogs(defaultLogs);\n148 | \n149 |     // Dynamic low-noise polling telemetry logs\n150 |     const interval = setInterval(() => {\n151 |       if (negotiating) return; // let negotiating logs stay in focus\n152 |       const phrases = [\n153 |         `[KEY_ROT] Rotating CRYSTALS-Dilithium cryptographic headers...`,\n154 |         `[ZKP_VAL] Verification session polling active... [STABLE]`,\n155 |         `[SYS_SEC] Handshake buffer check: 0x7FFA${Math.floor(Math.random() * 9000 + 1000)}B90C`,\n156 |         `[FIREWALL] Ingress inspection running on decentralized network boundary...`,\n157 |         `[AUDIT] Sovereign consensus ledger block committed to cluster.`\n158 |       ];\n159 |       setTerminalLogs(prev => [...prev.slice(-5), phrases[Math.floor(Math.random() * phrases.length)]]);\n160 |     }, 5000);\n161 | \n162 |     return () => clearInterval(interval);\n163 |   }, [activeSec, type, session, hasAccess, mounted, negotiating]);\n164 | \n165 |   // Handle live negotiating state logging\n166 |   useEffect(() => {\n167 |     if (!negotiating) return;\n168 |     const meta = ROLE_METADATA[negotiating];\n169 |     \n170 |     const timer1 = setTimeout(() => {\n171 |       setTerminalLogs(prev => [\n172 |         ...prev,\n173 |         `[KEY_NEG] Requesting cryptographic validation for role: ${negotiating.toUpperCase()}`,\n174 |         `[ZKP_VAL] Issuing Zero-Knowledge Challenge to authenticator node... [OK]`\n175 |       ]);\n176 |     }, 150);\n177 | \n178 |     const timer2 = setTimeout(() => {\n179 |       setTerminalLogs(prev => [\n180 |         ...prev,\n181 |         `[SYS_SEC] BOUNDARY TRAVERSAL AUTHORIZED. Token reissued.`,\n182 |         `[ROUTING] Stack relocation committed. Rebuilding page frame...`\n183 |       ]);\n184 |     }, 600);\n185 | \n186 |     return () => {\n187 |       clearTimeout(timer1);\n188 |       clearTimeout(timer2);\n189 |     };\n190 |   }, [negotiating]);\n191 | \n192 |   // Automatic redirect to standard login if no session is set up\n193 |   useEffect(() => {\n194 |     if (!mounted || loading || session || negotiating) return;\n195 |     const interval = setInterval(() => {\n196 |       setCountdown((p) => {\n197 |         if (p <= 1) { \n198 |           clearInterval(interval); \n199 |           router.push(type === \"admin\" ? \"/admin/login\" : \"/portal/login\"); \n200 |           return 0; \n201 |         }\n202 |         return p - 1;\n203 |       });\n204 |     }, 1000);\n205 |     return () => clearInterval(interval);\n206 |   }, [session, loading, mounted, router, negotiating, type]);\n207 | \n208 |   // Intelligent bypass helper: holds the user on the same path if the new role is authorized!\n209 |   const handleBypass = (role: PreviewRole) => {\n210 |     setNegotiating(role);\n211 |     setTimeout(() => {\n212 |       setPreviewSession(role);\n213 |       setNegotiating(null);\n214 |       \n215 |       const segments = pathname.split(\"/\");\n216 |       const sec = segments[2] || \"dashboard\";\n217 |       const allowed = type === \"portal\" ? canAccessPortalSection(role, sec) : canAccessAdminSection(role, sec);\n218 |       \n219 |       if (allowed) {\n220 |         // Refresh or traverse cleanly to the exact page they requested\n221 |         router.push(pathname);\n222 |       } else {\n223 |         // Fall back to dashboard of the respective section\n224 |         router.push(role.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n225 |       }\n226 |     }, 1000);\n227 |   };\n228 | \n229 |   // Helper to dynamically calculate which roles are authorized for the blocked section\n230 |   const getAuthorizedRoles = (): PreviewRole[] => {\n231 |     return ALL_ROLES.filter(role => \n232 |       type === \"portal\" \n233 |         ? canAccessPortalSection(role, activeSec) \n234 |         : canAccessAdminSection(role, activeSec)\n235 |     );\n236 |   };\n237 | \n238 |   if (!mounted) return <div className=\"min-h-screen bg-[#030303]\" />;\n239 | \n240 |   // Verify loading state\n241 |   if (loading) {\n242 |     return (\n243 |       <div className=\"min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n244 |         <RefreshCw className=\"w-5 h-5 text-cyan-400 animate-spin mx-auto mb-3\" />\n245 |         <p className=\"text-[10px] uppercase tracking-widest text-white/40\">Securing Local Decoupled Enclave...</p>\n246 |       </div>\n247 |     );\n248 |   }\n249 | \n250 |   // SCREEN 1: Enclave Session Expired / Authentication Required (Split-Panel Layout)\n251 |   if (!session) {\n252 |     const pct = (countdown / 5) * 100;\n253 |     const simProfiles: PreviewRole[] = [\"client_admin\", \"gff_admin\", \"gff_operator\", \"client_member\"];\n254 | \n255 |     return (\n256 |       <div className=\"min-h-screen grid grid-cols-1 lg:grid-cols-12 bg-[#030303] text-white font-sans antialiased selection:bg-cyan-500/20 selection:text-cyan-300\">\n257 |         \n258 |         {/* Left Side: Dynamic Architecture Visualization & Live Log terminal (Desktop only) */}\n259 |         <div className=\"hidden lg:flex lg:col-span-5 border-r border-white/5 bg-[#050505]/60 flex-col justify-between p-10 font-mono\">\n260 |           <div className=\"space-y-4\">\n261 |             <div className=\"flex items-center gap-2 text-white/30 text-[9px] uppercase tracking-widest font-bold\">\n262 |               <Network className=\"w-3.5 h-3.5 text-cyan-500\" />\n263 |               <span>GFF Security Architecture Node</span>\n264 |             </div>\n265 |             <h3 className=\"text-xs font-bold text-white tracking-wider uppercase\">Zero-Knowledge Trust Enclave</h3>\n266 |             <p className=\"text-[11px] text-zinc-500 leading-relaxed font-sans\">\n267 |               To support decoupled localized testing, GFF AI utilizes client-side zero-knowledge session assertions. All data remains federated and isolated.\n268 |             </p>\n269 |           </div>\n270 | \n271 |           {/* SVG Connection Network map */}\n272 |           <div className=\"my-8 flex items-center justify-center\">\n273 |             <svg className=\"w-full max-w-[280px] h-48\" viewBox=\"0 0 400 300\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n274 |               <defs>\n275 |                 <pattern id=\"diag-grid\" width=\"20\" height=\"20\" patternUnits=\"userSpaceOnUse\">\n276 |                   <path d=\"M 20 0 L 0 0 0 20\" fill=\"none\" stroke=\"