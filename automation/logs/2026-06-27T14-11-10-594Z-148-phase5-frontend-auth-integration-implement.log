                             onClick={() => {\n477 |                                 logTelemetry(\"[SYS] Requested simulation OTP broadcast. Code generated: 102486\");\n478 |                                 setOtpCode(\"102486\");\n479 |                                 setError(\"\");\n480 |                                 setTimeout(() => otpRefs[5].current?.focus(), 50);\n481 |                               }}\n482 |                               className=\"px-2 py-0.5 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF] font-mono text-[8.5px] font-bold tracking-wider hover:bg-[#009DFF]/25 transition-colors cursor-pointer focus:outline-none\"\n483 |                             >\n484 |                               GENERATE CODE\n485 |                             </button>\n486 |                           </div>\n487 |                         </div>\n488 |                         <div className=\"flex justify-between gap-2.5 max-w-[320px] mx-auto py-2\">\n489 |                           {Array.from({ length: 6 }).map((_, idx) => (\n490 |                             <input\n491 |                               key={idx}\n492 |                               id={`otp-${idx}`}\n493 |                               ref={otpRefs[idx]}\n494 |                               type=\"text\"\n495 |                               inputMode=\"numeric\"\n496 |                               pattern=\"[0-9]*\"\n497 |                               value={otpCode[idx] || \"\"}\n498 |                               onChange={(e) => handleOtpChange(idx, e.target.value)}\n499 |                               onKeyDown={(e) => handleOtpKeyDown(idx, e)}\n500 |                               onPaste={handleOtpPaste}\n501 |                               placeholder=\"•\"\n502 |                               maxLength={1}\n503 |                               className=\"w-10 h-12 rounded-lg bg-zinc-950 border border-zinc-800 text-center text-sm font-bold text-white placeholder-zinc-