          <span className=\"text-[8px] tracking-widest font-bold uppercase px-2.5 py-1 rounded bg-zinc-900 border border-white/5 text-zinc-400 select-none\">\n357 |                 ENCLAVE DISCOVERY GATEWAY\n358 |               </span>\n359 |               <h1 className=\"text-2xl md:text-3xl font-extrabold tracking-tight text-white uppercase font-sans\">\n360 |                 Identity Decoupled\n361 |               </h1>\n362 |               <p className=\"text-[11px] md:text-xs text-zinc-400 leading-relaxed font-sans max-w-md\">\n363 |                 No simulated preview session is currently associated with your browser client. To access the interactive sandbox of GFF AI, authorize your token.\n364 |               </p>\n365 |             </div>\n366 | \n367 |             {/* Countdown redirect bar */}\n368 |             <div className=\"space-y-1.5 bg-zinc-950/40 p-4 rounded-xl border border-white/5\">\n369 |               <div className=\"flex justify-between items-center text-[9px] font-mono text-zinc-500 tracking-wider\">\n370 |                 <span className=\"flex items-center gap-1.5\">\n371 |                   <RefreshCw className=\"w-3 h-3 text-red-500 animate-spin\" />\n372 |                   STANDBY: REDIRECTING TO IDENTITY GATEWAY\n373 |                 </span>\n374 |                 <span className=\"font-bold\">{countdown}S</span>\n375 |               </div>\n376 |               <div className=\"h-1 bg-zinc-900 border border-white/5 rounded-full overflow-hidden\">\n377 |                 <div \n378 |                   className=\"h-full bg-red-500/80 transition-all duration-1000 ease-linear\" \n379 |                   style={{ width: `${pct}%` }} \n380 |                 />\n381 |               </div>\n382 |               <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n383 |                 <button \n384 |                   onClick={() => router.push(type === \"admin\" ? \"/admin/login\" : \"/portal/login\")}\n385 |                   class