{"ts":"2026-06-27T07:21:12.583Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"02lhke1b","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/billing/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { FinancialLedgerTab } from \"../admin-tabs-part2\";\n\nexport default function AdminBillingPage() {\n  return <FinancialLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo, useEffect } from \"react\";\nimport { \n  FileText, Search, Plus, Filter, Download, Check, Lock, Shield, \n  Activity, RefreshCw, SlidersHorizontal, ChevronRight, X, Key, \n  Database, Cpu, Sparkles, Calendar, CreditCard, CheckCircle2, AlertTriangle, AlertCircle\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\nimport { previewClientAccounts, previewProjects } from \"@/lib/mock-data-model\";\n\ninterface ExtendedInvoice {\n  id: string;\n  date: string;\n  amount: number;\n  status: \"paid\" | \"unpaid\" | \"processing\" | \"overdue\";\n  dueDate: string;\n  category: \"Compute Epoch\" | \"SLA Support\" | \"Telemetry Stream\" | \"Premium Support\";\n  clientId: string;\n  clientName: string;\n  projectId: string;\n  projectName: string;\n  hash: string;\n  billingMonth: string;\n}\n\nconst INITIAL_INVOICES: ExtendedInvoice[] = [\n  {\n    id: \"GFF-2026-0899\",\n    date: \"2026-06-01\",\n    amount: 14820.00,\n    status: \"paid\",\n    dueDate: \"2026-06-15\",\n    category: \"Compute Epoch\",\n    clientId: \"client-001\",\n    clientName: \"Apex Sovereign Group [Preview Client]\",\n    projectId: \"proj-001\",\n    projectName: \"Sovereign Core Sandbox 02\",\n    hash: \"0xDE897FF021BC8102C019FFAD998E1256E3B890CC7FFADE138EE87A02FF90A11B\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0914\",\n    date: \"2026-06-15\",\n    amount: 3500.00,\n    status: \"paid\",\n    dueDate: \"2026-06-30\",\n    category: \"SLA Support\",\n    clientId: \"client-002\",\n    clientName: \"Global Retail Enclave [Preview Client]\",\n    projectId: \"proj-003\",\n    projectName: \"Sovereign Mining Intel Loop\",\n    hash: \"0x11B8A02FEE907C10BDE8267FEE10BC91A23D4FFA289F02ECBC12A349CDE150FA\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0945\",\n    date: \"2026-06-25\",\n    amount: 24900.00,\n    status: \"processing\",\n    dueDate: \"2026-07-10\",\n    category: \"Telemetry Stream\",\n    clientId: \"client-001\",\n    clientName: \"Apex Sovereign Group [Preview Client]\",\n    projectId: \"proj-002\",\n    projectName: \"Model Guardrail Sandbox 04\",\n    hash: \"0x8FDE3102C130D7B2D26788AB0E8A850CE3207FFCDE10B74E824A45B12A4F23AA\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0988\",\n    date: \"2026-06-27\",\n    amount: 8250.00,\n    status: \"unpaid\",\n    dueDate: \"2026-07-15\",\n    category: \"Compute Epoch\",\n    clientId: \"client-004\",\n    clientName: \"Federal Treasury Division [Preview Client]\",\n    projectId: \"proj-004\",\n    projectName: \"Federal Ledger Enclave Alpha\",\n    hash: \"0x3FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89FBC10492\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-1011\",\n    date: \"2026-05-12\",\n    amount: 19500.00,\n    status: \"overdue\",\n    dueDate: \"2026-05-26\",\n    category: \"Premium Support\",\n    clientId: \"client-003\",\n    clientName: \"Sovereign Logistics Unit [Preview Client]\",\n    projectId: \"proj-001\",\n    projectName: \"Sovereign Logistics Thread Map\",\n    hash: \"0xBC04923FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89F\",\n    billingMonth: \"2026-05\"\n  }\n];\n\nexport default function AdminBillingPage() {\n  const [invoices, setInvoices] = useState<ExtendedInvoice[]>(INITIAL_INVOICES);\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedClient, setSelectedClient] = useState(\"all\");\n  const [selectedStatus, setSelectedStatus] = useState(\"all\");\n  const [selectedMonth, setSelectedMonth] = useState(\"all\");\n\n  const [activeInvoice, setActiveInvoice] = useState<ExtendedInvoice | null>(null);\n  const [isCreateOpen, setIsCreateOpen] = useState(false);\n  const [toast, setToast] = useState<{ m: string; t: \"s\" | \"e\" | \"i\" } | null>(null);\n\n  // New Invoice Form State\n  const [newClientId, setNewClientId] = useState(\"\");\n  const [newProjectId, setNewProjectId] = useState(\"\");\n  const [newCategory, setNewCategory] = useState<ExtendedInvoice[\"category\"]>(\"Compute Epoch\");\n  const [newAmount, setNewAmount] = useState(\"\");\n  const [newDueDate, setNewDueDate] = useState(\"\");\n  const [newStatus, setNewStatus] = useState<ExtendedInvoice[\"status\"]>(\"unpaid\");\n  const [newMonth, setNewMonth] = useState(\"2026-06\");\n\n  // Signing Loop State\n  const [isSigning, setIsSigning] = useState(false);\n  const [signingStep, setSigningStep] = useState(0);\n  const signingLogs = [\n    \"Establishing AMD SEV-SNP secure socket...\",\n    \"Retrieving kernel thread metrics (eBPF)...\",\n    \"Loading ECC-256 HSM Handshake Key...\",\n    \"Signing telemetry digest & committing blocks...\"\n  ];\n\n  const [isDownloading, setIsDownloading] = useState(false);\n  const [isProcessing, setIsProcessing] = useState(false);\n\n  const triggerToast = (m: string, t: \"s\" | \"e\" | \"i\" = \"s\") => {\n    setToast({ m, t });\n    setTimeout(() => setToast(null), 3500);\n  };\n\n  useEffect(() => {\n    let timer: NodeJS.Timeout;\n    if (isSigning) {\n      if (signingStep < signingLogs.length - 1) {\n        timer = setTimeout(() => setSigningStep(p => p + 1), 600);\n      } else {\n        timer = setTimeout(() => {\n          const clientObj = previewClientAccounts.find(c => c.id === newClientId);\n          const projectObj = previewProjects.find(p => p.id === newProjectId);\n          const nextIdNum = Math.max(...invoices.map(i => parseInt(i.id.split(\"-\")[2]))) + 1;\n          const invoiceId = `GFF-2026-${String(nextIdNum).padStart(4, \"0\")}`;\n          const hashHex = `0x${Array.from({length: 40}, () => Math.floor(Math.random()*16).toString(16)).join(\"\").toUpperCase()}`;\n\n          const newRecord: ExtendedInvoice = {\n            id: invoiceId,\n            date: new Date().toISOString().split(\"T\")[0],\n            amount: parseFloat(newAmount) || 0,\n            status: newStatus,\n            dueDate: newDueDate || new Date(Date.now() + 14*24*60*60*1000).toISOString().split(\"T\")[0],\n            category: newCategory,\n            clientId: newClientId,\n            clientName: clientObj ? clientObj.name : \"Sovereign Enterprise\",\n            projectId: newProjectId,\n            projectName: projectObj ? projectObj.name : \"Enclave Sandbox\",\n            hash: hashHex,\n            billingMonth: newMonth\n          };\n\n          setInvoices(p => [newRecord, ...p]);\n          setIsSigning(false);\n          setSigningStep(0);\n          setIsCreateOpen(false);\n          setNewClientId(\"\");\n          setNewAmount(\"\");\n          setNewDueDate(\"\");\n          triggerToast(`Invoice ${invoiceId} signed & archived.`, \"s\");\n        }, 700);\n      }\n    }\n    return () => clearTimeout(timer);\n  }, [isSigning, signingStep]);\n\n  const filteredProjects = useMemo(() => {\n    if (!newClientId) return [];\n    return previewProjects.filter(p => p.clientAccountId === newClientId);\n  }, [newClientId]);\n\n  useEffect(() => {\n    if (filteredProjects.length > 0) setNewProjectId(filteredProjects[0].id);\n    else setNewProjectId(\"\");\n  }, [newClientId, filteredProjects]);\n\n  const stats = useMemo(() => {\n    let total = 0, settled = 0, processing = 0, unpaid = 0;\n    invoices.forEach(i => {\n      total += i.amount;\n      if (i.status === \"paid\") settled += i.amount;\n      else if (i.status === \"processing\") processing += i.amount;\n      else unpaid += i.amount;\n    });\n    return { total, settled, processing, unpaid, count: invoices.length };\n  }, [invoices]);\n\n  const filteredInvoices = useMemo(() => {\n    return invoices.filter(i => {\n      if (searchQuery.trim() !== \"\") {\n        const q = searchQuery.toLowerCase();\n        if (!i.id.toLowerCase().includes(q) && !i.clientName.toLowerCase().includes(q) && !i.projectName.toLowerCase().includes(q)) return false;\n      }\n      if (selectedClient !== \"all\" && i.clientId !== selectedClient) return false;\n      if (selectedStatus !== \"all\" && i.status !== selectedStatus) return false;\n      if (selectedMonth !== \"all\" && i.billingMonth !== selectedMonth) return false;\n      return true;\n    });\n  }, [invoices, searchQuery, selectedClient, selectedStatus, selectedMonth]);\n\n  const handleSettlePayment = (id: string) => {\n    setIsProcessing(true);\n    setTimeout(() => {\n      setInvoices(p => p.map(i => i.id === id ? { ...i, status: \"paid\" } : i));\n      setActiveInvoice(p => p && p.id === id ? { ...p, status: \"paid\" } : p);\n      setIsProcessing(false);\n      triggerToast(`Ledger settled for ${id}.`, \"s\");\n    }, 1000);\n  };\n\n  const handleDownload = (id: string) => {\n    setIsDownloading(true);\n    setTimeout(() => {\n      setIsDownloading(false);\n      triggerToast(`Receipt downloaded for ${id}`, \"s\");\n    }, 800);\n  };\n\n  const formatUSD = (v: number) => new Intl.NumberFormat(\"en-US\", { style: \"currency\", currency: \"USD\" }).format(v);\n\n  return (\n    <div className=\"space-y-6 font-mono text-[11px] text-white\">\n      {/* Toast */}\n      <AnimatePresence>\n        {toast && (\n          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, y: -20 }}\n            className={`fixed top-6 right-6 z-50 flex items-center gap-2 px-4 py-3 rounded-xl border backdrop-blur-md ${\n              toast.t === \"s\" ? \"bg-black/90 border-emerald-500/30 text-emerald-400\" : \"bg-black/90 border-[#009DFF]/30 text-[#009DFF]\"\n            }`}\n          >\n            {toast.t === \"s\" ? <CheckCircle2 className=\"w-4 h-4\" /> : <Shield className=\"w-4 h-4\" />}\n            <span>{toast.m}</span>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      <PrivatePageHeader \n        title=\"FINANCIAL LEDGER OPERATIONS\" \n        desc=\"Internal console to draft client invoice previews, audit HSM resource seals, and verify secure billing blocks.\"\n        actions={\n          <button \n            onClick={() => setIsCreateOpen(true)}\n            className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-mono font-bold uppercase text-white flex items-center gap-1.5 transition-all cursor-pointer border border-white/5 shadow-md\"\n          >\n            <Plus className=\"w-3.5 h-3.5\" />\n            <span>Draft Invoice Preview</span>\n          </button>\n        }\n      />\n\n      {/* SVG Flow diagram */}\n      <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 p-5 space-y-4 relative overflow-hidden\">\n        <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n          <div>\n            <h4 className=\"text-[12px] font-bold tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <Shield className=\"w-4 h-4 text-[#009DFF]\" />\n              <span>SOVEREIGN CRYPTOGRAPHIC SIGNING FLOW</span>\n            </h4>\n            <p className=\"text-[10px] text-white/40 mt-0.5\">Hardware-attested pipeline verifying resource telemetry before drafting ledgers.</p>\n          </div>\n          <div className=\"text-[9.5px] text-emerald-400 bg-emerald-500/5 px-2 py-0.5 rounded border border-emerald-500/20 uppercase font-bold\">\n            HSM Core Active\n          </div>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-2\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex items-start gap-3\">\n            <Cpu className=\"w-5 h-5 text-[#009DFF] shrink-0\" />\n            <div className=\"space-y-1\">\n              <span className=\"text-[11px] font-bold text-white uppercase\">1. eBPF Telemetry</span>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">Continuous hardware resource credit collection from sovereign client nodes.</p>\n            </div>\n          </div>\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex items-start gap-3\">\n            <Key className=\"w-5 h-5 text-emerald-400 shrink-0\" />\n            <div className=\"space-y-1\">\n              <span className=\"text-[11px] font-bold text-white uppercase\">2. HSM Enclave</span>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">ECC-256 hardware security modules cryptographically seal the usage ledger.</p>\n            </div>\n          </div>\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex items-start gap-3\">\n            <Database className=\"w-5 h-5 text-[#00FFC2] shrink-0\" />\n            <div className=\"space-y-1\">\n              <span className=\"text-[11px] font-bold text-white uppercase\">3. Sealed Ledger</span>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">Verified and signed invoice blocks committed securely for admin and client review.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* KPI Stats Grid */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Total Invoiced\", value: formatUSD(stats.total), color: \"text-white\", icon: FileText, desc: `${stats.count} active blocks` },\n          { label: \"Settled Receipts\", value: formatUSD(stats.settled), color: \"text-emerald-400\", icon: Check, desc: \"Sealed ledger blocks\" },\n          { label: \"Awaiting Audit\", value: formatUSD(stats.processing), color: \"text-[#009DFF]\", icon: RefreshCw, desc: \"Processing blocks\" },\n          { label: \"Exposure / Unpaid\", value: formatUSD(stats.unpaid), color: \"text-rose-400\", icon: AlertCircle, desc: \"Pending settlement\" }\n        ].map((stat, idx) => {\n          const Icon = stat.icon;\n          return (\n            <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center\">\n              <div className=\"space-y-1\">\n                <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">{stat.label}</span>\n                <div className={`text-[15px] font-extrabold tracking-tight ${stat.color}`}>{stat.value}</div>\n                <div className=\"text-[8.5px] text-white/35\">{stat.desc}</div>\n              </div>\n              <div className=\"p-2 rounded-lg bg-white/[0.02] border border-white/5 text-white/40\">\n                <Icon className=\"w-4 h-4\" />\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* Filters Panel */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/30 flex flex-col gap-3\">\n        <div className=\"flex justify-between items-center\">\n          <div className=\"flex items-center gap-2 text-white/60\">\n            <SlidersHorizontal className=\"w-4 h-4\" />\n            <span className=\"text-[10px] font-bold uppercase tracking-widest\">QUERY LEDGER INDEX</span>\n          </div>\n          {(searchQuery || selectedClient !== \"all\" || selectedStatus !== \"all\" || selectedMonth !== \"all\") && (\n            <button \n              onClick={() => { setSearchQuery(\"\"); setSelectedClient(\"all\"); setSelectedStatus(\"all\"); setSelectedMonth(\"all\"); }}\n              className=\"text-[9px] text-rose-400 hover:text-rose-300 font-bold uppercase bg-rose-500/5 border border-rose-500/10 px-2 py-0.5 rounded cursor-pointer\"\n            >\n              Reset Filters\n            </button>\n          )}\n        </div>\n\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3\">\n          <div className=\"relative\">\n            <Search className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/35\" />\n            <input \n              type=\"text\" \n              placeholder=\"Query by Code, Client, Project...\" \n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              className=\"w-full h-9 pl-9 pr-3 rounded bg-black/40 border border-white/5 text-[10px] text-white placeholder-white/30 focus:outline-none focus:border-[#009DFF]/40\"\n            />\n          </div>\n\n          <select\n            value={selectedClient}\n            onChange={(e) => setSelectedClient(e.target.value)}\n            className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n          >\n            <option value=\"all\">Sovereign Client: All</option>\n            {previewClientAccounts.map(c => (\n              <option key={c.id} value={c.id}>{c.name.replace(\" [Preview Client]\", \"\")}</option>\n            ))}\n          </select>\n\n          <select\n            value={selectedStatus}\n            onChange={(e) => setSelectedStatus(e.target.value)}\n            className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n          >\n            <option value=\"all\">Status: All</option>\n            <option value=\"paid\">Paid</option>\n            <option value=\"unpaid\">Unpaid</option>\n            <option value=\"processing\">Processing</option>\n            <option value=\"overdue\">Overdue</option>\n          </select>\n\n          <select\n            value={selectedMonth}\n            onChange={(e) => setSelectedMonth(e.target.value)}\n            className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n          >\n            <option value=\"all\">Month: All</option>\n            <option value=\"2026-06\">June 2026</option>\n            <option value=\"2026-05\">May 2026</option>\n          </select>\n        </div>\n      </div>\n\n      {/* Invoices Table */}\n      <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 overflow-hidden\">\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full border-collapse text-left\">\n            <thead>\n              <tr className=\"border-b border-white/5 bg-black/30 text-[9.5px] uppercase text-white/50\">\n                <th className=\"py-3 px-5 font-bold\">Invoice ID</th>\n                <th className=\"py-3 px-5 font-bold\">Client</th>\n                <th className=\"py-3 px-5 font-bold\">Hardware Enclave</th>\n                <th className=\"py-3 px-5 font-bold\">Category</th>\n                <th className=\"py-3 px-5 font-bold text-right\">Amount (USD)</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Due Date</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Status</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Seal Hash</th>\n                <th className=\"py-3 px-5\"></th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-white/[0.03]\">\n              {filteredInvoices.length === 0 ? (\n                <tr>\n                  <td colSpan={9} className=\"py-12 text-center text-white/35\">\n                    No matching ledger blocks found.\n                  </td>\n                </tr>\n              ) : (\n                filteredInvoices.map((inv) => (\n                  <tr \n                    key={inv.id}\n                    onClick={() => setActiveInvoice(inv)}\n                    className=\"hover:bg-white/[0.02] active:bg-white/[0.04] transition-all cursor-pointer group\"\n                  >\n                    <td className=\"py-3 px-5 font-bold text-[#009DFF]\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <FileText className=\"w-3.5 h-3.5 opacity-60 group-hover:opacity-100\" />\n                        <span>{inv.id}</span>\n                      </div>\n                    </td>\n                    <td className=\"py-3 px-5 text-white/80 font-medium\">\n                      <div className=\"truncate max-w-[160px]\">{inv.clientName.replace(\" [Preview Client]\", \"\")}</div>\n                    </td>\n                    <td className=\"py-3 px-5 text-white/60\">\n                      <div className=\"truncate max-w-[150px]\">{inv.projectName}</div>\n                    </td>\n                    <td className=\"py-3 px-5 text-white/40 tracking-wider uppercase text-[9px]\">\n                      {inv.category}\n                    </td>\n                    <td className=\"py-3 px-5 text-right font-extrabold font-mono text-white\">\n                      {formatUSD(inv.amount)}\n                    </td>\n                    <td className=\"py-3 px-5 text-center text-white/50\">{inv.dueDate}</td>\n                    <td className=\"py-3 px-5 text-center\">\n                      <span className={`inline-flex items-center gap-1 rounded px-2 py-0.5 text-[8.5px] font-bold uppercase border ${\n                        inv.status === \"paid\" ? \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\" :\n                        inv.status === \"unpaid\" ? \"bg-amber-400/10 text-amber-400 border-amber-400/25\" :\n                        inv.status === \"processing\" ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\" :\n                        \"bg-rose-500/10 text-rose-400 border-rose-500/25\"\n                      }`}>\n                        <span>{inv.status}</span>\n                      </span>\n                    </td>\n                    <td className=\"py-3 px-5 text-center text-white/30 text-[9px]\">\n                      {inv.hash.slice(0, 10)}...\n                    </td>\n                    <td className=\"py-3 px-5 text-center text-white/20 group-hover:text-white/80\">\n                      <ChevronRight className=\"w-4 h-4 translate-x-0 group-hover:translate-x-0.5 transition-transform\" />\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      {/* Detail Slide-over Drawer */}\n      <AnimatePresence>\n        {activeInvoice && (\n          <div className=\"fixed inset-0 z-40 overflow-hidden\">\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={() => setActiveInvoice(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" />\n            <div className=\"absolute inset-y-0 right-0 flex pl-10\">\n              <motion.div initial={{ x: \"100%\" }} animate={{ x: 0 }} exit={{ x: \"100%\" }} transition={{ type: \"spring\", damping: 25, stiffness: 220 }} className=\"w-screen max-w-md bg-[#050505] border-l border-white/5 flex flex-col justify-between\">\n                <div className=\"p-6 border-b border-white/5 bg-[#0a0a0a] flex items-center justify-between\">\n                  <div className=\"space-y-1\">\n                    <span className=\"text-[9px] text-[#009DFF] font-bold uppercase block\">Ledger Block Attestation</span>\n                    <h3 className=\"text-sm font-extrabold text-white uppercase\">{activeInvoice.id}</h3>\n                  </div>\n                  <button onClick={() => setActiveInvoice(null)} className=\"p-1 rounded-lg border border-white/5 bg-white/[0.02] text-white/40 hover:text-white cursor-pointer\"><X className=\"w-4 h-4\" /></button>\n                </div>\n\n                <div className=\"flex-1 overflow-y-auto p-6 space-y-5\">\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex justify-between items-center\">\n                    <div>\n                      <span className=\"text-[9px] text-white/30 uppercase block\">Attested Amount</span>\n                      <div className=\"text-[17px] font-extrabold text-white\">{formatUSD(activeInvoice.amount)}</div>\n                    </div>\n                    <span className={`inline-flex items-center rounded px-2.5 py-0.5 text-[9px] font-bold uppercase border ${\n                      activeInvoice.status === \"paid\" ? \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\" :\n                      activeInvoice.status === \"unpaid\" ? \"bg-amber-400/10 text-amber-400 border-amber-400/25\" :\n                      activeInvoice.status === \"processing\" ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\" :\n                      \"bg-rose-500/10 text-rose-400 border-rose-500/25\"\n                    }`}>{activeInvoice.status}</span>\n                  </div>\n\n                  <div className=\"space-y-3\">\n                    <span className=\"text-[10px] font-bold text-white/50 uppercase block border-b border-white/5 pb-1\">ENTERPRISE ATTRIBUTES</span>\n                    <div className=\"flex justify-between text-[10.5px]\">\n                      <span className=\"text-white/40\">Sovereign Client</span>\n                      <span className=\"text-white font-bold max-w-[200px] truncate\">{activeInvoice.clientName.replace(\" [Preview Client]\", \"\")}</span>\n                    </div>\n                    <div className=\"flex justify-between text-[10.5px]\">\n                      <span className=\"text-white/40\">Hardware Enclave</span>\n                      <span className=\"text-white font-bold max-w-[200px] truncate\">{activeInvoice.projectName}</span>\n                    </div>\n                    <div className=\"flex justify-between text-[10.5px]\">\n                      <span className=\"text-white/40\">SLA Category</span>\n                      <span className=\"text-[#009DFF] font-bold\">{activeInvoice.category}</span>\n                    </div>\n                    <div className=\"flex justify-between text-[10.5px]\">\n                      <span className=\"text-white/40\">Sealed On</span>\n                      <span className=\"text-white/70\">{activeInvoice.date}</span>\n                    </div>\n                    <div className=\"flex justify-between text-[10.5px]\">\n                      <span className=\"text-white/40\">Due Date</span>\n                      <span className=\"text-white/70\">{activeInvoice.dueDate}</span>\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-2 pt-2\">\n                    <span className=\"text-[10px] text-white/50 uppercase font-bold flex items-center gap-1.5\"><Lock className=\"w-3.5 h-3.5 text-emerald-400\" />HSM Signature Block</span>\n                    <div className=\"p-3.5 rounded-lg border border-white/5 bg-zinc-950 font-mono text-[9px] text-zinc-400 whitespace-pre overflow-x-auto\">\n{`{\n  \"ledger_seal\": \"${activeInvoice.hash}\",\n  \"attestation\": \"AMD_SEV_SNP_HSM_SEALED\",\n  \"root_key\": \"GFF_ROOT_ECC256\",\n  \"state_integrity\": \"100%_SECURE\"\n}`}\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"p-5 border-t border-white/5 bg-black/40 space-y-3\">\n                  <div className=\"grid grid-cols-2 gap-2.5\">\n                    <button \n                      onClick={() => handleDownload(activeInvoice.id)}\n                      disabled={isDownloading}\n                      className=\"h-9 rounded border border-white/10 hover:border-white/20 text-[10px] text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer disabled:opacity-50\"\n                    >\n                      {isDownloading ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <Download className=\"w-3.5 h-3.5\" />}\n                      <span>Export PDF</span>\n                    </button>\n\n                    {activeInvoice.status !== \"paid\" ? (\n                      <button \n                        onClick={() => handleSettlePayment(activeInvoice.id)}\n                        disabled={isProcessing}\n                        className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-bold text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer disabled:opacity-50\"\n                      >\n                        {isProcessing ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <Check className=\"w-3.5 h-3.5\" />}\n                        <span>Settle Block</span>\n                      </button>\n                    ) : (\n                      <div className=\"h-9 rounded border border-emerald-500/20 bg-emerald-500/5 text-[9.5px] text-emerald-400 flex items-center justify-center gap-1\">\n                        <Check className=\"w-3.5 h-3.5\" />\n                        <span>Receipt Settled</span>\n                      </div>\n                    )}\n                  </div>\n                </div>\n              </motion.div>\n            </div>\n          </div>\n        )}\n      </AnimatePresence>\n\n      {/* Create / Draft Invoice Slide-over Drawer */}\n      <AnimatePresence>\n        {isCreateOpen && (\n          <div className=\"fixed inset-0 z-40 overflow-hidden\">\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={() => !isSigning && setIsCreateOpen(false)} className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" />\n            <div className=\"absolute inset-y-0 right-0 flex pl-10\">\n              <motion.div initial={{ x: \"100%\" }} animate={{ x: 0 }} exit={{ x: \"100%\" }} transition={{ type: \"spring\", damping: 25, stiffness: 220 }} className=\"w-screen max-w-md bg-[#050505] border-l border-white/5 flex flex-col justify-between\">\n                <div className=\"p-6 border-b border-white/5 bg-[#0a0a0a] flex items-center justify-between\">\n                  <div className=\"space-y-1\">\n                    <span className=\"text-[9px] text-emerald-400 font-bold uppercase block\">Sovereign HSM Operations</span>\n                    <h3 className=\"text-sm font-extrabold text-white uppercase\">Draft Ledger Block</h3>\n                  </div>\n                  <button disabled={isSigning} onClick={() => setIsCreateOpen(false)} className=\"p-1 rounded-lg border border-white/5 bg-white/[0.02] text-white/40 hover:text-white cursor-pointer disabled:opacity-30\"><X className=\"w-4 h-4\" /></button>\n                </div>\n\n                <div className=\"flex-1 overflow-y-auto p-6\">\n                  {isSigning ? (\n                    <div className=\"h-full flex flex-col justify-center items-center space-y-6 py-12\">\n                      <div className=\"relative w-16 h-16 flex items-center justify-center\">\n                        <div className=\"absolute inset-0 rounded-full border-2 border-t-[#009DFF] border-b-[#00FFC2] animate-spin\" />\n                        <Lock className=\"w-5 h-5 text-emerald-400 animate-pulse\" />\n                      </div>\n                      \n                      <div className=\"text-center space-y-1\">\n                        <span className=\"text-[11px] font-bold text-white uppercase block\">SEALING SECURE BLOCK...</span>\n                        <p className=\"text-[9.5px] text-white/40 font-mono\">Signing ledger with ECC-256 HSM keys...</p>\n                      </div>\n\n                      <div className=\"w-full p-4 rounded-lg bg-black border border-white/5 text-[9px] text-zinc-400 space-y-2 h-[120px] overflow-y-auto\">\n                        {signingLogs.map((logStr, idx) => {\n                          const isDone = idx < signingStep;\n                          const isActive = idx === signingStep;\n                          return (\n                            <div key={idx} className={`flex gap-1.5 ${isDone ? \"text-emerald-400\" : isActive ? \"text-[#009DFF]\" : \"opacity-25\"}`}>\n                              <span>{isDone ? \"✓\" : \"❯\"}</span>\n                              <span>{logStr}</span>\n                            </div>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  ) : (\n                    <form onSubmit={(e) => { e.preventDefault(); setIsSigning(true); }} className=\"space-y-5\">\n                      <div className=\"p-3.5 rounded-lg border border-emerald-500/10 bg-emerald-500/5 text-[#00FFC2] text-[9px] leading-relaxed flex items-start gap-2\">\n                        <Shield className=\"w-4 h-4 shrink-0\" />\n                        <div>\n                          <strong className=\"block uppercase font-bold tracking-wider mb-0.5\">LOCAL PREVIEW DRAFT ACTIONS</strong>\n                          Drafting creates a mock block inside local memory for dashboard simulation.\n                        </div>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Sovereign Client *</label>\n                        <select\n                          required\n                          value={newClientId}\n                          onChange={(e) => setNewClientId(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none appearance-none cursor-pointer\"\n                        >\n                          <option value=\"\">-- Choose Enterprise Client --</option>\n                          {previewClientAccounts.map(c => (\n                            <option key={c.id} value={c.id}>{c.name.replace(\" [Preview Client]\", \"\")}</option>\n                          ))}\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Hardware Enclave *</label>\n                        <select\n                          required\n                          disabled={!newClientId}\n                          value={newProjectId}\n                          onChange={(e) => setNewProjectId(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none appearance-none cursor-pointer disabled:opacity-30\"\n                        >\n                          {!newClientId ? (\n                            <option value=\"\">-- Choose Client First --</option>\n                          ) : filteredProjects.length === 0 ? (\n                            <option value=\"\">No Active Enclaves Found</option>\n                          ) : (\n                            filteredProjects.map(p => (\n                              <option key={p.id} value={p.id}>{p.name}</option>\n                            ))\n                          )}\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">SLA Ingestion Category *</label>\n                        <select\n                          value={newCategory}\n                          onChange={(e) => setNewCategory(e.target.value as any)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none appearance-none cursor-pointer\"\n                        >\n                          <option value=\"Compute Epoch\">Compute Epoch</option>\n                          <option value=\"SLA Support\">SLA Support</option>\n                          <option value=\"Telemetry Stream\">Telemetry Stream</option>\n                          <option value=\"Premium Support\">Premium Support</option>\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Billing Amount (USD) *</label>\n                        <div className=\"relative\">\n                          <span className=\"absolute left-3 top-3 text-white/30 font-bold\">$</span>\n                          <input\n                            required\n                            type=\"number\"\n                            min=\"1\"\n                            placeholder=\"12000.00\"\n                            value={newAmount}\n                            onChange={(e) => setNewAmount(e.target.value)}\n                            className=\"w-full h-10 pl-7 pr-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none\"\n                          />\n                        </div>\n                      </div>\n\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Due Settlement Date *</label>\n                        <input\n                          required\n                          type=\"date\"\n                          value={newDueDate}\n                          onChange={(e) => setNewDueDate(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none\"\n                        />\n                      </div>\n\n                      <div className=\"grid grid-cols-2 gap-3\">\n                        <div className=\"space-y-1.5\">\n                          <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Billing Month</label>\n                          <select value={newMonth} onChange={(e) => setNewMonth(e.target.value)} className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none cursor-pointer\">\n                            <option value=\"2026-06\">June 2026</option>\n                            <option value=\"2026-05\">May 2026</option>\n                          </select>\n                        </div>\n                        <div className=\"space-y-1.5\">\n                          <label className=\"text-[9.5px] font-bold text-white/40 uppercase block\">Initial Status</label>\n                          <select value={newStatus} onChange={(e) => setNewStatus(e.target.value as any)} className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] text-white focus:outline-none cursor-pointer\">\n                            <option value=\"unpaid\">Unpaid</option>\n                            <option value=\"processing\">Processing</option>\n                            <option value=\"paid\">Paid</option>\n                            <option value=\"overdue\">Overdue</option>\n                          </select>\n                        </div>\n                      </div>\n\n                      <div className=\"pt-2 flex gap-3\">\n                        <button type=\"button\" onClick={() => setIsCreateOpen(false)} className=\"flex-1 h-10 rounded border border-white/10 hover:border-white/20 text-[10px] text-white uppercase font-bold cursor-pointer\">Cancel</button>\n                        <button type=\"submit\" disabled={!newClientId || !newProjectId || !newAmount} className=\"flex-1 h-10 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] text-white uppercase font-bold flex items-center justify-center gap-1 cursor-pointer disabled:opacity-40\">\n                          <Sparkles className=\"w-3.5 h-3.5\" />\n                          <span>Sign Block</span>\n                        </button>\n                      </div>\n                    </form>\n                  )}\n                </div>\n              </motion.div>\n            </div>\n          </div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"}}}
