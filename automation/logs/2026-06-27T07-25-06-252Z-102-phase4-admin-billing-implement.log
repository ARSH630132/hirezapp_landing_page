y, and initial status. I am simulating the signature process and implementing a 2-second signing state with a holographic panel. I'm focusing on user interaction and displaying relevant information. The signature generation includes: a 1.8-second SHA-256 integrity digest, 2.4-second sealing block, hash generation, a unique invoice ID, local invoice state update, a success message or notification, and the closing of the drawer.\n\n\n**Refining Invoice Signing**\n\nI'm now refining the modal view to create new invoices, focusing on improved interactivity. I'm adding a \"Download Cryptographic Receipt\" action with dynamic local states, along with a simulated \"Payment Confirmation\" button for unpaid invoices. I will adjust the status of unpaid invoices to make the admin tool feel interactive. I'm writing the UI code for the `/admin/billing` page to support it.\n\n\n"}}
{"ts":"2026-06-27T07:20:15.284Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"rs03xm84","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/billing/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { FinancialLedgerTab } from \"../admin-tabs-part2\";\n\nexport default function AdminBillingPage() {\n  return <FinancialLedgerTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState, useMemo, useEffect } from \"react\";\nimport { \n  FileText, Search, Plus, Filter, Download, Check, Lock, Shield, \n  Activity, RefreshCw, SlidersHorizontal, ChevronRight, X, Key, \n  ArrowUpRight, Database, Cpu, History, Sparkles, DollarSign, Calendar,\n  CreditCard, CheckCircle2, AlertTriangle, AlertCircle, TrendingUp\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\nimport { previewClientAccounts, previewProjects } from \"@/lib/mock-data-model\";\n\ninterface ExtendedInvoice {\n  id: string;\n  date: string;\n  amount: number;\n  status: \"paid\" | \"unpaid\" | \"processing\" | \"overdue\";\n  dueDate: string;\n  category: \"Compute Epoch\" | \"SLA Support\" | \"Telemetry Stream\" | \"Premium Support\";\n  clientId: string;\n  clientName: string;\n  projectId: string;\n  projectName: string;\n  hash: string;\n  billingMonth: string; // e.g. \"2026-06\", \"2026-05\"\n}\n\n// Initial deterministic records matching other admin interfaces, but extended with client and project context\nconst INITIAL_INVOICES: ExtendedInvoice[] = [\n  {\n    id: \"GFF-2026-0899\",\n    date: \"2026-06-01\",\n    amount: 14820.00,\n    status: \"paid\",\n    dueDate: \"2026-06-15\",\n    category: \"Compute Epoch\",\n    clientId: \"client-001\",\n    clientName: \"Apex Sovereign Group [Preview Client]\",\n    projectId: \"proj-001\",\n    projectName: \"Sovereign Core Sandbox 02\",\n    hash: \"0xDE897FF021BC8102C019FFAD998E1256E3B890CC7FFADE138EE87A02FF90A11B\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0914\",\n    date: \"2026-06-15\",\n    amount: 3500.00,\n    status: \"paid\",\n    dueDate: \"2026-06-30\",\n    category: \"SLA Support\",\n    clientId: \"client-002\",\n    clientName: \"Global Retail Enclave [Preview Client]\",\n    projectId: \"proj-003\",\n    projectName: \"Sovereign Mining Intel Loop\",\n    hash: \"0x11B8A02FEE907C10BDE8267FEE10BC91A23D4FFA289F02ECBC12A349CDE150FA\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0945\",\n    date: \"2026-06-25\",\n    amount: 24900.00,\n    status: \"processing\",\n    dueDate: \"2026-07-10\",\n    category: \"Telemetry Stream\",\n    clientId: \"client-001\",\n    clientName: \"Apex Sovereign Group [Preview Client]\",\n    projectId: \"proj-002\",\n    projectName: \"Model Guardrail Sandbox 04\",\n    hash: \"0x8FDE3102C130D7B2D26788AB0E8A850CE3207FFCDE10B74E824A45B12A4F23AA\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-0988\",\n    date: \"2026-06-27\",\n    amount: 8250.00,\n    status: \"unpaid\",\n    dueDate: \"2026-07-15\",\n    category: \"Compute Epoch\",\n    clientId: \"client-004\",\n    clientName: \"Federal Treasury Division [Preview Client]\",\n    projectId: \"proj-004\",\n    projectName: \"Federal Ledger Enclave Alpha\",\n    hash: \"0x3FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89FBC10492\",\n    billingMonth: \"2026-06\"\n  },\n  {\n    id: \"GFF-2026-1011\",\n    date: \"2026-05-12\",\n    amount: 19500.00,\n    status: \"overdue\",\n    dueDate: \"2026-05-26\",\n    category: \"Premium Support\",\n    clientId: \"client-003\",\n    clientName: \"Sovereign Logistics Unit [Preview Client]\",\n    projectId: \"proj-001\",\n    projectName: \"Sovereign Logistics Thread Map\",\n    hash: \"0xBC04923FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89F\",\n    billingMonth: \"2026-05\"\n  },\n  {\n    id: \"GFF-2026-1025\",\n    date: \"2026-05-20\",\n    amount: 11200.00,\n    status: \"paid\",\n    dueDate: \"2026-06-03\",\n    category: \"Telemetry Stream\",\n    clientId: \"client-002\",\n    clientName: \"Global Retail Enclave [Preview Client]\",\n    projectId: \"proj-003\",\n    projectName: \"Sovereign Mining Intel Loop\",\n    hash: \"0x99A02FEE907C10BDE8267FEE10BC91A23D4FFA289F02ECBC12A349CDE150FACD\",\n    billingMonth: \"2026-05\"\n  }\n];\n\nexport default function AdminBillingPage() {\n  const [invoices, setInvoices] = useState<ExtendedInvoice[]>(INITIAL_INVOICES);\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedClient, setSelectedClient] = useState(\"all\");\n  const [selectedStatus, setSelectedStatus] = useState(\"all\");\n  const [selectedMonth, setSelectedMonth] = useState(\"all\");\n\n  // Selection & Details Drawers\n  const [activeInvoice, setActiveInvoice] = useState<ExtendedInvoice | null>(null);\n  const [isCreateOpen, setIsCreateOpen] = useState(false);\n  const [toastMessage, setToastMessage] = useState<string | null>(null);\n  const [toastType, setToastType] = useState<\"success\" | \"info\" | \"error\">(\"success\");\n\n  // Create Invoice Form State\n  const [newClientId, setNewClientId] = useState(\"\");\n  const [newProjectId, setNewProjectId] = useState(\"\");\n  const [newCategory, setNewCategory] = useState<ExtendedInvoice[\"category\"]>(\"Compute Epoch\");\n  const [newAmount, setNewAmount] = useState(\"\");\n  const [newDueDate, setNewDueDate] = useState(\"\");\n  const [newStatus, setNewStatus] = useState<ExtendedInvoice[\"status\"]>(\"unpaid\");\n  const [newMonth, setNewMonth] = useState(\"2026-07\");\n\n  // Holographic Signing Animation\n  const [isSigning, setIsSigning] = useState(false);\n  const [signingStep, setSigningStep] = useState(0);\n  const signingLogs = [\n    \"Initialising hardware security enclave socket...\",\n    \"Querying node resource thread metrics (eBPF stream)...\",\n    \"Loading ECC-256 HSM Private Key [GFF-ROOT-V5]...\",\n    \"Hashing telemetry records & generating cryptographic checksum...\",\n    \"Committing certified block to Sovereign ledger: SUCCESS.\"\n  ];\n\n  // Simulated download / operation actions\n  const [isDownloading, setIsDownloading] = useState(false);\n  const [isProcessingPayment, setIsProcessingPayment] = useState(false);\n\n  // Trigger Toast Helper\n  const triggerToast = (msg: string, type: \"success\" | \"info\" | \"error\" = \"success\") => {\n    setToastMessage(msg);\n    setToastType(type);\n    setTimeout(() => setToastMessage(null), 4000);\n  };\n\n  // Signing Loop\n  useEffect(() => {\n    let timer: NodeJS.Timeout;\n    if (isSigning) {\n      if (signingStep < signingLogs.length - 1) {\n        timer = setTimeout(() => {\n          setSigningStep(prev => prev + 1);\n        }, 550);\n      } else {\n        // Finalize Invoice Creation\n        timer = setTimeout(() => {\n          const clientObj = previewClientAccounts.find(c => c.id === newClientId);\n          const projectObj = previewProjects.find(p => p.id === newProjectId);\n          const clientName = clientObj ? clientObj.name : \"Unknown Enterprise Client\";\n          const projectName = projectObj ? projectObj.name : \"General Enclave Service\";\n          \n          const nextIdNum = Math.max(...invoices.map(inv => parseInt(inv.id.split(\"-\")[2]))) + 1;\n          const invoiceId = `GFF-2026-${String(nextIdNum).padStart(4, \"0\")}`;\n          \n          const sha = Array.from({length: 64}, () => Math.floor(Math.random()*16).toString(16)).join(\"\");\n          const hashHex = `0x${sha.toUpperCase()}`;\n\n          const newRecord: ExtendedInvoice = {\n            id: invoiceId,\n            date: new Date().toISOString().split(\"T\")[0],\n            amount: parseFloat(newAmount) || 0,\n            status: newStatus,\n            dueDate: newDueDate || new Date(Date.now() + 14*24*60*60*1000).toISOString().split(\"T\")[0],\n            category: newCategory,\n            clientId: newClientId,\n            clientName,\n            projectId: newProjectId,\n            projectName,\n            hash: hashHex,\n            billingMonth: newMonth\n          };\n\n          setInvoices(prev => [newRecord, ...prev]);\n          setIsSigning(false);\n          setSigningStep(0);\n          setIsCreateOpen(false);\n          \n          // Clear inputs\n          setNewClientId(\"\");\n          setNewProjectId(\"\");\n          setNewAmount(\"\");\n          setNewDueDate(\"\");\n          \n          triggerToast(`Invoice ${invoiceId} cryptographically signed & drafted.`, \"success\");\n        }, 700);\n      }\n    }\n    return () => clearTimeout(timer);\n  }, [isSigning, signingStep]);\n\n  // Project List based on Selected Client for creation dropdown\n  const filteredProjectsForCreation = useMemo(() => {\n    if (!newClientId) return [];\n    return previewProjects.filter(p => p.clientAccountId === newClientId);\n  }, [newClientId]);\n\n  // Auto-select first project when client is chosen\n  useEffect(() => {\n    if (filteredProjectsForCreation.length > 0) {\n      setNewProjectId(filteredProjectsForCreation[0].id);\n    } else {\n      setNewProjectId(\"\");\n    }\n  }, [newClientId, filteredProjectsForCreation]);\n\n  // Months available for filtering compiled from invoice dates + next months\n  const availableMonths = useMemo(() => {\n    const months = new Set<string>();\n    invoices.forEach(inv => months.add(inv.billingMonth));\n    months.add(\"2026-07\"); // add upcoming as potential draft month\n    return Array.from(months).sort();\n  }, [invoices]);\n\n  // Financial Summary Computations (KPIs)\n  const stats = useMemo(() => {\n    let totalInvoiced = 0;\n    let settledReceipts = 0;\n    let processingAwaiting = 0;\n    let unpaidExposure = 0;\n\n    invoices.forEach(inv => {\n      totalInvoiced += inv.amount;\n      if (inv.status === \"paid\") {\n        settledReceipts += inv.amount;\n      } else if (inv.status === \"processing\") {\n        processingAwaiting += inv.amount;\n      } else {\n        unpaidExposure += inv.amount;\n      }\n    });\n\n    return {\n      total: totalInvoiced,\n      settled: settledReceipts,\n      processing: processingAwaiting,\n      unpaid: unpaidExposure,\n      count: invoices.length\n    };\n  }, [invoices]);\n\n  // Filtering Logic\n  const filteredInvoices = useMemo(() => {\n    return invoices.filter(inv => {\n      // Search Box text query\n      if (searchQuery.trim() !== \"\") {\n        const query = searchQuery.toLowerCase();\n        const matchesQuery = \n          inv.id.toLowerCase().includes(query) ||\n          inv.clientName.toLowerCase().includes(query) ||\n          inv.projectName.toLowerCase().includes(query) ||\n          inv.category.toLowerCase().includes(query) ||\n          inv.hash.toLowerCase().includes(query);\n        \n        if (!matchesQuery) return false;\n      }\n\n      // Client Dropdown\n      if (selectedClient !== \"all\" && inv.clientId !== selectedClient) {\n        return false;\n      }\n\n      // Status Dropdown\n      if (selectedStatus !== \"all\" && inv.status !== selectedStatus) {\n        return false;\n      }\n\n      // Month Dropdown\n      if (selectedMonth !== \"all\" && inv.billingMonth !== selectedMonth) {\n        return false;\n      }\n\n      return true;\n    });\n  }, [invoices, searchQuery, selectedClient, selectedStatus, selectedMonth]);\n\n  // Execute Invoice Creation Request\n  const handleCreateInvoice = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newClientId || !newProjectId || !newAmount) {\n      triggerToast(\"Please fill in all required cryptographic metadata fields.\", \"error\");\n      return;\n    }\n    \n    // Start holographic signing loop\n    setIsSigning(true);\n    setSigningStep(0);\n  };\n\n  // Simulate Payment Confirmation (Admin Override Action)\n  const handleSimulatePayment = (invoiceId: string) => {\n    setIsProcessingPayment(true);\n    setTimeout(() => {\n      setInvoices(prev => prev.map(inv => {\n        if (inv.id === invoiceId) {\n          return { ...inv, status: \"paid\" };\n        }\n        return inv;\n      }));\n      \n      // Update selected drawer invoice state\n      setActiveInvoice(prev => prev && prev.id === invoiceId ? { ...prev, status: \"paid\" } : prev);\n      \n      setIsProcessingPayment(false);\n      triggerToast(`Secured ledger: Payment block matched for ${invoiceId}.`, \"success\");\n    }, 1200);\n  };\n\n  // Simulate Cryptographic Receipt Download\n  const handleDownloadReceipt = (invoice: ExtendedInvoice) => {\n    setIsDownloading(true);\n    setTimeout(() => {\n      setIsDownloading(false);\n      triggerToast(`Receipt PDF copy simulated download for ${invoice.id}`, \"success\");\n    }, 1000);\n  };\n\n  // Reset Filters Helper\n  const handleResetFilters = () => {\n    setSearchQuery(\"\");\n    setSelectedClient(\"all\");\n    setSelectedStatus(\"all\");\n    setSelectedMonth(\"all\");\n    triggerToast(\"Ledger query parameters reset.\", \"info\");\n  };\n\n  // Formatting helpers\n  const formatCurrency = (val: number) => {\n    return new Intl.NumberFormat(\"en-US\", {\n      style: \"currency\",\n      currency: \"USD\",\n      maximumFractionDigits: 2\n    }).format(val);\n  };\n\n  const getStatusBadgeStyles = (status: ExtendedInvoice[\"status\"]) => {\n    switch (status) {\n      case \"paid\":\n        return \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\";\n      case \"unpaid\":\n        return \"bg-amber-400/10 text-amber-400 border-amber-400/25\";\n      case \"processing\":\n        return \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\";\n      case \"overdue\":\n        return \"bg-rose-500/10 text-rose-400 border-rose-500/25\";\n      default:\n        return \"bg-white/5 text-white/50 border-white/10\";\n    }\n  };\n\n  return (\n    <div className=\"space-y-6 font-mono text-[11px] text-white\">\n      {/* Toast Alert Banner */}\n      <AnimatePresence>\n        {toastMessage && (\n          <motion.div\n            initial={{ opacity: 0, y: -20, scale: 0.95 }}\n            animate={{ opacity: 1, y: 0, scale: 1 }}\n            exit={{ opacity: 0, y: -20, scale: 0.95 }}\n            className={`fixed top-6 right-6 z-50 flex items-center gap-2.5 px-4 py-3 rounded-xl border backdrop-blur-md shadow-2xl ${\n              toastType === \"success\" \n                ? \"bg-[#050505]/90 border-emerald-500/20 text-emerald-400 shadow-emerald-500/5\" \n                : toastType === \"error\"\n                ? \"bg-[#050505]/90 border-rose-500/20 text-rose-400 shadow-rose-500/5\"\n                : \"bg-[#050505]/90 border-[#009DFF]/20 text-[#009DFF] shadow-[#009DFF]/5\"\n            }`}\n          >\n            {toastType === \"success\" && <CheckCircle2 className=\"w-4 h-4 text-emerald-400 shrink-0\" />}\n            {toastType === \"error\" && <AlertTriangle className=\"w-4 h-4 text-rose-400 shrink-0\" />}\n            {toastType === \"info\" && <Shield className=\"w-4 h-4 text-[#009DFF] shrink-0\" />}\n            <span className=\"font-mono text-[10.5px] font-medium leading-none\">{toastMessage}</span>\n          </motion.div>\n        )}\n      </AnimatePresence>\n\n      {/* Page Header */}\n      <PrivatePageHeader \n        title=\"FINANCIAL LEDGER OPERATIONS\" \n        desc=\"Admin control center for managing cryptographic billing, sealing customer invoices, and auditing node hardware compute credits.\"\n        actions={\n          <button \n            onClick={() => setIsCreateOpen(true)}\n            className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)] border border-white/5\"\n          >\n            <Plus className=\"w-3.5 h-3.5\" />\n            <span>Draft Invoice Preview</span>\n          </button>\n        }\n      />\n\n      {/* SVG Hardware Cryptographic Signing pipeline Graphic */}\n      <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm p-5 space-y-4 relative overflow-hidden\">\n        {/* Subtle decorative background glow */}\n        <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-20 bg-[#009DFF]/5 rounded-full blur-[60px] pointer-events-none select-none\" />\n        \n        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 border-b border-white/5 pb-3 relative z-10\">\n          <div>\n            <h4 className=\"text-[12px] font-bold tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <Shield className=\"w-4 h-4 text-[#009DFF]\" />\n              <span>SOVEREIGN CRYPTOGRAPHIC SIGNING FLOW</span>\n            </h4>\n            <p className=\"text-[10px] text-white/40 mt-0.5\">Continuous hardwareattested verification pipeline mapping cloud sandboxes to the administrative ledger.</p>\n          </div>\n          <div className=\"flex items-center gap-1.5 text-[9.5px] font-mono text-emerald-400 bg-emerald-500/5 px-2 py-0.5 rounded border border-emerald-500/15\">\n            <span className=\"relative flex h-1.5 w-1.5\">\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n              <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500\"></span>\n            </span>\n            <span className=\"uppercase tracking-wider font-bold\">HSM Keys Online</span>\n          </div>\n        </div>\n\n        {/* Live Flow Diagram */}\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-2 relative z-10\">\n          \n          {/* Node 1 */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 hover:border-[#009DFF]/20 transition-all flex items-start gap-3\">\n            <div className=\"p-2 rounded-lg bg-[#009DFF]/5 border border-[#009DFF]/10 text-[#009DFF] shrink-0\">\n              <Cpu className=\"w-5 h-5 animate-pulse\" />\n            </div>\n            <div className=\"space-y-1\">\n              <div className=\"text-[11px] font-bold text-white uppercase tracking-wider\">1. Telemetry Ingestion</div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">eBPF kernel-level handlers capture active compute epoch thread hours on isolated client nodes.</p>\n              <div className=\"text-[9px] text-[#009DFF] font-bold font-mono\">STATUS: COLLECTING...</div>\n            </div>\n          </div>\n\n          {/* Node 2 */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 hover:border-emerald-500/20 transition-all flex items-start gap-3 relative\">\n            {/* SVG Connecting arrow effect */}\n            <div className=\"hidden md:block absolute -left-4 top-1/2 -translate-y-1/2 z-20 pointer-events-none select-none\">\n              <svg width=\"24\" height=\"12\" viewBox=\"0 0 24 12\" fill=\"none\">\n                <path d=\"M0 6H20M20 6L15 1M20 6L15 11\" stroke=\"rgba(255, 255, 255, 0.15)\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\" />\n              </svg>\n            </div>\n            <div className=\"p-2 rounded-lg bg-emerald-500/5 border border-emerald-500/10 text-emerald-400 shrink-0\">\n              <Key className=\"w-5 h-5\" />\n            </div>\n            <div className=\"space-y-1\">\n              <div className=\"text-[11px] font-bold text-white uppercase tracking-wider\">2. AMD SEV-SNP Seal</div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">Sovereign hardware security enclaves wrap metrics inside cryptographically sealed transaction envelopes.</p>\n              <div className=\"text-[9px] text-emerald-400 font-bold font-mono\">KEY STATUS: ARMED</div>\n            </div>\n          </div>\n\n          {/* Node 3 */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 hover:border-[#00FFC2]/20 transition-all flex items-start gap-3 relative\">\n            {/* SVG Connecting arrow effect */}\n            <div className=\"hidden md:block absolute -left-4 top-1/2 -translate-y-1/2 z-20 pointer-events-none select-none\">\n              <svg width=\"24\" height=\"12\" viewBox=\"0 0 24 12\" fill=\"none\">\n                <path d=\"M0 6H20M20 6L15 1M20 6L15 11\" stroke=\"rgba(255, 255, 255, 0.15)\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\" />\n              </svg>\n            </div>\n            <div className=\"p-2 rounded-lg bg-[#00FFC2]/5 border border-[#00FFC2]/10 text-[#00FFC2] shrink-0\">\n              <Database className=\"w-5 h-5\" />\n            </div>\n            <div className=\"space-y-1\">\n              <div className=\"text-[11px] font-bold text-white uppercase tracking-wider\">3. Immutable Ledger</div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">Signed receipts are permanently written to internal ledgers with fully-auditable SHA hashes.</p>\n              <div className=\"text-[9px] text-[#00FFC2] font-bold font-mono\">LEDGER COMPLIANT</div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      {/* KPI Stats Grid */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {/* KPI 1 */}\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center hover:border-white/10 transition-all\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-semibold block\">Total Invoiced</span>\n            <div className=\"text-[15px] font-extrabold tracking-tight text-white\">{formatCurrency(stats.total)}</div>\n            <div className=\"flex items-center gap-1 text-[8.5px] text-[#009DFF]\">\n              <TrendingUp className=\"w-3 h-3\" />\n              <span>{stats.count} active blocks</span>\n            </div>\n          </div>\n          <div className=\"p-2 rounded-lg bg-white/[0.02] border border-white/5 text-white/55\">\n            <FileText className=\"w-4 h-4\" />\n          </div>\n        </div>\n\n        {/* KPI 2 */}\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center hover:border-white/10 transition-all\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-semibold block\">Settled Receipts</span>\n            <div className=\"text-[15px] font-extrabold tracking-tight text-emerald-400\">{formatCurrency(stats.settled)}</div>\n            <div className=\"text-[8.5px] text-white/35\">\n              <span>{((stats.settled / (stats.total || 1)) * 100).toFixed(1)}% recovery rate</span>\n            </div>\n          </div>\n          <div className=\"p-2 rounded-lg bg-emerald-500/5 border border-emerald-500/10 text-emerald-400\">\n            <Check className=\"w-4 h-4\" />\n          </div>\n        </div>\n\n        {/* KPI 3 */}\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center hover:border-white/10 transition-all\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-semibold block\">Awaiting Audit</span>\n            <div className=\"text-[15px] font-extrabold tracking-tight text-[#009DFF]\">{formatCurrency(stats.processing)}</div>\n            <div className=\"text-[8.5px] text-white/35\">\n              <span>Undergoing pipeline check</span>\n            </div>\n          </div>\n          <div className=\"p-2 rounded-lg bg-[#009DFF]/5 border border-[#009DFF]/10 text-[#009DFF]\">\n            <RefreshCw className=\"w-4 h-4 animate-spin-slow\" />\n          </div>\n        </div>\n\n        {/* KPI 4 */}\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center hover:border-white/10 transition-all\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-semibold block\">Exposure / Exposure</span>\n            <div className=\"text-[15px] font-extrabold tracking-tight text-rose-400\">{formatCurrency(stats.unpaid)}</div>\n            <div className=\"text-[8.5px] text-white/35\">\n              <span>Unpaid & Overdue ledger</span>\n            </div>\n          </div>\n          <div className=\"p-2 rounded-lg bg-rose-500/5 border border-rose-500/10 text-rose-400\">\n            <AlertCircle className=\"w-4 h-4\" />\n          </div>\n        </div>\n      </div>\n\n      {/* Advanced Filter Bar Panel */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/30 flex flex-col gap-4\">\n        <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-center gap-3\">\n          <div className=\"flex items-center gap-2\">\n            <SlidersHorizontal className=\"w-4 h-4 text-white/40\" />\n            <span className=\"text-[10px] font-bold uppercase tracking-widest text-white/60\">LEDGER INQUIRY INDEX FILTERS</span>\n          </div>\n          {(searchQuery || selectedClient !== \"all\" || selectedStatus !== \"all\" || selectedMonth !== \"all\") && (\n            <button \n              onClick={handleResetFilters}\n              className=\"text-[9px] font-mono font-bold text-rose-400 uppercase tracking-widest flex items-center gap-1 hover:text-rose-300 transition-colors bg-rose-500/5 border border-rose-500/10 px-2 py-1 rounded cursor-pointer\"\n            >\n              <X className=\"w-3 h-3\" />\n              <span>Reset Ledgers Filter</span>\n            </button>\n          )}\n        </div>\n\n        {/* Filters Grid */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3\">\n          {/* Search */}\n          <div className=\"relative\">\n            <Search className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/35\" />\n            <input \n              type=\"text\" \n              placeholder=\"Query by Invoice, Client, project, hash...\" \n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              className=\"w-full h-9 pl-9 pr-3 rounded bg-black/40 border border-white/5 text-[10px] font-mono text-white placeholder-white/30 focus:outline-none focus:border-[#009DFF]/40 transition-colors\"\n            />\n          </div>\n\n          {/* Client Select */}\n          <div className=\"relative\">\n            <Filter className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/35\" />\n            <select\n              value={selectedClient}\n              onChange={(e) => setSelectedClient(e.target.value)}\n              className=\"w-full h-9 pl-9 pr-3 rounded bg-black/40 border border-white/5 text-[10px] font-mono text-white/80 focus:outline-none focus:border-[#009DFF]/40 transition-colors appearance-none cursor-pointer\"\n            >\n              <option value=\"all\">Sovereign client: All</option>\n              {previewClientAccounts.map(client => (\n                <option key={client.id} value={client.id}>\n                  {client.name.replace(\" [Preview Client]\", \"\")}\n                </option>\n              ))}\n            </select>\n          </div>\n\n          {/* Status Select */}\n          <div className=\"relative\">\n            <CreditCard className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/35\" />\n            <select\n              value={selectedStatus}\n              onChange={(e) => setSelectedStatus(e.target.value)}\n              className=\"w-full h-9 pl-9 pr-3 rounded bg-black/40 border border-white/5 text-[10px] font-mono text-white/80 focus:outline-none focus:border-[#009DFF]/40 transition-colors appearance-none cursor-pointer\"\n            >\n              <option value=\"all\">Invoice Status: All</option>\n              <option value=\"paid\">Paid</option>\n              <option value=\"unpaid\">Unpaid</option>\n              <option value=\"processing\">Processing</option>\n              <option value=\"overdue\">Overdue</option>\n            </select>\n          </div>\n\n          {/* Month Select */}\n          <div className=\"relative\">\n            <Calendar className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/35\" />\n            <select\n              value={selectedMonth}\n              onChange={(e) => setSelectedMonth(e.target.value)}\n              className=\"w-full h-9 pl-9 pr-3 rounded bg-black/40 border border-white/5 text-[10px] font-mono text-white/80 focus:outline-none focus:border-[#009DFF]/40 transition-colors appearance-none cursor-pointer\"\n            >\n              <option value=\"all\">Billing Month: All</option>\n              {availableMonths.map(month => (\n                <option key={month} value={month}>{month}</option>\n              ))}\n            </select>\n          </div>\n        </div>\n      </div>\n\n      {/* Main Table Ledger / List Section */}\n      <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 overflow-hidden\">\n        {/* Table header meta info */}\n        <div className=\"px-5 py-4 border-b border-white/5 flex justify-between items-center bg-[#0d0d0d]/30\">\n          <div>\n            <span className=\"text-[10px] font-mono text-white/35 uppercase tracking-widest font-bold\">SOVEREIGN ACTIVE FINANCE LEDGER</span>\n            <p className=\"text-[9px] text-white/40 mt-0.5\">Showing {filteredInvoices.length} of {invoices.length} deterministic invoice records</p>\n          </div>\n          <div className=\"text-[9px] font-mono text-white/30 uppercase tracking-widest\">\n            SECURE SHA-256 SEALS ATTACHED\n          </div>\n        </div>\n\n        {/* Responsive Table wrapper */}\n        <div className=\"overflow-x-auto\">\n          <table className=\"w-full border-collapse text-left\">\n            <thead>\n              <tr className=\"border-b border-white/5 bg-black/30 text-[9.5px] uppercase font-mono tracking-wider text-white/50\">\n                <th className=\"py-3 px-5 font-bold\">Invoice Code</th>\n                <th className=\"py-3 px-5 font-bold\">Sovereign Client</th>\n                <th className=\"py-3 px-5 font-bold\">Project Enclave</th>\n                <th className=\"py-3 px-5 font-bold\">Billing Type</th>\n                <th className=\"py-3 px-5 font-bold text-right\">Amount (USD)</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Due Date</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Status</th>\n                <th className=\"py-3 px-5 font-bold text-center\">Integrity Hash</th>\n                <th className=\"py-3 px-5 text-center\"></th>\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-white/[0.03]\">\n              {filteredInvoices.length === 0 ? (\n                <tr>\n                  <td colSpan={9} className=\"py-12 text-center text-white/30 font-mono text-[10px]\">\n                    <div className=\"flex flex-col items-center justify-center gap-2\">\n                      <SlidersHorizontal className=\"w-6 h-6 text-white/20 animate-pulse\" />\n                      <span>NO COMPLIANT LEDGER BLOCKS MATCH THIS QUERY INDEX.</span>\n                    </div>\n                  </td>\n                </tr>\n              ) : (\n                filteredInvoices.map((inv) => (\n                  <tr \n                    key={inv.id}\n                    onClick={() => setActiveInvoice(inv)}\n                    className=\"hover:bg-white/[0.02] active:bg-white/[0.04] transition-all cursor-pointer group\"\n                  >\n                    {/* Invoice ID */}\n                    <td className=\"py-3.5 px-5 font-bold text-[#009DFF] tracking-wide font-mono\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <FileText className=\"w-3.5 h-3.5 opacity-65 group-hover:opacity-100 transition-opacity\" />\n                        <span>{inv.id}</span>\n                      </div>\n                    </td>\n\n                    {/* Client Name */}\n                    <td className=\"py-3.5 px-5 text-white/80 font-medium\">\n                      <div className=\"truncate max-w-[200px]\" title={inv.clientName}>\n                        {inv.clientName.replace(\" [Preview Client]\", \"\")}\n                      </div>\n                    </td>\n\n                    {/* Project Name */}\n                    <td className=\"py-3.5 px-5 text-white/60\">\n                      <div className=\"flex items-center gap-1.5 truncate max-w-[180px]\" title={inv.projectName}>\n                        <div className=\"w-1 h-3 rounded-full bg-[#009DFF]/30 shrink-0\" />\n                        <span>{inv.projectName}</span>\n                      </div>\n                    </td>\n\n                    {/* Billing Category */}\n                    <td className=\"py-3.5 px-5\">\n                      <span className=\"text-white/40 text-[9.5px] font-mono tracking-widest block uppercase\">\n                        {inv.category}\n                      </span>\n                    </td>\n\n                    {/* Amount */}\n                    <td className=\"py-3.5 px-5 text-right font-extrabold text-white font-mono\">\n                      {formatCurrency(inv.amount)}\n                    </td>\n\n                    {/* Due Date */}\n                    <td className=\"py-3.5 px-5 text-center text-white/50 font-mono\">\n                      {inv.dueDate}\n                    </td>\n\n                    {/* Status badge */}\n                    <td className=\"py-3.5 px-5 text-center\">\n                      <span className={`inline-flex items-center gap-1 rounded px-2.5 py-0.5 text-[8.5px] font-mono font-bold uppercase border ${getStatusBadgeStyles(inv.status)}`}>\n                        {inv.status === \"paid\" && <span className=\"w-1 h-1 rounded-full bg-emerald-400\" />}\n                        {inv.status === \"processing\" && <span className=\"w-1 h-1 rounded-full bg-[#009DFF] animate-pulse\" />}\n                        {inv.status === \"unpaid\" && <span className=\"w-1 h-1 rounded-full bg-amber-400\" />}\n                        {inv.status === \"overdue\" && <span className=\"w-1 h-1 rounded-full bg-rose-500 animate-ping\" />}\n                        <span>{inv.status}</span>\n                      </span>\n                    </td>\n\n                    {/* Cryptographic Hash snippet */}\n                    <td className=\"py-3.5 px-5 text-center font-mono\">\n                      <span className=\"text-[9px] text-white/30 hover:text-white/70 transition-colors\" title={inv.hash}>\n                        {inv.hash.slice(0, 10)}...{inv.hash.slice(-8)}\n                      </span>\n                    </td>\n\n                    {/* Chevron Action */}\n                    <td className=\"py-3.5 px-5 text-center text-white/20 group-hover:text-white/80 transition-colors\">\n                      <ChevronRight className=\"w-4 h-4 translate-x-0 group-hover:translate-x-0.5 transition-transform\" />\n                    </td>\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      {/* Detail Slide-over Panel (Active Invoice Drawer) */}\n      <AnimatePresence>\n        {activeInvoice && (\n          <div className=\"fixed inset-0 z-40 overflow-hidden\">\n            {/* Backdrop */}\n            <motion.div \n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={() => setActiveInvoice(null)}\n              className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\"\n            />\n\n            {/* Slide Sheet panel */}\n            <div className=\"absolute inset-y-0 right-0 max-w-full flex pl-10\">\n              <motion.div \n                initial={{ x: \"100%\" }}\n                animate={{ x: 0 }}\n                exit={{ x: \"100%\" }}\n                transition={{ type: \"spring\", damping: 25, stiffness: 220 }}\n                className=\"w-screen max-w-md bg-[#050505] border-l border-white/5 shadow-2xl relative flex flex-col justify-between\"\n              >\n                {/* Header */}\n                <div className=\"p-6 border-b border-white/5 bg-[#0a0a0a] flex items-center justify-between\">\n                  <div className=\"space-y-1\">\n                    <div className=\"flex items-center gap-1.5 font-mono text-[9px] text-[#009DFF] font-bold uppercase tracking-wider\">\n                      <Shield className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                      <span>Ledger block attestation</span>\n                    </div>\n                    <h3 className=\"text-sm font-extrabold text-white uppercase font-mono tracking-tight\">{activeInvoice.id}</h3>\n                  </div>\n                  <button \n                    onClick={() => setActiveInvoice(null)}\n                    className=\"p-1 rounded-lg border border-white/5 bg-white/[0.02] text-white/40 hover:text-white transition-colors cursor-pointer\"\n                  >\n                    <X className=\"w-4 h-4\" />\n                  </button>\n                </div>\n\n                {/* Content */}\n                <div className=\"flex-1 overflow-y-auto p-6 space-y-5\">\n                  \n                  {/* Status & Amount Block */}\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex justify-between items-center\">\n                    <div className=\"space-y-1\">\n                      <span className=\"text-[9px] text-white/30 uppercase tracking-widest\">Attested Amount</span>\n                      <div className=\"text-[18px] font-extrabold text-white font-mono\">{formatCurrency(activeInvoice.amount)}</div>\n                    </div>\n                    <div className=\"flex flex-col items-end gap-1.5\">\n                      <span className=\"text-[8px] text-white/30 uppercase font-mono tracking-wider\">Verification status</span>\n                      <span className={`inline-flex items-center gap-1 rounded px-2.5 py-0.5 text-[9px] font-mono font-bold uppercase border ${getStatusBadgeStyles(activeInvoice.status)}`}>\n                        <span>{activeInvoice.status}</span>\n                      </span>\n                    </div>\n                  </div>\n\n                  {/* Core Meta Parameters */}\n                  <div className=\"space-y-3.5\">\n                    <h4 className=\"text-[10px] font-bold tracking-widest text-white/50 uppercase border-b border-white/5 pb-1\">ENTERPRISE CONTEXT</h4>\n                    \n                    {/* Client */}\n                    <div className=\"flex justify-between items-start text-[10.5px]\">\n                      <span className=\"text-white/40\">Sovereign Client</span>\n                      <span className=\"text-white font-bold text-right max-w-[220px] truncate\">\n                        {activeInvoice.clientName.replace(\" [Preview Client]\", \"\")}\n                      </span>\n                    </div>\n\n                    {/* Project */}\n                    <div className=\"flex justify-between items-start text-[10.5px]\">\n                      <span className=\"text-white/40\">Hardware Enclave</span>\n                      <span className=\"text-white font-bold text-right max-w-[220px] truncate\">\n                        {activeInvoice.projectName}\n                      </span>\n                    </div>\n\n                    {/* Billing Category */}\n                    <div className=\"flex justify-between items-center text-[10.5px]\">\n                      <span className=\"text-white/40\">SLA Ingestion Tier</span>\n                      <span className=\"text-[#009DFF] font-bold uppercase font-mono tracking-wider text-[9.5px]\">\n                        {activeInvoice.category}\n                      </span>\n                    </div>\n\n                    {/* Invoice Issue Date */}\n                    <div className=\"flex justify-between items-center text-[10.5px]\">\n                      <span className=\"text-white/40\">Ingested on Block</span>\n                      <span className=\"text-white/80 font-mono\">{activeInvoice.date}</span>\n                    </div>\n\n                    {/* Due Date */}\n                    <div className=\"flex justify-between items-center text-[10.5px]\">\n                      <span className=\"text-white/40\">Settlement Due Block</span>\n                      <span className=\"text-white/80 font-mono\">{activeInvoice.dueDate}</span>\n                    </div>\n\n                    {/* Billing Month */}\n                    <div className=\"flex justify-between items-center text-[10.5px]\">\n                      <span className=\"text-white/40\">Fiscal Month</span>\n                      <span className=\"text-white/80 font-mono\">{activeInvoice.billingMonth}</span>\n                    </div>\n                  </div>\n\n                  {/* Cryptographic Attestation Block */}\n                  <div className=\"space-y-2 pt-2\">\n                    <div className=\"flex items-center gap-1.5 text-[10px] text-white/50 uppercase font-bold tracking-wider\">\n                      <Lock className=\"w-3.5 h-3.5 text-emerald-400\" />\n                      <span>HSM Cryptographic Signature Block</span>\n                    </div>\n                    <div className=\"p-3.5 rounded-lg border border-white/5 bg-zinc-950 font-mono text-[9px] text-zinc-400 select-all leading-relaxed whitespace-pre overflow-x-auto\">\n{`{\n  \"ledger_seal\": \"${activeInvoice.hash}\",\n  \"attestation_method\": \"AMD_SEV_SNP_HSM_SEALED\",\n  \"root_handshake_key\": \"GFF_ROOT_V5_SEC_ECC256\",\n  \"block_checksum\": \"SHA256_0x${activeInvoice.hash.slice(2, 22).toUpperCase()}\",\n  \"telemetry_verification\": \"100.00%_INTEGRITY_VERIFIED\",\n  \"enclave_isolated_memory_locked\": true\n}`}\n                    </div>\n                    <p className=\"text-[8.5px] text-white/35 leading-relaxed\">\n                      This block represents a secure, cryptographically validated bill compiled directly from memory registers inside the designated isolated sandbox enclave cluster. Handshake signed.\n                    </p>\n                  </div>\n\n                  {/* Simulated Telemetry Logs */}\n                  <div className=\"space-y-2 pt-1\">\n                    <div className=\"flex items-center gap-1.5 text-[10px] text-white/50 uppercase font-bold tracking-wider\">\n                      <Activity className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                      <span>Sovereign Enclave Node Telemetry</span>\n                    </div>\n                    <div className=\"p-3 rounded-lg border border-white/5 bg-[#020202] text-[9px] font-mono text-zinc-500 leading-normal space-y-1\">\n                      <div><span className=\"text-[#009DFF]/70\">&gt;</span> [System] Ingested 128 core compute hours.</div>\n                      <div><span className=\"text-[#009DFF]/70\">&gt;</span> [System] SLA network response validated: average 14.2ms.</div>\n                      <div><span className=\"text-emerald-400/70\">&gt;</span> [Attestation] Sealed metrics using secure keys.</div>\n                    </div>\n                  </div>\n\n                </div>\n\n                {/* Footer Controls */}\n                <div className=\"p-5 border-t border-white/5 bg-black/40 space-y-3\">\n                  <div className=\"flex items-center gap-1.5 text-[9px] font-mono text-white/35\"><Lock className=\"w-3.5 h-3.5 text-emerald-400\" /><span>Sovereign Key Handshake Sealed</span></div>\n                  \n                  <div className=\"grid grid-cols-2 gap-2.5\">\n                    {/* Simulated PDF Download button */}\n                    <button \n                      onClick={() => handleDownloadReceipt(activeInvoice)}\n                      disabled={isDownloading}\n                      className=\"h-9 rounded border border-white/10 hover:border-white/20 hover:bg-white/[0.01] text-[10px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer disabled:opacity-50\"\n                    >\n                      {isDownloading ? (\n                        <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                      ) : (\n                        <Download className=\"w-3.5 h-3.5\" />\n                      )}\n                      <span>{isDownloading ? \"Downloading...\" : \"Export PDF Copy\"}</span>\n                    </button>\n\n                    {/* Operational Action - Simulating Payment Override */}\n                    {activeInvoice.status !== \"paid\" ? (\n                      <button \n                        onClick={() => handleSimulatePayment(activeInvoice.id)}\n                        disabled={isProcessingPayment}\n                        className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-mono font-bold uppercase text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.25)] disabled:opacity-50\"\n                      >\n                        {isProcessingPayment ? (\n                          <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                        ) : (\n                          <Check className=\"w-3.5 h-3.5\" />\n                        )}\n                        <span>{isProcessingPayment ? \"Securing...\" : \"Settle Payment\"}</span>\n                      </button>\n                    ) : (\n                      <div className=\"h-9 rounded border border-emerald-500/20 bg-emerald-500/5 text-[9.5px] font-mono font-bold uppercase text-emerald-400 flex items-center justify-center gap-1 cursor-default\">\n                        <Check className=\"w-3.5 h-3.5\" />\n                        <span>Receipt Settled</span>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n              </motion.div>\n            </div>\n          </div>\n        )}\n      </AnimatePresence>\n\n      {/* Draft Invoice Drawer/Modal */}\n      <AnimatePresence>\n        {isCreateOpen && (\n          <div className=\"fixed inset-0 z-40 overflow-hidden\">\n            {/* Backdrop */}\n            <motion.div \n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={() => !isSigning && setIsCreateOpen(false)}\n              className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\"\n            />\n\n            {/* Modal Sheet panel */}\n            <div className=\"absolute inset-y-0 right-0 max-w-full flex pl-10\">\n              <motion.div \n                initial={{ x: \"100%\" }}\n                animate={{ x: 0 }}\n                exit={{ x: \"100%\" }}\n                transition={{ type: \"spring\", damping: 25, stiffness: 220 }}\n                className=\"w-screen max-w-md bg-[#050505] border-l border-white/5 shadow-2xl relative flex flex-col justify-between\"\n              >\n                {/* Drawer Header */}\n                <div className=\"p-6 border-b border-white/5 bg-[#0a0a0a] flex items-center justify-between\">\n                  <div className=\"space-y-1\">\n                    <div className=\"flex items-center gap-1.5 font-mono text-[9px] text-emerald-400 font-bold uppercase tracking-wider\">\n                      <Key className=\"w-3.5 h-3.5 text-emerald-400\" />\n                      <span>Sovereign HSM Operations</span>\n                    </div>\n                    <h3 className=\"text-sm font-extrabold text-white uppercase font-mono tracking-tight\">Draft Ledger Block</h3>\n                  </div>\n                  <button \n                    disabled={isSigning}\n                    onClick={() => setIsCreateOpen(false)}\n                    className=\"p-1 rounded-lg border border-white/5 bg-white/[0.02] text-white/40 hover:text-white transition-colors cursor-pointer disabled:opacity-30\"\n                  >\n                    <X className=\"w-4 h-4\" />\n                  </button>\n                </div>\n\n                {/* Form Content / In-progress animation */}\n                <div className=\"flex-1 overflow-y-auto p-6\">\n                  {isSigning ? (\n                    /* Holographic Cryptographic Signing Loop */\n                    <div className=\"h-full flex flex-col justify-center items-center space-y-6 py-12\">\n                      <div className=\"relative w-16 h-16 flex items-center justify-center\">\n                        {/* Spinning locks */}\n                        <div className=\"absolute inset-0 rounded-full border-2 border-t-[#009DFF] border-r-transparent border-b-[#00FFC2] border-l-transparent animate-spin\" />\n                        <div className=\"absolute inset-2 rounded-full border border-dashed border-white/10 animate-spin-reverse\" />\n                        <Lock className=\"w-5 h-5 text-emerald-400 animate-pulse\" />\n                      </div>\n                      \n                      <div className=\"text-center space-y-2\">\n                        <div className=\"text-[11px] font-bold text-white uppercase tracking-widest font-mono\">ENCLAVE SECURE KEY SIGNING IN PROGRESS</div>\n                        <p className=\"text-[9.5px] text-white/40\">Certifying compute metrics with zero-trust HSM ECC private key...</p>\n                      </div>\n\n                      {/* Holographic shell stream */}\n                      <div className=\"w-full p-4 rounded-lg bg-black border border-white/5 font-mono text-[9px] text-zinc-400 space-y-2 h-[160px] overflow-y-auto select-text\">\n                        {signingLogs.map((logStr, index) => {\n                          const isCompleted = index < signingStep;\n                          const isActive = index === signingStep;\n                          return (\n                            <div \n                              key={index} \n                              className={`flex items-start gap-1.5 transition-opacity duration-300 ${\n                                isCompleted ? \"opacity-100 text-emerald-400\" : isActive ? \"opacity-100 text-[#009DFF]\" : \"opacity-25\"\n                              }`}\n                            >\n                              <span>{isCompleted ? \"✓\" : isActive ? \"❯\" : \"·\"}</span>\n                              <span className=\"leading-relaxed\">{logStr}</span>\n                            </div>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  ) : (\n                    /* Invoice Draft Parameters Form */\n                    <form onSubmit={handleCreateInvoice} className=\"space-y-5\">\n                      {/* Notice */}\n                      <div className=\"p-3.5 rounded-lg border border-emerald-500/10 bg-emerald-500/5 text-[#00FFC2] font-mono text-[9px] leading-relaxed flex items-start gap-2\">\n                        <Shield className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                        <div>\n                          <strong className=\"block uppercase font-bold tracking-wider mb-0.5\">LOCAL PREVIEW DRAFT ACTIONS ONLY</strong>\n                          All created invoices will exist locally in state for operational dashboard simulation. No actual database commits or emails will be initiated.\n                        </div>\n                      </div>\n\n                      {/* Client Dropdown */}\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Sovereign client *</label>\n                        <select\n                          required\n                          value={newClientId}\n                          onChange={(e) => setNewClientId(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n                        >\n                          <option value=\"\">-- Choose Enterprise Client --</option>\n                          {previewClientAccounts.map(client => (\n                            <option key={client.id} value={client.id}>\n                              {client.name.replace(\" [Preview Client]\", \"\")} ({client.region})\n                            </option>\n                          ))}\n                        </select>\n                      </div>\n\n                      {/* Project Dropdown - Filtered based on selected client */}\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Client hardware enclave *</label>\n                        <select\n                          required\n                          disabled={!newClientId}\n                          value={newProjectId}\n                          onChange={(e) => setNewProjectId(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer disabled:opacity-30\"\n                        >\n                          {!newClientId ? (\n                            <option value=\"\">-- Select Client First --</option>\n                          ) : filteredProjectsForCreation.length === 0 ? (\n                            <option value=\"\">No Active Enclave Projects Registered</option>\n                          ) : (\n                            filteredProjectsForCreation.map(proj => (\n                              <option key={proj.id} value={proj.id}>\n                                {proj.name} [{proj.enclaveType}]\n                              </option>\n                            ))\n                          )}\n                        </select>\n                      </div>\n\n                      {/* Billing Category */}\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">SLA Ingestion category *</label>\n                        <div className=\"grid grid-cols-2 gap-2\">\n                          {([\"Compute Epoch\", \"SLA Support\", \"Telemetry Stream\", \"Premium Support\"] as const).map(cat => (\n                            <button\n                              key={cat}\n                              type=\"button\"\n                              onClick={() => setNewCategory(cat)}\n                              className={`h-9 rounded border text-[9.5px] font-mono font-bold uppercase tracking-wider transition-all flex items-center justify-center cursor-pointer ${\n                                newCategory === cat \n                                  ? \"border-[#009DFF] bg-[#009DFF]/10 text-white\" \n                                  : \"border-white/5 bg-black/30 text-white/50 hover:bg-white/[0.01]\"\n                              }`}\n                            >\n                              {cat}\n                            </button>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* Amount & Currency */}\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Billing Invoiced amount (USD) *</label>\n                        <div className=\"relative\">\n                          <span className=\"absolute left-3 top-3 text-white/30 font-bold\">$</span>\n                          <input\n                            required\n                            type=\"number\"\n                            min=\"1\"\n                            step=\"0.01\"\n                            placeholder=\"Amount in USD, e.g. 15450.00\"\n                            value={newAmount}\n                            onChange={(e) => setNewAmount(e.target.value)}\n                            className=\"w-full h-10 pl-7 pr-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 transition-colors\"\n                          />\n                        </div>\n                      </div>\n\n                      {/* Due date picker */}\n                      <div className=\"space-y-1.5\">\n                        <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Ledger Due settlement Date *</label>\n                        <input\n                          required\n                          type=\"date\"\n                          value={newDueDate}\n                          onChange={(e) => setNewDueDate(e.target.value)}\n                          className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 transition-colors appearance-none\"\n                        />\n                      </div>\n\n                      {/* Month & Initial Status */}\n                      <div className=\"grid grid-cols-2 gap-3\">\n                        <div className=\"space-y-1.5\">\n                          <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Fiscal billing month</label>\n                          <select\n                            value={newMonth}\n                            onChange={(e) => setNewMonth(e.target.value)}\n                            className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n                          >\n                            <option value=\"2026-07\">July 2026</option>\n                            <option value=\"2026-06\">June 2026</option>\n                            <option value=\"2026-05\">May 2026</option>\n                            <option value=\"2026-04\">April 2026</option>\n                          </select>\n                        </div>\n                        <div className=\"space-y-1.5\">\n                          <label className=\"text-[9.5px] font-bold text-white/40 uppercase tracking-widest block font-mono\">Initial block status</label>\n                          <select\n                            value={newStatus}\n                            onChange={(e) => setNewStatus(e.target.value as ExtendedInvoice[\"status\"])}\n                            className=\"w-full h-10 px-3 rounded bg-black/60 border border-white/5 text-[10.5px] font-mono text-white/85 focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n                          >\n                            <option value=\"unpaid\">Unpaid</option>\n                            <option value=\"processing\">Processing</option>\n                            <option value=\"paid\">Paid</option>\n                            <option value=\"overdue\">Overdue</option>\n                          </select>\n                        </div>\n                      </div>\n                    </form>\n                  )}\n                </div>\n\n                {/* Footer Controls */}\n                {!isSigning && (\n                  <div className=\"p-5 border-t border-white/5 bg-black/40 space-y-3\">\n                    <div className=\"flex items-center gap-1.5 text-[9px] font-mono text-white/35\"><Lock className=\"w-3.5 h-3.5 text-emerald-400\" /><span>Secure cryptokey hashing required</span></div>\n                    \n                    <div className=\"grid grid-cols-2 gap-2.5\">\n                      <button \n                        type=\"button\"\n                        onClick={() => setIsCreateOpen(false)}\n                        className=\"h-10 rounded border border-white/10 hover:border-white/20 hover:bg-white/[0.01] text-[10px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center cursor-pointer\"\n                      >\n                        Cancel\n                      </button>\n                      <button \n                        type=\"button\"\n                        onClick={handleCreateInvoice}\n                        disabled={!newClientId || !newProjectId || !newAmount}\n                        className=\"h-10 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-mono font-bold uppercase text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.25)] disabled:opacity-40 disabled:cursor-not-allowed\"\n                      >\n                        <Sparkles className=\"w-3.5 h-3.5\" />\n                        <span>Sign Ledger block</span>\n                      </button>\n                    </div>\n                  </div>\n                )}\n\n              </motion.div>\n            </div>\n          </div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"}}}
