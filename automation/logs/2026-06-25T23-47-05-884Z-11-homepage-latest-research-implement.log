{"ts":"2026-06-25T23:43:08.745Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ktwr6t0c","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/LatestResearchSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\n\n// Core categories with custom descriptions and accent properties\nconst CATEGORIES = [\n  {\n    name: \"Articles\",\n    desc: \"Read detailed technical analyses of multi-agent orchestration, transactional isolation, and secure execution boundaries.\",\n    accentColor: \"#E98828\",\n    bgGlow: \"rgba(233, 136, 40, 0.12)\",\n    icon: (\n      <svg className=\"w-5 h-5 text-[#E98828]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 01-2-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0011.5 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2z\" />\n      </svg>\n    )\n  },\n  {\n    name: \"Videos\",\n    desc: \"Watch engineering walk-throughs, architecture breakdowns, and live terminal demonstrations of running agent systems.\",\n    accentColor: \"#009DFF\",\n    bgGlow: \"rgba(0, 157, 255, 0.12)\",\n    icon: (\n      <svg className=\"w-5 h-5 text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z\" />\n      </svg>\n    )\n  },\n  {\n    name: \"Podcasts\",\n    desc: \"Listen to GFF's technical leads and research partners discuss compliance, scalability, and agentic design principles.\",\n    accentColor: \"#9D00FF\",\n    bgGlow: \"rgba(157, 0, 255, 0.12)\",\n    icon: (\n      <svg className=\"w-5 h-5 text-[#9D00FF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z\" />\n      </svg>\n    )\n  },\n  {\n    name: \"Whitepapers\",\n    desc: \"Access foundational technical specifications, validation methodologies, and formal verification frameworks.\",\n    accentColor: \"#F74539\",\n    bgGlow: \"rgba(247, 69, 57, 0.12)\",\n    icon: (\n      <svg className=\"w-5 h-5 text-[#F74539]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n      </svg>\n    )\n  }\n];\n\n// Actual representative technical papers (no fake authors/dates/downloads)\nconst RESEARCH_PAPERS = [\n  {\n    id: \"gff-orchestration\",\n    title: \"GFF Heuristic Agent Orchestration Framework v1.4\",\n    category: \"Agentic AI / Architecture\",\n    description: \"A comprehensive reference guide outlining dynamic task routing, autonomous sub-agent spawning, and transactional isolation limits within high-throughput enterprise environments.\",\n    size: \"2.4 MB TECHNICAL SPECIFICATION\",\n    tag: \"STABLE CORE\",\n    tagColor: \"text-emerald-400 bg-emerald-400/10 border-emerald-400/20\"\n  },\n  {\n    id: \"gff-security\",\n    title: \"Zero-Trust Agentic Security: Multi-Layer Sandboxing\",\n    category: \"Security & Compliance Protocols\",\n    description: \"Analysis of secure memory boundaries, runtime sandboxing, PII token obfuscation, and runtime container isolation designed to safeguard enterprise intelligence paths.\",\n    size: \"4.1 MB DESIGN STANDARD\",\n    tag: \"UNDER COMPLIANCE AUDIT\",\n    tagColor: \"text-amber-400 bg-amber-400/10 border-amber-400/20\"\n  },\n  {\n    id: \"gff-scaling\",\n    title: \"Horizontal Multi-Agent Scaling & Latency Benchmarks\",\n    category: \"Scalability / Platform Infrastructure\",\n    description: \"Empirical latency metrics regarding microsecond-level synchronization of shared graph databases and custom state memory buffers across globally distributed networks.\",\n    size: \"1.8 MB BENCHMARK DATA SHEET\",\n    tag: \"PEER REVIEWED\",\n    tagColor: \"text-blue-400 bg-blue-400/10 border-blue-400/20\"\n  },\n  {\n    id: \"gff-alignment\",\n    title: \"Ensuring System Alignment: Safety Loops & Audits\",\n    category: \"Safety / Alignment Systems\",\n    description: \"Detailed walkthrough of Human-in-the-Loop exception handling, automated compliance tracing, and multi-tier verification loop architectures.\",\n    size: \"3.2 MB GOVERNANCE FRAMEWORK\",\n    tag: \"APPROVED PRODUCTION\",\n    tagColor: \"text-[#00FFCC] bg-[#00FFCC]/10 border-[#00FFCC]/20\"\n  }\n];\n\n// 12 Required routes to present as part of GFF's Research Hub directory\nconst DIRECTORY_CHANNELS = [\n  { name: \"Blog\", category: \"Daily Insights\", icon: \"💬\" },\n  { name: \"Research\", category: \"Strategic Theory\", icon: \"🔬\" },\n  { name: \"Case Studies\", category: \"Representative Solutions\", icon: \"📊\" },\n  { name: \"Architecture Library\", category: \"System Blueprints\", icon: \"📐\" },\n  { name: \"Webinars\", category: \"Live Case Studies\", icon: \"🎥\" },\n  { name: \"Events\", category: \"Technical Summits\", icon: \"📅\" },\n  { name: \"Developer Docs\", category: \"API & SDK Reference\", icon: \"💻\" },\n  { name: \"Downloads\", category: \"Secure Platform Modules\", icon: \"📦\" },\n  { name: \"Reports\", category: \"Quarterly Intelligence\", icon: \"📈\" },\n  { name: \"Newsroom\", category: \"Official Statements\", icon: \"📰\" },\n  { name: \"Thought Leadership\", category: \"Industry Standards\", icon: \"💡\" },\n  { name: \"Patterns of Intelligence\", category: \"Orchestration Paradigms\", icon: \"🕸️\" }\n];\n\nexport default function LatestResearchSection() {\n  // Simulator states for downloading documents\n  const [downloadingId, setDownloadingId] = useState<string | null>(null);\n  const [downloadProgress, setDownloadProgress] = useState<number>(0);\n  const [downloadSuccessId, setDownloadSuccessId] = useState<string | null>(null);\n\n  // Modal states for coming-soon routes\n  const [activeChannel, setActiveChannel] = useState<string | null>(null);\n  const [emailInput, setEmailInput] = useState(\"\");\n  const [subscriptionState, setSubscriptionState] = useState<\"idle\" | \"submitting\" | \"success\">(\"idle\");\n\n  // Handle document download simulation\n  const startDownloadSimulation = (id: string) => {\n    if (downloadingId) return; // Prevent double trigger\n    setDownloadSuccessId(null);\n    setDownloadProgress(0);\n    setDownloadingId(id);\n  };\n\n  useEffect(() => {\n    let interval: NodeJS.Timeout;\n    if (downloadingId) {\n      interval = setInterval(() => {\n        setDownloadProgress((prev) => {\n          if (prev >= 100) {\n            clearInterval(interval);\n            setDownloadSuccessId(downloadingId);\n            setDownloadingId(null);\n            // Auto fade the checkmark state after 4 seconds\n            setTimeout(() => {\n              setDownloadSuccessId((curr) => (curr === downloadingId ? null : curr));\n            }, 4000);\n            return 100;\n          }\n          return prev + Math.floor(Math.random() * 20) + 10;\n        });\n      }, 180);\n    }\n    return () => clearInterval(interval);\n  }, [downloadingId]);\n\n  // Handle register interest submission simulation\n  const handleRegisterInterest = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!emailInput || !emailInput.includes(\"@\")) return;\n\n    setSubscriptionState(\"submitting\");\n    setTimeout(() => {\n      setSubscriptionState(\"success\");\n    }, 1200);\n  };\n\n  const closeChannelModal = () => {\n    setActiveChannel(null);\n    setEmailInput(\"\");\n    setSubscriptionState(\"idle\");\n  };\n\n  return (\n    <motion.section\n      id=\"research\"\n      initial={{ opacity: 0 }}\n      whileInView={{ opacity: 1 }}\n      viewport={{ once: true }}\n      transition={{ duration: 0.8 }}\n      className=\"w-full bg-[#030303] text-white px-6 lg:px-16 py-24 lg:py-32 relative overflow-hidden border-t border-white/5\"\n    >\n      {/* Background visual cues */}\n      <div className=\"absolute top-0 right-0 w-[500px] h-[500px] bg-gradient-radial from-[#009DFF]/5 via-transparent to-transparent opacity-40 pointer-events-none\" />\n      <div className=\"absolute bottom-0 left-0 w-[600px] h-[600px] bg-gradient-radial from-[#E98828]/5 via-transparent to-transparent opacity-30 pointer-events-none\" />\n\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        \n        {/* Header Block */}\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16\">\n          <SectionHeading\n            title={\n              <h2 className=\"text-[32px] sm:text-[44px] leading-tight font-bold uppercase tracking-wider text-white\">\n                LATEST <span className=\"text-[#009DFF]\">RESEARCH</span> & INTEL\n              </h2>\n            }\n            titleClassName=\"text-left\"\n            dividerWidthClassName=\"w-[180px]\"\n          />\n          <p className=\"text-[#A0A0A0] text-[14px] sm:text-[15px] max-w-md font-light leading-relaxed\">\n            Access GFF's technical blueprints, architectural paradigms, and operational safety standards for enterprise multi-agent execution.\n          </p>\n        </div>\n\n        {/* 1. Core Categories Grid (Articles, Videos, Podcasts, Whitepapers) */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-24\">\n          {CATEGORIES.map((c, i) => (\n            <motion.div\n              key={c.name}\n              initial={{ y: 20, opacity: 0 }}\n              whileInView={{ y: 0, opacity: 1 }}\n              viewport={{ once: true }}\n              transition={{ duration: 0.4, delay: i * 0.08 }}\n              className=\"relative rounded-[24px] p-[1px] bg-gradient-to-b from-white/10 via-transparent to-transparent hover:from-white/20 transition-all duration-500 h-full group\"\n            >\n              <div className=\"relative h-full rounded-[23px] bg-[#080808]/90 p-8 flex flex-col justify-between min-h-[260px] overflow-hidden border border-white/5\">\n                \n                {/* Accent glow on hover */}\n                <div \n                  className=\"absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none\" \n                  style={{ background: `radial-gradient(circle at 10% 10%, ${c.bgGlow} 0%, transparent 65%)` }} \n                />\n\n                <div>\n                  <div className=\"flex items-center justify-between mb-6\">\n                    <div className=\"w-10 h-10 rounded-xl flex items-center justify-center bg-white/5 border border-white/10 group-hover:border-white/20 transition-colors\">\n                      {c.icon}\n                    </div>\n                    <span className=\"text-[9px] font-mono tracking-widest text-white/30 group-hover:text-white/50 uppercase transition-colors\">\n                      Secure Channel\n                    </span>\n                  </div>\n\n                  <h3 \n                    className=\"text-[22px] font-bold tracking-tight text-white transition-all duration-300 group-hover:translate-x-1\"\n                  >\n                    {c.name}\n                  </h3>\n                  \n                  <p className=\"text-[13.5px] text-[#A0A0A0] leading-relaxed mt-4 font-light group-hover:text-white/80 transition-colors\">\n                    {c.desc}\n                  </p>\n                </div>\n\n                <div className=\"mt-8 pt-4 border-t border-white/5 flex items-center justify-between text-[12px] font-mono font-medium\">\n                  <span className=\"text-white/40 group-hover:text-white/70 transition-colors\">Browse Category</span>\n                  <span className=\"text-white/30 group-hover:translate-x-1 transition-transform\" style={{ color: c.accentColor }}>→</span>\n                </div>\n\n              </div>\n            </motion.div>\n          ))}\n        </div>\n\n        {/* 2. Split Workspace (Active Specs Index & Network Channels Directory) */}\n        <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-10 items-stretch\">\n          \n          {/* Left Column (8/12 width): Engineering Specs Preview / Research Papers */}\n          <div className=\"xl:col-span-7 flex flex-col justify-between\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#009DFF] block mb-2\">Active Index</span>\n              <h3 className=\"text-2xl font-bold tracking-tight text-white uppercase\">\n                Enterprise Engineering Specifications\n              </h3>\n              <p className=\"text-[14px] text-white/55 font-light mt-1\">\n                Authentic structural standards verified by GFF Core Platform and Protocol divisions.\n              </p>\n            </div>\n\n            <div className=\"space-y-4\">\n              {RESEARCH_PAPERS.map((paper) => {\n                const isThisDownloading = downloadingId === paper.id;\n                const isThisSuccess = downloadSuccessId === paper.id;\n\n                return (\n                  <div\n                    key={paper.id}\n                    className=\"relative rounded-[20px] bg-[#070707] border border-white/5 hover:border-white/15 p-6 transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between gap-6 group\"\n                  >\n                    {/* Inner content */}\n                    <div className=\"max-w-xl\">\n                      <div className=\"flex flex-wrap items-center gap-3 mb-2.5\">\n                        <span className=\"text-[10px] font-mono uppercase text-white/40 tracking-wider\">\n                          {paper.category}\n                        </span>\n                        <span className={`text-[9px] font-mono border px-2 py-0.5 rounded-full tracking-wider uppercase font-semibold ${paper.tagColor}`}>\n                          {paper.tag}\n                        </span>\n                      </div>\n                      \n                      <h4 className=\"text-[16px] sm:text-[17px] font-bold text-white tracking-tight group-hover:text-[#009DFF] transition-colors\">\n                        {paper.title}\n                      </h4>\n                      \n                      <p className=\"text-[13px] text-white/55 leading-relaxed mt-2 font-light\">\n                        {paper.description}\n                      </p>\n\n                      <div className=\"flex items-center gap-2 mt-3.5 text-white/30 font-mono text-[11px]\">\n                        <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                        </svg>\n                        <span>{paper.size}</span>\n                      </div>\n                    </div>\n\n                    {/* Simulation Download Trigger */}\n                    <div className=\"md:self-center flex flex-col items-stretch md:items-end justify-center min-w-[150px]\">\n                      {isThisDownloading ? (\n                        <div className=\"w-full text-center md:text-right\">\n                          <span className=\"text-[#009DFF] text-[11px] font-mono block mb-1.5 animate-pulse\">\n                            DECRYPTING STREAM {downloadProgress}%\n                          </span>\n                          <div className=\"w-full bg-white/10 rounded-full h-1.5 overflow-hidden\">\n                            <motion.div \n                              className=\"bg-[#009DFF] h-1.5 rounded-full\"\n                              style={{ width: `${downloadProgress}%` }}\n                            />\n                          </div>\n                        </div>\n                      ) : isThisSuccess ? (\n                        <div className=\"flex items-center justify-center md:justify-end gap-2 text-emerald-400 font-mono text-[11.5px] uppercase border border-emerald-400/25 bg-emerald-400/5 px-4 py-2.5 rounded-full\">\n                          <svg className=\"w-4 h-4 animate-bounce\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                          </svg>\n                          <span>Spec Dispatched</span>\n                        </div>\n                      ) : (\n                        <button\n                          onClick={() => startDownloadSimulation(paper.id)}\n                          className=\"flex items-center justify-center gap-2 bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF] hover:text-[#009DFF] text-white/80 font-mono text-[11.5px] uppercase tracking-wider px-5 py-3 rounded-full transition-all cursor-pointer font-bold duration-300 w-full md:w-auto\"\n                        >\n                          <span>Decrypt Spec</span>\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122\" />\n                          </svg>\n                        </button>\n                      )}\n                    </div>\n\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* Right Column (5/12 width): GFF Intelligence Channels Directory */}\n          <div className=\"xl:col-span-5 flex flex-col justify-between\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#E98828] block mb-2\">Hub Registry</span>\n              <h3 className=\"text-2xl font-bold tracking-tight text-white uppercase\">\n                Intelligence Network Directory\n              </h3>\n              <p className=\"text-[14px] text-white/55 font-light mt-1\">\n                Centralized gateway routes for continuous updates, case histories, and research branches.\n              </p>\n            </div>\n\n            {/* Matrix grid of the 12 routes */}\n            <div className=\"grid grid-cols-2 gap-3.5\">\n              {DIRECTORY_CHANNELS.map((channel, i) => (\n                <button\n                  key={channel.name}\n                  onClick={() => setActiveChannel(channel.name)}\n                  className=\"group rounded-xl border border-white/5 hover:border-white/15 bg-[#070707] hover:bg-[#0c0c0c] p-4 text-left transition-all duration-300 relative overflow-hidden flex flex-col justify-between min-h-[95px] cursor-pointer\"\n                >\n                  {/* Absolute glowing element */}\n                  <div className=\"absolute top-1.5 right-2 flex items-center gap-1.5\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse opacity-60\" />\n                    <span className=\"text-[7.5px] font-mono uppercase tracking-widest text-white/30 group-hover:text-white/60\">\n                      Access\n                    </span>\n                  </div>\n\n                  <div className=\"text-lg mb-1 filter grayscale group-hover:grayscale-0 transition-all\">\n                    {channel.icon}\n                  </div>\n\n                  <div>\n                    <h4 className=\"text-[13.5px] font-bold text-white tracking-tight group-hover:text-[#E98828] transition-colors leading-tight\">\n                      {channel.name}\n                    </h4>\n                    <p className=\"text-[10.5px] text-white/40 group-hover:text-white/60 transition-colors mt-0.5 leading-none\">\n                      {channel.category}\n                    </p>\n                  </div>\n                </button>\n              ))}\n            </div>\n\n            {/* Extra information callout */}\n            <div className=\"mt-6 rounded-xl border border-[#9D00FF]/20 bg-[#9D00FF]/5 p-4 flex items-start gap-3\">\n              <span className=\"text-lg\">🔐</span>\n              <div>\n                <h5 className=\"text-[12px] font-bold uppercase tracking-wider text-white\">Secure Sandbox Routing Layer</h5>\n                <p className=\"text-[11px] text-white/50 leading-relaxed mt-0.5 font-light\">\n                  All intelligence directory gateways utilize decentralized verification layers. Direct specification decryptions are processed securely in-memory.\n                </p>\n              </div>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n\n      {/* 3. Secure Portal Release Interactive Overlay Dialog */}\n      <AnimatePresence>\n        {activeChannel && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            \n            {/* Backdrop Blur */}\n            <motion.div\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={closeChannelModal}\n              className=\"absolute inset-0 bg-black/85 backdrop-blur-[16px]\"\n            />\n\n            {/* Content Card */}\n            <motion.div\n              initial={{ opacity: 0, scale: 0.95, y: 15 }}\n              animate={{ opacity: 1, scale: 1, y: 0 }}\n              exit={{ opacity: 0, scale: 0.95, y: 15 }}\n              transition={{ type: \"spring\", damping: 25, stiffness: 350 }}\n              className=\"relative w-full max-w-[550px] rounded-[28px] border border-white/10 bg-[#0a0a0a] p-8 md:p-10 shadow-2xl overflow-hidden text-left\"\n            >\n              {/* Outer visual decor */}\n              <div className=\"absolute top-0 right-0 w-[200px] h-[200px] bg-gradient-radial from-[#E98828]/10 via-transparent to-transparent opacity-50 pointer-events-none\" />\n              <div className=\"absolute bottom-0 left-0 w-[250px] h-[250px] bg-gradient-radial from-[#9D00FF]/10 via-transparent to-transparent opacity-40 pointer-events-none\" />\n\n              {/* Close Button */}\n              <button\n                onClick={closeChannelModal}\n                className=\"absolute top-6 right-6 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/10 hover:border-white/30 text-white/50 hover:text-white transition-all cursor-pointer\"\n                aria-label=\"Close Portal Modal\"\n              >\n                ✕\n              </button>\n\n              <div className=\"relative z-10\">\n                {/* Glowing Security Badge */}\n                <div className=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#E98828]/25 bg-[#E98828]/5 text-[#E98828] font-mono text-[9.5px] uppercase tracking-widest font-semibold mb-6\">\n                  <span className=\"w-2 h-2 rounded-full bg-[#E98828] animate-ping\" />\n                  GFF Gateway: Stage 2 Draft Access\n                </div>\n\n                {/* Main Heading */}\n                <h3 className=\"text-2xl sm:text-3xl font-bold tracking-tight text-white uppercase\">\n                  Route: {activeChannel}\n                </h3>\n                \n                <p className=\"text-[14px] text-white/60 leading-relaxed mt-4 font-light\">\n                  This core directory resource page is currently undergoing standard security evaluation and architectural consolidation. Verification schedules place public deployment for <strong className=\"text-[#E98828] font-semibold\">{activeChannel}</strong> in the Q3 2026 Release Cycle.\n                </p>\n\n                {/* Split line */}\n                <div className=\"h-[1px] bg-white/10 my-6\" />\n\n                {/* Submitting state renderer */}\n                {subscriptionState === \"idle\" && (\n                  <form onSubmit={handleRegisterInterest} className=\"space-y-4\">\n                    <p className=\"text-[12px] font-mono uppercase tracking-wider text-white/40\">\n                      Request Pre-Release Specification Draft\n                    </p>\n                    \n                    <div className=\"relative\">\n                      <input\n                        type=\"email\"\n                        required\n                        value={emailInput}\n                        onChange={(e) => setEmailInput(e.target.value)}\n                        placeholder=\"Enter your enterprise email...\"\n                        className=\"w-full bg-black border border-white/10 rounded-xl px-5 py-3.5 text-[14px] text-white placeholder-white/30 focus:outline-none focus:border-[#E98828] focus:ring-1 focus:ring-[#E98828] transition-all\"\n                      />\n                    </div>\n\n                    <button\n                      type=\"submit\"\n                      className=\"w-full bg-white hover:bg-white/95 text-black font-mono text-[12px] uppercase tracking-wider py-3.5 rounded-xl transition-all cursor-pointer font-bold shadow-lg\"\n                    >\n                      Authenticate & Queue Request\n                    </button>\n                  </form>\n                )}\n\n                {subscriptionState === \"submitting\" && (\n                  <div className=\"py-8 flex flex-col items-center justify-center text-center\">\n                    {/* Futuristic loading circle */}\n                    <div className=\"w-12 h-12 rounded-full border-2 border-white/5 border-t-[#E98828] animate-spin mb-4\" />\n                    <p className=\"text-[13px] font-mono text-[#E98828] uppercase tracking-widest animate-pulse\">\n                      Validating Credentials...\n                    </p>\n                    <p className=\"text-[12px] text-white/40 mt-1.5 font-light\">\n                      Establishing sandbox route authorization.\n                    </p>\n                  </div>\n                )}\n\n                {subscriptionState === \"success\" && (\n                  <div className=\"py-4 space-y-4\">\n                    <div className=\"w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 mx-auto text-xl mb-2\">\n                      ✓\n                    </div>\n                    \n                    <div className=\"text-center\">\n                      <h4 className=\"text-[16px] font-bold text-white uppercase tracking-tight\">\n                        Clearance Request Logged\n                      </h4>\n                      <p className=\"text-[13px] text-white/50 leading-relaxed mt-2 font-light\">\n                        System security validation for <span className=\"text-emerald-400 font-mono font-medium\">{emailInput}</span> is queued. A secure pre-release link will be dispatched automatically upon draft publication.\n                      </p>\n                    </div>\n\n                    <button\n                      onClick={closeChannelModal}\n                      className=\"w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white/80 font-mono text-[12px] uppercase tracking-wider py-3 rounded-xl transition-all cursor-pointer font-bold mt-4\"\n                    >\n                      Dismiss Console\n                    </button>\n                  </div>\n                )}\n\n              </div>\n            </motion.div>\n\n          </div>\n        )}\n      </AnimatePresence>\n\n    </motion.section>\n  );\n}\n"}}}
