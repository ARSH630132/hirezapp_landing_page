{"ts":"2026-06-25T23:43:36.661Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"i4o27s4g","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/LatestResearchSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\n\nconst CATEGORIES = [\n  { name: \"Articles\", desc: \"Detailed technical analyses of multi-agent orchestration, transactional isolation, and secure execution boundaries.\", color: \"#E98828\", glow: \"rgba(233, 136, 40, 0.1)\" },\n  { name: \"Videos\", desc: \"Watch engineering walk-throughs, architecture breakdowns, and live terminal demonstrations of running agent systems.\", color: \"#009DFF\", glow: \"rgba(0, 157, 255, 0.1)\" },\n  { name: \"Podcasts\", desc: \"Listen to GFF's technical leads and research partners discuss compliance, scalability, and agentic design principles.\", color: \"#9D00FF\", glow: \"rgba(157, 0, 255, 0.1)\" },\n  { name: \"Whitepapers\", desc: \"Access foundational technical specifications, validation methodologies, and formal verification frameworks.\", color: \"#F74539\", glow: \"rgba(247, 69, 57, 0.1)\" }\n];\n\nconst SPECS = [\n  { id: \"gff-orch\", title: \"GFF Heuristic Agent Orchestration Framework v1.4\", category: \"Agentic AI / Architecture\", desc: \"Reference guide on dynamic routing, sub-agent spawning, and transactional isolation limits.\", size: \"2.4 MB SPEC\" },\n  { id: \"gff-sec\", title: \"Zero-Trust Agentic Security: Multi-Layer Sandboxing\", category: \"Security & Compliance\", desc: \"Analysis of memory boundaries, token obfuscation, and container isolation protocols.\", size: \"4.1 MB SPEC\" },\n  { id: \"gff-scale\", title: \"Horizontal Multi-Agent Scaling & Latency Benchmarks\", category: \"Scalability / Infra\", desc: \"Empirical study on microsecond-level state synchronization across global networks.\", size: \"1.8 MB DATA\" }\n];\n\nconst CHANNELS = [\n  { name: \"Blog\", cat: \"Daily Insights\" },\n  { name: \"Research\", cat: \"Core Theory\" },\n  { name: \"Case Studies\", cat: \"System Patterns\" },\n  { name: \"Architecture Library\", cat: \"Blueprints\" },\n  { name: \"Webinars\", cat: \"Knowledge Shares\" },\n  { name: \"Events\", cat: \"Tech Summits\" },\n  { name: \"Developer Docs\", cat: \"API/SDK Specs\" },\n  { name: \"Downloads\", cat: \"Secure Packages\" },\n  { name: \"Reports\", cat: \"Quarterly Intel\" },\n  { name: \"Newsroom\", cat: \"Official Press\" },\n  { name: \"Thought Leadership\", cat: \"Standard Boards\" },\n  { name: \"Patterns of Intelligence\", cat: \"Agent Paradigms\" }\n];\n\nexport default function LatestResearchSection() {\n  const [downloadingId, setDownloadingId] = useState<string | null>(null);\n  const [progress, setProgress] = useState(0);\n  const [successId, setSuccessId] = useState<string | null>(null);\n\n  const [activeChannel, setActiveChannel] = useState<string | null>(null);\n  const [email, setEmail] = useState(\"\");\n  const [subState, setSubState] = useState<\"idle\" | \"submitting\" | \"success\">(\"idle\");\n\n  const startDownload = (id: string) => {\n    if (downloadingId) return;\n    setSuccessId(null);\n    setProgress(0);\n    setDownloadingId(id);\n  };\n\n  useEffect(() => {\n    if (!downloadingId) return;\n    const interval = setInterval(() => {\n      setProgress((p) => {\n        if (p >= 100) {\n          clearInterval(interval);\n          setSuccessId(downloadingId);\n          setDownloadingId(null);\n          setTimeout(() => setSuccessId(null), 3000);\n          return 100;\n        }\n        return p + 20;\n      });\n    }, 120);\n    return () => clearInterval(interval);\n  }, [downloadingId]);\n\n  const handleSubscribe = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!email.includes(\"@\")) return;\n    setSubState(\"submitting\");\n    setTimeout(() => setSubState(\"success\"), 1000);\n  };\n\n  return (\n    <motion.section\n      id=\"research\"\n      initial={{ opacity: 0 }}\n      whileInView={{ opacity: 1 }}\n      viewport={{ once: true }}\n      transition={{ duration: 0.8 }}\n      className=\"w-full bg-[#030303] text-white px-6 lg:px-16 py-24 lg:py-32 relative overflow-hidden border-t border-white/5\"\n    >\n      <div className=\"absolute top-0 right-0 w-[400px] h-[400px] bg-gradient-radial from-[#009DFF]/5 via-transparent to-transparent opacity-40 pointer-events-none\" />\n      <div className=\"absolute bottom-0 left-0 w-[400px] h-[400px] bg-gradient-radial from-[#E98828]/5 via-transparent to-transparent opacity-30 pointer-events-none\" />\n\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        \n        {/* Header */}\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16\">\n          <SectionHeading\n            title={\n              <h2 className=\"text-[30px] sm:text-[40px] leading-tight font-bold uppercase tracking-wider text-white\">\n                LATEST <span className=\"text-[#009DFF]\">RESEARCH</span> & INTEL\n              </h2>\n            }\n            titleClassName=\"text-left\"\n            dividerWidthClassName=\"w-[180px]\"\n          />\n          <p className=\"text-[#A0A0A0] text-[14px] sm:text-[15px] max-w-md font-light leading-relaxed\">\n            Access GFF's design paradigms, verified architectural frameworks, and operational safety specifications for enterprise multi-agent execution.\n          </p>\n        </div>\n\n        {/* 1. Core Categories */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20\">\n          {CATEGORIES.map((c, i) => (\n            <motion.div\n              key={c.name}\n              initial={{ y: 20, opacity: 0 }}\n              whileInView={{ y: 0, opacity: 1 }}\n              viewport={{ once: true }}\n              transition={{ duration: 0.4, delay: i * 0.05 }}\n              className=\"relative rounded-[20px] p-[1px] bg-gradient-to-b from-white/10 to-transparent hover:from-white/20 transition-all duration-500 h-full group\"\n            >\n              <div className=\"relative h-full rounded-[19px] bg-[#070707] p-7 flex flex-col justify-between min-h-[220px] overflow-hidden border border-white/5\">\n                <div className=\"absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none\" style={{ background: `radial-gradient(circle at 10% 10%, ${c.glow} 0%, transparent 65%)` }} />\n                <div>\n                  <div className=\"w-8 h-8 rounded-lg flex items-center justify-center bg-white/5 border border-white/10 mb-5 group-hover:border-white/20\">\n                    <div className=\"w-2.5 h-2.5 rounded-full\" style={{ backgroundColor: c.color }} />\n                  </div>\n                  <h3 className=\"text-[20px] font-bold tracking-tight text-white group-hover:translate-x-1 transition-transform\">{c.name}</h3>\n                  <p className=\"text-[13px] text-white/55 leading-relaxed mt-3 font-light group-hover:text-white/80 transition-colors\">{c.desc}</p>\n                </div>\n                <div className=\"mt-6 pt-3 border-t border-white/5 flex items-center justify-between text-[11px] font-mono text-white/40 group-hover:text-white/70\">\n                  <span>Browse Category</span>\n                  <span style={{ color: c.color }}>→</span>\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </div>\n\n        {/* 2. Split Workspace */}\n        <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-8 items-stretch\">\n          \n          {/* Active Specs */}\n          <div className=\"xl:col-span-7 flex flex-col justify-between\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#009DFF] block mb-1\">Active Index</span>\n              <h3 className=\"text-xl font-bold tracking-tight text-white uppercase\">Enterprise Specifications</h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              {SPECS.map((s) => {\n                const isDownloading = downloadingId === s.id;\n                const isSuccess = successId === s.id;\n                return (\n                  <div key={s.id} className=\"rounded-[16px] bg-[#070707] border border-white/5 p-5 flex flex-col md:flex-row md:items-center justify-between gap-5 hover:border-white/15 transition-all\">\n                    <div className=\"max-w-md\">\n                      <span className=\"text-[10px] font-mono uppercase text-white/40 tracking-wider block mb-1.5\">{s.category}</span>\n                      <h4 className=\"text-[15.5px] font-bold text-white tracking-tight\">{s.title}</h4>\n                      <p className=\"text-[12.5px] text-white/55 mt-1 font-light\">{s.desc}</p>\n                    </div>\n\n                    <div className=\"flex flex-col items-stretch md:items-end min-w-[140px]\">\n                      {isDownloading ? (\n                        <div className=\"w-full text-center\">\n                          <span className=\"text-[#009DFF] text-[10px] font-mono block mb-1 animate-pulse\">DECRYPTING {progress}%</span>\n                          <div className=\"w-full bg-white/5 rounded-full h-1 overflow-hidden\">\n                            <div className=\"bg-[#009DFF] h-1\" style={{ width: `${progress}%` }} />\n                          </div>\n                        </div>\n                      ) : isSuccess ? (\n                        <div className=\"text-emerald-400 font-mono text-[10.5px] uppercase border border-emerald-500/20 bg-emerald-500/5 px-3 py-1.5 rounded-full text-center\">\n                          ✓ Spec Streamed\n                        </div>\n                      ) : (\n                        <button onClick={() => startDownload(s.id)} className=\"bg-white/5 hover:bg-white/10 hover:border-[#009DFF] hover:text-[#009DFF] text-white border border-white/10 font-mono text-[10.5px] uppercase tracking-wider px-4 py-2 rounded-full cursor-pointer transition-all text-center\">\n                          Stream Spec\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* Directory Grid */}\n          <div className=\"xl:col-span-5 flex flex-col justify-between\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#E98828] block mb-1\">Hub Registry</span>\n              <h3 className=\"text-xl font-bold tracking-tight text-white uppercase\">Intelligence Channels</h3>\n            </div>\n\n            <div className=\"grid grid-cols-2 gap-3\">\n              {CHANNELS.map((ch) => (\n                <button\n                  key={ch.name}\n                  onClick={() => setActiveChannel(ch.name)}\n                  className=\"rounded-xl border border-white/5 bg-[#070707] hover:bg-[#0c0c0c] hover:border-white/15 p-3.5 text-left transition-all relative flex flex-col justify-between min-h-[85px] cursor-pointer group\"\n                >\n                  <div className=\"absolute top-1.5 right-2 flex items-center gap-1\">\n                    <span className=\"w-1 h-1 rounded-full bg-orange-500 animate-pulse\" />\n                    <span className=\"text-[7px] font-mono uppercase tracking-widest text-white/30 group-hover:text-white/50\">Access</span>\n                  </div>\n                  <span className=\"text-sm\">🔑</span>\n                  <div>\n                    <h4 className=\"text-[13px] font-bold text-white group-hover:text-[#E98828] transition-colors leading-tight\">{ch.name}</h4>\n                    <p className=\"text-[10px] text-white/40 leading-none mt-0.5\">{ch.cat}</p>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      {/* Gateway Overlay */}\n      <AnimatePresence>\n        {activeChannel && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={closeChannelModal} className=\"absolute inset-0 bg-black/80 backdrop-blur-[12px]\" />\n            <motion.div initial={{ opacity: 0, scale: 0.96 }} animate={{ opacity: 1, scale: 1 }} exit={{ opacity: 0, scale: 0.96 }} className=\"relative w-full max-w-[480px] rounded-[24px] border border-white/10 bg-[#0a0a0a] p-8 shadow-2xl text-left overflow-hidden\">\n              <button onClick={closeChannelModal} className=\"absolute top-5 right-5 text-white/40 hover:text-white transition-colors cursor-pointer text-sm\">✕</button>\n              \n              <div className=\"inline-flex items-center gap-2 px-2.5 py-1 rounded-full border border-[#E98828]/20 bg-[#E98828]/5 text-[#E98828] font-mono text-[9px] uppercase tracking-widest font-semibold mb-5\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-[#E98828] animate-ping\" />\n                GFF Gateway: Secure Portal\n              </div>\n\n              <h3 className=\"text-xl font-bold tracking-tight text-white uppercase\">Route: {activeChannel}</h3>\n              <p className=\"text-[13px] text-white/55 leading-relaxed mt-3 font-light\">\n                This gateway resource is undergoing formal compliance evaluation and structural deployment. Public access for <strong className=\"text-[#E98828] font-medium\">{activeChannel}</strong> is scheduled in the Q3 2026 GFF Intelligence Update.\n              </p>\n\n              <div className=\"h-[1px] bg-white/10 my-5\" />\n\n              {subState === \"idle\" && (\n                <form onSubmit={handleSubscribe} className=\"space-y-3\">\n                  <p className=\"text-[11px] font-mono uppercase tracking-wider text-white/40\">Request Pre-Release Specification Draft</p>\n                  <input\n                    type=\"email\" required value={email} onChange={(e) => setEmail(e.target.value)}\n                    placeholder=\"Enter enterprise email...\"\n                    className=\"w-full bg-black border border-white/10 rounded-lg px-4 py-3 text-[13px] text-white focus:outline-none focus:border-[#E98828] transition-all\"\n                  />\n                  <button type=\"submit\" className=\"w-full bg-white hover:bg-white/95 text-black font-mono text-[11px] uppercase tracking-wider py-3 rounded-lg transition-all cursor-pointer font-bold\">\n                    Authenticate & Queue Request\n                  </button>\n                </form>\n              )}\n\n              {subState === \"submitting\" && (\n                <div className=\"py-4 text-center\">\n                  <div className=\"w-8 h-8 rounded-full border-2 border-white/5 border-t-[#E98828] animate-spin mb-3 mx-auto\" />\n                  <p className=\"text-[11px] font-mono text-[#E98828] uppercase tracking-widest animate-pulse\">Establishing Route Clearance...</p>\n                </div>\n              )}\n\n              {subState === \"success\" && (\n                <div className=\"py-2 text-center space-y-3\">\n                  <div className=\"w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/25 flex items-center justify-center text-emerald-400 mx-auto text-md\">✓</div>\n                  <h4 className=\"text-[14px] font-bold text-white uppercase tracking-tight\">Clearance Request Logged</h4>\n                  <p className=\"text-[12.5px] text-white/50 leading-relaxed font-light\">System security validation for <span className=\"text-emerald-400 font-mono\">{email}</span> is queued. A notification will be dispatched automatically upon draft publication.</p>\n                  <button onClick={closeChannelModal} className=\"w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white font-mono text-[10.5px] uppercase tracking-wider py-2.5 rounded-lg cursor-pointer transition-all\">Dismiss Console</button>\n                </div>\n              )}\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n    </motion.section>\n  );\n}\n"}}}
