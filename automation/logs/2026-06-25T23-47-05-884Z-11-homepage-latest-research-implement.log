{"ts":"2026-06-25T23:44:06.150Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"1ddiiveg","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/LatestResearchSection.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\n\nconst CATEGORIES = [\n  { name: \"Articles\", desc: \"Detailed technical analyses of multi-agent orchestration and security boundaries.\", color: \"#E98828\" },\n  { name: \"Videos\", desc: \"Watch engineering walk-throughs and terminal demonstrations of agent runtimes.\", color: \"#009DFF\" },\n  { name: \"Podcasts\", desc: \"Listen to leads discuss compliance, scalability, and agentic design principles.\", color: \"#9D00FF\" },\n  { name: \"Whitepapers\", desc: \"Access foundational specifications and formal verification frameworks.\", color: \"#F74539\" }\n];\n\nconst SPECS = [\n  { id: \"orch\", title: \"GFF Heuristic Agent Orchestration Framework v1.4\", cat: \"Agentic AI / Architecture\", desc: \"Dynamic routing, sub-agent spawning, and isolation limit specifications.\", size: \"2.4 MB SPEC\" },\n  { id: \"sec\", title: \"Zero-Trust Agentic Security: Multi-Layer Sandboxing\", cat: \"Security & Compliance\", desc: \"Memory boundaries, token obfuscation, and container isolation standards.\", size: \"4.1 MB SPEC\" }\n];\n\nconst CHANNELS = [\n  \"Blog\", \"Research\", \"Case Studies\", \"Architecture Library\", \"Webinars\", \"Events\",\n  \"Developer Docs\", \"Downloads\", \"Reports\", \"Newsroom\", \"Thought Leadership\", \"Patterns of Intelligence\"\n];\n\nexport default function LatestResearchSection() {\n  const [downloading, setDownloading] = useState<string | null>(null);\n  const [progress, setProgress] = useState(0);\n  const [success, setSuccess] = useState<string | null>(null);\n  const [active, setActive] = useState<string | null>(null);\n  const [email, setEmail] = useState(\"\");\n  const [sub, setSub] = useState<\"idle\" | \"submitting\" | \"success\">(\"idle\");\n\n  useEffect(() => {\n    if (!downloading) return;\n    const interval = setInterval(() => {\n      setProgress((p) => {\n        if (p >= 100) {\n          clearInterval(interval);\n          setSuccess(downloading);\n          setDownloading(null);\n          setTimeout(() => setSuccess(null), 3500);\n          return 100;\n        }\n        return p + 25;\n      });\n    }, 120);\n    return () => clearInterval(interval);\n  }, [downloading]);\n\n  const handleSub = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!email.includes(\"@\")) return;\n    setSub(\"submitting\");\n    setTimeout(() => setSub(\"success\"), 1200);\n  };\n\n  const close = () => { setActive(null); setEmail(\"\"); setSub(\"idle\"); };\n\n  return (\n    <motion.section \n      id=\"research\" \n      initial={{ opacity: 0 }}\n      whileInView={{ opacity: 1 }}\n      viewport={{ once: true }}\n      transition={{ duration: 0.8 }}\n      className=\"w-full bg-[#030303] text-white px-6 lg:px-16 py-24 border-t border-white/5 relative overflow-hidden\"\n    >\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        \n        {/* Header Block */}\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16\">\n          <SectionHeading \n            title={\n              <h2 className=\"text-[30px] sm:text-[40px] font-bold uppercase tracking-wider text-left\">\n                LATEST <span className=\"text-[#009DFF]\">RESEARCH</span> & INTEL\n              </h2>\n            } \n            titleClassName=\"text-left\" \n            dividerWidthClassName=\"w-[180px]\" \n          />\n          <p className=\"text-[#A0A0A0] text-[14px] max-w-md font-light leading-relaxed\">\n            Access GFF's verified design paradigms, structural blueprints, and operational safety standards for enterprise multi-agent execution.\n          </p>\n        </div>\n\n        {/* 1. Core Categories Grid */}\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20\">\n          {CATEGORIES.map((c, i) => (\n            <div key={c.name} className=\"relative rounded-[16px] bg-[#070707] p-6 border border-white/5 hover:border-white/15 transition-all flex flex-col justify-between min-h-[220px] group\">\n              <div>\n                <div className=\"w-3 h-3 rounded-full mb-4 group-hover:scale-110 transition-transform\" style={{ backgroundColor: c.color }} />\n                <h3 className=\"text-[18px] font-bold tracking-tight text-white\">{c.name}</h3>\n                <p className=\"text-[13px] text-white/55 mt-2 font-light leading-relaxed\">{c.desc}</p>\n              </div>\n              <span className=\"text-[11px] font-mono mt-4 block\" style={{ color: c.color }}>Browse Category →</span>\n            </div>\n          ))}\n        </div>\n\n        {/* 2. Split Workspace (Specs Index & Directory Channels) */}\n        <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-8 items-stretch\">\n          \n          {/* Left Panel: Verified Specifications */}\n          <div className=\"xl:col-span-7 flex flex-col justify-between\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#009DFF] block mb-1\">Active Index</span>\n              <h3 className=\"text-xl font-bold tracking-tight text-white uppercase\">Enterprise Specifications</h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              {SPECS.map((s) => (\n                <div key={s.id} className=\"rounded-[12px] bg-[#070707] border border-white/5 p-5 flex flex-col md:flex-row md:items-center justify-between gap-4 hover:border-white/12 transition-all\">\n                  <div className=\"max-w-md\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block mb-1\">{s.cat} • {s.size}</span>\n                    <h4 className=\"text-[15px] font-bold text-white tracking-tight\">{s.title}</h4>\n                    <p className=\"text-[12.5px] text-white/55 mt-1 font-light leading-relaxed\">{s.desc}</p>\n                  </div>\n                  <div className=\"min-w-[120px] text-right\">\n                    {downloading === s.id ? (\n                      <span className=\"text-[#009DFF] text-[10.5px] font-mono animate-pulse block\">STREAMING {progress}%</span>\n                    ) : success === s.id ? (\n                      <span className=\"text-emerald-400 font-mono text-[10.5px] uppercase block\">✓ Streamed</span>\n                    ) : (\n                      <button \n                        onClick={() => startDownload(s.id)} \n                        className=\"bg-white/5 hover:bg-white/10 text-white border border-white/10 font-mono text-[10.5px] uppercase tracking-wider px-3.5 py-1.5 rounded-full cursor-pointer transition-all duration-300 block w-full md:w-auto text-center\"\n                      >\n                        Stream Spec\n                      </button>\n                    )}\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          {/* Right Panel: Hub Registry */}\n          <div className=\"xl:col-span-5\">\n            <div className=\"mb-6\">\n              <span className=\"text-[10px] font-mono uppercase tracking-[0.25em] text-[#E98828] block mb-1\">Hub Registry</span>\n              <h3 className=\"text-xl font-bold tracking-tight text-white uppercase\">Intelligence Channels</h3>\n            </div>\n            \n            <div className=\"grid grid-cols-2 gap-3\">\n              {CHANNELS.map((ch) => (\n                <button \n                  key={ch} \n                  onClick={() => setActive(ch)} \n                  className=\"rounded-xl border border-white/5 bg-[#070707] hover:bg-[#0c0c0c] hover:border-white/15 p-4 text-left transition-all flex items-center justify-between min-h-[60px] cursor-pointer group\"\n                >\n                  <span className=\"text-[13px] font-bold text-white group-hover:text-[#E98828] transition-colors leading-tight\">{ch}</span>\n                  <span className=\"text-[8.5px] font-mono text-white/30 group-hover:text-white/60\">ACCESS</span>\n                </button>\n              ))}\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      {/* Gateway Dialog Overlay */}\n      <AnimatePresence>\n        {active && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} onClick={close} className=\"absolute inset-0 bg-black/80 backdrop-blur-[10px]\" />\n            <motion.div \n              initial={{ opacity: 0, scale: 0.96 }} \n              animate={{ opacity: 1, scale: 1 }} \n              exit={{ opacity: 0, scale: 0.96 }} \n              className=\"relative w-full max-w-[440px] rounded-[20px] border border-white/10 bg-[#0a0a0a] p-6 shadow-2xl text-left\"\n            >\n              <button onClick={close} className=\"absolute top-4 right-4 text-white/40 hover:text-white text-xs cursor-pointer\">✕</button>\n              \n              <span className=\"text-[#E98828] font-mono text-[9px] uppercase tracking-widest font-semibold block mb-2\">GFF Gateway Security</span>\n              <h3 className=\"text-lg font-bold text-white uppercase\">Route: {active}</h3>\n              <p className=\"text-[12.5px] text-white/55 leading-relaxed mt-2 font-light\">\n                This channel is undergoing formal compliance evaluation and deployment. Secure access for <strong className=\"text-[#E98828] font-medium\">{active}</strong> is scheduled for the GFF Q3 2026 update.\n              </p>\n              \n              <div className=\"h-[1px] bg-white/10 my-4\" />\n              \n              {sub === \"idle\" && (\n                <form onSubmit={handleSub} className=\"space-y-3\">\n                  <p className=\"text-[10px] font-mono uppercase text-white/40\">Request Pre-Release Spec Draft</p>\n                  <input \n                    type=\"email\" \n                    required \n                    value={email} \n                    onChange={(e) => setEmail(e.target.value)} \n                    placeholder=\"Enter enterprise email...\" \n                    className=\"w-full bg-black border border-white/10 rounded-lg px-3.5 py-2.5 text-[12.5px] text-white focus:outline-none focus:border-[#E98828] transition-all\" \n                  />\n                  <button type=\"submit\" className=\"w-full bg-white text-black font-mono text-[10.5px] uppercase tracking-wider py-2.5 rounded-lg cursor-pointer font-bold transition-all\">Queue Request</button>\n                </form>\n              )}\n\n              {sub === \"submitting\" && (\n                <div className=\"text-center py-4\">\n                  <div className=\"w-6 h-6 rounded-full border-2 border-white/5 border-t-[#E98828] animate-spin mb-3 mx-auto\" />\n                  <span className=\"text-[#E98828] text-[10px] font-mono animate-pulse uppercase\">Establishing Clearance Route...</span>\n                </div>\n              )}\n\n              {sub === \"success\" && (\n                <div className=\"text-center space-y-3 py-2\">\n                  <div className=\"w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/25 flex items-center justify-center text-emerald-400 mx-auto text-md\">✓</div>\n                  <h4 className=\"text-[13.5px] font-bold text-white uppercase\">Request Logged</h4>\n                  <p className=\"text-[12px] text-white/50 leading-relaxed font-light\">\n                    System security validation for <span className=\"text-emerald-400 font-mono\">{email}</span> has been queued. A notification will be dispatched upon draft publication.\n                  </p>\n                  <button onClick={close} className=\"w-full bg-white/5 hover:bg-white/10 border border-white/10 text-white font-mono text-[10px] uppercase tracking-wider py-2 rounded-lg cursor-pointer transition-all\">Dismiss Console</button>\n                </div>\n              )}\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n    </motion.section>\n  );\n}\n"}}}
