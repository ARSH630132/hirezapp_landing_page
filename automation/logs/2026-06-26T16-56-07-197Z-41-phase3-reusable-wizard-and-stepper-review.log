g;\n511 | }\n512 | \n513 | export function ToolSummaryCard({ label, value, description, accentColor = \"#009DFF\" }: ToolSummaryCardProps) {\n514 |   return (\n515 |     <div className=\"p-5 rounded-xl border border-white/5 bg-[#030305] flex flex-col justify-between hover:border-white/10 transition-all group relative\">\n516 |       {/* Light edge beam */}\n517 |       <div\n518 |         className=\"absolute top-0 left-1/4 right-1/4 h-[1px] opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\"\n519 |         style={{\n520 |           background: `linear-gradient(90deg, transparent, ${accentColor}, transparent)`\n521 |         }}\n522 |       />\n523 |       <div>\n524 |         <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">{label}</span>\n525 |         <span className=\"text-2xl lg:text-3xl font-bold text-white block mt-2 font-mono tracking-tight\" style={{ textShadow: `0 0 15px ${accentColor}10` }}>\n526 |           {value}\n527 |         </span>\n528 |       </div>\n529 |       {description && (\n530 |         <p className=\"text-[11px] text-white/40 font-light mt-2 leading-tight\">\n531 |           {description}\n532 |         </p>\n533 |       )}\n534 |     </div>\n535 |   );\n536 | }\n537 | \n538 | \n539 | \n540 | // ==========================================\n541 | // 12. ToolEmptyState\n542 | // ==========================================\n543 | interface ToolEmptyStateProps {\n544 |   title: string;\n545 |   description: string;\n546 |   actionText?: string;\n547 |   onAction?: () => void;\n548 | }\n549 | \n550 | export function ToolEmptyState({ title, description, actionText, onAction }: ToolEmptyStateProps) {\n551 |   return (\n552 |     <div className=\"p-8 lg:p-12 rounded-2xl border border-white/5 bg-[#030304]/80 backdrop-blur-sm text-center space-y-6 flex flex-col items-center justify-center min-h-[350px]\">\n553 |       {/* Schematic SVG Blueprint graphic */}\n554 |       <div className=\"w-16 h-16 rounded-xl border border-white/10 bg-white/[0.02] flex items-center justify-center text-white/20 relative group\">\n555 |         <div className=\"absolute inset-0 bg-grid-pattern opacity-10 rounded-xl\" />\n556 |         <svg className=\"w-8 h-8 font-light\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n557 |           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.2} d=\"M9 20l-5.447-2.724A2 2 0 013 15.485V5.515a2 2 0 011.553-1.954l8.944-4.472a2 2 0 011.11 0l8.944 4.472A2 2 0 0121 5.515v9.97a2 2 0 01-1.553 1.954L15 20M9 20l3 1.5 3-1.5M9 20v-5m6 5v-5M12 2.25V15\" />\n558 |         </svg>\n559 |       </div>\n560 | \n561 |       <div className=\"space-y-2 max-w-sm\">\n562 |         <h4 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">{title}</h4>\n563 |         <p className=\"text-white/40 text-xs font-light leading-relaxed\">{description}</p>\n564 |       </div>\n565 | \n566 |       {actionText && onAction && (\n567 |         <button\n568 |           onClick={onAction}\n569 |           className=\"px-5 py-2.5 rounded-lg text-xs font-semibold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 hover:bg-[#009DFF]/10 transition\"\n570 |         >\n571 |           {actionText}\n572 |         </button>\n573 |       )}\n574 |     </div>\n575 |   );\n576 | }\n577 | \n578 | // ==========================================\n579 | // 13. ToolTabs\n580 | // ==========================================\n581 | interface TabItem {\n582 |   id: string;\n583 |   label: string;\n584 | }\n585 | \n586 | interface ToolTabsProps {\n587 |   tabs: TabItem[];\n588 |   activeTabId: string;\n589 |   onChange: (id: string) => void;\n590 |   accentColor?: string;\n591 | }\n592 | \n593 | export function ToolTabs({ tabs, activeTabId, onChange, accentColor = \"#009DFF\" }: ToolTabsProps) {\n594 |   return (\n595 |     <div className=\"flex gap-1.5 p-1 rounded-xl bg-[#04060b] border border-white/5 self-start overflow-x-auto scrollbar-none w-full max-w-md\">\n596 |       {tabs.map((tab) => {\n597 |         const isActive = tab.id === activeTabId;\n598 | \n599 |         return (\n600 |           <button\n601 |             key={tab.id}\n602 |             onClick={() => onChange(tab.id)}\n603 |             type=\"button\"\n604 |             className=\"relative px-4 py-2 text-xs font-semibold rounded-lg uppercase tracking-wider transition-colors duration-200 cursor-pointer flex-1 text-center text-white/50 hover:text-white\"\n605 |           >\n606 |             {/* Sliding backdrop indicator */}\n607 |             {isActive && (\n608 |               <motion.div\n609 |                 layoutId=\"active-tool-tab\"\n610 |                 className=\"absolute inset-0 bg-white/[0.03] border border-white/5 rounded-lg shadow-sm\"\n611 |                 transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n612 |                 style={{\n613 |                   borderTopColor: `${accentColor}30`,\n614 |                   borderBottomColor: `${accentColor}30`\n615 |                 }}\n616 |               />\n617 |             )}\n618 |             \n619 |             <span className={`relative z-10 transition-colors ${isActive ? \"text-white font-bold\" : \"\"}`}>\n620 |               {tab.label}\n621 |             </span>\n622 |           </button>\n623 |         );\n624 |       })}\n625 |     </div>\n626 |   );\n627 | }\n628 | \n629 | \n630 | \n631 | // ==========================================\n632 | // 14. ToolComparisonRail","success":true}],"durationMs":4}}
