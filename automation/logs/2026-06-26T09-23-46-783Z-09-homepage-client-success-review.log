[0]]);\n201 |         logIndexRef.current = 1;\n202 |       }\n203 |     }, playSpeed);\n204 |   }, [activePattern.logs, playSpeed]);\n205 | \n206 |   useEffect(() => {\n207 |     setStreamedLogs([activePattern.logs[0]]);\n208 |     logIndexRef.current = 1;\n209 |     \n210 |     if (timerIdRef.current) {\n211 |       clearInterval(timerIdRef.current);\n212 |     }\n213 | \n214 |     if (isPlaying) {\n215 |       startLogStream();\n216 |     }\n217 | \n218 |     return () => {\n219 |       if (timerIdRef.current) clearInterval(timerIdRef.current);\n220 |     };\n221 |   }, [activePattern.logs, isPlaying, startLogStream]);\n222 | \n223 |   const handleTogglePlay = () => {\n224 |     if (isPlaying) {\n225 |       if (timerIdRef.current) clearInterval(timerIdRef.current);\n226 |       setIsPlaying(false);\n227 |     } else {\n228 |       setIsPlaying(true);\n229 |     }\n230 |   };\n231 | \n232 |   const handleResetStream = () => {\n233 |     setStreamedLogs([activePattern.logs[0]]);\n234 |     logIndexRef.current = 1;\n235 |     if (isPlaying) {\n236 |       startLogStream();\n237 |     }\n238 |   };\n239 | \n240 |   return (\n241 |     <motion.section \n242 |       initial={{ opacity: 0 }}\n243 |       whileInView={{ opacity: 1 }}\n244 |       viewport={{ once: true }}\n245 |       transition={{ duration: 1 }}\n246 |       className=\"w-full bg-[#020202] px-6 lg:px-16 lg:py-32 py-20 relative overflow-hidden\"\n247 |     >\n248 |       <div className=\"absolute inset-0 pointer-events-none\" style={{ backgroundImage: \"radial-gradient(circle at 100% 50%, #E9882805 0%, transparent 40%)\" }} />\n249 |       \n250 |       <div className=\"max-w-[1795px] mx-auto relative z-10\">\n251 |         \n252 |         {/* Section Heading */}\n253 |         <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16\">\n254 |           <SectionHeading\n255 |             title={\n256 |               <h2 className=\"text-[32px] sm:text-[44px] leading-none font-