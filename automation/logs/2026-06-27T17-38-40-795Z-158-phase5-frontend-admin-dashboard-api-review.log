mic Support Tickets */}\n381 |               {support.recent.slice(0, 1).map((t: any) => {\n382 |                 const isAcked = ack[t.id];\n383 |                 return (\n384 |                   <div key={t.id} className={`p-2 rounded border transition-all duration-300 ${isAcked ? \"border-white/5 opacity-40 bg-transparent\" : \"bg-rose-500/[0.03] border-rose-500/10 hover:border-rose-500/20\"}`}>\n385 |                     <div className=\"flex justify-between items-center gap-2\">\n386 |                       <div className=\"truncate flex-1\">\n387 |                         <div className=\"flex items-center gap-1.5\">\n388 |                           <span className=\"text-[7.5px] px-1 rounded bg-rose-500/10 text-rose-400 font-bold font-sans uppercase\">SLA W-{(t.priority || \"P1\").toUpperCase()}</span>\n389 |                           <span className=\"font-bold text-white/90 truncate\">{t.subject}</span>\n390 |                         </div>\n391 |                         <div className=\"text-[8.5px] text-white/40 mt-0.5 truncate\">{t.client_name}</div>\n392 |                       </div>\n393 |                       {!isAcked && (\n394 |                         <button \n395 |                           onClick={() => { \n396 |                             setAck(p => ({ ...p, [t.id]: true })); \n397 |                             logTelemetry(`Acknowledged critical operational ticket ${t.id} from client.`); \n398 |                           }} \n399 |                           className=\"h-5 px-2 rounded bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 border border-rose-500/20 hover:border-rose-500/35 text-[8.5px] font-bold uppercase transition-all cursor-pointer shrink-0\"\n400 |                         >","success":true}],"durationMs":7}}
