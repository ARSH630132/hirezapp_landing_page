  {/* Silent Quick Sync trigger button */}\n248 |         <button \n249 |           onClick={() => {\n250 |             fetchDashboardData(true);\n251 |             logTelemetry(\"Manual system sweep initiated. Synchronizing mesh memory ledger...\");\n252 |           }}\n253 |           className=\"h-7 px-2.5 rounded border border-white/5 hover:border-white/15 bg-white/[0.01] hover:bg-white/[0.03] text-[9px] font-bold uppercase tracking-wider flex items-center gap-1.5 transition-all cursor-pointer text-white/75\"\n254 |           title=\"Force telemetry ledger synchronization\"\n255 |         >\n256 |           <RefreshCw className=\"w-3 h-3 text-[#009DFF]\" />\n257 |           <span>Sync Ledger</span>\n258 |         </button>\n259 |       </div>\n260 |       \n261 |       {/* KPIs */}\n262 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n263 |         {[\n264 |           { \n265 |             l: \"Sandboxes\", \n266 |             v: `${clients.totalCount || 0} Clusters`, \n267 |             i: Server,\n268 |             c: \"text-sky-400\"\n269 |           },\n270 |           { \n271 |             l: \"Active AI Loops\", \n272 |             v: `${aiOperations.activeCount || 0} Loops`, \n273 |             i: Activity,\n274 |             c: \"text-emerald-400\"\n275 |           },\n276 |           { \n277 |             l: \"Pending SLA\", \n278 |             v: `${unresolvedSlaCount} Wires`, \n279 |             i: Clock,\n280 |             c: unresolvedSlaCount > 0 ? \"text-rose-400 animate-pulse\" : \"text-zinc-500\"\n281 |           },\n282 |           { \n283 |             l: \"ISO Compliance Status\", \n284 |             v: unresolvedGovCount === 0 ? \"100% SECURE\" : `${unresolvedGovCount} RISKS`, \n285 |             i: ShieldCheck,\n286 |             c: unresolvedGovCount === 0 ? \"text-emerald-400\" : \"text-amber-400 animate-pulse\"\n287 |           }\n288 |         ].map((k, idx) => {\n289 |           const Icon = k.i;\n290 |           return (\n291 |             <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between items-center hover:border-white/10 transition-colors\">\n292 |               <div>\n293 |                 <span className=\"text-[9px] text-white/35 uppercase\">{k.l}</span>\n294 |                 <div className=\"text-base font-bold tracking-tight mt-0.5\">{k.v}</div>\n295 |               </div>\n296 |               <Icon className={`w-4 h-4 ${k.c}`} />\n297 |             </div>\n298 |           );\n299 |         })}\n300 |       </div>\n301 | \n302 |       {/* BENTO GRID */}\n303 |       <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n304 |         {/* Column 1: Clients & Projects Overview */}\n305 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-3 flex flex-col justify-between min-h-[220px]\">\n306 |           <div>\n307 |             <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n308 |               <span className=\"text-xs font-bold uppercase tracking-wider block\">Clients & Projects</span>\n309 |               <span className=\"text-[8px] px-1.5 py-0.5 rounded bg-white/5 border border-white/10 text-white/50\">{clients.totalCount} active</span>\n310 |             </div>\n311 |             <div className=\"space-y-2.5 mt-3\">\n312 |               {clients.recent.slice(0, 3).map((c: any) => (\n313 |                 <div key={c.id} className=\"flex justify-between items-center text-[10px] group hover:bg-white/[0.01] p-1 rounded transition-colors\">\n314 |                   <div className=\"flex flex-col\">\n315 |                     <span className=\"font-bold text-white/80 group-hover:text-white transition-colors truncate max-w-[150px]\">{c.name}</span>\n316 |                     <span className=\"text-[8px] text-white/35 uppercase tracking-wider\">{c.tier} Tier</span>\n317 |                   </div>\n318 |                   <span className=\"text-[8.5px