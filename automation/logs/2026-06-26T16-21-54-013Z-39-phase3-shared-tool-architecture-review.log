 |   const rawSum = dataIntegration + vpcIsolation + complianceTelemetry + fleetStrategy;\n 78 |   const score = Math.round((rawSum / 20) * 100);\n 79 | \n 80 |   let level = \"Discovery Sandbox Phase\";\n 81 |   let color = \"#E4000F\";\n 82 |   let description =\n 83 |     \"Your data resides in disconnected legacy clusters. Running an isolated sandbox trace in GFF Labs is highly recommended to design custom security schemas.\";\n 84 | \n 85 |   if (score >= 80) {\n 86 |     level = \"Sovereign Production Ready\";\n 87 |     color = \"#00FF9D\";\n 88 |     description =\n 89 |       \"Your network edge nodes and unified vector caches are fully optimized for autonomous agent deployment in hardened private subnets.\";\n 90 |   } else if (score >= 55) {\n 91 |     level = \"Strategic Incubation Required\";\n 92 |     color = \"#3B82F6\";\n 93 |     description =\n 94 |       \"Solid infrastructural foundations exist, but real-time audit logs and single-tenant hardware isolation policies require further alignment.\";\n 95 |   }\n 96 | \n 97 |   const dimensionScores = [\n 98 |     {\n 99 |       label: \"Data Pipeline Integration\",\n100 |       score: dataIntegration,\n101 |       description: dataIntegration >= 4 ? \"Excellent vectorized caching\" : \"Legacy relational bottlenecks present\",\n102 |       recommendation:\n103 |         dataIntegration >= 4\n104 |           ? \"Maintain secure local cache structures.\"\n105 |           : \"Introduce GFF OmniMesh connectors to bridge relational mainframes directly.\"\n106 |     },\n107 |     {\n108 |       label: \"VPC Network Isolation\",\n109 |       score: vpcIsolation,\n110 |       description: vpcIsolation >= 4 ? \"Hardened private enclave isolated\" : \"Shared ingress pathways vulnerable\",\n111 |       recommendation:\n112 |         vpcIsolation >= 4\n113 |           ? \"Execute quarterly zero-trust dry runs.\"\n114 |           : \"Enforce single-tenant subnets with GFF dedicated edge nodes.\"\n115 |     },\n116 |     {\n117 |       label: \"Compliance Telemetry\",\n118 |       score: complianceTelemetry,\n119 |       description: complianceTelemetry >= 4 ? \"Continuous real-time SOC2 telemetry\" : \"Periodic audit checks only\",\n120 |       recommendation:\n121 |         complianceTelemetry >= 4\n122 |           ? \"Automate policy reporting outputs.\"\n123 |           : \"Deploy GFF Policy Watchdog nodes to catch configuration drift instantly.\"\n124 |     },\n125 |     {\n126 |       label: \"Multi-Agent Fleet Strategy\",\n127 |       score: fleetStrategy,\n128 |       description: fleetStrategy >= 4 ? \"Orchestrated DAG topology active\" : \"Ad-hoc task execution\",\n129 |       recommendation:\n130 |         fleetStrategy >= 4\n131 |           ? \"Scale to cross-department supervisor nodes.\"\n132 |           : \"Model multi-agent hierarchies using GFF Foundry Studio DAG designers.\"\n133 |     }\n134 |   ];\n135 | \n136 |   return {\n137 |     score,\n138 |     level,\n139 |     color,\n140 |     description,\n141 |     dimensionScores,\n142 |     strategicPriority:\n143 |       score >= 80\n144 |         ? \"Hardened production deployment & scale\"\n145 |         : score >= 55\n146 |         ? \"Isolation architecture validation\"\n147 |         : \"VPC topology design & basic sandboxing\",\n148 |     securityClearance: score >= 80 ? \"Sovereign Level 3\" : score >= 55 ? \"Strategic Level 2\" : \"Sandbox Level 1\"\n149 |   };\n150 | }\n151 | \n152 | export function calculateROIEstimate(inputs: ROIInputs): ROIResult {\n153 |   const { teamSize, avgHourlyRate, inefficientHoursPerWeek, initialInvestment, priority } = inputs;\n154 | \n155 |   const annualHoursSaved = Math.round(teamSize * inefficientHoursPerWeek * 52 * 0.85);\n156 |   const grossSavings = annualHoursSaved * avgHourlyRate;\n157 |   const netSavings = Math.max(0, grossSavings - initialInvestment);\n158 |   const roiPercentage = initialInvestment > 0 ? Math.round((netSavings / initialInvestment) * 100) : 