\n461 |                 ? \"bg-white/[0.03] border-white/10\"\n462 |                 : \"bg-white/[0.01] border-white/5 hover:border-white/10 hover:bg-white/[0.02]\"\n463 |             }`}\n464 |           >\n465 |             {/* Custom glowing accent border */}\n466 |             <div\n467 |               className={`absolute inset-x-0 top-0 h-[1.5px] transition-all duration-300 pointer-events-none ${\n468 |                 selected ? \"opacity-100\" : \"opacity-0 group-hover:opacity-35\"\n469 |               }`}\n470 |               style={{\n471 |                 background: `linear-gradient(90deg, transparent, ${accent}, transparent)`\n472 |               }}\n473 |             />\n474 | \n475 |             {opt.icon && (\n476 |               <div\n477 |                 className={`w-8 h-8 rounded-lg border flex items-center justify-center shrink-0 transition-all ${\n478 |                   selected\n479 |                     ? \"bg-white/5 border-white/10 text-white\"\n480 |                     : \"bg-white/[0.01] border-white/5 text-white/35 group-hover:text-white\"\n481 |                 }`}\n482 |                 style={selected ? { color: accent, borderColor: `${accent}25` } : {}}\n483 |               >\n484 |                 {opt.icon}\n485 |               </div>\n486 |             )}\n487 | \n488 |             <div className=\"space-y-1\">\n489 |               <span className={`text-xs font-bold transition-colors ${selected ? \"text-white\" : \"text-white/70 group-hover:text-white\"}`}>\n490 |                 {opt.title}\n491 |               </span>\n492 |               <p className=\"text-[11px] text-white/40 leading-relaxed font-light group-hover:text-white/50 transition\">\n493 |                 {opt.description}\n494 |               </p>\n495 |             </div>\n496 |           </button>\n497 |         );\n498 |       })}\n499 |     </div>\n500 |   );\n501 | }\n502 | \n503 | // ==========================================\n504 | // 11. ToolSummaryCard