 | }\n 64 | \n 65 | export function ToolHero({\n 66 |   category,\n 67 |   title,\n 68 |   highlightedWord,\n 69 |   description,\n 70 |   metricLabel,\n 71 |   metricValue\n 72 | }: ToolHeroProps) {\n 73 |   const parts = highlightedWord ? title.split(highlightedWord) : [title];\n 74 | \n 75 |   return (\n 76 |     <div className=\"border-b border-white/5 pb-8 mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 animate-fadeIn\">\n 77 |       <div className=\"space-y-3 max-w-4xl\">\n 78 |         <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">\n 79 |           {category}\n 80 |         </span>\n 81 |         <h1 className=\"text-3xl lg:text-5xl font-extrabold text-white tracking-tight leading-none\">\n 82 |           {highlightedWord && parts.length > 1 ? (\n 83 |             <>\n 84 |               {parts[0]}\n 85 |               <span className=\"bg-gradient-to-r from-white via-white to-[#009DFF] bg-clip-text text-transparent\">\n 86 |                 {highlightedWord}\n 87 |               </span>\n 88 |               {parts[1]}\n 89 |             </>\n 90 |           ) : (\n 91 |             title\n 92 |           )}\n 93 |         </h1>\n 94 |         <p className=\"text-white/60 text-xs lg:text-sm font-light max-w-2xl leading-relaxed\">\n 95 |           {description}\n 96 |         </p>\n 97 |       </div>\n 98 | \n 99 |       {metricLabel && metricValue && (\n100 |         <div className=\"p-4 px-6 rounded-xl bg-white/[0.01] border border-white/5 flex flex-col items-start min-w-[200px] shrink-0\">\n101 |           <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest\">{metricLabel}</span>\n102 |           <span className=\"text-xl font-bold text-[#00FF9D] mt-1 font-mono tracking-tight\">{metricValue}</span>\n103 |         </div>\n104 |       )}\n105 |     </div>\n106 |   );\n107 | }\n108 | \n109 | // ==========================================\n110 | // 3. ToolStepLayou