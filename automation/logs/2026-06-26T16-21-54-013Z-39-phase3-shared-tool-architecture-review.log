ease-out\"\n161 |           style={{ width: `${percentage}%` }}\n162 |         />\n163 |       </div>\n164 | \n165 |       {/* Steps List */}\n166 |       <div className=\"space-y-4 pt-2\">\n167 |         {steps.map((step, idx) => {\n168 |           const isActive = idx === currentStepIndex;\n169 |           const isCompleted = idx < currentStepIndex;\n170 | \n171 |           return (\n172 |             <button\n173 |               key={step.id}\n174 |               onClick={() => onStepClick && onStepClick(idx)}\n175 |               disabled={!onStepClick || (!isCompleted && !isActive)}\n176 |               className={`w-full text-left flex gap-4 p-3 rounded-xl transition border text-xs group ${\n177 |                 isActive\n178 |                   ? \"bg-white/[0.03] border-white/10 text-white\"\n179 |                   : isCompleted\n180 |                   ? \"bg-transparent border-transparent text-white/50 hover:text-white\"\n181 |                   : \"bg-transparent border-transparent text-white/20 cursor-not-allowed\"\n182 |               }`}\n183 |             >\n184 |               {/* Step Marker */}\n185 |               <div className=\"mt-0.5 shrink-0\">\n186 |                 <div\n187 |                   className={`w-5 h-5 rounded-full flex items-center justify-center font-mono text-[9px] border transition ${\n188 |                     isActive\n189 |                       ? \"border-[#009DFF] text-[#009DFF] bg-[#009DFF]/10\"\n190 |                       : isCompleted\n191 |                       ? \"border-[#00FF9D] text-[#00FF9D] bg-[#00FF9D]/5\"\n192 |                       : \"border-white/10 text-white/20\"\n193 |                   }`}\n194 |                 >\n195 |                   {isCompleted ? (\n196 |                     <svg className=\"w-2.5 h-2.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n197 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={3} d=\"M5 13l4 4L19 7\" />\n198 |                     </svg>\n199 |                   ) : (\n200 |                     idx + 1\n201 |                   )}\n202 |                 </div>\n203 |               </div>\n204 | \n205 |               {/* Step Info */}\n206 |               <div className=\"space-y-1\">\n207 |                 <div className=\"flex items-center gap-2\">\n208 |                   <span className={`font-semibold ${isActive ? \"text-[#009DFF]\" : \"\"}`}>{step.label}</span>\n209 |                   {step.duration && (\n210 |                     <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 border border-white/5 text-white/30 uppercase\">\n211 |                       {step.duration}\n212 |                     </span>\n213 |                   )}\n214 |                 </div>\n215 |                 {step.description && (\n216 |                   <p className=\"text-[11px] text-white/40 font-light leading-relaxed group-hover:text-white/60 transition\">\n217 |                     {step.description}\n218 |                   </p>\n219 |                 )}\n220 |               </div>\n221 |             </button>\n222 |           );\n223 |         })}\n224 |       </div>\n225 |     </div>\n226 |   );\n227 | }\n228 | \n229 | \n230 | \n231 | // ==========================================\n232 | // 5. ToolPreviewNotice\n233 | // ==========================================\n234 | export function ToolPreviewNotice() {\n235 |   return (\n236 |     <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex items-start gap-3.5 text-xs\">\n237 |       <div className=\"p-2 rounded bg-white/5 border border-white/10 shrink-0 mt-0.5 text-[#009DFF]\">\n238 |         <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n239 |           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.8} d=\"M12 15v2m0-6v2m0-6h.01M12 2a10 10 0 110 20 10 10 0 010-20z\" />\n240 |         </svg>\n241 |       </div>\n242 |     