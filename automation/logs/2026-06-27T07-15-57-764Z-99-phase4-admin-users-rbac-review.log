|       setAuditLogs((prev) => [\n248 |         `[${finishedTimestamp}] SUCCESS: Sealed backup coordinates with HSM signature.`,\n249 |         `[${finishedTimestamp}] CRYPTO: Bound public keys. Temp Recovery Code: ${generatedBackupCode}`,\n250 |         ...prev\n251 |       ]);\n252 |       alert(`Cryptographic FIDO2 access reset successful!\\n\\nTemporary Recovery Token (Local Simulation):\\n${generatedBackupCode}\\n\\nNote: The user key card has been re-bound in local memory.`);\n253 |     }, 1200);\n254 |   };\n255 | \n256 | \n257 |   // Handle Invite Form Submission\n258 |   const handleInviteSubmit = (e: React.FormEvent) => {\n259 |     e.preventDefault();\n260 |     if (!inviteName.trim() || !inviteEmail.trim()) return;\n261 | \n262 |     setInviteStep(\"generating\");\n263 |     \n264 |     setTimeout(() => {\n265 |       const token = `gff_envelope_0x${Math.random().toString(16).slice(2, 14).toUpperCase()}`;\n266 |       setGeneratedToken(token);\n267 | \n268 |       const newUser: LocalUser = {\n269 |         id: `usr-${Math.floor(100 + Math.random() * 900)}`,\n270 |         name: inviteName,\n271 |         email: inviteEmail,\n272 |         role: inviteRole,\n273 |         clientAssociation: inviteRole === \"gff_admin\" ? \"GFF AI Platform Core (Global Root)\" : inviteClient,\n274 |         status: \"inactive\", // inactive until accepted in simulation\n275 |         clearance: ROLE_CLEARANCES[inviteRole],\n276 |         lastActive: \"Never\",\n277 |         createdAt: new Date().toISOString().split(\"T\")[0],\n278 |         permissions: ROLE_PERMISSIONS[inviteRole]\n279 |       };\n280 | \n281 |       setUsers((prev) => [...prev, newUser]);\n282 |       setSelectedUser(newUser);\n283 |       \n284 |       const timestamp = new Date().toLocaleTimeString();\n285 |       setAuditLogs((prev) => [\n286 |         `[${timestamp}] PROVISION: Sealed dual-key cryptographic invitation envelope for ${inviteEmail}.`,\n287 |         `[${timestamp}] ENVELOPE: Token ${token} queued. Access bounds mapped to ${inviteRole.toUpperCase()}.`,\n288 |         ...prev\n289 |       ]);\n290 | \n291 |       setInviteStep(\"success\");\n292 |     }, 1000);\n293 |   };\n294 | \n295 |   // Emulate Accepting the Invite (instantly makes the newly added user active)\n296 |   const handleAcceptInviteSimulated = () => {\n297 |     const lastUser = users[users.length - 1];\n298 |     if (lastUser) {\n299 |       const updatedUsers = users.map((u) => \n300 |         u.id === lastUser.id ? { ...u, status: \"active\" as const, lastActive: \"Just now\" } : u\n301 |       );\n302 |       setUsers(updatedUsers);\n303 |       setSelectedUser({ ...lastUser, status: \"active\" as const, lastActive: \"Just now\" });\n304 | \n305 |       const timestamp = new Date().toLocaleTimeString();\n306 |       setAuditLogs((prev) => [\n307 |         `[${timestamp}] ACCEPTANCE: Operator ${lastUser.name} accepted invite token.`,\n308 |         `[${timestamp}] ACCESS: Cryptographic session established. FIDO2 security token bound.`,\n309 |         ...prev\n310 |       ]);\n311 |     }\n312 |     setIsInviteOpen(false);\n313 |     setInviteStep(\"form\");\n314 |     setInviteName(\"\");\n315 |     setInviteEmail(\"\");\n316 |   };\n317 | \n318 |   // Copy simulated invite link/token\n319 |   const copyTokenToClipboard = () => {\n320 |     navigator.clipboard.writeText(generatedToken);\n321 |     setCopiedToken(true);\n322 |     setTimeout(() => setCopiedToken(false), 2000);\n323 |   };\n324 | \n325 |   // Derive unique clients list for filtering\n326 |   const uniqueClients = Array.from(\n327 |     new Set(users.map((u) => u.clientAssociation).filter((c) => c !== \"GFF AI Platform Core (Global Root)\"))\n328 |   );\n329 | \n330 |   // Filter Users\n331 |   const filteredUsers = users.filter((user) => {\n332 |     // Search filter\n333 |     if (\n334 |       searchQuery.trim() !== \"\" &&\n335 |       !user.name.toLowerCase().includes(searchQuery.toLowerCase()) &&\n336 |     