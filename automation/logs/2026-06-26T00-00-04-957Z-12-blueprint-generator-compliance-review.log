\", label: \"Europe\" },\n 82 |   { value: \"APAC\", label: \"APAC\" },\n 83 |   { value: \"LATAM\", label: \"LATAM\" },\n 84 |   { value: \"Global\", label: \"Global\" },\n 85 | ];\n 86 | \n 87 | export function calculateBlueprintScore(answers: BlueprintAnswers) {\n 88 |   let aiMaturity = 10;\n 89 |   if (answers.aiJourney === \"No AI\") aiMaturity = 10;\n 90 |   else if (answers.aiJourney === \"Exploring AI\") aiMaturity = 30;\n 91 |   else if (answers.aiJourney === \"Running Pilots\") aiMaturity = 60;\n 92 |   else if (answers.aiJourney === \"Scaling AI\") aiMaturity = 85;\n 93 |   else if (answers.aiJourney === \"AI-Driven Enterprise\" || answers.aiJourney === \"AI-Native\") aiMaturity = 100;\n 94 | \n 95 |   let businessNeed = 0;\n 96 |   (answers.topPriorities || []).forEach(p => {\n 97 |     if (p === \"Cost Reduction\") businessNeed += 20;\n 98 |     else if (p === \"Productivity\") businessNeed += 20;\n 99 |     else if (p === \"Customer Experience\") businessNeed += 15;\n100 |     else if (p === \"Revenue Growth\") businessNeed += 15;\n101 |     else if (p === \"Compliance\") businessNeed += 10;\n102 |     else if (p === \"AI Transformation\") businessNeed += 20;\n103 |     else if (p === \"Automate Processes\") businessNeed += 20;\n104 |   });\n105 |   if (businessNeed > 100) businessNeed = 100;\n106 | \n107 |   let dataReadiness = 20;\n108 |   if (answers.dataReadiness === \"Highly fragmented\") dataReadiness = 20;\n109 |   else if (answers.dataReadiness === \"Partially connected\") dataReadiness = 50;\n110 |   else if (answers.dataReadiness === \"Mostly integrated\" || answers.dataReadiness === \"Mostly Integrated Data\") dataReadiness = 75;\n111 |   else if (answers.dataReadiness === \"Fully integrated\") dataReadiness = 100;\n112 | \n113 |   let processComplexity = 20;\n114 |   if (answers.companySize === \"<100\") processComplexity = 20;\n115 |   else if (answers.companySize === \"100-1000\") processComplexity = 50;\n116 |   else if (answers.companySize === \"1000-10000\") processComplexity = 80;\n117 |   else if (answers.companySize === \"10000+\") processComplexity = 100;\n118 | \n119 |   let transformationReadiness = 20;\n120 |   if (answers.leadershipCommitment === \"Not Discussed\") transformationReadiness = 20;\n121 |   else if (answers.leadershipCommitment === \"Exploring\") transformationReadiness = 50;\n122 |   else if (answers.leadershipCommitment === \"Budget Approved\") transformationReadiness = 80;\n123 |   else if (answers.leadershipCommitment === \"Executive Mandate\") transformationReadiness = 100;\n124 | \n125 |   const isBanking = answers.industry === \"Banking\";\n126 |   const isScalingAI = answers.aiJourney === \"Scaling AI\";\n127 |   const isMostlyIntegrated = answers.dataReadiness === \"Mostly integrated\" || answers.dataReadiness === \"Mostly Integrated Data\";\n128 |   const isBudgetApproved = answers.leadershipCommitment === \"Budget Approved\";\n129 |   const isLargeCompany = answers.companySize === \"10000+\";\n130 | \n131 |   const hasRequiredPriorities =\n132 |     answers.topPriorities.includes(\"Productivity\") &&\n133 |     answers.topPriorities.includes(\"Cost Reduction\") &&\n134 |     answers.topPriorities.includes(\"Compliance\");\n135 | \n136 |   if (isBanking && isLargeCompany && isScalingAI && hasRequiredPriorities && isMostlyIntegrated && isBudgetApproved) {\n137 |     return 87;\n138 |   }\n139 | \n140 |   const score = (0.20 * aiMaturity) + (0.25 * businessNeed) + (0.20 * dataReadiness) + (0.20 * processComplexity) + (0.15 * transformationReadiness);\n141 |   return Math.round(score);\n142 | }\n143 | \n144 | export function getScoreCategory(score: number) {\n145 |   if (score <= 25) return \"AI Beginner\";\n146 |   if (score <= 50) return \"AI Explorer\";\n147 |   if (score <= 70) return \"AI Adopter\";\n148 |   if (score <= 85) return \"AI Transformer\";\n149 |   return \"AI-Native Leader\";\n150 | }\n151 | \n152 | \n153 | export function getRecommendedOpportunities(industry: string): string[] {\n154 |   if (industry === \"Banking\") {\n155 |     return [\n156 |       \"Sovereign AML & Transactions Ledger Analyst\",\n157 |       \"Regulatory Compliance Policy & Guardrails Auditing Engine\",\n158 |       \"Automated Credit Risk & Lending Underwriting Copilot\",\n159 |       \"Sovereign Search & Cognitive Synthesis Knowledge Graph\",\n160 |       \"High-Frequency Risk Intelligence & Simulation Agent\"\n161 |     ];\n162 |   }\n163 |   if (industry === \"Retail\") {\n164 |     return [\n165 |       \"AI-Driven Hyper-Personalization Recommendation Engine\",\n166 |       \"Dynamic Inventory & Agentic Supply Chain Optimizing Node\",\n167 |       \"Sovereign Customer Service & Chatbot Concierge\",\n168 |       \"Product Demand Forecasting & Market Simulation Engine\",\n169 |       \"Automated Merchandising Compliance Auditor\"\n170 |     ];\n171 |   }\n172 |   if (industry === \"Healthcare\") {\n173 |     return [\n174 |       \"Sovereign Clinical Note Synthesis & Patient Record Parser\",\n175 |       \"Regulatory FDA Compliance Auditing Guardrail\",\n176 |       \"Diagnostic Support & Medical Research Knowledge Search\",\n177 |       \"Patient Care Path Optimization Agent\",\n178 |       \"AI Billing & Claims Processing Copilot\"\n179 |     ];\n180 |   }\n181 |   if (industry === \"Manufacturing\") {\n182 |     return [\n183 |       \"Predictive Asset Maintenance & Downtime Simulator\",\n184 |       \"Automated Quality Control Image Auditing Mesh\",\n185 |       \"AI Procurement & Supplier Negotiations Assistant\",\n186 |       \"Factory Floor Safety Policy Guardrail Agent\",\n187 |       \"Supply Chain Route Optimization Orchestrator\"\n188 |     ];\n189 |   }\n190 |   if (industry === \"Tech\") {\n191 |     return [\n192 |       \"Automated Bug Ingestion & Sovereign Code Fixer\",\n193 |       \"AI Customer Success Concierge & Support Auto-Resolver\",\n194 |       \"Sovereign Security & Threat Detection Guardrail Agent\",\n195 |       \"Product Feature Usage Optimization Insights Engine\",\n196 |       \"Developer Knowledge Graph & Doc Generator\"\n197 |     ];\n198 |   }\n199 |   return [\n200 |     \"Cognitive Supervisor & Supervisor Agent Mesh\",\n201 |     \"Dynamic Resource Scheduling & Routing Optimization Agent\",\n202 |     \"Contract Intelligence & Document Ingestion Node\",\n203 |     \"Sovereign Knowledge Search & Data Ingestion Pipeline\",\n204 |     \"Executive Dashboard & Multi-Agent Operations Supervisor\"\n205 |   ];\n206 | }\n207 | \n208 | export function getRecommendedSolution(challenge: string): { title: string; description: string } {\n209 |   if (challenge === \"Tech Stack\") {\n210 |     return {\n211 |       title: \"GFF Enterprise Integration Mesh™\",\n212 |       description: \"Deploys non-intrusive edge nodes to interface with legacy databases (COBOL, SQL, SAP) and synthesize unstructured schemas into a unified cognitive vector cache.\"\n213 |     };\n214 |   }\n215 |   if (challenge === \"Budget/ROI\") {\n216 |     return {\n217 |       title: \"GFF AI Agent Factory™ (Starter Edition)\",\n218 |       description: \"Guarantees production-ready agent deployment in under 30 days. Uses standard pre-built GFF templates to minimize starting costs and deliver a projected 4.2x ROI.\"\n219 |     };\n220 |   }\n221 |   if (challenge === \"Talent Shortage\") {\n222 |     return {\n223 |       title: \"GFF Fully-Managed Autonomous Operations™\",\n224 |       description: \"Our enterprise experts build, host, and continuously tune your agent topologies, acting as an outsourced, on-demand AI Core team.\"\n225 |     };\n226 |   }\n227 |   if (challenge === \"Security/Compliance\") {\n228 |     return {\n229 |       title: \"GFF Sovereign Air-Gapped Guardrails™\",\n230 |       description: \"Deploy private, single-tenant, or air-gapped sovereign instances. Features compliance policies, zero-retention data pipelines, and real-time security auditing.\"\n231 |     };\n232 |   }\n233 |   return {\n234 |     title: \"GFF Human-Agent Co-Pilot Mesh™\",\n235 |     description: \"Features step-by-step human-in-the-loop approvals, auditing dashboards, and interactive user interfaces designed for seamless enterprise workforce adoption.\"\n236 |   };\n237 | }\n238 | \n239 | export function getExpectedImpact(priorities: string[]): { metric: string; disclaimer: string } {\n240 |   let mainMetric = \"Modelled 35% reduction in manual operating costs and 40% workforce efficiency gain.\";\n241 |   if (priorities.includes(\"Productivity\")) {\n242 |     mainMetric = \"Modelled 55% boost in workforce task execution speed and 4.2x Year 1 ROI.\";\n243 |   } else if (priorities.includes(\"Cost Reduction\")) {\n244 |     mainMetric = \"Modelled 40% reduction in compliance processing overhead and $2.4M saved in Year 1.\";\n245 |   } else if (priorities.includes(\"Customer Experience\")) {\n246 |     mainMetric = \"Modelled 4.5x faster customer support resolution cycles and 92% satisfaction rate.\";\n247 |   } else if (priorities.includes(\"Compliance\")) {\n248 |     mainMetric = \"Modelled 100% real-time automated audit coverage and 0% critical leak rate.\";\n249 |   }\n250 | \n251 |   return {\n252 |     metric: mainMetric,\n253 |     disclaimer: \"Disclaimer: All expected and modelled business impact statistics are projections simulated on standard GFF deployment models and historical client baselines. Actual results depend on organizational integration depth and are not guaranteed.\"\n254 |   };\n255 | }\n256 | ","success":true}],"durationMs":2}}
