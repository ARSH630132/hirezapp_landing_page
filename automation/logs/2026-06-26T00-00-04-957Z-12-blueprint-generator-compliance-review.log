ompanySize: \"\",\n 35 |     topPriorities: [],\n 36 |     aiJourney: \"\",\n 37 |     dataReadiness: \"\",\n 38 |     leadershipCommitment: \"\",\n 39 |     biggestChallenge: \"\",\n 40 |     email: \"\",\n 41 |     otp: \"\",\n 42 |     budget: \"\",\n 43 |     geography: \"\",\n 44 |   });\n 45 | \n 46 |   // Verification states\n 47 |   const [otpSent, setOtpSent] = useState(false);\n 48 |   const [enteredOtp, setEnteredOtp] = useState(\"\");\n 49 |   const [otpError, setOtpError] = useState(\"\");\n 50 |   const [isCompiling, setIsCompiling] = useState(false);\n 51 |   const [compilingStep, setCompilingStep] = useState(0);\n 52 |   const [reportGenerated, setReportGenerated] = useState(false);\n 53 |   \n 54 |   // Validation errors\n 55 |   const [error, setError] = useState(\"\");\n 56 | \n 57 | \n 58 |   useEffect(() => {\n 59 |     if (!isCompiling) return;\n 60 |     const interval = setInterval(() => {\n 61 |       setCompilingStep((prev) => {\n 62 |         if (prev < compilingMessages.length - 1) {\n 63 |           return prev + 1;\n 64 |         } else {\n 65 |           clearInterval(interval);\n 66 |           setIsCompiling(false);\n 67 |           setReportGenerated(true);\n 68 |           setStep(5);\n 69 |           return prev;\n 70 |         }\n 71 |       });\n 72 |     }, 500);\n 73 |     return () => clearInterval(interval);\n 74 |   }, [isCompiling]);\n 75 | \n 76 |   // Handle priority multi-selection (max 3)\n 77 |   const handlePriorityToggle = (val: string) => {\n 78 |     setError(\"\");\n 79 |     const current = [...answers.topPriorities];\n 80 |     if (current.includes(val)) {\n 81 |       setAnswers({\n 82 |         ...answers,\n 83 |         topPriorities: current.filter((x) => x !== val),\n 84 |       });\n 85 |     } else {\n 86 |       if (current.length >= 3) {\n 87 |         setError(\"You can select a maximum of 3 top priorities.\");\n 88 |         return;\n 89 |       }\n 90 |       setAnswers({\n 91 |         ...answers,\n 92 |         topPriorities: [...current, val],\n 93 |       });\n 94 |     }\n 95 |   };\n 96 | \n 97 |   // Next Step validation\n 98 |   const validateAndNext = () => {\n 99 |     setError(\"\");\n100 |     if (step === 1) {\n101 |       if (!answers.industry || !answers.companySize) {\n102 |         setError(\"Industry and Company Size are required fields.\");\n103 |         return;\n104 |       }\n105 |       setStep(2);\n106 |     } else if (step === 2) {\n107 |       if (!answers.aiJourney || !answers.dataReadiness || !answers.leadershipCommitment || !answers.biggestChallenge) {\n108 |         setError(\"Please complete all strategy and maturity fields.\");\n109 |         return;\n110 |       }\n111 |       setStep(3);\n112 |     } else if (step === 3) {\n113 |       if (answers.topPriorities.length === 0) {\n114 |         setError(\"Please select at least 1 priority (max 3).\");\n115 |         return;\n116 |       }\n117 |       setStep(4);\n118 |     }\n119 |   };\n120 | \n121 |   const requestOtp = () => {\n122 |     setError(\"\");\n123 |     if (!answers.email || !answers.email.includes(\"@\")) {\n124 |       setError(\"Please enter a valid email address.\");\n125 |       return;\n126 |     }\n127 |     setOtpSent(true);\n128 |   };\n129 | \n130 |   const verifyOtpAndGenerate = () => {\n131 |     setOtpError(\"\");\n132 |     if (!enteredOtp) {\n133 |       setOtpError(\"Please enter the verification code.\");\n134 |       return;\n135 |     }\n136 |     // Frontend mock validation: allow any 4+ digit OTP\n137 |     if (enteredOtp.length < 4) {\n138 |       setOtpError(\"Verification code must be at least 4 digits.\");\n139 |       return;\n140 |     }\n141 |     setIsCompiling(true);\n142 |   };\n143 | \n144 |   // Calculate scores and output elements\n145 |   const score = calculateBlueprintScore(answers);\n146 |   const category = getScoreCategory(score);\n147 |   const opportunities = getRecommendedOpportunities(answers.industry);\n148 |   const solution = getRecommendedSolution(answers.biggestChallenge);\n149 |   const impact = getExpectedImpact(answers.topPriorities);\n150 | \n151 |   return (\n152 |     <div className=\"w-full max-w-[1200px] mx-auto bg-[#040815]/90 border border-white/10 rounded-2xl overflow-hidden shadow-[0_0_50px_rgba(8,125,243,0.15)] backdrop-blur-xl\">\n153 |       {/* Top Header & Title */}\n154 |       <div className=\"p-6 md:p-8 border-b border-white/5 bg-gradient-to-r from-blue-950/20 via-black/40 to-purple-950/20\">\n155 |         <h2 className=\"text-2xl md:text-3xl lg:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-200 to-slate-400\">\n156 |           Get Your Enterprise AI Blueprint in 60 Seconds\n157 |         </h2>\n158 |         <p className=\"mt-2 text-xs md:text-sm text-white/60\">\n159 |           Tailored Operating Model, Topology Nodes, Recommended Solutions, and a 90-Day Roadmap.\n160 |         </p>\n161 |       </div>\n162 | \n163 |       {/* Step Indicators */}\n164 |       {step < 5 && (\n165 |         <div className=\"px-6 md:px-8 py-4 bg-black/40 border-b border-white/5 flex gap-2 items-center justify-between text-xs font-semibold text-white/40\">\n166 |           <div className=\"flex gap-4\">\n167 |             <span className={step === 1 ? \"text-[#087DF3]\" : step > 1 ? \"text-white/80\" : \"\"}>1. Profile</span>\n168 |             <span className={step === 2 ? \"text-[#087DF3]\" : step > 2 ? \"text-white/80\" : \"\"}>2. Strategy</span>\n169 |             <span className={step === 3 ? \"text-[#087DF3]\" : step > 3 ? \"text-white/80\" : \"\"}>3. Priorities</span>\n170 |             <span className={step === 4 ? \"text-[#087DF3]\" : step > 4 ? \"text-white/80\" : \"\"}>4. Verify</span>\n171 |           </div>\n172 |           <span className=\"text-white/60\">Step {step} of 4</span>\n173 |         </div>\n174 |       )}\n175 | \n176 |       {/* Main Wizard Area */}\n177 |       <div className=\"p-6 md:p-8 min-h-[380px] flex flex-col justify-between\">\n178 |         {/* Step 1: Enterprise Profile */}\n179 |         {step === 1 && (\n180 |           <div className=\"space-y-6 animate-fadeIn\">\n181 |             <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n182 |               <div className=\"space-y-2\">\n183 |                 <label className=\"text-sm font-semibold text-white/80 block\">Industry <span className=\"text-red-500\">*</span></label>\n184 |                 <select\n185 |                   value={answers.industry}\n186 |                   onChange={(e) => setAnswers({ ...answers, industry: e.target.value })}\n187 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n188 |                 >\n189 |                   <option value=\"\">-- Select Industry --</option>\n190 |                   {industryOptions.map((o) => (\n191 |                     <option key={o.value} value={o.value}>{o.label}</option>\n192 |                   ))}\n193 |                 </select>\n194 |               </div>\n195 | \n196 |               <div className=\"space-y-2\">\n197 |                 <label className=\"text-sm font-semibold text-white/80 block\">Company Size <span className=\"text-red-500\">*</span></label>\n198 |                 <select\n199 |                   value={answers.companySize}\n200 |                   onChange={(e) => setAnswers({ ...answers, companySize: e.target.value })}\n201 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n202 |                 >\n203 |                   <option value=\"\">-- Select Size --</option>\n204 |                   {companySizeOptions.map((o) => (\n205 |                     <option key={o.value} value={o.value}>{o.label}</option>\n206 |                   ))}\n207 |                 </select>\n208 |               </div>\n209 | \n210 |               <div className=\"space-y-2\">\n211 |                 <label className=\"text-sm font-semibold text-white/40 block\">Budget (Optional)</label>\n212 |                 <select\n213 |                   value={answers.budget}\n214 |                   onChange={(e) => setAnswers({ ...answers, budget: e.target.value })}\n215 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white/60 focus:border-[#087DF3] outline-none transition\"\n216 |                 >\n217 |                   <option value=\"\">-- Select Budget --</option>\n218 |                   {budgetOptions.map((o) => (\n219 |                     <option key={o.value} value={o.value}>{o.label}</option>\n220 |                   ))}\n221 |                 </select>\n222 |               </div>\n223 | \n224 |               <div className=\"space-y-2\">\n225 |                 <label className=\"text-sm font-semibold text-white/40 block\">Geography (Optional)</label>\n226 |                 <select\n227 |                   value={answers.geography}\n228 |                   onChange={(e) => setAnswers({ ...answers, geography: e.target.value })}\n229 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white/60 focus:border-[#087DF3] outline-none transition\"\n230 |                 >\n231 |                   <option value=\"\">-- Select Region --</option>\n232 |                   {geographyOptions.map((o) => (\n233 |                     <option key={o.value} value={o.value}>{o.label}</option>\n234 |                   ))}\n235 |                 </select>\n236 |               </div>\n237 |             </div>\n238 |           </div>\n239 |         )}\n240 | \n241 | \n242 |         {/* Step 2: Strategy & Maturity */}\n243 |         {step === 2 && (\n244 |           <div className=\"space-y-6 animate-fadeIn\">\n245 |             <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n246 |               <div className=\"space-y-2\">\n247 |                 <label className=\"text-sm font-semibold text-white/80 block\">AI Journey <span className=\"text-red-500\">*</span></label>\n248 |                 <select\n249 |                   value={answers.aiJourney}\n250 |                   onChange={(e) => setAnswers({ ...answers, aiJourney: e.target.value })}\n251 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n252 |                 >\n253 |                   <option value=\"\">-- Select AI Journey Stage --</option>\n254 |                   {aiJourneyOptions.map((o) => (\n255 |                     <option key={o.value} value={o.value}>{o.label}</option>\n256 |                   ))}\n257 |                 </select>\n258 |               </div>\n259 | \n260 |               <div className=\"space-y-2\">\n261 |                 <label className=\"text-sm font-semibold text-white/80 block\">Data Readiness <span className=\"text-red-500\">*</span></label>\n262 |                 <select\n263 |                   value={answers.dataReadiness}\n264 |                   onChange={(e) => setAnswers({ ...answers, dataReadiness: e.target.value })}\n265 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n266 |                 >\n267 |                   <option value=\"\">-- Select Data Readiness --</option>\n268 |                   {dataReadinessOptions.map((o) => (\n269 |                     <option key={o.value} value={o.value}>{o.label}</option>\n270 |                   ))}\n271 |                 </select>\n272 |               </div>\n273 | \n274 |               <div className=\"space-y-2\">\n275 |                 <label className=\"text-sm font-semibold text-white/80 block\">Leadership Commitment <span className=\"text-red-500\">*</span></label>\n276 |                 <select\n277 |                   value={answers.leadershipCommitment}\n278 |                   onChange={(e) => setAnswers({ ...answers, leadershipCommitment: e.target.value })}\n279 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n280 |                 >\n281 |                   <option value=\"\">-- Select Commitment --</option>\n282 |                   {leadershipOptions.map((o) => (\n283 |                     <option key={o.value} value={o.value}>{o.label}</option>\n284 |                   ))}\n285 |                 </select>\n286 |               </div>\n287 | \n288 |               <div className=\"space-y-2\">\n289 |                 <label className=\"text-sm font-semibold text-white/80 block\">Biggest Challenge <span className=\"text-red-500\">*</span></label>\n290 |                 <select\n291 |                   value={answers.biggestChallenge}\n292 |                   onChange={(e) => setAnswers({ ...answers, biggestChallenge: e.target.value })}\n293 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n294 |                 >\n295 |                   <option value=\"\">-- Select Challenge --</option>\n296 |                   {challengeOptions.map((o) => (\n297 |                     <option key={o.value} value={o.value}>{o.label}</option>\n298 |                   ))}\n299 |                 </select>\n300 |               </div>\n301 |             </div>\n302 |           </div>\n303 |         )}\n304 | \n305 | \n306 |         {/* Step 3: Top Priorities (Max 3) */}\n307 |         {step === 3 && (\n308 |           <div className=\"space-y-4 animate-fadeIn\">\n309 |             <p className=\"text-sm font-semibold text-white/80\">Select Top Priorities (Max 3) <span className=\"text-red-500\">*</span></p>\n310 |             <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3\">\n311 |               {priorityOptions.map((o) => {\n312 |                 const isSelected = answers.topPriorities.includes(o.value);\n313 |                 return (\n314 |                   <button\n315 |                     key={o.value}\n316 |                     type=\"button\"\n317 |                     onClick={() => handlePriorityToggle(o.value)}\n318 |                     className={`p-4 rounded-xl border text-left transition duration-200 group flex justify-between items-center ${\n319 |                       isSelected\n320 |                         ? \"border-[#087DF3] bg-[#087DF3]/15 text-white\"\n321 |                         : \"border-white/10 bg-black/40 text-white/70 hover:border-white/20 hover:bg-black/60\"\n322 |                     }`}\n323 |                   >\n324 |                     <span className=\"text-xs md:text-sm font-medium\">{o.label}</span>\n325 |                     <span className={`w-4 h-4 rounded-full border flex items-center justify-center shrink-0 ml-2 ${\n326 |                       isSelected ? \"border-[#087DF3] bg-[#087DF3]\" : \"border-white/30\"\n327 |                     }`}>\n328 |                       {isSelected && <span className=\"text-[10px] text-white\">✓</span>}\n329 |                     </span>\n330 |                   </button>\n331 |                 );\n332 |               })}\n333 |             </div>\n334 |           </div>\n335 |         )}\n336 | \n337 |         {/* Step 4: Verification Flow */}\n338 |         {step === 4 && (\n339 |           <div className=\"space-y-6 max-w-[500px] mx-auto w-full animate-fadeIn py-4\">\n340 |             <h3 className=\"text-lg font-bold text-white text-center\">Secure Verification Check</h3>\n341 |             <p className=\"text-xs text-white/50 text-center\">\n342 |               Enter your enterprise email to verify instant delivery and view your interactive roadmap.\n343 |             </p>\n344 | \n345 |             <div className=\"space-y-4\">\n346 |               <div className=\"space-y-2\">\n347 |                 <label className=\"text-xs font-semibold text-white/70 block\">Enterprise Email</label>\n348 |                 <input\n349 |                   type=\"email\"\n350 |                   disabled={otpSent}\n351 |                   value={answers.email}\n352 |                   onChange={(e) => setAnswers({ ...answers, email: e.target.value })}\n353 |                   placeholder=\"name@company.com\"\n354 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition disabled:opacity-50\"\n355 |                 />\n356 |               </div>\n357 | \n358 |               {!otpSent ? (\n359 |                 <button\n360 |                   type=\"button\"\n361 |                   onClick={requestOtp}\n362 |                   className=\"w-full h-[46px] rounded-lg bg-[#087DF3] text-sm font-bold text-white hover:bg-[#087DF3]/80 transition mt-4\"\n363 |                 >\n364 |                   Generate Free Blueprint\n365 |                 </button>\n366 |               ) : (\n367 |                 <div className=\"space-y-4 animate-fadeIn\">\n368 |                   <div className=\"space-y-2\">\n369 |                     <div className=\"flex justify-between items-center\">\n370 |                       <label className=\"text-xs font-semibold text-white/70 block\">Enter One-Time PIN (OTP)</label>\n371 |                       <span className=\"text-[10px] text-[#087DF3] font-mono font-bold\">Suggested Code: 123456</span>\n372 |                     </div>\n373 |                     <input\n374 |                       type=\"text\"\n375 |                       maxLength={6}\n376 |                       value={enteredOtp}\n377 |                       onChange={(e) => setEnteredOtp(e.target.value.replace(/\\D/g, \"\"))}\n378 |                       placeholder=\"Enter 6-digit code\"\n379 |                       className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-center tracking-[0.5em] text-white focus:border-[#087DF3] outline-none transition\"\n380 |                     />\n381 |                     {otpError && <p className=\"text-xs text-red-400 font-semibold\">{otpError}</p>}\n382 |                   </div>\n383 | \n384 |                   <button\n385 |                     type=\"button\"\n386 |                     onClick={verifyOtpAndGenerate}\n387 |                     className=\"w-full h-[46px] rounded-lg bg-[#E98828] text-sm font-bold text-white hover:bg-[#E98828]/80 transition\"\n388 |                   >\n389 |                     Verify & Build Blueprint\n390 |                   </button>\n391 |                 </div>\n392 |               )}\n393 |             </div>\n394 |           </div>\n395 |         )}\n396 | \n397 | \n398 |         {/* Compile Loading Screen */}\n399 |         {isCompiling && (\n400 |           <div className=\"fixed inset-0 z-[10000] bg-black/95 backdrop-blur-md flex flex-col justify-center items-center text-center p-4 animate-fadeIn\">\n401 |             <div className=\"relative w-20 h-20 mb-6\">\n402 |               <div className=\"absolute inset-0 rounded-full border-4 border-white/10\"></div>\n403 |               <div className=\"absolute inset-0 rounded-full border-4 border-t-[#087DF3] animate-spin\"></div>\n404 |             </div>\n405 |             <h4 className=\"text-lg font-bold text-white mb-2\">Compiling Custom AI Blueprint</h4>\n406 |             <p className=\"text-sm font-semibold text-[#087DF3] h-6 transition-all animate-pulse\">\n407 |               {compilingMessages[compilingStep]}\n408 |             </p>\n409 |           </div>\n410 |         )}\n411 | \n412 |         {/* Bottom Wizard Controls */}\n413 |         {step < 4 && (\n414 |           <div className=\"mt-8 pt-4 border-t border-white/5 flex justify-between items-center\">\n415 |             {error && <p className=\"text-xs md:text-sm text-red-400 font-semibold max-w-[70%]\">{error}</p>}\n416 |             <div className=\"flex gap-4 ml-auto\">\n417 |               {step > 1 && (\n418 |                 <button\n419 |                   type=\"button\"\n420 |                   onClick={() => setStep(step - 1)}\n421 |                   className=\"px-5 h-[42px] rounded-lg border border-white/15 text-xs font-semibold text-white hover:bg-white/5 transition\"\n422 |                 >\n423 |                   Back\n424 |                 </button>\n425 |               )}\n426 |               <button\n427 |                 type=\"button\"\n428 |                 onClick={validateAndNext}\n429 |                 className=\"px-6 h-[42px] rounded-lg bg-[#087DF3] text-xs font-semibold text-white hover:bg-[#087DF3]/80 transition\"\n430 |               >\n431 |                 Continue\n432 |               </button>\n433 |             </div>\n434 |           </div>\n435 |         )}\n436 | \n437 | \n438 |         {/* Step 5: High-Fidelity Enterprise Blueprint Report */}\n439 |         {step === 5 && reportGenerated && (\n440 |           <div className=\"space-y-8 animate-fadeIn text-white\">\n441 |             <div className=\"flex flex-col lg:flex-row gap-8 items-stretch\">\n442 |               \n443 |               {/* Score Circular Dial & Category Badge */}\n444 |               <div className=\"lg:w-1/3 rounded-xl border border-white/10 bg-black/40 p-6 flex flex-col justify-center items-center text-center relative overflow-hidden group\">\n445 |                 <div className=\"absolute inset-0 bg-gradient-to-b from-[#087DF3]/5 via-transparent to-[#E98828]/5 pointer-events-none\" />\n446 |                 <h3 className=\"text-xs uppercase tracking-wider font-semibold text-white/40 mb-4\">Enterprise AI Readiness Score</h3>\n447 |                 \n448 |                 {/* Circular Score Gauge */}\n449 |                 <div className=\"relative w-36 h-36 flex items-center justify-center mb-4\">\n450 |                   <svg className=\"w-full h-full transform -rotate-90\">\n451 |                     <circle cx=\"72\" cy=\"72\" r=\"64\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"8\" fill=\"transparent\" />\n452 |                     <circle\n453 |                       cx=\"72\"\n454 |                       cy=\"72\"\n455 |                       r=\"64\"\n456 |                       stroke=\"#087DF3\"\n457 |                       strokeWidth=\"8\"\n458 |                       fill=\"transparent\"\n459 |                       strokeDasharray=\"402\"\n460 |                       strokeDashoffset={402 - (402 * score) / 100}\n461 |                       className=\"transition-all duration-1000 ease-out\"\n462 |                     />\n463 |                   </svg>\n464 |                   <div className=\"absolute inset-0 flex flex-col items-center justify-center\">\n465 |                     <span className=\"text-4xl font-extrabold tracking-tight text-white\">{score}</span>\n466 |                     <span className=\"text-[10px] text-white/40\">/ 100</span>\n467 |                   </div>\n468 |                 </div>\n469 | \n470 |                 {/* Score Category Badge with Custom Glows */}\n471 |                 <div className=\"px-4 py-1.5 rounded-full border border-[#087DF3]/40 bg-[#087DF3]/10 shadow-[0_0_15px_rgba(8,125,243,0.2)] text-xs font-bold text-[#087DF3] uppercase tracking-wider\">\n472 |                   {category}\n473 |                 </div>\n474 |               </div>\n475 | \n476 |               {/* Recommended Solution & Business Impact */}\n477 |               <div className=\"lg:w-2/3 flex flex-col justify-between gap-6\">\n478 |                 {/* Recommended GFF Solution */}\n479 |                 <div className=\"rounded-xl border border-white/10 bg-black/40 p-6 space-y-3\">\n480 |                   <span className=\"text-[10px] uppercase tracking-widest font-semibold text-[#087DF3]\">RECOMMENDED GFF AI SOLUTION</span>\n481 |                   <h4 className=\"text-lg font-bold text-white flex items-center gap-2\">\n482 |                     {solution.title}\n483 |                   </h4>\n484 |                   <p className=\"text-xs text-white/70 leading-relaxed\">\n485 |                     {solution.description}\n486 |                   </p>\n487 |                 </div>\n488 | \n489 |                 {/* Expected Business Impact */}\n490 |                 <div className=\"rounded-xl border border-white/10 bg-black/40 p-6 space-y-3 relative overflow-hidden\">\n491 |                   <div className=\"absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-[#087DF3] to-[#E98828]\" />\n492 |                   <span className=\"text-[10px] uppercase tracking-widest font-semibold text-[#E98828]\">EXPECTED BUSINESS IMPACT (MODELLED)</span>\n493 |                   <p className=\"text-sm font-bold text-white/90\">\n494 |                     {impact.metric}\n495 |                   </p>\n496 |                   <p className=\"text-[11px] text-white/50 leading-relaxed font-mono italic\">\n497 |                     {impact.disclaimer}\n498 |                   </p>\n499 |                 </div>\n500 |               </div>\n501 |             </div>\n502 | \n503 | \n504 |             {/* Top 5 Recommended AI Opportunities */}\n505 |             <div className=\"rounded-xl border border-white/10 bg-black/40 p-6 space-y-4\">\n506 |               <span className=\"text-[10px] uppercase tracking-widest font-semibold text-white/40 block\">Top 5 Recommended AI Opportunities</span>\n507 |               <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n508 |                 {opportunities.map((opp, idx) => (\n509 |                   <div key={idx} className=\"p-4 rounded-lg border border-white/5 bg-white/[0.02] hover:border-white/10 hover:bg-white/[0.04] transition duration-200 flex flex-col justify-between min-h-[140px]\">\n510 |                     <div>\n511 |                       <span className=\"text-xs font-bold text-[#087DF3] font-mono block mb-2\">0{idx + 1}</span>\n512 |                       <h5 className=\"text-xs font-bold text-white/90 leading-snug\">{opp}</h5>\n513 |                     </div>\n514 |                     <span className=\"text-[9px] text-white/40 uppercase tracking-widest font-semibold mt-4\">Node Active</span>\n515 |                   </div>\n516 |                 ))}\n517 |               </div>\n518 |             </div>\n519 | \n520 |             {/* 90-Day Implementation Roadmap */}\n521 |             <div className=\"rounded-xl border border-white/10 bg-black/40 p-6 space-y-4\">\n522 |               <span className=\"text-[10px] uppercase tracking-widest font-semibold text-white/40 block\">90-Day Sovereign Implementation Roadmap</span>\n523 |               <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 relative\">\n524 |                 \n525 |                 {/* Roadmap Step 1 */}\n526 |                 <div className=\"space-y-2 relative pl-6 border-l border-[#087DF3]/30\">\n527 |                   <div className=\"absolute -left-[6px] top-1.5 w-3 h-3 rounded-full bg-[#087DF3] shadow-[0_0_10px_rgba(8,125,243,0.8)]\" />\n528 |                   <span className=\"text-[10px] font-bold text-[#087DF3] font-mono\">PHASE 1: DAYS 1 - 30</span>\n529 |                   <h4 className=\"text-sm font-bold text-white\">Ingestion & Security Baseline</h4>\n530 |                   <p className=\"text-xs text-white/60 leading-relaxed\">\n531 |                     Deploy GFF secure edge nodes. Map standard data schemas and establish compliance firewalls tailored to {answers.industry} parameters.\n532 |                   </p>\n533 |                 </div>\n534 | \n535 |                 {/* Roadmap Step 2 */}\n536 |                 <div className=\"space-y-2 relative pl-6 border-l border