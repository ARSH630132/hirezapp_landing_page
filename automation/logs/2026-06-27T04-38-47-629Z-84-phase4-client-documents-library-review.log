eEffect(() => {\n239 |     if (toastMessage) {\n240 |       const timer = setTimeout(() => {\n241 |         setToastMessage(null);\n242 |         setToastType(null);\n243 |       }, 3500);\n244 |       return () => clearTimeout(timer);\n245 |     }\n246 |   }, [toastMessage]);\n247 | \n248 |   // Terminal Handshake Log Simulator inside Drawer\n249 |   useEffect(() => {\n250 |     if (!selectedDoc) {\n251 |       setTerminalLogs([]);\n252 |       return;\n253 |     }\n254 | \n255 |     setIsLogsSyncing(true);\n256 |     setTerminalLogs([\n257 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n258 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n259 |     ]);\n260 | \n261 |     const logsArray = [\n262 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n263 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n264 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n265 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n266 |     ];\n267 | \n268 |     let timerIndex = 0;\n269 |     const interval = setInterval(() => {\n270 |       if (timerIndex < logsArray.length) {\n271 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n272 |         timerIndex++;\n273 |       } else {\n274 |         setIsLogsSyncing(false);\n275 |         clearInterval(interval);\n276 |       }\n277 |     }, 450);\n278 | \n279 |     return () => clearInterval(interval);\n280 |   }, [selectedDoc]);\n281 | \n282 |   // Copy Clipboard Helper\n283 |   const handleCopyHash = (text: string) => {\n284 |     navigator.clipboard.writeText(text);\n285 |     setCopiedHash(true);\n286 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n287 |     setTimeout(() => setCopiedHash(false), 1500);\n288 |   };\n289 | \n290 |   // Reset Filters Helper\n291 |   const handleResetFilters = () => {\n292 |     setSearchQuery(\"\");\n293 |     setSelectedCategory(\"\");\n294 |     setSelectedProject(\"\");\n295 |     setSelectedFormat(\"\");\n296 |     setSelectedStatus(\"\");\n297 |     showToast(\"All filters reset successfully.\", \"info\");\n298 |   };\n299 | \n300 |   // Simulated Actions\n301 |   const handleSimulatedDownload = (doc: PortalDocument) => {\n302 |     showToast(`DEMO SHIELD: File transfer blocked. '${doc.name}' cannot be downloaded in telemetry preview.`, \"warning\");\n303 |   };\n304 | \n305 |   const handleSimulatedUploadClick = () => {\n306 |     showToast(\"SECURE GATEWAY: Upload restricted. Local sandbox is currently in read-only audit mode.\", \"warning\");\n307 |   };\n308 | \n309 |   // Filtering Logic\n310 |   const filteredDocuments = PREVIEW_DOCUMENTS.filter((doc) => {\n311 |     // 1. Text Search query (checks title, hash, id, owner)\n312 |     if (searchQuery.trim() !== \"\") {\n313 |       const query = searchQuery.toLowerCase();\n314 |       const matchText = \n315 |         doc.name.toLowerCase().includes(query) ||\n316 |         doc.id.toLowerCase().includes(query) ||\n317 |         doc.hash.toLowerCase().includes(query) ||\n318 |         doc.owner.toLowerCase().includes(query) ||\n319 |         doc.desc.toLowerCase().includes(query);\n320 |       if (!matchText) return false;\n321 |     }\n322 |     // 2. Category\n323 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n324 |     // 3. Related Project\n325 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n326 |     // 4. File Format (Type)\n327 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) retur