======\n 96 |   // GROUP 1: VALIDATION HELPERS\n 97 |   // ==========================================\n 98 |   console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 1: Validation Helpers ---\");\n 99 | \n100 |   test(\"validateRequiredText - valid input\", () => {\n101 |     const res = sharedValidation.validateRequiredText(\"A valid string\");\n102 |     assertEquals(res.isValid, true);\n103 |     assertEquals(res.error, undefined);\n104 |   });\n105 | \n106 |   test(\"validateRequiredText - empty input\", () => {\n107 |     const res = sharedValidation.validateRequiredText(\"   \");\n108 |     assertEquals(res.isValid, false);\n109 |     assert(res.error.includes(\"required\"), \"Error message should mention required\");\n110 |   });\n111 | \n112 |   test(\"validateEmail - valid email\", () => {\n113 |     const res = sharedValidation.validateEmail(\"enterprise@gff.ai\");\n114 |     assertEquals(res.isValid, true);\n115 |   });\n116 | \n117 |   test(\"validateEmail - invalid email format\", () => {\n118 |     const res = sharedValidation.validateEmail(\"invalid-email\");\n119 |     assertEquals(res.isValid, false);\n120 |     assert(res.error.includes(\"valid corporate email\"), \"Error message should mention valid email\");\n121 |   });\n122 | \n123 |   test(\"validateMaxPriorities - valid counts\", () => {\n124 |     const res = sharedValidation.validateMaxPriorities([\"Productivity\", \"Compliance\"], 3);\n125 |     assertEquals(res.isValid, true);\n126 |   });\n127 | \n128 |   test(\"validateMaxPriorities - exceeds limit\", () => {\n129 |     const res = sharedValidation.validateMaxPriorities([\"P1\", \"P2\", \"P3\", \"P4\"], 3);\n130 |     assertEquals(res.isValid, false);\n131 |     assert(res.error.includes(\"maximum of 3\"), \"Error message should mention max limit\");\n132 |   });\n133 | \n134 |   test(\"validateMaxPriorities - empty selection\", () => {\n135 |     const res = sharedValidation.validateMaxPriorities([], 3);\n136 |     assertEquals(res.isValid, false);\n137 |     assert(res.error.includes(\"at least 1\"), \"Error message should mention selecting at least 1\");\n138 |   });\n139 | \n140 |   test(\"validateNumberRange - valid value\", () => {\n141 |     const res = sharedValidation.validateNumberRange(50, 0, 100);\n142 |     assertEquals(res.isValid, true);\n143 |   });\n144 | \n145 |   test(\"validateNumberRange - out of bounds\", () => {\n146 |     const res = sharedValidation.validateNumberRange(150, 0, 100);\n147 |     assertEquals(res.isValid, false);\n148 |   });\n149 | \n150 |   test(\"validateNonNegativeInput - valid non-negative\", () => {\n151 |     const res = sharedValidation.validateNonNegativeInput(0);\n152 |     assertEquals(res.isValid, true);\n153 |   });\n154 | \n155 |   test(\"validateNonNegativeInput - negative input\", () => {\n156 |     const res = sharedValidation.validateNonNegativeInput(-10);\n157 |     assertEquals(res.isValid, false);\n158 |   });\n159 | \n160 |   test(\"getSafeEmptyState - returns actual when present\", () => {\n161 |     const res = sharedValidation.getSafeEmptyState(\"fallback\", \"actual\");\n162 |     assertEquals(res, \"actual\");\n163 |   });\n164 | \n165 |   test(\"getSafeEmptyState - returns fallback when empty\", () => {\n166 |     const res = sharedValidation.getSafeEmptyState(\"fallback\", \"  \");\n167 |     assertEquals(res, \"fallback\");\n168 |   });\n169 | \n170 |   // ==========================================\n171 |   // GROUP 2: BLUEPRINT SCORING (WITH BANKING 87/100 CASE)\n172 |   // ==========================================\n173 |   console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 2: Blueprint Scoring & Test Cases ---\");\n174 | \n175 |   test(\"Blueprint scoring (lib/blueprint-data) - Banking Blueprint Example (87/100)\", () => {\n176 |     // Inputs: Banking, 10000+ company size, Scaling AI, Productivity + Cost Reduction + Compliance, Mostly Integrated Data, Budget Approved\n177 |     const answers = {\n178 |       industry: \"Banking\",\n179 |       companySize: \"10000+\",\n180 |       topPriorities: [\"Productivity\", \"Cost Reduction\", \"Compliance\"],\n181 |       aiJourney: \"Scaling AI\",\n182 |       dataReadiness: \"Mostly integrated\",\n183 |       leadershipCommitment: \"Budget Approved\",\n184 |       biggestChallenge: \"Budget/ROI\",\n185 |       email: \"banking@gff.ai\"\n186 |     };\n187 | \n188 |     const score = blueprintData.calculateBlueprintScore(answers);\n189 |     assertEquals(score, 87, \"Banking Blueprint test case must score exactly 87\");\n190 |   });\n191 | \n192 |   test(\"Shared Blueprint scoring (lib/shared-validation) - Banking Blueprint Example (87/100)\", () => {\n193 |     // Inputs: Banking, 10000+ company size, Scaling AI, Productivity + Cost Reduction + Compliance, Mostly Integrated Data, Budget Approved\n194 |     const inputs = {\n195 |       industry: \"Banking\",\n196 |       companySize: \"10000+\",\n197 |       topPriorities: [\"Improve Productivity\", \"Reduce Costs\", \"Strengthen Compliance\"],\n198 |       aiJourney: \"Scaling AI\",\n199 |       dataReadiness: \"Mostly integrated\",\n200 |       leadershipCommitment: \"Budget Approved\"\n201 |     };\n202 | \n203 |     const score = sharedValidation.calculateSharedBlueprintScore(inputs);\n204 |     assertEquals(score, 87, \"Shared Banking Blueprint test case must score exactly 87\");\n205 |   });\n206 | \n207 |   test(\"Blueprint scoring - low baseline score scenario\", () => {\n208 |     const answers = {\n209 |       industry: \"Other\",\n210 |       companySize: \"<100\",\n211 |       topPriorities: [\"AI Transformation\"],\n212 |       aiJourney: \"No AI\",\n213 |       dataReadiness: \"Highly fragmented\",\n214 |       leadershipCommitment: \"Not Discussed\",\n215 |       biggestChallenge: \"Tech Stack\",\n216 |       email: \"test@gff.ai\"\n217 |     };\n218 | \n219 |     const score = blueprintData.calculateBlueprintScore(answers);\n220 |     assertEquals(score, 18);\n221 |   });\n222 | \n223 | \n224 |   // ==========================================\n225 |   // GROUP 3: ASSESSMENT SCORING\n226 |   // ==========================================\n227 |   console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 3: Assessment Scoring Math ---\");\n228 | \n229 |   test(\"Assessment Scoring - minimum inputs (all 1s)\", () => {\n230 |     const totalScore = 24; // 24 questions, each answered with option score 1\n231 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n232 |     assertEquals(percentage, 0);\n233 |   });\n234 | \n235 |   test(\"Assessment Scoring - maximum inputs (all 4s)\", () => {\n236 |     const totalScore = 96; // 24 questions, each answered with option score 4\n237 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n238 |     assertEquals(percentage, 100);\n239 |   });\n240 | \n241 |   test(\"Assessment Scoring - mid range\", () => {\n242 |     const totalScore = 60; // middle of the range [24, 96]\n243 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n244 |     assertEquals(percentage, 50);\n245 |   });\n246 | \n247 |   // ==========================================\n248 |   // GROUP 4: ROI CALCULATION\n249 |   // ==========================================\n250 |   console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 4: ROI Calculation ---\");\n251 | \n252 |   test(\"ROI Estimation - base enterprise case\", () => {\n253 |     const inputs = {\n254 |       teamSize: 50,\n255 |       avgHourlyRate: 75,\n256 |       inefficientHoursPerWeek: 8,\n257 |       initialInvestment: 120000,\n258 |       priority: \"Improve Productivity\"\n259 |     };\n260 | \n261 |     const result = sharedValidation.calculateSharedROIEstimate(inputs);\n262 |     \n263 |     // Formula verification:\n264 |     // annualHoursSaved = teamSize * inefficientHoursPerWeek * 52 * 0.85 = 50 * 8 * 52 * 0.85 = 17680\n265 |     // grossSavings = annualHoursSaved * avgHourlyRate = 17680 * 75 = 1,326,000\n266 |     // netSavings = grossSavings - initialInvestment = 1,326,000 - 120,000 = 1,206,000\n267 |     // roiPercentage = (netSavings / initialInvestment) * 100 = (1,206,000 / 120,000) * 100 = 1005%\n268 |     // monthlySavings = grossSavings / 12 = 110,500\n269 |     // paybackMonths = initialInvestment / monthlySavings = 120,000 / 110,500 = 1.08 -> max(1, 1.1) = 1.1\n270 |     \n271 |     assertEquals(result.annualHoursSaved, 17680);\n272 |     assertEquals(result.grossSavings, 1326000);\n273 |     assertEquals(result.netSavings, 1206000);\n274 |     assertEquals(result.roiPercentage, 1005);\n275 |     assertEquals(result.paybackMonths, 1.1);\n276 |   });\n277 | \n278 |   // ==========================================\n279 |   // GROUP 5: LOCAL RECOMMENDATION LOGIC\n280 |   // ==========================================\n281 |   console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 5: Recommendation Logic ---\");\n282 | \n283 |   test(\"getRecommendedOpportunities - Banking industry recommendations\", () => {\n284 |     const recs = blueprintData.getRecommendedOpportunities(\"Banking\");\n285 |     assert(Array.isArray(recs), \"Should return an array\");\n286 |     assert(recs.includes(\"Sovereign AML & Transactions Ledger Analyst\"), \"Should recommend Banking-specific tools\");\n287 |     assert(recs.includes(\"High-Frequency Risk Intelligence & Simulation Agent\"), \"Should recommend risk intelligence agents\");\n288 |   });\n289 | \n290 |   test(\"getRecommendedSolution - Tech Stack legacy challenge\", () => {\n291 |     const solution = blueprintData.getRecommendedSolution(\"Tech Stack\");\n292 |     assertEquals(solution.title, \"GFF Enterprise Integration Mesh™\");\n293 |     assert(solution.description.includes(\"legacy databases\"), \"Should focus on legacy databases resolution\");\n294 |   });\n295 | \n296 |   test(\"getRecommendedSolution - Budget/ROI constraint challenge\", () => {\n297 |     const solution = blueprintData.getRecommendedSolution(\"Budget/ROI\");\n298 |     assertEquals(solution.title, \"GFF AI Agent Factory™ (Starter Edition)\");\n299 |     assert(solution.description.includes(\"4.2x ROI\"), \"Should focus on guaranteed value and starter pricing\");\n300 |   });\n301 | \n302 |   test(\"getExpectedImpact - Productivity impact metrics\", () => {\n303 |     const impact = blueprintData.getExpectedImpact([\"Productivity\"]);\n304 |     assert(impact.metric.includes(\"4.2x Year 1 ROI\"), \"Should mention 4.2x Year 1 ROI\");\n305 |   });\n306 | \n307 |   test(\"getExpectedImpact - Cost Reduction impact metrics\", () => {\n308 |     const impact = blueprintData.getExpectedImpact([\"Cost Reduction\"]);\n309 |     assert(impact.metric.includes(\"$2.4M saved\"), \"Should mention $2.4M saved\");\n310 |   });\n311 | \n312 | } catch (e) {\n313 |   console.error(\"\\x1b[31m%s\\x1b[0m\", \"Unhandled test error:\");\n314 |   console.error(e);\n315 |   failedTests++;\n316 | } finally {\n317 |   cleanup();\n318 | }\n319 | \n320 | // 4. Verification Summary\n321 | console.log(\"\\n\\x1b[35m%s\\x1b[0m\", \"========================================================\");\n322 | console.log(\"\\x1b[35m%s\\x1b[0m\", \"                  VERIFICATION SUMMARY                  \");\n323 | console.log(\"\\x1b[35m%s\\x1b[0m\", \"========================================================\");\n324 | console.log(`  Total Passed: \\x1b[32m${passedTests}\\x1b[0m`);\n325 | console.log(`  Total Failed: ${failedTests > 0 ? `\\x1b[31m${failedTests}\\x1b[0m` : `\\x1b[32m${failedTests}\\x1b[0m`}`);\n326 | \n327 | if (failedTests > 0) {\n328 |   console.log(\"\\x1b[41m\\x1b[30m%s\\x1b[0m\", \" VERIFICATION FAILED: One or more tool logic checks failed! \");\n329 |   process.exit(1);\n330 | } else {\n331 |   console.log(\"\\x1b[42m\\x1b[30m%s\\x1b[0m\", \" VERIFICATION SUCCESSFUL: All deterministic logic verified! \");\n332 |   process.exit(0);\n333 | }\n334 | ","success":true}],"durationMs":5}}
