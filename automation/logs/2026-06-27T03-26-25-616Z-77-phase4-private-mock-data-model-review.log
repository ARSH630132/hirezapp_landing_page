{"ts":"2026-06-27T03:24:35.719Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"9lckjikt","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/mock-data-model.ts:1-400","result":"  1 | /**\n  2 |  * UI QUALITY CONSTITUTION - GFF AI PREVIEW DATA MODEL\n  3 |  * \n  4 |  * This file centralizes the complete, high-fidelity mock data model for the\n  5 |  * Client Portal and Admin Portal as required by Task 77-phase4-private-mock-data-model.\n  6 |  * \n  7 |  * All data is deterministic, marked as demo/preview data, and contains no real-world clients or logos.\n  8 |  */\n  9 | \n 10 | // ============================================================================\n 11 | // 1. DATA TYPES (15 REQUIRED TYPES)\n 12 | // ============================================================================\n 13 | \n 14 | export interface ClientAccount {\n 15 |   id: string;\n 16 |   name: string;\n 17 |   domain: string;\n 18 |   status: \"active\" | \"suspended\" | \"pending\";\n 19 |   tier: \"Sovereign\" | \"Enterprise\" | \"Standard\";\n 20 |   createdAt: string;\n 21 |   region: string;\n 22 |   complianceLevel: string;\n 23 |   contactName: string;\n 24 |   contactEmail: string;\n 25 | }\n 26 | \n 27 | export interface Project {\n 28 |   id: string;\n 29 |   name: string;\n 30 |   clientAccountId: string;\n 31 |   status: \"active\" | \"completed\" | \"paused\" | \"evaluating\";\n 32 |   desc: string;\n 33 |   enclaveType: \"Intel SGX\" | \"AMD SEV-SNP\" | \"AWS Nitro Enclave\";\n 34 |   nodesCount: number;\n 35 |   lastUpdated: string;\n 36 |   tag: string;\n 37 | }\n 38 | \n 39 | export interface Program {\n 40 |   id: string;\n 41 |   name: string;\n 42 |   status: \"active\" | \"completed\" | \"on_hold\";\n 43 |   progress: number; // percentage 0-100\n 44 |   projectIds: string[];\n 45 | }\n 46 | \n 47 | export interface AgentOperation {\n 48 |   id: string;\n 49 |   name: string;\