assName=\"relative\">\n                    <select value={f.v} onChange={e => f.s(e.target.value)} className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/60 text-white outline-none appearance-none cursor-pointer text-[10px] font-mono\">\n                      {f.o.map(o => <option key={o.v} value={o.v} className=\"bg-black text-white font-mono\">{o.l}</option>)}\n                    </select>\n                    <ChevronDown className=\"absolute right-2 top-2.5 h-3 w-3 text-white/30 pointer-events-none\" />\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          {/* Ticket list */}\n          <div className=\"space-y-3 max-h-[600px] overflow-y-auto pr-1\">\n            {filtered.length === 0 ? (\n              <div className=\"p-8 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-2 font-mono\">\n                <p className=\"text-xs text-white/30\">No active wires match filter parameters.</p>\n                <button onClick={() => { setSearch(\"\"); setStatusFilter(\"ALL\"); setCatFilter(\"ALL\"); setPriFilter(\"ALL\"); setProjFilter(\"ALL\"); }} className=\"text-[10px] text-[#009DFF] underline uppercase font-bold\">Reset filters</button>\n              </div>\n            ) : (\n              filtered.map(t => {\n                const isSelected = t.id === selectedTicketId;\n                const proj = previewProjects.find(p => p.id === t.projectId);\n                return (\n                  <div key={t.id} onClick={() => setSelectedTicketId(t.id)} className={`relative cursor-pointer rounded-xl border transition-all p-4 ${isSelected ? \"border-[#009DFF]/40 bg-[#009DFF]/5\" : \"border-white/5 bg-[#050505]/40 hover:border-white/10\"}`}>\n                    {isSelected && <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-[#009DFF] rounded-l-xl\" />}\n                    <div className=\"space-y-2 font-mono text-left\">\n                      <div className=\"flex justify-between items-center text-[9px]\">\n                        <div className=\"flex items-center gap-1.5\">\n                          <span className={`px-1.5 py-0.5 rounded border font-bold text-[8px] uppercase ${getPriorityStyle(t.priority)}`}>{t.priority}</span>\n                          <span className=\"text-white/40 font-bold\">{t.id}</span>\n                        </div>\n                        <StatusBadge state={t.status === \"open\" ? \"active\" : t.status === \"in_progress\" ? \"warning\" : \"stable\"} label={t.status} />\n                      </div>\n                      <h4 className=\"text-[11.5px] font-bold text-white leading-snug\">{t.title}</h4>\n                      <div className=\"flex items-center gap-2 text-[9px] text-white/40 pt-1 border-t border-white/[0.03]\">\n                        <span className=\"flex items-center gap-1\">\n                          {getCatIcon(t.category)}\n                          <span className=\"uppercase text-[8px]\">{t.category}</span>\n                        </span>\n                        {proj && <span className=\"text-[#00FFC2] bg-[#00FFC2]/5 px-1 py-0.5 rounded text-[8px] font-bold\">PROJ: {proj.tag}</span>}\n                        <span className=\"text-white/20 ml-auto\">{new Date(t.createdAt).toLocaleDateString()}</span>\n                      </div>\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>"}}}
