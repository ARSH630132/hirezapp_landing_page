he border and color choices. I'm focused on improving the overall visual clarity of ticket details.\n\n\n"}}
{"ts":"2026-06-27T10:34:07.289Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"1faoi0y2","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/support/[id]/page.tsx","old_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { \n  ArrowLeft, MessageSquare, ShieldCheck, Clock, Lock, Terminal, \n  Send, RefreshCw, X, HelpCircle, Layers, Cpu, DollarSign, FileText, Key, Shield\n} from \"lucide-react\";\nimport { previewProjects, previewSupportTickets, SupportTicket } from \"@/lib/mock-data-model\";\nimport { StatusBadge } from \"@/components/private-app\";\n\ninterface ClientSupportTicket extends SupportTicket {\n  category: \"Project Delivery\" | \"AI Operations\" | \"Billing\" | \"Documents\" | \"Access\" | \"Governance\" | \"General\";\n  projectId?: string;\n}\n\nexport default function ClientSupportDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const ticketId = typeof id === \"string\" ? id : \"\";\n\n  const [tickets, setTickets] = useState<ClientSupportTicket[]>([]);\n  const [replyText, setReplyText] = useState(\"\");\n  const [isReplying, setIsReplying] = useState(false);\n  const chatEndRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const saved = localStorage.getItem(\"gff_support_tickets\");\n      if (saved) {\n        try { setTickets(JSON.parse(saved)); } catch (e) { resetToDefault(); }\n      } else { resetToDefault(); }\n    }\n  }, []);\n\n  const resetToDefault = () => {\n    const cats: ClientSupportTicket[\"category\"][] = [\"AI Operations\", \"AI Operations\", \"Governance\"];\n    const projs = [\"proj-001\", \"proj-002\", \"proj-001\"];\n    const augmented = previewSupportTickets.map((t, i) => ({\n      ...t,\n      category: cats[i] || \"General\",\n      projectId: projs[i]\n    })) as ClientSupportTicket[];\n    setTickets(augmented);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_support_tickets\", JSON.stringify(augmented));\n    }\n  };\n\n  const saveTickets = (updated: ClientSupportTicket[]) => {\n    setTickets(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_support_tickets\", JSON.stringify(updated));\n    }\n  };\n\n  const activeTicket = tickets.find(t => t.id === ticketId);\n\n  const handleSendReply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!replyText.trim() || !activeTicket) return;\n\n    const currentReply = replyText;\n    setReplyText(\"\");\n    setIsReplying(true);\n\n    const userReply = {\n      sender: \"Alexander Mercer (Client)\",\n      text: currentReply,\n      timestamp: new Date().toISOString()\n    };\n\n    const updatedReplies = [...(activeTicket.replies || []), userReply];\n    const updatedTickets = tickets.map(t => {\n      if (t.id === ticketId) {\n        return { ...t, replies: updatedReplies, status: t.status === \"resolved\" ? \"in_progress\" : t.status };\n      }\n      return t;\n    }) as ClientSupportTicket[];\n\n    saveTickets(updatedTickets);\n\n    setTimeout(() => {\n      let botText = \"Handshake acknowledged. Our on-call systems engineers are reviewing your trace reports inside the secure sandbox.\";\n      let botSender = \"GFF Support Sentinel\";\n\n      if (activeTicket.category === \"AI Operations\") {\n        botSender = \"Dr. Sarah Vance (Lead Systems Architect)\";\n        botText = \"Analyzing enclave CPU and HSM logs. The cryptographic state is re-asserted and key rotational interlocks are operating nominally. All propagation latency is mitigated (<0.4ms).\";\n      } else if (activeTicket.category === \"Billing\") {\n        botSender = \"Nicolette Durand (Billing & Treasury)\";\n        botText = \"Invoices check completed. Invoice settlement is verified at blockchain consensus block 18290192 under seal 0xDE897FFA.\";\n      } else if (activeTicket.category === \"Governance\" || activeTicket.category === \"Documents\") {\n        botSender = \"Sovereign Audit Agent\";\n        botText = \"Operator credentials verified at Clearance Level IV. The NIST AI RMF logs are compiled successfully within SGX memory. Access credentials issued.\";\n      }\n\n      const botReply = { sender: botSender, text: botText, timestamp: new Date().toISOString() };\n      \n      saveTickets(updatedTickets.map(t => {\n        if (t.id === ticketId) {\n          return { ...t, replies: [...updatedReplies, botReply], status: \"in_progress\" };\n        }\n        return t;\n      }) as ClientSupportTicket[]);\n      \n      setIsReplying(false);\n    }, 1500);\n  };\n\n  if (tickets.length > 0 && !activeTicket) {\n    return (\n      <div className=\"space-y-6 max-w-xl mx-auto p-8 border border-white/5 bg-[#050505]/40 rounded-xl text-center font-mono text-white\">\n        <X className=\"w-12 h-12 text-red-400 mx-auto animate-pulse\" />\n        <h3 className=\"text-sm font-bold uppercase\">Secure Wire Not Authorized</h3>\n        <p className=\"text-xs text-white/50\">This communication enclave ID has either expired, rotated, or does not exist inside your clear session namespace.</p>\n        <button onClick={() => router.push(\"/portal/support\")} className=\"inline-flex h-9 items-center justify-center rounded px-4 bg-white text-black font-semibold text-xs tracking-wider uppercase cursor-pointer\">\n          Return to Comm Hub\n        </button>\n      </div>\n    );\n  }\n\n  const proj = activeTicket ? previewProjects.find(p => p.id === activeTicket.projectId) : null;\n\n  return (\n    <div className=\"space-y-6 max-w-[1200px] mx-auto pb-12 select-none text-white font-mono\">\n      {/* Top Navigation */}\n      <div className=\"flex items-center gap-3\">\n        <button\n          onClick={() => router.push(\"/portal/support\")}\n          className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer transition-colors\"\n        >\n          <ArrowLeft className=\"w-4 h-4\" />\n        </button>\n        <div className=\"text-left font-sans\">\n          <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">\n            ACTIVE SLA WIRE TUNNEL\n          </span>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase mt-1\">\n            Audit Ticket: {ticketId}\n          </h2>\n        </div>\n      </div>\n\n      {activeTicket && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 font-sans text-left\">\n          {/* Main Chat Thread (2/3 Column) */}\n          <div className=\"lg:col-span-2 space-y-4\">\n            <div className=\"p-4 rounded-xl border border-white/10 bg-[#050505]/40 backdrop-blur-sm overflow-hidden flex flex-col h-[600px] justify-between font-mono\">\n              <div className=\"p-4 border-b border-white/5 bg-black/20 flex justify-between items-start font-mono\">\n                <div className=\"space-y-1\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded font-bold uppercase\">SECURE WIRE</span>\n                    <span className=\"text-[9px] text-white/40 font-bold\">{activeTicket.id}</span>\n                  </div>\n                  <h3 className=\"text-[12px] font-bold text-white uppercase mt-1\">{activeTicket.title}</h3>\n                </div>\n                <button onClick={() => router.push(\"/portal/support\")} className=\"p-1 text-white/40 hover:text-white\"><X className=\"w-4 h-4\" /></button>\n              </div>\n\n              <div className=\"flex-1 overflow-y-auto p-4 space-y-4\">\n                <div className=\"grid grid-cols-2 gap-2 text-[9px]\">\n                  <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8px]\">Enclave Attestation</span>\n                    <div className=\"flex items-center gap-1 text-emerald-400 font-bold mt-1\">\n                      <Lock className=\"w-3.5 h-3.5\" />\n                      <span>Intel SGX Signed</span>\n                    </div>\n                  </div>\n                  <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8px]\">SLA Response Window</span>\n                    <div className=\"flex items-center gap-1 text-amber-400 font-bold mt-1\">\n                      <Clock className=\"w-3.5 h-3.5 animate-pulse\" />\n                      <span>{activeTicket.priority === \"critical\" ? \"P1 (15m window)\" : \"P2 (1h window)\"}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase font-mono\">Diagnostics Dump</span>\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-black/70 text-[10px] text-white/80 leading-relaxed max-h-[120px] overflow-y-auto select-text font-mono\">\n                    <div className=\"flex items-center gap-1 text-[#009DFF] border-b border-white/5 pb-1 mb-1.5 font-mono\">\n                      <Terminal className=\"w-3.5 h-3.5\" />\n                      <span>LOCAL EXCEPTION TRACE</span>\n                    </div>\n                    {activeTicket.desc}\n                  </div>\n                </div>\n\n                {/* Replies Thread */}\n                <div className=\"space-y-3 pt-1\">\n                  <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase font-mono\">Handshake Logs</span>\n                  <div className=\"space-y-2.5\">\n                    <div className=\"p-2.5 rounded border border-white/5 bg-white/[0.01] text-[10px] space-y-1 max-w-[90%] font-mono\">\n                      <span className=\"text-[#00FFC2] font-bold\">SYSTEM INTEGRATOR</span>\n                      <p className=\"text-white/70 leading-normal font-mono\">Operational handshake validated. Route map deployed to core systems engineers.</p>\n                    </div>\n\n                    {activeTicket.replies?.map((r, i) => {\n                      const isClient = r.sender.includes(\"Client\") || r.sender.includes(\"Mercer\");\n                      return (\n                        <div key={i} className={`p-3 rounded-xl border text-[10px] space-y-1 max-w-[90%] font-mono ${isClient ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right font-mono\" : \"border-emerald-500/10 bg-emerald-500/[0.02]\"}`}>\n                          <span className={`font-bold block font-mono ${isClient ? \"text-[#009DFF]\" : \"text-emerald-400\"}`}>{r.sender.toUpperCase()}</span>\n                          <p className=\"text-white/85 leading-relaxed select-text font-mono\">{r.text}</p>\n                        </div>\n                      );\n                    })}\n\n                    {isReplying && (\n                      <div className=\"p-2.5 rounded-lg border border-white/5 text-[9px] text-white/30 flex items-center gap-1.5 animate-pulse max-w-[80%] font-mono\">\n                        <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-emerald-400\" />\n                        <span>Core system architect parsing telemetry...</span>\n                      </div>\n                    )}\n                    <div ref={chatEndRef} />\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"p-3 border-t border-white/5 bg-black/40\">\n                <form onSubmit={handleSendReply} className=\"relative font-mono\">\n                  <textarea\n                    required\n                    disabled={isReplying}\n                    placeholder=\"Compose secured response...\"\n                    value={replyText}\n                    onChange={e => setReplyText(e.target.value)}\n                    onKeyDown={e => { if (e.key === \"Enter\" && !e.shiftKey) { e.preventDefault(); handleSendReply(e); } }}\n                    className=\"w-full h-14 rounded-lg border border-white/10 bg-black/60 pl-3 pr-12 py-2.5 text-white text-[11px] outline-none resize-none leading-relaxed font-mono\"\n                  />\n                  <button type=\"submit\" disabled={!replyText.trim() || isReplying} className=\"absolute right-2 bottom-3 p-1.5 rounded-md bg-white text-black hover:bg-white/90 disabled:opacity-25 cursor-pointer font-mono\"><Send className=\"w-3.5 h-3.5\" /></button>\n                </form>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Parameters panel */}\n          <div className=\"space-y-4\">\n            <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2 font-mono\">\n                <ShieldCheckIcon className=\"w-4 h-4 text-[#00FFC2]\" />\n                <h3 className=\"text-xs font-bold text-white uppercase tracking-wider font-mono\">Sovereign SLA Bounds</h3>\n              </div>\n              <div className=\"space-y-3.5 text-[10.5px] font-mono\">\n                <div className=\"flex justify-between border-b border-white/5 pb-1.5 font-mono\">\n                  <span className=\"text-white/40 font-mono\">SLA Priority:</span>\n                  <span className=\"text-white font-bold uppercase font-mono\">{activeTicket.priority}</span>\n                </div>\n                <div className=\"flex justify-between border-b border-white/5 pb-1.5 font-mono\">\n                  <span className=\"text-white/40 font-mono\">Category:</span>\n                  <span className=\"text-white uppercase font-mono\">{activeTicket.category}</span>\n                </div>\n                {proj && (\n                  <div className=\"flex justify-between border-b border-white/5 pb-1.5 font-mono\">\n                    <span className=\"text-white/40 font-mono\">Attached Sandbox:</span>\n                    <span className=\"text-[#00FFC2] font-bold uppercase font-mono\">{proj.tag}</span>\n                  </div>\n                )}\n                <div className=\"p-3 rounded-lg bg-black/50 border border-white/5 text-[9.5px] leading-relaxed space-y-1 text-white/60 font-mono\">\n                  <div className=\"flex items-center gap-1 font-bold text-[#009DFF] uppercase text-[8.5px] font-mono\">\n                    <Lock className=\"w-3.5 h-3.5\" />\n                    <span>Tunnel Signature</span>\n                  </div>\n                  <span className=\"block truncate text-white/30 text-[8px] font-mono\">0xCRYPTOSIGN_L4_{activeTicket.id}_GFF</span>\n                  <p className=\"font-mono\">All transited context is locked under ephemeral dual-private key hashes. Persistent memory blocks rotated every 24 hours.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n\nfunction ShieldCheckIcon({ className }: { className?: string }) {\n  return (\n    <svg className={className} xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"2\">\n      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n    </svg>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { ArrowLeft, Clock, Lock, Terminal, Send, RefreshCw, X, ShieldCheck } from \"lucide-react\";\nimport { previewProjects, previewSupportTickets, SupportTicket } from \"@/lib/mock-data-model\";\nimport { StatusBadge } from \"@/components/private-app\";\n\ninterface ClientSupportTicket extends SupportTicket {\n  category: \"Project Delivery\" | \"AI Operations\" | \"Billing\" | \"Documents\" | \"Access\" | \"Governance\" | \"General\";\n  projectId?: string;\n}\n\nexport default function ClientSupportDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const ticketId = typeof id === \"string\" ? id : \"\";\n\n  const [tickets, setTickets] = useState<ClientSupportTicket[]>([]);\n  const [replyText, setReplyText] = useState(\"\");\n  const [isReplying, setIsReplying] = useState(false);\n  const chatEndRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const saved = localStorage.getItem(\"gff_support_tickets\");\n      if (saved) {\n        try { setTickets(JSON.parse(saved)); } catch (e) { resetToDefault(); }\n      } else { resetToDefault(); }\n    }\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, []);\n\n  const resetToDefault = () => {\n    const cats: ClientSupportTicket[\"category\"][] = [\"AI Operations\", \"AI Operations\", \"Governance\"];\n    const projs = [\"proj-001\", \"proj-002\", \"proj-001\"];\n    const augmented = previewSupportTickets.map((t, i) => ({\n      ...t,\n      category: cats[i] || \"General\",\n      projectId: projs[i]\n    })) as ClientSupportTicket[];\n    setTickets(augmented);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_support_tickets\", JSON.stringify(augmented));\n    }\n  };\n\n  useEffect(() => { chatEndRef.current?.scrollIntoView({ behavior: \"smooth\" }); }, [tickets]);\n\n  const saveTickets = (updated: ClientSupportTicket[]) => {\n    setTickets(updated);\n    if (typeof window !== \"undefined\") localStorage.setItem(\"gff_support_tickets\", JSON.stringify(updated));\n  };\n\n  const activeTicket = tickets.find(t => t.id === ticketId);\n\n  const handleSendReply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!replyText.trim() || !activeTicket) return;\n\n    const currentReply = replyText;\n    setReplyText(\"\");\n    setIsReplying(true);\n\n    const userReply = { sender: \"Alexander Mercer (Client)\", text: currentReply, timestamp: new Date().toISOString() };\n    const updatedReplies = [...(activeTicket.replies || []), userReply];\n    const updatedTickets = tickets.map(t => {\n      if (t.id === ticketId) return { ...t, replies: updatedReplies, status: t.status === \"resolved\" ? \"in_progress\" : t.status };\n      return t;\n    }) as ClientSupportTicket[];\n\n    saveTickets(updatedTickets);\n\n    setTimeout(() => {\n      let botText = \"Handshake acknowledged. Systems engineers are reviewing logs inside the enclave sandbox.\";\n      let botSender = \"GFF Support Sentinel\";\n\n      if (activeTicket.category === \"AI Operations\") {\n        botSender = \"Dr. Sarah Vance (Lead Systems Architect)\";\n        botText = \"Analyzing enclave CPU and HSM logs. The key rotational interlocks are operating nominally. All propagation latency is mitigated (<0.4ms).\";\n      } else if (activeTicket.category === \"Billing\") {\n        botSender = \"Nicolette Durand (Billing & Treasury)\";\n        botText = \"Invoices check completed. Invoice settlement is verified at epoch block 18290192 under seal 0xDE897FFA.\";\n      } else if (activeTicket.category === \"Governance\" || activeTicket.category === \"Documents\") {\n        botSender = \"Sovereign Audit Agent\";\n        botText = \"Credentials verified at Clearance Level IV. The NIST AI RMF logs are compiled successfully.\";\n      }\n\n      const botReply = { sender: botSender, text: botText, timestamp: new Date().toISOString() };\n      saveTickets(updatedTickets.map(t => t.id === ticketId ? { ...t, replies: [...updatedReplies, botReply], status: \"in_progress\" } : t) as ClientSupportTicket[]);\n      setIsReplying(false);\n    }, 1500);\n  };\n\n  if (tickets.length > 0 && !activeTicket) {\n    return (\n      <div className=\"space-y-6 max-w-xl mx-auto p-8 border border-white/5 bg-[#050505]/40 rounded-xl text-center font-mono text-white mt-12\">\n        <X className=\"w-12 h-12 text-red-400 mx-auto animate-pulse\" />\n        <h3 className=\"text-sm font-bold uppercase font-sans\">Secure Wire Not Authorized</h3>\n        <p className=\"text-xs text-white/50\">This communication enclave ID has expired or does not exist.</p>\n        <button onClick={() => router.push(\"/portal/support\")} className=\"inline-flex h-9 items-center justify-center rounded px-4 bg-white text-black font-semibold text-xs tracking-wider uppercase cursor-pointer\">Return to Comm Hub</button>\n      </div>\n    );\n  }\n\n  const proj = activeTicket ? previewProjects.find(p => p.id === activeTicket.projectId) : null;\n\n  return (\n    <div className=\"space-y-6 max-w-[1200px] mx-auto pb-12 select-none text-white font-mono text-left\">\n      <div className=\"flex items-center gap-3\">\n        <button onClick={() => router.push(\"/portal/support\")} className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer\"><ArrowLeft className=\"w-4 h-4\" /></button>\n        <div>\n          <span className=\"text-[10px] text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">ACTIVE SLA WIRE TUNNEL</span>\n          <h2 className=\"text-xl font-bold tracking-tight uppercase mt-1\">Audit Ticket: {ticketId}</h2>\n        </div>\n      </div>\n\n      {activeTicket && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 font-sans\">\n          <div className=\"lg:col-span-2 space-y-4\">\n            <div className=\"p-4 rounded-xl border border-white/10 bg-[#050505]/40 backdrop-blur-sm space-y-4 flex flex-col h-[600px] justify-between font-mono\">\n              <div className=\"flex-1 overflow-y-auto space-y-4 pr-1\">\n                <div className=\"p-3 rounded-lg border border-white/5 bg-black/70 text-[10.5px] leading-relaxed\">\n                  <div className=\"flex items-center gap-1.5 text-[#009DFF] border-b border-white/5 pb-1 mb-2 font-bold uppercase text-[9px]\"><Terminal className=\"w-3.5 h-3.5\" /><span>Diagnostics Trace Log</span></div>\n                  {activeTicket.desc}\n                </div>\n\n                <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase\">Log handshakes</span>\n                <div className=\"space-y-2.5\">\n                  <div className=\"p-2.5 rounded border border-white/5 bg-white/[0.01] text-[10px] space-y-1 max-w-[90%]\">\n                    <span className=\"text-[#00FFC2] font-bold uppercase text-[9px]\">SYSTEM SYSTEM INITIALIZATION</span>\n                    <p className=\"text-white/70 leading-normal\">Operational tunnel secured. Initial telemetry packet success.</p>\n                  </div>\n\n                  {activeTicket.replies?.map((reply, idx) => {\n                    const isClient = reply.sender.includes(\"Client\");\n                    return (\n                      <div key={idx} className={`p-3 rounded-xl border text-[10px] space-y-1 max-w-[90%] ${isClient ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right\" : \"border-emerald-500/10 bg-emerald-500/[0.02]\"}`}>\n                        <span className={`font-bold block ${isClient ? \"text-[#009DFF]\" : \"text-emerald-400\"}`}>{reply.sender.toUpperCase()}</span>\n                        <p className=\"text-white/85 leading-relaxed select-text\">{reply.text}</p>\n                      </div>\n                    );\n                  })}\n\n                  {isReplying && (\n                    <div className=\"p-2.5 rounded-lg border border-white/5 text-[9px] text-white/30 flex items-center gap-1.5 animate-pulse max-w-[80%]\">\n                      <RefreshCw className=\"w-3 h-3 animate-spin text-emerald-400\" />\n                      <span>Systems architect decoding signal...</span>\n                    </div>\n                  )}\n                  <div ref={chatEndRef} />\n                </div>\n              </div>\n\n              <div className=\"border-t border-white/5 pt-3\">\n                <form onSubmit={handleSendReply} className=\"relative\">\n                  <textarea\n                    required\n                    disabled={isReplying}\n                    placeholder=\"Compose secured response...\"\n                    value={replyText}\n                    onChange={e => setReplyText(e.target.value)}\n                    onKeyDown={e => { if (e.key === \"Enter\" && !e.shiftKey) { e.preventDefault(); handleSendReply(e); } }}\n                    className=\"w-full h-14 rounded-lg border border-white/10 bg-black/60 pl-3 pr-12 py-2.5 text-white text-[11px] outline-none resize-none leading-relaxed font-mono\"\n                  />\n                  <button type=\"submit\" disabled={!replyText.trim() || isReplying} className=\"absolute right-2 bottom-3 p-1.5 rounded-md bg-white text-black hover:bg-white/90 disabled:opacity-25 cursor-pointer\"><Send className=\"w-3.5 h-3.5\" /></button>\n                </form>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"space-y-4\">\n            <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n                <ShieldCheck className=\"w-4 h-4 text-[#00FFC2]\" />\n                <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Sovereign SLA Bounds</h3>\n              </div>\n              <div className=\"space-y-3.5 text-[10.5px]\">\n                <div className=\"flex justify-between border-b border-white/5 pb-1.5\"><span className=\"text-white/40\">SLA Priority:</span><span className=\"text-white font-bold uppercase\">{activeTicket.priority}</span></div>\n                <div className=\"flex justify-between border-b border-white/5 pb-1.5\"><span className=\"text-white/40\">Category:</span><span className=\"text-white uppercase\">{activeTicket.category}</span></div>\n                {proj && <div className=\"flex justify-between border-b border-white/5 pb-1.5\"><span className=\"text-white/40\">Attached Sandbox:</span><span className=\"text-[#00FFC2] font-bold uppercase\">{proj.tag}</span></div>}\n                <div className=\"p-3 rounded-lg bg-black/50 border border-white/5 text-[9.5px] leading-relaxed space-y-1 text-white/60\">\n                  <div className=\"flex items-center gap-1 font-bold text-[#009DFF] uppercase text-[8.5px]\"><Lock className=\"w-3.5 h-3.5\" /><span>Tunnel Signature</span></div>\n                  <span className=\"block truncate text-white/30 text-[8px]\">0xCRYPTOSIGN_L4_{activeTicket.id}_GFF</span>\n                  <p>All transited context is locked under ephemeral dual-private key hashes. Persistent memory blocks rotated every 24 hours.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"}}}
