t Forms**\n\nI'm now integrating the select fields for project, category, and priority into the ticket creation form. I am making use of the values and onChange handlers to update the appropriate state values. I'm also preparing to fetch the appropriate project names for the user to make an informed selection.\n\n\n**Polishing UI Aesthetics**\n\nI'm now focusing on refining the UI for the ticket interface to increase usability. I'm prioritizing clean borders with subtle opacity and avoiding heavy gradients. I'm also planning to use high-contrast text and low-opacity backgrounds with CSS transitions for glowing accents on hover to simulate high-end engineering components.\n\n\n"}}
{"ts":"2026-06-27T10:26:58.320Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"tf1r3h7j","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/support/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { \n  MessageSquare, Cpu, DollarSign, FileText, Key, Shield, HelpCircle, \n  Layers, Plus, Search, Filter, ArrowLeft, Check, Clock, Lock, \n  Terminal, ChevronRight, AlertTriangle, Send, X, ShieldAlert, \n  Sparkles, RefreshCw, CheckCircle2, ChevronDown\n} from \"lucide-react\";\nimport { previewProjects, SupportTicket } from \"@/lib/mock-data-model\";\nimport { WorkspaceCard, StatusBadge } from \"@/components/private-app\";\n\ninterface ClientSupportTicket extends SupportTicket {\n  category: \"Project Delivery\" | \"AI Operations\" | \"Billing\" | \"Documents\" | \"Access\" | \"Governance\" | \"General\";\n  projectId?: string;\n}\n\nconst CATEGORIES = [\n  \"Project Delivery\",\n  \"AI Operations\",\n  \"Billing\",\n  \"Documents\",\n  \"Access\",\n  \"Governance\",\n  \"General\"\n] as const;\n\nconst getInitialAugmentedTickets = (): ClientSupportTicket[] => [\n  {\n    id: \"SLA-TKT-9912\",\n    title: \"Secure HSM Key Rotation Interlock Delayed\",\n    status: \"open\",\n    priority: \"critical\",\n    category: \"AI Operations\",\n    projectId: \"proj-001\",\n    createdAt: \"2026-06-27T10:15:00Z\",\n    desc: \"Enclave hardware is reporting socket timeout while performing automatic HSM roll-key rotation with Sovereign Core Sandbox 02. Expected timeout in 45 minutes.\",\n    replies: [\n      {\n        sender: \"Alexander Mercer\",\n        text: \"Initiated automated rotation but the ledger remains uncommitted. Telemetry is fully active.\",\n        timestamp: \"2026-06-27T10:15:00Z\"\n      },\n      {\n        sender: \"Dr. Sarah Vance (Admin)\",\n        text: \"Analyzing cryptographic enclave stream. Standby, we will manually sign the handshake bypass if needed.\",\n        timestamp: \"2026-06-27T10:25:00Z\"\n      }\n    ]\n  },\n  {\n    id: \"SLA-TKT-9801\",\n    title: \"Thread Load Allocation Exceeding Normal Boundaries\",\n    status: \"in_progress\",\n    priority: \"high\",\n    category: \"AI Operations\",\n    projectId: \"proj-002\",\n    createdAt: \"2026-06-27T07:18:00Z\",\n    desc: \"Node MED-CLINIC-H9 CPU utilization hit 94.5% during diagnostic prompt scan lifecycle. Requesting auto-scaling validation check.\",\n    replies: [\n      {\n        sender: \"Evelyn Carter\",\n        text: \"The threat mapping thread is locked in an infinite evaluation state on local SGX enclave.\",\n        timestamp: \"2026-06-27T07:18:00Z\"\n      },\n      {\n        sender: \"Security Bot\",\n        text: \"Auto-scan activated. Sandboxed namespace isolated. No breach or policy leakage detected.\",\n        timestamp: \"2026-06-27T07:22:00Z\"\n      }\n    ]\n  },\n  {\n    id: \"SLA-TKT-9450\",\n    title: \"SOC2 Compliance Report Signoff Complete\",\n    status: \"resolved\",\n    priority: \"medium\",\n    category: \"Governance\",\n    projectId: \"proj-001\",\n    createdAt: \"2026-06-25T11:40:00Z\",\n    desc: \"Audit check complete on all active sandbox namespaces. No policy violations detected across 10,000 epoch transactions.\",\n    replies: [\n      {\n        sender: \"Auditor Jenkins\",\n        text: \"Signed off on compliant enclaves for Q2 2026. Cryptographic seal logged on GFF AI ledger.\",\n        timestamp: \"2026-06-25T11:40:00Z\"\n      },\n      {\n        sender: \"Alexander Mercer\",\n        text: \"Confirmed. Loaded compliance badge into Sovereign Core portal.\",\n        timestamp: \"2026-06-25T14:30:00Z\"\n      }\n    ]\n  },\n  {\n    id: \"SLA-TKT-8711\",\n    title: \"Singapore Node Deployment Gateway Intercept\",\n    status: \"in_progress\",\n    priority: \"high\",\n    category: \"Project Delivery\",\n    projectId: \"proj-003\",\n    createdAt: \"2026-06-24T09:15:00Z\",\n    desc: \"Secondary nodes on Singapore geological stream are failing initial hardware handshakes. Need manual certificate clearance from GFF systems architect.\",\n    replies: [\n      {\n        sender: \"Evelyn Carter\",\n        text: \"Re-generated client CSR, pending remote signature.\",\n        timestamp: \"2026-06-24T09:15:00Z\"\n      }\n    ]\n  },\n  {\n    id: \"SLA-TKT-7651\",\n    title: \"Compute Epoch Invoice Cryptoseal Validation\",\n    status: \"resolved\",\n    priority: \"low\",\n    category: \"Billing\",\n    projectId: \"proj-001\",\n    createdAt: \"2026-06-22T14:20:00Z\",\n    desc: \"Requesting deep audit hash of GFF-2026-0899 compute invoice to verify on client-side ledger.\",\n    replies: [\n      {\n        sender: \"Alexander Mercer\",\n        text: \"Please provide the SHA-256 seal.\",\n        timestamp: \"2026-06-22T14:20:00Z\"\n      },\n      {\n        sender: \"Dr. Sarah Vance (Admin)\",\n        text: \"Invoice seal: 0xDE897FFA11B8BF99. Successfully recorded on public Ethereum/Sovereign-L2 ledger.\",\n        timestamp: \"2026-06-22T15:00:00Z\"\n      }\n    ]\n  },\n  {\n    id: \"SLA-TKT-6541\",\n    title: \"Clearance Level IV Security Audit Log Access\",\n    status: \"open\",\n    priority: \"medium\",\n    category: \"Documents\",\n    projectId: \"proj-004\",\n    createdAt: \"2026-06-26T16:00:00Z\",\n    desc: \"Need download logs of all sandboxed document queries executed inside Level IV Federal Ledger Enclave during last auditing cycle.\",\n    replies: []\n  },\n  {\n    id: \"SLA-TKT-5211\",\n    title: \"Revoke Expired Certificates on Legacy Nodes\",\n    status: \"open\",\n    priority: \"high\",\n    category: \"Access\",\n    projectId: \"proj-001\",\n    createdAt: \"2026-06-27T01:30:00Z\",\n    desc: \"Secondary access tokens for offboarded contractor accounts require certificate-level revocation on Sovereign Core Sandbox 02.\",\n    replies: []\n  },\n  {\n    id: \"SLA-TKT-4122\",\n    title: \"Sovereign Loop Core Buffering Recommendation\",\n    status: \"resolved\",\n    priority: \"low\",\n    category: \"General\",\n    projectId: \"proj-003\",\n    createdAt: \"2026-06-20T10:00:00Z\",\n    desc: \"Looking for recommendations regarding optimal thread allocation bounds when running low-latency loop geologists.\",\n    replies: [\n      {\n        sender: \"Security Bot\",\n        text: \"Suggested allocation: 8 dedicated AMD SEV-SNP threads, memory bounded at 16GB context overhead.\",\n        timestamp: \"2026-06-20T10:05:00Z\"\n      }\n    ]\n  }\n];\n\nconst generateBotResponse = (ticket: ClientSupportTicket, userReply: string) => {\n  const category = ticket.category;\n  let text = \"\";\n  let sender = \"GFF Support Sentinel\";\n  const replyLower = userReply.toLowerCase();\n  \n  if (category === \"AI Operations\") {\n    sender = \"Dr. Sarah Vance (Lead Systems Architect)\";\n    if (replyLower.includes(\"key\") || replyLower.includes(\"hsm\") || replyLower.includes(\"rotation\")) {\n      text = \"Analyzing sovereign enclave key-rotation logs. The HSM attestation block has been manually cycled and verified against Sandbox Core 02. The propagation delay has returned to a nominal baseline (<0.4ms).\";\n    } else if (replyLower.includes(\"cpu\") || replyLower.includes(\"thread\") || replyLower.includes(\"load\") || replyLower.includes(\"utilization\")) {\n      text = \"Allocated temporary burst threads to your node partition. Enclave CPU utilization on MED-CLINIC-H9 has been buffered and capped. Run checks and advise if further spikes emerge.\";\n    } else {\n      text = \"Direct telemetry stream acknowledged. We have re-routed the signal path away from the secondary transit proxy. Enclave handshakes are performing securely under full AMD SEV-SNP isolation.\";\n    }\n  } else if (category === \"Billing\") {\n    sender = \"Nicolette Durand (Head of Client Accounts)\";\n    text = \"Cryptographic ledger reconciliation completed. Invoice GFF-2026-0899 was checked against the private epoch consensus seal (0xDE897FFA). Settlement is confirmed and logged. No client action required.\";\n  } else if (category === \"Documents\" || category === \"Governance\") {\n    sender = \"Sovereign Audit Sentinel\";\n    text = \"Credential audit complete. Your operator ID is validated at Clearance Level IV. The NIST compliance reports and related transaction log zip files are now compiling within the isolated sandbox environment. They will appear under your Documents workspace shortly.\";\n  } else if (category === \"Access\") {\n    sender = \"GFF Security Core\";\n    text = \"Zero-trust revocation trigger committed. Expired certificates and inactive developer tokens are purged from SGX local memory. Keys rotated successfully. Global directory updated.\";\n  } else {\n    sender = \"GFF Core Support (On-Call)\";\n    text = \"Message intercepted by GFF system engineers. Telemetry packets are currently parsing within our triage environment. We are monitoring your sandbox stream and will coordinate within the SLA window.\";\n  }\n  \n  return { sender, text, timestamp: new Date().toISOString() };\n};\n\nexport default function ClientSupportPage() {\n  const [tickets, setTickets] = useState<ClientSupportTicket[]>([]);\n  const [selectedTicketId, setSelectedTicketId] = useState<string | null>(null);\n  const [replyText, setReplyText] = useState(\"\");\n  const [isReplying, setIsReplying] = useState(false);\n  const [showCreatedToast, setShowCreatedToast] = useState(false);\n  const [createdTicketId, setCreatedTicketId] = useState(\"\");\n\n  // Filters State\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"ALL\");\n  const [selectedCategory, setSelectedCategory] = useState(\"ALL\");\n  const [selectedPriority, setSelectedPriority] = useState(\"ALL\");\n  const [selectedProject, setSelectedProject] = useState(\"ALL\");\n\n  // Create Ticket Form State\n  const [formSubject, setFormSubject] = useState(\"\");\n  const [formCategory, setFormCategory] = useState<ClientSupportTicket[\"category\"]>(\"AI Operations\");\n  const [formPriority, setFormPriority] = useState<ClientSupportTicket[\"priority\"]>(\"high\");\n  const [formProject, setFormProject] = useState(\"none\");\n  const [formDesc, setFormDesc] = useState(\"\");\n\n  const chatEndRef = useRef<HTMLDivElement>(null);\n\n  // Load tickets on mount\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const saved = localStorage.getItem(\"gff_support_tickets\");\n      if (saved) {\n        try {\n          setTickets(JSON.parse(saved));\n        } catch (e) {\n          const fallback = getInitialAugmentedTickets();\n          localStorage.setItem(\"gff_support_tickets\", JSON.stringify(fallback));\n          setTickets(fallback);\n        }\n      } else {\n        const initial = getInitialAugmentedTickets();\n        localStorage.setItem(\"gff_support_tickets\", JSON.stringify(initial));\n        setTickets(initial);\n      }\n    }\n  }, []);\n\n  // Scroll chat thread to bottom when selected ticket replies change\n  useEffect(() => {\n    if (selectedTicketId) {\n      chatEndRef.current?.scrollIntoView({ behavior: \"smooth\" });\n    }\n  }, [selectedTicketId, tickets]);\n\n  const saveTickets = (updated: ClientSupportTicket[]) => {\n    setTickets(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_support_tickets\", JSON.stringify(updated));\n    }\n  };\n\n  const handleCreateTicket = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!formSubject.trim() || !formDesc.trim()) return;\n\n    const newId = `SLA-TKT-${Math.floor(1000 + Math.random() * 9000)}`;\n    const newTicket: ClientSupportTicket = {\n      id: newId,\n      title: formSubject,\n      status: \"open\",\n      priority: formPriority,\n      category: formCategory,\n      projectId: formProject !== \"none\" ? formProject : undefined,\n      createdAt: new Date().toISOString(),\n      desc: formDesc,\n      replies: []\n    };\n\n    const updated = [newTicket, ...tickets];\n    saveTickets(updated);\n    \n    // UI Feedback\n    setCreatedTicketId(newId);\n    setShowCreatedToast(true);\n    setTimeout(() => setShowCreatedToast(false), 5000);\n\n    // Auto-select and clear\n    setSelectedTicketId(newId);\n    setFormSubject(\"\");\n    setFormDesc(\"\");\n    setFormProject(\"none\");\n    setFormPriority(\"high\");\n    setFormCategory(\"AI Operations\");\n  };\n\n  const handleSendReply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!replyText.trim() || !selectedTicketId) return;\n\n    const currentReplyText = replyText;\n    setReplyText(\"\");\n    setIsReplying(true);\n\n    const userReply = {\n      sender: \"Alexander Mercer (Client Operator)\",\n      text: currentReplyText,\n      timestamp: new Date().toISOString()\n    };\n\n    const targetTicket = tickets.find(t => t.id === selectedTicketId);\n    if (!targetTicket) {\n      setIsReplying(false);\n      return;\n    }\n\n    const updatedReplies = [...(targetTicket.replies || []), userReply];\n    const updatedTickets = tickets.map(t => {\n      if (t.id === selectedTicketId) {\n        return { \n          ...t, \n          replies: updatedReplies,\n          status: t.status === \"resolved\" ? \"in_progress\" : t.status \n        } as ClientSupportTicket;\n      }\n      return t;\n    });\n\n    saveTickets(updatedTickets);\n\n    // Trigger simulated support bot reply after 1.5 seconds\n    setTimeout(() => {\n      const botResponseObj = generateBotResponse(targetTicket, currentReplyText);\n      \n      const ticketsPostBot = updatedTickets.map(t => {\n        if (t.id === selectedTicketId) {\n          return {\n            ...t,\n            replies: [...updatedReplies, botResponseObj],\n            status: \"in_progress\" as const\n          } as ClientSupportTicket;\n        }\n        return t;\n      });\n\n      saveTickets(ticketsPostBot);\n      setIsReplying(false);\n    }, 1500);\n  };\n\n  // Filter logic\n  const filteredTickets = tickets.filter(t => {\n    const query = searchQuery.trim().toLowerCase();\n    const matchesSearch = query === \"\" ||\n      t.id.toLowerCase().includes(query) ||\n      t.title.toLowerCase().includes(query) ||\n      t.desc.toLowerCase().includes(query);\n\n    const matchesStatus = selectedStatus === \"ALL\" || t.status.toLowerCase() === selectedStatus.toLowerCase();\n    const matchesCategory = selectedCategory === \"ALL\" || t.category === selectedCategory;\n    const matchesPriority = selectedPriority === \"ALL\" || t.priority.toLowerCase() === selectedPriority.toLowerCase();\n    const matchesProject = selectedProject === \"ALL\" || t.projectId === selectedProject;\n\n    return matchesSearch && matchesStatus && matchesCategory && matchesPriority && matchesProject;\n  });\n\n  const activeTicket = tickets.find(t => t.id === selectedTicketId);\n\n  // Statistics Calculation\n  const totalActive = tickets.filter(t => t.status !== \"resolved\").length;\n  const criticalCount = tickets.filter(t => t.priority === \"critical\" && t.status !== \"resolved\").length;\n  const resolvedCount = tickets.filter(t => t.status === \"resolved\").length;\n\n  const getPriorityStyles = (p: string) => {\n    switch(p.toLowerCase()) {\n      case \"critical\":\n        return \"bg-red-500/10 text-red-400 border-red-500/20 shadow-[0_0_12px_rgba(239,68,68,0.1)]\";\n      case \"high\":\n        return \"bg-amber-500/10 text-amber-400 border-amber-500/20\";\n      case \"medium\":\n        return \"bg-blue-500/10 text-blue-400 border-blue-500/20\";\n      default:\n        return \"bg-white/5 text-white/50 border-white/10\";\n    }\n  };\n\n  const getCategoryIcon = (cat: string) => {\n    switch(cat) {\n      case \"Project Delivery\": return <Layers className=\"w-3.5 h-3.5\" />;\n      case \"AI Operations\": return <Cpu className=\"w-3.5 h-3.5\" />;\n      case \"Billing\": return <DollarSign className=\"w-3.5 h-3.5\" />;\n      case \"Documents\": return <FileText className=\"w-3.5 h-3.5\" />;\n      case \"Access\": return <Key className=\"w-3.5 h-3.5\" />;\n      case \"Governance\": return <Shield className=\"w-3.5 h-3.5\" />;\n      default: return <HelpCircle className=\"w-3.5 h-3.5\" />;\n    }\n  };\n\n  return (\n    <div className=\"space-y-6 max-w-[1600px] mx-auto pb-12\">\n      {/* 1. Page Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 select-none\">\n        <div>\n          <span className=\"text-[10px] font-mono font-bold tracking-widest text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded uppercase\">\n            SOVEREIGN ENCLAVE OPERATIONS\n          </span>\n          <h2 className=\"text-2xl font-bold text-white tracking-tight font-mono uppercase mt-1\">Sovereign Support Center</h2>\n          <p className=\"text-xs text-white/50 mt-1 max-w-xl leading-relaxed\">\n            Direct hardware-isolated communications channel with GFF systems engineering teams. Decoupled, cryptographically verified support logs.\n          </p>\n        </div>\n\n        {/* Quick controls if needed */}\n        {selectedTicketId && (\n          <button \n            onClick={() => setSelectedTicketId(null)}\n            className=\"self-start md:self-auto h-9 px-4 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.04] text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center gap-2 cursor-pointer\"\n          >\n            <Plus className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>Launch New Wire</span>\n          </button>\n        )}\n      </div>\n\n      {/* 2. Top Stats Dashboard */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 select-none\">\n        <WorkspaceCard className=\"py-4 px-5\">\n          <div className=\"flex flex-col\">\n            <span className=\"text-[9.5px] font-mono tracking-wider text-white/35 uppercase\">Active Support Wires</span>\n            <div className=\"text-2xl font-bold text-white font-mono mt-1 flex items-baseline gap-2\">\n              {totalActive}\n              {criticalCount > 0 && (\n                <span className=\"text-[10px] font-bold text-red-400 bg-red-400/10 px-1.5 py-0.5 rounded border border-red-400/20 animate-pulse\">\n                  {criticalCount} Critical\n                </span>\n              )}\n            </div>\n            <span className=\"text-[9.5px] text-white/20 mt-1\">Pending GFF review</span>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"py-4 px-5\">\n          <div className=\"flex flex-col\">\n            <span className=\"text-[9.5px] font-mono tracking-wider text-white/35 uppercase\">SLA Target Fulfillment</span>\n            <div className=\"text-2xl font-bold text-white font-mono mt-1\">100.0%</div>\n            <span className=\"text-[9.5px] text-emerald-400 font-mono mt-1 flex items-center gap-1\">\n              <span className=\"w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse\" />\n              <span>&lt; 15m Response Active</span>\n            </span>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"py-4 px-5\">\n          <div className=\"flex flex-col\">\n            <span className=\"text-[9.5px] font-mono tracking-wider text-white/35 uppercase\">Trust System Clearance</span>\n            <div className=\"text-2xl font-bold text-[#00FFC2] font-mono mt-1\">LEVEL IV</div>\n            <span className=\"text-[9.5px] text-white/20 mt-1\">Isolated memory seal active</span>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"py-4 px-5\">\n          <div className=\"flex flex-col\">\n            <span className=\"text-[9.5px] font-mono tracking-wider text-white/35 uppercase\">Consensus Logs Checked</span>\n            <div className=\"text-2xl font-bold text-white font-mono mt-1\">{resolvedCount} Sealed</div>\n            <span className=\"text-[9.5px] text-white/20 mt-1\">Cryptographically archived</span>\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* 3. Main Workspace Grid */}\n      <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-6 items-start\">\n        {/* Left Column: Tickets List */}\n        <div className={`space-y-4 ${selectedTicketId ? \"xl:col-span-5\" : \"xl:col-span-7\"}`}>\n          {/* Filter Bar */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm space-y-3\">\n            <div className=\"flex flex-col md:flex-row gap-3 items-center\">\n              <div className=\"relative w-full\">\n                <Search className=\"absolute left-3 top-2.5 h-4.5 w-4.5 text-white/30\" />\n                <input\n                  type=\"text\"\n                  placeholder=\"Search secure wire ID, subject...\"\n                  value={searchQuery}\n                  onChange={e => setSearchQuery(e.target.value)}\n                  className=\"w-full h-10 pl-9 pr-4 rounded-lg border border-white/10 bg-black/40 text-white text-[12px] outline-none font-mono focus:border-[#009DFF]/30 placeholder:text-white/20\"\n                />\n              </div>\n\n              {/* Quick Reset */}\n              {(selectedStatus !== \"ALL\" || selectedCategory !== \"ALL\" || selectedPriority !== \"ALL\" || selectedProject !== \"ALL\" || searchQuery !== \"\") && (\n                <button\n                  onClick={() => {\n                    setSearchQuery(\"\");\n                    setSelectedStatus(\"ALL\");\n                    setSelectedCategory(\"ALL\");\n                    setSelectedPriority(\"ALL\");\n                    setSelectedProject(\"ALL\");\n                  }}\n                  className=\"shrink-0 text-[10.5px] font-mono text-white/40 hover:text-[#009DFF] transition-all flex items-center gap-1 border border-white/5 hover:border-[#009DFF]/20 px-3 h-10 rounded-lg bg-white/[0.01]\"\n                >\n                  <X className=\"w-3.5 h-3.5\" />\n                  <span>Reset Filters</span>\n                </button>\n              )}\n            </div>\n\n            {/* Filter Dropdowns */}\n            <div className=\"grid grid-cols-2 md:grid-cols-4 gap-2 pt-1 font-mono text-[10px]\">\n              <div>\n                <label className=\"text-white/35 font-bold uppercase block mb-1\">Status</label>\n                <div className=\"relative\">\n                  <select\n                    value={selectedStatus}\n                    onChange={e => setSelectedStatus(e.target.value)}\n                    className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/50 text-white outline-none cursor-pointer appearance-none text-[10.5px]\"\n                  >\n                    <option value=\"ALL\">ALL STATUSES</option>\n                    <option value=\"open\">OPEN</option>\n                    <option value=\"in_progress\">IN PROGRESS</option>\n                    <option value=\"resolved\">RESOLVED</option>\n                  </select>\n                  <ChevronDown className=\"absolute right-2 top-2.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-white/35 font-bold uppercase block mb-1\">Category</label>\n                <div className=\"relative\">\n                  <select\n                    value={selectedCategory}\n                    onChange={e => setSelectedCategory(e.target.value)}\n                    className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/50 text-white outline-none cursor-pointer appearance-none text-[10.5px]\"\n                  >\n                    <option value=\"ALL\">ALL CATEGORIES</option>\n                    {CATEGORIES.map(cat => (\n                      <option key={cat} value={cat}>{cat.toUpperCase()}</option>\n                    ))}\n                  </select>\n                  <ChevronDown className=\"absolute right-2 top-2.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-white/35 font-bold uppercase block mb-1\">Priority</label>\n                <div className=\"relative\">\n                  <select\n                    value={selectedPriority}\n                    onChange={e => setSelectedPriority(e.target.value)}\n                    className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/50 text-white outline-none cursor-pointer appearance-none text-[10.5px]\"\n                  >\n                    <option value=\"ALL\">ALL PRIORITIES</option>\n                    <option value=\"critical\">P1 - CRITICAL</option>\n                    <option value=\"high\">P2 - HIGH</option>\n                    <option value=\"medium\">P3 - MEDIUM</option>\n                    <option value=\"low\">P4 - LOW</option>\n                  </select>\n                  <ChevronDown className=\"absolute right-2 top-2.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                </div>\n              </div>\n\n              <div>\n                <label className=\"text-white/35 font-bold uppercase block mb-1\">Project Link</label>\n                <div className=\"relative\">\n                  <select\n                    value={selectedProject}\n                    onChange={e => setSelectedProject(e.target.value)}\n                    className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/50 text-white outline-none cursor-pointer appearance-none text-[10.5px]\"\n                  >\n                    <option value=\"ALL\">ALL PROJECTS</option>\n                    {previewProjects.map(p => (\n                      <option key={p.id} value={p.id}>{p.tag}</option>\n                    ))}\n                  </select>\n                  <ChevronDown className=\"absolute right-2 top-2.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* Scrollable Ticket List */}\n          <div className=\"space-y-3 max-h-[750px] overflow-y-auto pr-1\">\n            {filteredTickets.length === 0 ? (\n              <div className=\"p-8 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-3 font-mono\">\n                <AlertTriangle className=\"w-8 h-8 text-white/20 mx-auto\" />\n                <p className=\"text-xs text-white/40\">No matching sovereign communication wires located.</p>\n                <button \n                  onClick={() => {\n                    setSearchQuery(\"\");\n                    setSelectedStatus(\"ALL\");\n                    setSelectedCategory(\"ALL\");\n                    setSelectedPriority(\"ALL\");\n                    setSelectedProject(\"ALL\");\n                  }}\n                  className=\"text-[11px] text-[#009DFF] underline uppercase font-bold\"\n                >\n                  Clear search filters\n                </button>\n              </div>\n            ) : (\n              filteredTickets.map(t => {\n                const isSelected = t.id === selectedTicketId;\n                const linkedProject = previewProjects.find(p => p.id === t.projectId);\n                return (\n                  <div\n                    key={t.id}\n                    onClick={() => setSelectedTicketId(t.id)}\n                    className={`relative text-left cursor-pointer rounded-xl border transition-all p-4 select-none ${\n                      isSelected \n                        ? \"border-[#009DFF]/40 bg-[#009DFF]/5 shadow-[0_0_20px_rgba(0,157,255,0.06)]\" \n                        : \"border-white/5 bg-[#050505]/40 hover:border-white/15\"\n                    }`}\n                  >\n                    {/* Glowing indicator line on active selection */}\n                    {isSelected && (\n                      <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-[#009DFF] rounded-l-xl\" />\n                    )}\n\n                    <div className=\"space-y-3\">\n                      <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                        <div className=\"flex items-center gap-2\">\n                          <span className={`px-1.5 py-0.5 rounded border text-[9px] font-bold uppercase tracking-wider ${getPriorityStyles(t.priority)}`}>\n                            {t.priority.toUpperCase()}\n                          </span>\n                          <span className=\"text-white/40 font-bold tracking-widest\">{t.id}</span>\n                        </div>\n                        <StatusBadge state={t.status === \"open\" ? \"active\" : t.status === \"in_progress\" ? \"warning\" : \"stable\"} label={t.status.replace(\"_\", \" \")} />\n                      </div>\n\n                      <h4 className=\"text-[12px] font-bold text-white font-mono leading-snug tracking-tight\">\n                        {t.title}\n                      </h4>\n\n                      <div className=\"flex flex-wrap items-center gap-x-3 gap-y-1 text-[10px] font-mono text-white/45 pt-1.5 border-t border-white/[0.03]\">\n                        <span className=\"flex items-center gap-1 border border-white/5 px-1.5 py-0.5 rounded bg-white/[0.01]\">\n                          {getCategoryIcon(t.category)}\n                          <span className=\"uppercase text-[8.5px] font-bold tracking-wider\">{t.category}</span>\n                        </span>\n                        \n                        {linkedProject && (\n                          <span className=\"text-[#00FFC2] bg-[#00FFC2]/5 border border-[#00FFC2]/10 px-1.5 py-0.5 rounded text-[8.5px] font-bold\">\n                            PROJ: {linkedProject.tag}\n                          </span>\n                        )}\n\n                        <span className=\"text-white/25 ml-auto text-[9px]\">\n                          {new Date(t.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>\n        </div>\n\n        {/* Right Column: Dynamic Form / Detail Panel */}\n        <div className={`xl:sticky xl:top-6 ${selectedTicketId ? \"xl:col-span-7\" : \"xl:col-span-5\"}`}>\n          {activeTicket ? (\n            /* Secure Communication Tunnel Detail Panel */\n            <div className=\"rounded-xl border border-white/10 bg-[#050505]/50 backdrop-blur-sm overflow-hidden flex flex-col h-[750px] shadow-[0_4px_30px_rgba(0,0,0,0.4)]\">\n              {/* Detail Header */}\n              <div className=\"p-4 border-b border-white/5 bg-black/20 flex justify-between items-start select-none\">\n                <div className=\"space-y-1\">\n                  <div className=\"flex items-center gap-2\">\n                    <button \n                      onClick={() => setSelectedTicketId(null)}\n                      className=\"p-1 rounded hover:bg-white/5 border border-white/5 mr-1 text-white/50 hover:text-white\"\n                    >\n                      <ArrowLeft className=\"w-3.5 h-3.5\" />\n                    </button>\n                    <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">\n                      ACTIVE ENCLAVE COMS\n                    </span>\n                    <span className=\"text-[10px] font-mono text-white/40 font-bold\">{activeTicket.id}</span>\n                  </div>\n                  <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-tight mt-1\">\n                    {activeTicket.title}\n                  </h3>\n                </div>\n                <button \n                  onClick={() => setSelectedTicketId(null)}\n                  className=\"p-1 rounded text-white/40 hover:text-white/80 cursor-pointer\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              {/* Scrollable Content Pane */}\n              <div className=\"flex-1 overflow-y-auto p-5 space-y-6\">\n                \n                {/* Parameters Section */}\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3\">\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-black/40 font-mono text-[10px] space-y-1\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8.5px]\">Cryptographic Status</span>\n                    <div className=\"flex items-center gap-1.5 font-bold\">\n                      <Lock className=\"w-3.5 h-3.5 text-emerald-400\" />\n                      <span className=\"text-emerald-400\">Zero-Trust Enclave Signed</span>\n                    </div>\n                    <span className=\"text-white/20 text-[8px] block truncate\">SHA-256: 0xSEAL_{activeTicket.id}_2026</span>\n                  </div>\n\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-black/40 font-mono text-[10px] space-y-1\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8.5px]\">SLA Countdown Parameters</span>\n                    <div className=\"flex items-center gap-1.5 font-bold\">\n                      <Clock className=\"w-3.5 h-3.5 text-amber-400 animate-pulse\" />\n                      <span className=\"text-amber-400\">\n                        {activeTicket.priority === \"critical\" ? \"00:14:52 P1 Critical\" : \n                         activeTicket.priority === \"high\" ? \"00:54:10 P2 SLA Window\" :\n                         activeTicket.priority === \"medium\" ? \"03:45:00 P3 SLA Window\" : \"11:24:12 P4 SLA Window\"}\n                      </span>\n                    </div>\n                    <span className=\"text-white/20 text-[8px] block\">Response guaranteed within timeline bounds</span>\n                  </div>\n                </div>\n\n                {/* Original Diagnostics telemetry container */}\n                <div className=\"space-y-1.5\">\n                  <span className=\"text-[9.5px] font-mono font-bold tracking-widest text-white/30 uppercase block\">\n                    TELEMETRY DIAGNOSTIC PACKET\n                  </span>\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-black/70 text-[11px] font-mono text-white/85 leading-relaxed shadow-inner\">\n                    <div className=\"flex items-center gap-1 text-[9.5px] text-[#009DFF] border-b border-white/5 pb-1.5 mb-2 select-none\">\n                      <Terminal className=\"w-3.5 h-3.5\" />\n                      <span>ORIGINAL ATTRIBUTE DUMP</span>\n                      <span className=\"ml-auto text-white/20\">LOG SECURED</span>\n                    </div>\n                    <p className=\"whitespace-pre-wrap select-text\">{activeTicket.desc}</p>\n                  </div>\n                </div>\n\n                {/* Communication Threads */}\n                <div className=\"space-y-4 pt-2\">\n                  <span className=\"text-[9.5px] font-mono font-bold tracking-widest text-white/30 uppercase block\">\n                    SECURED ENCLAVE WIRE HISTORY\n                  </span>\n                  \n                  <div className=\"space-y-3.5\">\n                    {/* System Initial Message */}\n                    <div className=\"p-3 rounded-lg border border-white/5 bg-white/[0.01] font-mono space-y-1.5 max-w-[90%]\">\n                      <div className=\"flex items-center gap-1.5 text-[10px]\">\n                        <div className=\"w-1.5 h-1.5 rounded-full bg-[#00FFC2]\" />\n                        <span className=\"text-[#00FFC2] font-bold\">GFF System Node</span>\n                        <span className=\"text-white/20 ml-auto\">{new Date(activeTicket.createdAt).toLocaleTimeString()}</span>\n                      </div>\n                      <p className=\"text-[11px] text-white/75 leading-relaxed\">\n                        Secure wire handshake established. Core diagnostics logged. Dispatching context variables to on-call infrastructure engineers...\n                      </p>\n                    </div>\n\n                    {/* Replies */}\n                    {activeTicket.replies && activeTicket.replies.map((reply, idx) => {\n                      const isClient = reply.sender.includes(\"Client\") || reply.sender.includes(\"Mercer\");\n                      return (\n                        <div \n                          key={idx} \n                          className={`p-3.5 rounded-xl border font-mono space-y-1.5 max-w-[90%] transition-all ${\n                            isClient \n                              ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right\" \n                              : \"border-emerald-500/10 bg-emerald-500/[0.02] mr-auto\"\n                          }`}\n                        >\n                          <div className={`flex items-center gap-2 text-[10px] ${isClient ? \"justify-end\" : \"justify-start\"}`}>\n                            {!isClient && <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" />}\n                            <span className={`font-bold ${isClient ? \"text-[#009DFF]\" : \"text-emerald-400\"}`}>\n                              {reply.sender.toUpperCase()}\n                            </span>\n                            {isClient && <span className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF]\" />}\n                            <span className=\"text-white/25 ml-1\">\n                              {new Date(reply.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' })}\n                            </span>\n                          </div>\n                          <p className={`text-[11.5px] leading-relaxed text-white/80 whitespace-pre-wrap select-text ${isClient ? \"text-right\" : \"text-left\"}`}>\n                            {reply.text}\n                          </p>\n                        </div>\n                      );\n                    })}\n\n                    {isReplying && (\n                      <div className=\"p-3.5 rounded-xl border border-white/5 bg-white/[0.01] mr-auto font-mono text-[11px] text-white/40 flex items-center gap-2 max-w-[80%] animate-pulse\">\n                        <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-emerald-400\" />\n                        <span>Systems engineer parsing stream...</span>\n                      </div>\n                    )}\n\n                    <div ref={chatEndRef} />\n                  </div>\n                </div>\n              </div>\n\n              {/* Chat Input Area */}\n              <div className=\"p-4 border-t border-white/5 bg-black/40\">\n                <form onSubmit={handleSendReply} className=\"relative\">\n                  <textarea\n                    required\n                    disabled={isReplying}\n                    placeholder=\"Transmit cryptographically secured command/reply...\"\n                    value={replyText}\n                    onChange={e => setReplyText(e.target.value)}\n                    onKeyDown={e => {\n                      if (e.key === \"Enter\" && !e.shiftKey) {\n                        e.preventDefault();\n                        handleSendReply(e);\n                      }\n                    }}\n                    className=\"w-full h-16 rounded-xl border border-white/10 bg-black/60 pl-4 pr-14 py-3 text-white text-[11.5px] outline-none font-mono focus:border-[#009DFF]/30 resize-none placeholder:text-white/20 leading-relaxed disabled:opacity-50\"\n                  />\n                  <button \n                    type=\"submit\" \n                    disabled={!replyText.trim() || isReplying}\n                    className=\"absolute right-3.5 bottom-3.5 p-2 rounded-lg bg-white text-black hover:bg-white/90 disabled:bg-white/10 disabled:text-white/30 transition-all cursor-pointer\"\n                  >\n                    <Send className=\"w-3.5 h-3.5\" />\n                  </button>\n                </form>\n                <div className=\"flex items-center gap-1.5 text-[9px] font-mono text-white/25 mt-2 select-none\">\n                  <ShieldCheckIcon className=\"w-3 h-3 text-emerald-400\" />\n                  <span>Enclave stream cryptosealed on each keystroke transition</span>\n                </div>\n              </div>\n            </div>\n          ) : (\n            /* Create Support Ticket Form */\n            <div className=\"p-6 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-6\">\n              <div className=\"flex items-center gap-2.5 border-b border-white/5 pb-4 select-none\">\n                <MessageSquare className=\"w-5 h-5 text-[#009DFF]\" />\n                <div>\n                  <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">Open Support Handshake</h3>\n                  <p className=\"text-[10px] text-white/40 mt-0.5\">Initialize dual-socket isolated wire with systems engineering team.</p>\n                </div>\n              </div>\n\n              <form onSubmit={handleCreateTicket} className=\"space-y-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono uppercase text-white/40 font-bold block\">\n                    Diagnostic Subject / Short Summary\n                  </label>\n                  <input\n                    required\n                    placeholder=\"Describe issues (e.g., node latency spike Singapore)...\"\n                    value={formSubject}\n                    onChange={e => setFormSubject(e.target.value)}\n                    className=\"w-full h-10 rounded-lg border border-white/10 bg-black/40 px-4 text-white text-[12px] outline-none font-mono focus:border-[#009DFF]/30 placeholder:text-white/20\"\n                  />\n                </div>\n\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  <div className=\"space-y-1.5 font-mono\">\n                    <label className=\"text-[10px] uppercase text-white/40 font-bold block\">Category</label>\n                    <div className=\"relative\">\n                      <select\n                        value={formCategory}\n                        onChange={e => setFormCategory(e.target.value as any)}\n                        className=\"w-full h-10 rounded-lg border border-white/10 bg-black/40 px-3 text-white text-[12px] outline-none focus:border-[#009DFF]/30 appearance-none cursor-pointer\"\n                      >\n                        {CATEGORIES.map(cat => (\n                          <option key={cat} value={cat} className=\"bg-[#050505] text-white\">\n                            {cat.toUpperCase()}\n                          </option>\n                        ))}\n                      </select>\n                      <ChevronDown className=\"absolute right-3 top-3.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-1.5 font-mono\">\n                    <label className=\"text-[10px] uppercase text-white/40 font-bold block\">SLA Priority Tier</label>\n                    <div className=\"relative\">\n                      <select\n                        value={formPriority}\n                        onChange={e => setFormPriority(e.target.value as any)}\n                        className=\"w-full h-10 rounded-lg border border-white/10 bg-black/40 px-3 text-white text-[12px] outline-none focus:border-[#009DFF]/30 appearance-none cursor-pointer font-bold\"\n                      >\n                        <option value=\"critical\" className=\"bg-[#050505] text-red-400\">P1 - CRITICAL SLA (15m)</option>\n                        <option value=\"high\" className=\"bg-[#050505] text-amber-400\">P2 - HIGH SLA (1h)</option>\n                        <option value=\"medium\" className=\"bg-[#050505] text-[#009DFF]\">P3 - MEDIUM SLA (4h)</option>\n                        <option value=\"low\" className=\"bg-[#050505] text-white/60\">P4 - LOW SLA (12h)</option>\n                      </select>\n                      <ChevronDown className=\"absolute right-3 top-3.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5 font-mono\">\n                  <label className=\"text-[10px] uppercase text-white/40 font-bold block\">Linked Secure Project</label>\n                  <div className=\"relative\">\n                    <select\n                      value={formProject}\n                      onChange={e => setFormProject(e.target.value)}\n                      className=\"w-full h-10 rounded-lg border border-white/10 bg-black/40 px-3 text-white text-[12px] outline-none focus:border-[#009DFF]/30 appearance-none cursor-pointer\"\n                    >\n                      <option value=\"none\" className=\"bg-[#050505] text-white/50\">NO ATTACHED ARCHITECTURE (GENERAL)</option>\n                      {previewProjects.map(p => (\n                        <option key={p.id} value={p.id} className=\"bg-[#050505] text-white\">\n                          {p.name.toUpperCase()} ({p.tag})\n                        </option>\n                      ))}\n                    </select>\n                    <ChevronDown className=\"absolute right-3 top-3.5 h-3.5 w-3.5 text-white/30 pointer-events-none\" />\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono uppercase text-white/40 font-bold block\">\n                    Detailed Telemetry & Diagnostic Logs\n                  </label>\n                  <textarea\n                    required\n                    placeholder=\"Paste error logs, CPU boundaries, key replication buffers, or describe the system issue...\"\n                    value={formDesc}\n                    onChange={e => setFormDesc(e.target.value)}\n                    className=\"w-full h-32 rounded-lg border border-white/10 bg-black/40 p-4 text-white text-[11.5px] outline-none font-mono focus:border-[#009DFF]/30 resize-none placeholder:text-white/20 leading-relaxed\"\n                  />\n                </div>\n\n                <button \n                  type=\"submit\" \n                  className=\"w-full h-11 rounded-lg bg-white hover:bg-white/95 text-black font-semibold text-xs tracking-wider uppercase transition-all cursor-pointer flex items-center justify-center gap-2 select-none shadow-[0_0_20px_rgba(255,255,255,0.05)] font-mono\"\n                >\n                  <CheckCircle2 className=\"w-4 h-4 text-black\" />\n                  <span>Transmit Sovereign Handshake</span>\n                </button>\n              </form>\n\n              <div className=\"p-4 rounded-lg bg-emerald-500/5 border border-emerald-500/10 text-[10.5px] font-mono text-emerald-400/80 leading-relaxed space-y-1 select-none\">\n                <div className=\"flex items-center gap-1 font-bold uppercase text-[9.5px]\">\n                  <Lock className=\"w-3.5 h-3.5\" />\n                  <span>Zero-Trust Cryptographic Guarantee</span>\n                </div>\n                <p>\n                  All tickets are routed through hardware-encrypted memory registers (Intel SGX). Metadata containing passwords or specific client database keys is never stored on persistent storage blocks.\n                </p>\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* Toast Notification for ticket creation */}\n      {showCreatedToast && (\n        <div className=\"fixed bottom-6 right-6 p-4 rounded-xl border border-emerald-500/20 bg-black/90 backdrop-blur-sm text-white font-mono text-[11px] shadow-[0_0_30px_rgba(16,185,129,0.15)] flex items-center gap-3 animate-slide-up z-50 select-none max-w-sm\">\n          <Sparkles className=\"w-5 h-5 text-emerald-400 animate-pulse\" />\n          <div className=\"space-y-0.5\">\n            <span className=\"text-emerald-400 font-bold block\">TICKET TRANSMITTED SECURELY</span>\n            <span className=\"text-white/60 text-[10px]\">Registry ID: {createdTicketId} is now active in Singapore Enclave.</span>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n\n// Inline small SVG helper component\nfunction ShieldCheckIcon({ className }: { className?: string }) {\n  return (\n    <svg \n      className={className} \n      xmlns=\"http://www.w3.org/2000/svg\" \n      fill=\"none\" \n      viewBox=\"0 0 24 24\" \n      stroke=\"currentColor\" \n      strokeWidth=\"2\"\n    >\n      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n    </svg>\n  );\n}\n"}}}
