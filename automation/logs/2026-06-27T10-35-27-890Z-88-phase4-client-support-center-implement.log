{"ts":"2026-06-27T10:27:39.184Z","type":"agent_event","event":{"type":"content_end","contentType":"reasoning","reasoning":"**Analyzing File Size Limits**\n\nI'm currently trying to understand why a recent operation failed due to a size limitation. Initially, I thought the file content was around 15,000 characters, but the error message mentions a much larger number. It seems the limit is around 6,000. I need to figure out what's going on, and I'm a bit confused.\n\n\n"}}
{"ts":"2026-06-27T10:27:39.187Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"xswdu8xi","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/support/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { \n  MessageSquare, Cpu, DollarSign, FileText, Key, Shield, HelpCircle, \n  Layers, Plus, Search, ArrowLeft, Clock, Lock, Terminal, Send, X, Sparkles, RefreshCw, ChevronDown\n} from \"lucide-react\";\nimport { previewProjects, previewSupportTickets, SupportTicket } from \"@/lib/mock-data-model\";\nimport { StatusBadge } from \"@/components/private-app\";\n\ninterface ClientSupportTicket extends SupportTicket {\n  category: \"Project Delivery\" | \"AI Operations\" | \"Billing\" | \"Documents\" | \"Access\" | \"Governance\" | \"General\";\n  projectId?: string;\n}\n\nconst CATEGORIES = [\"Project Delivery\", \"AI Operations\", \"Billing\", \"Documents\", \"Access\", \"Governance\", \"General\"] as const;\n\nexport default function ClientSupportPage() {\n  const [tickets, setTickets] = useState<ClientSupportTicket[]>([]);\n  const [selectedTicketId, setSelectedTicketId] = useState<string | null>(null);\n  const [replyText, setReplyText] = useState(\"\");\n  const [isReplying, setIsReplying] = useState(false);\n  const [showToast, setShowToast] = useState(false);\n  const [toastMsg, setToastMsg] = useState(\"\");\n\n  // Filters State\n  const [search, setSearch] = useState(\"\");\n  const [statusFilter, setStatusFilter] = useState(\"ALL\");\n  const [catFilter, setCatFilter] = useState(\"ALL\");\n  const [priFilter, setPriFilter] = useState(\"ALL\");\n  const [projFilter, setProjFilter] = useState(\"ALL\");\n\n  // Create Ticket Form State\n  const [subject, setSubject] = useState(\"\");\n  const [category, setCategory] = useState<ClientSupportTicket[\"category\"]>(\"AI Operations\");\n  const [priority, setPriority] = useState<ClientSupportTicket[\"priority\"]>(\"high\");\n  const [project, setProject] = useState(\"none\");\n  const [desc, setDesc] = useState(\"\");\n\n  const chatEndRef = useRef<HTMLDivElement>(null);\n\n  // Initialize and augment tickets safely\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const saved = localStorage.getItem(\"gff_support_tickets\");\n      if (saved) {\n        try { setTickets(JSON.parse(saved)); } catch (e) { resetToDefault(); }\n      } else { resetToDefault(); }\n    }\n  }, []);\n\n  const resetToDefault = () => {\n    const cats: ClientSupportTicket[\"category\"][] = [\"AI Operations\", \"AI Operations\", \"Governance\"];\n    const projs = [\"proj-001\", \"proj-002\", \"proj-001\"];\n    const augmented = previewSupportTickets.map((t, i) => ({\n      ...t,\n      category: cats[i] || \"General\",\n      projectId: projs[i]\n    })) as ClientSupportTicket[];\n    saveTickets(augmented);\n  };\n\n  useEffect(() => {\n    if (selectedTicketId) chatEndRef.current?.scrollIntoView({ behavior: \"smooth\" });\n  }, [selectedTicketId, tickets]);\n\n  const saveTickets = (updated: ClientSupportTicket[]) => {\n    setTickets(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_support_tickets\", JSON.stringify(updated));\n    }\n  };\n\n  const handleCreate = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!subject.trim() || !desc.trim()) return;\n\n    const newId = `SLA-TKT-${Math.floor(1000 + Math.random() * 9000)}`;\n    const newTkt: ClientSupportTicket = {\n      id: newId,\n      title: subject,\n      status: \"open\",\n      priority,\n      category,\n      projectId: project !== \"none\" ? project : undefined,\n      createdAt: new Date().toISOString(),\n      desc,\n      replies: []\n    };\n\n    saveTickets([newTkt, ...tickets]);\n    setToastMsg(`Ticket ${newId} initialized on secure network.`);\n    setShowToast(true);\n    setTimeout(() => setShowToast(false), 4000);\n\n    setSelectedTicketId(newId);\n    setSubject(\"\");\n    setDesc(\"\");\n    setProject(\"none\");\n  };\n\n  const handleSendReply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!replyText.trim() || !selectedTicketId) return;\n\n    const currentReply = replyText;\n    setReplyText(\"\");\n    setIsReplying(true);\n\n    const userReply = {\n      sender: \"Alexander Mercer (Client)\",\n      text: currentReply,\n      timestamp: new Date().toISOString()\n    };\n\n    const target = tickets.find(t => t.id === selectedTicketId);\n    if (!target) return;\n\n    const updatedReplies = [...(target.replies || []), userReply];\n    const updatedTickets = tickets.map(t => {\n      if (t.id === selectedTicketId) {\n        return { ...t, replies: updatedReplies, status: t.status === \"resolved\" ? \"in_progress\" : t.status };\n      }\n      return t;\n    }) as ClientSupportTicket[];\n\n    saveTickets(updatedTickets);\n\n    setTimeout(() => {\n      let botText = \"Handshake acknowledged. Our on-call systems engineers are reviewing your trace reports inside the secure sandbox.\";\n      let botSender = \"GFF Support Sentinel\";\n\n      if (target.category === \"AI Operations\") {\n        botSender = \"Dr. Sarah Vance (Lead Systems Architect)\";\n        botText = \"Analyzing enclave CPU and HSM logs. The cryptographic state is re-asserted and key rotational interlocks are operating nominally. All propagation latency is mitigated (<0.4ms).\";\n      } else if (target.category === \"Billing\") {\n        botSender = \"Nicolette Durand (Billing & Treasury)\";\n        botText = \"Invoices check completed. Invoice settlement is verified at blockchain epoch block 18290192 under seal 0xDE897FFA.\";\n      } else if (target.category === \"Governance\" || target.category === \"Documents\") {\n        botSender = \"Sovereign Audit Agent\";\n        botText = \"Operator credentials verified at Clearance Level IV. The NIST AI RMF logs are compiled successfully within SGX memory. Access credentials issued.\";\n      }\n\n      const botReply = { sender: botSender, text: botText, timestamp: new Date().toISOString() };\n      \n      saveTickets(updatedTickets.map(t => {\n        if (t.id === selectedTicketId) {\n          return { ...t, replies: [...updatedReplies, botReply], status: \"in_progress\" };\n        }\n        return t;\n      }) as ClientSupportTicket[]);\n      \n      setIsReplying(false);\n    }, 1500);\n  };\n\n  const filtered = tickets.filter(t => {\n    const q = search.toLowerCase();\n    const matchSearch = q === \"\" || t.id.toLowerCase().includes(q) || t.title.toLowerCase().includes(q) || t.desc.toLowerCase().includes(q);\n    const matchStatus = statusFilter === \"ALL\" || t.status === statusFilter;\n    const matchCat = catFilter === \"ALL\" || t.category === catFilter;\n    const matchPri = priFilter === \"ALL\" || t.priority === priFilter;\n    const matchProj = projFilter === \"ALL\" || t.projectId === projFilter;\n    return matchSearch && matchStatus && matchCat && matchPri && matchProj;\n  });\n\n  const activeTicket = tickets.find(t => t.id === selectedTicketId);\n\n  const getPriorityStyle = (p: string) => {\n    switch(p) {\n      case \"critical\": return \"bg-red-500/10 text-red-400 border-red-500/20\";\n      case \"high\": return \"bg-amber-500/10 text-amber-400 border-amber-500/20\";\n      case \"medium\": return \"bg-blue-500/10 text-blue-400 border-blue-500/20\";\n      default: return \"bg-white/5 text-white/50 border-white/10\";\n    }\n  };\n\n  const getCatIcon = (cat: string) => {\n    switch(cat) {\n      case \"Project Delivery\": return <Layers className=\"w-3.5 h-3.5\" />;\n      case \"AI Operations\": return <Cpu className=\"w-3.5 h-3.5\" />;\n      case \"Billing\": return <DollarSign className=\"w-3.5 h-3.5\" />;\n      case \"Documents\": return <FileText className=\"w-3.5 h-3.5\" />;\n      case \"Access\": return <Key className=\"w-3.5 h-3.5\" />;\n      case \"Governance\": return <Shield className=\"w-3.5 h-3.5\" />;\n      default: return <HelpCircle className=\"w-3.5 h-3.5\" />;\n    }\n  };\n\n  return (\n    <div className=\"space-y-6 max-w-[1600px] mx-auto pb-12 select-none\">\n      {/* Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4\">\n        <div>\n          <span className=\"text-[10px] font-mono font-bold tracking-widest text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded uppercase\">\n            SOVEREIGN SECURITY TUNNEL\n          </span>\n          <h2 className=\"text-2xl font-bold text-white tracking-tight font-mono uppercase mt-1\">Client Support Center</h2>\n          <p className=\"text-xs text-white/50 mt-1 max-w-xl\">\n            Isolated zero-trust communications wire. Exchange diagnostic telemetry and core credentials directly with on-call engineers.\n          </p>\n        </div>\n        {selectedTicketId && (\n          <button onClick={() => setSelectedTicketId(null)} className=\"h-9 px-4 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.01] text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center gap-2 cursor-pointer\">\n            <Plus className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>Launch New Wire</span>\n          </button>\n        )}\n      </div>\n\n      {/* Stats row */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 font-mono\">\n        {[\n          { label: \"Active Tunnels\", value: tickets.filter(t => t.status !== \"resolved\").length, desc: \"Pending resolution\" },\n          { label: \"SLA Response Target\", value: \"100%\", desc: \"< 15m compliance\" },\n          { label: \"Trust Clearance\", value: \"LEVEL IV\", desc: \"Hardware isolated\" },\n          { label: \"Archived Wires\", value: tickets.filter(t => t.status === \"resolved\").length, desc: \"Cryptographically sealed\" }\n        ].map((s, idx) => (\n          <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm\">\n            <span className=\"text-[9.5px] text-white/35 uppercase\">{s.label}</span>\n            <div className=\"text-xl font-bold text-white mt-1\">{s.value}</div>\n            <span className=\"text-[9px] text-white/20 block mt-1\">{s.desc}</span>\n          </div>\n        ))}\n      </div>\n\n      {/* Main workspace */}\n      <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-6 items-start\">\n        {/* Left Side: Tickets List */}\n        <div className={`space-y-4 ${selectedTicketId ? \"xl:col-span-5\" : \"xl:col-span-7\"}`}>\n          {/* Filters Bar */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm space-y-3 font-mono\">\n            <div className=\"relative\">\n              <Search className=\"absolute left-3 top-2.5 h-4 w-4 text-white/30\" />\n              <input\n                type=\"text\"\n                placeholder=\"Search secure tickets by subject, error hash...\"\n                value={search}\n                onChange={e => setSearch(e.target.value)}\n                className=\"w-full h-10 pl-9 pr-4 rounded-lg border border-white/10 bg-black/40 text-white text-[12px] outline-none focus:border-[#009DFF]/30\"\n              />\n            </div>\n            \n            <div className=\"grid grid-cols-2 md:grid-cols-4 gap-2 text-[9px]\">\n              {[\n                { label: \"Status\", val: statusFilter, set: setStatusFilter, opts: [{ v: \"ALL\", l: \"ALL STATUSES\" }, { v: \"open\", l: \"OPEN\" }, { v: \"in_progress\", l: \"IN PROGRESS\" }, { v: \"resolved\", l: \"RESOLVED\" }] },\n                { label: \"Category\", val: catFilter, set: setCatFilter, opts: [{ v: \"ALL\", l: \"ALL CATEGORIES\" }, ...CATEGORIES.map(c => ({ v: c, l: c.toUpperCase() }))] },\n                { label: \"Priority\", val: priFilter, set: setPriFilter, opts: [{ v: \"ALL\", l: \"ALL PRIORITIES\" }, { v: \"critical\", l: \"CRITICAL\" }, { v: \"high\", l: \"HIGH\" }, { v: \"medium\", l: \"MEDIUM\" }, { v: \"low\", l: \"LOW\" }] },\n                { label: \"Project\", val: projFilter, set: setProjFilter, opts: [{ v: \"ALL\", l: \"ALL PROJECTS\" }, ...previewProjects.map(p => ({ v: p.id, l: p.tag }))] }\n              ].map((f, i) => (\n                <div key={i}>\n                  <label className=\"text-white/35 block mb-1 uppercase font-bold\">{f.label}</label>\n                  <div className=\"relative\">\n                    <select\n                      value={f.val}\n                      onChange={e => f.set(e.target.value)}\n                      className=\"w-full h-8 px-2 pr-6 rounded border border-white/10 bg-black/60 text-white outline-none appearance-none cursor-pointer text-[10px]\"\n                    >\n                      {f.opts.map(o => <option key={o.v} value={o.v} className=\"bg-black text-white\">{o.l}</option>)}\n                    </select>\n                    <ChevronDown className=\"absolute right-2 top-2.5 h-3 w-3 text-white/30 pointer-events-none\" />\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          {/* Ticket list */}\n          <div className=\"space-y-3 max-h-[600px] overflow-y-auto pr-1\">\n            {filtered.length === 0 ? (\n              <div className=\"p-8 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-2 font-mono\">\n                <p className=\"text-xs text-white/30\">No active wires match filter parameters.</p>\n                <button onClick={() => { setSearch(\"\"); setStatusFilter(\"ALL\"); setCatFilter(\"ALL\"); setPriFilter(\"ALL\"); setProjFilter(\"ALL\"); }} className=\"text-[10px] text-[#009DFF] underline uppercase font-bold\">Reset filters</button>\n              </div>\n            ) : (\n              filtered.map(t => {\n                const isSelected = t.id === selectedTicketId;\n                const proj = previewProjects.find(p => p.id === t.projectId);\n                return (\n                  <div\n                    key={t.id}\n                    onClick={() => setSelectedTicketId(t.id)}\n                    className={`relative cursor-pointer rounded-xl border transition-all p-4 ${\n                      isSelected ? \"border-[#009DFF]/40 bg-[#009DFF]/5\" : \"border-white/5 bg-[#050505]/40 hover:border-white/10\"\n                    }`}\n                  >\n                    {isSelected && <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-[#009DFF] rounded-l-xl\" />}\n                    <div className=\"space-y-2 font-mono\">\n                      <div className=\"flex justify-between items-center text-[9px]\">\n                        <div className=\"flex items-center gap-1.5\">\n                          <span className={`px-1.5 py-0.5 rounded border font-bold text-[8px] uppercase ${getPriorityStyle(t.priority)}`}>\n                            {t.priority}\n                          </span>\n                          <span className=\"text-white/40 font-bold\">{t.id}</span>\n                        </div>\n                        <StatusBadge state={t.status === \"open\" ? \"active\" : t.status === \"in_progress\" ? \"warning\" : \"stable\"} label={t.status} />\n                      </div>\n                      <h4 className=\"text-[11.5px] font-bold text-white leading-snug\">{t.title}</h4>\n                      <div className=\"flex items-center gap-2 text-[9px] text-white/40 pt-1 border-t border-white/[0.03]\">\n                        <span className=\"flex items-center gap-1\">\n                          {getCatIcon(t.category)}\n                          <span className=\"uppercase text-[8px]\">{t.category}</span>\n                        </span>\n                        {proj && <span className=\"text-[#00FFC2] bg-[#00FFC2]/5 px-1 py-0.5 rounded text-[8px] font-bold\">PROJ: {proj.tag}</span>}\n                        <span className=\"text-white/20 ml-auto\">{new Date(t.createdAt).toLocaleDateString()}</span>\n                      </div>\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>\n        </div>\n\n        {/* Right Side: Form / Details */}\n        <div className={`xl:sticky xl:top-6 ${selectedTicketId ? \"xl:col-span-7\" : \"xl:col-span-5\"}`}>\n          {activeTicket ? (\n            /* Secure Coms Detail */\n            <div className=\"rounded-xl border border-white/10 bg-[#050505]/50 backdrop-blur-sm overflow-hidden flex flex-col h-[650px] font-mono\">\n              <div className=\"p-4 border-b border-white/5 bg-black/20 flex justify-between items-start\">\n                <div className=\"space-y-1\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <button onClick={() => setSelectedTicketId(null)} className=\"p-1 rounded hover:bg-white/5 border border-white/5 mr-1 text-white/40 hover:text-white\">\n                      <ArrowLeft className=\"w-3 h-3\" />\n                    </button>\n                    <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded font-bold uppercase\">SECURE WIRE</span>\n                    <span className=\"text-[9px] text-white/40 font-bold\">{activeTicket.id}</span>\n                  </div>\n                  <h3 className=\"text-[12px] font-bold text-white uppercase mt-1\">{activeTicket.title}</h3>\n                </div>\n                <button onClick={() => setSelectedTicketId(null)} className=\"p-1 text-white/40 hover:text-white\"><X className=\"w-4 h-4\" /></button>\n              </div>\n\n              <div className=\"flex-1 overflow-y-auto p-4 space-y-4\">\n                <div className=\"grid grid-cols-2 gap-2 text-[9px]\">\n                  <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8px]\">Enclave Attestation</span>\n                    <div className=\"flex items-center gap-1 text-emerald-400 font-bold mt-1\">\n                      <Lock className=\"w-3.5 h-3.5\" />\n                      <span>Intel SGX Signed</span>\n                    </div>\n                  </div>\n                  <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n                    <span className=\"text-white/30 font-bold block uppercase text-[8px]\">SLA Response Window</span>\n                    <div className=\"flex items-center gap-1 text-amber-400 font-bold mt-1\">\n                      <Clock className=\"w-3.5 h-3.5 animate-pulse\" />\n                      <span>{activeTicket.priority === \"critical\" ? \"P1 (15m window)\" : \"P2 (1h window)\"}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase\">Diagnostics Dump</span>\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-black/70 text-[10px] text-white/80 leading-relaxed max-h-[120px] overflow-y-auto select-text\">\n                    <div className=\"flex items-center gap-1 text-[#009DFF] border-b border-white/5 pb-1 mb-1.5\">\n                      <Terminal className=\"w-3 h-3\" />\n                      <span>LOCAL EXCEPTION TRACE</span>\n                    </div>\n                    {activeTicket.desc}\n                  </div>\n                </div>\n\n                {/* Replies Thread */}\n                <div className=\"space-y-3 pt-1\">\n                  <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase\">Handshake Logs</span>\n                  <div className=\"space-y-2.5\">\n                    <div className=\"p-2.5 rounded border border-white/5 bg-white/[0.01] text-[10px] space-y-1 max-w-[90%]\">\n                      <span className=\"text-[#00FFC2] font-bold\">SYSTEM INTEGRATOR</span>\n                      <p className=\"text-white/70 leading-normal\">Operational handshake validated. Route map deployed to core systems engineers.</p>\n                    </div>\n\n                    {activeTicket.replies?.map((r, i) => {\n                      const isClient = r.sender.includes(\"Client\");\n                      return (\n                        <div key={i} className={`p-3 rounded-xl border text-[10px] space-y-1 max-w-[90%] ${isClient ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right\" : \"border-emerald-500/10 bg-emerald-500/[0.02]\"}`}>\n                          <span className={`font-bold block ${isClient ? \"text-[#009DFF]\" : \"text-emerald-400\"}`}>{r.sender.toUpperCase()}</span>\n                          <p className=\"text-white/85 leading-relaxed select-text\">{r.text}</p>\n                        </div>\n                      );\n                    })}\n\n                    {isReplying && (\n                      <div className=\"p-2.5 rounded-lg border border-white/5 text-[9px] text-white/30 flex items-center gap-1.5 animate-pulse max-w-[80%]\">\n                        <RefreshCw className=\"w-3 h-3 animate-spin text-emerald-400\" />\n                        <span>Core system architect parsing telemetry...</span>\n                      </div>\n                    )}\n                    <div ref={chatEndRef} />\n                  </div>\n                </div>\n              </div>\n\n              {/* Message inputs */}\n              <div className=\"p-3 border-t border-white/5 bg-black/40\">\n                <form onSubmit={handleSendReply} className=\"relative\">\n                  <textarea\n                    required\n                    disabled={isReplying}\n                    placeholder=\"Type secured reply and press Send...\"\n                    value={replyText}\n                    onChange={e => setReplyText(e.target.value)}\n                    onKeyDown={e => { if (e.key === \"Enter\" && !e.shiftKey) { e.preventDefault(); handleSendReply(e); } }}\n                    className=\"w-full h-14 rounded-lg border border-white/10 bg-black/60 pl-3 pr-12 py-2.5 text-white text-[11px] outline-none resize-none leading-relaxed\"\n                  />\n                  <button type=\"submit\" disabled={!replyText.trim() || isReplying} className=\"absolute right-2 bottom-3 p-1.5 rounded-md bg-white text-black hover:bg-white/90 disabled:opacity-25 disabled:bg-white cursor-pointer\"><Send className=\"w-3 h-3\" /></button>\n                </form>\n              </div>\n            </div>\n          ) : (\n            /* Create Support Ticket Form */\n            <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n                <MessageSquare className=\"w-4 h-4 text-[#009DFF]\" />\n                <div>\n                  <h3 className=\"text-[12px] font-bold text-white uppercase\">Initialize Support Wire</h3>\n                  <p className=\"text-[9px] text-white/40 mt-0.5\">Route real-time diagnostics securely to systems triage.</p>\n                </div>\n              </div>\n\n              <form onSubmit={handleCreate} className=\"space-y-3.5 text-[10px]\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-white/40 uppercase font-bold block\">Summary Subject</label>\n                  <input\n                    required\n                    placeholder=\"Briefly describe system issue (e.g., Replication Latency)...\"\n                    value={subject}\n                    onChange={e => setSubject(e.target.value)}\n                    className=\"w-full h-9 rounded-lg border border-white/10 bg-black/40 px-3 text-white text-[11px] outline-none focus:border-[#009DFF]/30\"\n                  />\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-3\">\n                  <div className=\"space-y-1\">\n                    <label className=\"text-white/40 uppercase font-bold block\">Category</label>\n                    <select\n                      value={category}\n                      onChange={e => setCategory(e.target.value as any)}\n                      className=\"w-full h-9 rounded-lg border border-white/10 bg-black/40 px-2 text-white outline-none cursor-pointer text-[10px]\"\n                    >\n                      {CATEGORIES.map(c => <option key={c} value={c} className=\"bg-black text-white\">{c.toUpperCase()}</option>)}\n                    </select>\n                  </div>\n\n                  <div className=\"space-y-1\">\n                    <label className=\"text-white/40 uppercase font-bold block\">Priority SLA</label>\n                    <select\n                      value={priority}\n                      onChange={e => setPriority(e.target.value as any)}\n                      className=\"w-full h-9 rounded-lg border border-white/10 bg-black/40 px-2 text-white outline-none cursor-pointer font-bold text-[10px]\"\n                    >\n                      <option value=\"critical\" className=\"bg-black text-red-400\">CRITICAL (15m response)</option>\n                      <option value=\"high\" className=\"bg-black text-amber-400\">HIGH (1h response)</option>\n                      <option value=\"medium\" className=\"bg-black text-blue-400\">MEDIUM (4h response)</option>\n                      <option value=\"low\" className=\"bg-black text-white/50\">LOW (12h response)</option>\n                    </select>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-white/40 uppercase font-bold block\">Linked Sandbox Project</label>\n                  <select\n                    value={project}\n                    onChange={e => setProject(e.target.value)}\n                    className=\"w-full h-9 rounded-lg border border-white/10 bg-black/40 px-2 text-white outline-none cursor-pointer text-[10px]\"\n                  >\n                    <option value=\"none\" className=\"bg-black text-white/40\">NO ATTACHED ARCHITECTURE (GENERAL)</option>\n                    {previewProjects.map(p => <option key={p.id} value={p.id} className=\"bg-black text-white\">{p.name.toUpperCase()} ({p.tag})</option>)}\n                  </select>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <label className=\"text-white/40 uppercase font-bold block\">Telemetry Logs / Details</label>\n                  <textarea\n                    required\n                    placeholder=\"Provide error exceptions, node configurations, CPU metrics or specific sandbox anomalies...\"\n                    value={desc}\n                    onChange={e => setDesc(e.target.value)}\n                    className=\"w-full h-24 rounded-lg border border-white/10 bg-black/40 p-3 text-white text-[11px] outline-none resize-none leading-relaxed\"\n                  />\n                </div>\n\n                <button type=\"submit\" className=\"w-full h-10 rounded-lg bg-white hover:bg-white/90 text-black font-bold uppercase transition-all cursor-pointer flex items-center justify-center gap-1.5 select-none text-[10px]\">\n                  <span>Submit Sovereign Wire</span>\n                </button>\n              </form>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {showToast && (\n        <div className=\"fixed bottom-6 right-6 p-4 rounded-xl border border-emerald-500/20 bg-black/90 backdrop-blur-sm text-white font-mono text-[10.5px] shadow-[0_0_20px_rgba(16,185,129,0.15)] flex items-center gap-2 z-50\">\n          <Sparkles className=\"w-4.5 h-4.5 text-emerald-400 animate-pulse\" />\n          <span>{toastMsg}</span>\n        </div>\n      )}\n    </div>\n  );\n}\n"}}}
