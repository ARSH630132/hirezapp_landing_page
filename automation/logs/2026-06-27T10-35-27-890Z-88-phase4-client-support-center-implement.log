{"ts":"2026-06-27T10:32:04.314Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"kkzmfoz1","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/support/[id]/page.tsx","old_text":"        <div id=\"detail-chat-block\" className=\"lg:col-span-2\">CHAT BLOCK</div>","new_text":"        <div className=\"lg:col-span-2 space-y-4\">\n          <div className=\"p-4 rounded-xl border border-white/10 bg-[#050505]/40 backdrop-blur-sm space-y-4 flex flex-col h-[600px] justify-between\">\n            \n            <div className=\"flex-1 overflow-y-auto space-y-4 pr-1 scrollbar-thin\">\n              {/* original description */}\n              <div className=\"p-3 rounded-lg border border-white/5 bg-black/70 text-[10.5px] text-white/80 leading-relaxed\">\n                <div className=\"flex items-center gap-1.5 text-[#009DFF] border-b border-white/5 pb-1 mb-2 font-bold uppercase text-[9px]\">\n                  <Terminal className=\"w-3.5 h-3.5\" />\n                  <span>Diagnostics Trace Log</span>\n                </div>\n                <p className=\"whitespace-pre-wrap select-text\">{activeTicket?.desc}</p>\n              </div>\n\n              {/* Handshake logs */}\n              <span className=\"text-[8px] font-bold tracking-wider text-white/30 block uppercase\">Log handshakes</span>\n              \n              <div className=\"space-y-2.5\">\n                <div className=\"p-2.5 rounded border border-white/5 bg-white/[0.01] text-[10px] space-y-1 max-w-[90%]\">\n                  <span className=\"text-[#00FFC2] font-bold uppercase text-[9px]\">SYSTEM INITIALIZATION</span>\n                  <p className=\"text-white/70 leading-normal\">Operational tunnel secured. Initial telemetry packet dispatch success.</p>\n                </div>\n\n                {activeTicket?.replies?.map((reply, idx) => {\n                  const isClient = reply.sender.includes(\"Client\") || reply.sender.includes(\"Mercer\");\n                  return (\n                    <div \n                      key={idx} \n                      className={`p-3 rounded-xl border text-[10px] space-y-1 max-w-[90%] ${\n                        isClient \n                          ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right\" \n                          : \"border-emerald-500/10 bg-emerald-500/[0.02]\"\n                      }`}\n                    >\n                      <span className={`font-bold block ${isClient ? \"text-[#009DFF]\" : \"text-emerald-400\"}`}>\n                        {reply.sender.toUpperCase()}\n                      </span>\n                      <p className=\"text-white/85 leading-relaxed select-text\">{reply.text}</p>\n                    </div>\n                  );\n                })}\n\n                {isReplying && (\n                  <div className=\"p-2.5 rounded-lg border border-white/5 text-[9px] text-white/30 flex items-center gap-1.5 animate-pulse max-w-[80%]\">\n                    <RefreshCw className=\"w-3 h-3 animate-spin text-emerald-400\" />\n                    <span>Systems architect decoding signal...</span>\n                  </div>\n                )}\n                <div ref={chatEndRef} />\n              </div>\n            </div>\n\n            {/* Chat Input */}\n            <div className=\"border-t border-white/5 pt-3\">\n              <form onSubmit={handleSendReply} className=\"relative\">\n                <textarea\n                  required\n                  disabled={isReplying}\n                  placeholder=\"Compose secured response...\"\n                  value={replyText}\n                  onChange={e => setReplyText(e.target.value)}\n                  onKeyDown={e => { if (e.key === \"Enter\" && !e.shiftKey) { e.preventDefault(); handleSendReply(e); } }}\n                  className=\"w-full h-14 rounded-lg border border-white/10 bg-black/60 pl-3 pr-12 py-2.5 text-white text-[11px] outline-none resize-none leading-relaxed\"\n                />\n                <button \n                  type=\"submit\" \n                  disabled={!replyText.trim() || isReplying}\n                  className=\"absolute right-2 bottom-3 p-1.5 rounded-md bg-white text-black hover:bg-white/90 disabled:opacity-25 cursor-pointer\"\n                >\n                  <Send className=\"w-3.5 h-3.5\" />\n                </button>\n              </form>\n            </div>\n          </div>\n        </div>"}}}
