{"ts":"2026-06-27T16:04:11.913Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"8hvxx5h3","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","old_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { BarChart3, RefreshCw, Cpu, Activity } from \"lucide-react\";\n\nexport default function ClientAnalyticsPage() {\n  const [dataPoints, setDataPoints] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      setDataPoints(prev => {\n        const nextVal = Math.min(100, Math.max(20, prev[prev.length - 1] + (Math.floor(Math.random() * 14) - 7)));\n        return [...prev.slice(1), nextVal];\n      });\n    }, 1500);\n    return () => clearInterval(interval);\n  }, []);\n\n  return (\n    <div className=\"space-y-6\">\n      <div>\n        <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n        <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <Activity className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Enclave CPU Load Stream</h3>\n            </div>\n            <span className=\"text-[9px] font-mono text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-0.5 rounded-full uppercase tracking-wider animate-pulse\">\n              LIVE BROADCAST\n            </span>\n          </div>\n\n          <div className=\"h-32 flex items-end justify-between gap-1 bg-black/40 border border-white/5 rounded-xl p-4 relative\">\n            {/* SVG graph line */}\n            <svg className=\"absolute inset-x-0 bottom-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path\n                d={`M ${dataPoints.map((val, idx) => `${idx * 55}, ${112 - (val * 0.9)}`).join(\" L \")}`}\n                fill=\"none\"\n                stroke=\"#009DFF\"\n                strokeWidth=\"2.5\"\n                className=\"transition-all duration-500 ease-in-out\"\n              />\n              <circle\n                cx=\"500\"\n                cy={112 - (dataPoints[dataPoints.length - 1] * 0.9)}\n                r=\"4\"\n                className=\"fill-[#009DFF]\"\n              />\n            </svg>\n            <div className=\"absolute top-3 left-3 text-[10px] font-mono text-white/20 select-none\">\n              Mean Sandbox CPU: {dataPoints[dataPoints.length - 1]}%\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n            <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Network Latencies</h3>\n          </div>\n          \n          <div className=\"space-y-2 font-mono text-[11px] text-white/60\">\n            {[\n              { hash: \"f3a8b291c9\", label: \"Singapore Zone A\", ping: \"4ms\" },\n              { hash: \"e88d123880\", label: \"London Zone C\", ping: \"3ms\" },\n              { hash: \"a01fe99211\", label: \"Local Enclave Mesh\", ping: \"5ms\" }\n            ].map((node) => (\n              <div key={node.hash} className=\"flex justify-between border-b border-white/5 pb-2 last:border-b-0 last:pb-0\">\n                <div>\n                  <span className=\"text-white block font-bold\">{node.label}</span>\n                  <span className=\"text-[9px] text-[#009DFF]/60 block\">{node.hash}</span>\n                </div>\n                <span className=\"text-emerald-400 font-bold text-xs\">{node.ping}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { RefreshCw, Cpu, Activity, AlertCircle, Shield, Briefcase, FileText, Server } from \"lucide-react\";\n\nexport default function ClientAnalyticsPage() {\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [data, setData] = useState<any>(null);\n  const [pts, setPts] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n  const [isRef, setIsRef] = useState(false);\n\n  const fetchAnalytics = useCallback(async (silent = false) => {\n    if (!silent) setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) throw new Error(\"Credentials missing. Please log in first.\");\n      const res = await fetch(\"/api/v1/analytics/client\", {\n        headers: { \"Authorization\": `Bearer ${token}` }\n      });\n      if (!res.ok) throw new Error(`Telemetry fetch failed (Status ${res.status})`);\n      const json = await res.json();\n      if (json.success) setData(json);\n      else throw new Error(json.message);\n    } catch (err: any) {\n      setError(err.message || \"Connection failed.\");\n    } finally {\n      setLoading(false);\n      setIsRef(false);\n    }\n  }, []);\n\n  useEffect(() => { fetchAnalytics(); }, [fetchAnalytics]);\n\n  useEffect(() => {\n    const inv = setInterval(() => {\n      setPts(p => [...p.slice(1), Math.min(100, Math.max(20, p[p.length-1] + Math.floor(Math.random()*14)-7))]);\n    }, 1500);\n    return () => clearInterval(inv);\n  }, []);\n\n  if (loading) return (\n    <div className=\"space-y-6 font-mono animate-pulse\">\n      <div className=\"h-10 bg-white/5 rounded w-1/3\" />\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[1,2,3,4].map(i => <div key={i} className=\"h-20 bg-white/5 rounded-xl\" />)}\n      </div>\n      <div className=\"h-44 bg-white/5 rounded-xl\" />\n    </div>\n  );\n\n  if (error) return (\n    <div className=\"p-8 border border-red-500/10 bg-red-500/[0.02] text-center space-y-4 font-mono rounded-xl max-w-md mx-auto\">\n      <AlertCircle className=\"w-8 h-8 text-red-500 mx-auto animate-pulse\" />\n      <p className=\"text-xs text-white/70\">{error}</p>\n      <button onClick={() => fetchAnalytics()} className=\"px-4 py-1.5 rounded bg-red-500/10 border border-red-500/20 text-xs text-red-400\">Retry Connection</button>\n    </div>\n  );\n\n  const s = data?.summary;\n  if (!s) return (\n    <div className=\"p-8 border border-white/5 bg-[#050505]/40 text-center space-y-4 font-mono max-w-xl mx-auto rounded-xl\">\n      <Briefcase className=\"w-8 h-8 text-white/20 mx-auto\" />\n      <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">No Telemetry Recorded</h3>\n      <p className=\"text-xs text-white/40 leading-relaxed\">No active sandboxes or sovereign clusters are registered for your account.</p>\n      <button onClick={() => fetchAnalytics()} className=\"px-4 py-1.5 rounded bg-white/5 hover:bg-white/10 text-[10px] text-white border border-white/10 uppercase cursor-pointer\">Refresh</button>\n    </div>\n  );\n\n  return (\n    <div className=\"space-y-6 font-mono\">\n      <div className=\"flex justify-between items-center\">\n        <div>\n          <h2 className=\"text-lg font-bold text-white uppercase tracking-tight\">Telemetry Analytics</h2>\n          <p className=\"text-[11px] text-white/50\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        <button onClick={() => { setIsRef(true); fetchAnalytics(true); }} className=\"flex items-center gap-1.5 px-2.5 py-1 rounded border border-white/10 bg-white/5 hover:bg-white/10 text-xs text-white cursor-pointer\">\n          <RefreshCw className={`w-3 h-3 ${isRef ? \"animate-spin text-[#009DFF]\" : \"\"}`} />\n          <span>Sync</span>\n        </button>\n      </div>\n\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Sovereign Enclaves\", val: s.projects?.totalCount, badge: \"ACTIVE\", detail: Object.entries(s.projects?.byPhase || {}).map(([ph, c]) => `${ph}: ${c}`).join(\" • \"), icon: Server },\n          { label: \"Running AI Ops\", val: s.aiOperations?.totalCount, badge: \"STREAMING\", detail: `Health: ${s.aiOperations?.byHealth?.healthy || s.aiOperations?.totalCount} Healthy`, icon: Activity },\n          { label: \"Governance Health\", val: s.governance?.totalCount, badge: \"SECURE\", detail: `Compliant: ${s.governance?.byStatus?.compliant || s.governance?.byStatus?.active || s.governance?.byStatus?.resolved || 0}`, icon: Shield },\n          { label: \"Financials & Audit\", val: s.invoices?.totalCount, badge: \"INVOICES\", detail: `Paid: ${s.invoices?.byStatus?.paid || 0} • Unpaid: ${s.invoices?.byStatus?.unpaid || 0}`, icon: FileText },\n        ].map((item, idx) => (\n          <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between hover:border-[#009DFF]/20 transition-all duration-300\">\n            <div className=\"flex justify-between items-center text-[9px] text-white/40 uppercase\">\n              <span>{item.label}</span>\n              <item.icon className=\"w-3.5 h-3.5 text-[#009DFF]/70\" />\n            </div>\n            <div className=\"mt-2 flex items-baseline gap-1.5\">\n              <span className=\"text-xl font-bold text-white\">{item.val || 0}</span>\n              <span className=\"text-[8px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1 py-0.2 rounded\">{item.badge}</span>\n            </div>\n            <div className=\"mt-2 text-[9px] text-white/45 truncate\">{item.detail}</div>\n          </div>\n        ))}\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n            <span className=\"text-xs font-bold text-white uppercase flex items-center gap-1.5\"><Activity className=\"w-4 h-4 text-[#009DFF]\" /> Enclave CPU Load Stream</span>\n            <span className=\"text-[9px] text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-0.5 rounded-full animate-pulse\">LIVE</span>\n          </div>\n          <div className=\"h-32 flex items-end justify-between bg-black/40 border border-white/5 rounded-xl p-4 relative overflow-hidden\">\n            <svg className=\"absolute inset-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path d={`M ${pts.map((val, idx) => `${idx * 55}, ${112 - (val * 0.9)}`).join(\" L \")}`} fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"2\" className=\"transition-all duration-500 ease-in-out\" />\n            </svg>\n            <div className=\"absolute top-3 left-3 text-[9px] text-white/30\">Mean Sandbox CPU: {pts[pts.length - 1]}%</div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n            <Cpu className=\"w-4 h-4 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white uppercase\">Network Latencies</h3>\n          </div>\n          <div className=\"space-y-2 text-[10px] text-white/60\">\n            {[\n              { hash: \"f3a8b291c9\", label: \"Singapore Zone A\", ping: \"4ms\" },\n              { hash: \"e88d123880\", label: \"London Zone C\", ping: \"3ms\" },\n              { hash: \"a01fe99211\", label: \"Local Enclave Mesh\", ping: \"5ms\" }\n            ].map((node) => (\n              <div key={node.hash} className=\"flex justify-between border-b border-white/5 pb-1.5 last:border-b-0 last:pb-0\">\n                <div>\n                  <span className=\"text-white block font-bold\">{node.label}</span>\n                  <span className=\"text-[8px] text-[#009DFF]/60 block\">{node.hash}</span>\n                </div>\n                <span className=\"text-emerald-400 font-bold text-xs\">{node.ping}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
