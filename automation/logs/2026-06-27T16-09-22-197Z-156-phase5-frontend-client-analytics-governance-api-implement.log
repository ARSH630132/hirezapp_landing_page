hash: \"0x3FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89FBC10492\",\n      uploadedAt: \"2026-06-01\",\n      category: \"governance\",\n      clearanceLevel: \"LEVEL_IV\"\n    }\n  ]);","new_text":"  const [policies, setPolicies] = useState<PolicyItem[]>([]);\n  const [oversights, setOversights] = useState<OversightItem[]>([]);\n  const [documents, setDocuments] = useState<DocItem[]>([]);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n\n  const fetchGovernanceAndDocs = useCallback(async (silent = false) => {\n    if (!silent) setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) throw new Error(\"Credentials missing. Please log in first.\");\n\n      const [govRes, docRes] = await Promise.all([\n        fetch(\"/api/v1/governance\", { headers: { \"Authorization\": `Bearer ${token}` } }),\n        fetch(\"/api/v1/documents\", { headers: { \"Authorization\": `Bearer ${token}` } })\n      ]);\n\n      if (!govRes.ok) throw new Error(`Governance lookup failed: Status ${govRes.status}`);\n      if (!docRes.ok) throw new Error(`Document verification failed: Status ${docRes.status}`);\n\n      const govData = await govRes.json();\n      const docData = await docRes.json();\n\n      if (govData.success && docData.success) {\n        const rawGov = govData.governance || [];\n        \n        const mappedPols = rawGov.map((item: any) => {\n          let fStatus: \"compliant\" | \"warning\" | \"critical\" = \"compliant\";\n          const s = (item.status || \"\").toLowerCase();\n          const sev = (item.severity || \"\").toLowerCase();\n          if ([\"under review\", \"flagged\", \"active\", \"warning\"].includes(s)) {\n            fStatus = [\"critical\", \"high\"].includes(sev) ? \"critical\" : \"warning\";\n          }\n          return {\n            id: item.id,\n            name: item.title,\n            standard: (item.standard || \"ISO-27001\") as any,\n            status: fStatus,\n            severity: ([\"critical\", \"high\"].includes(sev) ? \"high\" : sev === \"medium\" ? \"medium\" : \"low\") as any,\n            projectId: item.project_id || \"proj-001\",\n            projectName: item.project_name || \"Sovereign Core Sandbox 02\",\n            agentId: item.nodeId || \"agent-001\",\n            agentName: item.nodeId || \"RETAIL-CORE-A1\",\n            desc: item.description,\n            lastChecked: item.lastUpdated ? new Date(item.lastUpdated).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : \"11:00 AM\",\n            logs: item.logs || []\n          };\n        });\n\n        const mappedOversights = rawGov.map((item: any) => {\n          let fStatus: \"pending\" | \"approved\" | \"rejected\" = \"pending\";\n          const s = (item.status || \"\").toLowerCase();\n          if ([\"compliant\", \"completed\", \"remediated\", \"suppressed\", \"approved\"].includes(s)) fStatus = \"approved\";\n          else if (s === \"rejected\") fStatus = \"rejected\";\n\n          return {\n            id: item.id,\n            title: item.title,\n            project: item.project_name || \"Sovereign Core Sandbox 02\",\n            projectId: item.project_id || \"proj-001\",\n            agent: item.nodeId || \"RETAIL-CORE-A1\",\n            agentId: item.nodeId || \"agent-001\",\n            requester: item.owner || \"System\",\n            status: fStatus,\n            severity: ([\"critical\", \"high\"].includes(item.severity?.toLowerCase()) ? \"high\" : item.severity?.toLowerCase() === \"medium\" ? \"medium\" : \"low\") as any,\n            requestDate: item.lastUpdated || new Date().toISOString(),\n            category: (item.standard === \"ISO-27001\" ? \"Access Elevation\" : item.standard === \"HIPAA\" ? \"HSM Seal Rollover\" : \"Model Boundary Shift\") as any,\n            desc: item.description\n          };\n        });\n\n        const mappedDocs = (docData.documents || []).map((doc: any) => ({\n          id: doc.id,\n          name: doc.title,\n          size: doc.size || \"1.2 MB\",\n          format: (doc.type?.toLowerCase().includes(\"pdf\") ? \"PDF\" : doc.type?.toLowerCase().includes(\"yaml\") ? \"YAML\" : \"CSV\") as any,\n          projectId: doc.project_id || \"proj-001\",\n          projectName: doc.project_name || \"Sovereign Core Sandbox 02\",\n          agentId: \"agent-001\",\n          agentName: \"RETAIL-CORE-A1\",\n          status: ([\"compliant\", \"approved\", \"active\"].includes(doc.status) ? \"compliant\" : \"warning\") as any,\n          hash: doc.hash || \"0x8FDE3102C130D7B2D26788AB0E8\",\n          uploadedAt: doc.created_at ? doc.created_at.split('T')[0] : \"2026-06-27\",\n          category: \"audit\" as any,\n          clearanceLevel: \"LEVEL_III\"\n        }));\n\n        setPolicies(mappedPols);\n        setOversights(mappedOversights);\n        setDocuments(mappedDocs);\n      } else {\n        throw new Error(govData.message || docData.message || \"Failed to load data.\");\n      }\n    } catch (err: any) {\n      setError(err.message || \"Unable to sync with compliance ledger.\");\n    } finally {\n      setLoading(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchGovernanceAndDocs();\n  }, [fetchGovernanceAndDocs]);"}}}
