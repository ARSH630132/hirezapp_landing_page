order border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n427 |             <style dangerouslySetInnerHTML={{ __html: `\n428 |               @keyframes flow { to { stroke-dashoffset: -20; } }\n429 |               .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n430 |             `}} />\n431 | \n432 |             <div className=\"flex-grow flex flex-col justify-between gap-4\">\n433 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n434 |                 <div className=\"flex items-center gap-1.5 font-mono text-[11px]\">\n435 |                   <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n436 |                   <span className=\"font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n437 |                 </div>\n438 |                 <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology</span>\n439 |               </div>\n440 | \n441 |               <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n442 |                 <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n443 |                   <svg className=\"w-full h-[2px] overflow-visible\">\n444 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n445 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n446 |                   </svg>\n447 |                 </div>\n448 | \n449 |                 {steps.map((st, idx) => {\n450 |                   const isActive = step === st.id;\n451 |                   const clr = \n452 |                     st.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n453 |                     st.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n454 |                     st.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n455 |                     st.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" : \"border-emerald-500/10 text-emerald-400\";\n456 |                   \n457 |                   const activeStyle = isActive \n458 |                     ? \"shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102\" \n459 |                     : \"bg-black/45 hover:border-white/10\";\n460 | \n461 |                   return (\n462 |                     <button \n463 |                       key={st.id} \n464 |                       onClick={() => setStep(st.id)}\n465 |                       className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${clr} ${activeStyle}`}\n466 |                     >\n467 |                       <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"}`}>\n468 |                         {st.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n469 |                         {st.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n470 |                         {st.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n471 |                         {st.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n472 |                         {st.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n473 |                       </div>\n474 |                       <div className=\"text-center font-mono select-none\">\n475 |                         <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n476 |                         <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">{st.id === \"step-1\" ? \"Ingress\" : st.id === \"step-2\" ? \"Guardrail\" : st.id === \"step-3\" ? \"Enclave\" : st.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}</span>\n477 |                       </div>\n478 |                     </button>\n479 |                   );\n480 |                 })}\n481 |               </div>\n482 |             </div>\n483 | \n484 |             {/* Node Telemetry Details card */}\n485 |             <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n486 |               {(() => {\n487 |                 const info = steps.find(s => s.id === step) || steps[0];\n488 |                 return (\n489 |                   <div className=\"space-y-3 h-full flex flex-col justify-between\">\n490 |                     <div className=\"space-y-1.5\">\n491 |                       <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">REALTIME METRICS</span>\n492 |                       <p className=\"text-white font-bold text-[11px] leading-tight\">{info.title}</p>\n493 |                       \n494 |                       <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n495 |                         <span className={`w-1 h-1 rounded-full ${step === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n496 |                         <span className=\"text-white/40\">Status:</span>\n497 |                         <span className={`font-bold ${step === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>{info.val}</span>\n498 |                       </div>\n499 |                       <p className=\"text-[10px] text-white/50 leading-normal pt-1\">{info.desc}</p>\n500 |                     </div>\n501 |                     \n502 |                     <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 select-none\">\n503 |                       <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n504 |                       <span>Mathematical boundary verified</span>\n505 |                     </div>\n506 |                   </div>\n507 |                 );\n508 |               })()}\n509 |             </div>\n510 | \n511 |           </div>\n512 |         </div>\n513 | \n514 |       </div>\n515 | \n516 |       {/* Dynamic Filters panel */}\n517 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#070707]/60 backdrop-blur-sm space-y-3 font-mono\">\n518 |         <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n519 |           <div className=\"flex items-center gap-1.5\">\n520 |             <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/50\" />\n521 |             <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Workspace Filters</h3>\n522 |           </div>\n523 |           {(selProj || selAgent || selStatus || selSeverity || search) && (\n524 |             <button onClick={resetAll} className=\"flex items-center gap-1 text-[10px] text-amber-500 hover:text-amber-400 cursor-pointer\">\n525 |               <RotateCcw className=\"w-3 h-3\" /> Reset Filters\n526 |             </button>\n527 |           )}\n528 |         </div>\n529 | \n530 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n531 |           \n532 |           <div>\n533 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Project Target</label>\n534 |             <select \n535 |               value={selProj} \n536 |               onChange={(e) => { setSelProj(e.target.value); triggerToast(\"Filter: Project target updated\", \"info\"); }}\n537 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n538 |             >\n539 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/4