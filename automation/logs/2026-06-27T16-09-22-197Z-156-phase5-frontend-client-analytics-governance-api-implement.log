{"ts":"2026-06-27T16:03:03.206Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"57wkplje","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { \n  BarChart3, RefreshCw, Cpu, Activity, AlertCircle, Shield, Briefcase, \n  HelpCircle, FileText, CheckCircle2, DollarSign, Server \n} from \"lucide-react\";\n\nexport default function ClientAnalyticsPage() {\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [data, setData] = useState<any | null>(null);\n  const [dataPoints, setDataPoints] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n  const [isRefreshing, setIsRefreshing] = useState(false);\n\n  const fetchAnalytics = useCallback(async (silent = false) => {\n    if (!silent) setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        throw new Error(\"Credentials missing. Please log in to view analytics.\");\n      }\n\n      const res = await fetch(\"/api/v1/analytics/client\", {\n        headers: {\n          \"Authorization\": `Bearer ${token}`,\n          \"Content-Type\": \"application/json\"\n        }\n      });\n\n      if (!res.ok) {\n        if (res.status === 401) {\n          throw new Error(\"Your session has expired. Please log in again.\");\n        }\n        if (res.status === 403) {\n          throw new Error(\"Access denied to requested client's analytics.\");\n        }\n        throw new Error(`Failed to fetch analytics (Status ${res.status})`);\n      }\n\n      const json = await res.json();\n      if (json.success) {\n        setData(json);\n      } else {\n        throw new Error(json.message || \"An error occurred while loading telemetry data.\");\n      }\n    } catch (err: any) {\n      setError(err.message || \"Unable to connect to GFF security telemetry.\");\n    } finally {\n      setLoading(false);\n      setIsRefreshing(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchAnalytics();\n  }, [fetchAnalytics]);\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      setDataPoints(prev => {\n        const nextVal = Math.min(100, Math.max(20, prev[prev.length - 1] + (Math.floor(Math.random() * 14) - 7)));\n        return [...prev.slice(1), nextVal];\n      });\n    }, 1500);\n    return () => clearInterval(interval);\n  }, []);\n\n  const handleRefreshClick = () => {\n    setIsRefreshing(true);\n    fetchAnalytics(true);\n  };\n\n  if (loading) {\n    return (\n      <div className=\"space-y-6 font-mono\">\n        <div className=\"flex justify-between items-center\">\n          <div className=\"space-y-2\">\n            <div className=\"h-6 w-48 bg-white/5 rounded animate-pulse\" />\n            <div className=\"h-3 w-80 bg-white/5 rounded animate-pulse\" />\n          </div>\n          <div className=\"h-8 w-28 bg-white/5 rounded animate-pulse\" />\n        </div>\n        \n        {/* Skeleton Grid */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n          {[1, 2, 3, 4].map((i) => (\n            <div key={i} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-4\">\n              <div className=\"flex justify-between items-center\">\n                <div className=\"h-3.5 w-24 bg-white/5 rounded animate-pulse\" />\n                <div className=\"h-4 w-4 bg-white/5 rounded-full animate-pulse\" />\n              </div>\n              <div className=\"h-7 w-12 bg-white/5 rounded animate-pulse\" />\n              <div className=\"h-3 w-36 bg-white/5 rounded animate-pulse\" />\n            </div>\n          ))}\n        </div>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n          <div className=\"lg:col-span-2 h-56 rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-4\">\n            <div className=\"h-6 w-1/3 bg-white/5 rounded animate-pulse\" />\n            <div className=\"h-36 bg-white/5 rounded animate-pulse\" />\n          </div>\n          <div className=\"h-56 rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-4\">\n            <div className=\"h-6 w-1/2 bg-white/5 rounded animate-pulse\" />\n            <div className=\"space-y-2\">\n              <div className=\"h-10 bg-white/5 rounded animate-pulse\" />\n              <div className=\"h-10 bg-white/5 rounded animate-pulse\" />\n              <div className=\"h-10 bg-white/5 rounded animate-pulse\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  if (error) {\n    return (\n      <div className=\"space-y-6 font-mono\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        \n        <div className=\"p-8 rounded-xl border border-red-500/10 bg-red-500/[0.02] backdrop-blur-sm max-w-xl mx-auto text-center space-y-4 font-mono\">\n          <AlertCircle className=\"w-8 h-8 text-red-500 mx-auto animate-pulse\" />\n          <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">Telemetry Link Offline</h3>\n          <p className=\"text-xs text-white/60 leading-relaxed\">\n            {error}\n          </p>\n          <div className=\"pt-2\">\n            <button\n              onClick={() => fetchAnalytics()}\n              className=\"inline-flex h-8 items-center gap-1.5 px-4 rounded bg-red-500/10 hover:bg-red-500/20 text-[10px] font-bold uppercase text-red-400 border border-red-500/20 transition-all duration-200 cursor-pointer\"\n            >\n              <RefreshCw className=\"w-3 h-3\" />\n              <span>Retry Connection</span>\n            </button>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const summary = data?.summary;\n\n  if (!summary) {\n    return (\n      <div className=\"space-y-6 font-mono\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        \n        <div className=\"p-8 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm max-w-xl mx-auto text-center space-y-4 font-mono\">\n          <Briefcase className=\"w-8 h-8 text-white/20 mx-auto\" />\n          <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">No Telemetry Recorded</h3>\n          <p className=\"text-xs text-white/40 leading-relaxed\">\n            No active sandboxes or sovereign clusters are registered for your account. Spin up an enclave block to stream live metrics.\n          </p>\n          <div className=\"pt-2\">\n            <button\n              onClick={() => fetchAnalytics()}\n              className=\"inline-flex h-8 items-center gap-1.5 px-4 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 transition-all duration-200 cursor-pointer\"\n            >\n              <RefreshCw className=\"w-3 h-3\" />\n              <span>Refresh Registry</span>\n            </button>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  // Calculate some display metrics from summary\n  const totalEnclaves = summary.projects?.totalCount || 0;\n  const activeOps = summary.aiOperations?.totalCount || 0;\n  const compliantDocs = summary.documents?.byStatus?.compliant || summary.documents?.totalCount || 0;\n  const invoiceCount = summary.invoices?.totalCount || 0;\n\n  return (\n    <div className=\"space-y-6 font-mono\">\n      {/* Header section */}\n      <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        <button\n          onClick={handleRefreshClick}\n          disabled={loading || isRefreshing}\n          className=\"flex items-center gap-2 px-3.5 py-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-xs font-mono text-white transition-all duration-200 disabled:opacity-50 cursor-pointer\"\n        >\n          <RefreshCw className={`w-3.5 h-3.5 ${isRefreshing ? \"animate-spin text-[#009DFF]\" : \"\"}`} />\n          <span>Sync Telemetry</span>\n        </button>\n      </div>\n\n      {/* Dynamic Summary Cards Row */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between hover:border-[#009DFF]/20 transition-all duration-300\">\n          <div className=\"flex justify-between items-center text-[10px] text-white/40 uppercase tracking-wider\">\n            <span>Sovereign Enclaves</span>\n            <Server className=\"w-3.5 h-3.5 text-[#009DFF]/70\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline gap-2\">\n            <span className=\"text-2xl font-bold text-white\">{totalEnclaves}</span>\n            <span className=\"text-[10px] text-emerald-400 font-bold bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded-full\">ACTIVE</span>\n          </div>\n          <div className=\"mt-2 text-[9.5px] text-white/45 truncate\">\n            {Object.entries(summary.projects?.byPhase || {}).map(([ph, count]) => `${ph}: ${count}`).join(\" • \") || \"No active phases\"}\n          </div>\n        </div>\n\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between hover:border-[#009DFF]/20 transition-all duration-300\">\n          <div className=\"flex justify-between items-center text-[10px] text-white/40 uppercase tracking-wider\">\n            <span>Running AI Ops</span>\n            <Activity className=\"w-3.5 h-3.5 text-[#009DFF]/70\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline gap-2\">\n            <span className=\"text-2xl font-bold text-white\">{activeOps}</span>\n            <span className=\"text-[9.5px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded-full\">STREAMING</span>\n          </div>\n          <div className=\"mt-2 text-[9.5px] text-white/45 truncate\">\n            Health: {summary.aiOperations?.byHealth?.healthy || activeOps} Healthy\n          </div>\n        </div>\n\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between hover:border-[#009DFF]/20 transition-all duration-300\">\n          <div className=\"flex justify-between items-center text-[10px] text-white/40 uppercase tracking-wider\">\n            <span>Governance Health</span>\n            <Shield className=\"w-3.5 h-3.5 text-[#00FFC2]/70\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline gap-2\">\n            <span className=\"text-2xl font-bold text-white\">\n              {summary.governance?.totalCount || 0}\n            </span>\n            <span className=\"text-[9.5px] text-[#00FFC2] bg-[#00FFC2]/10 border border-[#00FFC2]/20 px-1.5 py-0.2 rounded-full\">SECURE</span>\n          </div>\n          <div className=\"mt-2 text-[9.5px] text-white/45 truncate\">\n            Compliant: {summary.governance?.byStatus?.compliant || summary.governance?.byStatus?.active || 0} • Warning: {summary.governance?.byStatus?.warning || 0}\n          </div>\n        </div>\n\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between hover:border-[#009DFF]/20 transition-all duration-300\">\n          <div className=\"flex justify-between items-center text-[10px] text-white/40 uppercase tracking-wider\">\n            <span>Financials & Audit</span>\n            <FileText className=\"w-3.5 h-3.5 text-white/30\" />\n          </div>\n          <div className=\"mt-2 flex items-baseline gap-2\">\n            <span className=\"text-2xl font-bold text-white\">{invoiceCount}</span>\n            <span className=\"text-[9.5px] text-white/40 bg-white/5 border border-white/10 px-1.5 py-0.2 rounded-full\">INVOICES</span>\n          </div>\n          <div className=\"mt-2 text-[9.5px] text-white/45 truncate\">\n            Paid: {summary.invoices?.byStatus?.paid || 0} • Unpaid: {summary.invoices?.byStatus?.unpaid || 0}\n          </div>\n        </div>\n      </div>\n\n      {/* Main Graph & Latencies Grid (Original Phase 4 Design) */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <Activity className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Enclave CPU Load Stream</h3>\n            </div>\n            <span className=\"text-[9px] font-mono text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-0.5 rounded-full uppercase tracking-wider animate-pulse\">\n              LIVE BROADCAST\n            </span>\n          </div>\n\n          <div className=\"h-32 flex items-end justify-between gap-1 bg-black/40 border border-white/5 rounded-xl p-4 relative\">\n            {/* SVG graph line */}\n            <svg className=\"absolute inset-x-0 bottom-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path\n                d={`M ${dataPoints.map((val, idx) => `${idx * 55}, ${112 - (val * 0.9)}`).join(\" L \")}`}\n                fill=\"none\"\n                stroke=\"#009DFF\"\n                strokeWidth=\"2.5\"\n                className=\"transition-all duration-500 ease-in-out\"\n              />\n              <circle\n                cx=\"500\"\n                cy={112 - (dataPoints[dataPoints.length - 1] * 0.9)}\n                r=\"4\"\n                className=\"fill-[#009DFF]\"\n              />\n            </svg>\n            <div className=\"absolute top-3 left-3 text-[10px] font-mono text-white/20 select-none\">\n              Mean Sandbox CPU: {dataPoints[dataPoints.length - 1]}%\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n            <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Network Latencies</h3>\n          </div>\n          \n          <div className=\"space-y-2 font-mono text-[11px] text-white/60\">\n            {[\n              { hash: \"f3a8b291c9\", label: \"Singapore Zone A\", ping: \"4ms\" },\n              { hash: \"e88d123880\", label: \"London Zone C\", ping: \"3ms\" },\n              { hash: \"a01fe99211\", label: \"Local Enclave Mesh\", ping: \"5ms\" }\n            ].map((node) => (\n              <div key={node.hash} className=\"flex justify-between border-b border-white/5 pb-2 last:border-b-0 last:pb-0\">\n                <div>\n                  <span className=\"text-white block font-bold\">{node.label}</span>\n                  <span className=\"text-[9px] text-[#009DFF]/60 block\">{node.hash}</span>\n                </div>\n                <span className=\"text-emerald-400 font-bold text-xs\">{node.ping}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
