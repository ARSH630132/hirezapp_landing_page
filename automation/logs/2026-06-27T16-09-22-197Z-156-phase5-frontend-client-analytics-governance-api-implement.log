{"ts":"2026-06-27T16:00:30.286Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"vot6wrwk","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/dashboard/page.tsx:50-115","result":" 50 | \n 51 | export default function ClientDashboardPage() {\n 52 |   const [dashboardData, setDashboardData] = useState<any | null>(null);\n 53 |   const [loading, setLoading] = useState(true);\n 54 | \n 55 |   useEffect(() => {\n 56 |     let isSubscribed = true;\n 57 | \n 58 |     const fetchDashboard = async () => {\n 59 |       try {\n 60 |         const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n 61 |         if (!token) {\n 62 |           if (isSubscribed) {\n 63 |             setLoading(false);\n 64 |           }\n 65 |           return;\n 66 |         }\n 67 | \n 68 |         const res = await fetch(\"/api/v1/dashboard/client\", {\n 69 |           headers: {\n 70 |             \"Authorization\": `Bearer ${token}`,\n 71 |             \"Content-Type\": \"application/json\"\n 72 |           }\n 73 |         });\n 74 | \n 75 |         if (res.ok) {\n 76 |           const data = await res.json();\n 77 |           if (isSubscribed && data.success) {\n 78 |             setDashboardData(data);\n 79 |           }\n 80 |         }\n 81 |       } catch (err) {\n 82 |         console.error(\"Error fetching client dashboard API:\", err);\n 83 |       } finally {\n 84 |         if (isSubscribed) {\n 85 |           setLoading(false);\n 86 |         }\n 87 |       }\n 88 |     };\n 89 | \n 90 |     fetchDashboard();\n 91 | \n 92 |     return () => {\n 93 |       isSubscribed = false;\n 94 |     };\n 95 |   }, []);\n 96 |   // Map metrics based on dynamic backend data or fall back to original Phase 4 mock analytics\n 97 |   const metrics = dashboardData?.summary ? [\n 98 |     {\n 99 |       id: \"metric-projects\",\n100 |       name: \"Active Sandbox Enclaves\",\n101 |       value: `${dashboardData.summary.projects.activeCount} / ${dashboardData.summary.projects.totalCount}`,\n102 |       delta: `${dashboardData.summary.projects.activeCount >= 0 ? \"+\" : \"\"}${dashboardData.summary.projects.activeCount} Online`,\n103 |       direction: \"up\" as const,\n104 |       status: \"normal\" as const,\n105 |       sparkPoints: [32, 35, 38, 42, 45, 48, 52, 55, 58, 62, 65, 68]\n106 |     },\n107 |     {\n108 |       id: \"metric-ops\",\n109 |       name: \"Running AI Operations\",\n110 |       value: `${dashboardData.summary.aiOperations.activeCount} / ${dashboardData.summary.aiOperations.totalCount}`,\n111 |       delta: \"Stable\",\n112 |       direction: \"neutral\" as const,\n113 |       status: \"stable\" as const,\n114 |       sparkPoints: [18, 17, 18, 17, 19, 18, 19, 20, 19, 21, 20, 20]\n115 |     },","success":true}],"durationMs":8}}
