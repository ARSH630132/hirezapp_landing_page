e=\"bg-[#0c0c0c] text-red-400\">CRITICAL FAULT</option>\n567 |             </select>\n568 |           </div>\n569 | \n570 |           <div>\n571 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Risk Severity</label>\n572 |             <select \n573 |               value={selSeverity} \n574 |               onChange={(e) => { setSelSeverity(e.target.value); triggerToast(\"Filter: Severity updated\", \"info\"); }}\n575 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n576 |             >\n577 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL SEVERITIES</option>\n578 |               <option value=\"high\" className=\"bg-[#0c0c0c] text-red-400 font-bold\">HIGH RISK</option>\n579 |               <option value=\"medium\" className=\"bg-[#0c0c0c] text-amber-400\">MEDIUM RISK</option>\n580 |               <option value=\"low\" className=\"bg-[#0c0c0c] text-blue-400\">LOW RISK</option>\n581 |             </select>\n582 |           </div>\n583 | \n584 |           <div>\n585 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Log Search</label>\n586 |             <div className=\"relative\">\n587 |               <Search className=\"absolute left-2 top-2.5 w-3.5 h-3.5 text-white/35 font-mono\" />\n588 |               <input \n589 |                 type=\"text\" \n590 |                 value={search} \n591 |                 onChange={(e) => setSearch(e.target.value)}\n592 |                 placeholder=\"Search rule standard or ID...\"\n593 |                 className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] pl-7.5 pr-7 text-[10.5px] text-white outline-none focus:border-white/10\"\n594 |               />\n595 |               {search && <X className=\"absolute right-2 top-2.5 w-3.5 h-3.5 text-white/40 cursor-pointer font-mono\" onClick={() => setSearch(\"\")} />}\n596 |             </div>\n597 |           </div>\n598 | \n599 |         </div>\n600 |       </div>\n601 | \n602 |       {/* Tabs list */}\n603 |       <div className=\"space-y-4 font-mono\">\n604 |         <div className=\"flex border-b border-white/5 gap-6 select-none text-xs\">\n605 |           <button onClick={() => setTab(\"pols\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"pols\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n606 |             <span>AI Checks & Policies</span>\n607 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredPols.length}</span>\n608 |             {tab === \"pols\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n609 |           </button>\n610 |           \n611 |           <button onClick={() => setTab(\"oversight\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"oversight\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n612 |             <span>Human Oversight Interlocks</span>\n613 |             <span className={`px-1 rounded text-[9px] ${pendingCount > 0 ? \"bg-amber-400/10 text-amber-500\" : \"bg-white/5 text-white/50\"}`}>{filteredOversights.length}</span>\n614 |             {tab === \"oversight\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n615 |           </button>\n616 | \n617 |           <button onClick={() => setTab(\"docs\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"docs\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n618 |             <span>Document Ledger</span>\n619 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredDocs.length}</span>\n620 |             {tab === \"docs\" && <span cl