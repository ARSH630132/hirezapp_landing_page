st typeFilter = searchParams.get(\"type\");\n44 |     const searchQuery = searchParams.get(\"search\");\n45 | \n46 |     let documents = Object.values(API_MOCK_DOCUMENTS) as ApiDocumentItem[];\n47 | \n48 |     // RBAC policy logic\n49 |     if (caller.role !== \"gff_admin\") {\n50 |       const callerClientId = getClientIdFromAssociation(caller.clientAssociation);\n51 |       documents = documents.filter(d => d.client_id === callerClientId);\n52 | \n53 |       // Enforce client boundaries\n54 |       if (clientIdFilter && clientIdFilter !== callerClientId) {\n55 |         return NextResponse.json(\n56 |           { success: false, error: \"Forbidden\", message: \"Access denied to requested client's documents.\" },\n57 |           { status: 403 }\n58 |         );\n59 |       }\n60 |     } else {\n61 |       // Admin filter\n62 |       if (clientIdFilter) {\n63 |         documents = documents.filter(d => d.client_id === clientIdFilter);\n64 |       }\n65 |     }\n66 | \n67 |     // Apply specific filters\n68 |     if (statusFilter) {\n69 |       const q = statusFilter.toLowerCase().trim();\n70 |       documents = documents.filter(d => d.status.toLowerCase().includes(q));\n71 |     }\n72 |     if (typeFilter) {\n73 |       const q = typeFilter.toLowerCase().trim();\n74 |       documents = documents.filter(d => d.type.toLowerCase().includes(q));\n75 |     }\n76 |     if (searchQuery) {\n77 |       const q = searchQuery.toLowerCase().trim();\n78 |       documents = documents.filter(d => \n79 |         d.title.toLowerCase().includes(q) || \n80 |         d.description.toLowerCase().includes(q) || \n81 |         d.owner.toLowerCase().includes(q) ||\n82 |         d.id.toLowerCase().includes(q)\n83 |       );\n84 |     }\n85 | \n86 |     return NextResponse.json({ success: true, documents });\n87 |   } catch (err) {\n88 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n89 |   }\n90 | }","success":true}],"durationMs":2}}
