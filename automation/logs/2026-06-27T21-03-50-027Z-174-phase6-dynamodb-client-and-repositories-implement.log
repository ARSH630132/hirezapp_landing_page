_vals.get(\":sk\") or expr_vals.get(\":sk_prefix\")\n                if sk_prefix:\n                    sk_f = \"SK\" if pk_f == \"PK\" else \"GSI1SK\"\n                    if not str(item.get(sk_f, \"\")).startswith(str(sk_prefix)):\n                        keep = False\n            if keep:\n                res.append(item)\n        return {\"Items\": res, \"Count\": len(res)}"}}}
