"\n                if \"GSI1\" in kwargs.get(\"IndexName\", \"\") or \"GSI1PK\" in key_expr:\n                    target_pk_field = \"GSI1PK\"\n                \n                pk_val = expr_vals.get(\":pk\") or expr_vals.get(\":gsi1pk\")\n                if not pk_val:\n                    for placeholder, val in expr_vals.items():\n                        if placeholder in key_expr:\n                            pk_val = val\n                            break\n                \n                if pk_val and item.get(target_pk_field) != pk_val:\n                    keep = False\n                \n                sk_prefix = expr_vals.get(\":sk\") or expr_vals.get(\":sk_prefix\")\n                if not sk_prefix:\n                    for placeholder, val in expr_vals.items():\n                        if \"begins_with\" in key_expr and placeholder in key_expr and placeholder not in (\":pk\", \":gsi1pk\"):\n                            sk_prefix = val\n                            break\n                \n                if sk_prefix:\n                    target_sk_field = \"SK\" if target_pk_field == \"PK\" else \"GSI1SK\"\n                    if not str(item.get(target_sk_field, \"\")).startswith(str(sk_prefix)):\n                        keep = False\n            \n            if keep:\n                filtered_items.append(item)\n                \n        return {\"Items\": filtered_items, \"Count\": len(filtered_items)}\n\nclass DynamoDBClientManager:\n    def __init__(self):\n        self.use_mock = True\n        self.dynamodb = None\n        try:\n            if settings.ENVIRONMENT == \"production\":\n                self.dynamodb = boto3.resource(\n                    \"dynamodb\",\n                    region_name=settings.AWS_REGION,\n                    aws_access_key_id=settings.AWS_ACCESS_KEY_ID,\n                    aws_secret_access_key=settings.AWS_SECRET_ACCESS_KEY,\n                )\n                self.dynamodb.meta.client.list_tables()\n                self.use_mock = False\n            else:\n                self.use_mock = True\n        except Exception as e:\n            self.use_mock = True\n\n    def get_table(self, table_name):\n        if self.use_mock:\n            pks = [\"email\"]\n            if table_name == settings.DYNAMODB_CLIENTS_TABLE:\n                pks = [\"client_id\"]\n            elif table_name == settings.DYNAMODB_ITEMS_TABLE:\n                pks = [\"PK\", \"SK\"]\n            return MockTable(table_name, pks)\n        return self.dynamodb.Table(table_name)\n\ndb_manager = DynamoDBClientManager()\n\ndef seed_mock_database():\n    # Seeding Clients\n    MOCK_DB[settings.DYNAMODB_CLIENTS_TABLE] = [\n        {\"client_id\": \"1\", \"name\": \"Apex Global\", \"industry\": \"Financial Services\", \"region\": \"North America\", \"status\": \"active\", \"account_owner\": \"GFF Partner Team\"},\n        {\"client_id\": \"2\", \"name\": \"Nova Energy\", \"industry\": \"Energy\", \"region\": \"Europe\", \"status\": \"active\", \"account_owner\": \"GFF Partner Team\"},\n        {\"client_id\": \"3\", \"name\": \"Orion Tech\", \"industry\": \"Technology\", \"region\": \"Asia-Pacific\", \"status\": \"active\", \"account_owner\": \"GFF Partner Team\"},\n        {\"client_id\": \"4\", \"name\": \"Chevron Corporation\", \"industry\": \"Energy\", \"region\": \"North America\", \"status\": \"active\", \"account_owner\": \"GFF Partner Team\"}\n    ]\n\n    # Seeding Users\n    pwd_hash = hash_password(\"password123\")\n    MOCK_DB[settings.DYNAMODB_USERS_TABLE] = [\n        {\"email\": \"gff_admin@gff.ai\", \"hashed_password\": pwd_hash, \"full_name\": \"GFF Admin Lead\", \"role\": \"gff_admin\", \"client_id\": None, \"is_active\": True},\n        {\"email\": \"client_admin@apex.com\", \"hashed_password\": pwd_hash, \"full_name\": \"Apex Admin Lead\", \"role\": \"client_admin\", \"client_id\": \"1\", \"is_active\": True},\n        {\"email\": \"client_member@apex.com\", \"hashed_password\": pwd_hash, \"full_name\": \"Apex Analyst\", \"role\": \"client_member\", \"client_id\": \"1\", \"is_active\": True},\n        {\"email\": \"admin@gff.ai\", \"hashed_password\": hash_password(\"gff_enterprise_admin_pass_2026\"), \"full_name\": \"GFF Executive Admin\", \"role\": \"admin\", \"client_id\": None, \"is_active\": True},\n        {\"email\": \"client@chevron.com\", \"hashed_password\": hash_password(\"chevron_secure_pass_2026\"), \"full_name\": \"Chevron Operations Lead\", \"role\": \"client\", \"client_id\": \"4\", \"is_active\": True}\n    ]\n\n    # Seeding Items (PROJECT, AI_OPERATION, DOCUMENT, INVOICE, SUPPORT, GOVERNANCE)\n    MOCK_DB[settings.DYNAMODB_ITEMS_TABLE] = [\n        # PROJECTS\n        {\"PK\": \"CLIENT#1\", \"SK\": \"PROJ#1\", \"GSI1PK\": \"PROJ#1\", \"GSI1SK\": \"METADATA\", \"id\": 1, \"client_id\": \"1\", \"name\": \"Project Sovereign\", \"phase\": \"Phase 1: Foundation\", \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 35, \"description\": \"Deploying enterprise sovereign AI foundation.\", \"entity_type\": \"PROJECT\"},\n        {\"PK\": \"CLIENT#1\", \"SK\": \"PROJ#2\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"METADATA\", \"id\": 2, \"client_id\": \"1\", \"name\": \"Automated Tax Intelligence\", \"phase\": \"Phase 3: Integration\", \"status\": \"active\", \"health\": \"amber\", \"owner\": \"GFF Lead\", \"progress\": 75, \"description\": \"Integrating tax reporting agent nodes with internal ERP.\", \"entity_type\": \"PROJECT\"},\n        {\"PK\": \"CLIENT#2\", \"SK\": \"PROJ#3\", \"GSI1PK\": \"PROJ#3\", \"GSI1SK\": \"METADATA\", \"id\": 3, \"client_id\": \"2\", \"name\": \"Omesh Predictive Operations\", \"phase\": \"Phase 2: Core Deployment\", \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 55, \"description\": \"Deploying autonomous agent meshes on energy infrastructure.\", \"entity_type\": \"PROJECT\"},\n        {\"PK\": \"CLIENT#3\", \"SK\": \"PROJ#4\", \"GSI1PK\": \"PROJ#4\", \"GSI1SK\": \"METADATA\", \"id\": 4, \"client_id\": \"3\", \"name\": \"Orion Agent Orchestrator\", \"phase\": \"Phase 4: Optimization\", \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 90, \"description\": \"Constructing the next-gen developer platform agent hub.\", \"entity_type\": \"PROJECT\"},\n        # AI_OPERATIONS\n        {\"PK\": \"CLIENT#1\", \"SK\": \"AIOPS#1\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"AIOPS#1\", \"id\": 1, \"client_id\": \"1\", \"project_id\": 2, \"name\": \"TaxComplianceAgent\", \"agent_type\": \"Compliance & Regulatory Audit\", \"status\": \"active\", \"health\": \"healthy\", \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"},\n        {\"PK\": \"CLIENT#1\", \"SK\": \"AIOPS#2\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"AIOPS#2\", \"id\": 2, \"client_id\": \"1\", \"project_id\": 2, \"name\": \"LedgerIngestionAgent\", \"agent_type\": \"Data Processing & Validation\", \"status\": \"active\", \"health\": \"healthy\", \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"},\n        {\"PK\": \"CLIENT#2\", \"SK\": \"AIOPS#3\", \"GSI1PK\": \"PROJ#3\", \"GSI1SK\": \"AIOPS#3\", \"id\": 3, \"client_id\": \"2\", \"project_id\": 3, \"name\": \"PipelineAnomalyDetector\", \"agent_type\": \"Anomaly Detection & Vision\", \"status\": \"active\", \"health\": \"healthy\", \"owner\": \"system\", \"governance_status\": \"warning\", \"entity_type\": \"AI_OPERATION\"},\n        {\"PK\": \"CLIENT#3\", \"SK\": \"AIOPS#4\", \"GSI1PK\": \"PROJ#4\", \"GSI1SK\": \"AIOPS#4\", \"id\": 4, \"client_id\": \"3\", \"project_id\": 4, \"name\": \"DeveloperCopilotAgent\", \"agent_type\": \"Code Synthesis & QA Test\", \"status\": \"active\", \"health\": \"healthy\", \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"},\n        # DOCUMENTS\n        {\"PK\": \"CLIENT#1\", \"SK\": \"DOC#1\", \"GSI1PK\": \"PROJ#