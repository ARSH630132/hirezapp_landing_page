{"ts":"2026-06-27T20:54:32.697Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ld9be3s6","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/app/repositories/dynamodb_client.py","new_text":"import os\nimport datetime\nimport logging\nimport boto3\nfrom botocore.exceptions import ClientError\nfrom ..core.config import settings\nfrom ..core.security import hash_password\n\nlogger = logging.getLogger(__name__)\n\n# Mock database store\nMOCK_DB = {\n    settings.DYNAMODB_USERS_TABLE: [],\n    settings.DYNAMODB_CLIENTS_TABLE: [],\n    settings.DYNAMODB_ITEMS_TABLE: []\n}\n\nclass MockTable:\n    def __init__(self, table_name, pk_fields):\n        self.table_name = table_name\n        self.pk_fields = pk_fields\n\n    def put_item(self, Item):\n        # Remove any existing item with the same PK/SK\n        self.delete_item(Key={k: Item[k] for k in self.pk_fields if k in Item})\n        MOCK_DB[self.table_name].append(Item)\n        return {\"ResponseMetadata\": {\"HTTPStatusCode\": 200}}\n\n    def get_item(self, Key):\n        for item in MOCK_DB[self.table_name]:\n            if all(item.get(k) == Key[k] for k in self.pk_fields):\n                return {\"Item\": item}\n        return {}\n\n    def delete_item(self, Key):\n        MOCK_DB[self.table_name] = [\n            item for item in MOCK_DB[self.table_name]\n            if not all(item.get(k) == Key[k] for k in self.pk_fields)\n        ]\n        return {\"ResponseMetadata\": {\"HTTPStatusCode\": 200}}\n\n    def scan(self, **kwargs):\n        items = MOCK_DB[self.table_name]\n        return {\"Items\": items, \"Count\": len(items)}\n\n    def query(self, **kwargs):\n        items = MOCK_DB[self.table_name]\n        \n        expr_vals = kwargs.get(\"ExpressionAttributeValues\", {})\n        key_expr = kwargs.get(\"KeyConditionExpression\", \"\")\n        \n        filtered_items = []\n        for item in items:\n            keep = True\n            if key_expr:\n                # Basic KeyConditionExpression check (e.g. \"PK = :pk AND begins_with(SK, :sk)\")\n                # If checking GSI1PK, update accordingly\n                target_pk_field = \"PK\"\n                if \"GSI1\" in kwargs.get(\"IndexName\", \"\") or \"GSI1PK\" in key_expr:\n                    target_pk_field = \"GSI1PK\"\n                \n                # Try finding value for the PK\n                pk_val = expr_vals.get(\":pk\") or expr_vals.get(\":gsi1pk\")\n                if not pk_val:\n                    # Generic lookup from expression values\n                    for placeholder, val in expr_vals.items():\n                        if placeholder in key_expr:\n                            pk_val = val\n                            break\n                \n                # Check PK\n                if pk_val and item.get(target_pk_field) != pk_val:\n                    keep = False\n                \n                # Check SK begins_with if applicable\n                sk_prefix = expr_vals.get(\":sk\") or expr_vals.get(\":sk_prefix\")\n                if not sk_prefix:\n                    # Look for other placeholders in begins_with\n                    for placeholder, val in expr_vals.items():\n                        if f\"begins_with\" in key_expr and placeholder in key_expr and placeholder != \":pk\" and placeholder != \":gsi1pk\":\n                            sk_prefix = val\n                            break\n                \n                if sk_prefix:\n                    target_sk_field = \"SK\" if target_pk_field == \"PK\" else \"GSI1SK\"\n                    if not str(item.get(target_sk_field, \"\")).startswith(str(sk_prefix)):\n                        keep = False\n            \n            if keep:\n                filtered_items.append(item)\n                \n        return {\"Items\": filtered_items, \"Count\": len(filtered_items)}\n\nclass DynamoDBClientManager:\n    def __init__(self):\n        self.use_mock = True\n        self.dynamodb = None\n        \n        try:\n            # Check if environment is production or testing with live AWS configured\n            if settings.ENVIRONMENT == \"production\":\n                self.dynamodb = boto3.resource(\n                    \"dynamodb\",\n                    region_name=settings.AWS_REGION,\n                    aws_access_key_id=settings.AWS_ACCESS_KEY_ID,\n                    aws_secret_access_key=settings.AWS_SECRET_ACCESS_KEY,\n                )\n                self.dynamodb.meta.client.list_tables()\n                self.use_mock = False\n                logger.info(\"Successfully connected to live AWS DynamoDB.\")\n            else:\n                self.use_mock = True\n                logger.info(\"Using DynamoDB Mock fallback for local development.\")\n        except Exception as e:\n            self.use_mock = True\n            logger.info(f\"DynamoDB connection failed. Falling back to local mock. Details: {e}\")\n\n    def get_table(self, table_name):\n        if self.use_mock:\n            pks = [\"email\"]\n            if table_name == settings.DYNAMODB_CLIENTS_TABLE:\n                pks = [\"client_id\"]\n            elif table_name == settings.DYNAMODB_ITEMS_TABLE:\n                pks = [\"PK\", \"SK\"]\n            return MockTable(table_name, pks)\n        return self.dynamodb.Table(table_name)\n\ndb_manager = DynamoDBClientManager()\n\ndef seed_mock_database():\n    \"\"\"Seed the local in-memory Mock DynamoDB with initial data matching requirements.\"\"\"\n    logger.info(\"Seeding Mock DynamoDB...\")\n    \n    # 1. Clients Table Seeding\n    clients_data = [\n        {\"client_id\": \"1\", \"name\": \"Apex Global\", \"industry\": \"Financial Services\", \"region\": \"North America\", \"status\": \"active\", \"account_owner\": \"GFF Partner Team\", \"created_at\": \"2026-01-10T12:00:00.000Z\"},\n        {\"client_id\": \"2\", \"name\": \"Nova Energy\", \"industr