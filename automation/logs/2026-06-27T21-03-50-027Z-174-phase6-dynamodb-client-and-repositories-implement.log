assword(\"gff_enterprise_admin_pass_2026\"),\n            \"full_name\": \"GFF Executive Admin\",\n            \"name\": \"GFF Executive Admin\",\n            \"role\": \"admin\",\n            \"client_id\": None,\n            \"is_active\": True,\n            \"created_at\": \"2026-01-01T00:00:00.000Z\"\n        },\n        {\n            \"email\": \"client@chevron.com\",\n            \"hashed_password\": hash_password(\"chevron_secure_pass_2026\"),\n            \"full_name\": \"Chevron Operations Lead\",\n            \"name\": \"Chevron Operations Lead\",\n            \"role\": \"client\",\n            \"client_id\": \"4\",\n            \"is_active\": True,\n            \"created_at\": \"2026-02-20T14:45:00.000Z\"\n        }\n    ]\n    MOCK_DB[settings.DYNAMODB_USERS_TABLE] = users_data\n\n    # 3. Portal Items Table Seeding\n    items = []\n    \n    # PROJECT seeding\n    projects = [\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"PROJ#1\", \"GSI1PK\": \"PROJ#1\", \"GSI1SK\": \"METADATA\",\n            \"id\": 1, \"client_id\": \"1\", \"name\": \"Project Sovereign\", \"phase\": \"Phase 1: Foundation\",\n            \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 35,\n            \"description\": \"Deploying enterprise sovereign AI foundation.\", \"entity_type\": \"PROJECT\"\n        },\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"PROJ#2\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"METADATA\",\n            \"id\": 2, \"client_id\": \"1\", \"name\": \"Automated Tax Intelligence\", \"phase\": \"Phase 3: Integration\",\n            \"status\": \"active\", \"health\": \"amber\", \"owner\": \"GFF Lead\", \"progress\": 75,\n            \"description\": \"Integrating tax reporting agent nodes with internal ERP.\", \"entity_type\": \"PROJECT\"\n        },\n        {\n            \"PK\": \"CLIENT#2\", \"SK\": \"PROJ#3\", \"GSI1PK\": \"PROJ#3\", \"GSI1SK\": \"METADATA\",\n            \"id\": 3, \"client_id\": \"2\", \"name\": \"Omesh Predictive Operations\", \"phase\": \"Phase 2: Core Deployment\",\n            \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 55,\n            \"description\": \"Deploying autonomous agent meshes on energy infrastructure.\", \"entity_type\": \"PROJECT\"\n        },\n        {\n            \"PK\": \"CLIENT#3\", \"SK\": \"PROJ#4\", \"GSI1PK\": \"PROJ#4\", \"GSI1SK\": \"METADATA\",\n            \"id\": 4, \"client_id\": \"3\", \"name\": \"Orion Agent Orchestrator\", \"phase\": \"Phase 4: Optimization\",\n            \"status\": \"active\", \"health\": \"green\", \"owner\": \"GFF Lead\", \"progress\": 90,\n            \"description\": \"Constructing the next-gen developer platform agent hub.\", \"entity_type\": \"PROJECT\"\n        }\n    ]\n    items.extend(projects)\n\n    # AI_OPERATION seeding\n    ai_ops = [\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"AIOPS#1\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"AIOPS#1\",\n            \"id\": 1, \"client_id\": \"1\", \"project_id\": 2, \"name\": \"TaxComplianceAgent\",\n            \"agent_type\": \"Compliance & Regulatory Audit\", \"status\": \"active\", \"health\": \"healthy\",\n            \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"\n        },\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"AIOPS#2\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"AIOPS#2\",\n            \"id\": 2, \"client_id\": \"1\", \"project_id\": 2, \"name\": \"LedgerIngestionAgent\",\n            \"agent_type\": \"Data Processing & Validation\", \"status\": \"active\", \"health\": \"healthy\",\n            \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"\n        },\n        {\n            \"PK\": \"CLIENT#2\", \"SK\": \"AIOPS#3\", \"GSI1PK\": \"PROJ#3\", \"GSI1SK\": \"AIOPS#3\",\n            \"id\": 3, \"client_id\": \"2\", \"project_id\": 3, \"name\": \"PipelineAnomalyDetector\",\n            \"agent_type\": \"Anomaly Detection & Vision\", \"status\": \"active\", \"health\": \"healthy\",\n            \"owner\": \"system\", \"governance_status\": \"warning\", \"entity_type\": \"AI_OPERATION\"\n        },\n        {\n            \"PK\": \"CLIENT#3\", \"SK\": \"AIOPS#4\", \"GSI1PK\": \"PROJ#4\", \"GSI1SK\": \"AIOPS#4\",\n            \"id\": 4, \"client_id\": \"3\", \"project_id\": 4, \"name\": \"DeveloperCopilotAgent\",\n            \"agent_type\": \"Code Synthesis & QA Test\", \"status\": \"active\", \"health\": \"healthy\",\n            \"owner\": \"system\", \"governance_status\": \"compliant\", \"entity_type\": \"AI_OPERATION\"\n        }\n    ]\n    items.extend(ai_ops)\n\n    # DOCUMENT seeding\n    docs = [\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"DOC#1\", \"GSI1PK\": \"PROJ#1\", \"GSI1SK\": \"DOC#1\",\n            \"id\": 1, \"client_id\": \"1\", \"project_id\": 1, \"title\": \"Sovereign AI Security Architecture\",\n            \"document_type\": \"Architecture Guide\", \"visibility\": \"private\", \"status\": \"active\", \"version\": \"1.0.0\",\n            \"owner\": \"system\", \"entity_type\": \"DOCUMENT\"\n        },\n        {\n            \"PK\": \"CLIENT#1\", \"SK\": \"DOC#2\", \"GSI1PK\": \"PROJ#2\", \"GSI1SK\": \"DOC#2\",\n            \"id\": 2, \"client_id\": \"1\", \"project_id\": 2, \"title\": \"Tax Automation Node Protocol\",\n            \"document_type\": \"Integration Protocol\", \"visibility\": \"private\", \"status\": \"active\", \"version\": \"1.0.0\",\n            \"owner\": \"system\", \"entity_type\": \"DOCUMENT\"\n        },\n        {\n            \"PK\": \"CLIENT#2\", \"SK\": \"DOC#3\", \"GSI1PK\": \"PROJ#3\", \"GSI1SK\": \"DOC#3\",\n            \"id\": 3, \"client_id\": \"2\", \"project_id\": 3, \"title\": \"Omesh Agent Security Threat Model\",\n            \"document_type\": \"Threat Model\", \"visibility\": \"private\", \"status\": \"active\", \"version\": \"1.0.0\",\n            \"owner\": \"system