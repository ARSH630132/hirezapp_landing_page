\", \"entity_type\": \"INVOICE\"},\n        {\"PK\": \"CLIENT#2\", \"SK\": \"INV#3\", \"GSI1PK\": \"BILLING_PERIOD#2026_06\", \"GSI1SK\": \"INV#3\", \"id\": 3, \"client_id\": \"2\", \"project_id\": 3, \"invoice_number\": \"INV-2026-003\", \"status\": \"unpaid\", \"amount\": 150000.0, \"currency\": \"USD\", \"entity_type\": \"INVOICE\"},\n        {\"PK\": \"CLIENT#3\", \"SK\": \"INV#4\", \"GSI1PK\": \"BILLING_PERIOD#2026_06\", \"GSI1SK\": \"INV#4\", \"id\": 4, \"client_id\": \"3\", \"project_id\": 4, \"invoice_number\": \"INV-2026-004\", \"status\": \"paid\", \"amount\": 80000.0, \"currency\": \"USD\", \"entity_type\": \"INVOICE\"},\n        # SUPPORT (TICKETS)\n        {\"PK\": \"CLIENT#1\", \"SK\": \"TICKET#1\", \"GSI1PK\": \"STATUS#RESOLVED\", \"GSI1SK\": \"TICKET#1\", \"id\": 1, \"client_id\": \"1\", \"project_id\": 2, \"title\": \"API Handshake Failure in Production\", \"category\": \"Technical\", \"priority\": \"critical\", \"status\": \"resolved\", \"assigned_to\": \"support_team\", \"created_by\": \"user\", \"description\": \"The API gateway returned 502 errors during high-volume ledger integration runs.\", \"entity_type\": \"SUPPORT\"},\n        {\"PK\": \"CLIENT#1\", \"SK\": \"TICKET#2\", \"GSI1PK\": \"STATUS#OPEN\", \"GSI1SK\": \"TICKET#2\", \"id\": 2, \"client_id\": \"1\", \"project_id\": 2, \"title\": \"Request for Custom Model Fine-Tuning\", \"category\": \"Feature Request\", \"priority\": \"medium\", \"status\": \"open\", \"assigned_to\": \"support_team\", \"created_by\": \"user\", \"description\": \"Need a pipeline to fine-tune Sovereign Llama models with quarterly tax reports.\", \"entity_type\": \"SUPPORT\"},\n        {\"PK\": \"CLIENT#2\", \"SK\": \"TICKET#3\", \"GSI1PK\": \"STATUS#IN_PROGRESS\", \"GSI1SK\": \"TICKET#3\", \"id\": 3, \"client_id\": \"2\", \"project_id\": 3, \"title\": \"Late Telemetry Sync from Omesh Nodes\", \"category\": \"Hardware Integration\", \"priority\": \"high\", \"status\": \"in_progress\", \"assigned_to\": \"support_team\", \"created_by\": \"user\", \"description\": \"Some remote nodes show high latency (>10s) when reporting pipeline status.\", \"entity_type\": \"SUPPORT\"},\n        # GOVERNANCE\n        {\"PK\": \"CLIENT#1\", \"SK\": \"GOV#1\", \"GSI1PK\": \"STANDARD#EXTERNAL\", \"GSI1SK\": \"GOV#1\", \"id\": 1, \"client_id\": \"1\", \"project_id\": 1, \"title\": \"Third-Party Agent Audit\", \"severity\": \"high\", \"status\": \"active\", \"description\": \"Perform independent automated audits of all external integrations.\", \"entity_type\": \"GOVERNANCE\"},\n        {\"PK\": \"CLIENT#2\", \"SK\": \"GOV#2\", \"GSI1PK\": \"STANDARD#MODEL_DRIFT\", \"GSI1SK\": \"GOV#2\", \"id\": 2, \"client_id\": \"2\", \"project_id\": 3, \"title\": \"Model Drift Check - Pipeline Anomaly Detector\", \"severity\": \"medium\", \"status\": \"active\", \"description\": \"Review performance metrics of pipeline anomaly models to verify consistency.\", \"entity_type\": \"GOVERNANCE\"},\n        {\"PK\": \"CLIENT#3\", \"SK\": \"GOV#3\", \"GSI1PK\": \"STANDARD#TOKEN_ROTATION\", \"GSI1SK\": \"GOV#3\", \"id\": 3, \"client_id\": \"3\", \"project_id\": 4, \"title\": \"Access Token Rotation Enforcement\", \"severity\": \"critical\", \"status\": \"resolved\", \"description\": \"Force rotate all integration access keys for API Gateway following scheduled quarterly audit.\", \"entity_type\": \"GOVERNANCE\"}\n    ]\n\nseed_mock_database()\n"}}}
