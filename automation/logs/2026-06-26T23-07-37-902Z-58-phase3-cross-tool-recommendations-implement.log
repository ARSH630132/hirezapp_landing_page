Proposal Studio\";\n    case \"talk\": return \"Talk to Agent\";\n    case \"sandbox\": return \"Execution Sandbox\";\n    case \"marketplace\": return \"Agent Marketplace\";\n    case \"foundryStudio\": return \"Foundry Studio\";\n    default: return id;\n  }\n};\n\nexport default function NextBestAction({ currentTool, completed = false }: NextBestActionProps) {\n  const [isVisible, setIsVisible] = useState(false);\n  const containerRef = useRef<HTMLDivElement>(null);\n  const [coords, setCoords] = useState({ x: 0, y: 0 });\n  const [isHovered, setIsHovered] = useState(false);\n\n  useEffect(() => {\n    if (completed) {\n      setIsVisible(true);\n      return;\n    }\n\n    const checkLocalState = () => {\n      try {\n        if (currentTool === \"blueprint\") {\n          return getBlueprintHistory().length > 0;\n        }\n        const ws = getFullWorkspace();\n        const state = ws[currentTool as keyof GFFWorkspace];\n        if (!state) return false;\n\n        if (currentTool === \"assessment\") {\n          return !!state.showResult;\n        }\n        if (currentTool === \"talk\") {\n          return !!state.showResults || !!state.data;\n        }\n        return true;\n      } catch {\n        return false;\n      }\n    };\n\n    setIsVisible(checkLocalState());\n\n    const handleStorage = () => {\n      setIsVisible(checkLocalState());\n    };\n    window.addEventListener(\"storage\", handleStorage);\n    return () => {\n      window.removeEventListener(\"storage\", handleStorage);\n    };\n  }, [currentTool, completed]);\n\n  const handleMouseMove = (e: MouseEvent<HTMLDivElement>) => {\n    if (!containerRef.current) return;\n    const rect = containerRef.current.getBoundingClientRect();\n    setCoords({\n      x: e.clientX - rect.left,\n      y: e.clientY - rect.top,\n    });\n  };\n\n  const config = CONFIGS[currentTool];\n\n  if (!isVisible || !config) return null;\n\n  return (\n    <AnimatePresence>\n      <motion.div\n        initial={{ opacity: 0, y: 25 }}\n        animate={{ opacity: 1, y: 0 }}\n        exit={{ opacity: 0, y: 15 }}\n        className=\"w-full mt-12\"\n      >\n        <div\n          ref={containerRef}\n          onMouseMove={handleMouseMove}\n          onMouseEnter={() => setIsHovered(true)}\n          onMouseLeave={() => setIsHovered(false)}\n          className=\"relative w-full overflow-hidden rounded-[24px] border border-white/5 bg-[#030305]/90 backdrop-blur-[12px] p-6 md:p-8 lg:p-10 shadow-2xl transition-all duration-300 hover:border-white/10 group\"\n        >\n          {/* Spotlight Glow */}\n          <div\n            className=\"absolute inset-0 pointer-events-none transition-all duration-300 opacity-80\"\n            style={{\n              background: isHovered\n                ? `radial-gradient(circle 380px at ${coords.x}px ${coords.y}px, ${config.accentColor}25, rgba(0, 157, 255, 0.02), transparent 75%)`\n                : `radial-gradient(circle 380px at 50% 50%, ${config.accentColor}15 20%, transparent 80%)`,\n            }}\n          />\n\n          {/* Tech accents */}\n          <div className=\"absolute top-0 left-0 w-6 h-6 border-t border-l border-white/10 rounded-tl-[24px]\" />\n          <div className=\"absolute top-0 right-0 w-6 h-6 border-t border-r border-white/10 rounded-tr-[24px]\" />\n          <div className=\"absolute bottom-0 left-0 w-6 h-6 border-b border-l border-white/10 rounded-bl-[24px]\" />\n          <div className=\"absolute bottom-0 right-0 w-6 h-6 border-b border-r border-white/10 rounded-br-[24px]\" />\n\n          <div className=\"relative z-10 flex flex-col lg:flex-row items-center justify-between gap-8\">\n            <div className=\"space-y-4 max-w-3xl text-left\">\n              <div className=\"flex items-center gap-2\">\n                <span className=\"relative flex h-2 w-2\">\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full opacity-75\" style={{ backgroundColor: config.accent