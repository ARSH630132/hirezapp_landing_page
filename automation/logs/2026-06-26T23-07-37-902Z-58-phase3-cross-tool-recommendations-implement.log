             { id: \"large_enterprise\", label: \"2K-10K\", title: \"Large Enterprise (2,000-10,000 FTE)\" },\n462 |                     { id: \"global_corp\", label: \"10K+\", title: \"Global Corporation (10,000+ FTE)\" }\n463 |                   ].map((item) => (\n464 |                     <button\n465 |                       key={item.id}\n466 |                       type=\"button\"\n467 |                       onClick={() => setCompanySize(item.id)}\n468 |                       className={`h-8 rounded text-[9px] font-semibold transition-all border ${\n469 |                         companySize === item.id\n470 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n471 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n472 |                       }`}\n473 |                       title={item.title}\n474 |                     >\n475 |                       {item.label}\n476 |                     </button>\n477 |                   ))}\n478 |                 </div>\n479 |               </div>\n480 | \n481 |               {/* Operational Function */}\n482 |               <div className=\"space-y-1.5\">\n483 |                 <div className=\"flex justify-between items-center\">\n484 |                   <label htmlFor=\"function-select\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n485 |                     Operational Function\n486 |                   </label>\n487 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Labor Complexity Factor</span>\n488 |                 </div>\n489 |                 <select\n490 |                   id=\"function-select\"\n491 |                   value={opFunction}\n492 |                   onChange={(e) => setOpFunction(e.target.value)}\n493 |                   className=\"w-full h-9 bg-white/5 border border-white/10 rounded-lg px-2.5 text-xs text-white focus:outline-none focus:border-[#009DFF]/50 transition-colors cursor-pointer\"\n494 |                 >\n495 |                   <option value=\"customer_operations\">Customer Support & Operations</option>\n496 |                   <option value=\"legal_compliance\">Legal, Risk & Compliance</option>\n497 |                   <option value=\"supply_chain\">Supply Chain & Logistics</option>\n498 |                   <option value=\"finance_accounting\">Finance, Audit & Accounting</option>\n499 |                   <option value=\"it_engineering\">IT Service & Infrastructure</option>\n500 |                   <option value=\"hr_admin\">People & Administrative Services</option>\n501 |                 </select>\n502 |               </div>\n503 |             </div>\n504 | \n505 |             {/* SECTION 2: CURRENT WORKLOAD & COSTS */}\n506 |             <div className=\"space-y-4 border-b border-white/5 pb-5\">\n507 |               <div className=\"flex items-center gap-2\">\n508 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">02</span>\n509 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Friction & Baseline</span>\n510 |               </div>\n511 | \n512 |               {/* Annual Cost Baseline */}\n513 |               <div className=\"space-y-2\">\n514 |                 <div className=\"flex justify-between items-center\">\n515 |                   <label htmlFor=\"cost-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n516 |                     Annual Cost Baseline\n517 |                   </label>\n518 |                   <div className=\"flex items-center gap-1.5\">\n519 |                     <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n520 |                     <input\n521 |                       id=\"cost-input\"\n522 |                       type=\"text\"\n523 |                       value={annualCostBaseline === 0 ? \"\" : annualCostBaseline.toLocaleString()}\n524 |                       onChange={(e) => handleBaselineChange(e.target.value)}\n525 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n526 |                     />\n527 |                   </div>\n528 |                 </div>\n529 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n530 |                   Annual expenses of targeted operational unit (labor + software tools).\n531 |                 </p>\n532 |                 <input\n533 |                   id=\"cost-slider\"\n534 |                   aria-label=\"Annual Cost Baseline range slider\"\n535 |                   type=\"range\"\n536 |                   min=\"50000\"\n537 |                   max=\"25000000\"\n538 |                   step=\"50000\"\n539 |                   value={annualCostBaseline}\n540 |                   onChange={(e) => setAnnualCostBaseline(parseInt(e.target.value))}\n541 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n542 |                 />\n543 |               </div>\n544 | \n545 |               {/* Process Volume */}\n546 |               <div className=\"space-y-2\">\n547 |                 <div className=\"flex justify-between items-center\">\n548 |                   <label htmlFor=\"volume-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n549 |                     Annual Process Volume\n550 |                   </label>\n551 |                   <div className=\"flex items-center gap-1.5\">\n552 |                     <input\n553 |                       id=\"volume-input\"\n554 |                       type=\"text\"\n555 |                       value={processVolume === 0 ? \"\" : processVolume.toLocaleString()}\n556 |                       onChange={(e) => handleVolumeChange(e.target.value)}\n557 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n558 |                     />\n559 |                   </div>\n560 |                 </div>\n561 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n562 |                   Annual requests, transactions, or tasks processed in this department.\n563 |                 </p>\n564 |                 <input\n565 |                   id=\"volume-slider\"\n566 |                   aria-label=\"Annual Process Volume range slider\"\n567 |                   type=\"range\"\n568 |                   min=\"1000\"\n569 |                   max=\"5000000\"\n570 |                   step=\"1000\"\n571 |                   value={processVolume}\n572 |                   onChange={(e) => setProcessVolume(parseInt(e.target.value))}\n573 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n574 |                 />\n575 |               </div>\n576 | \n577 |               {/* Average Handling Time */}\n578 |               <div className=\"space-y-2\">\n579 |                 <div className=\"flex justify-between items-center\">\n580 |                   <label htmlFor=\"aht-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n581 |                     Avg Handling Time (Mins)\n582 |                   </label>\n583 |                   <div className=\"flex items-center gap-2\">\n584 |                     <input\n585 |                       id=\"aht-input\"\n586 |                       type=\"text\"\n587 |                       placeholder=\"Sector Avg\"\n588 |                       value={avgHandlingTime}\n589 |                       onChange={(e) => handleHandlingTimeChange(e.target.value)}\n590 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50 placeholder:text-white/20\"\n591 |                     />\n592 |                     <span className=\"text-[8px] font-mono text-white/30\">MIN</span>\n593 |                   </div>\n594 |                 </div>\n595 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n596 |                   Optional. Left blank, GFF models friction hours based on industry standards.\n597 |                 </p>\n598 |                 <input\n599 |                   id=\"aht-slider\"\n600 |                   aria-label=\"Avg Handling Time range slider\"\n601 |                   type=\"range\"\n602 |                   min=\"0\"\n603 |                   max=\"180\"\n604 |                   step=\"1\"\n605 |                   value={avgHandlingTime === \"\" ? 0 : avgHandlingTime}\n606 |                   onChange={(e) => setAvgHandlingTime(parseInt(e.target.value) || \"\")}\n607 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n608 |                 />\n609 |               </div>\n610 | \n611 |               {/* Manual Friction Index (Current Manual Effort Level) */}\n612 |               <div className=\"space-y-1.5\">\n613 |                 <div className=\"flex justify-between items-center\">\n614 |                   <span className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider\">\n615 |                     Manual Friction Index\n616 |                   </span>\n617 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Wasted Effort Level</span>\n618 |                 </div>\n619 |                 <div className=\"grid grid-cols-4 gap-1\" role=\"group\" aria-label=\"Manual Friction Index\">\n620 |                   {[\n621 |                     { id: \"low\", label: \"Low\", desc: \"Highly standardized, minimal cognitive friction\" },\n622 |                     { id: \"medium\", label: \"Medium\", desc: \"Rule-based processing, minor exceptions\" },\n623 |                     { id: \"high\", label: \"High\", desc: \"Complex workflow, significant administrative drag\" },\n624 |                     { id: \"critical\", label: \"Critical\", desc: \"Severe operational bottleneck, data-heavy\" }\n625 |                   ].map((item) => (\n626 |                     <button\n627 |                       key={item.id}\n628 |                       type=\"button\"\n629 |                       onClick={() => setManualEffort(item.id)}\n630 |                       className={`py-1.5 rounded text-[10px] font-medium transition-all border flex flex-col items-center justify-center ${\n631 |                         manualEffort === item.id\n632 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n633 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n634 |                       }`}\n635 |                       title={item.desc}\n636 |                     >\n637 |                       <span>{item.label}</span>\n638 |                     </button>\n639 |                   ))}\n640 |                 </div>\n641 |               </div>\n642 |             </div>\n643 | \n644 |             {/* SECTION 3: SOVEREIGN AMBITION */}\n645 |             <div className=\"space-y-4 pb-2\">\n646 |               <div className=\"flex items-center gap-2\">\n647 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">03</span>\n648 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Sovereign Automation Targets</span>\n649 |               </div>\n650 | \n651 |               {/* Automation Target Rate */}\n652 |               <div className=\"space-y-2\">\n653 |                 <div className=\"flex justify-between items-center\">\n654 |                   <label htmlFor=\"automation-slider\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n655 |                     Automation Target Rate\n656 |                   </label>\n657 |                   <span className=\"text-[#00FF9D] font-mono font-bold text-xs\">{automationTarget}%</span>\n658 |                 </div>\n659 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n660 |                   Target volume percentage delegated to secure multi-agent chains.\n661 |                 </p>\n662 |                 <input\n663 |                   id=\"automation-slider\"\n664 |                   aria-label=\"Automation Target Rate range slider\"\n665 |                   type=\"range\"\n666 |                   min=\"10\"\n667 |                   max=\"95\"\n668 |                   step=\"5\"\n669 |                   value={automationTarget}\n670 |                   onChange={(e) => setAutomationTarget(parseInt(e.target.value))}\n671 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#00FF9D] hover:accent-[#00FF9D]\"\n672 |                 />\n673 |               </div>\n674 | \n675 |               {/* Target Productivity Boost */}\n676 |               <div className=\"space-y-2\">\n677 |                 <div className=\"flex justify-between items-center\">\n678 |                   <label htmlFor=\"productivity-slider\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n679 |                     Target Productivity Boost\n680 |                   </label>\n681 |                   <span className=\"text-white font-mono font-bold text-xs\">\n682 |                     {productivityImprovement}% <span className=\"text-white/30 text-[9px] font-light\">({Math.max(10, productivityImprovement - 15)}% - {Math.min(95, productivityImprovement + 15)}% model)</span>\n683 |                   </span>\n684 |                 </div>\n685 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n686 |                   Modelled efficiency multiplier of automated tasks. Bounds denote safety ranges.\n687 |                 </p>\n688 |                 <input\n689 |                   id=\"productivity-slider\"\n690 |                   aria-label=\"Target Productivity Boost range slider\"\n691 |                   type=\"range\"\n692 |                   min=\"10\"\n693 |                   max=\"90\"\n694 |                   step=\"5\"\n695 |                   value={productivityImprovement}\n696 |                   onChange={(e) => setProductivityImprovement(parseInt(e.target.value))}\n697 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n698 |                 />\n699 |               </div>\n700 | \n701 |               {/* Deployment Horizon */}\n702 |               <div className=\"space-y-1.5\">\n703 |                 <div className=\"flex justify-between items-center\">\n704 |                   <span className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider\">\n705 |                     Deployment Horizon\n706 |                   </span>\n707 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Phased System Integration</span>\n708 |                 </div>\n709 |                 <div className=\"grid grid-cols-4 gap-1\" role=\"group\" aria-label=\"Deployment Horizon\">\n710 |                   {[\n711 |                     { id: \"3_months\", label: \"3M\", title: \"3 Months (Fast Track Setup)\" },\n712 |                     { id: \"6_months\", label: \"6M\", title: \"6 Months (Standard Setup)\" },\n713 |                     { id: \"12_months\", label: \"12M\", title: \"12 Months (Phased Enterprise Setup)\" },\n714 |                     { id: \"18_months\", label: \"18M\", title: \"18 Months (Global Core Implementation)\" }\n715 |                   ].map((item) => (\n716 |                     <button\n717 |                       key={item.id}\n718 |                       type=\"button\"\n719 |                       onClick={() => setImplementationHorizon(item.id)}\n720 |                       className={`py-1.5 rounded text-[10px] font-medium transition-all border ${\n721 |                         implementationHorizon === item.id\n722 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n723 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n724 |                       }`}\n725 |                       title={item.title}\n726 |                     >\n727 |                       {item.label}\n728 |                     </button>\n729 |                   ))}\n730 |                 </div>\n731 |               </div>\n732 | \n733 |               {/* Enclave Platform Investment (CapEx) */}\n734 |               <div className=\"space-y-2 pt-1\">\n735 |                 <div className=\"flex justify-between items-center\">\n736 |                   <label htmlFor=\"investment-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n737 |                     Enclave Platform CapEx\n738 |                   </label>\n739 |                   <div className=\"flex items-center gap-1\">\n740 |                     <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n741 |                     <input\n742 |                       id=\"investment-input\"\n743 |                       type=\"text\"\n744 |                       value={initialInvestment === 0 ? \"\" : initialInvestment.toLocaleString()}\n745 |                       onChange={(e) => handleInvestmentChange(e.target.value)}\n746 |                       className=\"w-20 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n747 |                     />\n748 |                   </div>\n749 |                 </div>\n750 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n751 |                   Platform deployment, hardware sandboxing, secure compliance setup, and integration.\n752 |                 </p>\n753 |                 <input\n754 |                   id=\"investment-slider\"\n755 |                   aria-label=\"Enclave Platform CapEx range slider\"\n756 |                   type=\"range\"\n757 |                   min=\"10000\"\n758 |                   max=\"2500000\"\n759 |                   step=\"10000\"\n760 |                   value={initialInvestment}\n761 |                   onChange={(e) => setInitialInvestment(parseInt(e.target.value))}\n762 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n763 |                 />\n764 |               </div>\n765 |             </div>\n766 | \n767 |             {/* Strategic Priorities Selection Grid */}\n768 |             <div className=\"space-y-3 pt-3 border-t border-white/5\">\n769 |               <span className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider block\">Strategic Focus Lens</span>\n770 |               <div className=\"grid grid-cols-1 gap-2\" role=\"group\" aria-label=\"Strategic Focus Lens\">\n771 |                 {priorities.map((item) => {\n772 |                   const isActive = item.id === priority;\n773 |                   return (\n774 |                     <button\n775 |                       key={item.id}\n776 |                       onClick={() => setPriority(item.id)}\n777 |                       type=\"button\"\n778 |                       className={`relative text-left p-2.5 rounded-lg border transition-all text-xs flex items-start gap-3 overflow-hidden ${\n779 |                         isActive\n780 |                           ? \"border-white/20 text-white\"\n781 |                           : \"border-white/5 bg-transparent text-white/70 hover:border-white/10 hover:bg-white/[0.01]\"\n782 |                       }`}\n783 |                     >\n784 |                       {isActive && (\n785 |                         <motion.div\n786 |                           layoutId=\"activePriorityBg\"\n787 |                           className=\"absolute inset-0 bg-white/[0.03] -z-10\"\n788 |                           transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n789 |                         />\n790 |                       )}\n791 |                       <div\n792 |                         className=\"w-2 h-2 rounded-full shrink-0 mt-1\"\n793 |                         style={{ backgroundColor: item.color }}\n794 |                       />\n795 |                       <div className=\"relative z-10\">\n796 |                         <span className={`font-semibold block text-[11px] ${isActive ? \"text-white\" : \"text-white/70\"}`}>\n797 |                           {item.title}\n798 |                         </span>\n799 |                         <span className=\"text-[9px] text-white/40 block leading-tight font-light mt-0.5\">\n800 |                           {item.desc}\n801 |                         </span>\n802 |                       </div>\n803 |                     </button>\n804 |                   );\n805 |                 })}\n806 |               </div>\n807 |             </div>\n808 |           </div>\n809 | \n810 |           {/* Footnote Compliance Panel */}\n811 |           <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/40 text-[10px] text-white/30 space-y-2 leading-relaxed\">\n812 |             <span className=\"font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">SECURE SHIELD COMPLIANCE</span>\n813 |             <p>\n814 |               This simulator processes data points purely inside local volatile browser memory, aligning with the GFF AI zero-retention mandate. No telemetry is logged outside your sandboxed session.\n815 |             </p>\n816 |           </div>\n817 |         </div>\n818 | \n819 |         {/* RIGHT COLUMN: Results Console */}\n820 |         <div className=\"lg:col-span-7 space-y-8 text-white\">\n821 |           {/* Section A: Main Telemetry Summary Cards */}\n822 |           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n823 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n824 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#00FF9D]/30 to-transparent\" />\n825 |               <div>\n826 |                 <div className=\"flex items-center gap-1.5\">\n827 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">RECLAIMED ANNUAL VALUE</span>\n828 |                   <span className=\"text-[8px] font-mono font-bold bg-[#00FF9D]/10 text-[#00FF9D] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n829 |                 </div>\n830 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#00FF9D] block mt-2 font-mono tracking-tight\">\n831 |                   {formatCompactCurrency(expectedGrossSavings)}\n832 |                 </span>\n833 |               </div>\n834 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n835 |                 Illustrative annual budget returned from manual operations to executive reserves.\n836 |               </p>\n837 |             </div>\n838 | \n839 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n840 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/30 to-transparent\" />\n841 |               <div>\n842 |                 <div className=\"flex items-center gap-1.5\">\n843 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">PRODUCTIVE HOURS RECLAIMED</span>\n844 |                   <span className=\"text-[8px] font-mono font-bold bg-[#009DFF]/10 text-[#009DFF] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n845 |                 </div>\n846 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#009DFF] block mt-2 font-mono tracking-tight\">\n847 |                   {expectedHoursSaved.toLocaleString()} Hrs\n848 |                 </span>\n849 |               </div>\n850 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n\n[Showing lines 1-850 of 1153. Use start_line/end_line to read other sections.]","success":true}],"durationMs":4}}
