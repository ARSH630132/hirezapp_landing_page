 | // ==========================================\n110 | // 3. ToolStepLayout\n111 | // ==========================================\n112 | interface ToolStepLayoutProps {\n113 |   sidebar: React.ReactNode;\n114 |   content: React.ReactNode;\n115 | }\n116 | \n117 | export function ToolStepLayout({ sidebar, content }: ToolStepLayoutProps) {\n118 |   return (\n119 |     <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-start\">\n120 |       <div className=\"lg:col-span-4 space-y-6\">\n121 |         {sidebar}\n122 |       </div>\n123 |       <div className=\"lg:col-span-8\">\n124 |         {content}\n125 |       </div>\n126 |     </div>\n127 |   );\n128 | }\n129 | \n130 | \n131 | // ==========================================\n132 | // 4. ToolSidebarProgress\n133 | // ==========================================\n134 | interface Step {\n135 |   id: string;\n136 |   label: string;\n137 |   description?: string;\n138 |   duration?: string;\n139 | }\n140 | \n141 | interface ToolSidebarProgressProps {\n142 |   steps: Step[];\n143 |   currentStepIndex: number;\n144 |   onStepClick?: (index: number) => void;\n145 | }\n146 | \n147 | export function ToolSidebarProgress({ steps, currentStepIndex, onStepClick }: ToolSidebarProgressProps) {\n148 |   const percentage = Math.round((currentStepIndex / (steps.length - 1)) * 100);\n149 | \n150 |   return (\n151 |     <div className=\"p-6 rounded-2xl border border-white/5 bg-[#04060b]/80 backdrop-blur-sm space-y-6\">\n152 |       <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n153 |         <span className=\"text-xs font-bold text-white uppercase tracking-wider font-mono\">CONSTRUCT PIPELINE</span>\n154 |         <span className=\"text-xs font-mono text-white/40\">{percentage}% COMPLETED</span>\n155 |       </div>\n156 | \n157 |       {/* Progress Track */}\n158 |       <div className=\"w-full h-1 bg-white/5 rounded-full overflow-hidden\">\n159 |         <div\n160 |           className=\"h-full bg-gradient-to-r from-[#009DFF] to-[#00FF9D] transition-all duration-500 ease-out\"\n161 |           style={{ width: `${percentage}%` }}\n162 |         />\n163 |       </div>\n164 | \n165 |       {/* Steps List */}\n166 |       <div className=\"space-y-4 pt-2\">\n167 |         {steps.map((step, idx) => {\n168 |           const isActive = idx === currentStepIndex;\n169 |           const isCompleted = idx < currentStepIndex;\n170 | \n171 |           return (\n172 |             <button\n173 |               key={step.id}\n174 |               onClick={() => onStepClick && onStepClick(idx)}\n175 |               disabled={!onStepClick || (!isCompleted && !isActive)}\n176 |               className={`w-full text-left flex gap-4 p-3 rounded-xl transition border text-xs group ${\n177 |                 isActive\n178 |                   ? \"bg-white/[0.03] border-white/10 text-white\"\n179 |                   : isCompleted\n180 |                   ? \"bg-transparent border-transparent text-white/50 hover:text-white\"\n181 |                   : \"bg-transparent border-transparent text-white/20 cursor-not-allowed\"\n182 |               }`}\n183 |             >\n184 |               {/* Step Marker */}\n185 |               <div className=\"mt-0.5 shrink-0\">\n186 |                 <div\n187 |                   className={`w-5 h-5 rounded-full flex items-center justify-center font-mono text-[9px] border transition ${\n188 |                     isActive\n189 |                       ? \"border-[#009DFF] text-[#009DFF] bg-[#009DFF]/10\"\n190 |                       : isCompleted\n191 |                       ? \"border-[#00FF9D] text-[#00FF9D] bg-[#00FF9D]/5\"\n192 |                       : \"border-white/10 text-white/20\"\n193 |                   }`}\n194 |                 >\n195 |                   {isCompleted ? (\n196 |                     <svg className=\"w-2.5 h-2.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n197 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={3} d=\"M5 13l4 4L19 7\" />\n198 |                     </svg>\n199 |                   ) : (\n200 |                     idx + 1\n201 |                   )}\n202 |                 </div>\n203 |               </div>\n204 | \n205 |               {/* Step Info */}\n206 |               <div className=\"space-y-1\">\n207 |                 <div className=\"flex items-center gap-2\">\n208 |                   <span className={`font-semibold ${isActive ? \"text-[#009DFF]\" : \"\"}`}>{step.label}</span>\n209 |                   {step.duration && (\n210 |                     <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 border border-white/5 text-white/30 uppercase\">\n211 |                       {step.duration}\n212 |                     </span>\n213 |                   )}\n214 |                 </div>\n215 |                 {step.description && (\n216 |                   <p className=\"text-[11px] text-white/40 font-light leading-relaxed group-hover:text-white/60 transition\">\n217 |                     {step.description}\n218 |                   </p>\n219 |                 )}\n220 |               </div>\n221 |             </button>\n222 |           );\n223 |         })}\n224 |       </div>\n225 |     </div>\n226 |   );\n227 | }\n228 | \n229 | \n230 | \n231 | // ==========================================\n232 | // 5. ToolPreviewNotice\n233 | // ==========================================\n234 | export function ToolPreviewNotice() {\n235 |   return (\n236 |     <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex items-start gap-3.5 text-xs\">\n237 |       <div className=\"p-2 rounded bg-white/5 border border-white/10 shrink-0 mt-0.5 text-[#009DFF]\">\n238 |         <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n239 |           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.8} d=\"M12 15v2m0-6v2m0-6h.01M12 2a10 10 0 110 20 10 10 0 010-20z\" />\n240 |         </svg>\n241 |       </div>\n242 |       <div className=\"space-y-1\">\n243 |         <h4 className=\"font-bold text-white font-mono text-[10px] uppercase tracking-wider\">SANDBOX COMPLIANCE SIMULATION</h4>\n244 |         <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">\n245 |           This modeling framework operates as a localized Web Sandbox in compliance with GFF security blueprints. \n246 |           Calculations are calculated deterministically on memory buffers. In keeping with our zero-retention architecture, \n247 |           no parameter schemas or variables are sent to public clouds.\n248 |         </p>\n249 |       </div>\n250 |     </div>\n251 |   );\n252 | }\n253 | \n254 | // ==========================================\n255 | // 6. ToolCTA\n256 | // ==========================================\n257 | interface ToolCTAProps {\n258 |   title?: string;\n259 |   description?: string;\n260 |   buttonText?: string;\n261 |   onAction?: () => void;\n262 |   href?: string;\n263 | }\n264 | \n265 | export function ToolCTA({\n266 |   title = \"Ready to Execute This Topology?\",\n267 |   description = \"Connect with a GFF Enterprise Architect to compile your simulated sandbox specifications into a production-ready private enclave.\",\n268 |   buttonText = \"Secure Technical Sync\",\n269 |   onAction,\n270 |   href = \"/contact\"\n271 | }: ToolCTAProps) {\n272 |   const content = (\n273 |     <div className=\"relative p-8 lg:p-10 rounded-2xl border border-white/5 bg-[#030305] flex flex-col md:flex-row items-center justify-between gap-8 group overflow-hidden\">\n274 |       {/* Decorative glows */}\n275 |       <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[#009DFF]/5 blur-3xl pointer-events-none rounded-full\" />\n276 |       <div className=\"absolute top-0 right-0 w-px h-full bg-gradient-to-b from-white/10 to-transparent pointer-events-none\" />\n277 | \n278 |       <div className=\"space-y-3 max-w-2xl relative z-10 text-center md:text-left\">\n279 |         <span className=\"text-[9px] font-mono text-[#00FF9D] font-bold uppercase tracking-widest block\">\n280 |           SOVEREIGN ENCLAVE ELEVATION\n281 |         </span>\n282 |         <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">{title}</h3>\n283 |         <p className=\"text-white/50 text-xs font-light leading-relaxed max-w-lg\">{description}</p>\n284 |       </div>\n285 | \n286 |       <div className=\"relative z-10 shrink-0\">\n287 |         {onAction ? (\n288 |           <button\n289 |             onClick={onAction}\n290 |             className=\"px-6 py-3 rounded-xl text-xs font-bold text-black bg-[#009DFF] hover:bg-[#009DFF]/90 transition uppercase tracking-wider flex items-center gap-2 group/btn shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n291 |           >\n292 |             <span>{buttonText}</span>\n293 |             <svg className=\"w-3.5 h-3.5 group-hover/btn:translate-x-0.5 transition-transform\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n294 |               <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M14 5l7 7m0 0l-7 7m7-7H3\" />\n295 |             </svg>\n296 |           </button>\n297 |         ) : (\n298 |           <a\n299 |             href={href}\n300 |             className=\"px-6 py-3 rounded-xl text-xs font-bold text-black bg-[#009DFF] hover:bg-[#009DFF]/90 transition uppercase tracking-wider inline-flex items-center gap-2 group/btn shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n301 |           >\n302 |             <span>{buttonText}</span>\n303 |             <svg className=\"w-3.5 h-3.5 group-hover/btn:translate-x-0.5 transition-transform\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n304 |               <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M14 5l7 7m0 0l-7 7m7-7H3\" />\n305 |             </svg>\n306 |           </a>\n307 |         )}\n308 |       </div>\n309 |     </div>\n310 |   );\n311 | \n312 |   return <div className=\"mt-16\">{content}</div>;\n313 | }\n314 | \n315 | // ==========================================\n316 | // 7. ToolMotionReveal\n317 | // ==========================================\n318 | interface ToolMotionRevealProps {\n319 |   children: React.ReactNode;\n320 |   delay?: number;\n321 | }\n322 | \n323 | export function ToolMotionReveal({ children, delay = 0 }: ToolMotionRevealProps) {\n324 |   return (\n325 |     <motion.div\n326 |       initial={{ opacity: 0, y: 12 }}\n327 |       animate={{ opacity: 1, y: 0 }}\n328 |       exit={{ opacity: 0, y: -12 }}\n329 |       transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1], delay }}\n330 |       className=\"w-full\"\n331 |     >\n332 |       {children}\n333 |     </motion.div>\n334 |   );\n335 | }\n336 | \n337 | \n338 | \n339 | // ==========================================\n340 | // 8. ToolResultPanel\n341 | // ==========================================\n342 | interface ToolResultPanelProps {\n343 |   title: string;\n344 |   subtitle?: string;\n345 |   children: React.ReactNode;\n346 |   badge?: string;\n347 |   headerAction?: React.ReactNode;\n348 | }\n349 | \n350 | export function ToolResultPanel({ title, subtitle, children, badge, headerAction }: ToolResultPanelProps) {\n351 |   return (\n352 |     <div className=\"rounded-2xl border border-white/5 bg-[#030305]/95 backdrop-blur-sm overflow-hidden shadow-2xl relative group\">\n353 |       {/* Laser line overlay */}\n354 |       <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/35 to-transparent pointer-events-none\" />\n355 | \n356 |       {/* Panel Header */}\n357 |       <div className=\"p-6 border-b border-white/5 flex flex-wrap items-center justify-between gap-4\">\n358 |         <div className=\"space-y-1\">\n359 |           <div className=\"flex items-center gap-2.5\">\n360 |             {badge && (\n361 |               <span className=\"text-[8px] font-mono font-bold px-2 py-0.5 rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 uppercase tracking-wider\">\n362 |                 {badge}\n363 |               </span>\n364 |             )}\n365 |             <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">{title}</h3>\n366 |           </div>\n367 |           {subtitle && <p className=\"text-xs text-white/40 font-light\">{subtitle}</p>}\n368 |         </div>\n369 |         {headerAction && <div className=\"relative z-10\">{headerAction}</div>}\n370 |       </div>\n371 | \n372 |       {/* Content Area */}\n373 |       <div className=\"p-6 space-y-6\">\n374 |         {children}\n375 |       </div>\n376 |     </div>\n377 |   );\n378 | }\n379 | \n380 | // ==========================================\n381 | // 9. ToolInputGroup\n382 | // ==========================================\n383 | interface ToolInputGroupProps {\n384 |   label: string;\n385 |   valueDisplay: string | React.ReactNode;\n386 |   description?: string;\n387 |   children: React.ReactNode;\n388 |   accentColor?: string;\n389 | }\n390 | \n391 | export function ToolInputGroup({ label, valueDisplay, description, children, accentColor = \"#009DFF\" }: ToolInputGroupProps) {\n392 |   return (\n393 |     <div className=\"p-5 rounded-xl border border-white/5 bg-white/[0.01] hover:border-white/10 transition-all space-y-3 relative group\">\n394 |       {/* Corner laser glow indicator on hover */}\n395 |       <div\n396 |         className=\"absolute top-0 right-0 w-8 h-[1px] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none\"\n397 |         style={{ backgroundColor: accentColor }}\n398 |       />\n399 |       <div\n400 |         className=\"absolute top-0 right-0 w-[1px] h-8 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none\"\n401 |         style={{ backgroundColor: accentColor }}\n402 |       />\n403 | \n404 |       <div className=\"flex justify-between items-baseline gap-4\">\n405 |         <span className=\"text-[11px] font-mono text-white/50 uppercase tracking-wider\">{label}</span>\n406 |         <span className=\"text-xs font-bold font-mono\" style={{ color: accentColor }}>\n407 |           {valueDisplay}\n408 |         </span>\n409 |       </div>\n410 |       \n411 |       {description && <p className=\"text-[11px] text-white/40 font-light leading-relaxed\">{description}</p>}\n412 |       \n413 |       <div className=\"pt-2 w-full\">\n414 |         {children}\n415 |       </div>\n416 |     </div>\n417 |   );\n418 | }\n419 | \n420 | \n421 | \n422 | // ==========================================\n423 | // 10. ToolOptionGrid\n424 | // ==========================================\n425 | interface OptionItem {\n426 |   id: string;\n427 |   title: string;\n428 |   description: string;\n429 |   icon?: React.ReactNode;\n430 |   accentColor?: string;\n431 | }\n432 | \n433 | interface ToolOptionGridProps {\n434 |   options: OptionItem[];\n435 |   selectedId: string | string[];\n436 |   onChange: (id: string) => void;\n437 |   multiSelect?: boolean;\n438 | }\n439 | \n440 | export function ToolOptionGrid({ options, selectedId, onChange, multiSelect = false }: ToolOptionGridProps) {\n441 |   const isSelected = (id: string) => {\n442 |     if (multiSelect && Array.isArray(selectedId)) {\n443 |       return selectedId.includes(id);\n444 |     }\n445 |     return selectedId === id;\n446 |   };\n447 | \n448 |   return (\n449 |     <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n450 |       {options.map((opt) => {\n451 |         const selected = isSelected(opt.id);\n452 |         const accent = opt.accentColor || \"#009DFF\";\n453 | \n454 |         return (\n455 |           <button\n456 |             key={opt.id}\n457 |             onClick={() => onChange(opt.id)}\n458 |             type=\"button\"\n459 |             className={`text-left p-5 rounded-xl border transition-all duration-300 relative group flex gap-4 ${\n460 |               selected\n461 |                 ? \"bg-white/[0.03] border-white/10\"\n462 |                 : \"bg-white/[0.01] border-white/5 hover:border-white/10 hover:bg-white/[0.02]\"\n463 |             }`}\n464 |           >\n465 |             {/* Custom glowing accent border */}\n466 |             <div\n467 |               className={`absolute inset-x-0 top-0 h-[1.5px] transition-all duration-300 pointer-events-none ${\n468 |                 selected ? \"opacity-100\" : \"opacity-0 group-hover:opacity-35\"\n469 |               }`}\n470 |               style={{\n471 |                 background: `linear-gradient(90deg, transparent, ${accent}, transparent)`\n472 |               }}\n473 |             />\n474 | \n475 |             {opt.icon && (\n476 |               <div\n477 |                 className={`w-8 h-8 rounded-lg border flex items-center justify-center shrink-0 transition-all ${\n478 |                   selected\n479 |                     ? \"bg-white/5 border-white/10 text-white\"\n480 |                     : \"bg-white/[0.01] border-white/5 text-white/35 group-hover:text-white\"\n481 |                 }`}\n482 |                 style={selected ? { color: accent, borderColor: `${accent}25` } : {}}\n483 |               >\n484 |                 {opt.icon}\n485 |               </div>\n486 |             )}\n487 | \n488 |             <div className=\"space-y-1\">\n489 |               <span className={`text-xs font-bold transition-colors ${selected ? \"text-white\" : \"text-white/70 group-hover:text-white\"}`}>\n490 |                 {opt.title}\n491 |               </span>\n492 |               <p className=\"text-[11px] text-white/40 leading-relaxed font-light group-hover:text-white/50 transition\">\n493 |                 {opt.description}\n494 |               </p>\n495 |             </div>\n496 |           </button>\n497 |         );\n498 |       })}\n499 |     </div>\n500 |   );\n501 | }\n502 | \n503 | 