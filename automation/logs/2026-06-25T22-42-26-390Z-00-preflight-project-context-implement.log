rchestration\"],\n156 | };\n157 | \n158 | const riskGovernance: Record<string, string[]> = {\n159 |   conservative: [\"Strict Model Governance\", \"Human-in-the-Loop Controls\", \"Audit & Compliance Trails\", \"Ethics Review Board\"],\n160 |   moderate: [\"Policy-Based Guardrails\", \"Risk Tiering Framework\", \"Security & Privacy Controls\", \"Responsible AI Standards\"],\n161 |   aggressive: [\"Automated Policy Checks\", \"Rapid Release Gates\", \"Security Monitoring\", \"Ethics Guidelines\"],\n162 |   experimental: [\"Sandbox Environments\", \"Pilot Governance\", \"Fast Feedback Loops\", \"Ethics & Safety Reviews\"],\n163 | };\n164 | \n165 | const sizeRoadmapTiming: Record<string, [string, string, string, string]> = {\n166 |   startup: [\"0-2 Months\", \"2-6 Months\", \"6-12 Months\", \"12+ Months\"],\n167 |   \"mid-market\": [\"0-3 Months\", \"3-9 Months\", \"9-15 Months\", \"15+ Months\"],\n168 |   enterprise: [\"0-3 Months\", \"3-9 Months\", \"9-18 Months\", \"18+ Months\"],\n169 |   global: [\"0-4 Months\", \"4-12 Months\", \"12-24 Months\", \"24+ Months\"],\n170 | };\n171 | \n172 | function getOptionLabel(key: BlueprintFieldKey, value: string) {\n173 |   return blueprintFields.find((field) => field.key === key)?.options.find((option) => option.value === value)?.label ?? value;\n174 | }\n175 | \n176 | export function getEmptyBlueprintAnswers(): BlueprintAnswers {\n177 |   return {\n178 |     industry: \"\",\n179 |     enterpriseSize: \"\",\n180 |     aiGoals: \"\",\n181 |     workforceSize: \"\",\n182 |     existingSystems: \"\",\n183 |     riskAppetite: \"\",\n184 |   };\n185 | }\n186 | \n187 | export function isBlueprintComplete(answers: BlueprintAnswers) {\n188 |   return blueprintFields.every((field) => Boolean(answers[field.key]));\n189 | }\n190 | \n191 | export function generateBlueprint(answers: BlueprintAnswers): BlueprintResult {\n192 |   const industry = answers.industry;\n193 |   const operatingModel = industryOperatingModel[industry] ?? [\"Intelligent Workforce\", \"Agentic Automation\", \"Decision Intelligence\", \"Continuous Learning\"];\n194 |   const agents = goalAgents[answers.aiGoals] ?? { count: 24, types: [\"Workflow Agents\", \"Service Agents\", \"Analytics Agents\"] };\n195 |   const architecture = systemArchitecture[answers.existingSystems] ?? [\"Data & Intelligence Layer\", \"AI & Agent Layer\", \"Orchestration Layer\", \"Integration Layer\"];\n196 |   const governance = riskGovernance[answers.riskAppetite] ?? [\"Trust\", \"Risk\", \"Security\", \"Compliance\", \"Ethics\"];\n197 |   const timings = sizeRoadmapTiming[answers.enterpriseSize] ?? [\"0-3 Months\", \"3-9 Months\", \"9-18 Months\", \"18+ Months\"];\n198 | \n199 |   const workforceMultiplier =\n200 |     answers.workforceSize === \"very-large\" ? 1.35 : answers.workforceSize === \"large\" ? 1.2 : answers.workforceSize === \"medium\" ? 1.05 : 1;\n201 |   const agentCount = Math.round(agents.count * workforceMultiplier);\n202 | \n203 |   const industryLabel = getOptionLabel(\"industry\", industry);\n204 |   const goalLabel = getOptionLabel(\"aiGoals\", answers.aiGoals);\n205 |   const riskLabel = getOptionLabel(\"riskAppetite\", answers.riskAppetite);\n206 | \n207 |   return {\n208 |     operatingModel,\n209 |     agentCount,\n210 |     agentTypes: agents.types,\n211 |     architecture,\n212 |     governance,\n213 |     roadmap: [\n214 |       { phase: \"PHASE 1\", title: \"Foundation\", time: timings[0], focus: \"Data readiness, governance baseline, and priority use cases\" },\n215 |       { phase: \"PHASE 2\", title: \"Scale\", time: timings[1], focus: \"Agent deployment across high-impact workflows\" },\n216 |       { phase: \"PHASE 3\", title: \"Optimize\", time: timings[2], focus: \"Performance tuning, integration depth, and workforce adoption\" },\n217 |       { phase: \"PHASE 4\", title: \"Autonomous Enterprise\", time: timings[3], focus: \"Cross-functional agent orchestration at enterprise scale\" },\n218 |     ],\n219 |     insights: {\n220 |       summary: `A ${riskLabel.toLowerCase()} AI enterprise blueprint for ${industryLabel}, designed to deliver ${goalLabel.toLowerCase()} across your organization.`,\n221 |       recommendations: [\n222 |         `Start with ${operatingModel[0].toLowerCase()} as the anchor capability for your first production agents.`,\n223 |         `Deploy ${agentCount} agents in waves, prioritizing ${agents.types[0].toLowerCase()} in phase one.`,\n224 |         `Align architecture investments to your ${getOptionLabel(\"existingSystems\", answers.existingSystems).toLowerCase()} landscape before scaling.`,\n225 |         `Establish ${governance[0].toLowerCase()} as the non-negotiable control for every agent release.`,\n226 |       ],\n227 |       agentEcosystemDetail: `${agentCount} agents recommended across ${agents.types.join(\", \")}. This mix supports ${goalLabel.toLowerCase()} while matching your ${getOptionLabel(\"workforceSize\", answers.workforceSize).toLowerCase()} workforce footprint.`,\n228 |       architectureDetail: `Your ${getOptionLabel(\"existingSystems\", answers.existingSystems).toLowerCase()} environment maps to a layered architecture: ${architecture.join(\" → \")}. Integration depth should increase in phases 2 and 3.`,\n229 |       governanceDetail: `With a ${riskLabel.toLowerCase()} risk posture, governance should emphasize ${governance.slice(0, 3).join(\", \").toLowerCase()} before broad rollout.`,\n230 |       transformationNotes: [\n231 |         `${industryLabel}: prioritize industry-specific compliance and workflow patterns.`,\n232 |         `${getOptionLabel(\"enterpriseSize\", answers.enterpriseSize)} scale: phase timelines reflect your organizational complexity.`,\n233 |         `${goalLabel}: success metrics should track operational impact within the first 90 days.`,\n234 |       ],\n235 |     },\n236 |   };\n237 | }\n238 | \n239 | export function getFieldLabel(key: BlueprintFieldKey) {\n240 |   return blueprintFields.find((field) => field.key === key)?.label ?? key;\n241 | }\n242 | \n243 | export function getSelectedOptionLabel(key: BlueprintFieldKey, value: string) {\n244 |   return getOptionLabel(key, value);\n245 | }\n246 | \n247 | export function calculateBlueprintScore(input: {\n248 |   aiMaturityScore: number;\n249 |   businessNeedScore: number;\n250 |   dataReadinessScore: number;\n251 |   processComplexityScore: number;\n252 |   transformationReadinessScore: number;\n253 | }) {\n254 |   const {\n255 |     aiMaturityScore,\n256 |     businessNeedScore,\n257 |     dataReadinessScore,\n258 |     processComplexityScore,\n259 |     transformationReadinessScore,\n260 |   } = input;\n261 |   \n262 |   const score = \n263 |     (aiMaturityScore * 0.20) + \n264 |     (businessNeedScore * 0.25) + \n265 |     (dataReadinessScore * 0.20) + \n266 |     (processComplexityScore * 0.20) + \n267 |     (transformationReadinessScore * 0.15);\n268 |     \n269 |   return Math.round(score);\n270 | }\n271 | \n272 | export function getScoreCategory(score: number) {\n273 |   if (score <= 25) return \"AI Beginner\";\n274 |   if (score <= 50) return \"AI Explorer\";\n275 |   if (score <= 70) return \"AI Adopter\";\n276 |   if (score <= 85) return \"AI Transformer\";\n277 |   return \"AI-Native Leader\";\n278 | }\n279 | \n280 | export function getRecommendedOpportunities(industry: string, priorities: string[]) {\n281 |   const defaults = [\n282 |     \"Procurement Copilot\",\n283 |     \"HR Assistant\",\n284 |     \"Contract Intelligence\",\n285 |     \"Knowledge Search\",\n286 |     \"Executive Dashboard\"\n287 |   ];\n288 |   \n289 |   if (industry === \"Banking\" && priorities.includes(\"Strengthen Compliance\")) {\n290 |     return [\"Contract Intelligence\", \"Compliance Copilot\", \"Executive Dashboard\", \"Knowledge Search\", \"Risk Operations Assistant\"];\n291 |   }\n292 |   \n293 |   if (industry === \"Retail\" && (priorities.includes(\"Increase Revenue\") || priorities.includes(\"Improve Customer Experience\"))) {\n294 |     return [\"Customer Experience Copilot\", \"Store Operations Assistant\", \"Merchandising Intelligence\", \"Knowledge Search\", \"Executive Dashboard\"];\n295 |   }\n296 |   \n297 |   if (industry === \"Manufacturing\" && (priorities.includes(\"Improve Productivity\") || priorities.includes(\"Automate Processes\"))) {\n298 |     return [\"Maintenance Copilot\", \"Production Knowledge Search\", \"Procurement Copilot\", \"Quality Intelligence\", \"Executive Dashboard\"];\n299 |   }\n300 |   \n301 |   return defaults;\n302 | }\n303 | \n304 | export function getRecommendedSolutions(input: any) {\n305 |   return [\n306 |     \"Agent Factory™\",\n307 |     \"Knowledge Graph™\",\n308 |     \"AI Governance™\",\n309 |     \"Managed AI Operations™\"\n310 |   ];\n311 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/nav-data.ts","result":" 1 | export const navItems = [\n 2 |   { label: \"HOME\", href: \"/\" },\n 3 |   { label: \"WHY GFF AI\", href: \"/why-gff-ai\" },\n 4 |   { label: \"CAPABILITIES\", href: \"/capabilities\" },\n 5 |   { label: \"INDUSTRIES\", href: \"/industries\" },\n 6 |   { label: \"PLATFORMS\", href: \"/platforms\" },\n 7 |   { label: \"BUILD WITH GFF\", href: \"/build\" },\n 8 |   { label: \"RESOURCES\", href: \"/resources\" },\n 9 |   { label: \"COMPANY\", href: \"/company\" },\n10 |   { label: \"CONTACT\", href: \"/contact\" },\n11 |   { label: \"CLIENT LOGIN\", href: \"/portal\" },\n12 | ];","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/site-config.ts","result":" 1 | export const siteConfig = {\n 2 |   name: \"GFF AI\",\n 3 |   legalName: \"GFF AI\",\n 4 |   tagline: \"The Intelligent Enterprise Starts Here\",\n 5 |   description:\n 6 |     \"GFF AI delivers enterprise AI consulting, agentic automation, and intelligent systems from Garage to Foundry to Factory. Explore AI agents, industry solutions, productized assets, and transformation roadmaps.\",\