red: Secure admin transfer of \"${title}\" completed.`);\n313 |       alert(`[SECURE VAULT API] Administrator copy successfully transferred.\\n\\nDocument: ${title}\\nSHA-256 integrity checks completed over airgapped connection.`);\n314 |     }, 1500);\n315 |   };\n316 | \n317 |   // Toggle checklist inside drawer\n318 |   const handleToggleCheck = (docId: string, checkIndex: number) => {\n319 |     setDocuments(prevDocs => \n320 |       prevDocs.map(doc => {\n321 |         if (doc.id === docId) {\n322 |           const updatedChecks = [...doc.governanceChecks];\n323 |           updatedChecks[checkIndex] = {\n324 |             ...updatedChecks[checkIndex],\n325 |             checked: !updatedChecks[checkIndex].checked\n326 |           };\n327 |           return {\n328 |             ...doc,\n329 |             governanceChecks: updatedChecks,\n330 |             lastUpdated: new Date().toISOString()","success":true}],"durationMs":5}}
