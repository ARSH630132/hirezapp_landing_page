            status, dueDate: due || \"2026-07-15\", category: \"Compute Epoch\", clientId: cId,\n 85 |             clientName: cl ? cl.name : \"Sovereign Client\", projectId: pId,\n 86 |             projectName: pr ? pr.name : \"Enclave Sandbox\", hash, billingMonth: month\n 87 |           }, ...prev]);\n 88 |           setSigning(false);\n 89 |           setStep(0);\n 90 |           setIsOpen(false);\n 91 |           setCId(\"\"); setAmount(\"\");\n 92 |           triggerToast(`Sealed invoice ${id} successfully.`);\n 93 |           return 0;\n 94 |         });\n 95 |       }, 600);\n 96 |     }\n 97 |     return () => clearInterval(t);\n 98 |   }, [signing, cId, pId, amount, due, status, month, invoices.length]);\n 99 | \n100 |   const projects = useMemo(() => cId ? previewProjects.filter(p => p.clientAccountId === cId) : [], [cId]);\n101 |   \n102 |   useEffect(() => { \n103 |     if (projects.length > 0) {\n104 |       setPId(projects[0].id);\n105 |     } \n106 |   }, [projects]);\n107 | \n108 |   const stats = useMemo(() => {\n109 |     let total = 0, settled = 0, proc = 0, unp = 0;\n110 |     invoices.forEach(i => {\n111 |       total += i.amount;\n112 |       if (i.status === \"paid\") settled += i.amount;\n113 |       else if (i.status === \"processing\") proc += i.amount;\n114 |       else unp += i.amount;\n115 |     });\n116 |     return { total, settled, proc, unp, count: invoices.length };\n117 |   }, [invoices]);\n118 | \n119 |   const filtered = useMemo(() => {\n120 |     return invoices.filter(i => {\n121 |       if (query && !i.id.toLowerCase().includes(query.toLowerCase()) && !i.clientName.toLowerCase().includes(query.toLowerCase())) return false;\n122 |       if (selClient !== \"all\" && i.clientId !== selClient) return false;\n123 |       if (selStatus !== \"all\" && i.status !== selStatus) return false;\n124 |       if (selMonth !== \"all\" && i.billingMonth !== selMonth) return false;\n125 |       return true;\n126 |     });\n127 |   }, [invoices, query, selClient, selStatus, selMonth]);\n128 | \n129 |   const handleSettlePayment = (id: string) => {\n130 |     setIsProcessing(true);\n131 |     setTimeout(() => {\n132 |       setInvoices(p => p.map(i => i.id === id ? { ...i, status: \"paid\" } : i));\n133 |       setActive(p => p && p.id === id ? { ...p, status: \"paid\" } : p);\n134 |       setIsProcessing(false);\n135 |       triggerToast(`Ledger settled for ${id}.`);\n136 |     }, 1000);\n137 |   };\n138 | \n139 |   const handleDownload = (id: string) => {\n140 |     setIsDownloading(true);\n141 |     setTimeout(() => {\n142 |       setIsDownloading(false);\n143 |       triggerToast(`Receipt downloaded for ${id}`);\n144 |     }, 800);\n145 |   };\n146 | \n147 |   const formatUSD = (v: number) => new Intl.NumberFormat(\"en-US\", { style: \"currency\", currency: \"USD\" }).format(v);\n148 | \n149 |   return (\n150 |     <div className=\"space-y-6 text-zinc-100 pb-12\">\n151 |       {toast && (\n152 |         <div className=\"fixed top-6 right-6 z-50 px-4 py-3 rounded-xl border border-emerald-500/30 bg-black/95 text-emerald-400 backdrop-blur font-mono text-xs shadow-lg tracking-wide animate-fade-in\">\n153 |           <span>{toast}</span>\n154 |         </div>\n155 |       )}\n156 | \n157 |       <PrivatePageHeader \n158 |         title=\"FINANCIAL LEDGER OPERATIONS\" \n159 |         desc=\"Internal console to draft client invoice previews, audit HSM resource seals, and verify active contract cycles.\"\n160 |         actions={\n161 |           <button \n162 |             onClick={() => setIsOpen(true)} \n163 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10.5px] text-white flex items-center gap-1.5 transition-all border border-white/5 cursor-pointer font-bold uppercase tracking-wider\"\n164 |           >\n165 |             <Plus className=\"w-3.5 h-3.5\" />\n166 |             <span>Draft Invoice Preview</span>\n167 |           </button>\n168 |         }\n169 |       />\n170 | \n171 |       {/* RENDER_PIPELINE */}\n172 |       <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 p-5 space-y-4 relative overflow-hidden\">\n173 |         <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 border-b border-white/5 pb-3\">\n174 |           <div>\n175 |             <h4 className=\"text-xs font-bold tracking-widest text-white uppercase flex items-center gap-1.5 font-mono\">\n176 |               <Shield className=\"w-4 h-4 text-[#009DFF]\" />\n177 |               <span>SOVEREIGN CRYPTOGRAPHIC SIGNING FLOW</span>\n178 |             </h4>\n179 |             <p className=\"text-xs text-zinc-400 mt-0.5\">Continuous hardware-attested verification pipeline mapping cloud sandboxes to the administrative ledger.</p>\n180 |           </div>\n181 |           <div className=\"text-[10px] text-emerald-400 bg-emerald-500/5 px-2.5 py-0.5 rounded border border-emerald-500/20 uppercase font-bold font-mono tracking-wider shrink-0\">\n182 |             HSM Core Active\n183 |           </div>\n184 |         </div>\n185 | \n186 |         <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-2\">\n187 |           <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex gap-3 hover:border-white/10 transition-colors\">\n188 |             <Cpu className=\"w-5 h-5 text-[#009DFF] shrink-0\" />\n189 |             <div>\n190 |               <span className=\"text-xs font-bold text-zinc-200 block\">1. Ingest Telemetry</span>\n191 |               <p className=\"text-[11px] text-zinc-400 mt-1 leading-relaxed\">Continuous hardware credit utilization captured securely from active client sandboxes using kernel-level eBPF handlers.</p>\n192 |             </div>\n193 |           </div>\n194 |           <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex gap-3 hover:border-white/10 transition-colors\">\n195 |             <Key className=\"w-5 h-5 text-emerald-400 shrink-0\" />\n196 |             <div>\n197 |               <span className=\"text-xs font-bold text-zinc-200 block\">2. Seal HSM Block</span>\n198 |               <p className=\"text-[11px] text-zinc-400 mt-1 leading-relaxed\">Sovereign Hardware Security Enclaves generate dynamic ECDSA ECC-256 signatures over aggregated metrics.</p>\n199 |             </div>\n200 |           </div>\n201 |           <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex gap-3 hover:border-white/10 transition-colors\">\n202 |             <Database className=\"w-5 h-5 text-[#00FFC2] shrink-0\" />\n203 |             <div>\n204 |               <span className=\"text-xs font-bold text-zinc-200 block\">3. Commit Ledger</span>\n205 |               <p className=\"text-[11px] text-zinc-400 mt-1 leading-relaxed\">Sealed invoice blocks are mapped to the administrative index, creating an immutable history for auditing.</p>\n206 |             </div>\n207 |           </div>\n208 |         </div>\n209 |       </div>\n210 | \n211 |       {/* RENDER_STATS */}\n212 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n213 |         {[\n214 |           { l: \"Total Invoiced\", v: stats.total, c: \"text-white\" },\n215 |           { l: \"Settled Receipts\", v: stats.settled, c: \"text-emerald-400\" },\n216 |           { l: \"Awaiting Audit\", v: stats.proc, c: \"text-[#009DFF]\" },\n217 |           { l: \"Ledger Exposure\", v: stats.unp, c: \"text-rose-400\" }\n218 |         ].map((s, i) => (\n219 |           <div key={i} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-colors\">\n220 |             <span className=\"text-[10px] text-zinc-400 uppercase tracking-widest font-mono block\">{s.l}</span>\n221 |             <div className={`text-base font-extrabold mt-1.5 font-mono tracking-tight ${s.c}`}>\n222 |               {formatUSD(s.v)} <span className=\"text-[10px] text-zinc-500 font-normal\">USD</span>\n223 |             </div>\n224 |           </div>\n225 |         ))}\n226 |       </div>\n227 | \n228 |       {/* RENDER_FILTERS */}\n229 |       <div className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/30 grid grid-cols-1 sm:grid-cols-4 gap-3\">\n230 |         <div className=\"relative\">\n231 |           <input \n232 |             type=\"text\" \n233 |             placeholder=\"Query by ID, Client...\" \n234 |             value={query} \n235 |             onChange={e => setQuery(e.target.value)}\n236 |             className=\"w-full h-9 pl-3 pr-8 rounded bg-black/40 border border-white/5 text-xs text-white focus:outline-none focus:border-[#009DFF]/30 placeholder-white/30\"\n237 |           />\n238 |           <Search className=\"absolute right-2.5 top-2.5 w-4 h-4 text-white/20\" />\n239 |         </div>\n240 |         <select \n241 |           value={selClient} \n242 |           onChange={e => setSelClient(e.target.value)} \n243 |           className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-xs text-zinc-300 focus:outline-none appearance-none cursor-pointer hover:border-white/10\"\n244 |         >\n245 |           <option value=\"all\">Sovereign Client: All</option>\n246 |           {previewClientAccounts.map(c => (\n247 |             <option key={c.id} value={c.id}>{c.name.replace(\" [Preview Client]\", \"\")}</option>\n248 |           ))}\n249 |         </select>\n250 |         <select \n251 |           value={selStatus} \n252 |           onChange={e => setSelStatus(e.target.value)} \n253 |           className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-xs text-zinc-300 focus:outline-none appearance-none cursor-pointer hover:border-white/10\"\n254 |         >\n255 |           <option value=\"all\">Invoice Status: All</option>\n256 |           <option value=\"paid\">Paid</option>\n257 |           <option value=\"unpaid\">Unpaid</option>\n258 |           <option value=\"processing\">Processing</option>\n259 |           <option value=\"overdue\">Overdue</option>\n260 |         </select>\n261 |         <select \n262 |           value={selMonth} \n263 |           onChange={e => setSelMonth(e.target.value)} \n264 |           className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-xs text-zinc-300 focus:outline-none appearance-none cursor-pointer hover:border-white/10\"\n265 |         >\n266 |           <option value=\"all\">Billing Month: All</option>\n267 |           <option value=\"2026-06\">June 2026</option>\n268 |           <option value=\"2026-05\">May 2026</option>\n269 |         </select>\n270 |       </div>\n271 |       {/* RENDER_TABLE */}\n272 |       <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 overflow-hidden\">\n273 |         <div className=\"overflow-x-auto\">\n274 |           <table className=\"w-full text-left border-collapse\">\n275 |             <thead>\n276 |               <tr className=\"border-b border-white/5 bg-black/30 text-[10px] text-zinc-400 uppercase tracking-widest font-mono\">\n277 |                 <th className=\"py-3 px-5 font-bold\">Invoice ID</th>\n278 |                 <th className=\"py-3 px-5 font-bold\">Client</th>\n279 |                 <th className=\"py-3 px-5 font-bold\">Project</th>\n280 |                 <th className=\"py-3 px-5 font-bold\">Category</th>\n281 |                 <th className=\"py-3 px-5 font-bold text-right\">Amount (USD)</th>\n282 |                 <th className=\"py-3 px-5 font-bold text-center\">Due Date</th>\n283 |                 <th className=\"py-3 px-5 font-bold text-center\">Status</th>\n284 |                 <th className=\"py-3 px-5 font-bold text-center\">Seal Hash</th>\n285 |                 <th className=\"py-3 px-5\"></th>\n286 |               </tr>\n287 |             </thead>\n288 |             <tbody className=\"divide-y divide-white/[0.03] text-xs\">\n289 |               {filtered.length === 0 ? (\n290 |                 <tr>\n291 |                   <td colSpan={9} className=\"py-12 text-center text-zinc-500 font-mono\">\n292 |                     No matching ledger blocks found.\n293 |                   </td>\n294 |                 </tr>\n295 |               ) : (\n296 |                 filtered.map(i => (\n297 |                   <tr \n298 |                     key={i.id} \n299 |                     onClick={() => setActive(i)} \n300 |                     className=\"hover:bg-white/[0.02] transition-all cursor-pointer group\"\n301 |                   >\n302 |                     <td className=\"py-3.5 px-5 font-bold text-[#009DFF] font-mono\">{i.id}</td>\n303 |                     <td className=\"py-3.5 px-5 text-zinc-200 font-semibold\">{i.clientName.replace(\" [Preview Client]\", \"\")}</td>\n304 |                     <td className=\"py-3.5 px-5 text-zinc-400\">{i.projectName}</td>\n305 |                     <td className=\"py-3.5 px-5 text-zinc-500 text-[9.5px] uppercase tracking-wider font-mono\">{i.category}</td>\n306 |                     <td className=\"py-3.5 px-5 text-right font-bold text-white font-mono\">${i.amount.toLocaleString()}</td>\n307 |                     <td className=\"py-3.5 px-5 text-center text-zinc-400 font-mono\">{i.dueDate}</td>\n308 |                     <td className=\"py-3.5 px-5 text-center\">\n309 |                       <span className={`px-2 py-0.5 rounded text-[9px] uppercase border font-bold font-mono tracking-wider ${\n310 |                         i.status === \"paid\" ? \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\" :\n311 |                         i.status === \"unpaid\" ? \"bg-amber-400/10 text-amber-400 border-amber-400/25\" :\n312 |                         i.status === \"processing\" ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\" :\n313 |                         \"bg-rose-500/10 text-rose-400 border-rose-500/25\"\n314 |                       }`}>\n315 |                         {i.status}\n316 |                       </span>\n317 |                     </td>\n318 |                     <td className=\"py-3.5 px-5 text-center text-zinc-500 text-[10px] font-mono\">{i.hash.slice(0, 10)}...</td>\n319 |                     <td className=\"py-3.5 px-5 text-center text-white/20 group-hover:text-[#009DFF] transition-colors\">\n320 |                       <ChevronRight className=\"w-4 h-4 translate-x-0 group-hover:translate-x-0.5 transition-transform\" />\n321 |                     </td>\n322 |                   </tr>\n323 |                 ))\n324 |               )}\n325 |             </tbody>\n326 |           </table>\n327 |         </div>\n328 |       </div>\n329 |       {/* RENDER_DRAWER */}\n330 |       {active && (\n331 |         <div className=\"fixed inset-0 z-40 flex justify-end\">\n332 |           <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onClick={() => setActive(null)} />\n333 |           <div className=\"w-full max-w-md bg-[#050505] border-l border-white/5 relative z-10 p-6 flex flex-col justify-between h-full text-xs\">\n334 |             <div className=\"space-y-6\">\n335 |               <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n336 |                 <div>\n337 |                   <span className=\"text-[9px] text-[#009DFF] uppercase font-bold tracking-widest font-mono block\">Ledger Block Details</span>\n338 |                   <h3 className=\"text-sm font-extrabold text-white mt-1 font-mono tracking-wide\">{active.id}</h3>\n339 |                 </div>\n340 |                 <button \n341 |                   onClick={() => setActive(null)} \n342 |                   className=\"p-1 rounded border border-white/5 text-white/40 cursor-pointer hover:bg-white/5 hover:text-white transition-colors\"\n343 |                 >\n344 |                   <X className=\"w-4 h-4\" />\n345 |                 </button>\n346 |               </div>\n347 | \n348 |               <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex justify-between items-center\">\n349 |                 <div>\n350 |                   <