\n        <div className=\"max-w-xl w-full p-6 rounded-[20px] border border-red-500/15 bg-[#050505]/80 backdrop-blur-md space-y-5 relative shadow-2xl\">\n          <div className=\"absolute top-0 left-0 w-full h-1 bg-red-500\" />\n          <div className=\"flex items-center gap-3\">\n            <ShieldAlert className=\"w-8 h-8 text-red-500\" />\n            <div>\n              <span className=\"text-[8px] text-red-500 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded font-bold uppercase tracking-widest\">RESTRICTED BOUNDARY</span>\n              <h2 className=\"text-xs font-bold uppercase tracking-wider text-white\">Clearance Insufficient</h2>\n            </div>\n          </div>\n          <p className=\"text-[11px] text-white/60 leading-relaxed\">\n            Simulated role <strong className=\"text-red-400\">{session.role.toUpperCase()}</strong> holds insufficient clearance for <strong className=\"text-white\">/{type}/{activeSec}</strong>. This path requires <strong className=\"text-[#009DFF]\">L5 Administrator</strong> credentials.\n          </p>\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl text-[10px] space-y-1\">\n            <div className=\"text-white font-bold\">Session: {session.name}</div>\n            <div className=\"text-white/45\">Role Level: {session.clearance}</div>\n          </div>\n          \n          <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n            <button onClick={() => router.push(type === \"portal\" ? \"/portal/dashboard\" : \"/admin/dashboard\")} className=\"flex-1 h-10 rounded-lg border border-white/10 hover:border-white/20 text-white text-[10px] font-bold uppercase tracking-wider transition-all cursor-pointer\">\n              Return to Safety\n            </button>\n            <button onClick={() => handleInstantBypass(\"gff_admin\")} disabled={negotiating !== null} className=\"flex-1 h-10 rounded-lg bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 hover:to-red-600 text-white text-[10px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center justify-center gap-1\">\n              {negotiating ? <RefreshCw className=\"w-3 h-3 animate-spin\" /> : <Key className=\"w-3.5 h-3.5\" />}\n              Elevate to GFF Admin\n            </button>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  // 3. ADMIN IN PORTAL LAYOUT: Show an elegant context banner with workspace switch helper\n  const isAdminInPortal = type === \"portal\" && session && session.role.startsWith(\"gff_\");\n\n  return (\n    <>\n      {isAdminInPortal && !dismissBanner && (\n        <div className=\"sticky top-8 z-40 bg-gradient-to-r from-cyan-950/30 to-black border-b border-cyan-500/20 px-4 md:px-6 py-2 flex items-center justify-between text-[11px] font-mono text-cyan-200 backdrop-blur-md select-none\">\n          <div className=\"flex items-center gap-2\">\n            <span className=\"relative flex h-1.5 w-1.5\">\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\"></span>\n              <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-cyan-500\"></span>\n            </span>\n            <span><strong>ADMIN ENCLAVE CONTEXT:</strong> Simulating Client Portal with L5 clearance.</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <button \n              onClick={() => handleInstantBypass(\"client_admin\")}\n              disabled={negotiating !== null}\n              className=\"px-2.5 py-0.5 rounded bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-400/25 text-cyan-300 hover:text-cyan-200 text-[9px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center gap-1\"\n            >\n              {negotiating ? <RefreshCw className=\"w-2.5 h-2.5 animate-spin\" /> : <Sparkles className=\"w-2.5 h-2.5 text-cyan-400\" />}\n              Switch to Client Admin\n            </button>\n            <button onClick={() => setDismissBanner(true)} className=\"text-white/30 hover:text-white/75 transition-colors text-[9.5px] cursor-pointer\">\n              [Dismiss]\n            </button>\n          </div>\n        </div>\n      )}\n      {children}\n    </>\n  );\n}\n"}}}
