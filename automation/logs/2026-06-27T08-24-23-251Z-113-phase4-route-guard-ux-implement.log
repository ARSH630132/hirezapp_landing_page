 <div>\n              <span className=\"text-[8px] text-red-500 bg-red-500/10 px-2 py-0.5 rounded font-bold uppercase\">RESTRICTED BOUNDARY</span>\n              <h2 className=\"text-xs font-bold uppercase text-white\">Clearance Insufficient</h2>\n            </div>\n          </div>\n          <p className=\"text-[11px] text-white/60 leading-relaxed\">\n            Simulated role <strong className=\"text-red-400\">{session.role.toUpperCase()}</strong> cannot access <strong className=\"text-white\">/{type}/{activeSec}</strong>.\n            This demonstrates GFF AI's multi-tenant RBAC separation. Use the top-right switcher to bypass.\n          </p>\n          <div className=\"p-3 bg-white/[0.02] border border-white/5 rounded-xl text-[10px] space-y-1\">\n            <div className=\"text-white font-bold\">Session ID: {session.name}</div>\n            <div className=\"text-white/45\">Role Level: {session.clearance}</div>\n          </div>\n          <button onClick={() => router.push(type === \"portal\" ? \"/portal/dashboard\" : \"/admin/dashboard\")} className=\"w-full h-10 rounded-lg border border-white/10 text-white text-[10px] font-bold uppercase\">\n            Return to Dashboard\n          </button>\n          <p className=\"text-center text-[8px] text-white/30\"><strong>FRONTEND PREVIEW ONLY:</strong> Production auth connects in the backend phase.</p>\n        </div>\n      </div>\n    );\n  }\n\n  return <>{children}</>;\n}","new_text":"\"use client\";\n\nimport React, { useEffect, useState } from \"react\";\nimport { usePathname, useRouter } from \"next/navigation\";\nimport { ShieldAlert, Lock, ArrowLeft, RefreshCw, Key, Terminal, Shield, Sparkles } from \"lucide-react\";\nimport { \n  getPreviewSession, \n  setPreviewSession,\n  canAccessPortalSection, \n  canAccessAdminSection, \n  PreviewSession,\n  PreviewRole\n} from \"@/lib/preview-auth\";\n\nexport function PreviewRouteGuard({ children, type }: { children: React.ReactNode; type: \"portal\" | \"admin\" }) {\n  const router = useRouter();\n  const pathname = usePathname();\n  const [session, setSession] = useState<PreviewSession | null>(null);\n  const [mounted, setMounted] = useState(false);\n  const [loading, setLoading] = useState(true);\n  const [hasAccess, setHasAccess] = useState(false);\n  const [activeSec, setActiveSec] = useState(\"\");\n  const [countdown, setCountdown] = useState(4);\n  const [negotiating, setNegotiating] = useState<string | null>(null);\n  const [dismissBanner, setDismissBanner] = useState(false);\n\n  useEffect(() => {\n    setMounted(true);\n  }, []);\n\n  useEffect(() => {\n    if (!mounted) return;\n    const verifyAccess = () => {\n      const s = getPreviewSession();\n      setSession(s);\n      if (!s) {\n        setHasAccess(false);\n        setLoading(false);\n        return;\n      }\n      const segments = pathname.split(\"/\");\n      const sec = segments[2] || \"dashboard\";\n      setActiveSec(sec);\n      const ok = type === \"portal\" ? canAccessPortalSection(s.role, sec) : canAccessAdminSection(s.role, sec);\n      setHasAccess(ok);\n      setLoading(false);\n    };\n\n    verifyAccess();\n    const cb = () => verifyAccess();\n    window.addEventListener(\"gff_preview_session_changed\", cb);\n    return () => window.removeEventListener(\"gff_preview_session_changed\", cb);\n  }, [pathname, type, mounted]);\n\n  // Safe redirect if no session exists\n  useEffect(() => {\n    if (!mounted || loading || session) return;\n    const interval = setInterval(() => {\n      setCountdown((prev) => {\n        if (prev <= 1) {\n          clearInterval(interval);\n          router.push(\"/portal/login\");\n          return 0;\n        }\n        return prev - 1;\n      });\n    }, 1000);\n    return () => clearInterval(interval);\n  }, [session, loading, mounted, router]);\n\n  const handleInstantBypass = (role: PreviewRole) => {\n    setNegotiating(role);\n    setTimeout(() => {\n      setPreviewSession(role);\n      setNegotiating(null);\n      if (role.startsWith(\"client_\")) {\n        router.push(\"/portal/dashboard\");\n      } else {\n        router.push(\"/admin/dashboard\");\n      }\n    }, 1000);\n  };\n\n  if (!mounted) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n        <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto mb-2\" />\n        <p className=\"text-[9px] uppercase tracking-wider text-white/30\">Initializing Secure Handshake...</p>\n      </div>\n    );\n  }\n\n  if (loading) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n        <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto mb-2\" />\n        <p className=\"text-[10px] uppercase tracking-widest text-white/40\">Verifying Sandbox Clearance...</p>\n      </div>\n    );\n  }\n\n  // 1. NO SESSION: Premium \"Session Expired / Authenticate Required\" View with Auto-Redirect\n  if (!session) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono p-4 relative overflow-hidden\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(rgba(228,0,15,0.012)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n        <div className=\"max-w-md w-full p-6 rounded-[20px] border border-white/5 bg-[#050505]/80 backdrop-blur-md text-center space-y-5 relative shadow-2xl\">\n          <Lock className=\"w-8 h-8 text-red-500 mx-auto animate-pulse\" />\n          <span className=\"text-[8px] text-red-500 bg-red-500/5 border border-red-500/15 px-2.5 py-0.5 rounded-full font-bold tracking-widest\">AUTHENTICATION REQUIRED</span>\n          <h2 className=\"text-xs font-bold uppercase tracking-wider text-white\">Enclave Session Expired</h2>\n          <p className=\"text-[10px] text-white/50 leading-relaxed\">No simulated