sing on providing users a direct method to bypass clearance requirements. This will be triggered from the top-right switcher to bypass restrictions. I am designing a prominent \"Elevate Session\" button. This will improve the user experience, while also allowing me to test functionality.\n\n\n**Implementing Role Elevation**\n\nI'm now integrating instant role switching directly into the error UI, eliminating the need for a separate top-right switcher. My design also incorporates a dynamic diagnostic log that'll display security guard activity, for transparency. I am incorporating a new UI update with a beautiful, sleek layout that fits GFF AI's dark theme. I'm focusing on high readability and code quality for `PreviewRouteGuard.tsx`.\n\n\n**Defining UI Redirection**\n\nI'm now determining the optimal UI for redirection when a preview session is absent. My plan is to start an automatic countdown timer, clearly stating, \"Redirecting to Identity Gateway in 3 seconds...\". This will be displayed. I'll utilize standard `router.push()` or `window.location.reload()` for the actual redirection. I'm also carefully verifying import paths and identifying potential exports and imports, like `AnimatePresence`, `motion`, and Tailwind animations for performance.\n\n\n"}}
{"ts":"2026-06-27T08:20:20.530Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"e5tf6b9s","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/PreviewRouteGuard.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useEffect, useState } from \"react\";\nimport { usePathname, useRouter } from \"next/navigation\";\nimport { \n  ShieldAlert, Lock, ArrowLeft, RefreshCw, Key, Fingerprint, \n  CheckCircle, Server, Terminal, Shield, ChevronRight, Users, Sparkles\n} from \"lucide-react\";\nimport { \n  getPreviewSession, \n  setPreviewSession,\n  canAccessPortalSection, \n  canAccessAdminSection, \n  PreviewSession,\n  MOCK_PREVIEW_USERS,\n  PreviewRole\n} from \"@/lib/preview-auth\";\n\nexport function PreviewRouteGuard({ children, type }: { children: React.ReactNode; type: \"portal\" | \"admin\" }) {\n  const router = useRouter();\n  const pathname = usePathname();\n  const [session, setSession] = useState<PreviewSession | null>(null);\n  const [mounted, setMounted] = useState(false);\n  const [loading, setLoading] = useState(true);\n  const [hasAccess, setHasAccess] = useState(false);\n  const [activeSec, setActiveSec] = useState(\"\");\n  const [countdown, setCountdown] = useState(4);\n  const [negotiating, setNegotiating] = useState<string | null>(null);\n  const [dismissBanner, setDismissBanner] = useState(false);\n\n  // Initial mount check for hydration safety\n  useEffect(() => {\n    setMounted(true);\n  }, []);\n\n  useEffect(() => {\n    if (!mounted) return;\n\n    const verifyAccess = () => {\n      const s = getPreviewSession();\n      setSession(s);\n      \n      if (!s) {\n        setHasAccess(false);\n        setLoading(false);\n        return;\n      }\n      \n      const segments = pathname.split(\"/\");\n      const sec = segments[2] || \"dashboard\";\n      setActiveSec(sec);\n      \n      const ok = type === \"portal\" \n        ? canAccessPortalSection(s.role, sec) \n        : canAccessAdminSection(s.role, sec);\n      \n      setHasAccess(ok);\n      setLoading(false);\n    };\n\n    verifyAccess();\n    const cb = () => verifyAccess();\n    window.addEventListener(\"gff_preview_session_changed\", cb);\n    return () => window.removeEventListener(\"gff_preview_session_changed\", cb);\n  }, [pathname, type, mounted]);\n\n  // Automatic redirect countdown if no session exists\n  useEffect(() => {\n    if (!mounted || loading || session) return;\n\n    const interval = setInterval(() => {\n      setCountdown((prev) => {\n        if (prev <= 1) {\n          clearInterval(interval);\n          router.push(\"/portal/login\");\n          return 0;\n        }\n        return prev - 1;\n      });\n    }, 1000);\n\n    return () => clearInterval(interval);\n  }, [session, loading, mounted, router]);\n\n  const handleInstantBypass = (role: PreviewRole) => {\n    setNegotiating(role);\n    setTimeout(() => {\n      setPreviewSession(role);\n      setNegotiating(null);\n      // Reload current layout or push to appropriate dashboard\n      if (role.startsWith(\"client_\")) {\n        router.push(\"/portal/dashboard\");\n      } else {\n        router.push(\"/admin/dashboard\");\n      }\n    }, 1200);\n  };\n\n  const handleSwitchWorkspace = () => {\n    setNegotiating(\"client_admin\");\n    setTimeout(() => {\n      setPreviewSession(\"client_admin\");\n      setNegotiating(null);\n      router.push(\"/portal/dashboard\");\n    }, 800);\n  };\n\n  // Render a loading state during hydration to avoid mismatched UI\n  if (!mounted) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n        <div className=\"text-center space-y-3\">\n          <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto\" />\n          <p className=\"text-[9px] uppercase tracking-wider text-white/30\">Initializing Secure Handshake...</p>\n        </div>\n      </div>\n    );\n  }\n\n  if (loading) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n        <div className=\"text-center space-y-3\">\n          <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto\" />\n          <p className=\"text-[10px] uppercase tracking-widest text-white/40\">Verifying Sandbox Clearance...</p>\n        </div>\n      </div>\n    );\n  }\n\n  // 1. NO LOCAL SESSION DETECTED: Show elegant \"Clearance Expired / Auth Required\" view\n  if (!session) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center font-mono p-4 relative overflow-hidden\">\n        {/* Abstract Background Grid */}\n        <div className=\"absolute inset-0 bg-[radial-gradient(rgba(228,0,15,0.015)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n        <div className=\"absolute top-1/4 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-red-500/[0.01] rounded-full blur-[120px] pointer-events-none\" />\n\n        <div className=\"max-w-lg w-full p-8 rounded-[24px] border border-white/5 bg-[#050505]/85 backdrop-blur-md space-y-6 relative shadow-2xl\">\n          <div className=\"absolute top-0 left-1/4 right-1/4 h-px bg-gradient-to-r from-transparent via-red-500/40 to-transparent\" />\n          \n          <div className=\"text-center space-y-4\">\n            <div className=\"h-12 w-12 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mx-auto shadow-[0_0_20px_rgba(239,68,68,0.15)]\">\n              <Lock className=\"w-5 h-5 text-red-400\" />\n            </div>\n            <div>\n              <span className=\"text-[9px] text-red-400 bg-red-400/5 border border-red-400/15 px-3 py-0.5 rounded-full font-bold uppercase tracking-widest\">\n                AUTHENTICATION REQUIRED\n              </span>\n              <h2 className=\"text-[16px] font-bold uppercase tracking-wider text-white mt-3\">Enclave Clearance Expired</h2>\n              <p className=\"text-[11px] text-white/50 max-w-[340px] mx-auto leading-relaxed mt-1.5\">\n                No active simulated sandbox session was found. Secure tunnels must have validated keys to establish sockets.\n              </p>\n            </div>\n          </div>\n\n          {/* Simulated Cryptographic Diagnostic Logs */}\n          <div className=\"p-4 bg-black/40 border border-white/5 rounded-xl text-[10px] space-y-2 font-mono text-white/45 relative overflow-hidden\">\n            <div className=\"absolute top-1.5 right-2 flex items-center gap-1\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-red-500 animate-ping\" />\n              <span className=\"text-[7.5px] text-red-500 uppercase font-bold\">DISCONNECTED</span>\n            </div>\n            <div className=\"text-[8px] font-bold text-white/30 uppercase tracking-widest border-b border-white/5 pb-1 flex items-center gap-1.5\">\n              <Terminal className=\"w-3 h-3 text-white/30\" />\n              Gateway Diagnostics\n            </div>\n            <div className=\"space-y-1 text-[9.5px]\">\n              <div><span className=\"text-white/20\">00:01:</span> [SEC_DAEMON] Scanning storage threads... <span className=\"text-red-400\">FAILED</span></div>\n              <div><span className=\"text-white/20\">00:02:</span> [SEC_DAEMON] Missing zero-trust session token</div>\n              <div><span className=\"text-white/20\">00:03:</span> [SEC_DAEMON] Thread isolated. Enforcing redirect fallback...</div>\n            </div>\n          </div>\n\n          <div className=\"space-y-3\">\n            <button \n              onClick={() => router.push(\"/portal/login\")} \n              className=\"w-full h-11 rounded-xl bg-white text-black hover:bg-white/90 font-bold text-[11px] uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer shadow-lg active:scale-[0.99]\"\n            >\n              <Fingerprint className=\"w-4 h-4 text-black\" />\n              Identity Gateway ({countdown}s)\n              <ChevronRight className=\"w-3.5 h-3.5\" />\n            </button>\n\n            {/* Quick-Access Auto-Authenticate Bypasses for reviewers */}\n            <div className=\"pt-2 border-t border-white/5\">\n              <div className=\"text-[8px] font-bold text-white/20 uppercase tracking-widest text-center mb-3\">\n                Reviewer Quick Pass (Instant Auth)\n              </div>\n              <div className=\"grid grid-cols-2 gap-2\">\n                <button\n                  onClick={() => handleInstantBypass(\"client_admin\")}\n                  disabled={negotiating !== null}\n                  className=\"h-10 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] font-bold text-white/70 hover:text-white transition-all uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer disabled:opacity-50\"\n                >\n                  {negotiating === \"client_admin\" ? (\n                    <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin\" />\n                  ) : (\n                    <Users className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  )}\n                  Client Portal\n                </button>\n                <button\n                  onClick={() => handleInstantBypass(\"gff_admin\")}\n                  disabled={negotiating !== null}\n                  className=\"h-10 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] font-bold text-white/70 hover:text-white transition-all uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer disabled:opacity-50\"\n                >\n                  {negotiating === \"gff_admin\" ? (\n                    <RefreshCw className=\"w-3.5 h-3.5 text-red-400 animate-spin\" />\n                  ) : (\n                    <Shield className=\"w-3.5 h-3.5 text-red-400\" />\n                  )}\n                  Admin Panel\n                </button>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"text-center text-[8.5px] text-white/30 leading-normal\">\n            <strong>FRONTEND PREVIEW ONLY:</strong> Production zero-trust handshakes connect to AWS Enclaves.\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  // 2. CLEARANCE INSUFFICIENT: Elegant \"Access Restricted\" screen (e.g. Client trying to access /admin)\n  if (!hasAccess) {\n    return (\n      <div className=\"min-h-[85vh] w-full bg-[#030303] text-white flex items-center justify-center font-mono p-4 md:p-8 relative overflow-hidden\">\n        {/* Background Grid Accent */}\n        <div className=\"absolute inset-0 bg-[radial-gradient(rgba(228,0,15,0.012)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none\" />\n        <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-red-500/[0.01] rounded-full blur-[140px] pointer-events-none\" />\n\n        <div className=\"max-w-2xl w-full p-8 rounded-[24px] border border-red-500/15 bg-[#050505]/75 backdrop-blur-md space-y-6 relative shadow-3xl\">\n          <div className=\"absolute top-0 left-0 w-full h-1 bg-red-500/50 shadow-[0_2px_15px_rgba(239,68,68,0.3)]\" />\n          \n          <div className=\"flex flex-col sm:flex-row items-center sm:items-start gap-4 text-center sm:text-left border-b border-white/5 pb-5\">\n            <div className=\"h-14 w-14 rounded-2xl bg-red-500/10 border border-red-500/25 flex items-center justify-center shrink-0 shadow-[0_0_25px_rgba(239,68,68,0.15)]\">\n              <ShieldAlert className=\"w-7 h-7 text-red-500 animate-pulse\" />\n            </div>\n            <div>\n              <span className=\"inline-block text-[9px] text-red-500 bg-red-500/10 border border-red-500/20 px-2.5 py-0.5 rounded font-bold uppercase tracking-widest\">\n                ZERO-TRUST BOUNDARY DENIAL\n              </span>\n              <h2 className=\"text-[17px] font-black uppercase tracking-wider text-white mt-2\">\n                Clearance Level Insufficient\n              </h2>\n              <p className=\"text-[11.5px] text-white/50 leading-relaxed mt-1.5 max-w-lg\">\n                Your simulated role <strong className=\"text-red-400\">{session.role.toUpperCase()}</strong> holds <strong className=\"text-white\">{session.clearance.split(\" \")[2] || \"L3\"}</strong> credentials. Access to <strong className=\"text-white\">/{type}/{activeSec}</strong> requires <strong className=\"text-[#009DFF]\">L5 Administrator Enclave</strong>.\n              </p>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            {/* Thread Details */}\n            <div className=\"p-4 bg-white/[0.01] border border-white/5 rounded-xl space-y-2 text-[10.5px]\">\n              <div className=\"text-[8.5px] font-extrabold text-white/35 uppercase tracking-wider flex items-center gap-1.5\">\n                <Server className=\"w-3.5 h-3.5 text-white/20\" />\n                Isolated Session Details\n              </div>\n              <div className=\"space-y-1 text-white/60 font-mono\">\n                <div><span className=\"text-white/30\">ID Thread:</span> <span className=\"text-white\">{session.name}</span></div>\n                <div><span className=\"text-white/30\">User ID:</span> <span className=\"text-white truncate block\">{session.email}</span></div>\n                <div><span className=\"text-white/30\">Clearance:</span> <span className=\"text-red-400\">{session.clearance}</span></div>\n              </div>\n            </div>\n\n            {/* Cryptographic Policy Logs */}\n            <div className=\"p-4 bg-black/40 border border-white/5 rounded-xl space-y-1.5 text-[9.5px] font-mono text-white/40\">\n              <div className=\"text-[8px] font-bold text-white/30 uppercase tracking-widest border-b border-white/5 pb-1 flex items-center gap-1\">\n                <Terminal className=\"w-3 h-3 text-white/30\" />\n                Sovereign Guard Logs\n              </div>\n              <div>[GUARD] Boundary: <span className=\"text-red-400\">/{type}/{activeSec}</span></div>\n              <div>[GUARD] Evaluated token clearance: <span className=\"text-white\">{session.role}</span></div>\n              <div>[GUARD] Policy: <span className=\"text-red-500 font-bold\">DENY</span> (Reason: ISO-27001-A.9.2.1)</div>\n            </div>\n          </div>\n\n          {/* Strategic Actions for testing */}\n          <div className=\"pt-2 border-t border-white/5 space-y-3\">\n            <div className=\"text-[8.5px] font-bold text-white/30 uppercase tracking-widest text-center\">\n              Boundary Actions (Preview Simulation Controls)\n            </div>\n            \n            <div className=\"flex flex-col sm:flex-row gap-3\">\n              <button \n                onClick={() => router.push(type === \"portal\" ? \"/portal/dashboard\" : \"/admin/dashboard\")} \n                className=\"flex-1 h-11 rounded-xl border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.03] text-white text-[11px] font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer active:scale-[0.98]\"\n              >\n                <ArrowLeft className=\"w-4 h-4 text-white/60\" />\n                Return to Safety\n              </button>\n              \n              <button \n                onClick={() => handleInstantBypass(\"gff_admin\")}\n                disabled={negotiating !== null}\n                className=\"flex-1 h-11 rounded-xl bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 hover:to-red-600 text-white text-[11px] font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer shadow-[0_0_20px_rgba(239,68,68,0.2)] active:scale-[0.98] disabled:opacity-50\"\n              >\n                {negotiating === \"gff_admin\" ? (\n                  <RefreshCw className=\"w-4 h-4 animate-spin text-white\" />\n                ) : (\n                  <Key className=\"w-4 h-4 text-white\" />\n                )}\n                Elevate to L5 Admin\n              </button>\n            </div>\n          </div>\n\n          <p className=\"text-center text-[8.5px] text-white/30 font-mono\">\n            <strong>FRONTEND PREVIEW ONLY:</strong> Production RBAC utilizes cryptographically structured claims.\n          </p>\n        </div>\n      </div>\n    );\n  }\n\n  // 3. SECURE RENDER COHERENT WORKSPACE CONTEXT:\n  // If an Admin opens /portal pages, we show an premium, clean interactive banner allowing them to context switch easily\n  const isAdminInPortal = type === \"portal\" && session && session.role.startsWith(\"gff_\");\n\n  return (\n    <>\n      {isAdminInPortal && !dismissBanner && (\n        <div className=\"sticky top-8 z-40 bg-gradient-to-r from-cyan-950/40 via-blue-950/30 to-black border-b border-cyan-500/20 px-4 md:px-6 py-2.5 flex flex-col sm:flex-row items-center justify-between text-xs font-mono text-cyan-200 gap-3 backdrop-blur-md select-none\">\n          <div className=\"flex items-center gap-2.5 text-center sm:text-left\">\n            <span className=\"relative flex h-2 w-2\">\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\"></span>\n              <span className=\"relative inline-flex rounded-full h-2 w-2 bg-cyan-500\"></span>\n            </span>\n            <span className=\"text-[10px] uppercase tracking-wider\">\n              <strong>ADMIN ACTIVE CONTEXT:</strong> Simulating Portal as <strong className=\"text-white\">{session.role.toUpperCase()} (L5)</strong>\n            </span>\n          </div>\n          <div className=\"flex items-center gap-4\">\n            <button \n              onClick={handleSwitchWorkspace}\n              disabled={negotiating !== null}\n              className=\"px-3 py-1 rounded bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-400/25 text-cyan-300 hover:text-cyan-200 text-[9.5px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center gap-1.5\"\n            >\n              {negotiating === \"client_admin\" ? (\n                <RefreshCw className=\"w-3 h-3 animate-spin\" />\n              ) : (\n                <Sparkles className=\"w-3 h-3 text-cyan-400\" />\n              )}\n              Switch to Client Admin\n            </button>\n            <button \n              onClick={() => setDismissBanner(true)}\n              className=\"text-white/35 hover:text-white/70 transition-colors text-[10px] cursor-pointer\"\n              title=\"Dismiss warning\"\n            >\n              [Dismiss]\n            </button>\n          </div>\n        </div>\n      )}\n\n      {children}\n    </>\n  );\n}\n"}}}
