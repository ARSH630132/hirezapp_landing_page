rd\" : \"/admin/dashboard\")} className=\"flex-1 h-10 rounded-lg border border-white/10 hover:border-white/20 text-white text-[10px] font-bold uppercase tracking-wider\">\n              Return to Safety\n            </button>\n            <button onClick={() => handleBypass(\"gff_admin\")} className=\"flex-1 h-10 rounded-lg bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 hover:to-red-600 text-white text-[10px] font-bold uppercase tracking-wider flex items-center justify-center gap-1 cursor-pointer\">\n              {negotiating ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <Key className=\"w-3.5 h-3.5\" />}\n              Elevate to GFF Admin\n            </button>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const isAdminInPortal = type === \"portal\" && session && session.role.startsWith(\"gff_\");\n\n  return (\n    <>\n      {isAdminInPortal && !dismissBanner && (\n        <div className=\"sticky top-8 z-40 bg-gradient-to-r from-cyan-950/30 to-black border-b border-cyan-500/20 px-4 md:px-6 py-2 flex items-center justify-between text-[11px] font-mono text-cyan-200 backdrop-blur-md select-none\">\n          <div className=\"flex items-center gap-2\">\n            <span className=\"relative flex h-1.5 w-1.5\">\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\"></span>\n              <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-cyan-500\"></span>\n            </span>\n            <span><strong>ADMIN ENCLAVE ACTIVE:</strong> Simulating Client Portal with L5 clearance.</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <button \n              onClick={() => handleBypass(\"client_admin\")}\n              className=\"px-2.5 py-0.5 rounded bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-400/25 text-cyan-300 hover:text-cyan-200 text-[9.5px] font-bold uppercase tracking-wider transition-all cu