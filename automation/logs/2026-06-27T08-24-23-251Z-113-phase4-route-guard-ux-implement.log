onst pathname = usePathname();\n  const [session, setSession] = useState<PreviewSession | null>(null);\n  const [mounted, setMounted] = useState(false);\n  const [loading, setLoading] = useState(true);\n  const [hasAccess, setHasAccess] = useState(false);\n  const [activeSec, setActiveSec] = useState(\"\");\n  const [countdown, setCountdown] = useState(4);\n  const [negotiating, setNegotiating] = useState<string | null>(null);\n  const [dismissBanner, setDismissBanner] = useState(false);\n\n  useEffect(() => { setMounted(true); }, []);\n\n  useEffect(() => {\n    if (!mounted) return;\n    const verify = () => {\n      const s = getPreviewSession();\n      setSession(s);\n      if (!s) { setHasAccess(false); setLoading(false); return; }\n      const sec = pathname.split(\"/\")[2] || \"dashboard\";\n      setActiveSec(sec);\n      setHasAccess(type === \"portal\" ? canAccessPortalSection(s.role, sec) : canAccessAdminSection(s.role, sec));\n      setLoading(false);\n    };\n    verify();\n    window.addEventListener(\"gff_preview_session_changed\", verify);\n    return () => window.removeEventListener(\"gff_preview_session_changed\", verify);\n  }, [pathname, type, mounted]);\n\n  useEffect(() => {\n    if (!mounted || loading || session) return;\n    const interval = setInterval(() => {\n      setCountdown((p) => {\n        if (p <= 1) { clearInterval(interval); router.push(\"/portal/login\"); return 0; }\n        return p - 1;\n      });\n    }, 1000);\n    return () => clearInterval(interval);\n  }, [session, loading, mounted, router]);\n\n  const handleBypass = (role: PreviewRole) => {\n    setNegotiating(role);\n    setTimeout(() => {\n      setPreviewSession(role);\n      setNegotiating(null);\n      router.push(role.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n    }, 900);\n  };\n\n  if (!mounted) return <div className=\"min-h-screen bg-[#030303]\" />;\n  if (loading) {\n    return (\n      <div className=\"min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n        <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mb-2\" />\n        <p className=\"text-[10px] uppercase tracking-wider text-white/40\">Verifying Sandbox Clearance...</p>\n      </div>\n    );\n  }\n\n  if (!session) {\n    return (\n      <div className=\"min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center font-mono p-4\">\n        <div className=\"max-w-md w-full p-6 rounded-[20px] border border-white/5 bg-[#050505]/90 text-center space-y-4 shadow-2xl\">\n          <Lock className=\"w-8 h-8 text-red-500 mx-auto animate-pulse\" />\n          <span className=\"text-[8px] text-red-500 bg-red-500/5 border border-red-500/15 px-2.5 py-0.5 rounded-full font-bold uppercase tracking-widest\">AUTH REQUIRED</span>\n          <h2 className=\"text-xs font-bold uppercase text-white\">Enclave Session Expired</h2>\n          <p className=\"text-[10px] text-white/50 leading-relaxed\">No simulated preview session detected. Fallback routing active.</p>\n          <div className=\"p-3 bg-black/40 border border-white/5 rounded-xl text-[9px] text-left space-y-1 text-white/30\">\n            <div>[SEC] Missing session token. Redirecting in {countdown}s...</div>\n          </div>\n          <button onClick={() => router.push(\"/portal/login\")} className=\"w-full h-10 rounded-lg bg-white text-black font-bold text-[10px] uppercase hover:bg-white/90\">\n            Go to Identity Gateway ({countdown}s)\n          </button>\n          <div className=\"pt-2 border-t border-white/5\">\n            <div className=\"text-[7.5px] font-bold text-white/20 uppercase tracking-widest mb-2\">Simulate Quick Authentication</div>\n            <div className=\"grid grid-cols-2 gap-2\">\n              <button onClick={() => handleBypass(\"client_admin\")} className=\"h-8 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9px] font-bold text-white/70 hover:text-white uppercase tracking-wider cursor-pointer\">Client Portal</button>\n              <button onClick={() => handleBypass(\"gff_admin\")} className=\"h-8 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9px] font-bold text-white/70 hover:text-white uppercase tracking-wider cursor-pointer\">Admin Panel</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  if (!hasAccess) {\n    return (\n      <div className=\"min-h-[80vh] bg-[#030303] text-white flex items-center justify-center font-mono p-4\">\n        <div className=\"max-w-xl w-full p-6 rounded-[20px] border border-red-500/15 bg-[#050505]/95 space-y-5 relative shadow-2xl\">\n          <div className=\"absolute top-0 left-0 w-full h-1 bg-red-500\" />\n          <div className=\"flex items-center gap-3\">\n            <ShieldAlert className=\"w-8 h-8 text-red-500\" />\n            <div>\n              <span className=\"text-[8px] text-red-500 bg-red-500/10 border border-red-500/20 px-2.5 py-0.5 rounded font-bold uppercase tracking-widest\">RESTRICTED BOUNDARY</span>\n              <h2 className=\"text-xs font-bold uppercase text-white\">Clearance Insufficient</h2>\n            </div>\n          </div>\n          <p className=\"text-[11px] text-white/60 leading-relaxed\">\n            Simulated role <strong className=\"text-red-400\">{session.role.toUpperCase()}</strong> holds insufficient clearance for <strong className=\"text-white\">/{type}/{activeSec}</strong>. L5 Administrator clearance required.\n          </p>\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl text-[10px] space-y-1 text-white/45\">\n            <div>Session ID: {session.name}</div>\n            <div>Clearance: {session.clearance}</div>\n          </div>\n          <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n            <button onClick={() => router.push(type === \"portal\" ? \"/portal/dashboard\" : \"/admin/dashboard\")} className=\"flex-1 h-10 rounded-lg border border-white/10 hover:border-white/20 text-white text-[10px] font-bold uppercase tracking-wider\">\n              Return to Safety\n            </button>\n            <button onClick={() => handleBypass(\"gff_admin\")} className=\"flex-1 h-10 rounded-lg bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 hover:to-red-600 text-white text-[10px] font-bold uppercase tracking-wider flex items-center justify-center gap-1 cursor-pointer\">\n              {negotiating ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <Key className=\"w-3.5 h-3.5\" />}\n              Elevate to GFF Admin\n            </button>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const isAdminInPortal = type === \"portal\" && session && session.role.startsWith(\"gff_\");\n\n  return (\n    <>\n      {isAdminInPortal && !dismissBanner && (\n        <div className=\"sticky top-8 z-40 bg-gradient-to-r from-cyan-950/30 to-black border-b border-cyan-500/20 px-4 md:px-6 py-2 flex items-center justify-between text-[11px] font-mono text-cyan-200 backdrop-blur-md select-none\">\n          <div className=\"flex items-center gap-2\">\n            <span className=\"relative flex h-1.5 w-1.5\">\n              <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\"></span>\n              <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-cyan-500\"></span>\n            </span>\n            <span><strong>ADMIN ENCLAVE ACTIVE:</strong> Simulating Client Portal with L5 clearance.</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <button \n              onClick={() => handleBypass(\"client_admin\")}\n              className=\"px-2.5 py-0.5 rounded bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-400/25 text-cyan-300 hover:text-cyan-200 text-[9.5px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center gap-1\"\n            >\n              {negotiating ? <RefreshCw className=\"w-2.5 h-2.5 animate-spin\" /> : <Sparkles className=\"w-2.5 h-2.5 text-cyan-400\" />}\n              Switch Workspace\n            </button>\n            <button onClick={() => setDismissBanner(true)} className=\"text-white/30 hover:text-white/75 transition-colors text-[9.5px] cursor-pointer\">\n              [Dismiss]\n            </button>\n          </div>\n        </div>\n      )}\n      {children}\n    </>\n  );\n}\n"}}}
