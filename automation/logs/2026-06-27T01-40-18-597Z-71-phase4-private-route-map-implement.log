{"ts":"2026-06-27T01:33:41.244Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"iiyf2bri","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/portal/SecureLogin.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { Lock, Shield, Key, CheckCircle, RefreshCw, ArrowRight, ShieldCheck } from \"lucide-react\";\nimport { motion } from \"framer-motion\";\n\nexport default function SecureLogin({ defaultRole = \"Client\" }: { defaultRole?: \"Client\" | \"Administrator\" }) {\n  const router = useRouter();\n  const [role, setRole] = useState<\"Client\" | \"Administrator\">(defaultRole);\n  const [selectedEnclave, setSelectedEnclave] = useState(\"apex-sovereign\");\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n\n  const scanMessages = [\n    \"Establishing zero-trust handshake...\",\n    \"Scanning hardware security module (HSM)...\",\n    \"Verifying passkey signature (SHA-256)...\",\n    \"Decapsulating session enclave...\"\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    \n    const interval = setInterval(() => {\n      setScanStep(prev => {\n        if (prev < 3) return prev + 1;\n        return prev;\n      });\n    }, 450);\n\n    await new Promise(r => setTimeout(r, 1800));\n    clearInterval(interval);\n    setScanning(false);\n\n    if (role === \"Administrator\") {\n      router.push(\"/admin/dashboard\");\n    } else {\n      router.push(\"/portal/dashboard\");\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative overflow-hidden px-4 py-12 select-none\">\n      {/* Premium Decorative Ambient Lights */}\n      <div className=\"absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full bg-[#009DFF]/5 blur-[120px]\" />\n      <div className=\"absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-96 h-96 rounded-full bg-[#E4000F]/5 blur-[120px]\" />\n      \n      {/* Background Dot Grid */}\n      <div className=\"absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n\n      <div className=\"w-full max-w-[480px] z-10 space-y-8\">\n        <div className=\"text-center space-y-3\">\n          <div className=\"inline-flex h-12 w-12 items-center justify-center rounded-xl border border-white/5 bg-[#0a0a0a] text-[#009DFF] shadow-[0_0_30px_rgba(0,157,255,0.05)]\">\n            <Shield className=\"w-5 h-5 animate-pulse\" />\n          </div>\n          <div>\n            <span className=\"text-[10px] font-mono font-bold tracking-widest text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded-full uppercase\">\n              ZERO-TRUST SINGLE ENCLAVE\n            </span>\n          </div>\n          <h1 className=\"text-3xl font-bold tracking-tight text-white font-mono uppercase\">\n            Authenticate <span className=\"text-[#009DFF]\">Session</span>\n          </h1>\n          <p className=\"text-xs text-white/40 max-w-[340px] mx-auto leading-relaxed\">\n            Verify hardware signature components and decapsulate cryptographic keys to access GFF AI enclaves.\n          </p>\n        </div>\n\n        <div className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[16px] space-y-6 relative overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)]\">\n          {/* Active indicator bar */}\n          <div className=\"absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/40 to-transparent\" />\n\n          {/* Secure Environment Selector */}\n          {!scanning && (\n            <div className=\"space-y-4\">\n              <div className=\"space-y-1.5\">\n                <label className=\"text-[10px] font-mono font-bold text-white/30 uppercase tracking-wider block\">\n                  Select Target Enclave\n                </label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  <button\n                    onClick={() => setRole(\"Client\")}\n                    className={`h-11 rounded-lg border text-[11px] font-bold font-mono uppercase transition-all flex items-center justify-center gap-2 cursor-pointer ${\n                      role === \"Client\"\n                        ? \"border-[#009DFF]/30 bg-[#009DFF]/5 text-white\"\n                        : \"border-white/5 bg-white/[0.01] text-white/50 hover:bg-white/[0.03]\"\n                    }`}\n                  >\n                    <Key className=\"w-3.5 h-3.5\" />\n                    Client Core\n                  </button>\n                  <button\n                    onClick={() => setRole(\"Administrator\")}\n                    className={`h-11 rounded-lg border text-[11px] font-bold font-mono uppercase transition-all flex items-center justify-center gap-2 cursor-pointer ${\n                      role === \"Administrator\"\n                        ? \"border-[#E4000F]/30 bg-[#E4000F]/5 text-white\"\n                        : \"border-white/5 bg-white/[0.01] text-white/50 hover:bg-white/[0.03]\"\n                    }`}\n                  >\n                    <Lock className=\"w-3.5 h-3.5\" />\n                    Oversight (Admin)\n                  </button>\n                </div>\n              </div>\n\n              {role === \"Client\" && (\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono font-bold text-white/30 uppercase tracking-wider block\">\n                    Enterprise Domain\n                  </label>\n                  <select\n                    value={selectedEnclave}\n                    onChange={(e) => setSelectedEnclave(e.target.value)}\n          