{scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                  <div key={idx} className=\"flex items-center gap-2 text-white/80 animate-fade-in\">\n                    {idx < scanStep ? (\n                      <CheckCircle className=\"w-3.5 h-3.5 text-emerald-400 shrink-0\" />\n                    ) : (\n                      <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin shrink-0\" />\n                    )}\n                    <span className={idx < scanStep ? \"text-white/35 line-through\" : \"text-white\"}>\n                      {msg}\n                    </span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-3 pt-2\">\n              <button\n                onClick={handleAuthenticate}\n                className=\"w-full h-11 rounded-lg bg-white hover:bg-white/90 text-black font-semibold text-[11.5px] uppercase tracking-wider font-mono transition-all flex items-center justify-center gap-2 cursor-pointer\"\n              >\n                <Key className=\"w-4 h-4 text-black\" />\n                <span>Authenticate SSO / Passkey</span>\n              </button>\n\n              <div className=\"p-3.5 rounded-xl bg-white/[0.01] border border-white/5 text-[9.5px] font-mono text-white/35 leading-relaxed text-center\">\n                Cryptographically sealed with hardware-enforced AES-256 secure protocols under ISO-27001 requirements.\n              </div>\n            </div>\n          )}\n        </div>\n\n        {/* Footer info */}\n        <div className=\"text-center font-mono text-[9px] text-white/20 select-none\">\n          GFF SECURE PORTAL CORE V2026.06.27 • NO UNAUTHORIZED ACCESS ALIGNED\n        </div>\n      </div>\n    </div>\n  );\n}\n"}}}
