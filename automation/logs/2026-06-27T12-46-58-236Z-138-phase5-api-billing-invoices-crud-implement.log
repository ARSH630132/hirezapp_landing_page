{"ts":"2026-06-27T12:43:32.175Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"6nbply8v","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-invoice-apis.js","new_text":"/* eslint-disable */\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-invoice-build');\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\ntry {\n  execSync('npx tsc lib/api-auth.ts app/api/v1/invoices/route.ts app/api/v1/invoices/[id]/route.ts --outDir temp-invoice-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  process.exit(1);\n}\nconst apiAuth = require('../temp-invoice-build/lib/api-auth.js');\nconst r1 = require('../temp-invoice-build/app/api/v1/invoices/route.js');\nconst r2 = require('../temp-invoice-build/app/api/v1/invoices/[id]/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    let res = await r1.GET(new Request(\"http://l/api/v1/invoices\", { headers: { \"Authorization\": inactive } }));\n    if (res.status !== 403) throw new Error(\"Inactive user 403 failed\");\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices\"));\n    if (res.status !== 401) throw new Error(\"No token 401 failed\");\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.invoices.length < 4) throw new Error(\"Admin list failed\");\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices\", { headers: { \"Authorization\": client } }));\n    d = await res.json();\n    if (res.status !== 200 || d.invoices.some(i => i.client_id !== \"client-001\")) throw new Error(\"Client list leakage\");\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices?client_id=client-003\", { headers: { \"Authorization\": client } }));\n    if (res.status !== 403) throw new Error(\"Cross-tenant filter 403 failed\");\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices?client_id=client-003\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.invoices.some(i => i.client_id !== \"client-003\")) throw new Error(\"Admin client_id filter failed\");\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices?search=Retail\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.invoices.length !== 1 || !d.invoices[0].project_name.includes(\"Sovereign\") && !d.invoices[0].project_name.includes(\"Consensus\")) {\n      if (!d.invoices[0].client_name.includes(\"Apex\") && !d.invoices[0].client_name.includes(\"Retail\")) {\n        throw new Error(\"Search filter failed\");\n      }\n    }\n\n    res = await r1.GET(new Request(\"http://l/api/v1/invoices?start_date=2026-06-10&end_date=2026-06-26\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.invoices.some(i => i.issue_date < \"2026-06-10\" || i.issue_date > \"2026-06-26\")) throw new Error(\"Date filter failed\");\n\n    res = await r2.GET(new Request(\"http://l/api/v1/invoices/inv-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"inv-001\" }) });\n    d = await res.json();\n    if (res.status !== 200 || d.invoice.id !== \"inv-001\") throw new Error(\"GET single failed\");\n\n    res = await r2.GET(new Request(\"http://l/api/v1/invoices/inv-002\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"inv-002\" }) });\n    if (res.status !== 403) throw new Error(\"Cross-tenant GET single 403 failed\");\n\n    const invData = { invoice_number: \"GFF-2026-TEST\", client_id: \"client-002\", amount: 1500.00, category: \"Compute SLA\" };\n    res = await r1.POST(new Request(\"http://l/api/v1/invoices\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(invData) }));\n    if (res.status !== 403) throw new Error(\"Client POST 403 failed\");\n\n    res = await r1.POST(new Request(\"http://l/api/v1/invoices\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(invData) }));\n    if (res.status !== 201) throw new Error(\"Admin POST failed\");\n    d = await res.json();\n    const createdId = d.invoice.id;\n\n    res = await r2.PATCH(new Request(\"http://l/api/v1/invoices/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ amount: 9999 }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client PATCH 403 failed\");\n\n    res = await r2.PATCH(new Request(\"http://l/api/v1/invoices/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ amount: 5000, description: \"Updated SLA\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"Admin PATCH failed\");\n    d = await res.json();\n    if (d.invoice.amount !== 5000 || d.invoice.description !== \"Updated SLA\") throw new Error(\"PATCH fields failed\");\n\n    res = await r2.DELETE(new Request(\"http://l/api/v1/invoices/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client DELETE 403 failed\");\n\n    res = await r2.DELETE(new Request(\"http://l/api/v1/invoices/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"Admin DELETE failed\");\n\n    res = await r2.GET(new Request(\"http://l/api/v1/invoices/\" + createdId, { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 404) throw new Error(\"Lookup of deleted 404 failed\");\n\n    console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: Invoices CRUD APIs Verified!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\nrun();"}}}
