search\");\n\n    let invoices = Object.values(API_MOCK_INVOICES) as ApiInvoice[];\n    const isManager = caller.role === \"gff_admin\" || caller.role === \"finance_admin\";\n\n    if (!isManager) {\n      const cid = getClientIdFromAssociation(caller.clientAssociation);\n      invoices = invoices.filter(inv => inv.client_id === cid);\n      if (clientIdFilter && clientIdFilter !== cid) {\n        return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Access denied.\" }, { status: 403 });\n      }\n    } else if (clientIdFilter) {\n      invoices = invoices.filter(inv => inv.client_id === clientIdFilter);\n    }\n\n    if (projectIdFilter) invoices = invoices.filter(inv => inv.project_id === projectIdFilter);\n    if (statusFilter) invoices = invoices.filter(inv => inv.status.toLowerCase() === statusFilter.toLowerCase().trim());\n    if (monthFilter) invoices = invoices.filter(inv => inv.issue_date.toLowerCase().includes(monthFilter.toLowerCase().trim()));\n    if (startDateFilter && !isNaN(new Date(startDateFilter).getTime())) {\n      invoices = invoices.filter(inv => new Date(inv.issue_date) >= new Date(startDateFilter));\n    }\n    if (endDateFilter && !isNaN(new Date(endDateFilter).getTime())) {\n      invoices = invoices.filter(inv => new Date(inv.issue_date) <= new Date(endDateFilter));\n    }\n    if (searchQuery) {\n      const q = searchQuery.toLowerCase().trim();\n      invoices = invoices.filter(inv => \n        inv.invoice_number.toLowerCase().includes(q) || \n        inv.description.toLowerCase().includes(q) || \n        (inv.project_name && inv.project_name.toLowerCase().includes(q)) ||\n        inv.client_name.toLowerCase().includes(q) ||\n        inv.id.toLowerCase().includes(q)\n      );\n    }\n    return NextResponse.json({ success: true, invoices });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\nexport async function POST(req: Request) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n    const { caller } = auth;\n    if (caller.role !== \"gff_admin\" && caller.role !== \"finance_admin\") {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Forbidden.\" }, { status: 403 });\n    }\n    const body = await req.json().catch(() => null);\n    if (!body) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid JSON.\" }, { status: 400 });\n\n    const { invoice_number, client_id, project_id, amount, currency, status, issue_date, due_date, category, description } = body;\n    if (!client_id || typeof client_id !== \"string\" || !client_id.trim()) {\n      return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id.\" }, { status: 400 });\n    }\n    const valids = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n    if (!valids.includes(client_id)) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id.\" }, { status: 400 });\n    if (amount === undefined || typeof amount !== \"number\" || amount < 0) {\n      return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid amount.\" }, { status: 400 });\n    }\n    if (invoice_number && typeof invoice_number === \"string\" && invoice_number.trim()) {\n      if (Object.values(API_MOCK_INVOICES).some(inv => inv.invoice_number.toLowerCase() === invoice_number.toLowerCase().trim())) {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Duplicate invoice number.\" }, { status: 400 });\n      }\n    }\n\n    const pName = project_id ? (API_MOCK_PROJECTS[project_id]?.name || \"\") : \"\";\n    const nid = getNextInvoiceId();\n    const invNum = invoice_number?.trim() || `GFF-2026-${Math.floor(1000 + Math.random() * 9000)}`;\n    const issD = issue_date?.trim() || new Date().toISOString().substring(0, 10);\n    const dueD = due_date?.trim() || (() => {\n      const d = new Date(issD);\n      d.setDate(d.getDate() + 30);\n      return d.toISOString().substring(0, 10);\n    })();\n\n    const newInv: ApiInvoice = {\n      id: nid,\n      invoice_number: invNum,\n      client_id,\n      client_name: getClientNameFromId(client_id),\n      project_id: project_id || \"\",\n      project_name: pName,\n      amount,\n      currency: currency || \"USD\",\n      status: status || \"unpaid\",\n      issue_date: issD,\n      due_date: dueD,\n      category: category || \"Compute Epoch\",\n      hash: body.hash || `0x${crypto.randomBytes(32).toString(\"hex\").toUpperCase()}`,\n      signature: body.signature || `SHA_${crypto.randomBytes(5).toString(\"hex\").toUpperCase()}`,\n      description: description || \"Cloud native secure enclave compute fee.\",\n      lastUpdated: new Date().toISOString()\n    };\n    (API_MOCK_INVOICES as Record<string, ApiInvoice>)[nid] = newInv;\n    return NextResponse.json({ success: true, invoice: newInv }, { status: 201 });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}"}}}
