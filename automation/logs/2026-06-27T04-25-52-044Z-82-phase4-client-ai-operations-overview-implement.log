{"ts":"2026-06-27T04:25:09.274Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"f5jsyqcx","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/ai-operations/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport Link from \"next/link\";\nimport { \n  Bot, Shield, Cpu, ArrowRight, RefreshCw, Search, ChevronDown, \n  Terminal, ShieldCheck, Activity, Layers, Clock, CheckCircle, \n  AlertTriangle, Play, Pause, ExternalLink\n} from \"lucide-react\";\nimport { \n  WorkspaceCard, \n  StatusBadge, \n  PrivatePageHeader \n} from \"@/components/private-app\";\nimport { \n  previewAgentOperations, \n  previewProjects \n} from \"@/lib/mock-data-model\";\n\n// Custom SVG Circular Health Ring Component for premium aesthetic\ninterface HealthRingProps {\n  value: number;\n  max?: number;\n  color: string;\n  glowColor: string;\n  label: string;\n  sublabel: string;\n}\n\nfunction HealthRing({ value, max = 100, color, glowColor, label, sublabel }: HealthRingProps) {\n  const size = 100;\n  const strokeWidth = 5;\n  const radius = (size - strokeWidth) / 2;\n  const circumference = 2 * Math.PI * radius;\n  const offset = circumference - (value / max) * circumference;\n\n  return (\n    <div className=\"flex items-center gap-4 bg-white/[0.01] border border-white/5 rounded-xl p-4 hover:border-white/10 hover:bg-white/[0.02] transition-all\">\n      <div className=\"relative flex items-center justify-center shrink-0\">\n        <svg width={size} height={size} className=\"transform -rotate-90\">\n          <circle\n            cx={size / 2}\n            cy={size / 2}\n            r={radius}\n            className=\"stroke-white/5\"\n            strokeWidth={strokeWidth}\n            fill=\"transparent\"\n          />\n          <circle\n            cx={size / 2}\n            cy={size / 2}\n            r={radius}\n            stroke={color}\n            strokeWidth={strokeWidth}\n            fill=\"transparent\"\n            strokeDasharray={circumference}\n            strokeDashoffset={offset}\n            strokeLinecap=\"round\"\n            className=\"transition-all duration-1000 ease-out\"\n            style={{\n              filter: `drop-shadow(0 0 4px ${glowColor})`\n            }}\n          />\n        </svg>\n        <div className=\"absolute inset-0 flex items-center justify-center font-mono\">\n          <span className=\"text-[15px] font-bold text-white tracking-tight\">{value}%</span>\n        </div>\n      </div>\n      <div className=\"space-y-1\">\n        <span className=\"text-[10px] font-mono tracking-wider text-white/40 uppercase block\">{label}</span>\n        <span className=\"text-[13px] font-bold text-white block\">{sublabel}</span>\n        <span className=\"text-[9.5px] font-mono text-[#009DFF]/80 flex items-center gap-1\">\n          <span className=\"h-1 w-1 rounded-full bg-[#009DFF] animate-pulse\"></span>\n          ENCLAVE BOUNDED\n        </span>\n      </div>\n    </div>\n  );\n}\n\nexport default function ClientAiOperationsPage() {\n  const [search, setSearch] = useState(\"\");\n  const [selectedProject, setSelectedProject] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedStage, setSelectedStage] = useState(\"\");\n  const [activeTab, setActiveTab] = useState<\"telemetry\" | \"governance\" | \"runtime\">(\"telemetry\");\n\n  // Load static agent operations into local reactive state to make the reboot sequence feel alive\n  const [agentsState, setAgentsState] = useState(() => \n    previewAgentOperations.map(agent => ({\n      ...agent,\n      rebooting: false,\n      logs: [...agent.logs]\n    }))\n  );\n\n  // Trigger simulated hardware enclave recycle\n  const handleRecycle = (agentId: string) => {\n    setAgentsState(prev => prev.map(agent => {\n      if (agent.id === agentId) {\n        return {\n          ...agent,\n          rebooting: true,\n          logs: [\n            ...agent.logs,\n            `[${new Date().toLocaleTimeString()}] INITIATING CRYPTOGRAPHIC ENCLAVE RECYCLE...`,\n            `[${new Date().toLocaleTimeString()}] WIPING EPHEMERAL STATE BUFFER...`,\n            `[${new Date().toLocaleTimeString()}] RE-ALIGNING MULTI-AGENT BOUNDARY MASKS...`\n          ]\n        };\n      }\n      return agent;\n    }));\n\n    setTimeout(() => {\n      setAgentsState(prev => prev.map(agent => {\n        if (agent.id === agentId) {\n          return {\n            ...agent,\n            rebooting: false,\n            status: \"active\" as const, // warnings or errors get resolved on recycle\n            logs: [\n              ...agent.logs,\n              `[${new Date().toLocaleTimeString()}] ISO-27001 COMPLIANCE MATCH: 100%`,\n              `[${new Date().toLocaleTimeString()}] CPU THREAD LOCK PINNING COMPLETE`,\n              `[${new Date().toLocaleTimeString()}] SANDBOX TELEMETRY HEARTBEAT DISPATCHED`\n            ]\n          };\n        }\n        return agent;\n      }));\n    }, 1800);\n  };\n\n  // Extract unique projects from local preview metadata\n  const projectsList = useMemo(() => {\n    return previewProjects.map(p => ({ id: p.id, name: p.name }));\n  }, []);\n\n  // Filter agent list based on filters and search queries\n  const filteredAgents = useMemo(() => {\n    return agentsState.filter(agent => {\n      // 1. Search filter\n      const matchesSearch = agent.name.toLowerCase().includes(search.toLowerCase()) || \n                            agent.id.toLowerCase().includes(search.toLowerCase());\n      \n      // 2. Project filter\n      const matchesProject = !selectedProject || agent.projectId === selectedProject;\n      \n      // 3. Agent Type filter\n      let agentType = \"\";\n      if (agent.name.startsWith(\"RETAIL\")) agentType = \"RETAIL\";\n      else if (agent.name.startsWith(\"ALIGN\")) agentType = \"ALIGN\";\n      else if (agent.name.startsWith(\"ORE\")) agentType = \"ORE\";\n      else if (agent.name.startsWith(\"MED\")) agentType = \"MED\";\n      else if (agent.name.startsWith(\"TRANS\")) agentType = \"TRANS\";\n      const matchesType = !selectedType || agentType === selectedType;\n      \n      // 4. Status filter\n      const matchesStatus = !selectedStatus || agent.status === selectedStatus;\n      \n      // 5. Operating Stage filter\n      let stage = \"\";\n      if (agent.status === \"active\") stage = \"Core Verification\";\n      else if (agent.status === \"evaluating\") stage = \"State Synchronized\";\n      else if (agent.status === \"warning\") stage = \"Policy Match\";\n      else if (agent.status === \"decoupled\") stage = \"Terminated\";\n      const matchesStage = !selectedStage || stage === selectedStage;\n\n      return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n    });\n  }, [agentsState, search, selectedProject, selectedType, selectedStatus, selectedStage]);\n\n  // System stats summary values\n  const activeCount = agentsState.filter(a => a.status === \"active\").length;\n  const warningCount = agentsState.filter(a => a.status === \"warning\").length;\n  const decoupledCount = agentsState.filter(a => a.status === \"decoupled\").length;\n\n  const governancePolicies = [\n    {\n      id: \"GOV-001\",\n      standard: \"ISO-27001 Enclave Compliance\",\n      desc: \"Enforces air-gapped CPU memory registers and secure key handshakes inside hardware.\",\n      status: \"compliant\" as const,\n      lastChecked: \"2 minutes ago\",\n      hash: \"SHA-256: 0x9DFF...81F2\"\n    },\n    {\n      id: \"GOV-002\",\n      standard: \"Model Bias & Alignment Guard\",\n      desc: \"Real-time verification of model parameters and input/output vector alignment.\",\n      status: \"compliant\" as const,\n      lastChecked: \"12 minutes ago\",\n      hash: \"SHA-256: 0x4B3A...C92D\"\n    },\n    {\n      id: \"GOV-003\",\n      standard: \"eBPF Outbound Telemetry Guard\",\n      desc: \"Continuous sandbox outbound port and network layer filtering to mitigate risk.\",\n      status: \"compliant\" as const,\n      lastChecked: \"4 minutes ago\",\n      hash: \"SHA-256: 0xE8A1...F530\"\n    },\n    {\n      id: \"GOV-004\",\n      standard: \"HSM Enclave Key Rollover\",\n      desc: \"Requires periodic physical keys cycle inside GFF Hardware Security Modules.\",\n      status: \"warning\" as const,\n      descWarning: \"Key rotation due in 4 days. Auto-schedule verified.\",\n      lastChecked: \"1 hour ago\",\n      hash: \"SHA-256: 0x7E12...B39A\"\n    }\n  ];\n\n  const timelineSteps = [\n    {\n      title: \"ENCLAVE HARDWARE ISOLATION PROVISIONED\",\n      desc: \"Dedicated physical CPU thread partitioning and memory register isolation validated successfully.\",\n      timestamp: \"Epoch 10842 • 15m ago\",\n      status: \"complete\" as const,\n      meta: \"Intel SGX Enclave Lock • SUCCESS\"\n    },\n    {\n      title: \"CONTEXT STATE STATE CACHE LOADED\",\n      desc: \"Model contextual weight layers and state variables injected via cryptographically signed memory channels.\",\n      timestamp: \"Epoch 10845 • 11m ago\",\n      status: \"complete\" as const,\n      meta: \"128k Tokens Sync • SUCCESS\"\n    },\n    {\n      title: \"GUARDRAIL COMPLIANCE ALIGNMENT CHECKED\",\n      desc: \"Continuous alignment engine verified 100% match with sovereign guardrail policies.\",\n      timestamp: \"Epoch 10849 • 6m ago\",\n      status: \"complete\" as const,\n      meta: \"Policy Set: ISO-27001-AI • ACTIVE\"\n    },\n    {\n      title: \"ACTIVE HEARTBEAT OPERATION MONITORING\",\n      desc: \"Sandbox multi-agent running state is fully functional and dispatching periodic cryptographic telemetry hashes.\",\n      timestamp: \"Active Run Phase\",\n      status: \"current\" as const,\n      meta: \"eBPF Stream Active • VERIFIED\"\n    }\n  ];\n\n  return (\n    <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n      \n      {/* SECURE PREVIEW STATUS BANNER */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2.5 text-white/70\">\n          <Activity className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span>\n            <strong className=\"text-white\">DETERMINISTIC TELEMETRY EMBED:</strong> Operation telemetry maps mock sandboxed environments. State syncing does not represent real-time cluster execution.\n          </span>\n        </div>\n        <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n          EMULATION ACTIVE\n        </span>\n      </div>\n\n      {/* HEADER SECTION WITH CONTROL CENTER LINK */}\n      <PrivatePageHeader\n        title=\"AI Operations Telemetry Hub\"\n        desc=\"Audit, filter, and recycle active sandboxed multi-agent runtimes, isolation memory scopes, and cryptographic security states.\"\n        badgeLabel=\"OVERSIGHT SECURED\"\n        actions={\n          <div className=\"flex gap-2 w-full md:w-auto\">\n            <Link\n              href=\"/portal/control-center\"\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 hover:border-[#009DFF]/50 transition-all cursor-pointer\"\n            >\n              <ExternalLink className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n              <span>ACCESS CONTROL CENTER</span>\n            </Link>\n          </div>\n        }\n      />\n\n      {/* SYSTEM OPERATIONS STATUS & HEALTH RINGS */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <HealthRing \n          value={78} \n          color=\"#009DFF\" \n          glowColor=\"rgba(0,157,255,0.4)\" \n          label=\"THREAD LOAD\" \n          sublabel=\"Concurrent CPU Workers\" \n        />\n        <HealthRing \n          value={64} \n          color=\"#10B981\" \n          glowColor=\"rgba(16,185,129,0.4)\" \n          label=\"MEMORY ALLOCATION\" \n          sublabel=\"Enclave Partition Buffer\" \n        />\n        <HealthRing \n          value={100} \n          color=\"#10B981\" \n          glowColor=\"rgba(16,185,129,0.4)\" \n          label=\"COMPLIANCE RATING\" \n          sublabel=\"Guardrails Verification\" \n        />\n        \n        {/* Managed AI Operations Status Summary */}\n        <div className=\"bg-white/[0.01] border border-white/5 rounded-xl p-4 flex flex-col justify-between hover:border-white/10 transition-all\">\n          <div className=\"flex justify-between items-start\">\n            <span className=\"text-[10px] font-mono tracking-wider text-white/40 uppercase block\">OPERATIONAL STATUS</span>\n            <span className=\"h-2 w-2 rounded-full bg-emerald-500 animate-ping\"></span>\n          </div>\n          <div className=\"my-1.5\">\n            <div className=\"text-[18px] font-bold text-white font-mono uppercase tracking-tight\">SYSTEM SECURE</div>\n            <p className=\"text-[10px] text-white/50 font-mono mt-0.5 leading-tight\">All hardware memory enclaves synced & sealed.</p>\n          </div>\n          <div className=\"flex items-center gap-2 border-t border-white/5 pt-2 text-[10px] font-mono\">\n            <span className=\"text-emerald-400 font-bold\">{activeCount} ACTIVE</span>\n            <span className=\"text-white/20\">•</span>\n            <span className=\"text-amber-400 font-bold\">{warningCount} ALERT</span>\n            <span className=\"text-white/20\">•</span>\n            <span className=\"text-white/40\">{decoupledCount} TERMINATED</span>\n          </div>\n        </div>\n      </div>\n\n      {/* SEARCH AND ADVANCED SELECTIVE FILTER BAR */}\n      <div className=\"bg-[#050505]/40 border border-white/5 rounded-xl p-4 space-y-3\">\n        <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n          <Layers className=\"w-4 h-4 text-[#009DFF]\" />\n          <h4 className=\"text-[11.5px] font-bold text-white font-mono uppercase tracking-wider\">Selective Operational Filter</h4>\n        </div>\n        \n        <div className=\"grid grid-cols-1 md:grid-cols-5 gap-3\">\n          {/* Text Search */}\n          <div className=\"relative\">\n            <Search className=\"absolute left-3 top-2.5 w-3.5 h-3.5 text-white/30\" />\n            <input \n              type=\"text\"\n              value={search}\n              onChange={(e) => setSearch(e.target.value)}\n              placeholder=\"Search agent signature...\"\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-8.5 pr-3 text-[11.5px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n            />\n          </div>\n\n          {/* Project Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedProject}\n              onChange={(e) => setSelectedProject(e.target.value)}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n            >\n              <option value=\"\">ALL PROJECTS</option>\n              {projectsList.map(proj => (\n                <option key={proj.id} value={proj.id}>{proj.name.toUpperCase()}</option>\n              ))}\n            </select>\n            <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n\n          {/* Agent Type Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedType}\n              onChange={(e) => setSelectedType(e.target.value)}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n            >\n              <option value=\"\">ALL AGENT TYPES</option>\n              <option value=\"RETAIL\">RETAIL CORE COGNITION</option>\n              <option value=\"ALIGN\">ALIGNMENT SHIELD</option>\n              <option value=\"ORE\">GEOLOGICAL DEEP CRUNCH</option>\n              <option value=\"MED\">MEDICAL THREAD ENGINE</option>\n              <option value=\"TRANS\">DECISION LOOP SYSTEM</option>\n            </select>\n            <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n\n          {/* Status Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedStatus}\n              onChange={(e) => setSelectedStatus(e.target.value)}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n            >\n              <option value=\"\">ALL STATUS STATES</option>\n              <option value=\"active\">ACTIVE / VERIFIED</option>\n              <option value=\"evaluating\">EVALUATING MODEL</option>\n              <option value=\"warning\">WARNING DISPATCHED</option>\n              <option value=\"decoupled\">DECOUPLED ENCLAVE</option>\n            </select>\n            <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n\n          {/* Operating Stage Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedStage}\n              onChange={(e) => setSelectedStage(e.target.value)}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n            >\n              <option value=\"\">ALL OPERATING STAGES</option>\n              <option value=\"Core Verification\">CORE VERIFICATION</option>\n              <option value=\"State Synchronized\">STATE SYNCHRONIZED</option>\n              <option value=\"Policy Match\">POLICY MATCH</option>\n              <option value=\"Terminated\">TERMINATED ENCLAVE</option>\n            </select>\n            <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n        </div>\n      </div>\n\n      {/* TABBED SYSTEM SELECTOR */}\n      <div className=\"flex border-b border-white/5\">\n        <button\n          onClick={() => setActiveTab(\"telemetry\")}\n          className={`px-5 py-3 text-[11px] font-mono font-bold uppercase border-b-2 tracking-wider transition-all cursor-pointer select-none ${\n            activeTab === \"telemetry\" \n              ? \"border-[#009DFF] text-white bg-white/[0.01]\" \n              : \"border-transparent text-white/40 hover:text-white/80\"\n          }`}\n        >\n          Active Agents & Telemetry ({filteredAgents.length})\n        </button>\n        <button\n          onClick={() => setActiveTab(\"governance\")}\n          className={`px-5 py-3 text-[11px] font-mono font-bold uppercase border-b-2 tracking-wider transition-all cursor-pointer select-none ${\n            activeTab === \"governance\" \n              ? \"border-[#009DFF] text-white bg-white/[0.01]\" \n              : \"border-transparent text-white/40 hover:text-white/80\"\n          }`}\n        >\n          Governance & Guardrail Policies\n        </button>\n        <button\n          onClick={() => setActiveTab(\"runtime\")}\n          className={`px-5 py-3 text-[11px] font-mono font-bold uppercase border-b-2 tracking-wider transition-all cursor-pointer select-none ${\n            activeTab === \"runtime\" \n              ? \"border-[#009DFF] text-white bg-white/[0.01]\" \n              : \"border-transparent text-white/40 hover:text-white/80\"\n          }`}\n        >\n          Enclave Runtime Status & Timeline\n        </button>\n      </div>\n\n      {/* TABBED SECTIONS */}\n      {activeTab === \"telemetry\" && (\n        <div className=\"grid grid-cols-1 xl:grid-cols-2 gap-6\">\n          {filteredAgents.length === 0 ? (\n            <div className=\"xl:col-span-2 py-16 text-center border border-dashed border-white/5 rounded-2xl bg-white/[0.01]\">\n              <AlertTriangle className=\"w-8 h-8 text-white/20 mx-auto mb-3\" />\n              <p className=\"text-[12px] font-mono text-white/50\">No sandbox agent telemetry matches the active filters.</p>\n              <button \n                onClick={() => {\n                  setSearch(\"\");\n                  setSelectedProject(\"\");\n                  setSelectedType(\"\");\n                  setSelectedStatus(\"\");\n                  setSelectedStage(\"\");\n                }}\n                className=\"mt-3 inline-flex h-8 items-center justify-center rounded border border-white/10 px-4 text-[10px] font-mono text-white hover:bg-white/5 transition-all cursor-pointer\"\n              >\n                RESET ALL FILTERS\n              </button>\n            </div>\n          ) : (\n            filteredAgents.map((agent) => (\n              <WorkspaceCard key={agent.id} className=\"space-y-4 flex flex-col justify-between h-full bg-[#050505]/40 border-white/5\">\n                <div>\n                  {/* Card Header */}\n                  <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n                    <div>\n                      <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1.5 py-0.5 rounded\">\n                        {agent.id.toUpperCase()}\n                      </span>\n                      <h4 className=\"text-[13.5px] font-bold text-white font-mono mt-1.5 tracking-tight\">{agent.name}</h4>\n                    </div>\n                    <StatusBadge \n                      state={agent.rebooting ? \"warning\" : agent.status === \"active\" ? \"active\" : agent.status === \"warning\" ? \"warning\" : agent.status === \"decoupled\" ? \"decoupled\" : \"stable\"} \n                      label={agent.rebooting ? \"REPL_REBOOTING\" : agent.status === \"active\" ? \"VERIFIED_ACTIVE\" : agent.status} \n                    />\n                  </div>\n\n                  {/* Core specs grids */}\n                  <div className=\"grid grid-cols-3 gap-2 font-mono text-[10.5px] mt-4\">\n                    <div className=\"p-2 rounded border border-white/5 bg-white/[0.005]\">\n                      <span className=\"text-white/30 block text-[8px] uppercase\">THREAD REGISTER</span>\n                      <span className=\"text-white font-bold block mt-0.5\">{agent.threads} CORES</span>\n                    </div>\n                    <div className=\"p-2 rounded border border-white/5 bg-white/[0.005]\">\n                      <span className=\"text-white/30 block text-[8px] uppercase\">CONTEXT CACHE</span>\n                      <span className=\"text-white font-bold block mt-0.5 truncate\">{agent.memory}</span>\n                    </div>\n                    <div className=\"p-2 rounded border border-white/5 bg-white/[0.005]\">\n                      <span className=\"text-white/30 block text-[8px] uppercase\">SYNC STAGE</span>\n                      <span className=\"text-[#009DFF] font-bold block mt-0.5 uppercase\">\n                        {agent.status === \"active\" ? \"Core verified\" : agent.status === \"evaluating\" ? \"STATE SYNC\" : agent.status === \"warning\" ? \"POLICY MATCH\" : \"TERMINATED\"}\n                      </span>\n                    </div>\n                  </div>\n\n                  {/* Sandbox Telemetry Log Screen */}\n                  <div className=\"mt-4 border border-white/5 rounded-lg overflow-hidden bg-black/70 p-3 h-32 overflow-y-auto font-mono text-[10px] text-white/50 space-y-1.5 relative\">\n                    <div className=\"absolute top-2 right-2 flex items-center gap-1.5 select-none text-[8px] text-white/30 border border-white/5 rounded bg-black/40 px-1.5 py-0.5\">\n                      <Terminal className=\"w-2.5 h-2.5\" />\n                      <span>TELEMETRY OUT</span>\n                    </div>\n                    {agent.logs.map((log, idx) => (\n                      <div key={idx} className=\"leading-normal flex items-start gap-1\">\n                        <span className=\"text-white/20 select-none\">&gt;&gt;</span>\n                        <span className={log.includes(\"REBOOT\") || log.includes(\"WIPING\") ? \"text-[#009DFF] font-bold\" : log.includes(\"SUCCESS\") || log.includes(\"COMPLETE\") ? \"text-emerald-400 font-bold\" : \"\"}>\n                          {log}\n                        </span>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n\n                {/* Card Actions */}\n                <div className=\"flex gap-2 border-t border-white/5 pt-3.5 mt-2\">\n                  <button \n                    onClick={() => handleRecycle(agent.id)}\n                    disabled={agent.rebooting || agent.status === \"decoupled\"}\n                    className=\"flex-grow inline-flex h-8 items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.01] hover:bg-white/[0.03] text-[10px] font-bold font-mono text-white transition-all disabled:opacity-50 disabled:pointer-events-none cursor-pointer\"\n                  >\n                    {agent.rebooting ? (\n                      <>\n                        <RefreshCw className=\"w-3 h-3 animate-spin text-[#009DFF]\" />\n                        <span>CYCLING ENCLAVE KEY...</span>\n                      </>\n                    ) : (\n                      <>\n                        <RefreshCw className=\"w-3 h-3 text-white/70\" />\n                        <span>RECYCLE CORE ENCLAVE</span>\n                      </>\n                    )}\n                  </button>\n                  <Link\n                    href={`/portal/ai-operations/${agent.id}`}\n                    className=\"inline-flex h-8 items-center justify-center gap-1 rounded border border-[#009DFF]/25 bg-[#009DFF]/5 hover:bg-[#009DFF]/10 px-3 text-[10px] font-bold font-mono text-[#009DFF] transition-all cursor-pointer\"\n                  >\n                    <span>ANALYZE STATE</span>\n                    <ArrowRight className=\"w-3 h-3\" />\n                  </Link>\n                </div>\n              </WorkspaceCard>\n            ))\n          )}\n        </div>\n      )}\n\n      {activeTab === \"governance\" && (\n        <div className=\"space-y-6\">\n          <WorkspaceCard className=\"p-5 bg-[#050505]/40 border-white/5 space-y-4\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n              <ShieldCheck className=\"w-5 h-5 text-emerald-400\" />\n              <div>\n                <h4 className=\"text-[13.5px] font-bold text-white font-mono uppercase tracking-tight\">Active Policy Guardrail Ledger</h4>\n                <p className=\"text-[10.5px] font-mono text-white/40 mt-0.5\">Continuous verification audits ensuring alignment with enterprise standards inside hardware enclaves.</p>\n              </div>\n            </div>\n\n            <div className=\"overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse font-mono text-[11.5px]\">\n                <thead>\n                  <tr className=\"border-b border-white/5 text-white/30 uppercase text-[9px] tracking-wider select-none\">\n                    <th className=\"py-2.5\">Standard Rule</th>\n                    <th className=\"py-2.5\">Isolation Description</th>\n                    <th className=\"py-2.5 text-center\">Status state</th>\n                    <th className=\"py-2.5\">Telemetry signature hash</th>\n                    <th className=\"py-2.5 text-right\">Checked</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-white/5 text-white/80\">\n                  {governancePolicies.map((policy) => (\n                    <tr key={policy.id} className=\"hover:bg-white/[0.01] transition-colors\">\n                      <td className=\"py-3 font-bold text-white\">{policy.standard}</td>\n                      <td className=\"py-3 pr-4\">\n                        <p className=\"leading-normal\">{policy.desc}</p>\n                        {policy.status === \"warning\" && policy.descWarning && (\n                          <span className=\"text-amber-400 text-[10px] font-bold block mt-1\">\n                            ⚠️ {policy.descWarning}\n                          </span>\n                        )}\n                      </td>\n                      <td className=\"py-3 text-center\">\n                        <span className={`inline-flex rounded-full px-2 py-0.5 text-[9px] font-bold uppercase ${\n                          policy.status === \"compliant\" \n                            ? \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" \n                            : \"bg-amber-400/10 text-amber-400 border border-amber-400/20\"\n                        }`}>\n                          {policy.status.toUpperCase()}\n                        </span>\n                      </td>\n                      <td className=\"py-3 text-white/40\">{policy.hash}</td>\n                      <td className=\"py-3 text-right text-white/30\">{policy.lastChecked}</td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          </WorkspaceCard>\n        </div>\n      )}\n\n      {activeTab === \"runtime\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n          {/* Timeline */}\n          <div className=\"lg:col-span-2\">\n            <WorkspaceCard className=\"p-5 bg-[#050505]/40 border-white/5 space-y-4 h-full\">\n              <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n                <Clock className=\"w-5 h-5 text-[#009DFF]\" />\n                <div>\n                  <h4 className=\"text-[13.5px] font-bold text-white font-mono uppercase tracking-tight\">Cryptographic Runtime Lifecycle</h4>\n                  <p className=\"text-[10.5px] font-mono text-white/40 mt-0.5\">Chronological record of hardware enclave allocation and calibration.</p>\n                </div>\n              </div>\n\n              {/* Vertical Timeline Steps */}\n              <div className=\"space-y-6 pt-2 pl-2\">\n                {timelineSteps.map((step, idx) => (\n                  <div key={idx} className=\"flex gap-4 relative\">\n                    {/* Line connector */}\n                    {idx < timelineSteps.length - 1 && (\n                      <div className=\"absolute left-2.5 top-5 bottom-[-24px] w-[1px] bg-white/5\" />\n                    )}\n                    \n                    {/* Indicator Icon */}\n                    <div className=\"relative z-10 shrink-0\">\n                      {step.status === \"complete\" ? (\n                        <div className=\"h-5 w-5 rounded-full bg-emerald-500/10 border border-emerald-500/40 flex items-center justify-center text-emerald-400\">\n                          <CheckCircle className=\"w-3 h-3\" />\n                        </div>\n                      ) : (\n                        <div className=\"h-5 w-5 rounded-full bg-[#009DFF]/20 border border-[#009DFF] flex items-center justify-center text-[#009DFF] animate-pulse\">\n                          <div className=\"h-1.5 w-1.5 rounded-full bg-[#009DFF]\" />\n                        </div>\n                      )}\n                    </div>\n\n                    {/* Step details */}\n                    <div className=\"space-y-1\">\n                      <div className=\"flex items-baseline gap-2\">\n                        <span className=\"text-[11.5px] font-bold font-mono text-white tracking-tight\">{step.title}</span>\n                        <span className=\"text-[9px] font-mono text-white/30\">{step.timestamp}</span>\n                      </div>\n                      <p className=\"text-[11px] text-white/50 font-mono leading-relaxed\">{step.desc}</p>\n                      <span className=\"inline-block text-[9.5px] font-mono text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.5 rounded\">\n                        {step.meta}\n                      </span>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </WorkspaceCard>\n          </div>\n\n          {/* Hardware Enclave Specs Column */}\n          <div>\n            <WorkspaceCard className=\"p-5 bg-[#050505]/40 border-white/5 space-y-4 h-full\">\n              <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n                <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n                <div>\n                  <h4 className=\"text-[13.5px] font-bold text-white font-mono uppercase tracking-tight\">Isolated Hardware Specs</h4>\n                  <p className=\"text-[10.5px] font-mono text-white/40 mt-0.5\">Physical hypervisor execution details.</p>\n                </div>\n              </div>\n\n              <div className=\"space-y-3 font-mono text-[11px]\">\n                <div className=\"p-3 bg-white/[0.005] border border-white/5 rounded-lg space-y-1\">\n                  <span className=\"text-white/30 text-[9px] 