clientX - rect.left, y: e.clientY - rect.top });\n 27 |   };\n 28 | \n 29 |   return (\n 30 |     <div \n 31 |       ref={divRef}\n 32 |       onMouseMove={handleMouseMove}\n 33 |       onMouseEnter={() => setOpacity(1)}\n 34 |       onMouseLeave={() => setOpacity(0)}\n 35 |       className={`relative overflow-hidden rounded-2xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 transition-all hover:border-white/10 ${className}`}\n 36 |     >\n 37 |       <div \n 38 |         className=\"pointer-events-none absolute -inset-px rounded-2xl opacity-0 transition-opacity duration-300\"\n 39 |         style={{\n 40 |           opacity,\n 41 |           background: `radial-gradient(350px circle at ${position.x}px ${position.y}px, ${spotlightColor}, transparent 80%)`\n 42 |         }}\n 43 |       />\n 44 |       <div className=\"relative z-10\">{children}</div>\n 45 |     </div>\n 46 |   );\n 47 | }\n 48 | \n 49 | // ==========================================\n 50 | // 2. METRIC TILE\n 51 | // ==========================================\n 52 | export function MetricTile({ \n 53 |   title, \n 54 |   value, \n 55 |   delta, \n 56 |   direction, \n 57 |   status = \"stable\", \n 58 |   sparkPoints = [30, 40, 35, 50, 45, 60, 55, 70, 65, 80]\n 59 | }: { \n 60 |   title: string; \n 61 |   value: string; \n 62 |   delta: string; \n 63 |   direction: \"up\" | \"down\" | \"neutral\"; \n 64 |   status?: \"normal\" | \"warning\" | \"error\" | \"stable\";\n 65 |   sparkPoints?: number[];\n 66 | }) {\n 67 |   const width = 120;\n 68 |   const height = 40;\n 69 |   const maxVal = Math.max(...sparkPoints);\n 70 |   const minVal = Math.min(...sparkPoints);\n 71 |   const range = maxVal - minVal || 1;\n 72 | \n 73 |   const points = sparkPoints.map((val, idx) => {\n 74 |     const x = (idx / (sparkPoints.length - 1)) * width;\n 75 |     const y = height - ((val - minVal) / range) * (height - 8) - 4;\n 76 |     return `${x},${y}`;\n 77 |   }).join(\" \");\n 78 | \n 79 |   const deltaColor = direction === \"up\" ? \"text-emerald-400\" : direction === \"down\" ? \"text-[#E4000F]\" : \"text-white/40\";\n 80 |   const strokeColor = direction === \"up\" ? \"#10b981\" : direction === \"down\" ? \"#E4000F\" : \"#009DFF\";\n 81 | \n 82 |   return (\n 83 |     <WorkspaceCard className=\"flex items-center justify-between gap-4\">\n 84 |       <div className=\"space-y-1\">\n 85 |         <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">{title}</span>\n 86 |         <div className=\"text-[22px] font-bold tracking-tight text-white\">{value}</div>\n 87 |         <div className=\"flex items-center gap-1.5 text-[11px] font-mono leading-none\">\n 88 |           <span className={`font-bold ${deltaColor}`}>\n 89 |             {direction === \"up\" ? \"+\" : \"\"}{delta}\n 90 |           </span>\n 91 |           <span className=\"text-white/20\">•</span>\n 92 |           <span className=\"text-white/40 uppercase text-[9.5px]\">vs last cycle</span>\n 93 |         </div>\n 94 |       </div>\n 95 | \n 96 |       <div className=\"flex flex-col items-end shrink-0 select-none\">\n 97 |         <svg width={width} height={height} className=\"overflow-visible\">\n 98 |           <polyline \n 99 |             fill=\"none\" \n100 |             stroke={strokeColor} \n101 |             strokeWidth=\"1.5\" \n102 |             points={points} \n103 |             strokeLinecap=\"round\"\n104 |             strokeLinejoin=\"round\"\n105 |             className=\"transition-all duration-500\"\n106 |           />\n107 |           <polyline \n108 |             fill=\"none\" \n109 |             stroke={strokeColor} \n110 |             strokeWidth=\"4\" \n111 |             points={points} \n112 |             strokeLinecap=\"round\"\n113 |             strokeLinejoin=\"round\"\n114 |             className=\"opacity-15 blur-sm transition-all duration-500\"\n115 |           />\n116 |         </svg>\n117 |         <div className=\"mt-1 flex items-center gap-1\">\n118 |           <span className={`h-1.5 w-1.5 rounded-full ${\n119 |             status === \"normal\" ? \"bg-emerald-500\" :\n120 |             status === \"warning\" ? \"bg-amber-400\" :\n121 |             status === \"error\" ? \"bg-[#E4000F]\" : \"bg-[#009DFF]\"\n122 |           }`} />\n123 |           <span className=\"text-[9px] font-mono text-white/30 uppercase tracking-widest\">{status}</span>\n124 |         </div>\n125 |       </div>\n126 |     </WorkspaceCard>\n127 |   );\n128 | }\n129 | \n130 | // ==========================================\n131 | // 3. STATUS BADGE\n132 | // ==========================================\n133 | export function StatusBadge({ \n134 |   state, \n135 |   label \n136 | }: { \n137 |   state: BadgeState; \n138 |   label: string;\n139 | }) {\n140 |   const styles = {\n141 |     active: \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\",\n142 |     warning: \"bg-amber-400/10 text-amber-400 border-amber-400/25\",\n143 |     error: \"bg-red-500/10 text-red-400 border-red-500/25\",\n144 |     stable: \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\",\n145 |     decoupled: \"bg-white/5 text-white/50 border-white/10\"\n146 |   };\n147 | \n148 |   return (\n149 |     <span className={`inline-flex items-center gap-1.5 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[state]}`}>\n150 |       {state === \"active\" && (\n151 |         <span className=\"relative flex h-1.5 w-1.5 shrink-0\">\n152 |           <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n153 |           <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500\"></span>\n154 |         </span>\n155 |       )}\n156 |       <span>{label}</span>\n157 |     </span>\n158 |   );\n159 | }","success":true}],"durationMs":10}}
