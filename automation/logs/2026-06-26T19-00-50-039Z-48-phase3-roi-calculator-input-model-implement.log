ror: `Please select at least 1 ${fieldName.toLowerCase().replace(/s$/, \"\")}.` };\n 45 |   }\n 46 |   return { isValid: true };\n 47 | }\n 48 | \n 49 | export function validateNumberRange(value: number | null | undefined, min: number, max: number, fieldName = \"Value\"): ValidationResult {\n 50 |   if (value === null || value === undefined || isNaN(value)) {\n 51 |     return { isValid: false, error: `${fieldName} must be a valid number.` };\n 52 |   }\n 53 |   if (value < min || value > max) {\n 54 |     return { isValid: false, error: `${fieldName} must be between ${min} and ${max}.` };\n 55 |   }\n 56 |   return { isValid: true };\n 57 | }\n 58 | \n 59 | export function validateNonNegativeInput(value: number | null | undefined, fieldName = \"Input value\"): ValidationResult {\n 60 |   if (value === null || value === undefined || isNaN(value)) {\n 61 |     return { isValid: false, error: `${fieldName} must be a valid numeric value.` };\n 62 |   }\n 63 |   if (value < 0) {\n 64 |     return { isValid: false, error: `${fieldName} cannot be negative.` };\n 65 |   }\n 66 |   return { isValid: true };\n 67 | }\n 68 | \n 69 | export function getSafeEmptyState<T>(defaultValue: T, value?: T | null): T {\n 70 |   if (value === null || value === undefined) return defaultValue;\n 71 |   if (typeof value === \"string\" && value.trim() === \"\") return defaultValue;\n 72 |   if (Array.isArray(value) && value.length === 0) return defaultValue;\n 73 |   return value;\n 74 | }\n 75 | \n 76 | export interface SharedBlueprintInputs {\n 77 |   industry: SharedIndustry;\n 78 |   companySize: SharedCompanySize;\n 79 |   topPriorities: SharedPriority[];\n 80 |   aiJourney: SharedAIJourney;\n 81 |   dataReadiness: SharedDataReadiness;\n 82 |   leadershipCommitment: SharedLeadershipCommitment;\n 83 | }\n 84 | \n 85 | export function calculateSharedBlueprintScore(inputs: SharedBlueprintInputs): number {\n 86 |   let aiMaturity = 10;\n 87 |   if (inputs.aiJourney === \"No AI\") aiMaturity = 10;\n 88 |   else if (inputs.aiJourney === \"Exploring AI\") aiMaturity = 30;\n 89 |   else if (inputs.aiJourney === \"Running Pilots\") aiMaturity = 60;\n 90 |   else if (inputs.aiJourney === \"Scaling AI\") aiMaturity = 85;\n 91 |   else if (inputs.aiJourney === \"AI-Driven Enterprise\" || inputs.aiJourney === \"AI-Native\") aiMaturity = 100;\n 92 | \n 93 |   let businessNeed = 0;\n 94 |   (inputs.topPriorities || []).forEach(p => {\n 95 |     if (p === \"Reduce Costs\") businessNeed += 20;\n 96 |     else if (p === \"Improve Productivity\") businessNeed += 20;\n 97 |     else if (p === \"Improve Customer Experience\") businessNeed += 15;\n 98 |     else if (p === \"Increase Revenue\") businessNeed += 15;\n 99 |     else if (p === \"Strengthen Compliance\") businessNeed += 10;\n100 |     else if (p === \"AI Transformation\") businessNeed += 20;\n101 |     else if (p === \"Automate Processes\") businessNeed += 20;\n102 |   });\n103 |   if (businessNeed > 100) businessNeed = 100;\n104 | \n105 |   let dataReadiness = 20;\n106 |   if (inputs.dataReadiness === \"Highly fragmented\") dataReadiness = 20;\n107 |   else if (inputs.dataReadiness === \"Partially connected\") dataReadiness = 50;\n108 |   else if (inputs.dataReadiness === \"Mostly integrated\") dataReadiness = 75;\n109 |   else if (inputs.dataReadiness === \"Fully integrated\") dataReadiness = 100;\n110 | \n111 |   let processComplexity = 20;\n112 |   if (inputs.companySize === \"<100\") processComplexity = 20;\n113 |   else if (inputs.companySize === \"100-1000\") processComplexity = 50;\n114 |   else if (inputs.companySize === \"1000-10000\") processComplexity = 80;\n115 |   else if (inputs.companySize === \"10000+\") processComplexity = 100;\n116 | \n117 |   let transformationReadiness = 20;\n118 |   if (inputs.leadershipCommitment === \"Not Discussed\") transformationReadiness = 20;\n119 |   else if (inputs.leadershipCommitment === \"Exploring\") transformationReadiness = 50;\n120 |   else if (inputs.le