ment);\n163 |   const roiPercentage = initialInvestment > 0 ? Math.round((netSavings / initialInvestment) * 100) : 0;\n164 | \n165 |   const monthlySavings = grossSavings / 12;\n166 |   const paybackMonths = monthlySavings > 0 ? Math.max(1, Math.round((initialInvestment / monthlySavings) * 10) / 10) : 12;\n167 | \n168 |   return {\n169 |     annualHoursSaved,\n170 |     grossSavings,\n171 |     netSavings,\n172 |     roiPercentage,\n173 |     paybackMonths\n174 |   };\n175 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/shared-constants.ts","result":"  1 | /**\n  2 |  * GFF AI - SHARED CONSTANTS & DATA MODELS\n  3 |  * Designed for 2026 Sovereign Enterprise AI Platform.\n  4 |  */\n  5 | \n  6 | export const SHARED_INDUSTRIES = [\n  7 |   \"Banking\", \"Healthcare\", \"Manufacturing\", \"Retail\", \"Education\", \n  8 |   \"Government\", \"Insurance\", \"Financial Services\", \"Life Sciences\", \n  9 |   \"Mining\", \"Energy\", \"Telecom\", \"Audit\", \"Tax\", \"Legal\", \"Advisory\", \"Other\"\n 10 | ] as const;\n 11 | \n 12 | export type SharedIndustry = typeof SHARED_INDUSTRIES[number];\n 13 | \n 14 | export const SHARED_INDUSTRY_OPTIONS = SHARED_INDUSTRIES.map(ind => ({\n 15 |   value: ind,\n 16 |   label: ind === \"Other\" ? \"Other Services / General\" : ind + \" Enterprise\"\n 17 | }));\n 18 | \n 19 | export const SHARED_COMPANY_SIZES = [\"<100\", \"100-1000\", \"1000-10000\", \"10000+\"] as const;\n 20 | export type SharedCompanySize = typeof SHARED_COMPANY_SIZES[number];\n 21 | \n 22 | export const SHARED_COMPANY_SIZE_OPTIONS = [\n 23 |   { value: \"<100\", label: \"<100 employees\" },\n 24 |   { value: \"100-1000\", label: \"100 - 1,000 employees\" },\n 25 |   { value: \"1000-10000\", label: \"1,000 - 10,000 employees\" },\n 26 |   { value: \"10000+\", label: \"10,000+ employees\" }\n 27 | ] as const;\n 28 | \n 29 | export const SHARED_AI_JOURNEYS = [\n 30 |   \"No AI\", \"Exploring AI\", \"Running Pilots\", \"S