{"ts":"2026-06-26T19:00:11.751Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"hrmc0w9y","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/roi/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { ToolPageShell, ToolPreviewNotice, ToolCTA } from \"@/components/build/components\";\nimport { SHARED_INDUSTRIES, SHARED_COMPANY_SIZES } from \"@/lib/shared-constants\";\n\ninterface FormState {\n  industry: string;\n  companySize: string;\n  domain: string;\n  annualCost: string;\n  volume: string;\n  handlingTime: string;\n  targetPct: number;\n  effort: \"Low\" | \"Medium\" | \"High\";\n  improvement: number;\n  horizon: \"3 Months\" | \"6 Months\" | \"12 Months\";\n}\n\nexport default function ROICalculatorPage() {\n  const [form, setForm] = useState<FormState>({\n    industry: \"Financial Services\",\n    companySize: \"1000-10000\",\n    domain: \"Finance & Accounting\",\n    annualCost: \"450000\",\n    volume: \"125000\",\n    handlingTime: \"15\",\n    targetPct: 70,\n    effort: \"High\",\n    improvement: 45,\n    horizon: \"6 Months\",\n  });\n\n  const [errors, setErrors] = useState<Record<string, string>>({});\n  const [showModal, setShowModal] = useState(false);\n  const [loading, setLoading] = useState(false);\n\n  const handleVal = (f: keyof FormState, val: string | number) => {\n    setForm((p) => ({ ...p, [f]: val }));\n    const s = String(val).trim();\n    setErrors((prev) => {\n      const e = { ...prev };\n      if (f === \"annualCost\" || f === \"volume\") {\n        const p = parseFloat(s);\n        if (!s) e[f] = \"Required\";\n        else if (isNaN(p) || p < 0) e[f] = \"Non-negative number required\";\n        else delete e[f];\n      }\n      if (f === \"handlingTime\") {\n        const p = parseFloat(s);\n        if (s && (isNaN(p) || p < 0)) e[f] = \"Non-negative number required\";\n        else delete e[f];\n      }\n      return e;\n    });\n  };\n\n  const model = useMemo(() => {\n    if (Object.keys(errors).length > 0) return null;\n    const cost = parseFloat(form.annualCost) || 0;\n    const vol = parseFloat(form.volume) || 0;\n    const mins = parseFloat(form.handlingTime) || 0;\n\n    const effMult = form.effort === \"High\" ? 1.25 : form.effort === \"Medium\" ? 1.0 : 0.75;\n    const annualSavings = Math.min(cost * 0.92, cost * (form.targetPct / 100) * (form.improvement / 100) * effMult);\n    const baseScale = form.companySize === \"10000+\" ? 145000 : form.companySize === \"1000-10000\" ? 65000 : form.companySize === \"100-1000\" ? 28000 : 12000;\n    const investment = Math.round(baseScale + Math.min(180000, cost * 0.04));\n\n    const netSavings = Math.max(0, annualSavings - investment);\n    const roi = investment > 0 ? Math.round((annualSavings / investment) * 100) : 0;\n    const payback = annualSavings > 0 ? Math.min(12, Math.round((investment / (annualSavings / 12)) * 10) / 10) : 12;\n    const hours = Math.round(((vol * mins) / 60) * (form.targetPct / 100) * (form.improvement / 100));\n\n    return { annualSavings, investment, netSavings, roi, payback, hours, y2: annualSavings * 1.05, y3: annualSavings * 1.1 };\n  }, [form, errors]);\n\n  const triggerSimulation = () => {\n    if (Object.keys(errors).length > 0) return;\n    setLoading(true);\n    setTimeout(() => { setLoading(false); setShowModal(true); }, 750);\n  };\n\n  return (\n    <ToolPageShell>\n      {/* Page Hero Header */}\n      <div className=\"border-b border-white/5 pb-8 mb-10 flex flex-col lg:flex-row lg:items-end justify-between gap-6 animate-fadeIn\">\n        <div className=\"space-y-3 max-w-4xl\">\n          <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">Operational Blueprinting</span>\n          <h1 className=\"text-3xl lg:text-5xl font-extrabold text-white tracking-tight leading-none\">\n            Sovereign Enclave <span className=\"bg-gradient-to-r from-white via-white to-[#009DFF] bg-clip-text text-transparent\">ROI Calculator</span>\n          </h1>\n          <p className=\"text-white/60 text-xs lg:text-sm font-light max-w-2xl leading-relaxed\">\n            Perform enterprise-grade efficiency modeling. Graph financial velocity, reclaimed bandwidth, and capital returns of private, watchdog-orchestrated AI nodes.\n          </p>\n        </div>\n        <div className=\"p-4 px-6 rounded-xl bg-white/[0.01] border border-white/5 flex flex-col min-w-[210px] shrink-0\">\n          <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest\">Illustrative System Class</span>\n          <span className=\"text-xl font-bold text-[#00FF9D] mt-1 font-mono tracking-tight\">CLASS-IV ENCLAVE</span>\n        </div>\n      </div>\n\n      {/* Main Dual Pane Frame */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n        {/* Left Inputs Pane */}\n        <div className=\"lg:col-span-5 space-y-6\">\n          <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030305]/95 backdrop-blur-sm space-y-5 relative\">\n            <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/30 to-transparent pointer-events-none\" />\n            \n            <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n              <h2 className=\"text-xs font-bold text-white uppercase tracking-wider font-mono flex items-center gap-2\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF] animate-pulse\" /> Model Parameters\n              </h2>\n              <span className=\"text-[10px] font-mono text-white/40\">LOCAL SECURE BUFFER</span>\n            </div>\n\n            {/* Section 1: Firmographics */}\n            <div className=\"space-y-3.5\">\n              <h3 className=\"text-[10px] font-mono font-bold text-[#009DFF] uppercase tracking-wider\">1. Scale & Domain</h3>\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] font-mono text-white/40 uppercase block\">Enterprise Industry</label>\n                <select\n                  value={form.industry}\n                  onChange={(e) => handleVal(\"industry\", e.target.value)}\n                  className=\"w-full bg-[#080a10]/80 border border-white/5 rounded-lg px-3 py-2 text-xs text-white focus:outline-none focus:border-[#009DFF]/60 transition\"\n                >\n                  {SHARED_INDUSTRIES.map((ind) => (\n                    <option key={ind} value={ind} className=\"bg-[#030305]\">{ind} Enterprise</option>\n                  ))}\n                </select>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] font-mono text-white/40 uppercase block\">Organization FTE Scale</label>\n                <div className=\"grid grid-cols-4 gap-1 bg-[#080a10]/60 p-0.5 rounded-lg border border-white/5\">\n                  {SHARED_COMPANY_SIZES.map((sz) => (\n                    <button\n                      key={sz}\n                      type=\"button\"\n                      onClick={() => handleVal(\"companySize\", sz)}\n                      className={`py-1.5 text-[9px] font-mono rounded transition ${\n                        form.companySize === sz ? \"bg-[#009DFF]/15 text-[#009DFF] border border-[#009DFF]/30\" : \"text-white/40 hover:text-white/70\"\n                      }`}\n                    >\n                      {sz}\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] font-mono text-white/40 uppercase block\">Functional Scope</label>\n                <div className=\"grid grid-cols-2 gap-2\">\n                  {[\"Finance & Accounting\", \"Customer Operations\", \"Legal & Compliance\", \"IT & Security Ops\"].map((dom) => (\n                    <button\n                      key={dom}\n                      type=\"button\"\n                      onClick={() => handleVal(\"domain\", dom)}\n                      className={`p-2 rounded-lg border text-left transition text-[10px] truncate ${\n                        form.domain === dom ? \"bg-[#009DFF]/5 border-[#009DFF]/30 text-white\" : \"bg-[#080a10]/40 border-white/5 text-white/50 hover:text-white\"\n                      }`}\n                    >\n                      🛡️ {dom}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Section 2: Baselines & Volumes */}\n            <div className=\"space-y-3.5 pt-2 border-t border-white/5\">\n              <h3 className=\"text-[10px] font-mono font-bold text-[#009DFF] uppercase tracking-wider\">2. Cost & Volume Friction</h3>\n              \n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between items-baseline\">\n                  <label className=\"text-[9px] font-mono text-white/40 uppercase\">Annual Cost Baseline (USD)</label>\n                  {errors.annualCost && <span className=\"text-[8px] text-red-500 font-mono\">{errors.annualCost}</span>}\n                </div>\n                <div className=\"relative\">\n                  <span className=\"absolute left-3 top-1/2 -translate-y-1/2 text-xs text-white/30\">$</span>\n                  <input\n                    type=\"text\"\n                    inputMode=\"numeric\"\n                    value={form.annualCost}\n                    onChange={(e) => handleVal(\"annualCost\", e.target.value)}\n                    className=\"w-full bg-[#080a10]/80 border border-white/5 rounded-lg pl-6 pr-3 py-1.5 text-xs font-mono text-white focus:outline-none focus:border-[#009DFF]/60\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-3\">\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between items-baseline\">\n                    <label className=\"text-[9px] font-mono text-white/40 uppercase\">Annual Tasks</label>\n                    {errors.volume && <span className=\"text-[8px] text-red-500 font-mono\">{errors.volume}</span>}\n                  </div>\n                  <input\n                    type=\"text\"\n                    inputMode=\"numeric\"\n                    value={form.volume}\n                    onChange={(e) => handleVal(\"volume\", e.target.value)}\n                    className=\"w-full bg-[#080a10]/80 border border-white/5 rounded-lg px-3 py-1.5 text-xs font-mono text-white focus:outline-none focus:border-[#009DFF]/60\"\n                  />\n                </div>\n\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between items-baseline\">\n                    <label className=\"text-[9px] font-mono text-white/40 uppercase\">Handling Mins (Opt)</label>\n                    {errors.handlingTime && <span className=\"text-[8px] text-red-500 font-mono\">{errors.handlingTime}</span>}\n                  </div>\n                  <input\n                    type=\"text\"\n                    inputMode=\"numeric\"\n                    value={form.handlingTime}\n                    onChange={(e) => handleVal(\"handlingTime\", e.target.value)}\n                    className=\"w-full bg-[#080a10]/80 border border-white/5 rounded-lg px-3 py-1.5 text-xs font-mono text-white focus:outline-none focus:border-[#009DFF]/60\"\n                  />\n                </div>\n              </div>\n            </div>\n\n            {/* Section 3: Strategic Target Settings */}\n            <div className=\"space-y-3.5 pt-2 border-t border-white/5\">\n              <h3 className=\"text-[10px] font-mono font-bold text-[#009DFF] uppercase tracking-wider\">3. Sovereign Targets</h3>\n              \n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-[9px] font-mono\">\n                  <span className=\"text-white/40 uppercase\">Automation Target</span>\n                  <span className=\"text-[#00FF9D] font-bold\">{form.targetPct}%</span>\n                </div>\n                <input\n                  type=\"range\"\n                  min=\"10\"\n                  max=\"100\"\n                  step=\"5\"\n                  value={form.targetPct}\n                  onChange={(e) => handleVal(\"targetPct\", parseInt(e.target.value))}\n                  className=\"w-full h-1 bg-white/5 rounded appearance-none cursor-pointer accent-[#009DFF]\"\n                />\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] font-mono text-white/40 uppercase block\">Manual Effort Level</label>\n                <div className=\"grid grid-cols-3 gap-1 bg-[#080a10]/60 p-0.5 rounded-lg border border-white/5\">\n                  {([\"Low\", \"Medium\", \"High\"] as const).map((lvl) => (\n                    <button\n                      key={lvl}\n                      type=\"button\"\n                      onClick={() => handleVal(\"effort\", lvl)}\n                      className={`py-1 text-[9px] font-mono rounded transition ${\n                        form.effort === lvl ? \"bg-[#009DFF]/15 text-[#009DFF] border border-[#009DFF]/30\" : \"text-white/40 hover:text-white\"\n                      }`}\n                    >\n                      {lvl}\n                    </button>\n                  ))}\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-[9px] font-mono\">\n                  <span className=\"text-white/40 uppercase\">Productivity Gain</span>\n                  <span className=\"text-[#009DFF] font-bold\">{form.improvement}%</span>\n                </div>\n                <input\n                  type=\"range\"\n                  min=\"10\"\n                  max=\"90\"\n                  step=\"5\"\n                  value={form.improvement}\n                  onChange={(e) => handleVal(\"improvement\", parseInt(e.target.value))}\n                  className=\"w-full h-1 bg-white/5 rounded appearance-none cursor-pointer accent-[#009DFF]\"\n                />\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] font-mono text-white/40 uppercase block\">Deployment Horizon</label>\n                <div className=\"grid grid-cols-3 gap-1 bg-[#080a10]/60 p-0.5 rounded-lg border border-white/5\">\n                  {([\"3 Months\", \"6 Months\", \"12 Months\"] as const).map((hz) => (\n                    <button\n                      key={hz}\n                      type=\"button\"\n                      onClick={() => handleVal(\"horizon\", hz)}\n                      className={`py-1 text-[9px] font-mono rounded transition ${\n                        form.horizon === hz ? \"bg-[#009DFF]/15 text-[#009DFF] border border-[#009DFF]/30\" : \"text-white/40 hover:text-white\"\n                      }`}\n                    >\n                      {hz}\n                    </button>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            {/* Actions */}\n            <button\n              type=\"button\"\n              onClick={triggerSimulation}\n              disabled={Object.keys(errors).length > 0}\n              className={`w-full h-11 rounded-xl text-xs font-bold text-black bg-[#009DFF] hover:bg-[#009DFF]/90 transition uppercase tracking-wider flex items-center justify-center gap-2 shadow-[0_0_20px_rgba(0,157,255,0.2)] ${\n                Object.keys(errors).length > 0 ? \"opacity-40 cursor-not-allowed\" : \"\"\n              }`}\n            >\n              {loading ? \"COMPILING SECURE SPECIFICATION...\" : \"COMPILE SOVEREIGN REPORT\"}\n            </button>\n          </div>\n          <ToolPreviewNotice />\n        </div>\n\n        {/* Right Preview Pane */}\n        <div className=\"lg:col-span-7 space-y-6\">\n          <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030305]/95 backdrop-blur-sm space-y-6 relative overflow-hidden\">\n            <div className=\"absolute top-0 left-0 w-full h-[1px] bg-[#00FF9D]/30 pointer-events-none\" />\n            \n            <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n              <span className=\"text-xs font-bold text-white uppercase tracking-wider font-mono flex items-center gap-2\">\n                <span className=\"relative flex h-2 w-2\">\n                  <span className=\"animate-ping absolute h-full w-full rounded-full bg-[#00FF9D] opacity-75\" />\n                  <span className=\"relative rounded-full h-2 w-2 bg-[#00FF9D]\" />\n                </span> Live Modelled Projections\n              </span>\n              <span className=\"text-[9px] font-mono text-[#00FF9D] bg-[#00FF9D]/10 px-2 py-0.5 rounded font-bold\">RECALCULATING</span>\n            </div>\n\n            {model ? (\n              <div className=\"space-y-5 animate-fadeIn\">\n                {/* Bento Projections */}\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase block\">NET SAVINGS (YEAR 1)</span>\n                    <span className=\"text-2xl font-extrabold font-mono text-[#00FF9D] mt-1 block\">${model.netSavings.toLocaleString()}</span>\n                  </div>\n\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase block\">ESTIMATED FIRST-YEAR RETURN</span>\n                    <span className=\"text-2xl font-extrabold font-mono text-[#009DFF] mt-1 block\">+{model.roi}% ROI</span>\n                  </div>\n\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase block\">RECOVERY PAYBACK TIMELINE</span>\n                    <span className=\"text-2xl font-bold font-mono text-white mt-1 block\">{model.payback} Months</span>\n                  </div>\n\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase block\">RECLAIMED ANNUAL CAPACITY</span>\n                    <span className=\"text-2xl font-bold font-mono text-white mt-1 block\">\n                      {form.handlingTime ? `${model.hours.toLocaleString()} Hrs` : \"Provide Handling Time\"}\n                    </span>\n                  </div>\n                </div>\n\n                {/* Secure Routing Diagram */}\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#06080e]/40 space-y-2\">\n                  <span className=\"text-[9px] font-mono text-white/40 uppercase block\">Secure Single-Tenant VPC Watchdog Routing</span>\n                  <div className=\"p-3.5 rounded bg-black/50 border border-white/5 flex flex-col sm:flex-row items-center justify-between text-center sm:text-left gap-4\">\n                    <div>\n                      <span className=\"text-[9px] font-mono text-[#009DFF] uppercase font-bold block\">Inbound Inlet</span>\n                      <span className=\"text-[11px] font-bold text-white block mt-0.5\">{form.industry} Schema</span>\n                    </div>\n                    <span className=\"text-[#009DFF] font-bold animate-pulse\">→</span>\n                    <div>\n                      <span className=\"text-[9px] font-mono text-[#00FF9D] uppercase font-bold block\">Consensus Enclave</span>\n                      <span className=\"text-[11px] font-bold text-white block mt-0.5\">{form.domain} watchdog</span>\n                    </div>\n                    <span className=\"text-[#009DFF] font-bold animate-pulse\">→</span>\n                    <div>\n                      <span className=\"text-[9px] font-mono text-white/30 uppercase font-bold block\">Air-gapped State</span>\n                      <span className=\"text-[11px] font-bold text-[#00FF9D] block mt-0.5\">0% storage audit</span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Milestone Roadmap */}\n                <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] space-y-3\">\n                  <span className=\"text-[9px] font-mono text-white/40 uppercase block\">Deployment Horizon Milestone (Horizon: {form.horizon})</span>\n                  <div className=\"grid grid-cols-3 gap-3\">\n                    <div className=\"p-2.5 rounded bg-white/[0.01] border border-white/5 text-[10px]\">\n                      <span className=\"font-mono text-[#009DFF] font-bold block\">PHASE 1</span>\n                      <span className=\"text-white font-medium mt-0.5 block\">VPC Setup</span>\n                    </div>\n                    <div className=\"p-2.5 rounded bg-white/[0.01] border border-white/5 text-[10px]\">\n                      <span className=\"font-mono text-[#009DFF] font-bold block\">PHASE 2</span>\n                      <span className=\"text-white font-medium mt-0.5 block\">Fine-Tuning</span>\n                    </div>\n                    <div className=\"p-2.5 rounded bg-[#00FF9D]/5 border border-[#00FF9D]/20 text-[10px]\">\n                      <span className=\"font-mono text-[#00FF9D] font-bold block\">PHASE 3</span>\n                      <span className=\"text-white font-medium mt-0.5 block\">Watchdog Go-Live</span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Disclaimers */}\n                <div className=\"flex justify-between text-[9px] font-mono text-white/30 border-t border-white/5 pt-3\">\n                  <span>SYSTEM v2.26</span>\n                  <span>* MODELLED PROJECTIONS ONLY. NO PERFORMANCE GUARANTEED.</span>\n                </div>\n              </div>\n            ) : (\n              <div className=\"p-12 text-center rounded-xl border border-dashed border-white/10 flex flex-col items-center justify-center space-y-2\">\n                <span className=\"text-xs text-red-500 font-mono font-bold\">MODEL BLOCKED</span>\n                <p className=\"text-[10px] text-white/40\">Please fix parameter errors inside the left control panel to restore projections.</p>\n              </div>\n            )}\n          </div>\n        </div>\n      </div>\n\n      {/* Technical CTA Block */}\n      <ToolCTA />\n\n      {/* REPORT MODAL OVERLAY */}\n      <AnimatePresence>\n        {showModal && model && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#020204]/90 backdrop-blur-md overflow-y-auto\">\n            <motion.div\n              initial={{ opacity: 0, scale: 0.96 }}\n              animate={{ opacity: 1, scale: 1 }}\n              exit={{ opacity: 0, scale: 0.96 }}\n              className=\"relative w-full max-w-3xl rounded-2xl border border-white/10 bg-[#030305] p-6 md:p-8 shadow-3xl text-white my-8 overflow-hidden\"\n            >\n              <div className=\"absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-transparent via-[#009DFF] to-[#00FF9D]\" />\n              \n              <button\n                type=\"button\"\n                onClick={() => setShowModal(false)}\n                className=\"absolute top-5 right-5 p-2 rounded-lg border border-white/5 hover:bg-white/[0.08] transition text-white/50 hover:text-white\"\n 