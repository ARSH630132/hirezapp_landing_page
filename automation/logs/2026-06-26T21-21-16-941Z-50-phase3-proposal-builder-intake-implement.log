 className=\"text-xl font-extrabold tracking-tight mt-2 text-white\">Establish Organization Context</h2>\n323 |                     <p className=\"text-white/50 text-xs mt-1 font-light\">Input baseline coordinates to compile specific regulatory and compliance parameters.</p>\n324 |                   </div>\n325 | \n326 |                   <div className=\"space-y-2\">\n327 |                     <label className=\"text-[10px] font-mono text-white/55 uppercase block\">Organization / Company Name</label>\n328 |                     <input\n329 |                       type=\"text\"\n330 |                       value={inputs.companyName}\n331 |                       onChange={(e) => setInputs({ ...inputs, companyName: e.target.value })}\n332 |                       placeholder=\"e.g. Acme Sovereign Holdings\"\n333 |                       className=\"w-full h-11 px-4 rounded-lg bg-black border border-white/10 text-xs text-white placeholder-white/20 focus:border-[#009DFF] focus:outline-none transition\"\n334 |                     />\n335 |                   </div>\n336 | \n337 |                   <div className=\"space-y-2\">\n338 |                     <label className=\"text-[10px] font-mono text-white/55 uppercase block\">Target Operating Sector</label>\n339 |                     <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-2.5 max-h-[160px] overflow-y-auto pr-1.5 custom-scrollbar text-left\">\n340 |                       {INDUSTRIES.map((ind) => (\n341 |                         <button\n342 |                           key={ind.id}\n343 |                           type=\"button\"\n344 |                           onClick={() => setInputs({ ...inputs, industry: ind.id })}\n345 |                           className={`p-3 rounded-lg border text-left transition flex flex-col justify-between ${inputs.industry === ind.id ? \"border-[#009DFF]/50 bg-[#009DFF]/5\" : \"border-white/5 bg-black/50 hover:border-white/10\"}`}\n346 |                         >\n347 |              