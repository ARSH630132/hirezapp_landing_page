 || DATA_READINESS[2];\n152 | \n153 |     let baseWeeks = 12;\n154 |     if (sizeObj.id === \"small\") baseWeeks = 6;\n155 |     else if (sizeObj.id === \"medium\") baseWeeks = 8;\n156 |     else if (sizeObj.id === \"global-conglomerate\") baseWeeks = 16;\n157 | \n158 |     if (readObj.id === \"raw\") baseWeeks += 3;\n159 |     else if (readObj.id === \"vectorized\") baseWeeks -= 2;\n160 |     else if (readObj.id === \"fully-governed\") baseWeeks -= 3;\n161 | \n162 |     const totalWeeks = Math.max(4, baseWeeks);\n163 |     const p1 = Math.max(1, Math.round(totalWeeks * 0.15));\n164 |     const p2 = Math.max(1, Math.round(totalWeeks * 0.25));\n165 |     const p3 = Math.max(1, Math.round(totalWeeks * 0.40));\n166 |     const p4 = totalWeeks - (p1 + p2 + p3);\n167 | \n168 |     let licenseCost = \"$45,000 / Year\";\n169 |     if (sizeObj.id === \"global-conglomerate\") licenseCost = \"$120,000 / Year (Sovereign Core)\";\n170 |     else if (sizeObj.id === \"small\") licenseCost = \"$15,000 / Year (Sandbox Dev)\";\n171 |     else if (sizeObj.id === \"medium\") licenseCost = \"$30,000 / Year (Foundry Standard)\";\n172 | \n173 |     const squadSize = sizeObj.id === \"small\" ? 2 : sizeObj.id === \"medium\" ? 3 : sizeObj.id === \"enterprise\" ? 4 : 5;\n174 | \n175 |     return { org, industry: indObj.label, industryId: indObj.id, industryDesc: indObj.desc, companyScale: sizeObj.label, dataReadiness: readObj.label, dataReadinessId: readObj.id, totalWeeks, p1, p2, p3, p4, licenseCost, squadSize };\n176 |   };\n177 | \n178 |   const pData = generateProposalData();\n179 | \n180 |   const rawOutlineText = `\n181 | GFF AI PROPOSAL SPECIFICATION OUTLINE\n182 | Organization: ${pData.org}\n183 | Industry: ${pData.industry}\n184 | Scale: ${pData.companyScale}\n185 | Horizon Target: ${pData.totalWeeks} Weeks\n186 | License Plan: ${pData.licenseCost}\n187 | \n188 | I. EXECUTIVE SUMMARY: Deploy single-tenant VPC sovereign GFF nodes inside local bounds.\n189 | II. CHALLENGE STATEMENT: S