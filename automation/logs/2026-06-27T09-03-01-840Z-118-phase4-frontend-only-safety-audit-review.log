perations\", \"governance\", \"activity\"].includes(sectionId);\n148 |   }\n149 |   \n150 |   return false;\n151 | }\n152 | \n153 | // Check access rules for Admin Oversight Console (/admin/[sectionId])\n154 | export function canAccessAdminSection(role: PreviewRole, sectionId: string): boolean {\n155 |   // Only GFF internal roles and auditor can access admin panel\n156 |   if (role === \"gff_admin\") return true;\n157 |   \n158 |   if (role === \"gff_operator\") {\n159 |     // Operator cannot access billing, settings, or users management\n160 |     return ![\"billing\", \"settings\", \"users\"].includes(sectionId);\n161 |   }\n162 |   \n163 |   if (role === \"finance_admin\") {\n164 |     // Finance can access dashboard, clients, billing, analytics, activity, settings\n165 |     return [\"dashboard\", \"clients\", \"billing\", \"analytics\", \"activity\", \"settings\"].includes(sectionId);\n166 |   }\n167 |   \n168 |   if (role === \"support_agent\") {\n169 |     // Support agent can access dashboard, clients, support, activity, users\n170 |     return [\"dashboard\", \"clients\", \"support\", \"activity\", \"users\"].includes(sectionId);\n171 |   }\n172 |   \n173 |   if (role === \"viewer\") {\n174 |     // Auditor can view dashboards, activity, governance read-only\n175 |     return [\"dashboard\", \"clients\", \"projects\", \"analytics\", \"governance\", \"activity\"].includes(sectionId);\n176 |   }\n177 |   \n178 |   // Clients (client_admin, client_member) cannot access admin section AT ALL\n179 |   return false;\n180 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/mock-data-model.ts","result":"  1 | /**\n  2 |  * UI QUALITY CONSTITUTION - GFF AI PREVIEW DATA MODEL\n  3 |  * \n  4 |  * This file centralizes the complete, high-fidelity mock data model for the\n  5 |  * Client Portal and Admin Portal as required by Task 77-phase4-private-mock-data-model.\n  6 |  * \n  7 |  * All data is deterministic, marked as demo/