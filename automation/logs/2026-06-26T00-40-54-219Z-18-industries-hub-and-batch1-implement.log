tions\"\n        title=\"Industries We Transform\"\n        highlightedWord=\"Industries\"\n        description=\"GFF AI engineers custom cognitive architectures calibrated for the security, compliance, and velocity needs of your sector.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-16\">\n        <h2 className=\"text-[26px] sm:text-[34px] font-bold text-white tracking-tight mb-8\">\n          Interactive Industry Automation Hotspots\n        </h2>\n        <IndustrySolutionMap />\n      </div>\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24\">\n        <h2 className=\"text-[26px] sm:text-[34px] font-bold text-white tracking-tight mb-8\">\n          Industry Solutions Directory\n        </h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {industries.map((ind) => (\n            <div key={ind.id} id={ind.id} className=\"p-6 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] hover:border-[#009DFF]/20 transition-all group\">\n              <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-wider font-semibold\">SECTOR</span>\n              <h3 className=\"text-[18px] font-semibold text-white tracking-tight mt-2 group-hover:text-[#009DFF] transition-colors\">{ind.title}</h3>\n              <p className=\"mt-3 text-[13.5px] leading-[1.6] text-white/60 font-light\">{ind.desc}</p>\n            </div>\n          ))}\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nconst S_DATA = [\n  {\n    id: \"financial-services\",\n    title: \"Financial Services\",\n    path: \"/industries/financial-services\",\n    cat: \"CAPITAL MARKETS\",\n    desc: \"Deploy multi-asset auditing, compliance checks, and transaction risk surveillance.\",\n    challenges: [\"Legacy core system isolation\", \"Global compliance pressure\", \"Manual documentation gaps\"],\n    agents: [\"Compliance Assistant\", \"Risk Review Agent\", \"Customer Intelligence Agent\"]\n  },\n  {\n    id: \"banking\",\n    title: \"Banking\",\n    path: \"/industries/banking\",\n    cat: \"ENTERPRISE BANKING\",\n    desc: \"Unify legacy mainframes with conversational AI interfaces and relationship copilots.\",\n    challenges: [\"Inquiry scale bottlenecks\", \"Fragmented policy search archives\", \"Manual back-office tasks\"],\n    agents: [\"Banking Knowledge Agent\", \"Relationship Manager Copilot\", \"Contract Intelligence Agent\"]\n  },\n  {\n    id: \"insurance\",\n    title: \"Insurance\",\n    path: \"/industries/insurance\",\n    cat: \"PROPERTY & CASUALTY\",\n    desc: \"Accelerate claim lifecycle velocity and automate risk assessment with secure multi-agent pipelines.\",\n    challenges: [\"Claims operational overhead\", \"Unstructured policy search latency\", \"Document-heavy workflows\"],\n    agents: [\"Claims Triage Agent\", \"Policy Intelligence Agent\", \"Underwriting Copilot\"]\n  }\n];\n\nconst PATTERNS = [\n  { title: \"Legacy Core Decoupling\", desc: \"Decouple cognitive reasoning from direct writes through secure read-only mirrors.\" },\n  { title: \"Compliance Auditing\", desc: \"Embed legal policies directly into LLM orchestration logic as active system guardrails.\" },\n  { title: \"Information Isolation\", desc: \"Build private, local semantic vector databases with OCR pre-processing.\" },\n  { title: \"Human-in-the-Loop\", desc: \"All system dispatches queue in a human review panel before ledger settlement.\" }\n];\n\nexport default function IndustriesPage() {\n  const [tab, setTab] = useState(\"financial-services\");\n  const active = S_DATA.find((ind) => ind.id === tab) || S_DATA[0];\n  const [arch, setArch] = useState(\"cognitive\");\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Enterprise Verticals\"\n        title=\"AI Engineered for Your Industry\"\n        highlightedWord=\"Industry\"\n        description=\"GFF AI engineers custom cognitive frameworks calibrated for the strict security, compliance, and velocity needs of enterprise sectors.\"\n      />\n\n      {/* Selector Grid */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-20\">\n        <div className=\"text-center mb-12\">\n          <span className=\"text-[10px] font-mono uppercase tracking-widest text-[#009DFF] font-bold\">Interactive Solution Map</span>\n          <h2 className=\"text-[28px] sm:text-[34px] font-bold text-white tracking-tight mt-1\">Sectors We Transform</h2>\n        </div>\n\n        <div className=\"flex flex-wrap justify-center gap-2 mb-8\">\n          {S_DATA.map((ind) => (\n            <button\n              key={ind.id}\n              onClick={() => setTab(ind.id)}\n              className={`px-5 py-2.5 rounded-full text-xs font-semibold transition-all border ${\n                tab === ind.id ? \"bg-white text-black border-white\" : \"bg-white/5 text-white/70 border-white/5 hover:text-white\"\n              }`}\n            >\n              {ind.title}\n            </button>\n          ))}\n        </div>\n\n        <div className=\"rounded-2xl border border-white/5 bg-[#050507]/80 p-6 lg:p-8 max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          <div className=\"lg:col-span-5 flex flex-col justify-between min-h-[220px]\">\n            <div>\n              <span className=\"text-[9px] font-mono text-[#009DFF] tracking-widest uppercase\">{active.cat}</span>\n              <h3 className=\"text-2xl font-bold text-white tracking-tight mt-1\">{active.title}</h3>\n              <p className=\"mt-3 text-sm text-white/60 font-light leading-relaxed\">{active.desc}</p>\n            </div>\n            <div className=\"mt-6\">\n              <a href={active.path} className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10\">\n                Explore Full Strategy & Agents →\n              </a>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-4 border-t lg:border-t-0 lg:border-l border-white/5 pt-6 lg:pt-0 lg:pl-6\">\n            <h4 className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mb-4\">Core Challenges</h4>\n            <ul className=\"space-y-3\">\n              {active.challenges.map((c, i) => (\n                <li key={i} className=\"flex gap-2.5 items-start text-xs text-white/80 font-light leading-normal\">\n                  <span className=\"text-[#E4000F] font-mono font-bold\">•</span> {c}\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          <div className=\"lg:col-span-3 border-t lg:border-t-0 lg:border-l border-white/5 pt-6 lg:pt-0 lg:pl-6\">\n            <h4 className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mb-4\">Key Blueprints</h4>\n            <div className=\"space-y-2\">\n              {active.agents.map((a, i) => (\n                <div key={i} className=\"p-2.5 rounded-lg bg-white/[0.01] border border-white/5 text-xs font-medium text-white\">\n                  {a}\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Shared Patterns */}\n      <div className=\"border-t border-b border-white/5 bg-[#030304]/40 py-20\">\n        <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16\">\n          <div className=\"max-w-[800px] mb-12\">\n            <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Sovereign Architecture</span>\n            <h2 className=\"text-[26px] sm:text-[34px] font-bold text-white tracking-tight mt-1\">Cross-Industry Challenge Patterns</h2>\n          </div>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {PATTERNS.map((p, i) => (\n              <div key={i} className=\"p-6 rounded-2xl border border-white/5 bg-[#050506]/80 flex gap-4\">\n                <div className=\"w-1.5 h-1.5 rounded-full bg-[#E4000F] mt-2 shrink-0\" />\n                <div>\n                  <h3 className=\"text-sm font-semibold text-white tracking-tight\">{p.title}</h3>\n                  <p className=\"mt-1.5 text-xs text-white/60 font-light leading-relaxed\">{p.desc}</p>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Interactive Blueprint */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 py-20\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-[10px] font-mono text-[#E4000F] uppercase tracking-widest font-bold\">Reference Blueprint</span>\n            <h2 className=\"text-[26px] sm:text-[34px] font-bold text-white tracking-tight mt-1\">Reference Architecture</h2>\n            <p className=\"mt-3 text-xs text-white/60 font-light leading-relaxed\">\n              We separate agent functions into clean, isolated security tiers. Click below to inspect layers.\n            </p>\n            <div className=\"mt-6 space-y-2\">\n              {[\"ingest\", \"cognitive\", \"action\"].map((k) => (\n                <button\n                  key={k}\n                  onClick={() => setArch(k)}\n                  className={`w-full p-3.5 rounded-xl text-left border text-xs font-semibold transition-all ${\n                    arch === k ? \"bg-white/5 border-white/10 text-white\" : \"border-transparent text-white/50 hover:text-white\"\n                  }`}\n                >\n                  {k === \"ingest\" ? \"01. Data Ingestion Gateways\" : k === \"cognitive\" ? \"02. Cognitive Orchestration Layer\" : \"03. Secure Action Dispatch\"}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-7 p-6 rounded-2xl border border-white/5 bg-[#050506]/60 backdrop-blur-md\">\n            <div className=\"py-4 border-b border-white/5 text-center text-xs font-mono tracking-widest text-[#009DFF] uppercase font-bold\">\n              Layer Active Spec\n            </div>\n            <div className=\"mt-4 min-h-[100px]\">\n              <h4 className=\"text-sm font-bold text-white uppercase\">\n                {arch === \"ingest\" ? \"Data Extraction & Gateway\" : arch === \"cognitive\" ? \"Sovereign Cognitive Core\" : \"Secure Dispatched Outbound\"}\n              </h4>\n              <p className=\"mt-2 text-xs text-white/60 font-light leading-relaxed\">\n                {arch === \"ingest\"\n                  ? \"Ingest data from core legacy systems, transactional records, and internal document queues securely and with high throughput.\"\n                  : arch === \"cognitive\"\n                  ? \"Assess query intent, isolate tool logic execution, and route workloads within strict sandboxed compliance contexts.\"\n                  : \"Dispatch action payloads to legacy systems, databases, or API integrations with human-in-the-loop validation trails.\"}\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-20\">\n        <PremiumCTA\n          title=\"Build AI for Your Industry\"\n          description=\"Speak with our systems engineers to map your operational boundaries, security specifications, and custom sandbox deployments.\"\n          primaryLabel=\"Connect with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
