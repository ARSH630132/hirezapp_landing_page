5 |     description: \"No AI implementations in production; currently surveying options.\",\n136 |     accentColor: \"#94A3B8\"\n137 |   },\n138 |   {\n139 |     id: \"Exploring AI\",\n140 |     title: \"Exploring AI\",\n141 |     description: \"Initial workshops completed; assessing specific operational pilots.\",\n142 |     accentColor: \"#3B82F6\"\n143 |   },\n144 |   {\n145 |     id: \"Running Pilots\",\n146 |     title: \"Running Pilots\",\n147 |     description: \"Isolated, active pilot workflows or custom isolated GPT instances.\",\n148 |     accentColor: \"#087DF3\"\n149 |   },\n150 |   {\n151 |     id: \"Scaling AI\",\n152 |     title: \"Scaling AI\",\n153 |     description: \"Multi-department pipelines; production-ready systems scaling.\",\n154 |     accentColor: \"#F59E0B\"\n155 |   },\n156 |   {\n157 |     id: \"AI-Driven Enterprise\",\n158 |     title: \"AI-Driven Enterprise\",\n159 |     description: \"Agent-centric models are standard for operations and scheduling.\",\n160 |     accentColor: \"#8B5CF6\"\n161 |   },\n162 |   {\n163 |     id: \"AI-Native\",\n164 |     title: \"AI-Native\",\n165 |     description: \"Workflows are automated by default with human-in-the-loop nodes.\",\n166 |     accentColor: \"#10B981\"\n167 |   }\n168 | ];\n169 | \n170 | const dataReadinessOptItems = [\n171 |   { id: \"Highly fragmented\", title: \"Highly fragmented\", description: \"Siloed SQL, spreadsheets and offline legacy datastores.\" },\n172 |   { id: \"Partially connected\", title: \"Partially connected\", description: \"Some batch databases connected; basic REST API layer exists.\" },\n173 |   { id: \"Mostly integrated\", title: \"Mostly integrated\", description: \"Central vector cache or data warehouse active with regular syncs.\" },\n174 |   { id: \"Fully integrated\", title: \"Fully integrated\", description: \"Real-time Kafka streams and event-driven vectorized storage meshes.\" }\n175 | ];\n176 | \n177 | const leadershipOptItems = [\n178 |   { id: \"Not Discussed\", title: \"Not Discussed\", description: \"No leadership mandate; exploration at the engineering level only.\" },\n179 |   { id: \"Exploring\", title: \"Exploring\", description: \"Oversight committee formed; initial budgeting and planning underway.\" },\n180 |   { id: \"Budget Approved\", title: \"Budget Approved\", description: \"Dedicated funds allocated for sandboxed pilots and proof-of-concepts.\" },\n181 |   { id: \"Executive Mandate\", title: \"Executive Mandate\", description: \"Sovereign AI transformation listed as a top-3 enterprise corporate priority.\" }\n182 | ];\n183 | \n184 | const challengeOptions = [\n185 |   { value: \"Tech Stack\", label: \"Legacy Technology Stack\" },\n186 |   { value: \"Budget/ROI\", label: \"Unclear ROI & Budget Constraint\" },\n187 |   { value: \"Talent Shortage\", label: \"Talent & Skill Shortage\" },\n188 |   { value: \"Security/Compliance\", label: \"Security, Privacy & Compliance\" },\n189 |   { value: \"Change Management\", label: \"Organizational Inertia\" },\n190 | ];\n191 | \n192 | export default function BlueprintGenerator() {\n193 |   const [savedList, setSavedList] = useState<SavedBlueprint[]>([]);\n194 |   const [isSaved, setIsSaved] = useState(false);\n195 |   const [isCopied, setIsCopied] = useState(false);\n196 |   const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n197 |   const [historyLoaded, setHistoryLoaded] = useState<string | null>(null);\n198 | \n199 |   // Expose stepper actions to load states back in\n200 |   const [stepperActions, setStepperActions] = useState<WizardStepperSystemActions<WizardData> | null>(null);\n201 | \n202 |   useEffect(() => {\n203 |     // Load initial list from localStorage\n204 |     if (typeof window !== \"undefined\") {\n205 |       try {\n206 |         const stored = localStorage.getItem(\"gff_blueprint_history\");\n207 |         if (stored) {\n208 |           setSavedList(JSON.parse(stored));\n209 |         }\n210 |       } catch (e) {\n211 |         console.error(e);\n212 |       }\n213 |     }\n214 |   }, []);\n215 | \n216 |   const handleSaveLocally = (currentData: WizardData, currentScore: number, currentCategory: string) => {\n217 |     const newItem: SavedBlueprint = {\n218 |       id: `gff-bp-${Date.now()}`,\n219 |       timestamp: new Date().toLocaleString(\"en-US\", {\n220 |         month: \"short\",\n221 |         day: \"2-digit\",\n222 |         year: \"numeric\",\n223 |         hour: \"2-digit\",\n224 |         minute: \"2-digit\",\n225 |         second: \"2-digit\",\n226 |       }),\n227 |       data: currentData,\n228 |       score: currentScore,\n229 |       category: currentCategory,\n230 |     };\n231 | \n232 |     const updated = [newItem, ...savedList.filter(item => item.data.email !== currentData.email || item.score !== currentScore)];\n233 |     setSavedList(updated);\n234 |     if (typeof window !== \"undefined\") {\n235 |       try {\n236 |         localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updated));\n237 |       } catch (e) {\n238 |         console.error(\"Failed to save to localStorage:\", e);\n239 |       }\n240 |     }\n241 |     setIsSaved(true);\n242 |     setTimeout(() => setIsSaved(false), 3000);\n243 |   };\n244 | \n245 |   const initialData: WizardData = {\n246 |     industry: \"\",\n247 |     companySize: \"\",\n248 |     topPriorities: [],\n249 |     aiJourney: \"\",\n250 |     dataReadiness: \"\",\n251 |     leadershipCommitment: \"\",\n252 |     biggestChallenge: \"\",\n253 |     email: \"\",\n254 |     otp: \"\",\n255 |     budget: \"\",\n256 |     geography: \"\",\n257 |     customChallengeText: \"\",\n258 |     otpSent: false,\n259 |     enteredOtp: \"\"\n260 |   };\n261 | \n262 |   const steps: WizardStep<WizardData>[] = [\n263 |     {\n264 |       id: \"organization\",\n265 |       label: \"Organization Context\",\n266 |       description: \"Define your industry vertical, operational scale, and region.\",\n267 |       duration: \"1-2 min\",\n268 |       validate: (data) => {\n269 |         if (!data.industry) return \"Industry vertical selection is required.\";\n270 |         if (!data.companySize) return \"Organization scale selection is required.\";\n271 |         return null;\n272 |       },\n273 |       render: ({ data, onChange }) => (\n274 |         <div className=\"space-y-6\">\n275 |           <div className=\"space-y-3\">\n276 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n277 |               1. Select Industry Vertical <span className=\"text-[#087DF3]\">*</span>\n278 |             </span>\n279 |             <ToolOptionGrid\n280 |               options={industryOptItems}\n281 |               selectedId={data.industry}\n282 |               onChange={(id) => onChange({ industry: id })}\n283 |             />\n284 |           </div>\n285 | \n286 |           <div className=\"space-y-3 pt-6 border-t border-white/5\">\n287 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n288 |               2. Select Organization Scale <span className=\"text-[#087DF3]\">*</span>\n289 |             </span>\n290 |             <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-3\">\n291 |               {companySizeOptions.map((opt) => {\n292 |                 const isSelected = data.companySize === opt.value;\n293 |                 return (\n294 |                   <button\n295 |                     key={opt.value}\n296 |                     type=\"button\"\n297 |                     onClick={() => onChange({ companySize: opt.value })}\n298 |                     className={`p-3.5 rounded-xl border text-center transition-all duration-300 text-xs font-bold leading-normal ${\n299 |                       isSelected\n300 |                         ? \"bg-white/[0.03] border-[#087DF3] text-white shadow-[0_0_15px_rgba(8,125,243,0.15)]\"\n301 |                         : \"bg-white/[0.01] border-white/5 text-white/60 hover:border-white/10 hover:text-white\"\n302 |                     }`}\n303 |                   >\n304 |                     {opt.label}\n305 |                   </button>\n306 |                 );\n307 |               })}\n308 |             </div>\n309 |           </div>\n310 | \n311 |           <div className=\"pt-6 border-t border-white/5 grid grid-cols-1 md:grid-cols-2 gap-4\">\n312 |             <div className=\"space-y-1.5\">\n313 |               <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">Target Budget Range (Optional)</label>\n314 |               <select\n315 |                 value={data.budget || \"\"}\n316 |                 onChange={(e) => onChange({ budget: e.target.value })}\n317 |                 className=\"w-full h-11 rounded-xl border border-white/10 bg-black/50 px-4 text-xs text-white focus:border-[#087DF3] outline-none transition\"\n318 |               >\n319 |                 <option value=\"\" className=\"bg-black text-white/60\">-- Select Target Budget Range --</option>\n320 |                 {budgetOptions.map((o) => (\n321 |                   <option key={o.value} value={o.value} className=\"bg-black text-white\">{o.label}</option>\n322 |                 ))}\n323 |               </select>\n324 |             </div>\n325 | \n326 |             <div className=\"space-y-1.5\">\n327 |               <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">Geography / Region (Optional)</label>\n328 |               <select\n329 |                 value={data.geography || \"\"}\n330 |                 onChange={(e) => onChange({ geography: e.target.value })}\n331 |                 className=\"w-full h-11 rounded-xl border border-white/10 bg-black/50 px-4 text-xs text-white focus:border-[#087DF3] outline-none transition\"\n332 |               >\n333 |                 <option value=\"\" className=\"bg-black text-white/60\">-- Select Region / Deployment --</option>\n334 |                 {geographyOptions.map((o) => (\n335 |                   <option key={o.value} value={o.value} className=\"bg-black text-white\">{o.label}</option>\n336 |                 ))}\n337 |               </select>\n338 |             </div>\n339 |           </div>\n340 |         </div>\n341 |       )\n342 |     },\n343 |     {\n344 |       id: \"priorities\",\n345 |       label: \"Strategic Priorities\",\n346 |       description: \"Select up to 3 priority outcomes for your AI transformation.\",\n347 |       duration: \"1 min\",\n348 |       validate: (data) => {\n349 |         if (!data.topPriorities || data.topPriorities.length === 0) {\n350 |           return \"Please select at least 1 strategic priority outcome.\";\n351 |         }\n352 |         if (data.topPriorities.length > 3) {\n353 |           return \"You can select up to 3 strategic priority outcomes.\";\n354 |         }\n355 |         return null;\n356 |       },\n357 |       render: ({ data, onChange }) => {\n358 |         const togglePriority = (id: string) => {\n359 |           const current = [...(data.topPriorities || [])];\n360 |           if (current.includes(id)) {\n361 |             onChange({ topPriorities: current.filter((x) => x !== id) });\n362 |           } else {\n363 |             if (current.length < 3) {\n364 |               onChange({ topPriorities: [...current, id] });\n365 |             }\n366 |           }\n367 |         };\n368 | \n369 |         return (\n370 |           <div className=\"space-y-4\">\n371 |             <div className=\"flex justify-between items-center\">\n372 |               <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n373 |                 Select Strategic Targets (Max 3) <span className=\"text-[#087DF3]\">*</span>\n374 |               </span>\n375 |               <span className=\"text-[9px] font-mono text-white/40\">{(data.topPriorities || []).length} of 3 selected</span>\n376 |             </div>\n377 |             <ToolOptionGrid\n378 |               options={priorityOptItems}\n379 |               selectedId={data.topPriorities}\n380 |               onChange={togglePriority}\n381 |               multiSelect={true}\n382 |             />\n383 |           </div>\n384 |         );\n385 |       }\n386 |     },\n387 | \n388 |     {\n389 |       id: \"ai-journey\",\n390 |       label: \"AI Maturity Stage\",\n391 |       description: \"Assess your current operational AI implementation depth.\",\n392 |       duration: \"1 min\",\n393 |       validate: (data) => {\n394 |         if (!data.aiJourney) return \"AI Adoption stage is required.\";\n395 |         return null;\n396 |       },\n397 |       render: ({ data, onChange }) => (\n398 |         <div className=\"space-y-4\">\n399 |           <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n400 |             Select Current Operational AI Adoption Depth <span className=\"text-[#087DF3]\">*</span>\n401 |           </span>\n402 |           <ToolOptionGrid\n403 |             options={aiJourneyOptItems}\n404 |             selectedId={data.aiJourney}\n405 |             onChange={(id) => onChange({ aiJourney: id })}\n406 |           />\n407 |         </div>\n408 |       )\n409 |     },\n410 |     {\n411 |       id: \"data-leadership\",\n412 |       label: \"Data & Governance\",\n413 |       description: \"Select your data integration readiness and leadership commitment level.\",\n414 |       duration: \"1-2 min\",\n415 |       validate: (data) => {\n416 |         if (!data.dataReadiness) return \"Data infrastructure readiness selection is required.\";\n417 |         if (!data.leadershipCommitment) return \"Leadership commitment selection is required.\";\n418 |         return null;\n419 |       },\n420 |       render: ({ data, onChange }) => (\n421 |         <div className=\"space-y-6\">\n422 |           <div className=\"space-y-3\">\n423 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n424 |               1. Select Data Infrastructure Readiness <span className=\"text-[#087DF3]\">*</span>\n425 |             </span>\n426 |             <ToolOptionGrid\n427 |               options={dataReadinessOptItems}\n428 |               selectedId={data.dataReadiness}\n429 |               onChange={(id) => onChange({ dataReadiness: id })}\n430 |             />\n431 |           </div>\n432 | \n433 |           <div className=\"space-y-3 pt-6 border-t border-white/5\">\n434 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n435 |               2. Select Leadership Alignment & Mandate <span className=\"text-[#087DF3]\">*</span>\n436 |             </span>\n437 |             <ToolOptionGrid\n438 |               options={leadershipOptItems}\n439 |               selectedId={data.leadershipCommitment}\n440 |               onChange={(id) => onChange({ leadershipCommitment: id })}\n441 |             />\n442 |           </div>\n443 |         </div>\n444 |       )\n445 |     },\n446 |     {\n447 |       id: \"challenge\",\n448 |       label: \"Sovereign Roadblock\",\n449 |       description: \"Identify your primary roadblock and describe the context.\",\n450 |       duration: \"2 min\",\n451 |       validate: (data) => {\n452 |         if (!data.biggestChallenge) return \"Please select a primary bottleneck category.\";\n453 |         if (!data.customChallengeText || data.customChallengeText.trim().length < 10) {\n454 |           return \"Please describe your roadblock context (minimum 10 characters).\";\n455 |         }\n456 |         return null;\n457 |       },\n458 |       render: ({ data, onChange }) => (\n459 |         <div className=\"space-y-6\">\n460 |           <div className=\"space-y-3\">\n461 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n462 |               1. Select Primary Bottleneck Category <span className=\"text-[#087DF3]\">*</span>\n463 |             </span>\n464 |             <div className=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\n465 |               {challengeOptions.map((opt) => {\n466 |                 const isSelected = data.biggestChallenge === opt.value;\n467 |                 const cleanLabel = opt.label.split(\" & \").pop()?.split(\" Constraint\").shift() || opt.label;\n468 |                 return (\n469 |                   <button\n470 |                     key={opt.value}\n471 |                     type=\"button\"\n472 |                     onClick={() => onChange({ biggestChallenge: opt.value })}\n473 |                     className={`p-3 rounded-xl border text-center transition-all duration-300 text-xs font-bold leading-tight ${\n474 |                       isSelected\n475 |                         ? \"bg-white/[0.03] border-[#087DF3] text-white shadow-[0_0_15px_rgba(8,125,243,0.15)]\"\n476 |                         : \"bg-white/[0.01] border-white/5 text-white/60 hover:border-white/10 hover:text-white\"\n477 |                     }`}\n478 |                   >\n479 |                     {cleanLabel}\n480 |                   </button>\n481 |                 );\n482 |               })}\n483 |             </div>\n484 |           </div>\n485 | \n486 |           <div className=\"space-y-3 pt-6 border-t border-white/5\">\n487 |             <div className=\"flex justify-between items-center\">\n488 |               <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n489 |                 2. Describe Roadblock In Detail <span className=\"text-[#087DF3]\">*</span>\n490 |               </span>\n491 |               <span className=\"text-[9px] font-mono text-white/40\">{(data.customChallengeText || \"\").length} characters (min 10)</span>\n492 |             </div>\n493 |             <textarea\n494 |               value={data.customChallengeText || \"\"}\n495 |               onChange={(e) => onChange({ customChallengeText: e.target.value })}\n496 |               placeholder=\"E.g., We have legacy databases in SQL and SAP, but no unified knowledge graph. We want to automate invoice ingestion but are worried about security and compliance regulations...\"\n497 |               className=\"w-full h-36 rounded-xl border border-white/10 bg-black/50 p-4 text-xs sm:text-sm text-white focus:border-[#087DF3] outline-none transition resize-none leading-relaxed\"\n498 |             />\n499 |           </div>\n500 |         </div>\n501 |       )\n502 |     },\n503 | \n504 |     {\n505 |       id: \"verification\",\n506 |       label: \"Portal Authorization\",\n507 |       description: \"Verify your email with a simulated, secure GFF credentials checkpoint.\",\n508 |       duration: \"1 min\",\n509 |       validate: (data) => {\n510 |         if (!data.email) return \"Enterprise email address is required.\";\n511 |         const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n512 |         if (!emailRegex.test(data.email)) return \"Please enter a valid enterprise email address.\";\n513 |         if (!data.enteredOtp) {\n514 |           return \"Verification PIN is required. Please request and enter the access PIN.\";\n515 |         }\n516 |         if (data.enteredOtp !== \"123456\") {\n517 |           return \"Invalid verification PIN. Use the simulated PIN '123456' to proceed.\";\n518 |         }\n519 |         return null;\n520 |       },\n521 |       render: ({ data, onChange }) => {\n522 |         const requestSimulatedOtp = () => {\n523 |           if (!data.email) return;\n524 |           onChange({ otpSent: true });\n525 |         };\n526 | \n527 |         return (\n528 |           <div className=\"space-y-6 max-w-[540px] mx-auto w-full py-2\">\n529 |             <div className=\"text-center space-y-2\">\n530 |               <div className=\"w-12 h-12 rounded-full bg-[#087DF3]/10 border border-[#087DF3]/20 flex items-center justify-center mx-auto text-[#087DF3]\">\n531 |                 <svg className=\"w-6 h-6\" fill=\"none\"