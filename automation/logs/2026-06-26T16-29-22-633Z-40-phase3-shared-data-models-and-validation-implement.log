{"ts":"2026-06-26T16:25:26.139Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7z0s102d","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/shared-constants.ts","new_text":"/**\n * GFF AI - SHARED CONSTANTS & DATA MODELS (Phase 3 Foundation)\n * Designed for 2026 Sovereign Enterprise AI Platform.\n *\n * This file centralizes all core data sets, lists, type definitions,\n * and high-fidelity metadata across all enterprise tools (ROI Calculator,\n * Assessment Mesh, Proposal Builder, and Blueprint Generator).\n * \n * Strict frontend-only, local, and deterministic. No backend calls are allowed.\n */\n\n// ==========================================\n// 1. INDUSTRIES\n// ==========================================\nexport const SHARED_INDUSTRIES = [\n  \"Banking\",\n  \"Healthcare\",\n  \"Manufacturing\",\n  \"Retail\",\n  \"Education\",\n  \"Government\",\n  \"Insurance\",\n  \"Financial Services\",\n  \"Life Sciences\",\n  \"Mining\",\n  \"Energy\",\n  \"Telecom\",\n  \"Audit\",\n  \"Tax\",\n  \"Legal\",\n  \"Advisory\",\n  \"Other\"\n] as const;\n\nexport type SharedIndustry = typeof SHARED_INDUSTRIES[number];\n\nexport interface IndustryOption {\n  value: SharedIndustry;\n  label: string;\n}\n\nexport const SHARED_INDUSTRY_OPTIONS: readonly IndustryOption[] = [\n  { value: \"Banking\", label: \"Banking & Securities\" },\n  { value: \"Healthcare\", label: \"Healthcare Systems & Providers\" },\n  { value: \"Manufacturing\", label: \"Advanced Manufacturing & Automotive\" },\n  { value: \"Retail\", label: \"Retail & Consumer Omnichannel\" },\n  { value: \"Education\", label: \"Higher Education & Academic Networks\" },\n  { value: \"Government\", label: \"Sovereign Government & Public Sector\" },\n  { value: \"Insurance\", label: \"Insurance & Actuarial Systems\" },\n  { value: \"Financial Services\", label: \"Financial Services & Asset Management\" },\n  { value: \"Life Sciences\", label: \"Life Sciences & Biotech Diagnostics\" },\n  { value: \"Mining\", label: \"Mining & Heavy Resources\" },\n  { value: \"Energy\", label: \"Energy Grid & Smart Utilities\" },\n  { value: \"Telecom\", label: \"Telecom & High-Bandwidth Networks\" },\n  { value: \"Audit\", label: \"Enterprise Audit & Assurance\" },\n  { value: \"Tax\", label: \"Corporate Tax & Compliance\" },\n  { value: \"Legal\", label: \"Legal Operations & Contract Architecture\" },\n  { value: \"Advisory\", label: \"Advisory & Strategic Operations\" },\n  { value: \"Other\", label: \"Other Services / General Industry\" }\n] as const;\n\n// ==========================================\n// 2. COMPANY SIZES\n// ==========================================\nexport const SHARED_COMPANY_SIZES = [\n  \"<100\",\n  \"100-1000\",\n  \"1000-10000\",\n  \"10000+\"\n] as const;\n\nexport type SharedCompanySize = typeof SHARED_COMPANY_SIZES[number];\n\nexport interface CompanySizeOption {\n  value: SharedCompanySize;\n  label: string;\n}\n\nexport const SHARED_COMPANY_SIZE_OPTIONS: readonly CompanySizeOption[] = [\n  { value: \"<100\", label: \"Emerging Enterprise (<100 employees)\" },\n  { value: \"100-1000\", label: \"Mid-Market Enterprise (100 - 1,000 employees)\" },\n  { value: \"1000-10000\", label: \"Large Enterprise (1,000 - 10,000 employees)\" },\n  { value: \"10000+\", label: \"Global Conglomerate (10,000+ employees)\" }\n] as const;\n\n// ==========================================\n// 3. AI JOURNEY MATURITY STAGES\n// ==========================================\nexport const SHARED_AI_JOURNEYS = [\n  \"No AI\",\n  \"Exploring AI\",\n  \"Running Pilots\",\n  \"Scaling AI\",\n  \"AI-Driven Enterprise\",\n  \"AI-Native\"\n] as const;\n\nexport type SharedAIJourney = typeof SHARED_AI_JOURNEYS[number];\n\nexport interface AIJourneyOption {\n  value: SharedAIJourney;\n  label: string;\n}\n\nexport const SHARED_AI_JOURNEY_OPTIONS: readonly AIJourneyOption[] = [\n  { value: \"No AI\", label: \"No AI Adoption (Pre-Discovery)\" },\n  { value: \"Exploring AI\", label: \"Exploring AI (Active Research & Feasibility)\" },\n  { value: \"Running Pilots\", label: \"Running Pilots (Isolated Sandboxed Trials)\" },\n  { value: \"Scaling AI\", label: \"Scaling AI (Multi-Department Orchestration)\" },\n  { value: \"AI-Driven Enterprise\", label: \"AI-Driven Enterprise (Core Business Run by AI)\" },\n  { value: \"AI-Native\", label: \"AI-Native (Sovereign Autonomous Architecture)\" }\n] as const;\n\n// ==========================================\n// 4. STRATEGIC PRIORITIES\n// ==========================================\nexport const SHARED_PRIORITIES = [\n  \"Reduce Costs\",\n  \"Increase Revenue\",\n  \"Improve Productivity\",\n  \"Improve Customer Experience\",\n  \"Automate Processes\",\n  \"Strengthen Compliance\",\n  \"AI Transformation\"\n] as const;\n\nexport type SharedPriority = typeof SHARED_PRIORITIES[number];\n\nexport interface PriorityOption {\n  value: SharedPriority;\n  label: string;\n}\n\nexport const SHARED_PRIORITY_OPTIONS: readonly PriorityOption[] = [\n  { value: \"Reduce Costs\", label: \"Operational Cost Reduction\" },\n  { value: \"Increase Revenue\", label: \"Sovereign Revenue Generation\" },\n  { value: \"Improve Productivity\", label: \"Workforce Productivity Multiplication\" },\n  { value: \"Improve Customer Experience\", label: \"Hyper-Personalized Customer Experience\" },\n  { value: \"Automate Processes\", label: \"Autonomous Process Automation\" },\n  { value: \"Strengthen Compliance\", label: \"Zero-Retention Security & Compliance\" },\n  { value: \"AI Transformation\", label: \"Full Enterprise AI Transformation\" }\n] as const;\n\n// ==========================================\n// 5. DATA READINESS LEVELS (Blueprint scoring compatible)\n// ==========================================\nexport const SHARED_DATA_READINESS_LEVELS = [\n  \"Highly fragmented\",\n  \"Partially connected\",\n  \"Mostly integrated\",\n  \"Fully integrated\"\n] as const;\n\nexport type SharedDataReadiness = typeof SHARED_DATA_READINESS_LEVELS[number];\n\nexport interface DataReadinessOption {\n  value: SharedDataReadiness;\n  label: string;\n}\n\nexport const SHARED_DATA_READINESS_OPTIONS: readonly DataReadinessOption[] = [\n  { value: \"Highly fragmented\", label: \"Highly Fragmented (Siloed Legacy Databases)\" },\n  { value: \"Partially connected\", label: \"Partially Connected (Ad-hoc API Boundaries)\" },\n  { value: \"Mostly integrated\", label: \"Mostly Integrated (Centralized Vector Caches)\" },\n  { value: \"Fully integrated\", label: \"Fully Integrated (Real-time Autonomous Streams)\" }\n] as const;\n\n// ==========================================\n// 6. LEADERSHIP COMMITMENT LEVELS (Blueprint scoring compatible)\n// ==========================================\nexport const SHARED_LEADERSHIP_COMMITMENTS = [\n  \"Not Discussed\",\n  \"Exploring\",\n  \"Budget Approved\",\n  \"Executive Mandate\"\n] as const;\n\nexport type SharedLeadershipCommitment = typeof SHARED_LEADERSHIP_COMMITMENTS[number];\n\nexport interface LeadershipCommitmentOption {\n  value: SharedLeadershipCommitment;\n  label: string;\n}\n\nexport const SHARED_LEADERSHIP_COMMITMENT_OPTIONS: readonly LeadershipCommitmentOption[] = [\n  { value: \"Not Discussed\", label: \"Not Yet Discussed (Pre-Strategy)\" },\n  { value: \"Exploring\", label: \"Exploring Feasibility (Active Workgroups)\" },\n  { value: \"Budget Approved\", label: \"Budget Formally Approved & Allocated\" },\n  { value: \"Executive Mandate\", label: \"Executive Board Mandate & Active Rollout\" }\n] as const;\n\n// ==========================================\n// 7. COMMON SUGGESTED AI OPPORTUNITIES\n// ==========================================\nexport const SHARED_AI_OPPORTUNITIES = [\n  \"Procurement Copilot\",\n  \"HR Assistant\",\n  \"Contract Intelligence\",\n  \"Knowledge Search\",\n  \"Executive Dashboard\",\n  \"Compliance Assistant\",\n  \"Customer Experience Agent\",\n  \"Document Intelligence Agent\",\n  \"Operations Copilot\"\n] as const;\n\nexport type SharedAIOpportunity = typeof SHARED_AI_OPPORTUNITIES[number];\n\nexport interface AIOpportunityMetadata {\n  name: string;\n  tagline: string;\n  description: string;\n  primaryValueMetric: string;\n  estimatedComplexity: \"Low\" | \"Medium\" | \"High\";\n  typicalDeploymentDays: number;\n}\n\nexport const SHARED_AI_OPPORTUNITY_METADATA: Record<SharedAIOpportunity, AIOpportunityMetadata> = {\n  \"Procurement Copilot\": {\n    name: \"Procurement Copilot\",\n    tagline: \"Automated Supply Chain Ingestion & Negotiation\",\n    description: \"Automates complex supplier negotiation audits, matches line-items, and extracts localized price-discrepancies inside isolated hardware enclaves.\",\n    primaryValueMetric: \"Modelled 15-25% savings in multi-vendor purchasing cycles.\",\n    estimatedComplexity: \"Medium\",\n    typicalDeploymentDays: 45\n  },\n  \"HR Assistant\": {\n    name: \"HR Assistant\",\n    tagline: \"Sovereign HR Advisor & Policy Ingestor\",\n    description: \"Multi-modal internal employee helper. Instantly references internal employee handbooks, benefits files, and corporate policy lists in a zero-retention workspace.\",\n    primaryValueMetric: \"30% reduction in typical internal ticket handling times.\",\n    estimatedComplexity: \"Low\",\n    typicalDeploymentDays: 20\n  },\n  \"Contract Intelligence\": {\n    name: \"Contract Intelligence\",\n    tagline: \"Deep Semantic Document Integrity Auditor\",\n    description: \"Reads, parses, and identifies liabilities, indemnity limits, governing laws, and systemic operational risks in large contract libraries.\",\n    primaryValueMetric: \"Reduces third-party contract review cycle duration by up to 70%.\",\n    estimatedComplexity: \"High\",\n    typicalDeploymentDays: 60\n  },\n  \"Knowledge Search\": {\n    name: \"Knowledge Search\",\n    tagline: \"Cross-Department Sovereign Knowledge Graph\",\n    description: \"Integrates private corporate wiki systems, local files, and historical presentation slide decks into a high-accuracy, semantic vector cache.\",\n    primaryValueMetric: \"Saves operational personnel up to 6 hours weekly on research tasks.\",\n    estimatedComplexity: \"Medium\",\n    typicalDeploymentDays: 30\n  },\n  \"Executive Dashboard\": {\n    name: \"Executive Dashboard\",\n    tagline: \"Autonomous Agent Fleet Telemetry Console\",\n    description: \"Provides continuous, real-time board-level visibility into active agent node networks, process throughput, token overhead, and active security compliance keys.\",\n    primaryValueMetric: \"Delivers 100% cryptographic visibility of autonomous systems.\",\n    estimatedComplexity: \"Medium\",\n    typicalDeploymentDays: 35\n  },\n  \"Compliance Assistant\": {\n    name: \"Compliance Assistant\",\n    tagline: \"Real-time Regulatory Shield & Watchdog\",\n    description: \"Scans and intercepts multi-agent conversation trails and API tokens to strictly block data leaks, ensuring persistent conformity with SOC2, GDPR, and HIPAA.\",\n    primaryValueMetric: \"Maintains a guaranteed 0% critical compliance leak rate in test runs.\",\n    estimatedComplexity: \"High\",\n    typicalDeploymentDays: 50\n  },\n  \"Customer Experience Agent\": {\n    name: \"Customer Experience Agent\",\n    tagline: \"Context-Aware Non-Persistent Concierge\",\n    description: \"Enterprise customer service model that answers queries, resolves tracking questions, and handles returns without storing private consumer logs.\",\n    primaryValueMetric: \"Enables 4.5x faster customer support resolution times.\",\n    estimatedComplexity: \"Low\",\n    typicalDeploymentDays: 25\n  },\n  \"Document Intelligence Agent\": {\n    name: \"Document Intelligence Agent\",\n    tagline: \"Unstructured Multi-Format Parser Node\",\n    description: \"Automates semantic OCR and parsing for unstructured PDF assets, tax returns, healthcare files, bills of lading, and multi-tier bills.\",\n    primaryValueMetric: \"Increases historical document ingestion rate by over 10x.\",\n    estimatedComplexity: \"Medium\",\n    typicalDeploymentDays: 30\n  },\n  \"Operations Copilot\": {\n    name: \"Operations Copilot\",\n    tagline: \"Dynamic Workflow Scheduler & Optimizer\",\n    description: \"Enterprise operational assistant that coordinates process queues, triggers maintenance alerts, and minimizes operational network latency.\",\n    primaryValueMetric: \"Triggers up to 35% reduction in manual oversight requirements.\",\n    estimatedComplexity: \"High\",\n    typicalDeploymentDays: 55\n  }\n} as const;\n\n// ==========================================\n// 8. GFF SOLUTION RECOMMENDATIONS\n// ==========================================\nexport const SHARED_GFF_SOLUTIONS = [\n  \"Agent Factory\",\n  \"Knowledge Graph\",\n  \"AI Governance\",\n  \"Managed AI Operations\",\n  \"Garage\",\n  \"Foundry\",\n  \"Factory\",\n  \"Control Center\"\n] as const;\n\nexport type SharedGFFSolution = typeof SHARED_GFF_SOLUTIONS[number];\n\nexport interface GFFSolutionMetadata {\n  name: string;\n  category: \"Methodology\" | \"Platform\" | \"Module\" | \"Ops\";\n  tagline: string;\n  description: string;\n  maturityScoreBoost: number;\n}\n\nexport const SHARED_GFF_SOLUTION_METADATA: Record<SharedGFFSolution, GFFSolutionMetadata> = {\n  \"Agent Factory\": {\n    name: \"GFF Agent Factory™\",\n    category: \"Platform\",\n    tagline: \"High-Throughput Sovereign Agent Generation\",\n    description: \"Rapidly builds, deploys, and validates autonomous enterprise agent clusters with built-in consensus validation structures and zero-retention data pipelines.\",\n    maturityScoreBoost: 25\n  },\n  \"Knowledge Graph\": {\n    name: \"GFF Knowledge Graph™\",\n    category: \"Platform\",\n    tagline: \"Multi-Source Semantic Entity Ingestion\",\n    description: \"Bridges enterprise data silos, relational mainframes, PDFs, and team workspaces into a unified, encrypted, and low-latency cognitive cache.\",\n    maturityScoreBoost: 20\n  },\n  \"AI Governance\": {\n    name: \"GFF AI Governance & Telemetry™\",\n    category: \"Platform\",\n    tagline: \"SOC2, HIPAA, & NIST Hardened Guardrails\",\n    description: \"Enforces air-gapped security boundaries, deep policy audits, and continuous conversational drift monitoring for multi-agent workflows.\",\n    maturityScoreBoost: 15\n  },\n  \"Managed AI Operations\": {\n    name: \"GFF Managed AI Operations™\",\n    category: \"Ops\",\n    tagline: \"24/7 Monitored Multi-Agent Execution\",\n    description: \"Provides fully managed orchestration, secure hosting, active security patches, and network speed optimizations for production agent clusters.\",\n    maturityScoreBoost: 20\n  },\n  \"Garage\": {\n    name: \"GFF Garage™\",\n    category: \"Methodology\",\n    tagline: \"Co-Innovation Sandbox & Discovery Phase\",\n    description: \"The initial rapid-prototyping phase. Within 2-4 weeks, we design custom security schemas and run localized trial simulations inside isolated GFF sandboxes.\",\n    maturityScoreBoost: 10\n  },\n  \"Foundry\": {\n    name: \"GFF Foundry™\",\n    category: \"Methodology\",\n    tagline: \"Active Scale-Up and Integration Phase\",\n    description: \"The core production implementation stage. Connects the validated sandbox models to real corporate mainframes, legacy DBs, and low-latency API pipelines.\",\n    maturityScoreBoost: 15\n  },\n  \"Factory\": {\n    name: \"GFF Factory™\",\n    category: \"Methodology\",\n    tagline: \"Sovereign Production and Continuous Tuning\",\n    description: \"The sovereign optimization tier. Continuous automatic adaptation, local administration key handover, and multi-agent performance drift prevention.\",\n    maturityScoreBoost: 20\n  },\n  \"Control Center\": {\n    name: \"GFF Sovereign Control Center™\",\n    category: \"Platform\",\n    tagline: \"Centralized Autonomous Administration Workspace\",\n    description: \"A secure, enterprise-grade admin console for setting up multi-agent network subnets, monitoring system latencies, and verifying data isolation keys.\",\n    maturityScoreBoost: 15\n  }\n} as const;\n"}}}
