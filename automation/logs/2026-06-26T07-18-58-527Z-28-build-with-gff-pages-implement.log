etric: string; arts: string[]; }\n\nconst JOURNEY: Stage[] = [\n  { n: 1, name: \"Visitor\", desc: \"Explore core reference blueprints and test cognitive flows in sandbox environments.\", tool: \"/build/sandbox\", btn: \"Launch Sandbox\", metric: \"Free Access\", arts: [\"Interactive Maps\", \"Simulations\"] },\n  { n: 2, name: \"Assessment\", desc: \"Evaluate operational readiness and regulatory compliance score with our scanner.\", tool: \"/build/assessment\", btn: \"Run Assessor\", metric: \"Compliance Matrix\", arts: [\"AI Maturity Score\", \"VPC Audit\"] },\n  { n: 3, name: \"Blueprint\", desc: \"Architect personalized multi-agent execution roadmaps and custom DAG diagrams.\", tool: \"/build/blueprint\", btn: \"Create Blueprint\", metric: \"Custom Topology\", arts: [\"Sovereign DAG Schema\", \"90-Day SOW\"] },\n  { n: 4, name: \"Workshop\", desc: \"Review structural requirements with GFF AI engineers to model integration schemes.\", tool: \"/build/talk\", btn: \"Ask Engineers\", metric: \"Direct Architect Sync\", arts: [\"Integration Schema\", \"Security Spec\"] },\n  { n: 5, name: \"Proposal\", desc: \"Compile custom commercial scoping and download PPT execution deck previews.\", tool: \"/build/proposal\", btn: \"Proposal Studio\", metric: \"Algorithmic Pricing\", arts: [\"Project Proposal\", \"Cost Estimates\"] },\n  { n: 6, name: \"Contract\", desc: \"Sign secure enterprise-grade agreements. Secure dedicated air-gapped enclaves.\", tool: \"/build/sandbox\", btn: \"Sovereign Specs\", metric: \"SOC2 Compliance\", arts: [\"Sovereign SLA\", \"Privacy Charter\"] },\n  { n: 7, name: \"Delivery\", desc: \"Assemble and configure agent topologies dynamically inside GFF Foundry Studio.\", tool: \"/build/foundry-studio\", btn: \"Foundry Studio\", metric: \"30-Day Launch\", arts: [\"Active Agent Fleet\", \"Integration Mesh\"] },\n  { n: 8, name: \"Operate\", desc: \"Execute cognitive workflows. Supervisor nodes continually inspect transaction schemas.\", tool: \"/build/talk\", btn: \"Chat Console\", metric: \"99.9% Success Rate\", arts: [\"Supervisor Logs\", \"Live Telemetry\"] },\n  { n: 9, name: \"Expand\", desc: \"License new marketplace connectors and scale cognitive nodes as enterprise ROI grows.\", tool: \"/build/marketplace\", btn: \"Explore Marketplace\", metric: \"Dynamic Multipliers\", arts: [\"Cohort Expansion\", \"Assets Library\"] }\n];\n\nexport default function BuildHubPage() {\n  const [active, setActive] = useState<Stage>(JOURNEY[0]);\n\n  const tools = [\n    { title: \"Readiness Assessor\", href: \"/build/assessment\", desc: \"Evaluate system schemas, cloud security, and compliance telemetry.\", cat: \"DIAGNOSTIC\", clr: \"#009DFF\" },\n    { title: \"Blueprint Architect\", href: \"/build/blueprint\", desc: \"Map customized agent execution paths and operational schedules.\", cat: \"ROADMAP\", clr: \"#9D00FF\" },\n    { title: \"ROI Calculator\", href: \"/build/roi\", desc: \"Estimate annual labor hours reclaimed, margins, and licensing cost multipliers.\", cat: \"FINANCIAL\", clr: \"#E4000F\" },\n    { title: \"Cognitive Chat Console\", href: \"/build/talk\", desc: \"Interact directly with advanced supervisors in conversational sandboxes.\", cat: \"CHATBOT\", clr: \"#00FF9D\" },\n    { title: \"Proposal Studio\", href: \"/build/proposal\", desc: \"Receive automated scoping decks and Statement of Work deliverables.\", cat: \"COMMERCIAL\", clr: \"#3B82F6\" },\n    { title: \"Zero-Trust Sandbox\", href: \"/build/sandbox\", desc: \"Simulate agent workflows inside virtual hardware enclaves.\", cat: \"SANDBOX\", clr: \"#8B5CF6\" },\n    { title: \"Foundry Studio Simulator\", href: \"/build/foundry-studio\", desc: \"Orchestrate complex visual agent execution graphs and node topologies.\", cat: \"WORKSPACE\", clr: \"#009DFF\" },\n    { title: \"Asset Marketplace\", href: \"/build/marketplace\", desc: \"Acquire certified connector recipes and custom personas.\", cat: \"ASSETS\", clr: \"#EC4899\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Enterprise Development\"\n        title=\"Build with GFF AI\"\n        highlightedWord=\"GFF AI\"\n        description=\"Leverage our interactive assessor tools, blueprint planners, sandbox simulators, and proposal studios to construct your multi-agent fleet.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-20\">\n        <section className=\"p-8 lg:p-12 rounded-[24px] border border-white/5 bg-[#04060b] relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 w-[30%] h-[30%] bg-[#009DFF]/5 blur-3xl pointer-events-none\" />\n          <div className=\"relative z-10 max-w-[1400px] mx-auto space-y-8\">\n            <div className=\"flex flex-col lg:flex-row justify-between lg:items-end gap-4\">\n              <div>\n                <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block mb-1\">DEPLOYMENT PROTOCOL</span>\n                <h2 className=\"text-2xl lg:text-3xl font-bold text-white\">The 9-Stage Sovereign Journey</h2>\n                <p className=\"text-white/60 text-xs mt-1 max-w-[600px] font-light\">Select any milestone to inspect timeline metrics, expected artifacts, and relevant utilities.</p>\n              </div>\n              <div className=\"text-xs font-mono text-[#009DFF] bg-[#009DFF]/10 px-3 py-1 rounded-full border border-[#009DFF]/20 self-start\">\n                PHASE 0{active.n}: {active.name.toUpperCase()}\n              </div>\n            </div>\n\n            <div className=\"relative overflow-x-auto pb-4 scrollbar-none\">\n              <div className=\"min-w-[840px] flex items-center justify-between relative px-2\">\n                <div className=\"absolute top-[20px] left-4 right-4 h-[2px] bg-white/5 z-0\" />\n                <div className=\"absolute top-[20px] left-4 h-[2px] bg-gradient-to-r from-[#E4000F] to-[#009DFF] z-0 transition-all duration-300\" style={{ width: `${((active.n - 1) / 8) * 100}%` }} />\n                \n                {JOURNEY.map((stg) => {\n                  const act = active.n === stg.n;\n                  return (\n                    <button key={stg.n} onClick={() => setActive(stg)} className=\"flex flex-col items-center relative z-10 group focus:outline-none w-[80px]\">\n                      <div className={`w-10 h-10 rounded-full border-2 flex items-center justify-center text-xs font-bold transition-all ${\n                        act ? \"bg-black border-[#009DFF] text-[#009DFF] shadow-[0_0_12px_rgba(0,157,255,0.3)] scale-110\" :\n                        stg.n < active.n ? \"bg-gradient-to-r from-[#E4000F] to-[#009DFF] border-transparent text-white\" : \"bg-[#020202] border-white/10 text-white/40 group-hover:border-white/30\"\n                      }`}>{stg.n}</div>\n                      <span className={`text-[10px] mt-2 font-semibold truncate w-full text-center transition-colors ${act ? \"text-[#009DFF]\" : \"text-white/60 group-hover:text-white\"}`}>{stg.name}</span>\n                    </button>\n                  );\n                })}\n              </div>\n            </div>\n\n            <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 pt-6 border-t border-white/5\">\n              <div className=\"lg:col-span-8 space-y-4\">\n                <div className=\"flex flex-wrap items-center gap-4 text-[11px] font-mono text-white/50\">\n                  <span className=\"text-[#E4000F] font-bold\">PHASE 0{active.n}</span>\n                  <span>|</span>\n                  <span className=\"text-[#00FF9D] font-semibold\">{active.metric}</span>\n                </div>\n                <h3 className=\"text-xl lg:text-2xl font-bold text-white\">{active.name} Milestone</h3>\n                <p className=\"text-white/70 text-xs leading-relaxed max-w-[720px] font-light\">{active.desc}</p>\n                <div className=\"pt-2\">\n                  <Link href={active.tool} className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF]/30 transition group\">\n                    <span>{active.btn}</span>\n                    <svg className=\"w-3 h-3 group-hover:translate-x-1 transition-transform text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n                    </svg>\n                  </Link>\n                </div>\n              </div>\n              \n              <div className=\"lg:col-span-4 p-5 rounded-xl bg-white/[0.01] border border-white/5 flex flex-col justify-between\">\n                <div>\n                  <h4 className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mb-3\">Expected Artifacts</h4>\n                  <ul className=\"space-y-2\">\n                    {active.arts.map((a, i) => (\n                      <li key={i} className=\"flex items-center gap-2 text-xs text-white/80 font-light\">\n                        <span className=\"w-1 h-1 rounded-full bg-[#00FF9D]\" />\n                        {a}\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n                <div className=\"text-[9px] font-mono text-white/30 pt-4 border-t border-white/5 flex justify-between\">\n                  <span>DATA PRIVACY</span>\n                  <span className=\"text-[#00FF9D]\">ENFORCED ENCLAVE</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section className=\"space-y-8\">\n          <div className=\"text-center space-y-2\">\n            <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block\">UTILITY TERMINAL</span>\n            <h2 className=\"text-2xl lg:text-3xl font-bold text-white\">Self-Service Diagnostic & Simulator Tools</h2>\n            <p className=\"text-white/60 text-xs max-w-[600px] mx-auto font-light\">Access automated assessments, pricing calculators, and sandbox simulators.</p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\n            {tools.map((t) => (\n              <div key={t.title} className=\"p-6 rounded-2xl border border-white/5 bg-[#030304]/80 flex flex-col justify-between hover:border-white/10 transition-all group relative\">\n                <div>\n                  <span className=\"text-[9px] font-mono px-2 py-0.5 rounded border\" style={{ color: t.clr, borderColor: `${t.clr}25`, backgroundColor: `${t.clr}08` }}>{t.cat}</span>\n                  <h3 className=\"text-base font-bold text-white mt-4 group-hover:text-[#009DFF] transition-colors\">{t.title}</h3>\n                  <p className=\"mt-2 text-xs text-white/60 leading-relaxed font-light\">{t.desc}</p>\n                </div>\n                <div className=\"mt-6 pt-4 border-t border-white/5\">\n                  <Link href={t.href} className=\"inline-flex items-center gap-1.5 text-xs font-bold text-white hover:text-[#009DFF] transition\">\n                    <span>LAUNCH UTILITY</span>\n                    <svg className=\"w-3 h-3 group-hover:translate-x-0.5 transition-transform\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n                    </svg>\n                  </Link>\n                </div>\n              </div>\n            ))}\n          </div>\n        </section>\n\n        <PremiumCTA\n          title=\"Ready to Transition to Sovereign Production?\"\n          description=\"Establish isolated cloud nodes or air-gapped secure hardware instances. Coordinate live SOW metrics directly with GFF Core Architects.\"\n          primaryLabel=\"Connect with GFF Architects\"\n          primaryHref=\"/#contact\"\n          secondaryLabel=\"Platform Specs\"\n          secondaryHref=\"/platforms\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
