{"ts":"2026-06-26T07:13:06.156Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"kida3u1s","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/talk/page.tsx","old_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\nexport default function TalkToAgentPage() {\n  const [messages, setMessages] = useState([\n    { s: \"agent\", t: \"GFF Autonomous Supervisor online. Welcome to the high-fidelity agent sandbox.\" }\n  ]);\n  const [inVal, setInVal] = useState(\"\");\n  const [activeAgent, setActiveAgent] = useState(\"supervisor\");\n\n  const agents = {\n    supervisor: \"Decomposes complex, multi-system objectives into specialized sub-tasks.\",\n    compliance: \"Real-time auditing across database schemas and S3 policy logs.\",\n    logistics: \"SAP freight tracking pipeline optimizer and routing agent.\"\n  };\n\n  const handleSend = (text: string) => {\n    if (!text.trim()) return;\n    let ans = \"\";\n    if (activeAgent === \"compliance\") {\n      ans = \"[Compliance Auditor] Validated 42 IAM policies. Isolated and auto-remediated 3 configuration drift events in secure subnet.\";\n    } else if (activeAgent === \"logistics\") {\n      ans = \"[Logistics Advisor] Detected marine port congestion. Re-routing overland logistics via custom freight APIs in 320ms.\";\n    } else {\n      ans = \"[Supervisor] Parsing objective... Spawning specialized audit cohort. Local dry-run executed successfully.\";\n    }\n    setMessages((p) => [...p, { s: \"user\", t: text }, { s: \"agent\", t: ans }]);\n    setInVal(\"\");\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Interactive Tool\"\n        title=\"Agent Chat Console\"\n        description=\"Interact directly with our multi-agent cognitive supervisors in a secure, sandbox-ready simulation terminal.\"\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-8\">\n        {/* Sidebar */}\n        <div className=\"lg:col-span-4 space-y-4\">\n          <h3 className=\"text-sm font-bold text-white/40 uppercase tracking-wider\">Select Context Profile</h3>\n          {Object.entries(agents).map(([id, desc]) => (\n            <button\n              key={id}\n              onClick={() => setActiveAgent(id)}\n              className={`w-full text-left p-4 rounded-xl border transition-all ${\n                activeAgent === id ? \"bg-[#050B18] border-[#009DFF]/40\" : \"bg-white/[0.02] border-white/5 hover:bg-white/5\"\n              }`}\n            >\n              <span className=\"text-xs font-bold text-[#009DFF] uppercase tracking-wider\">{id} Agent</span>\n              <p className=\"text-xs text-white/60 mt-1\">{desc}</p>\n            </button>\n          ))}\n        </div>\n\n        {/* Terminal Chat */}\n        <div className=\"lg:col-span-8 rounded-2xl border border-white/10 bg-[#04060b] p-6 flex flex-col justify-between h-[480px]\">\n          <div className=\"h-[360px] rounded-lg border border-white/5 bg-black/50 p-4 overflow-y-auto font-mono text-xs space-y-3\">\n            {messages.map((m, i) => (\n              <div key={i} className={`flex ${m.s === \"user\" ? \"justify-end\" : \"justify-start\"}`}>\n                <div className={`max-w-[85%] rounded-md px-4 py-2 ${m.s === \"user\" ? \"bg-[#009DFF]/20 text-white\" : \"bg-white/[0.03] text-white/80\"}`}>\n                  {m.s === \"user\" ? \"> \" : `[${activeAgent.toUpperCase()}] `}{m.t}\n                </div>\n              </div>\n            ))}\n          </div>\n          <form onSubmit={(e) => { e.preventDefault(); handleSend(inVal); }} className=\"flex gap-3 mt-4\">\n            <input\n              type=\"text\"\n              value={inVal}\n              onChange={(e) => setInVal(e.target.value)}\n              placeholder={`Send objective to ${activeAgent}... (e.g. Audit legacy DB clusters)`}\n              className=\"flex-grow h-[42px] rounded-lg border border-white/10 bg-[#010101]/60 px-4 text-xs text-white focus:outline-none\"\n            />\n            <button type=\"submit\" className=\"px-6 h-[42px] rounded-lg bg-[#009DFF] text-xs font-semibold text-white hover:bg-[#009DFF]/80\">Send Command</button>\n          </form>\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function TalkToAgentPage() {\n  const [industry, setIndustry] = useState(\"Finance\");\n  const [size, setSize] = useState(\"100-1000\");\n  const [desc, setDesc] = useState(\"Automate transaction reconciliation and real-time compliance auditing.\");\n  const [analyzing, setAnalyzing] = useState(false);\n  const [analyzed, setAnalyzed] = useState(true);\n  const [activeTab, setActiveTab] = useState<\"proposal\" | \"squad\" | \"timeline\">(\"proposal\");\n\n  // Simulated Terminal State\n  const [messages, setMessages] = useState([\n    { s: \"agent\", t: \"GFF Cognitive Supervisor online. Ready for sandboxed instruction execution.\" }\n  ]);\n  const [inVal, setInVal] = useState(\"\");\n\n  const handleIntake = (e: React.FormEvent) => {\n    e.preventDefault();\n    setAnalyzing(true);\n    setTimeout(() => {\n      setAnalyzing(false);\n      setAnalyzed(true);\n    }, 1200);\n  };\n\n  const handleSendTerminal = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!inVal.trim()) return;\n    const ans = `[Supervisor] Request received. Analyzing compliance boundaries for \"${inVal}\" against local sandbox schemas. isolated dry-run successful.`;\n    setMessages((p) => [...p, { s: \"user\", t: inVal }, { s: \"agent\", t: ans }]);\n    setInVal(\"\");\n  };\n\n  // Tailored dynamic output based on selected industry\n  const getSimulatedOutput = () => {\n    if (industry === \"Retail\") {\n      return {\n        proposal: \"Optimize inventory allocation and container route bottlenecks dynamically. Integrates with SAP freight logs to reduce port-congestion overhead by 22% in the first quarter.\",\n        squad: [\n          { role: \"Supervisor AS-02\", detail: \"Decomposes logistics routing bottlenecks into localized shipping queries.\" },\n          { role: \"Route Planner\", detail: \"Analyzes marine traffic congestion patterns and Overland APIs.\" },\n          { role: \"Ledger Auditing Node\", detail: \"Ensures automated reconciliation of delivery bills.\" }\n        ],\n        timeline: [\"Day 1-15: Connect SAP and carrier feed hooks\", \"Day 16-45: Configure logistics DAG routing schemas\", \"Day 46-90: Air-gapped trial run and active SLA monitoring\"]\n      };\n    }\n    if (industry === \"Healthcare\") {\n      return {\n        proposal: \"Continuous HIPAA-compliant clinical record parsing and regulatory FDA policy validation. Accelerates medical record audits by 4.5x with zero retention data pipelines.\",\n        squad: [\n          { role: \"Privacy Supervisor\", detail: \"Audits all data inputs against HIPAA and regional privacy rules.\" },\n          { role: \"Clinical Note Parser\", detail: \"Applies semantic extraction to unstructured clinical files.\" },\n          { role: \"Compliance Watchdog\", detail: \"Maintains hard zero-retention memory isolation constraints.\" }\n        ],\n        timeline: [\"Day 1-20: Deploy zero-retention hardware enclaves\", \"Day 21-50: Test Clinical Note schema definitions\", \"Day 51-90: HIPAA-certified sovereign production run\"]\n      };\n    }\n    return { // General/Finance\n      proposal: \"Deploy automated ledger tracking and real-time transaction compliance auditing. Features continuous multi-agent DAG validation across transaction streams with zero human latency.\",\n      squad: [\n        { role: \"Supervisor AS-09\", detail: \"Monitors and balances localized ledger verification tasks.\" },\n        { role: \"Sovereign Audit Node\", detail: \"Continually compares real-time ledger records against standard compliance rulebooks.\" },\n        { role: \"Remediation Engine\", detail: \"Isolates configuration drift and triggers immediate corrective alerts.\" }\n      ],\n      timeline: [\"Day 1-10: Connect internal SQL/Oracle database mirrors\", \"Day 11-40: Build transaction reconciliation rulesets\", \"Day 41-90: Live transaction sandbox and automated SOC2 auditing\"]\n    };\n  };\n\n  const sim = getSimulatedOutput();\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Intake & Simulator\"\n        title=\"AI Challenge Intake Console\"\n        highlightedWord=\"Challenge Intake\"\n        description=\"Define your corporate operational bottlenecks. Access automated agent squad configurations, Statement of Work (SOW) outlines, and sandbox previews in real-time.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          {/* LEFT: Intake Form */}\n          <div className=\"lg:col-span-5 p-6 rounded-2xl border border-white/5 bg-[#04060b] space-y-6\">\n            <h2 className=\"text-lg font-bold text-white tracking-tight\">AI Challenge Intake</h2>\n            <form onSubmit={handleIntake} className=\"space-y-4\">\n              <div className=\"space-y-1.5\">\n                <label className=\"text-[11px] font-mono text-white/50 uppercase\">Industry Vertical</label>\n                <select\n                  value={industry}\n                  onChange={(e) => setIndustry(e.target.value)}\n                  className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-xs text-white px-3 focus:border-[#009DFF] outline-none transition\"\n                >\n                  <option value=\"Finance\">Banking & Financial Services</option>\n                  <option value=\"Retail\">Retail & Supply Chain</option>\n                  <option value=\"Healthcare\">Healthcare & Life Sciences</option>\n                </select>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-[11px] font-mono text-white/50 uppercase\">Company Size</label>\n                <select\n                  value={size}\n                  onChange={(e) => setSize(e.target.value)}\n                  className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-xs text-white px-3 focus:border-[#009DFF] outline-none transition\"\n                >\n                  <option value=\"<100\">&lt; 100 Employees</option>\n                  <option value=\"100-1000\">100 - 1,000 Employees</option>\n                  <option value=\"1000+\">1,000+ Employees</option>\n                </select>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-[11px] font-mono text-white/50 uppercase\">Challenge Description</label>\n                <textarea\n                  value={desc}\n                  onChange={(e) => setDesc(e.target.value)}\n                  rows={3}\n                  className=\"w-full rounded-lg border border-white/10 bg-black text-xs text-white p-3 focus:border-[#009DFF] outline-none transition resize-none leading-relaxed\"\n                  placeholder=\"Describe your legacy database integration or process automation bottlenecks...\"\n                />\n              </div>\n\n              <button\n                type=\"submit\"\n                disabled={analyzing}\n                className=\"w-full h-10 rounded-lg text-xs font-bold text-white uppercase tracking-wider bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-90 transition disabled:opacity-50\"\n              >\n                {analyzing ? \"Processing Context...\" : \"Initiate AI Analysis\"}\n              </button>\n            </form>\n\n            {/* Sandbox Live Chat */}\n            <div className=\"pt-6 border-t border-white/5 space-y-4\">\n              <h3 className=\"text-xs font-bold text-white/40 uppercase tracking-wider font-mono\">Simulate Instruction</h3>\n              <div className=\"h-36 rounded-lg border border-white/5 bg-black/60 p-3 overflow-y-auto font-mono text-[10px] space-y-2\">\n                {messages.map((m, idx) => (\n                  <div key={idx} className={m.s === \"user\" ? \"text-right\" : \"text-left\"}>\n                    <span className={m.s === \"user\" ? \"text-[#009DFF]\" : \"text-white/60\"}>\n                      {m.s === \"user\" ? \"> \" : \"[GFF] \"}{m.t}\n                    </span>\n                  </div>\n                ))}\n              </div>\n              <form onSubmit={handleSendTerminal} className=\"flex gap-2\">\n                <input\n                  type=\"text\"\n                  value={inVal}\n                  onChange={(e) => setInVal(e.target.value)}\n                  placeholder=\"Send sandbox objective (e.g., Auditing schema)\"\n                  className=\"flex-grow h-9 rounded-lg border border-white/10 bg-black px-3 text-[11px] text-white focus:outline-none\"\n                />\n                <button type=\"submit\" className=\"px-4 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold hover:bg-white/10 text-white\">Send</button>\n              </form>\n            </div>\n          </div>\n\n          {/* RIGHT: Results Preview Panel */}\n          <div className=\"lg:col-span-7 p-6 rounded-2xl border border-white/5 bg-[#04060b] flex flex-col justify-between min-h-[520px]\">\n            {analyzed ? (\n              <div className=\"space-y-6\">\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n                  <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">AI Generated Solution Framework</h3>\n                  <div className=\"flex gap-1.5\">\n                    {([\"proposal\", \"squad\", \"timeline\"] as const).map((tab) => (\n                      <button\n                        key={tab}\n                        onClick={() => setActiveTab(tab)}\n                        className={`px-3 py-1 rounded text-[11px] font-mono uppercase tracking-wider transition ${activeTab === tab ? \"bg-[#009DFF]/15 text-[#009DFF] border border-[#009DFF]/20\" : \"text-white/40 hover:text-white/80\"}`}\n                      >\n                        {tab}\n                      </button>\n                    ))}\n                  </div>\n                </div>\n\n                {activeTab === \"proposal\" && (\n                  <div className=\"space-y-4 animate-fadeIn\">\n                    <span className=\"text-[10px] font-mono text-[#00FF9D] uppercase tracking-wider font-semibold\">SOVEREIGN STATEMENT OF WORK</span>\n                    <h4 className=\"text-xl font-bold text-white leading-snug\">Autonomous Operational Proposal</h4>\n                    <p className=\"text-white/70 text-xs leading-relaxed font-light\">{sim.proposal}</p>\n                    <div className=\"p-4 rounded-xl bg-white/[0.01] border border-white/5 space-y-2\">\n                      <span className=\"text-[10px] text-white/40 font-mono block\">COMMERCIAL EXPECTATION</span>\n                      <p className=\"text-xs text-[#009DFF] font-semibold\">Estimated 30-Day Setup • Managed GFF AI Architecture</p>\n                    </div>\n                  </div>\n                )}\n\n                {activeTab === \"squad\" && (\n                  <div className=\"space-y-4 animate-fadeIn\">\n                    <span className=\"text-[10px] font-mono text-[#9D00FF] uppercase tracking-wider font-semibold\">COGNITIVE SUITE DEFINITION</span>\n                    <h4 className=\"text-xl font-bold text-white leading-snug\">Recommended Agent Cohort</h4>\n                    <div className=\"space-y-3\">\n                      {sim.squad.map((member, i) => (\n                        <div key={i} className=\"p-3 rounded-lg bg-white/[0.01] border border-white/5 flex flex-col\">\n                          <span className=\"text-[11px] font-bold text-white\">{member.role}</span>\n                          <span className=\"text-[10px] text-white/50 mt-0.5\">{member.detail}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n\n                {activeTab === \"timeline\" && (\n                  <div className=\"space-y-4 animate-fadeIn\">\n                    <span className=\"text-[10px] font-mono text-[#E4000F] uppercase tracking-wider font-semibold\">INTEGRATION MILESTONES</span>\n                    <h4 className=\"text-xl font-bold text-white leading-snug\">90-Day Delivery Roadmap</h4>\n                    <div className=\"space-y-3\">\n                      {sim.timeline.map((item, i) => (\n                        <div key={i} className=\"flex gap-3 text-xs text-white/80 font-light items-start\">\n                          <span className=\"w-5 h-5 rounded-full bg-white/5 flex items-center justify-center text-[10px] font-bold font-mono shrink-0 text-[#009DFF]\">{i+1}</span>\n                          <p className=\"mt-0.5\">{item}</p>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n              </div>\n            ) : (\n              <div className=\"flex-1 flex flex-col items-center justify-center text-center p-10 text-white/30 space-y-2\">\n                <svg className=\"w-10 h-10 text-white/15\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n                </svg>\n                <p className=\"text-xs\">Submit your AI Challenge details on the left to generate customized Proposal, Squad, and Timeline outlines.</p>\n              </div>\n            )}\n\n            <div className=\"border-t border-white/5 pt-4 mt-6 flex justify-between items-center text-[10px] font-mono text-white/30\">\n              <span>SOCIETY STANDARDS SOC2</span>\n              <span>ENCLAVE PRIVATE SECURE</span>\n            </div>\n          </div>\n        </div>\n\n        <PremiumCTA />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
