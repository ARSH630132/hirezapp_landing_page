{"ts":"2026-06-26T07:17:25.003Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"3gxre7zo","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function ProposalStudioPage() {\n  const [scope, setScope] = useState(\"Enterprise Core Topology\");\n  const [budget, setBudget] = useState(\"$100k-$500k\");\n  const [compliance, setCompliance] = useState(\"SOC2 Type II Hardened\");\n  const [exporting, setExporting] = useState<string | null>(null);\n  const [exportedMsg, setExportedMsg] = useState<string | null>(null);\n\n  const handleSimulateExport = (type: string) => {\n    setExporting(type);\n    setExportedMsg(null);\n    setTimeout(() => {\n      setExporting(null);\n      setExportedMsg(`Algorithmic ${type} compiled and cached in memory. Deliverable outline validated for SOC2 and GDPR compliance.`);\n    }, 1200);\n  };\n\n  const exportCards = [\n    { id: \"sow\", label: \"Statement of Work (SOW)\", desc: \"Formal legal and operational framework detailing service levels, security perimeters, and specific deliverables.\", file: \"SOW_Sovereign_DAG.pdf\", color: \"#009DFF\" },\n    { id: \"ppt\", label: \"Executive Pitch Deck (PPTX)\", desc: \"Strategic slide deck designed for leadership boards to illustrate ROI multipliers, deployment timelines, and cost saves.\", file: \"Executive_Board_Pitch.pptx\", color: \"#9D00FF\" },\n    { id: \"nodes\", label: \"Architecture Blueprints\", desc: \"Detailed technical schema maps outlining vector databases, hardened subnets, and cognitive Supervisor DAG topologies.\", file: \"DAG_Architecture_Specs.pdf\", color: \"#E4000F\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Interactive SOW Studio\"\n        title=\"Sovereign SOW Proposal Studio\"\n        highlightedWord=\"Proposal Studio\"\n        description=\"Instantly compile and preview strategic Statement of Work, slide-deck presentations, and architectural blueprints tailored to your organization.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          {/* Configurator Form */}\n          <div className=\"lg:col-span-5 p-6 rounded-2xl border border-white/5 bg-[#04060b] space-y-6\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">Scope Parameters</h3>\n            </div>\n\n            <div className=\"space-y-4 text-xs\">\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-mono text-white/50 uppercase\">Project Scope Target</label>\n                <select value={scope} onChange={(e) => { setScope(e.target.value); setExportedMsg(null); }} className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 focus:border-[#009DFF] outline-none\">\n                  <option value=\"Enterprise Core Topology\">Enterprise Core DAG Topology</option>\n                  <option value=\"Local Compliance Mesh\">Local Compliance Edge Mesh</option>\n                  <option value=\"High-Frequency Simulation\">High-Frequency Sandbox Simulation</option>\n                </select>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-mono text-white/50 uppercase\">Budget Target Scale</label>\n                <select value={budget} onChange={(e) => { setBudget(e.target.value); setExportedMsg(null); }} className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 focus:border-[#009DFF] outline-none\">\n                  <option value=\"$100k-$500k\">$100k - $500k Tier</option>\n                  <option value=\"$500k-$2M\">$500k - $2M Tier</option>\n                  <option value=\"$2M+\">$2M+ Corporate Tier</option>\n                </select>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[10px] font-mono text-white/50 uppercase\">Compliance Perimeter</label>\n                <select value={compliance} onChange={(e) => { setCompliance(e.target.value); setExportedMsg(null); }} className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 focus:border-[#009DFF] outline-none\">\n                  <option value=\"SOC2\">SOC2 Type II Hardware Enclave</option>\n                  <option value=\"HIPAA\">HIPAA Private Subnet</option>\n                  <option value=\"Air-Gapped\">Air-Gapped Sovereign Instance</option>\n                </select>\n              </div>\n            </div>\n          </div>\n\n          {/* Export Cards */}\n          <div className=\"lg:col-span-8 lg:col-start-6 space-y-6\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">Downloadable Proposal Packages</h3>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              {exportCards.map((card) => (\n                <div key={card.id} className=\"p-5 rounded-2xl border border-white/5 bg-[#030304]/80 flex flex-col justify-between hover:border-white/10 transition duration-300 relative group\">\n                  <div className=\"space-y-3\">\n                    <span className=\"text-[9px] font-mono uppercase tracking-widest px-2 py-0.5 rounded\" style={{ color: card.color, backgroundColor: `${card.color}10`, border: `1px solid ${card.color}20` }}>PREVIEW FILE</span>\n                    <h4 className=\"text-sm font-bold text-white mt-3\">{card.label}</h4>\n                    <p className=\"text-[11px] text-white/50 leading-relaxed font-light\">{card.desc}</p>\n                  </div>\n\n                  <div className=\"mt-6 pt-4 border-t border-white/5 space-y-2\">\n                    <span className=\"text-[9px] font-mono text-white/30 block\">EXPORTER FILENAME: {card.file}</span>\n                    <button\n                      onClick={() => handleSimulateExport(card.label)}\n                      disabled={exporting !== null}\n                      className=\"w-full h-9 rounded-lg text-xs font-bold text-white border transition bg-white/5 border-white/10 hover:bg-white/10 disabled:opacity-50\"\n                    >\n                      {exporting === card.label ? \"Compiling...\" : \"Simulate Export\"}\n                    </button>\n                  </div>\n                </div>\n              ))}\n            </div>\n\n            {exportedMsg && (\n              <div className=\"p-4 rounded-xl bg-[#00FF9D]/5 border border-[#00FF9D]/15 text-xs text-[#00FF9D] font-light leading-relaxed animate-fadeIn\">\n                <span className=\"font-bold uppercase font-mono block text-[10px] mb-1\">Algorithmic Compiler Success</span>\n                {exportedMsg}\n              </div>\n            )}\n          </div>\n        </div>\n\n        <PremiumCTA />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
