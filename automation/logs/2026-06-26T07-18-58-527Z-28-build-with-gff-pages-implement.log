 btn: string;\n  metric: string;\n  artifacts: string[];\n}\n\nconst JOURNEY: Stage[] = [\n  { n: 1, name: \"Visitor\", desc: \"Explore core features, reference blueprints, and test cognitive abilities in simulated sandboxes.\", tool: \"/build/sandbox\", btn: \"Launch Sandbox\", metric: \"100% Free Trial\", artifacts: [\"Interactive Mapping\", \"Simulated traces\"] },\n  { n: 2, name: \"AI Assessment\", desc: \"Diagnose organizational readiness, API density, and security compliance with our assessment engine.\", tool: \"/build/assessment\", btn: \"Run Assessor\", metric: \"Diagnostic Report\", artifacts: [\"AI Readiness Index\", \"Maturity Report\"] },\n  { n: 3, name: \"Blueprint\", desc: \"Architect dynamic multi-agent DAG topologies and timeline execution roadmaps based on budget and goals.\", tool: \"/build/blueprint\", btn: \"Generate Blueprint\", metric: \"Tailored Topologies\", artifacts: [\"Sovereign DAG Map\", \"90-Day Plan\"] },\n  { n: 4, name: \"Workshop\", desc: \"Joint technical session with GFF core engineers to review legacy interfaces and validate edge connectivity.\", tool: \"/build/talk\", btn: \"Initiate Dialogue\", metric: \"Direct Architect Sync\", artifacts: [\"Integration Schema\", \"Security Guardrails\"] },\n  { n: 5, name: \"Proposal\", desc: \"Receive automated algorithmic Statements of Work (SOW), commercial quotes, and PPT executive slide decks.\", tool: \"/build/proposal\", btn: \"Proposal Studio\", metric: \"Algorithmic Pricing\", artifacts: [\"Custom SOW\", \"Commercial Scope\"] },\n  { n: 6, name: \"Contract\", desc: \"Review and sign SOC2-compliant master licensing agreements. Secure single-tenant hardware enclaves.\", tool: \"/build/sandbox\", btn: \"Sovereign Specs\", metric: \"SOC2 Compliance\", artifacts: [\"Sovereign SLA\", \"Privacy Guidelines\"] },\n  { n: 7, name: \"Delivery\", desc: \"Build agent workflows in GFF Foundry Studio. Connect live databases and configure zero-retention memories.\", tool: \"/build/foundry-studio\