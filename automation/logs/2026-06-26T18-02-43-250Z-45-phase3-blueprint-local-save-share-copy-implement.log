{"ts":"2026-06-26T17:56:16.262Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"uncqf7ye","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/BlueprintGenerator.tsx","old_text":"export default function BlueprintGenerator() {\n  const initialData: WizardData = {\n    industry: \"\",\n    companySize: \"\",\n    topPriorities: [],\n    aiJourney: \"\",\n    dataReadiness: \"\",\n    leadershipCommitment: \"\",\n    biggestChallenge: \"\",\n    email: \"\",\n    otp: \"\",\n    budget: \"\",\n    geography: \"\",\n    customChallengeText: \"\",\n    otpSent: false,\n    enteredOtp: \"\"\n  };\n\n  const steps: WizardStep<WizardData>[] = [","new_text":"export default function BlueprintGenerator() {\n  const initialData: WizardData = {\n    industry: \"\",\n    companySize: \"\",\n    topPriorities: [],\n    aiJourney: \"\",\n    dataReadiness: \"\",\n    leadershipCommitment: \"\",\n    biggestChallenge: \"\",\n    email: \"\",\n    otp: \"\",\n    budget: \"\",\n    geography: \"\",\n    customChallengeText: \"\",\n    otpSent: false,\n    enteredOtp: \"\"\n  };\n\n  const [history, setHistory] = useState<any[]>([]);\n  const [loadedState, setLoadedState] = useState<any>(null);\n  const [isHistoryOpen, setIsHistoryOpen] = useState(false);\n  const [copySuccess, setCopySuccess] = useState(false);\n  const [saveSuccess, setSaveSuccess] = useState(false);\n\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      try {\n        const stored = localStorage.getItem(\"gff_blueprint_history\");\n        if (stored) {\n          setHistory(JSON.parse(stored));\n        }\n      } catch (e) {\n        console.error(\"Failed to parse GFF blueprint history\", e);\n      }\n    }\n  }, []);\n\n  const handleCopyToClipboard = (data: WizardData, result: any) => {\n    const dateStr = new Date().toLocaleString();\n    \n    const text = `============================================================\nGFF AI SOVEREIGN ENTERPRISE ARCHITECTURE BLUEPRINT SUMMARY\n============================================================\nGenerated: ${dateStr}\nStatus: DECRYPTED_SANDBOX_PREVIEW\n\n1. ORGANIZATIONAL PROFILE:\n- Vertical: ${data.industry || \"N/A\"}\n- Scale: ${data.companySize || \"N/A\"}\n- Budget Range: ${data.budget || \"N/A\"}\n- Region/Geography: ${data.geography || \"N/A\"}\n- Enterprise Email: ${data.email || \"N/A\"}\n\n2. ASSESSMENTS & SCORES:\n- Sovereign AI Readiness Score: ${result.score} / 100 (${result.category})\n- Dimension Breakdown:\n  * AI Maturity Index: ${result.dimensions?.aiMaturity ?? 0}/100\n  * Business Need Alignment: ${result.dimensions?.businessNeed ?? 0}/100\n  * Enterprise Data Readiness: ${result.dimensions?.dataReadiness ?? 0}/100\n  * Process Complexity: ${result.dimensions?.processComplexity ?? 0}/100\n  * Transformation Readiness: ${result.dimensions?.transformationReadiness ?? 0}/100\n\n3. TARGET GFF AI ARCHITECTURE OVERVIEW:\n- Recommended Solution: ${result.solution.title}\n- Expected Business Impact: ${result.impact.metric}\n\n4. SYNTHESIZED OPPORTUNITY NODES:\n${result.opportunities.map((opp: string, idx: number) => `  * NODE_0${idx + 1}: ${opp}`).join(\"\\n\")}\n\n============================================================\nCONFIDENTIALITY NOTE: Local browser preview only.\nThis report is encrypted in your local session. No server\nsubmissions were made during this assessment phase.\n============================================================`;\n\n    navigator.clipboard.writeText(text).then(() => {\n      setCopySuccess(true);\n      setTimeout(() => setCopySuccess(false), 2000);\n    }).catch(err => {\n      console.error(\"Could not copy text to clipboard: \", err);\n    });\n  };\n\n  const handleSaveLocally = (data: WizardData, result: any) => {\n    if (typeof window === \"undefined\") return;\n    try {\n      const newSavedItem = {\n        id: `gff_bp_${Date.now()}`,\n        timestamp: Date.now(),\n        email: data.email || \"anonymous@enterprise.local\",\n        industry: data.industry || \"General\",\n        score: result.score,\n        category: result.category,\n        solutionTitle: result.solution.title,\n        data,\n        result\n      };\n\n      const updatedHistory = [newSavedItem, ...history].slice(0, 10);\n      setHistory(updatedHistory);\n      localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updatedHistory));\n      \n      setSaveSuccess(true);\n      setTimeout(() => setSaveSuccess(false), 3000);\n    } catch (e) {\n      console.error(\"Failed to save blueprint locally\", e);\n    }\n  };\n\n  const handleDeleteSavedItem = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    const updated = history.filter(item => item.id !== id);\n    setHistory(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updated));\n    }\n  };\n\n  const handleLoadSavedItem = (item: any) => {\n    setLoadedState({\n      data: item.data,\n      result: item.result,\n      showResult: true,\n      currentStepIndex: 5\n    });\n    setIsHistoryOpen(false);\n  };\n\n  const handleResetExternal = () => {\n    setLoadedState(null);\n  };\n\n  const steps: WizardStep<WizardData>[] = ["}}}
