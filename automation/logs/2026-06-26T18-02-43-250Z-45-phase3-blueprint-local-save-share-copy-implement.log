e {\n309 |             if (current.length < 3) {\n310 |               onChange({ topPriorities: [...current, id] });\n311 |             }\n312 |           }\n313 |         };\n314 | \n315 |         return (\n316 |           <div className=\"space-y-4\">\n317 |             <div className=\"flex justify-between items-center\">\n318 |               <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n319 |                 Select Strategic Targets (Max 3) <span className=\"text-[#087DF3]\">*</span>\n320 |               </span>\n321 |               <span className=\"text-[9px] font-mono text-white/40\">{(data.topPriorities || []).length} of 3 selected</span>\n322 |             </div>\n323 |             <ToolOptionGrid\n324 |               options={priorityOptItems}\n325 |               selectedId={data.topPriorities}\n326 |               onChange={togglePriority}\n327 |               multiSelect={true}\n328 |             />\n329 |           </div>\n330 |         );\n331 |       }\n332 |     },\n333 | \n334 |     {\n335 |       id: \"ai-journey\",\n336 |       label: \"AI Maturity Stage\",\n337 |       description: \"Assess your current operational AI implementation depth.\",\n338 |       duration: \"1 min\",\n339 |       validate: (data) => {\n340 |         if (!data.aiJourney) return \"AI Adoption stage is required.\";\n341 |         return null;\n342 |       },\n343 |       render: ({ data, onChange }) => (\n344 |         <div className=\"space-y-4\">\n345 |           <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n346 |             Select Current Operational AI Adoption Depth <span className=\"text-[#087DF3]\">*</span>\n347 |           </span>\n348 |           <ToolOptionGrid\n349 |             options={aiJourneyOptItems}\n350 |             selectedId={data.aiJourney}\n351 |             onChange={(id) => onChange({ aiJourney: id })}\n352 |           />\n353 |         </div>\n354 |       )\n355 |     },\n356 |     {\n357 |       id: \"data-leadership\",\n358 |       label: \"Data & Governance\",\n359 |       description: \"Select your data integration readiness and leadership commitment level.\",\n360 |       duration: \"1-2 min\",\n361 |       validate: (data) => {\n362 |         if (!data.dataReadiness) return \"Data infrastructure readiness selection is required.\";\n363 |         if (!data.leadershipCommitment) return \"Leadership commitment selection is required.\";\n364 |         return null;\n365 |       },\n366 |       render: ({ data, onChange }) => (\n367 |         <div className=\"space-y-6\">\n368 |           <div className=\"space-y-3\">\n369 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n370 |               1. Select Data Infrastructure Readiness <span className=\"text-[#087DF3]\">*</span>\n371 |             </span>\n372 |             <ToolOptionGrid\n373 |               options={dataReadinessOptItems}\n374 |               selectedId={data.dataReadiness}\n375 |               onChange={(id) => onChange({ dataReadiness: id })}\n376 |             />\n377 |           </div>\n378 | \n379 |           <div className=\"space-y-3 pt-6 border-t border-white/5\">\n380 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n381 |               2. Select Leadership Alignment & Mandate <span className=\"text-[#087DF3]\">*</span>\n382 |             </span>\n383 |             <ToolOptionGrid\n384 |               options={leadershipOptItems}\n385 |               selectedId={data.leadershipCommitment}\n386 |               onChange={(id) => onChange({ leadershipCommitment: id })}\n387 |             />\n388 |           </div>\n389 |         </div>\n390 |       )\n391 |     },\n392 |     {\n393 |       id: \"challenge\",\n394 |       label: \"Sovereign Roadblock\",\n395 |       description: \"Identify your primary roadblock and describe the context.\",\n396 |       duration: \"2 min\",\n397 |       validate: (data) => {\n398 |         if (!data.biggestChallenge) return \"Please select a primary bottleneck category.\";\n399 |         if (!data.customChallengeText || data.customChallengeText.trim().length < 10) {\n400 |           return \"Please describe your roadblock context (minimum 10 characters).\";\n401 |         }\n402 |         return null;\n403 |       },\n404 |       render: ({ data, onChange }) => (\n405 |         <div className=\"space-y-6\">\n406 |           <div className=\"space-y-3\">\n407 |             <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n408 |               1. Select Primary Bottleneck Category <span className=\"text-[#087DF3]\">*</span>\n409 |             </span>\n410 |             <div className=\"grid grid-cols-2 md:grid-cols-5 gap-3\">\n411 |               {challengeOptions.map((opt) => {\n412 |                 const isSelected = data.biggestChallenge === opt.value;\n413 |                 const cleanLabel = opt.label.split(\" & \").pop()?.split(\" Constraint\").shift() || opt.label;\n414 |                 return (\n415 |                   <button\n416 |                     key={opt.value}\n417 |                     type=\"button\"\n418 |                     onClick={() => onChange({ biggestChallenge: opt.value })}\n419 |                     className={`p-3 rounded-xl border text-center transition-all duration-300 text-xs font-bold leading-tight ${\n420 |                       isSelected\n421 |                         ? \"bg-white/[0.03] border-[#087DF3] text-white shadow-[0_0_15px_rgba(8,125,243,0.15)]\"\n422 |                         : \"bg-white/[0.01] border-white/5 text-white/60 hover:border-white/10 hover:text-white\"\n423 |                     }`}\n424 |                   >\n425 |                     {cleanLabel}\n426 |                   </button>\n427 |                 );\n428 |               })}\n429 |             </div>\n430 |           </div>\n431 | \n432 |           <div className=\"space-y-3 pt-6 border-t border-white/5\">\n433 |             <div className=\"flex justify-between items-center\">\n434 |               <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n435 |                 2. Describe Roadblock In Detail <span className=\"text-[#087DF3]\">*</span>\n436 |               </span>\n437 |               <span className=\"text-[9px] font-mono text-white/40\">{(data.customChallengeText || \"\").length} characters (min 10)</span>\n438 |             </div>\n439 |             <textarea\n440 |               value={data.customChallengeText || \"\"}\n441 |               onChange={(e) => onChange({ customChallengeText: e.target.value })}\n442 |               placeholder=\"E.g., We have legacy databases in SQL and SAP, but no unified knowledge graph. We want to automate invoice ingestion but are worried about security and compliance regulations...\"\n443 |               className=\"w-full h-36 rounded-xl border border-white/10 bg-black/50 p-4 text-xs sm:text-sm text-white focus:border-[#087DF3] outline-none transition resize-none leading-relaxed\"\n444 |             />\n445 |           </div>\n446 |         </div>\n447 |       )\n448 |     },\n449 | \n450 |     {\n451 |       id: \"verification\",\n452 |       label: \"Portal Authorization\",\n453 |       description: \"Verify your email with a simulated, secure GFF credentials checkpoint.\",\n454 |       duration: \"1 min\",\n455 |       validate: (data) => {\n456 |         if (!data.email) return \"Enterprise email address is required.\";\n457 |         const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n458 |         if (!emailRegex.test(data.email)) return \"Please enter a valid enterprise email address.\";\n459 |         if (!data.enteredOtp) {\n460 |           return \"Verification PIN is required. Please request and enter the access PIN.\";\n461 |         }\n462 |         if (data.enteredOtp !== \"123456\") {\n463 |           return \"Invalid verification PIN. Use the simulated PIN '123456' to proceed.\";\n464 |         }\n465 |         return null;\n466 |       },\n467 |       render: ({ data, onChange }) => {\n468 |         const requestSimulatedOtp = () => {\n469 |           if (!data.email) return;\n470 |           onChange({ otpSent: true });\n471 |         };\n472 | \n473 |         return (\n474 |           <div className=\"space-y-6 max-w-[540px] mx-auto w-full py-2\">\n475 |             <div className=\"text-center space-y-2\">\n476 |               <div className=\"w-12 h-12 rounded-full bg-[#087DF3]/10 border border-[#087DF3]/20 flex items-center justify-center mx-auto text-[#087DF3]\">\n477 |                 <svg className=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"1.5\">\n478 |                   <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z\" />\n479 |                 </svg>\n480 |               </div>\n481 |               <h3 className=\"text-lg font-bold text-white tracking-tight\">Sovereign Portal Gate</h3>\n482 |               <p className=\"text-xs text-white/50 max-w-sm mx-auto leading-relaxed\">\n483 |                 Authorize access via secure enterprise credential checkpoint to synthesize your interactive topology roadmap.\n484 |               </p>\n485 |             </div>\n486 | \n487 |             <div className=\"space-y-4 pt-2\">\n488 |               <div className=\"space-y-1.5\">\n489 |                 <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n490 |                   Enterprise Email Address <span className=\"text-[#087DF3]\">*</span>\n491 |                 </label>\n492 |                 <input\n493 |                   type=\"email\"\n494 |                   value={data.email || \"\"}\n495 |                   onChange={(e) => onChange({ email: e.target.value })}\n496 |                   placeholder=\"yourname@enterprise.com\"\n497 |                   className=\"w-full h-[46px] rounded-xl border border-white/10 bg-black/50 px-4 text-xs md:text-sm text-white focus:border-[#087DF3] outline-none transition disabled:opacity-40\"\n498 |                   disabled={data.otpSent}\n499 |                 />\n500 |               </div>\n501 | \n502 |               {!data.otpSent ? (\n503 |                 <button\n504 |                   type=\"button\"\n505 |                   onClick={requestSimulatedOtp}\n506 |                   disabled={!data.email}\n507 |                   className=\"w-full h-11 rounded-xl bg-[#087DF3] text-xs font-bold uppercase tracking-wider text-black hover:bg-[#087DF3]/90 transition-all font-mono shadow-[0_0_15px_rgba(8,125,243,0.25)] disabled:opacity-35 disabled:cursor-not-allowed\"\n508 |                 >\n509 |                   Request Access PIN\n510 |                 </button>\n511 |               ) : (\n512 |                 <div className=\"space-y-4 pt-4 border-t border-white/5 animate-fadeIn\">\n513 |                   <div className=\"p-4 rounded-xl border border-amber-500/20 bg-amber-500/5 space-y-2\">\n514 |                     <div className=\"flex items-center gap-2\">\n515 |                       <span className=\"w-2 h-2 rounded-full bg-amber-500 animate-pulse\" />\n516 |                       <span className=\"text-[9px] font-bold text-amber-500 font-mono tracking-wider uppercase\">Simulated Node</span>\n517 |                     </div>\n518 |                     <p className=\"text-[11px] text-white/60 leading-relaxed font-light\">\n519 |                       No external emails will be dispatched in this sandbox. Use the simulated PIN below to authorize immediately:\n520 |                     </p>\n521 |                     <div className=\"flex justify-between items-center py-1 px-3 rounded bg-white/5 border border-white/10\">\n522 |                       <span className=\"text-[9px] text-white/40 font-mono font-bold\">Suggested PIN:</span>\n523 |                       <span className=\"text-xs font-mono font-extrabold text-[#087DF3] tracking-widest\">123456</span>\n524 |                     </div>\n525 |                   </div>\n526 | \n527 |                   <div className=\"space-y-1.5\">\n528 |                     <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n529 |                       Enter One-Time PIN (OTP) <span className=\"text-[#087DF3]\">*</span>\n530 |                     </label>\n531 |                     <input\n532 |                       type=\"text\"\n533 |                       maxLength={6}\n534 |                       value={data.enteredOtp || \"\"}\n535 |                       onChange={(e) => onChange({ enteredOtp: e.target.value.replace(/\\D/g, \"\") })}\n536 |                       placeholder=\"Enter 6-digit PIN\"\n537 |                       className=\"w-full h-[46px] rounded-xl border border-white/10 bg-black/50 px-4 text-xs sm:text-sm text-center tracking-[0.4em] font-mono text-white focus:border-[#087DF3] outline-none transition\"\n538 |                     />\n539 |                   </div>\n540 | \n541 |                   <p className=\"text-[10px] text-white/30 font-light leading-relaxed\">\n542 |                     * Note: Use the standard compile buttons below to complete verification and generate your report.\n543 |                   </p>\n544 |                 </div>\n545 |               )}\n546 |             </div>\n547 |           </div>\n548 |         );\n549 |       }\n550 |     }\n551 |   ];\n552 | \n553 |   const compilingMessages = [\n554 |     \"Analyzing industry process patterns...\",\n555 |     \"Calculating AI Maturity Index...\",\n556 |     \"Compiling dynamic multi-agent DAG topologies...\",\n557 |     \"Synthesizing 90-day enterprise execution roadmap...\",\n558 |     \"Running compliance audit baseline checks...\"\n559 |   ];\n560 | \n561 | \n562 | \n563 |   const onCompile = (data: WizardData) => {\n564 |     const score = calculateBlueprintScore(data);\n565 |     const category = getScoreCategory(score);\n566 |     const opportunities = getRecommendedOpportunities(data.industry);\n567 |     const solution = getRecommendedSolution(data.biggestChallenge);\n568 |     const impact = getExpectedImpact(data.topPriorities);\n569 |     const dimensions = calculateBlueprintDimensions(data);\n570 | \n571 |     return {\n572 |       score,\n573 |       category,\n574 |       opportunities,\n575 |       solution,\n576 |       impact,\n577 |       dimensions\n578 |     };\n579 |   };\n580 | \n581 |   const renderResult = (data: WizardData, result: any, onReset: () => void) => {\n582 |     return (\n583 |       <div className=\"space-y-8 anim-slide-up text-white\">\n584 |         <div className=\"p-6 md:p-8 rounded-2xl border border-[#087DF3]/30 bg-gradient-to-r from-[#030d1d] to-[#04060c] flex items-center justify-between shadow-lg\">\n585 |           <div>\n586 |             <span className=\"text-[10px] font-mono font-bold text-[#087DF3] uppercase tracking-widest\">VERIFIED COMPLETED ASSESSMENT</span>\n587 |             <h3 className=\"text-2xl font-bold tracking-tight text-white mt-1\">Your Custom GFF AI Blueprint is Synthesized</h3>\n588 |             <p className=\"text-xs text-white/60 mt-1\">\n589 |               Generated for enterprise gate credential <span className=\"text-[#087DF3] font-bold font-mono\">{data.email}</span>\n590 |             </p>\n591 |           </div>\n592 |           <div className=\"hidden sm:block\">\n593 |             <span className=\"text-xs font-mono font-bold bg-[#E98828]/15 text-[#E98828] border border-[#E98828]/20 px-3 py-1.5 rounded-lg\">PORTAL_VERIFIED_SECURE</span>\n594 |           </div>\n595 |         </div>\n596 | \n597 |         <div className=\"flex flex-col lg:flex-row gap-8 items-stretch\">\n598 |           {/* Score Circular Dial */}\n599 |           <div className=\"lg:w-1/3 rounded-2xl border border-white/10 bg-[#030712]/40 backdrop-blur-md p-6 flex flex-col justify-center items-center text-center relative overflow-hidden group\">\n600 |             <div className=\"absolute inset-0 bg-gradient-to-b from-[#087DF3]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none\" />\n601 |             <span className=\"text-[10px] uppercase tracking-widest font-extrabold text-white/40 block mb-6 font-mono\">AI READINESS MODEL</span>\n602 | \n603 |             {/* Circular Gauge */}\n604 |             <div className=\"relative w-36 h-36 flex items-center justify-center mb-6\">\n605 |               <svg className=\"w-full h-full -rotate-90\">\n606 |                 <circle cx=\"72\" cy=\"72\" r=\"64\" className=\"stroke-white/5 fill-none\" strokeWidth=\"6\" />\n607 |                 <circle \n608 |                   cx=\"72\" \n609 |                   cy=\"72\" \n610 |                   r=\"64\" \n611 |                   className=\"stroke-[#087DF3] fill-none transition-all duration-1000 ease-out\" \n612 |                   strokeWidth=\"8\" \n613 |                   strokeDasharray={`${2 * Math.PI * 64}`} \n614 |                   strokeDashoffset={`${2 * Math.PI * 64 * (1 - result.score / 100)}`} \n615 |                   strokeLinecap=\"round\"\n616 |                 />\n617 |               </svg>\n618 |               <div className=\"absolute inset-0 flex flex-col items-center justify-center\">\n619 |                 <span className=\"text-5xl font-black tracking-tighter text-white\">{result.score}</span>\n620 |                 <span className=\"text-[11px] font-mono text-white/40\">/ 100 SCORE</span>\n621 |               </div>\n622 |             </div>\n623 | \n624 |             <div className=\"px-5 py-2 rounded-full border border-[#087DF3]/40 bg-[#087DF3]/15 shadow-[0_0_15px_rgba(8,125,243,0.2)] text-xs font-black text-white uppercase tracking-wider\">\n625 |               {result.category}\n626 |             </div>\n627 |           </div>\n628 | \n629 | \n630 |           {/* Recommended Solution & Impact */}\n631 |           <div className=\"lg:w-2/3 flex flex-col justify-between gap-6\">\n632 |             <div className=\"rounded-2xl border border-white/10 bg-[#030712]/40 backdrop-blur-md p-6 space-y-3 relative overflow-hidden\">\n633 |               <span className=\"text-[10px] uppercase tracking-widest font-bold text-[#087DF3]\">RECOMMENDED GFF AI SOLUTION</span>\n634 |               <h4 className=\"text-lg md:text-xl font-extrabold text-white\">{result.solution.title}</h4>\n635 |               <p className=\"text-xs md:text-sm text-white/70 leading-relaxed\">{result.solution.description}</p>\n636 |             </div>\n637 | \n638 |             <div className=\"rounded-2xl border border-white/10 bg-[#030712]/40 backdrop-blur-md p-6 space-y-3 relative overflow-hidden\">\n639 |               <div className=\"absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-[#087DF3] to-[#E98828]\" />\n640 |               <span className=\"text-[10px] uppercase tracking-widest font-bold text-[#E98828]\">EXPECTED BUSINESS IMPACT (MODELLED)</span>\n641 |               <p className=\"text-sm md:text-base font-bold text-white/90 leading-normal\">{result.impact.metric}</p>\n642 |               <p className=\"text-[10px] text-white/45 leading-relaxed font-mono italic\">{result.impact.disclaimer}</p>\n643 |             </div>\n644 |           </div>\n645 |         </div>\n646 | \n647 |         {data.customChallengeText && (\n648 |           <div className=\"rounded-2xl border border-white/5 bg-[#030712]/30 p-6 space-y-3\">\n649 |             <span className=\"text-[10px] uppercase tracking-widest font-mono font-bold text-white/40 block\">Your Roadblock Context</span>\n650 |             <p className=\"text-xs md:text-sm text-white/70 italic leading-relaxed\">\"{data.customChallengeText}\"</p>\n651 |           </div>\n652 |         )}\n653 | \n654 |         {/* Dimension Breakdown Section */}\n655 |         <div className=\"space-y-4\">\n656 |           <span className=\"text-[10px] uppercase tracking-widest font-extrabold text-[#087DF3] block tracking-wider font-mono\">Enterprise AI Readiness Dimension Breakdown</span>\n657 |           \n658 |           <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4\">\n659 |             {/* Card 1: AI Maturity Index */}\n660 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030712]/30 hover:border-[#087DF3]/30 hover:bg-[#030712]/50 transition-all duration-300 flex flex-col justify-between relative overflow-hidden group\">\n661 |               <div className=\"absolute top-0 left-0 w-[2px] h-full bg-[#087DF3] opacity-50 group-hover:opacity-100 transition-opacity\" />\n662 |               <div className=\"space-y-3\">\n663 |                 <div className=\"flex justify-between items-start\">\n664 |                   <span className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">DIM_01 / MATURITY</span>\n665 |                   <span className=\"text-xs font-mono font-bold text-[#087DF3] bg-[#087DF3]/15 px-2 py-0.5 rounded\">20% WT.</span>\n666 |                 </div>\n667 |                 <h4 className=\"text-sm font-bold text-white tracking-tight\">AI Maturity Index</h4>\n668 |                 <p className=\"text-[11px] text-white/50 leading-relaxed font-light\">Strategic execution capability and architectural depth.</p>\n669 |               </div>\n670 |               <div className=\"mt-5 space-y-2\">\n671 |                 <div className=\"flex justify-between items-baseline\">\n672 |                   <span className=\"text-xl font-black font-mono text-white\">{result.dimensions?.aiMaturity ?? 0}<span className=\"text-xs text-white/45\">/100</span></span>\n673 |                   <span className=\"text-[10px] font-mono text-whit