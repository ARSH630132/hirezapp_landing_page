/ Map \"ai-operations\" pathname segment back to \"ai-operations\" link id\n45 |   const activeLinkId = activeTab;\n46 | \n47 |   const breadcrumbs: BreadcrumbItem[] = [\n48 |     { label: \"Sovereign Gateway\", href: \"/portal/dashboard\" },\n49 |     { label: activeTab.replace(\"-\", \" \").toUpperCase() }\n50 |   ];\n51 | \n52 |   const handleLinkChange = (id: string) => {\n53 |     const route = clientLinkToRoute[id] || `/portal/${id}`;\n54 |     router.push(route);\n55 |   };\n56 | \n57 |   const handleRoleChange = (role: \"Client\" | \"Administrator\") => {\n58 |     if (role === \"Administrator\") {\n59 |       router.push(\"/admin/dashboard\");\n60 |     } else {\n61 |       router.push(\"/portal/dashboard\");\n62 |     }\n63 |   };\n64 | \n65 |   // Build current user representation\n66 |   const activeUser = session ? {\n67 |     name: session.name,\n68 |     email: session.email,\n69 |     role: (session.role === \"client_admin\" || session.role === \"client_member\") ? (\"Client\" as const) : (\"Administrator\" as const),\n70 |     clearance: session.clearance\n71 |   } : clientUser;\n72 | \n73 |   return (\n74 |     <PreviewRouteGuard type=\"portal\">\n75 |       <PrivateAppShell\n76 |         user={activeUser}\n77 |         breadcrumbs={breadcrumbs}\n78 |         links={clientSidebarLinks}\n79 |         activeLink={activeLinkId}\n80 |         onLinkChange={handleLinkChange}\n81 |         role=\"Client\"\n82 |         onRoleChange={handleRoleChange}\n83 |       >\n84 |         {children}\n85 |       </PrivateAppShell>\n86 |     </PreviewRouteGuard>\n87 |   );\n88 | }\n89 | ","success":true}],"durationMs":5}}
