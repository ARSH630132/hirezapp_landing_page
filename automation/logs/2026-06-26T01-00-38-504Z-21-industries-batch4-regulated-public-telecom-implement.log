erations.\"\n 60 |         breadcrumbs={[{ label: \"Industries\", href: \"/industries\" }, { label: \"Healthcare\" }]}\n 61 |       />\n 62 | \n 63 |       {/* Challenge Landscape */}\n 64 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n 65 |         <h2 className=\"text-2xl font-bold text-white mb-6\">Challenge Landscape</h2>\n 66 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n 67 |           {CHALLENGES.map((c, i) => (\n 68 |             <div key={i} className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60\">\n 69 |               <span className=\"text-[#009DFF] font-mono text-xs block mb-2\">0{i+1} {\"//\"} {c.title}</span>\n 70 |               <p className=\"text-xs text-white/60 leading-relaxed font-light\">{c.desc}</p>\n 71 |             </div>\n 72 |           ))}\n 73 |         </div>\n 74 |       </div>\n 75 | \n 76 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n 77 |         <div className=\"lg:col-span-5 flex flex-col justify-center\">\n 78 |           <h2 className=\"text-2xl font-bold text-white mb-4\">Reference Solution</h2>\n 79 |           <p className=\"text-xs text-white/70 leading-relaxed font-light mb-6\">\n 80 |             Connecting medical systems of record with natural language orchestrators requires secure, airgapped boundaries. Our reference solution routes non-clinical inquiries through isolated cognitive layers, ensuring patient records are scrubbed of PHI before any agent processing.\n 81 |           </p>\n 82 |           <div className=\"space-y-2\">\n 83 |             {[\n 84 |               { id: \"gateway\", name: \"PHI Scrubbing Gateway\", desc: \"Zero-retention proxy cleans data of HIPAA identifiers.\" },\n 85 |               { id: \"orchestrator\", name: \"Cognitive Care Orchestrator\", desc: \"Semantic routing engine directs operational intents.\" },\n 86 |               { id: \"audit\", name: \"Immutab