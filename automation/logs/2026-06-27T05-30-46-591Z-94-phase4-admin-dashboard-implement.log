{"ts":"2026-06-27T05:30:10.499Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"q3zfswhr","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/dashboard/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { \n  Shield, Activity, Users, Layers, Bot, CreditCard, HelpCircle, \n  CheckCircle, AlertTriangle, Clock, ArrowUpRight, RefreshCw, \n  Sliders, Search, Plus, Check, Terminal, Lock, FileText, \n  Copy, ArrowRight, MessageSquare, AlertCircle, Sparkles, Send, ShieldCheck, Trash2, Database, Cpu\n} from \"lucide-react\";\nimport { \n  previewClientAccounts, \n  previewProjects, \n  previewAgentOperations, \n  previewSupportTickets, \n  previewInvoices, \n  previewGovernanceItems,\n  ClientAccount,\n  Project,\n  AgentOperation,\n  SupportTicket,\n  Invoice,\n  GovernanceItem\n} from \"@/lib/mock-data-model\";\nimport { PrivatePageHeader, WorkspaceCard } from \"@/components/private-app\";\n\nexport default function AdminDashboardPage() {\n  // --- Local Interactive States ---\n  const [terminalLogs, setTerminalLogs] = useState<string[]>([\n    `[${new Date().toLocaleTimeString()}] [SYSTEM] Global Oversight Core initialized. Enclave memory locks verified.`,\n    `[${new Date().toLocaleTimeString()}] [ATTEST] Continuous hardware-isolated enclave sweep: 100% SECURE (Intel SGX/AMD SEV-SNP active).`,\n    `[${new Date().toLocaleTimeString()}] [TLS] Secure websocket tunnel established. Peer: admin.gff.ai (Clearance Level V).`\n  ]);\n\n  const [clients, setClients] = useState<ClientAccount[]>(previewClientAccounts);\n  const [projects, setProjects] = useState<Project[]>(previewProjects);\n  const [agents, setAgents] = useState<AgentOperation[]>(previewAgentOperations);\n  const [tickets, setTickets] = useState<SupportTicket[]>(previewSupportTickets);\n  const [governance, setGovernance] = useState<GovernanceItem[]>(previewGovernanceItems);\n  const [invoices, setInvoices] = useState<Invoice[]>(previewInvoices);\n  \n  const [transientNodesCount, setTransientNodesCount] = useState(0);\n  const [sweeping, setSweeping] = useState(false);\n  const [rotating, setRotating] = useState(false);\n  const [focusedClient, setFocusedClient] = useState<ClientAccount | null>(null);\n\n  const consoleEndRef = useRef<HTMLDivElement>(null);\n\n  // Auto-scroll terminal log to bottom\n  useEffect(() => {\n    if (consoleEndRef.current) {\n      consoleEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n    }\n  }, [terminalLogs]);\n\n  const addLog = (category: string, message: string) => {\n    const timestamp = new Date().toLocaleTimeString();\n    setTerminalLogs(prev => [...prev, `[${timestamp}] [${category.toUpperCase()}] ${message}`]);\n  };\n\n  const clearLogs = () => {\n    setTerminalLogs([`[${new Date().toLocaleTimeString()}] [SYSTEM] Terminal log trace buffer cleared.`]);\n  };\n\n  // --- Interactive Command Actions ---\n\n  // Action 1: Trigger Compliance Audit Scan\n  const handleTriggerSweep = () => {\n    if (sweeping) return;\n    setSweeping(true);\n    addLog(\"audit\", \"Initiating continuous compliance sweep across 14 sovereign namespaces...\");\n    \n    setTimeout(() => {\n      // Find any warning status in governance and log remediation or state\n      const hasWarning = governance.some(g => g.status === \"warning\");\n      addLog(\"audit\", `Sweep complete. Evaluated 10,000 epoch transactions. 0 policy leakage detected.`);\n      if (hasWarning) {\n        addLog(\"warning\", \"Attention: NIST AI RMF warning status detected. Manual attestation or override recommended.\");\n      } else {\n        addLog(\"audit\", \"RESULT: All active systems fully compliant (100% SECURE).\");\n      }\n      setSweeping(false);\n    }, 1200);\n  };\n\n  // Action 2: Force HSM Master Key Rotation\n  const handleKeyRotation = () => {\n    if (rotating) return;\n    setRotating(true);\n    addLog(\"hsm\", \"Broadcasting rolling key request to all isolated hardware security modules...\");\n    \n    setTimeout(() => {\n      addLog(\"hsm\", \"Key rotation broadcast processed by all peer clusters. Regenerating local master certificates.\");\n      addLog(\"hsm\", \"SUCCESS: AMD SEV-SNP cryptographic seal validated (SHA-256 seal rollover finalized).\");\n      setRotating(false);\n    }, 1600);\n  };\n\n  // Action 3: Deploy Transient Sandbox Node\n  const handleDeployTransientNode = () => {\n    const nextId = transientNodesCount + 1;\n    setTransientNodesCount(nextId);\n    addLog(\"provision\", `Allocating transient sandbox resources for ID NODE-TRANS-${100 + nextId}...`);\n    \n    setTimeout(() => {\n      addLog(\"provision\", `Enclave memory segment isolated. Core loop bound successfully to RETAIL-CORE-A1 sandbox.`);\n      addLog(\"provision\", `SUCCESS: NODE-TRANS-${100 + nextId} is now reporting live telemetry (AMD EPYC, 8.0 GB allocation).`);\n    }, 800);\n  };\n\n  // Action 4: Inspect Client Sandbox\n  const handleInspectClient = (client: ClientAccount) => {\n    setFocusedClient(client);\n    addLog(\"identity\", `Handshake established with sovereign tenant: ${client.name} (${client.domain}).`);\n    addLog(\"identity\", `Attestation key: SHA256_0x${client.id.toUpperCase()}_SECURE. Compliance Index: ${client.complianceLevel}.`);\n  };\n\n  // Action 5: Add Sandbox Node to a Project\n  const handleAddProjectNode = (projectId: string) => {\n    setProjects(prev => prev.map(p => {\n      if (p.id === projectId) {\n        const nextCount = p.nodesCount + 1;\n        addLog(\"sandbox\", `Incremental node allocation requested for project: ${p.name}. Spawning node cluster #${nextCount}...`);\n        setTimeout(() => {\n          addLog(\"sandbox\", `Node cluster #${nextCount} successfully bound. AMD SEV-SNP hardware isolation fully active.`);\n        }, 500);\n        return { ...p, nodesCount: nextCount };\n      }\n      return p;\n    }));\n  };\n\n  // Action 6: Reset Core Loop for an Agent\n  const handleResetAgentLoop = (agentId: string, agentName: string) => {\n    setAgents(prev => prev.map(a => {\n      if (a.id === agentId) {\n        addLog(\"telemetry\", `Re-compiling and context re-allocating on agent loop: ${agentName}...`);\n        setTimeout(() => {\n          addLog(\"telemetry\", `Agent ${agentName} re-compiled. SHA-256 signature FF81 validated. Memory synchronized.`);\n        }, 600);\n        return { ...a, status: \"active\" as const };\n      }\n      return a;\n    }));\n  };\n\n  // Action 7: Dispatch Security Bypass Key / Close SLA Support Wire\n  const handleResolveTicket = (ticketId: string) => {\n    setTickets(prev => prev.map(t => {\n      if (t.id === ticketId) {\n        addLog(\"sla-support\", `Dispatching HSM bypass keys and signing certificate overrides for ticket ${ticketId}...`);\n        setTimeout(() => {\n          addLog(\"sla-support\", `Bypass keys verified by remote peer. Closed priority support wire ${ticketId}. SLA metrics cleared.`);\n        }, 700);\n        return { ...t, status: \"resolved\" as const };\n      }\n      return t;\n    }));\n  };\n\n  // Action 8: Remediate Governance Compliance Warnings\n  const handleRemediateGovernance = (govId: string, name: string) => {\n    setGovernance(prev => prev.map(g => {\n      if (g.id === govId) {\n        addLog(\"governance\", `Executing continuous prompt verification remediation protocol on: ${name}...`);\n        setTimeout(() => {\n          addLog(\"governance\", `SUCCESS: Log-limit allocation expanded by 50GB. System ${name} is now certified COMPLIANT.`);\n        }, 800);\n        return { ...g, status: \"compliant\" as const };\n      }\n      return g;\n    }));\n  };\n\n  // Action 9: Authorize Billing Settlement\n  const handleSettleInvoice = (invoiceId: string) => {\n    setInvoices(prev => prev.map(inv => {\n      if (inv.id === invoiceId) {\n        addLog(\"ledger\", `Cryptographically signing ledger settlement invoice validation for ${invoiceId}...`);\n        setTimeout(() => {\n          addLog(\"ledger\", `Invoice ${invoiceId} marked SETTLED on GFF block. Blockchain hash commitment complete.`);\n        }, 600);\n        return { ...inv, status: \"paid\" as const };\n      }\n      return inv;\n    }));\n  };\n\n  // --- Calculations for Metric Summary ---\n  const activeClientsCount = clients.filter(c => c.status === \"active\").length;\n  const activeProjectsCount = projects.filter(p => p.status === \"active\").length;\n  const totalEnclaveNodes = projects.reduce((acc, p) => acc + p.nodesCount, 0) + transientNodesCount;\n  const criticalSlaTickets = tickets.filter(t => t.status !== \"resolved\" && t.priority === \"critical\").length;\n  const unresolvedTickets = tickets.filter(t => t.status !== \"resolved\").length;\n  const unresolvedInvoices = invoices.filter(inv => inv.status !== \"paid\");\n  const totalUnpaidAmount = unresolvedInvoices.reduce((acc, inv) => {\n    const val = parseFloat(inv.amount.replace(/[^0-9.]/g, \"\"));\n    return acc + (isNaN(val) ? 0 : val);\n  }, 0);\n  const activeWarningsCount = governance.filter(g => g.status === \"warning\").length;\n\n  return (\n    <div className=\"space-y-6\">\n      {/* 1. Page Header with Control Center Descriptor */}\n      <PrivatePageHeader \n        title=\"Global Oversight & Delivery Center\" \n        desc=\"Sovereign enterprise telemetry, hardware-isolated enclave cluster control, and cross-client policy verification.\"\n        badgeLabel=\"INTERNAL ROOT CONSOLE\"\n        actions={\n          <div className=\"flex flex-wrap gap-2.5 w-full md:w-auto\">\n            <button \n              onClick={handleTriggerSweep}\n              disabled={sweeping}\n              className={`h-9 px-4 rounded border border-white/10 bg-white/[0.01] text-[10.5px] font-mono font-bold uppercase tracking-wider text-white hover:bg-white/[0.04] transition-all cursor-pointer flex items-center gap-1.5 ${sweeping ? \"opacity-50 cursor-not-allowed\" : \"\"}`}\n            >\n              {sweeping ? (\n                <>\n                  <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#009DFF]\" />\n                  <span>Sweeping...</span>\n                </>\n              ) : (\n                <>\n                  <Sliders className=\"w-3.5 h-3.5 text-white/40\" />\n                  <span>Audit compliance sweep</span>\n                </>\n              )}\n            </button>\n            <button \n              onClick={handleKeyRotation}\n              disabled={rotating}\n              className={`h-9 px-4 rounded bg-[#009DFF]/15 hover:bg-[#009DFF]/25 border border-[#009DFF]/30 text-[10.5px] font-mono font-bold uppercase tracking-wider text-[#009DFF] flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.05)] ${rotating ? \"opacity-50 cursor-not-allowed\" : \"\"}`}\n            >\n              {rotating ? (\n                <>\n                  <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                  <span>Rotating keys...</span>\n                </>\n              ) : (\n                <>\n                  <Lock className=\"w-3.5 h-3.5\" />\n                  <span>Force HSM Rollover</span>\n                </>\n              )}\n            </button>\n            <button \n              onClick={handleDeployTransientNode}\n              className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10.5px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n            >\n              <Plus className=\"w-4 h-4\" />\n              <span>Provision Enclave Core</span>\n            </button>\n          </div>\n        }\n      />\n\n      {/* 2. Custom High-Density Metric Summary Deck */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {/* Metric Card 1: Enclave Nodes */}\n        <WorkspaceCard className=\"p-4 flex items-center justify-between gap-3\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase block\">Live Enclave Cores</span>\n            <div className=\"text-xl md:text-2xl font-bold text-white tracking-tight flex items-baseline gap-1.5\">\n              <span>{totalEnclaveNodes} Loops</span>\n              {transientNodesCount > 0 && (\n                <span className=\"text-[10px] font-mono text-[#00FFC2] font-semibold\">+{transientNodesCount} transient</span>\n              )}\n            </div>\n            <p className=\"text-[10px] font-mono text-white/40\">{activeProjectsCount} Active project sandboxes</p>\n          </div>\n          <div className=\"h-10 w-10 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center text-[#009DFF] shrink-0\">\n            <Cpu className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n\n        {/* Metric Card 2: Clients Active */}\n        <WorkspaceCard className=\"p-4 flex items-center justify-between gap-3\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase block\">Sovereign Clients</span>\n            <div className=\"text-xl md:text-2xl font-bold text-white tracking-tight\">{activeClientsCount} / {clients.length}</div>\n            <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-green-400\" />\n              <span>All tenants verified</span>\n            </div>\n          </div>\n          <div className=\"h-10 w-10 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center text-[#00FFC2] shrink-0\">\n            <Users className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n\n        {/* Metric Card 3: Governance Risk Check */}\n        <WorkspaceCard className=\"p-4 flex items-center justify-between gap-3\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase block\">Governance Guardrails</span>\n            <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white flex items-center gap-1.5\">\n              {activeWarningsCount > 0 ? (\n                <>\n                  <span className=\"text-[#E4000F]\">{activeWarningsCount} Alerts</span>\n                  <span className=\"text-[9.5px] font-mono px-1 bg-[#E4000F]/10 border border-[#E4000F]/20 rounded text-[#E4000F] font-bold\">NIST</span>\n                </>\n              ) : (\n                <span className=\"text-[#00FFC2]\">100% Secure</span>\n              )}\n            </div>\n            <p className=\"text-[10px] font-mono text-white/40\">ISO-27001 & HIPAA validated</p>\n          </div>\n          <div className=\"h-10 w-10 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center shrink-0\">\n            {activeWarningsCount > 0 ? (\n              <AlertTriangle className=\"w-5 h-5 text-[#E4000F] animate-pulse\" />\n            ) : (\n              <ShieldCheck className=\"w-5 h-5 text-[#00FFC2]\" />\n            )}\n          </div>\n        </WorkspaceCard>\n\n        {/* Metric Card 4: Open Support SLA */}\n        <WorkspaceCard className=\"p-4 flex items-center justify-between gap-3\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase block\">Priority SLA support</span>\n            <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white flex items-center gap-1.5\">\n              <span>{unresolvedTickets} Open</span>\n              {criticalSlaTickets > 0 && (\n                <span className=\"text-[9.5px] font-mono px-1 bg-[#E4000F]/10 border border-[#E4000F]/20 rounded text-[#E4000F] font-bold animate-pulse\">\n                  CRITICAL\n                </span>\n              )}\n            </div>\n            <p className=\"text-[10px] font-mono text-white/40\">Zero SLA breach threshold</p>\n          </div>\n          <div className=\"h-10 w-10 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center text-amber-400 shrink-0\">\n            <HelpCircle className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* 3. Global Operations Live Terminal Trace Monitor */}\n      <div className=\"border border-white/5 rounded-2xl bg-[#020202]/90 shadow-2xl overflow-hidden font-mono\">\n        <div className=\"px-5 py-3 border-b border-white/5 bg-white/[0.02] flex items-center justify-between select-none\">\n          <div className=\"flex items-center gap-2.5 text-xs text-white/80 font-bold uppercase tracking-wider\">\n            <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n            <span>GLOBAL RECONCILIATION TELEMETRY FEED (LIVE ATTENUATION)</span>\n          </div>\n          <div className=\"flex items-center gap-3\">\n            <div className=\"flex items-center gap-1.5 text-[10px] font-medium text-[#00FFC2]\">\n              <span className=\"relative flex h-1.5 w-1.5\">\n                <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n                <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500\"></span>\n              </span>\n              <span>ATTESTATION BOUNDS INTACT</span>\n            </div>\n            <button \n              onClick={clearLogs}\n              title=\"Clear telemetry terminal\"\n              className=\"p-1 rounded hover:bg-white/5 text-white/40 hover:text-white transition-all cursor-pointer\"\n            >\n              <Trash2 className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        </div>\n        <div className=\"p-4 h-40 overflow-y-auto space-y-1.5 text-[11px] leading-relaxed text-zinc-300 scrollbar-thin select-text\">\n          {terminalLogs.map((log, index) => {\n            let textColor = \"text-zinc-300\";\n            if (log.includes(\"[AUDIT]\")) textColor = \"text-[#00FFC2]\";\n            if (log.includes(\"[GOVERNANCE]\") || log.includes(\"[HSM]\")) textColor = \"text-sky-300\";\n            if (log.includes(\"[WARNING]\")) textColor = \"text-amber-400 font-semibold\";\n            if (log.includes(\"[PROVISION]\")) textColor = \"text-blue-300\";\n            if (log.includes(\"[SLA-SUPPORT]\")) textColor = \"text-orange-300\";\n            \n            return (\n              <div key={index} className={`font-mono border-b border-white/[0.01] pb-1 flex items-start gap-1.5 ${textColor}`}>\n                <span className=\"text-[#009DFF] select-none\">&gt;</span>\n                <span className=\"flex-1\">{log}</span>\n              </div>\n            );\n          })}\n          <div ref={consoleEndRef} />\n        </div>\n      </div>\n\n      {/* 4. Beautiful 2026 Bento Grid Core Layout */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6\">\n        \n        {/* Bento Block A: Sovereign Clients Overview (Spans 6 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-6 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <div className=\"flex items-center justify-between\">\n              <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n                <Users className=\"w-4 h-4 text-[#009DFF]\" />\n                <span>Enterprise Clients Registry</span>\n              </h3>\n              <span className=\"text-[10px] font-mono text-white/30 uppercase\">5 Total Tenants</span>\n            </div>\n            <p className=\"text-xs text-white/50\">Manage active corporate domains, configure isolated sandboxes, and audit live compliance postures.</p>\n          </div>\n\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full text-left font-mono text-[11px]\">\n              <thead>\n                <tr className=\"border-b border-white/5 text-white/40 uppercase text-[9.5px] font-semibold tracking-wider\">\n                  <th className=\"pb-2\">Client Account</th>\n                  <th className=\"pb-2\">Region</th>\n                  <th className=\"pb-2\">Subscription</th>\n                  <th className=\"pb-2 text-right\">Compliance</th>\n                  <th className=\"pb-2 text-right\">Telemetry</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/[0.02]\">\n                {clients.map((client) => {\n                  const isFocused = focusedClient?.id === client.id;\n                  return (\n                    <tr \n                      key={client.id} \n                      onClick={() => handleInspectClient(client)}\n                      className={`group hover:bg-white/[0.02] cursor-pointer transition-all ${isFocused ? \"bg-[#009DFF]/5 text-white\" : \"text-white/80\"}`}\n                    >\n                      <td className=\"py-2.5 pr-2\">\n                        <div className=\"font-bold leading-none\">{client.name}</div>\n                        <div className=\"text-[9px] text-white/35 mt-0.5 group-hover:text-white/60\">{client.domain}</div>\n                      </td>\n                      <td className=\"py-2.5 text-white/60 text-[10px]\">{client.region}</td>\n                      <td className=\"py-2.5\">\n                        <span className={`px-1 py-0.5 rounded text-[9px] font-bold uppercase leading-none border ${\n                          client.tier === \"Sovereign\" ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" :\n                          client.tier === \"Enterprise\" ? \"bg-purple-500/10 text-purple-400 border-purple-500/20\" :\n                          \"bg-zinc-500/10 text-zinc-400 border-zinc-500/20\"\n                        }`}>\n                          {client.tier}\n                        </span>\n                      </td>\n                      <td className=\"py-2.5 text-right text-[#00FFC2] font-semibold text-[10px]\">{client.complianceLevel}</td>\n                      <td className=\"py-2.5 text-right\">\n                        <button className=\"h-6 px-2 rounded border border-white/5 bg-white/[0.02] text-[9.5px] font-bold text-white/50 group-hover:text-white group-hover:border-[#009DFF] group-hover:bg-[#009DFF]/10 transition-all\">\n                          Inspect\n                        </button>\n                      </td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </div>\n\n          {focusedClient && (\n            <div className=\"p-3 rounded-xl border border-white/5 bg-white/[0.01] flex items-start justify-between gap-3 text-[10.5px] font-mono animate-fadeIn\">\n              <div className=\"space-y-1\">\n                <div className=\"text-white font-bold\">{focusedClient.name} Administrative Peer</div>\n                <div className=\"text-white/50 text-[10px]\">L-3 Administrator: <span className=\"text-white\">{focusedClient.contactName}</span></div>\n                <div className=\"text-white/35 text-[9.5px]\">{focusedClient.contactEmail}</div>\n              </div>\n              <button \n                onClick={() => setFocusedClient(null)}\n                className=\"text-white/30 hover:text-white text-[10px] uppercase font-bold\"\n              >\n                Close\n              </button>\n            </div>\n          )}\n        </WorkspaceCard>\n\n        {/* Bento Block B: Isolated Sandbox Environments (Spans 6 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-6 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <div className=\"flex items-center justify-between\">\n              <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n                <Layers className=\"w-4 h-4 text-[#00FFC2]\" />\n                <span>Isolated Sandbox Environments</span>\n              </h3>\n              <span className=\"text-[10px] font-mono text-white/30 uppercase\">Active Projects</span>\n            </div>\n            <p className=\"text-xs text-white/50\">Cross-cluster delivery of tenant sandboxes, underlying hardware modules, and active security checks.</p>\n          </div>\n\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full text-left font-mono text-[11px]\">\n              <thead>\n                <tr className=\"border-b border-white/5 text-white/40 uppercase text-[9.5px] font-semibold tracking-wider\">\n                  <th className=\"pb-2\">Sandbox Name</th>\n                  <th className=\"pb-2\">Enclave Isolation Mode</th>\n                  <th className=\"pb-2 text-center\">Active Cores</th>\n                  <th className=\"pb-2\">State</th>\n                  <th className=\"pb-2 text-right\">Provision</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/[0.02]\">\n                {projects.map((project) => (\n                  <tr key={project.id} className=\"hover:bg-white/[0.01] transition-all\">\n                    <td className=\"py-2.5 pr-2\">\n                      <div className=\"font-bold leading-none\">{project.name}</div>\n                      <div className=\"text-[9px] text-white/35 mt-0.5\">{project.tag}</div>\n                    </td>\n                    <td className=\"py-2.5 text-white/60 text-[10px]\">\n                      <span className=\"flex items-center gap-1\">\n                        <Shield className=\"w-3 h-3 text-[#009DFF]\" />\n                        <span>{project.enclaveType}</span>\n                      </span>\n                    </td>\n                    <td className=\"py-2.5 text-center font-bold text-[#00FFC2]\">{project.nodesCount} Cores</td>\n                    <td className=\"py-2.5\">\n                      <span className={`inline-flex items-center gap-1 rounded-full px-1.5 py-0.5 text-[9px] font-bold uppercase leading-none ${\n                        project.status === \"active\" ? \"bg-emerald-500/10 text-[#00FFC2]\" :\n                        project.status === \"evaluating\" ? \"bg-amber-400/10 text-amber-400\" :\n                        \"bg-zinc-500/10 text-zinc-400\"\n                      }`}>\n                        {project.status}\n                      </span>\n                    </td>\n                    <td className=\"py-2.5 text-right\">\n                      <button \n                        onClick={() => handleAddProjectNode(project.id)}\n                        title=\"Add Core Enclave Node\"\n                        className=\"p-1 rounded border border-white/10 hover:border-[#009DFF] hover:bg-[#009DFF]/10 text-white transition-all cursor-pointer inline-flex items-center\"\n                      >\n                        <Plus className=\"w-3.5 h-3.5\" />\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n\n          <p className=\"text-[10px] font-mono text-white/20 select-none text-right uppercase tracking-wider\">\n            ROOT HARDWARE ATTESTATION SECURITY LEVEL 5\n          </p>\n        </WorkspaceCard>\n\n        {/* Bento Block C: AI Operations Overview (Spans 4 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-4 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <Bot className=\"w-4 h-4 text-purple-400\" />\n              <span>AI Operations Overview</span>\n            </h3>\n            <p className=\"text-xs text-white/50\">Multi-agent runtime telemetry, CPU core workloads, and sandbox memory bounds mapping.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            {agents.slice(0, 3).map((agent) => (\n              <div key={agent.id} className=\"p-3 rounded-xl border border-white/5 bg-white/[0.01] space-y-2\">\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"font-mono font-bold text-xs text-white\">{agent.name}</span>\n                  <span className={`inline-flex items-center gap-1 rounded-full px-1.5 py-0.5 text-[8.5px] font-bold uppercase leading-none ${\n                    agent.status === \"active\" ? \"bg-emerald-500/10 text-[#00FFC2]\" :\n                    agent.status === \"warning\" ? \"bg-amber-500/10 text-amber-400 animate-pulse\" :\n                    \"bg-zinc-500/10 text-zinc-400\"\n                  }`}>\n                    {agent.status}\n                  </span>\n                </div>\n                <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/60\">\n                  <div>Threads: <span className=\"text-white font-semibold\">{agent.threads} active</span></div>\n                  <div>Memory: <span className=\"text-white font-semibold\">{agent.memory}</span></div>\n                </div>\n                <div className=\"flex items-center justify-between pt-1 border-t border-white/[0.03]\">\n                  <span className=\"text-[9px] text-white/30 font-mono\">Heartbeat: {new Date(agent.lastHeartbeat).toLocaleTimeString()}</span>\n                  <button \n                    onClick={() => handleResetAgentLoop(agent.id, agent.name)}\n                    className=\"text-[9.5px] text-[#009DFF] hover:text-[#0082d4] font-bold font-mono flex items-center gap-1 uppercase transition-all\"\n                  >\n                    <RefreshCw className=\"w-2.5 h-2.5\" />\n                    <span>Re-Compile</span>\n                  </button>\n                </div>\n              </div>\n            ))}\n          </div>\n        </WorkspaceCard>\n\n        {/* Bento Block D: Pending Support SLA Wires (Spans 4 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-4 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <HelpCircle className=\"w-4 h-4 text-amber-400\" />\n              <span>Pending SLA Support Wires</span>\n            </h3>\n            <p className=\"text-xs text-white/50\">Priority client communications requiring instant cryptographic sign-off or system-level actions.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            {tickets.slice(0, 2).map((ticket) => {\n              const isResolved = ticket.status === \"resolved\";\n              return (\n                <div \n                  key={ticket.id} \n                  className={`p-3 rounded-xl border border-white/5 bg-white/[0.01] space-y-2 transition-all ${isResolved ? \"opacity-40\" : \"\"}`}\n                >\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-mono text-[10.5px] font-bold text-white/60\">{ticket.id}</span>\n                    <span className={`px-1 py-0.5 rounded text-[8.5px] font-bold uppercase leading-none border ${\n                      ticket.priority === \"critical\" ? \"bg-red-500/10 text-red-400 border-red-500/20\" :\n                      ticket.priority === \"high\" ? \"bg-amber-400/10 text-amber-400 border-amber-400/20\" :\n                      \"bg-zinc-500/10 text-zinc-400 border-zinc-500/20\"\n                    }`}>\n                      {ticket.priority}\n                    </span>\n                  </div>\n                  <div className=\"text-[11.5px] text-white font-bold leading-snug line-clamp-1\">\n                    {ticket.title}\n                  </div>\n                  <p className=\"text-[10px] text-white/45 font-mono line-clamp-2 leading-relaxed\">\n                    {ticket.desc}\n                  </p>\n                  <div className=\"flex items-center justify-between pt-1 border-t border-white/[0.03]\">\n                    <span className=\"text-[9px] text-white/30 font-mono\">Status: <span className=\"text-white uppercase font-semibold\">{ticket.status}</span></span>\n                    {!isResolved ? (\n                      <button \n                        onClick={() => handleResolveTicket(ticket.id)}\n                        className=\"px-2 py-0.5 rounded bg-amber-400/10 hover:bg-[#009DFF]/25 border border-amber-400/20 hover:border-[#009DFF]/40 text-amber-400 hover:text-[#009DFF] text-[9.5px] font-bold font-mono uppercase transition-all\"\n                      >\n                        Dispatch Bypass Key\n                      </button>\n                    ) : (\n                      <span className=\"text-[#00FFC2] font-mono text-[9px] font-bold uppercase flex items-center gap-1\">\n                        <CheckCircle className=\"w-3 h-3\" />\n                        <span>Resolved</span>\n                      </span>\n                    )}\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </WorkspaceCard>\n\n        {/* Bento Block E: Governance Alerts & Rulesets (Spans 4 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-4 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <ShieldCheck className=\"w-4 h-4 text-[#00FFC2]\" />\n              <span>Governance & Alerts</span>\n            </h3>\n            <p className=\"text-xs text-white/50\">Continuous compliance checks against international frameworks. Manual override actions.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            {governance.map((item) => {\n              const isWarning = item.status === \"warning\";\n              return (\n                <div key={item.id} className=\"p-3 rounded-xl border border-white/5 bg-white/[0.01] space-y-2\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"font-mono text-[10.5px] font-bold text-white leading-none truncate max-w-[70%]\">{item.name}</span>\n                    <span className={`px-1 py-0.5 rounded text-[8.5px] font-bold uppercase border leading-none ${\n                      item.status === \"compliant\" ? \"bg-emerald-500/10 text-[#00FFC2] border-emerald-500/20\" :\n                      \"bg-red-500/10 text-red-400 border-red-500/20 animate-pulse\"\n                    }`}>\n                      {item.status}\n                    </span>\n                  </div>\n                  <p className=\"text-[10px] text-white/40 leading-relaxed font-mono line-clamp-2\">\n                    {item.desc}\n                  </p>\n                  <div className=\"flex items-center justify-between pt-1 border-t border-white/[0.03] text-[9.5px]\">\n                    <span className=\"text-white/30 font-mono\">Standard: <span className=\"text-sky-300 font-semibold\">{item.standard}</span></span>\n                    {isWarning && (\n                      <button \n                        onClick={() => handleRemediateGovernance(item.id, item.name)}\n                        className=\"px-1.5 py-0.5 rounded bg-red-500/10 hover:bg-emerald-500/20 border border-red-500/20 hover:border-emerald-500/40 text-red-400 hover:text-[#00FFC2] font-bold font-mono uppercase transition-all\"\n                      >\n                        Bypass Warning\n                      </button>\n                    )}\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </WorkspaceCard>\n\n        {/* Bento Block F: Cryptographic Financial Ledger (Spans 4 cols on lg) */}\n        <WorkspaceCard className=\"lg:col-span-4 flex flex-col justify-between space-y-4\">\n          <div className=\"space-y-1\">\n            <h3 className=\"text-sm font-bold font-mono tracking-widest text-white uppercase flex items-center gap-1.5\">\n              <CreditCard className=\"w-4 h-4 text-emerald-400\" />\n              <span>Cryptographic Financial Ledger</span>\n            </h3>\n            <p className=\"text-xs text-white/50\">Settlement of epoch computing spins, cryptographic signatures, and payment auditing logs.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            <div className=\"p-3 rounded-xl border border-white/5 bg-[#020202]/50 font-mono text-[10.5px] space-y-1\">\n              <div className=\"flex justify-between\"><span className=\"text-white/40\">Total Unpaid Amount:</span><span className=\"text-white font-bold\">{totalUnpaidAmount.toLocaleString()} USD</span></div>\n              <div className=\"flex justify-between\"><span className=\"text-white/40\">Payment Status:</span><span className=\"text-amber-400 font-semibold\">{unresolvedInvoices.length} Pending Settlement</span></div>\n            </div>\n\n            <div className=\"space-y-2\">\n              {invoices.slice(0, 3).map((invoice) => {\n                const isUnpaid = invoice.status === \"unpaid\" || invoice.status === \"processing\";\n                return (\n                  <div key={invoice.id} className=\"p-2.5 rounded-xl border border-white/5 bg-white/[0.01] space-y-1.5\">\n                    <div className=\"flex items-center justify-between text-[10.5px]\">\n                      <span className=\"font-mono text-white font-bold\">{invoice.id}</span>\n                      <span className={`px-1 py-0.25 rounded text-[8px] font-bold uppercase leading-none border ${\n                        invoice.status === \"paid\" ? \"bg-emerald-500/10 text-[#00FFC2] border-emerald-500/20\" :\n                        invoice.status === \"processing\" ? \"bg-purple-500/10 text-purple-400 border-purple-500/20\" :\n                        \"bg-amber-400/10 text-amber-400 border-amber-400/20\"\n                      }`}>\n                        {invoice.status}\n                      </span>\n                    </div>\n                    <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                      <span className=\"text-white/40\">{invoice.category}</span>\n                      <span className=\"text-white font-semibold\">{invoice.amount}</span>\n                    </div>\n                    <div className=\"flex items-center justify-between pt-1 border-t border-white/[0.03] text-[9px] font-mono\">\n                      <span className=\"text-white/20 truncate max-w-[60%]\">{invoice.hash}</span>\n                      {isUnpaid ? (\n                        <button \n                          onClick={() => handleSettleInvoice(invoice.id)}\n                          className=\"px-1.5 py-0.5 rounded bg-emerald-500/10 hover:bg-[#009DFF]/20 border border-emerald-500/20 hover:border-[#009DFF]/40 text-[#00FFC2] hover:text-white font-bold font-mono uppercase transition-all\"\n                        >\n                          Settle Ledger\n                        </button>\n                      ) : (\n                        <span className=\"text-white/30\">Sealed block</span>\n                      )}\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n        </WorkspaceCard>\n\n      </div>\n    </div>\n  );\n}"}}}
