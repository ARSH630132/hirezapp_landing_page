{"ts":"2026-06-26T07:59:15.641Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"9zsuwpxz","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/privacy/page.tsx","old_text":"\"use client\";\n\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\nexport default function PrivacyPolicyPage() {\n  const sections = [\n    {\n      title: \"1. Data Isolation & Decoupling\",\n      text: \"At GFF AI, client data ingestion is cryptographically sandboxed. We do not store, process, or transmit raw training data outside of your designated container boundary. Models operating in the Foundry or Factory stage are completely isolated and decouple live transactions from global training weight pipelines.\"\n    },\n    {\n      title: \"2. Telemetry and Audit Logging\",\n      text: \"We collect basic, structural operational metrics (CPU loads, agent node latencies, and token spend tallies) to power your real-time dashboard telemetry. No personal, sensitive, or payload-level data is collected, logged, or scanned during this process, in absolute alignment with SOC2 compliance criteria.\"\n    },\n    {\n      title: \"3. Cryptographic Boundary Standards\",\n      text: \"All administrative client tokens, dashboard login credentials, and sandbox keys are encrypted using AES-256-GCM at rest and TLS 1.3 in transit. Dynamic multi-agent routing runs inside dedicated virtual networking blocks to ensure zero-leak security.\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Legal & Compliance\"\n        title=\"Privacy Policy\"\n        highlightedWord=\"Privacy\"\n        description=\"Learn how GFF AI enforces cryptographic boundaries, data sandboxing, and SOC2-compliant logging to protect enterprise assets.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 text-white/80 font-light text-[15px] leading-[1.75] space-y-10\">\n        <p>\n          Effective Date: June 26, 2026. This policy outlines GFF AI&apos;s rigorous, zero-trust framework regarding enterprise client data ingestion, telemetry monitoring, and sandbox security parameters.\n        </p>\n\n        {sections.map((sect) => (\n          <div key={sect.title} className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n            <h2 className=\"text-[18px] font-semibold text-white tracking-tight\">{sect.title}</h2>\n            <p className=\"text-white/70 leading-[1.7]\">{sect.text}</p>\n          </div>\n        ))}\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { Shield, Lock, Eye, Database, Server } from \"lucide-react\";\n\nexport default function PrivacyPolicyPage() {\n  const [activeTab, setActiveTab] = useState(\"telemetry\");\n  const [activeSection, setActiveSection] = useState(\"sec-1\");\n\n  const sections = [\n    {\n      id: \"sec-1\",\n      icon: <Shield className=\"w-4 h-4 text-[#E4000F]\" />,\n      title: \"1. Cryptographic Sandboxing\",\n      subtitle: \"Absolute Tenant Isolation Protocols\",\n      text: \"At GFF AI, client data ingestion is cryptographically sandboxed in designated local containers. We enforce a zero-trust network perimeter. No raw text, structured files, or vector embeddings escape your approved virtual private cloud (VPC) configurations.\"\n    },\n    {\n      id: \"sec-2\",\n      icon: <Lock className=\"w-4 h-4 text-[#009DFF]\" />,\n      title: \"2. Model Weight Decoupling\",\n      subtitle: \"Securing Proprietary Logical Core\",\n      text: \"Your model weights, cognitive adjustments, and system blueprints remain exclusively yours. Custom fine-tuning weights operating in the Garage, Foundry, or Factory stages are completely decoupled and are never backpropagated into our public base models.\"\n    },\n    {\n      id: \"sec-3\",\n      icon: <Eye className=\"w-4 h-4 text-white\" />,\n      title: \"3. Non-Intrusive Telemetry\",\n      subtitle: \"Zero-Payload Operational Audit Logging\",\n      text: \"To power real-time client dashboards, we log structural metrics: CPU loads, active agent latency, and token consumption. GFF AI does not log, inspect, or retain prompts, responses, execution contexts, or memory caches, adhering strictly to SOC2.\"\n    },\n    {\n      id: \"sec-4\",\n      icon: <Database className=\"w-4 h-4 text-[#009DFF]\" />,\n      title: \"4. Storage and Excision\",\n      subtitle: \"AES-256-GCM Secure Shredding Standards\",\n      text: \"All credentials and security keys are encrypted using AES-256-GCM at rest. Upon trial termination, our automated Cryptographic Excision protocol immediately zeroizes active sandbox registries and persistent cache stores across all multi-tenant nodes.\"\n    },\n    {\n      id: \"sec-5\",\n      icon: <Server className=\"w-4 h-4 text-red-500\" />,\n      title: \"5. Sovereign Regional Locks\",\n      subtitle: \"Jurisdictional Data Compliance Standards\",\n      text: \"We host sandbox operations across secure global nodes. Clients can lock computational pipelines inside specific sovereign regions (e.g., EU, US, APAC) ensuring total alignment with GDPR and local regulatory guidelines.\"\n    }\n  ];\n\n  useEffect(() => {\n    const handleScroll = () => {\n      const scrollPos = window.scrollY + 180;\n      for (const sect of sections) {\n        const el = document.getElementById(sect.id);\n        if (el && scrollPos >= el.offsetTop && scrollPos < el.offsetTop + el.offsetHeight) {\n          setActiveSection(sect.id);\n          break;\n        }\n      }\n    };\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  const scrollTo = (id: string) => {\n    const el = document.getElementById(id);\n    if (el) {\n      window.scrollTo({ top: el.offsetTop - 110, behavior: \"smooth\" });\n      setActiveSection(id);\n    }\n  };\n\n  const codeData: Record<string, string> = {\n    telemetry: `{\\n  \"gateway_status\": \"active\",\\n  \"isolated_tenant\": \"tenant_0x8f2d9c1\",\\n  \"telemetry_metrics\": {\\n    \"latency_ms\": 142.5,\\n    \"compute_utilization\": \"41.8%\",\\n    \"active_nodes\": 8\\n  },\\n  \"security_parameters\": {\\n    \"payload_logging\": \"DISABLED\",\\n    \"memory_vector_lock\": \"ACTIVE\",\\n    \"ssl_handshake\": \"TLS_1.3_ENCRYPTED\"\\n  }\\n}`,\n    isolation: `/* Ingestion Isolation Tunnel */\\n[Raw Payload] ──> (TLS 1.3 Secure Route)\\n                    ▼\\n[Decoupled Sandbox Model Base] ──x [Global Repository] (MUTED)\\n                    ▼\\n[Isolated Local Vector Index] (AES-256 Lock)`\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Legal & Compliance\"\n        title=\"Privacy & Data Sovereign Policy\"\n        highlightedWord=\"Sovereign\"\n        description=\"Learn how GFF AI enforces cryptographic boundaries, strict tenant decoupling, and SOC2-compliant non-intrusive logging to protect enterprise assets.\"\n      />\n\n      <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10\">\n        <aside className=\"lg:col-span-4 hidden lg:block\">\n          <div className=\"sticky top-[110px] p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-6\">\n            <div className=\"text-[10px] font-mono uppercase tracking-[0.15em] text-white/40\">Sections Index</div>\n            <nav className=\"space-y-1.5\">\n              {sections.map((sect) => (\n                <button\n                  key={sect.id}\n                  onClick={() => scrollTo(sect.id)}\n                  className={`w-full flex items-center gap-3 text-left py-2.5 px-3.5 rounded-xl text-[13px] transition-all ${\n                    activeSection === sect.id\n                      ? \"text-[#009DFF] bg-[#009DFF]/5 font-medium border-l border-[#009DFF]\"\n                      : \"text-white/50 hover:text-white hover:bg-white/5\"\n                  }`}\n                >\n                  {sect.icon}\n                  <span className=\"truncate\">{sect.title.substring(3)}</span>\n                </button>\n              ))}\n            </nav>\n            <div className=\"pt-5 border-t border-white/5 text-[11px] text-white/40 leading-relaxed\">\n              <span className=\"block font-semibold text-white/60 mb-0.5\">Last Updated: June 26, 2026</span>\n              Bespoke routing arrangements are detailed under dynamic enterprise SLAs.\n            </div>\n          </div>\n        </aside>\n\n        <main className=\"lg:col-span-8 space-y-10\">\n          <div className=\"p-6 rounded-[24px] border border-white/5 bg-gradient-to-b from-[#08080a] to-[#010101] overflow-hidden relative\">\n            <div className=\"flex flex-col md:flex-row gap-6 items-center\">\n              <div className=\"flex-1 space-y-3\">\n                <span className=\"inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-mono tracking-widest text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 uppercase\">\n                  Zero-Trust Router\n                </span>\n                <h3 className=\"text-[18px] font-semibold text-white tracking-tight\">Cryptographic Data Isolation</h3>\n                <p className=\"text-white/60 text-[13px] font-light leading-relaxed\">\n                  Visualization of client data parsed, cryptographically isolated in AES-256 memory locks, and processed inside detached enterprise runtimes.\n                </p>\n              </div>\n              <div className=\"w-full md:w-[240px] h-[130px] border border-white/5 rounded-xl bg-black/40 flex items-center justify-center p-3\">\n                <svg className=\"w-full h-full\" viewBox=\"0 0 240 130\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <rect x=\"10\" y=\"45\" width=\"40\" height=\"35\" rx=\"4\" fill=\"#050505\" stroke=\"#E4000F\" strokeWidth=\"0.75\" />\n                  <text x=\"30\" y=\"66\" textAnchor=\"middle\" fill=\"white\" fontSize=\"8\" fontFamily=\"monospace\" opacity=\"0.8\">DATA</text>\n                  <path d=\"M50 62.5 H95\" stroke=\"#E4000F\" strokeWidth=\"1\" strokeDasharray=\"3 2\" />\n                  <rect x=\"95\" y=\"30\" width=\"60\" height=\"65\" rx=\"6\" fill=\"#010101\" stroke=\"#009DFF\" strokeWidth=\"1.25\" />\n                  <circle cx=\"125\" cy=\"55\" r=\"10\" fill=\"#009DFF\" fillOpacity=\"0.1\" />\n                  <path d=\"M125 50 V60 M120 55 H130\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                  <text x=\"125\" y=\"77\" textAnchor=\"middle\" fill=\"#009DFF\" fontSize=\"7\" fontFamily=\"monospace\" fontWeight=\"bold\">SANDBOX</text>\n                  <path d=\"M155 62.5 H200\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                  <rect x=\"200\" y=\"45\" width=\"30\" height=\"35\" rx=\"4\" fill=\"#050505\" stroke=\"white\" strokeWidth=\"0.5\" strokeOpacity=\"0.2\" />\n                  <text x=\"215\" y=\"66\" textAnchor=\"middle\" fill=\"white\" fontSize=\"7\" fontFamily=\"monospace\" opacity=\"0.6\">MODEL</text>\n                </svg>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"space-y-8\">\n            {sections.map((sect) => (\n              <section\n                key={sect.id}\n                id={sect.id}\n                className=\"scroll-mt-[120px] p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-3 hover:border-white/10 transition-all duration-300\"\n              >\n                <div className=\"flex items-center gap-3\">\n                  <div className=\"p-2 rounded-xl bg-white/5 border border-white/10\">{sect.icon}</div>\n                  <div>\n                    <h2 className=\"text-[16px] sm:text-[18px] font-semibold text-white tracking-tight\">{sect.title}</h2>\n                    <p className=\"text-[11px] text-white/40 tracking-wider font-mono mt-0.5\">{sect.subtitle}</p>\n                  </div>\n                </div>\n                <p className=\"pt-2 text-white/70 text-[14px] leading-relaxed font-light\">{sect.text}</p>\n              </section>\n            ))}\n          </div>\n\n          <section className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/50 backdrop-blur-[8px] space-y-4\">\n            <h3 className=\"text-[16px] font-semibold text-white tracking-tight\">Trust Verification Console</h3>\n            <div className=\"flex gap-2 border-b border-white/5\">\n              <button\n                onClick={() => setActiveTab(\"telemetry\")}\n                className={`pb-2.5 px-4 text-[12px] font-medium transition-all relative ${\n                  activeTab === \"telemetry\" ? \"text-[#009DFF]\" : \"text-white/40 hover:text-white\"\n                }`}\n              >\n                System Telemetry\n                {activeTab === \"telemetry\" && <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#009DFF]\" />}\n              </button>\n              <button\n                onClick={() => setActiveTab(\"isolation\")}\n                className={`pb-2.5 px-4 text-[12px] font-medium transition-all relative ${\n                  activeTab === \"isolation\" ? \"text-[#009DFF]\" : \"text-white/40 hover:text-white\"\n                }`}\n              >\n                Decoupled Tunnel Flow\n                {activeTab === \"isolation\" && <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#009DFF]\" />}\n              </button>\n            </div>\n            <pre className=\"p-4 rounded-xl border border-white/5 bg-black/60 text-[11px] font-mono text-white/80 overflow-x-auto leading-relaxed\">\n              <code>{codeData[activeTab]}</code>\n            </pre>\n          </section>\n\n          <PremiumCTA\n            title=\"Have custom governance requirements?\"\n            description=\"Our specialized integration architects regularly configure bespoke isolated model deployments for global finance, logtech, and healthcare institutions.\"\n            primaryLabel=\"Initiate Security Review\"\n            primaryHref=\"/contact?pathway=governance\"\n            secondaryLabel=\"Explore Architecture Specs\"\n            secondaryHref=\"/resources/architecture-library\"\n          />\n        </main>\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
