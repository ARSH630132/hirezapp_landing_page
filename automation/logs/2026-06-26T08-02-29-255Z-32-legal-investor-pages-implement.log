 text-[13px] transition-all ${\n                    activeSec === sect.id ? \"text-[#009DFF] bg-[#009DFF]/5 font-medium border-l border-[#009DFF]\" : \"text-white/50 hover:text-white\"\n                  }`}\n                >\n                  {sect.icon}\n                  <span className=\"truncate\">{sect.title.substring(3)}</span>\n                </button>\n              ))}\n            </nav>\n          </div>\n        </aside>\n\n        <main className=\"lg:col-span-8 space-y-8\">\n          <div className=\"space-y-6\">\n            {sections.map((sect) => (\n              <section\n                key={sect.id}\n                id={sect.id}\n                className=\"scroll-mt-[120px] p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-3\"\n              >\n                <div className=\"flex items-center gap-3\">\n                  <div className=\"p-2 rounded-xl bg-white/5 border border-white/10\">{sect.icon}</div>\n                  <div>\n                    <h2 className=\"text-[16px] sm:text-[18px] font-semibold text-white tracking-tight\">{sect.title}</h2>\n                    <p className=\"text-[11px] text-white/40 tracking-wider font-mono mt-0.5\">{sect.subtitle}</p>\n                  </div>\n                </div>\n                <p className=\"text-white/70 text-[14px] leading-relaxed font-light\">{sect.text}</p>\n              </section>\n            ))}\n          </div>\n\n          <PremiumCTA\n            title=\"Have custom governance requirements?\"\n            description=\"Our specialized integration architects regularly configure bespoke isolated model deployments for global finance, logtech, and healthcare institutions.\"\n            primaryLabel=\"Initiate Security Review\"\n            primaryHref=\"/contact?pathway=governance\"\n            secondaryLabel=\"Explore Architecture Specs\"\n            secondaryHref=\"/resources/architecture-library\"\n          />\n        </main>\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
