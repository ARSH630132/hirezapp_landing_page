{"ts":"2026-06-26T08:00:58.117Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"b0elkhjf","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/nda/page.tsx","old_text":"\"use client\";\n\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\nexport default function NdaPage() {\n  const clauses = [\n    {\n      title: \"1. Definition of Confidential Information\",\n      text: \"Confidential Information encompasses all technical DAG blueprints, vector reasoning data, custom cognitive core architectures, token benchmarks, and business parameters shared during our Garage or Foundry consultation phases.\"\n    },\n    {\n      title: \"2. Absolute Non-Disclosure Commitment\",\n      text: \"Both parties agree to hold all Confidential Information in the strictest confidence. GFF AI enforces zero-trust sandbox boundaries to prevent unauthorized logical leakage across multi-tenant clusters.\"\n    },\n    {\n      title: \"3. Cryptographic and Memory Isolation\",\n      text: \"All shared code repositories, cognitive rules, and semantic context vectors will be immediately deleted or returned upon request, leaving zero residual cache weights on GFF AI local systems.\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Legal & Compliance\"\n        title=\"NDA Mutual Agreement\"\n        highlightedWord=\"Agreement\"\n        description=\"Review our standard bilateral Mutual Non-Disclosure Agreement safeguarding proprietary models, APIs, and business data.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 text-white/80 font-light text-[15px] leading-[1.75] space-y-10\">\n        <p>\n          Last updated: June 26, 2026. This Agreement establishes the protective rules and mutual sandboxing commitments governing GFF AI exploratory pilot workshops.\n        </p>\n\n        {clauses.map((clause) => (\n          <div key={clause.title} className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n            <h2 className=\"text-[18px] font-semibold text-white tracking-tight\">{clause.title}</h2>\n            <p className=\"text-white/70 leading-[1.7]\">{clause.text}</p>\n          </div>\n        ))}\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { Lock, FileCheck, Landmark, CheckCircle2, Send } from \"lucide-react\";\n\nexport default function NdaPage() {\n  const [formSubmitted, setFormSubmitted] = useState(false);\n  const [loading, setLoading] = useState(false);\n\n  const steps = [\n    {\n      step: \"01\",\n      title: \"Initiate Request\",\n      desc: \"Provide your corporate parameters and jurisdictional preference using our secure form below.\"\n    },\n    {\n      step: \"02\",\n      title: \"Automated Draft\",\n      desc: \"Our compliance parser compiles a standardized Mutual NDA tailored to your regional regulatory guidelines.\"\n    },\n    {\n      step: \"03\",\n      title: \"e-Sign & Lock\",\n      desc: \"Execute mutual digital signatures. Your shared repository context is immediately sealed inside GFF enclaves.\"\n    }\n  ];\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    setLoading(true);\n    setTimeout(() => {\n      setLoading(false);\n      setFormSubmitted(true);\n    }, 1200);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Legal & Compliance\"\n        title=\"Mutual NDA Protocol\"\n        highlightedWord=\"Protocol\"\n        description=\"Learn how GFF AI secures early-stage sandbox investigations, safeguards proprietary designs, and executes mutual non-disclosure agreements.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 space-y-16 relative z-10\">\n        \n        {/* Intro */}\n        <div className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n          <h2 className=\"text-[20px] font-semibold text-white tracking-tight flex items-center gap-3\">\n            <Lock className=\"w-5 h-5 text-[#E4000F]\" /> Bilateral Confidentiality Protection\n          </h2>\n          <p className=\"text-white/70 leading-[1.7] text-[14px] font-light\">\n            Before we demonstrate bespoke multi-agent sandboxes or evaluate your sensitive database DAGs in our Garage phase, GFF AI secures absolute reciprocal confidentiality. Our mutual NDA is engineered to safeguard proprietary codebases, vector weights, model configurations, and trade parameters.\n          </p>\n        </div>\n\n        {/* Dynamic Workflow Timeline */}\n        <div className=\"space-y-6\">\n          <h3 className=\"text-[18px] font-semibold text-white tracking-tight uppercase tracking-wider font-mono text-center text-white/40\">\n            NDA Request & Execution Pipeline\n          </h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            {steps.map((item, idx) => (\n              <div key={idx} className=\"p-6 rounded-[24px] border border-white/5 bg-gradient-to-b from-[#08080a] to-[#010101] relative overflow-hidden group hover:border-white/10 transition-all\">\n                <span className=\"absolute top-4 right-4 text-[48px] font-mono font-bold leading-none text-white/5 select-none\">{item.step}</span>\n                <h4 className=\"text-[16px] font-semibold text-white tracking-tight mt-4\">{item.title}</h4>\n                <p className=\"mt-3 text-[13px] leading-[1.6] text-white/50 font-light\">{item.desc}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Interactive request form */}\n        <div className=\"p-8 rounded-[32px] border border-white/5 bg-[#030304]/80 backdrop-blur-[16px] max-w-2xl mx-auto space-y-6 relative\">\n          <div className=\"space-y-2 text-center\">\n            <span className=\"inline-flex items-center gap-1 px-3 py-1 text-[11px] font-bold tracking-widest text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 rounded-full uppercase\">\n              Bespoke Request Portal\n            </span>\n            <h3 className=\"text-[22px] font-semibold text-white tracking-tight\">Initiate Mutual NDA Review</h3>\n            <p className=\"text-white/50 text-[13px] font-light\">Fill out your entity information below. No legally binding document will be signed immediately.</p>\n          </div>\n\n          {formSubmitted ? (\n            <div className=\"py-8 text-center space-y-4 animate-fade-in\">\n              <div className=\"w-12 h-12 bg-green-500/10 border border-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto\">\n                <CheckCircle2 className=\"w-6 h-6\" />\n              </div>\n              <h4 className=\"text-[18px] font-medium text-white\">NDA Request Logged Successfully</h4>\n              <p className=\"text-white/60 text-[13px] max-w-md mx-auto font-light leading-relaxed\">\n                Thank you. Our compliance desk will compile your custom bilateral NDA draft for your specified jurisdiction and email it to the authorized address within 4 business hours.\n              </p>\n              <button onClick={() => setFormSubmitted(false)} className=\"text-[12px] text-[#009DFF] hover:underline font-medium\">Submit Another Request</button>\n            </div>\n          ) : (\n            <form onSubmit={handleSubmit} className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-[11px] font-mono uppercase text-white/40 tracking-wider\">Corporate Entity Legal Name</label>\n                  <input required placeholder=\"e.g. Acme Corp Inc\" className=\"w-full px-4 py-2.5 rounded-xl border border-white/5 bg-[#050505]/80 text-[13px] text-white focus:outline-none focus:border-[#009DFF]/50 transition-all\" />\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[11px] font-mono uppercase text-white/40 tracking-wider\">Authorized Officer Email</label>\n                  <input type=\"email\" required placeholder=\"e.g. legal@acme.com\" className=\"w-full px-4 py-2.5 rounded-xl border border-white/5 bg-[#050505]/80 text-[13px] text-white focus:outline-none focus:border-[#009DFF]/50 transition-all\" />\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <label className=\"text-[11px] font-mono uppercase text-white/40 tracking-wider\">Governing Law Jurisdiction</label>\n                <select className=\"w-full px-4 py-2.5 rounded-xl border border-white/5 bg-[#050505]/80 text-[13px] text-white/80 focus:outline-none focus:border-[#009DFF]/50 transition-all\">\n                  <option>Delaware, United States</option>\n                  <option>England & Wales</option>\n                  <option>Singapore (SGX Compliant)</option>\n                  <option>Frankfurt, Germany (EU Compliant)</option>\n                </select>\n              </div>\n\n              <button type=\"submit\" disabled={loading} className=\"w-full mt-2 py-3 rounded-xl text-[13px] font-semibold text-white transition-all bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-90 flex items-center justify-center gap-2\">\n                {loading ? \"Processing Secure Crypt-Ticket...\" : (\n                  <>\n                    <Send className=\"w-4 h-4\" /> Request Mutual NDA Draft\n                  </>\n                )}\n              </button>\n            </form>\n          )}\n        </div>\n\n        <PremiumCTA\n          title=\"Preparing for an architectural audit session?\"\n          description=\"Schedule a technical workspace review to understand how your proprietary parameters are compartmentalized within private sandboxes.\"\n          primaryLabel=\"Contact Legal Desk\"\n          primaryHref=\"/contact?pathway=nda\"\n          secondaryLabel=\"Review Trust Specs\"\n          secondaryHref=\"/privacy\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
