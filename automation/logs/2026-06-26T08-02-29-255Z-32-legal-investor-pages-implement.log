{"ts":"2026-06-26T08:01:28.136Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"kmwt50zm","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/investor-relations/page.tsx","old_text":"\"use client\";\n\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\nexport default function InvestorRelationsPage() {\n  const highlights = [\n    { title: \"Market Alignment\", desc: \"GFF AI addresses the massive $150B enterprise AI consulting and orchestration gap with lightweight, high-performance, productized cognitive assets.\" },\n    { title: \"Bilateral Stability\", desc: \"Our subscription models, managed SLAs, and dedicated platforms ensure highly predictable enterprise client retention and scaling margins.\" },\n    { title: \"Capital Efficiency\", desc: \"Our remote-first, high-density engineering strategy decouples physical infrastructure overhead from core technology developments.\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Financial Operations\"\n        title=\"Investor Relations\"\n        highlightedWord=\"Investor\"\n        description=\"Access GFF AI's institutional milestones, enterprise growth trajectories, and corporate development updates.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 text-white/80 font-light text-[15px] space-y-12\">\n        <div className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n          <h2 className=\"text-[20px] font-semibold text-white tracking-tight\">Institutional Positioning</h2>\n          <p className=\"text-white/70 leading-[1.7]\">\n            GFF AI is backed by premium corporate capital and institutional AI visionaries. We deploy custom agent clusters into high-security finance, logistics, and manufacturing networks, capturing high-retention enterprise ARR.\n          </p>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          {highlights.map((item) => (\n            <div key={item.title} className=\"p-6 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] hover:border-[#009DFF]/20 transition-all\">\n              <h3 className=\"text-[16px] font-semibold text-white tracking-tight\">{item.title}</h3>\n              <p className=\"mt-3 text-[13px] leading-[1.6] text-white/60 font-light\">{item.desc}</p>\n            </div>\n          ))}\n        </div>\n\n        <div className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n          <h2 className=\"text-[18px] font-semibold text-white tracking-tight\">Inquiries and Contact</h2>\n          <p className=\"text-white/70 leading-[1.7]\">\n            For qualified corporate development inquiries, shareholder materials, or institutional pilot reviews, please contact our administrative desk directly at <a href=\"mailto:investors@gff.ai\" className=\"text-[#009DFF] hover:underline\">investors@gff.ai</a>.\n          </p>\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { TrendingUp, Landmark, FileCheck } from \"lucide-react\";\n\nexport default function InvestorRelationsPage() {\n  const [pathway, setPathway] = useState(\"strategic\");\n\n  const phases = [\n    { num: \"I\", title: \"Core Incubation\", desc: \"Constructing zero-trust cognitive enclaves and multi-agent DAG architectures.\" },\n    { num: \"II\", title: \"Enterprise Scaling\", desc: \"Capturing recurring SLA-backed allocations in high-security logistics and banking.\" },\n    { num: \"III\", title: \"Sovereign Hubs\", desc: \"Deploying localized regional model clusters to lock geographic regulatory nodes.\" }\n  ];\n\n  const pathways: Record<string, { title: string; desc: string; action: string }> = {\n    strategic: {\n      title: \"Strategic Venture & Equity\",\n      desc: \"We interface with premier technology-focused institutional funds seeking asymmetric equity exposure to highly efficient, software-only cognitive infrastructure.\",\n      action: \"Request Equity Deck\"\n    },\n    advisory: {\n      title: \"Institutional Advisories\",\n      desc: \"We coordinate with corporate advisory panels to align GFF AI systems deployments with multi-jurisdictional compliance and industrial policy goals.\",\n      action: \"Contact Corporate Development\"\n    },\n    governance: {\n      title: \"Audit & Fiscal Compliance\",\n      desc: \"Our financial operations run under stringent capital controls with continuous auditing, separating core R&D compute assets from recurring project revenue streams.\",\n      action: \"Review Governance Framework\"\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Financial Operations\"\n        title=\"Investor Relations Pathway\"\n        highlightedWord=\"Investor\"\n        description=\"Access GFF AI's institutional milestones, strategic corporate phases, and capital-efficient enterprise growth trajectories.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 space-y-16 relative z-10\">\n        \n        {/* Core Vision */}\n        <div className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n          <h2 className=\"text-[20px] font-semibold text-white tracking-tight flex items-center gap-3\">\n            <TrendingUp className=\"w-5 h-5 text-[#009DFF]\" /> Capital-Efficient Cognitive Infrastructure\n          </h2>\n          <p className=\"text-white/70 leading-[1.7] text-[14px] font-light\">\n            GFF AI addresses the massive enterprise orchestration gap with high-performance, productized cognitive assets. By separating cloud compute licensing from core proprietary logical structures, we maintain high margins and low physical overhead, securing Bilateral Stability and highly predictable enterprise retention.\n          </p>\n        </div>\n\n        {/* Growth Phases Timeline */}\n        <div className=\"space-y-6\">\n          <h3 className=\"text-[16px] font-mono uppercase tracking-[0.15em] text-white/40 text-center\">Corporate Expansion Roadmap</h3>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            {phases.map((phase, idx) => (\n              <div key={idx} className=\"p-6 rounded-[24px] border border-white/5 bg-gradient-to-b from-[#08080a] to-[#010101] relative overflow-hidden group hover:border-white/10 transition-all\">\n                <span className=\"absolute top-4 right-4 text-[42px] font-mono font-bold leading-none text-white/5\">{phase.num}</span>\n                <h4 className=\"text-[15px] font-semibold text-white tracking-tight mt-4\">{phase.title}</h4>\n                <p className=\"mt-2 text-[12px] leading-relaxed text-white/50 font-light\">{phase.desc}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Interactive Pathway Selector */}\n        <div className=\"p-8 rounded-[32px] border border-white/5 bg-[#030304]/80 backdrop-blur-[16px] space-y-6\">\n          <div className=\"space-y-2 text-center\">\n            <span className=\"inline-flex px-3 py-1 text-[10px] font-mono tracking-widest text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 rounded-full uppercase\">Allocators Portal</span>\n            <h3 className=\"text-[22px] font-semibold text-white tracking-tight\">Institutional Inquiries</h3>\n            <p className=\"text-white/50 text-[13px] font-light\">Select your pathway to interface with our corporate development desks.</p>\n          </div>\n\n          <div className=\"flex flex-wrap justify-center gap-2 border-b border-white/5 pb-4\">\n            {Object.keys(pathways).map((key) => (\n              <button\n                key={key}\n                onClick={() => setPathway(key)}\n                className={`px-4 py-2 text-[12px] font-medium transition-all rounded-lg ${\n                  pathway === key\n                    ? \"text-white bg-white/5 border border-white/10 font-semibold\"\n                    : \"text-white/40 hover:text-white\"\n                }`}\n              >\n                {key === \"strategic\" ? \"Strategic Equity\" : key === \"advisory\" ? \"Corporate Advisory\" : \"Fiscal Compliance\"}\n              </button>\n            ))}\n          </div>\n\n          <div className=\"p-6 rounded-2xl border border-white/5 bg-black/40 space-y-4 max-w-xl mx-auto text-center\">\n            <h4 className=\"text-[16px] font-semibold text-white\">{pathways[pathway].title}</h4>\n            <p className=\"text-white/60 text-[13px] font-light leading-relaxed\">{pathways[pathway].desc}</p>\n            <a\n              href={`/contact?pathway=${pathway}`}\n              className=\"inline-block px-6 py-2.5 rounded-full text-[12px] font-semibold text-white transition-all bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-95\"\n            >\n              {pathways[pathway].action}\n            </a>\n          </div>\n        </div>\n\n        <PremiumCTA\n          title=\"Interested in GFF AI's Corporate Governance?\"\n          description=\"Qualified representatives from strategic allocators, commercial partners, and family offices may request a detailed operational review.\"\n          primaryLabel=\"Connect with IR Desk\"\n          primaryHref=\"mailto:investors@gff.ai\"\n          secondaryLabel=\"Review Privacy Framework\"\n          secondaryHref=\"/privacy\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
