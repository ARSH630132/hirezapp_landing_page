lts and deallocates all enclave memory blocks.`)) {\n541 |       try {\n542 |         const res = await apiClient.aiOperations.delete(id);\n543 |         if (res.success) {\n544 |           setAgents(prev => prev.filter(a => a.id !== id));\n545 |           if (selectedAgentId === id) setSelectedAgentId(null);\n546 |         } else {\n547 |           alert(\"Failed to terminate running agent on the backend.\");\n548 |         }\n549 |       } catch (err: any) {\n550 |         alert(`Error: ${err.message || \"Failed to connect to supervisor.\"}`);\n551 |       }\n552 |     }\n553 |   };\n554 | \n555 |   const handleAlertAssignOwner = (alertId: string, newOwner: string) => {\n556 |     setAlerts(prev => prev.map(al => {\n557 |       if (al.id === alertId) {\n558 |         if (al.agentId) {\n559 |           setAgents(prevAg => prevAg.map(a => {\n560 |             if (a.id === al.agentId) return { ...a, owner: newOwner };\n561 |             return a;\n562 |           }));\n563 |           appendLogMessage(al.agentId, `Governance alert mitigation bound to owner: ${newOwner}`);\n564 |         }\n565 |         return { ...al, owner: newOwner };\n566 |       }\n567 |       return al;\n568 |     }));\n569 |   };\n570 | \n571 |   const handleUpdateAlertStatus = (alertId: string, newStatus: \"Open\" | \"Investigating\" | \"Resolved\") => {\n572 |     setAlerts(prev => prev.map(al => {\n573 |       if (al.id === alertId) {\n574 |         if (al.agentId) {\n575 |           appendLogMessage(al.agentId, `Governance Alert (${al.id}) status transitioned to: ${newStatus.toUpperCase()}`);\n576 |         }\n577 |         return { ...al, status: newStatus };\n578 |       }\n579 |       return al;\n580 |     }));\n581 |   };\n582 | \n583 |   const appendLogMessage = (agentId: string, message: string) => {\n584 |     const timestamp = new Date().toLocaleTimeString();\n585 |     setAgentLogs(prev => ({\n586 |       ...prev,\n587 |       [agentId]: [...(prev[agentId] || []), `[${timestamp}] 