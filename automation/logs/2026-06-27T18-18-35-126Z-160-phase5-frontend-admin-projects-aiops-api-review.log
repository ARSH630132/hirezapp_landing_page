y-100\" : \"opacity-40\"}`} />\n664 |             <span className=\"text-white/30 uppercase\">Telemetry state:</span>\n665 |             <span className=\"text-[#00FFC2] font-semibold uppercase tracking-wider\">SYNCED</span>\n666 |             <span className=\"text-white/20\">•</span>\n667 |             <span className=\"text-[10px] text-white/40\">EPOCH SEC_2026_A</span>\n668 |           </div>\n669 |         </div>\n670 |       </div>\n671 | \n672 |       {/* --- COMPLIANCE NOTICE BANNER (DO NOT CLAIM LIVE TELEMETRY) --- */}\n673 |       <div className=\"border border-white/5 rounded-xl bg-gradient-to-r from-blue-500/5 to-emerald-500/5 p-4 flex items-start gap-3.5\">\n674 |         <Shield className=\"w-5 h-5 text-[#009DFF] shrink-0 mt-0.5\" />\n675 |         <div className=\"space-y-1\">\n676 |           <div className=\"text-[11px] font-mono uppercase font-bold text-[#009DFF] tracking-wider\">SIMULATION TELEMETRY STREAM ONLY — Standard sandbox compliance auditing mode active.</div>\n677 |           <p className=\"text-[11px] text-white/45 font-mono leading-relaxed max-w-5xl\">\n678 |             This administrative control console operates inside isolated volatile memory spaces. Telemetric streams, CPU partitions (Intel SGX / AMD SEV-SNP), and hardware logs represent verified GFF AI preview models. Actions taken (e.g., owner assignment, diagnostic checks) are modeled locally inside the browser context to demonstrate governance alignment.\n679 |           </p>\n680 |         </div>\n681 |       </div>\n682 | \n683 | \n684 |       {/* --- SECTION 2: HEALTH KPI CARDS GRID --- */}\n685 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n686 |         <WorkspaceCard className=\"relative overflow-hidden group\">\n687 |           <div className=\"flex flex-col h-full justify-between gap-3\">\n688 |             <div className=\"flex items-start justify-between\">\n689 |               <div>\n690 |                 <span className=\"text-[9.5px] font-mono tracking-widest text-white/35 uppercase block\">Global Health Index</span>\n691 |                 <span className=\"text-2xl font-bold text-white tracking-tight font-mono mt-1 block\">{overallStats.healthIndex}%</span>\n692 |               </div>\n693 |               <div className=\"p-1.5 rounded-lg border border-emerald-500/20 bg-emerald-500/10 text-emerald-400\">\n694 |                 <CheckCircle2 className=\"w-4 h-4\" />\n695 |               </div>\n696 |             </div>\n697 |             \n698 |             <div className=\"space-y-1.5 mt-2\">\n699 |               <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase\">\n700 |                 <span>Core Status Pulse</span>\n701 |                 <span className=\"text-emerald-400 font-bold\">{overallStats.healthIndex === 100 ? \"OPTIMAL\" : \"STABLE BOUNDS\"}</span>\n702 |               </div>\n703 |               <div className=\"flex items-center gap-[2.5px] h-2.5 w-full\">\n704 |                 {Array.from({ length: 24 }).map((_, idx) => {\n705 |                   let bg = \"bg-[#00FFC2]\";\n706 |                   if (idx === 15) bg = \"bg-amber-400\";\n707 |                   if (idx === 21) bg = \"bg-white/10\";\n708 |                   return (\n709 |                     <div \n710 |                       key={idx} \n711 |                       className={`h-full flex-1 rounded-[1.5px] ${bg} opacity-80 hover:opacity-100 transition-opacity`} \n712 |                       title=\"Micro-Node Telemetry Integrity Check\"\n713 |                     />\n714 |                   );\n715 |                 })}\n716 |               </div>\n717 |             </div>\n718 |           </div>\n719 |         </WorkspaceCard>\n720 | \n721 |         <WorkspaceCard className=\"relative overflow-hidden group\">\n722 |           <div className=\"flex flex-col h-full justify-between gap-3\">\n723 |             <div className=\"flex items-start justify-between\">\n7