et loss\"] }\n274 |     ];\n275 |     agentsSource.forEach(a => {\n276 |       initialLogs[a.id] = [...a.logs];\n277 |     });\n278 |     return initialLogs;\n279 |   });\n280 | \n281 |   const fetchOperations = useCallback(async () => {\n282 |     setLoading(true);\n283 |     setError(null);\n284 |     try {\n285 |       const res = await apiClient.aiOperations.list();\n286 |       if (res.success && res.operations) {\n287 |         const mapped = res.operations.map(mapApiToRichAgent);\n288 |         setAgents(mapped);\n289 |         \n290 |         // Build initial logs\n291 |         const logsMap: Record<string, string[]> = {};\n292 |         mapped.forEach(a => {\n293 |           logsMap[a.id] = a.logs;\n294 |         });\n295 |         setAgentLogs(logsMap);\n296 |       } else {\n297 |         setError(\"Failed to fetch running AI Operations from secure ledger.\");\n298 |       }\n299 |     } catch (err: any) {\n300 |       setError(err?.message || \"Secure endpoint connection timeout.\");\n301 |     } finally {\n302 |       setLoading(false);\n303 |     }\n304 |   }, []);\n305 | \n306 |   useEffect(() => {\n307 |     fetchOperations();\n308 |   }, [fetchOperations]);\n309 | \n310 |   // --- 2.2 OBSERVED STATES (FILTERS) ---\n311 |   const [searchQuery, setSearchQuery] = useState(\"\");\n312 |   const [clientFilter, setClientFilter] = useState(\"All\");\n313 |   const [projectFilter, setProjectFilter] = useState(\"All\");\n314 |   const [agentTypeFilter, setAgentTypeFilter] = useState(\"All\");\n315 |   const [statusFilter, setStatusFilter] = useState(\"All\");\n316 |   const [severityFilter, setSeverityFilter] = useState(\"All\");\n317 |   const [ownerFilter, setOwnerFilter] = useState(\"All\");\n318 | \n319 |   const [selectedAgentId, setSelectedAgentId] = useState<string | null>(null);\n320 | \n321 |   // --- 2.3 SIMULATION STATES ---\n322 |   const [isVerifying, setIsVerifying] = useState(false);\n323 |   const [isDumping, setIsDumping] = useState(false);