 |         const matchesSearch = \n370 |           agent.name.toLowerCase().includes(q) ||\n371 |           agent.id.toLowerCase().includes(q) ||\n372 |           agent.projectName.toLowerCase().includes(q) ||\n373 |           agent.clientName.toLowerCase().includes(q) ||\n374 |           agent.agentType.toLowerCase().includes(q) ||\n375 |           agent.logs.some(log => log.toLowerCase().includes(q));\n376 |         if (!matchesSearch) return false;\n377 |       }\n378 | \n379 |       if (clientFilter !== \"All\" && agent.clientName !== clientFilter) return false;\n380 |       if (projectFilter !== \"All\" && agent.projectName !== projectFilter) return false;\n381 |       if (agentTypeFilter !== \"All\" && agent.agentType !== agentTypeFilter) return false;\n382 |       if (statusFilter !== \"All\" && agent.status !== statusFilter) return false;\n383 |       if (severityFilter !== \"All\" && agent.severity !== severityFilter) return false;\n384 |       if (ownerFilter !== \"All\" && agent.owner !== ownerFilter) return false;\n385 | \n386 |       return true;\n387 |     });\n388 |   }, [agents, searchQuery, clientFilter, projectFilter, agentTypeFilter, statusFilter, severityFilter, ownerFilter]);\n389 | \n390 |   const filteredAlerts = useMemo(() => {\n391 |     return alerts.filter(alert => {\n392 |       if (searchQuery.trim() !== \"\") {\n393 |         const q = searchQuery.toLowerCase();\n394 |         const matchesSearch = \n395 |           alert.title.toLowerCase().includes(q) ||\n396 |           alert.id.toLowerCase().includes(q) ||\n397 |           alert.clientName.toLowerCase().includes(q) ||\n398 |           alert.desc.toLowerCase().includes(q);\n399 |         if (!matchesSearch) return false;\n400 |       }\n401 | \n402 |       if (clientFilter !== \"All\" && alert.clientName !== clientFilter) return false;\n403 |       \n404 |       if (projectFilter !== \"All\") {\n405 |         const matchingAgent = agents.find(a => a.id === alert.agentId);\n406 |     