.includes(\"retail\") || normalized.includes(\"global\")) return \"client-002\";\n171 |     if (normalized.includes(\"logistics\")) return \"client-003\";\n172 |     if (normalized.includes(\"treasury\") || normalized.includes(\"federal\")) return \"client-004\";\n173 |     return \"client-001\";\n174 |   };\n175 | \n176 |   const fetchProjects = async () => {\n177 |     setLoading(true);\n178 |     setError(null);\n179 |     try {\n180 |       const res = await apiClient.projects.list();\n181 |       if (res.success && res.projects) {\n182 |         const mapped = res.projects.map(p => ({\n183 |           id: p.id,\n184 |           name: p.name,\n185 |           client: p.client_name || \"Apex Sovereign Group [Preview Client]\",\n186 |           phase: p.phase,\n187 |           status: p.health || \"On Track\",\n188 |           owner: p.owner,\n189 |           nodesCount: p.nodesCount || 4,\n190 |           enclaveType: p.enclaveType || \"Intel SGX\",\n191 |           desc: p.desc || \"\",\n192 |           lastUpdated: p.lastUpdated || new Date().toISOString()\n193 |         }));\n194 |         setProjects(mapped);\n195 |       } else {\n196 |         setError(\"Failed to fetch enclaves list from administrative backend.\");\n197 |       }\n198 |     } catch (err: any) {\n199 |       setError(err?.message || \"Secure endpoint connection timeout. Retry authorization.\");\n200 |     } finally {\n201 |       setLoading(false);\n202 |     }\n203 |   };\n204 | \n205 |   useEffect(() => {\n206 |     fetchProjects();\n207 |   }, []);\n208 | \n209 |   const handleResetFilters = () => {\n210 |     setSearchQuery(\"\");\n211 |     setSelectedClient(\"\");\n212 |     setSelectedPhase(\"\");\n213 |     setSelectedStatus(\"\");\n214 |     setSelectedOwner(\"\");\n215 |   };\n216 | \n217 |   const handleUpdateStatus = async (id: string, newStatus: string) => {\n218 |     try {\n219 |       const res = await apiClient.projects.update(id, {\n220 |         health: newStatus\n221 |       });\n222 |       if (res.success) {\n223 |         setProjects(prev => prev.map(p => p.id === id ? { ...p, status: newStatus, lastUpdated: new Date().toISOString() } : p));\n224 |         showToast(`Project ${id} status updated: ${newStatus}`);\n225 |       } else {\n226 |         showToast(`Error updating status: Failed server sync.`);\n227 |       }\n228 |     } catch (err: any) {\n229 |       showToast(`Error: ${err.message || \"Failed to sync status change.\"}`);\n230 |     }\n231 |   };\n232 | \n233 |   const handleUpdatePhase = async (id: string, newPhase: string) => {\n234 |     try {\n235 |       const res = await apiClient.projects.update(id, {\n236 |         phase: newPhase\n237 |       });\n238 |       if (res.success) {\n239 |         setProjects(prev => prev.map(p => p.id === id ? { ...p, phase: newPhase, lastUpdated: new Date().toISOString() } : p));\n240 |         showToast(`Project ${id} phase updated: ${newPhase}`);\n241 |       } else {\n242 |         showToast(`Error updating phase: Failed server sync.`);\n243 |       }\n244 |     } catch (err: any) {\n245 |       showToast(`Error: ${err.message || \"Failed to sync phase change.\"}`);\n246 |     }\n247 |   };\n248 | \n249 |   const handleDeprovision = async (id: string) => {\n250 |     if (confirm(`Deprovision hardware enclave registry ${id}? This halts active telemetry flows.`)) {\n251 |       try {\n252 |         const res = await apiClient.projects.delete(id);\n253 |         if (res.success) {\n254 |           setProjects(prev => prev.filter(p => p.id !== id));\n255 |           showToast(`Deprovisioned hardware enclave ${id}`);\n256 |         } else {\n257 |           showToast(`Error deprovisioning: Failed server action.`);\n258 |         }\n259 |       } catch (err: any) {\n260 |         showToast(`Error: ${err.message || \"Failed to delete enclave registry.\"}`);\n261 |       }\n262 |     }\n263 |   };\n264 | \n265 |   const handleCreateProject = async (e: React.FormEvent) => {\n266 |     e.preventDefault();\n267 |     if (!newProject.name || !newProject.desc) {\n268 |       alert(\"Please fill in project name and description.\");\n269 |       return;\n270 |     }\n271 | \n272 |     try {\n273 |       const payload = {\n274 |         name: newProject.name,\n275 |         client_id: getClientIdFromName(newProject.client),\n276 |         phase: newProject.phase,\n277 |         status: \"active\",\n278 |         health: newProject.status,\n279 |         owner: newProject.owner,\n280 |         nodesCount: Number(newProject.nodesCount) || 4,\n281 |         enclaveType: newProject.enclaveType,\n282 |         desc: newProject.desc\n283 |       };\n284 |       const res = await apiClient.projects.create(payload);\n285 |       if (res.success && res.project) {\n286 |         const p = res.project;\n287 |         const created: AdminProject = {\n288 |           id: p.id,\n289 |           name: p.name,\n290 |           client: p.client_name || newProject.client,\n291 |           phase: p.phase,\n292 |           status: p.health || newProject.status,\n293 |           owner: p.owner,\n294 |           nodesCount: p.nodesCount || 4,\n295 |           enclaveType: p.enclaveType,\n296 |           desc: p.desc,\n297 |           lastUpdated: p.lastUpdated || new Date().toISOString()\n298 |         };\n299 |         setProjects(prev => [created, ...prev]);\n300 |         setIsCreateModalOpen(false);\n301 |         \n302 |         // Reset Form\n303 |         setNewProject({\n304 |           name: \"\",\n305 |           client: AVAILABLE_CLIENTS[0],\n306 |           phase: AVAILABLE_PHASES[0],\n307 |           status: AVAILABLE_STATUSES[0],\n308 |           owner: AVAILABLE_OWNERS[0],\n309 |           nodesCount: 4,\n310 |           enclaveType: ENCLAVE_TYPES[0],\n311 |           desc: \"\"\n312 |         });\n313 |         showToast(`Successfully registered and isolated enclave ${p.id}`);\n314 |       } else {\n315 |         showToast(\"Error creating project enclave. Backend validation failed.\");\n316 |       }\n317 |     } catch (err: any) {\n318 |       showToast(`Error: ${err.message || \"Failed to create project sandbox.\"}`);\n319 |     }\n320 |   };\n321 | \n322 |   const handleEditProjectSubmit = async (e: React.FormEvent) => {\n323 |     e.preventDefault();\n324 |     if (!editForm) return;\n325 | \n326 |     try {\n327 |       const res = await apiClient.projects.update(editForm.id, {\n328 |         name: editForm.name,\n329 |         client_id: getClientIdFromName(editForm.client),\n330 |         phase: editForm.phase,\n331 |         health: editForm.status,\n332 |         owner: editForm.owner,\n333 |         nodesCount: Number(editForm.nodesCount) || 4,\n334 |         enclaveType: editForm.enclaveType,\n335 |         desc: editForm.desc\n336 |       });\n337 |       if (res.success && res.project) {\n338 |         const p = res.project;\n339 |         const updated: AdminProject = {\n340 |           id: p.id,\n341 |           name: p.name,\n342 |           client: p.client_name || editForm.client,\n343 |           phase: p.phase,\n344 |           status: p.health || editForm.status,\n345 |           owner: p.owner,\n346 |           nodesCount: p.nodesCount || 4,\n347 |           enclaveType: p.enclaveType,\n348 |           desc: p.desc,\n349 |           lastUpdated: p.lastUpdated || new Date().toISOString()\n350 |         };\n351 |         setProjects(prev => prev.map(item => item.id === editForm.id ? updated : item));\n352 |         setIsEditModalOpen(false);\n353 |         setEditForm(null);\n354 |         showToast(`Updated enclave parameter mappings for project ${editForm.id}`);\n355 |       } else {\n356 |         showToast(\"Error editing project sandbox.\");\n357 |       }\n358 |     } catch (err: any) {\n359 |       showToast(`Error: ${err.message || \"Failed to update project.\"}`);\n360 |     }\n361 |   };\n362 | \n363 |   // Memoized Filtered Projects List\n364 |   const filteredProjects = useMemo(() => {\n365 |     return projects.filter(p => {\n366 |       const query = searchQuery.trim().toLowerCase();\n367 |       const matchesSearch = query === \"\" ||\n368 |         p.name.toLowerCase().includes(query) ||\n369 |         p.id.toLowerCase().includes(query) ||\n370 |         p.owner.toLowerCase().includes(query) ||\n371 |         p.desc.toLowerCase().includes(query);\n372 | \n373 |       const matchesClient = selectedClient === \"\" || p.client === selectedClient;\n374 |       const matchesPhase = selectedPhase === \"\" || p.phase === selectedPhase;\n375 |       const matchesStatus = selectedStatus === \"\" || p.status === selectedStatus;\n376 |       const matchesOwner = selectedOwner === \"\" || p.owner === selectedOwner;\n377 | \n378 |       return matchesSearch && matchesClient && matchesPhase && matchesStatus && matchesOwner;\n379 |     });\n380 |   }, [projects, searchQuery, selectedClient, selectedPhase, selectedStatus, selectedOwner]);\n381 | \n382 |   const getStatusStyle = (status: string) => {\n383 |     switch (status) {\n384 |       case \"On Track\":\n385 |         return \"bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/15\";\n386 |       case \"At Risk\":\n387 |         return \"bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500/15\";\n388 |       case \"Delayed\":\n389 |         return \"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/15\";\n390 |       case \"Paused\":\n391 |         return \"bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/15\";\n392 |       default:\n393 |         return \"bg-white/5 border border-white/10 text-white/60 hover:bg-white/10\";\n394 |     }\n395 |   };\n396 | \n397 |   const getPhaseColor = (phase: string) => {\n398 |     switch (phase) {\n399 |       case \"Phase I: Planning\":\n400 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.6)\" };\n401 |       case \"Phase II: Sandbox Provisioning\":\n402 |         return { border: \"rgba(59, 130, 246, 0.2)\", dot: \"rgb(59, 130, 246)\" };\n403 |       case \"Phase III: Agent Alignment\":\n404 |         return { border: \"rgba(0, 157, 255, 0.3)\", dot: \"rgb(0, 157, 255)\" };\n405 |       case \"Phase IV: User Acceptance Testing\":\n406 |         return { border: \"rgba(99, 102, 241, 0.3)\", dot: \"rgb(99, 102, 241)\" };\n407 |       case \"Phase V: Production-Live\":\n408 |         return { border: \"rgba(0, 255, 194, 0.3)\", dot: \"rgb(0, 255, 194)\" };\n409 |       default:\n410 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.4)\" };\n411 |     }\n412 |   };\n413 | \n414 |   return (\n415 |     <div className=\"space-y-6\">\n416 |       {/* 1. Page Header */}\n417 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n418 |         <div>\n419 |           <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2 py-0.5 rounded uppercase tracking-wider\">\n420 |             Sovereign Admin Panel\n421 |           </span>\n422 |           <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase mt-1.5\">\n423 |             Internal Project Delivery\n424 |           </h2>\n425 |           <p className=\"text-xs text-white/50 mt-1 max-w-2xl font-mono leading-relaxed\">\n426 |             Administrative flight deck for auditing multi-agent alignment phases, cluster isolated nodes, and deployment owners across global sovereign client tenants.\n427 |           </p>\n428 |         </div>\n429 |         <div className=\"shrink-0\">\n430 |           <button\n431 |             onClick={() => setIsCreateModalOpen(true)}\n432 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n433 |           >\n434 |             <Plus className=\"w-4 h-4\" />\n435 |             <span>Create Sandbox Preview</span>\n436 |           </button>\n437 |         </div>\n438 |       </div>\n439 | \n440 |       {/* 2. Metrics Ribbon */}\n441 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n442 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n443 |           <div className=\"flex items-center justify-between\">\n444 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Active Enclaves</span>\n445 |             <Layers className=\"w-4 h-4 text-[#009DFF] opacity-80\" />\n446 |           </div>\n447 |           <div className=\"flex items-baseline gap-2\">\n448 |             <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{projects.length}</span>\n449 |             <span className=\"text-[10px] font-mono text-emerald-400 font-bold\">LIVE TELEMETRY</span>\n450 |           </div>\n451 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Isolated client lattices monitored</div>\n452 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#009DFF]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n453 |         </div>\n454 | \n455 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n456 |           <div className=\"flex items-center justify-between\">\n457 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Live Deployments</span>\n458 |             <CheckCircle2 className=\"w-4 h-4 text-[#00FFC2] opacity-80\" />\n459 |           </div>\n460 |           <div className=\"flex items-baseline gap-2\">\n461 |             <span className=\"text-2xl font-mono font-bold text-[#00FFC2] tracking-tight\">\n462 |               {projects.filter(p => p.phase === \"Phase V: Production-Live\").length}\n463 |             </span>\n464 |             <span className=\"text-[10px] font-mono text-[#00FFC2]/75 font-semibold\">PHASE V STATE</span>\n465 |           </div>\n466 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Enclaves in full production delivery</div>\n467 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#00FFC2]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n468 |         </div>\n469 | \n470 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n471 |           <div className=\"flex items-center justify-between\">\n472 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Active Delivery Risks</span>\n473 |             <ShieldAlert className=\"w-4 h-4 text-rose-400 opacity-80\" />\n474 |           </div>\n475 |           <div className=\"flex items-baseline gap-2\">\n476 |             <span className={`text-2xl font-mono font-bold tracking-tight ${projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"text-rose-400\" : \"text-white\"}`}>\n477 |               {projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length}\n478 |             </span>\n479 |             <span className={`text-[10px] font-mono font-bold ${projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"text-rose-400/80\" : \"text-white/40\"}`}>\n480 |               {projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"SLA BREACH RISK\" : \"NOMINAL\"}\n481 |             </span>\n482 |           </div>\n483 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">At-risk and delayed projects active</div>\n484 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-rose-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n485 |         </div>\n486 | \n487 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n488 |           <div className=\"flex items-center justify-between\">\n489 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">SLA Owners Active</span>\n490 |             <User className=\"w-4 h-4 text-purple-400 opacity-80\" />\n491 |           </div>\n492 |           <div className=\"flex items-baseline gap-2\">\n493 |             <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">\n494 |               {new Set(projects.map(p => p.owner)).size}\n495 |             </span>\n496 |             <span className=\"text-[10px] font-mono text-purple-400 font-bold\">ON DUTY</span>\n497 |           </div>\n498 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Sovereign engineering delivery staff</div>\n499 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-purple-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n500 |         </div>\n501 |       </div>\n502 | \n503 |       {/* 3. Search and Dynamic Filtering Control Deck */}\n504 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/40 space-y-4 shadow-[inset_0_1px_1px_rgba(255,255,255,0.02)]\">\n505 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-3\">\n506 |           {/* Text search */}\n507 |           <div className=\"relative md:col-span-1\">\n508 |             <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n509 |             <input\n510 |               type=\"text\"\n511 |               placeholder=\"Search registry...\"\n512 |               value={searchQuery}\n513 |               onChange={(e) => setSearchQuery(e.target.value)}\n514 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n515 |             />\n516 |           </div>\n517 | \n518 |           {/* Client filter */}\n519 |           <div className=\"relative\">\n520 |             <select\n521 |               value={selectedClient}\n522 |               onChange={(e) => setSelectedClient(e.target.value)}\n523 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-[#030303] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n524 |             >\n525 |               <option value=\"\" className=\"text-white/50\">ALL CLIENTS</option>\n526 |               {AVAILABLE_CLIENTS.map((c) => (\n527 |                 <option key={c} value={c} className=\"text-white\">\n528 |                   {c.replace(\" [Preview Client]\", \"\").toUpperCase()}\n529 |                 </option>\n530 |               ))}\n531 |             </select>\n532 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n533 |           </div>\n534 | \n535 |           {/* Phase filter */}\n536 |           <div className=\"relative\">\n537 |             <select\n538 |             