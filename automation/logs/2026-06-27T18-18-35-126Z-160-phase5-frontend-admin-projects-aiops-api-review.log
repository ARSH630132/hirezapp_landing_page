 !== \"Resolved\").length;\n350 |     \n351 |     const activeLatencies = agents.filter(a => a.latencyMs > 0).map(a => a.latencyMs);\n352 |     const meanLatency = activeLatencies.length > 0 \n353 |       ? Math.round(activeLatencies.reduce((acc, val) => acc + val, 0) / activeLatencies.length) \n354 |       : 0;\n355 | \n356 |     return {\n357 |       healthIndex,\n358 |       totalThreads,\n359 |       meanLatency,\n360 |       activeAlertsCount\n361 |     };\n362 |   }, [agents, alerts]);\n363 | \n364 |   // --- 2.5 REAL-TIME MATCHING / REACTION ENGINE ---\n365 |   const filteredAgents = useMemo(() => {\n366 |     return agents.filter(agent => {\n367 |       if (searchQuery.trim() !== \"\") {\n368 |         const q = searchQuery.toLowerCase();\n369 |         const matchesSearch = \n370 |           agent.name.toLowerCase().includes(q) ||\n371 |           agent.id.toLowerCase().includes(q) ||\n372 |           agent.projectName.toLowerCase().includes(q) ||\n373 |           agent.clientName.toLowerCase().includes(q) ||\n374 |           agent.agentType.toLowerCase().includes(q) ||\n375 |           agent.logs.some(log => log.toLowerCase().includes(q));\n376 |         if (!matchesSearch) return false;\n377 |       }\n378 | \n379 |       if (clientFilter !== \"All\" && agent.clientName !== clientFilter) return false;\n380 |       if (projectFilter !== \"All\" && agent.projectName !== projectFilter) return false;\n381 |       if (agentTypeFilter !== \"All\" && agent.agentType !== agentTypeFilter) return false;\n382 |       if (statusFilter !== \"All\" && agent.status !== statusFilter) return false;\n383 |       if (severityFilter !== \"All\" && agent.severity !== severityFilter) return false;\n384 |       if (ownerFilter !== \"All\" && agent.owner !== ownerFilter) return false;\n385 | \n386 |       return true;\n387 |     });\n388 |   }, [agents, searchQuery, clientFilter, projectFilter, agentTypeFilter, statusFilter, severityFilter, ownerFilter]);\n389 | \n390 |   const filteredAlerts = useMemo(() => {\n391 |     return alerts.filter(alert => {\n392 |       if (searchQuery.trim() !== \"\") {\n393 |         const q = searchQuery.toLowerCase();\n394 |         const matchesSearch = \n395 |           alert.title.toLowerCase().includes(q) ||\n396 |           alert.id.toLowerCase().includes(q) ||\n397 |           alert.clientName.toLowerCase().includes(q) ||\n398 |           alert.desc.toLowerCase().includes(q);\n399 |         if (!matchesSearch) return false;\n400 |       }\n401 | \n402 |       if (clientFilter !== \"All\" && alert.clientName !== clientFilter) return false;\n403 |       \n404 |       if (projectFilter !== \"All\") {\n405 |         const matchingAgent = agents.find(a => a.id === alert.agentId);\n406 |         if (!matchingAgent || matchingAgent.projectName !== projectFilter) return false;\n407 |       }\n408 | \n409 |       if (severityFilter !== \"All\" && alert.severity !== severityFilter) return false;\n410 |       if (ownerFilter !== \"All\" && alert.owner !== ownerFilter) return false;\n411 | \n412 |       return true;\n413 |     });\n414 |   }, [alerts, agents, searchQuery, clientFilter, projectFilter, severityFilter, ownerFilter]);\n415 | \n416 |   const selectedAgent = useMemo(() => {\n417 |     return agents.find(a => a.id === selectedAgentId) || null;\n418 |   }, [agents, selectedAgentId]);\n419 | \n420 | \n421 | \n422 |   // --- 2.6 LOCAL MUTATIVE ACTIONS (REST BACKEND CRUD CONNECTED) ---\n423 |   const handleAssignOwner = async (agentId: string, newOwner: string) => {\n424 |     try {\n425 |       const res = await apiClient.aiOperations.update(agentId, {\n426 |         owner: newOwner\n427 |       });\n428 |       if (res.success) {\n429 |         setAgents(prev => prev.map(a => a.id === agentId ? { ...a, owner: newOwner } : a));\n430 |         setAlerts(prev => prev.map(al => al.agentId === agentId ? { ...al, owner: newOwner } : al));\n431 |         appendLogMessage(agentId, `Security clearance validated. Re-assigned owner bounds to: ${newOwner}`);\n432 |       }\n433 |     } catch (err: any) {\n434 |       console.error(\"Failed to assign owner on backend:\", err);\n435 |     }\n436 |   };\n437 | \n438 |   const handleCreateAgentSubmit = async (e: React.FormEvent) => {\n439 |     e.preventDefault();\n440 |     if (!newAgent.name) {\n441 |       alert(\"Please provide an Agent name.\");\n442 |       return;\n443 |     }\n444 | \n445 |     try {\n446 |       const extraPayload = {\n447 |         projectName: getProjectNameFromId(newAgent.projectId),\n448 |         threads: 24,\n449 |         memory: \"4.0 GB / 8.0 GB\",\n450 |         cpu: 35,\n451 |         latencyMs: 15,\n452 |         uptime: 99.98,\n453 |         enclaveType: newAgent.enclaveType,\n454 |         logs: [\n455 |           \"Zero-Trust verification complete.\",\n456 |           \"Secure isolated telemetry stream initiated.\"\n457 |         ]\n458 |       };\n459 | \n460 |       const payload = {\n461 |         name: newAgent.name,\n462 |         client_id: getClientIdFromName(newAgent.clientName),\n463 |         project_id: newAgent.projectId,\n464 |         status: newAgent.status,\n465 |         health: \"healthy\",\n466 |         agent_type: newAgent.agentType,\n467 |         governance_status: newAgent.severity,\n468 |         owner: newAgent.owner,\n469 |         desc: JSON.stringify(extraPayload)\n470 |       };\n471 | \n472 |       const res = await apiClient.aiOperations.create(payload);\n473 |       if (res.success && res.operation) {\n474 |         const op = res.operation;\n475 |         const mapped = mapApiToRichAgent(op);\n476 |         setAgents(prev => [mapped, ...prev]);\n477 |         setAgentLogs(prev => ({ ...prev, [mapped.id]: mapped.logs }));\n478 |         setIsCreateModalOpen(false);\n479 |         setNewAgent({\n480 |           name: \"\",\n481 |           projectId: \"proj-001\",\n482 |           clientName: \"Apex Sovereign Group [Preview Client]\",\n483 |           status: \"active\",\n484 |           agentType: \"Core Model\",\n485 |           severity: \"Low\",\n486 |           owner: \"Unassigned\",\n487 |           enclaveType: \"Intel SGX\",\n488 |           desc: \"\"\n489 |         });\n490 |       } else {\n491 |         alert(\"Failed to register operational agent on backend.\");\n492 |       }\n493 |     } catch (err: any) {\n494 |       alert(`Error: ${err.message || \"Failed to sync enclave database.\"}`);\n495 |     }\n496 |   };\n497 | \n498 |   const handleEditAgentSubmit = async (e: React.FormEvent) => {\n499 |     e.preventDefault();\n500 |     if (!editAgentForm) return;\n501 | \n502 |     try {\n503 |       const extraPayload = {\n504 |         projectName: getProjectNameFromId(editAgentForm.projectId),\n505 |         threads: editAgentForm.threads,\n506 |         memory: editAgentForm.memory,\n507 |         cpu: editAgentForm.cpu,\n508 |         latencyMs: editAgentForm.latencyMs,\n509 |         uptime: editAgentForm.uptime,\n510 |         enclaveType: editAgentForm.enclaveType,\n511 |         logs: agentLogs[editAgentForm.id] || []\n512 |       };\n513 | \n514 |       const payload = {\n515 |         name: editAgentForm.name,\n516 |         client_id: getClientIdFromName(editAgentForm.clientName),\n517 |         project_id: editAgentForm.projectId,\n518 |         status: editAgentForm.status,\n519 |         agent_type: editAgentForm.agentType,\n520 |         governance_status: editAgentForm.severity,\n521 |         owner: editAgentForm.owner,\n522 |         desc: JSON.stringify(extraPayload)\n523 |       };\n524 | \n525 |       const res = await apiClient.aiOperations.update(editAgentForm.id, payload);\n526 |       if (res.success && res.operation) {\n527 |         const mapped = mapApiToRichAgent(res.operation);\n528 |         setAgents(prev => prev.map(a => a.id === editAgentForm.id ? mapped : a));\n529 |         setIsEditModalOpen(false);\n530 |         setEditAgentForm(null);\n531 |       } else {\n532 |         alert(\"Failed to update operational agent.\");\n533 |       }\n534 |     } catch (err: any) {\n535 |       alert(`Error: ${err.message || \"Failed to update agent.\"}`);\n536 |     }\n537 |   };\n538 | \n539 |   const handleTerminateAgent = async (id: string) => {\n540 |     if (confirm(`Terminate running operational agent ${id}? This halts and deallocates all enclave memory blocks.`)) {\n541 |       try {\n542 |         const res = await apiClient.aiOperations.delete(id);\n543 |         if (res.success) {\n544 |           setAgents(prev => prev.filter(a => a.id !== id));\n545 |           if (selectedAgentId === id) setSelectedAgentId(null);\n546 |         } else {\n547 |           alert(\"Failed to terminate running agent on the backend.\");\n548 |         }\n549 |       } catch (err: any) {\n550 |         alert(`Error: ${err.message || \"Failed to connect to supervisor.\"}`);\n551 |       }\n552 |     }\n553 |   };\n554 | \n555 |   const handleAlertAssignOwner = (alertId: string, newOwner: string) => {\n556 |     setAlerts(prev => prev.map(al => {\n557 |       if (al.id === alertId) {\n558 |         if (al.agentId) {\n559 |           setAgents(prevAg => prevAg.map(a => {\n560 |             if (a.id === al.agentId) return { ...a, owner: newOwner };\n561 |             return a;\n562 |           }));\n563 |           appendLogMessage(al.agentId, `Governance alert mitigation bound to owner: ${newOwner}`);\n564 |         }\n565 |         return { ...al, owner: newOwner };\n566 |       }\n567 |       return al;\n568 |     }));\n569 |   };\n570 | \n571 |   const handleUpdateAlertStatus = (alertId: string, newStatus: \"Open\" | \"Investigating\" | \"Resolved\") => {\n572 |     setAlerts(prev => prev.map(al => {\n573 |       if (al.id === alertId) {\n574 |         if (al.agentId) {\n575 |           appendLogMessage(al.agentId, `Governance Alert (${al.id}) status transitioned to: ${newStatus.toUpperCase()}`);\n576 |         }\n577 |         return { ...al, status: newStatus };\n578 |       }\n579 |       return al;\n580 |     }));\n581 |   };\n582 | \n583 |   const appendLogMessage = (agentId: string, message: string) => {\n584 |     const timestamp = new Date().toLocaleTimeString();\n585 |     setAgentLogs(prev => ({\n586 |       ...prev,\n587 |       [agentId]: [...(prev[agentId] || []), `[${timestamp}] ${message}`]\n588 |     }));\n589 |   };\n590 | \n591 |   const handleTriggerIntegrityCheck = (agentId: string) => {\n592 |     if (isVerifying) return;\n593 |     setIsVerifying(true);\n594 |     appendLogMessage(agentId, \"INTEGRITY INITIATED: Locking enclave heap structure...\");\n595 |     \n596 |     setTimeout(() => {\n597 |       appendLogMessage(agentId, \"INTEGRITY SCANNING: Correlating zero-trust hardware keys against HSM storage...\");\n598 |     }, 600);\n599 | \n600 |     setTimeout(() => {\n601 |       appendLogMessage(agentId, \"INTEGRITY OK: SHA-256 kernel signatures VERIFIED. (0x7FFA8F)\");\n602 |       setIsVerifying(false);\n603 |     }, 1500);\n604 |   };\n605 | \n606 |   const handleTriggerThreadDump = (agentId: string) => {\n607 |     if (isDumping) return;\n608 |     setIsDumping(true);\n609 |     appendLogMessage(agentId, \"THREAD DUMP INITIATED: Terminating transient context frames...\");\n610 | \n611 |     setTimeout(() => {\n612 |       appendLogMessage(agentId, \"THREAD DUMP PROGRESS: Dumping execution trace (128 KB written to compliance vault)...\");\n613 |     }, 800);\n614 | \n615 |     setTimeout(() => {\n616 |       appendLogMessage(agentId, \"THREAD DUMP OK: Sandbox registers re-synchronized. All threads resumed gracefully.\");\n617 |       setIsDumping(false);\n618 |     }, 1800);\n619 |   };\n620 | \n621 |   const handleResetFilters = () => {\n622 |     setSearchQuery(\"\");\n623 |     setClientFilter(\"All\");\n624 |     setProjectFilter(\"All\");\n625 |     setAgentTypeFilter(\"All\");\n626 |     setStatusFilter(\"All\");\n627 |     setSeverityFilter(\"All\");\n628 |     setOwnerFilter(\"All\");\n629 |   };\n630 | \n631 |   return (\n632 |     <motion.div \n633 |       initial={{ opacity: 0, y: 8 }}\n634 |       animate={{ opacity: 1, y: 0 }}\n635 |       transition={{ duration: 0.4, ease: \"easeOut\" }}\n636 |       className=\"space-y-6 max-w-[1600px] mx-auto pb-12\"\n637 |     >\n638 |       {/* --- SECTION 1: NARRATIVE HEADER & COMPLIANCE STITCH --- */}\n639 |       <div className=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-white/5 pb-5\">\n640 |         <div>\n641 |           <div className=\"flex items-center gap-2.5\">\n642 |             <div className=\"h-2 w-2 rounded-full bg-[#009DFF] relative flex shrink-0\">\n643 |               <span className={`animate-ping absolute inline-flex h-full w-full rounded-full bg-[#009DFF] opacity-75 ${simulationPulse ? \"scale-150\" : \"scale-100\"}`}></span>\n644 |             </div>\n645 |             <span className=\"text-[10px] font-mono tracking-widest text-[#009DFF] uppercase font-bold\">SOVEREIGN CORE TELEMETRY</span>\n646 |           </div>\n647 |           <h2 className=\"text-2xl font-bold text-white tracking-tight font-mono uppercase mt-1\">AI Operations Command Center</h2>\n648 |           <p className=\"text-xs text-white/55 mt-1 leading-relaxed max-w-2xl\">\n649 |             Global administrative terminal. Audit multi-agent runtimes, monitor context frame load indices, and coordinate incident ownership across verified hardware enclaves.\n650 |           </p>\n651 |         </div>\n652 | \n653 |         <div className=\"flex flex-col sm:flex-row items-start sm:items-center gap-3 self-start md:self-auto\">\n654 |           <button\n655 |             onClick={() => setIsCreateModalOpen(true)}\n656 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n657 |           >\n658 |             <Plus className=\"w-4 h-4\" />\n659 |             <span>Create Operational Agent</span>\n660 |           </button>\n661 | \n662 |           <div className=\"flex items-center gap-3 font-mono text-[11px] border border-white/5 bg-[#050505]/35 rounded-lg px-3 py-2 text-white/60\">\n663 |             <Activity className={`w-3.5 h-3.5 text-[#00FFC2] shrink-0 ${simulationPulse ? \"opacity-100\" : \"opacity-40\"}`} />\n664 |             <span className=\"text-white/30 uppercase\">Telemetry state:</span>\n665 |             <span className=\"text-[#00FFC2] font-semibold uppercase tracking-wider\">SYNCED</span>\n666 |             <span className=\"text-white/20\">•</span>\n667 |             <span className=\"text-[10px] text-white/40\">EPOCH SEC_2026_A</span>\n668 |           </div>\n669 |         </div>\n670 |       </div>\n671 | \n672 |       {/* --- COMPLIANCE NOTICE BANNER (DO NOT CLAIM LIVE TELEMETRY) --- */}\n673 |       <div className=\"border border-white/5 rounded-xl bg-gradient-to-r from-blue-500/5 to-emerald-500/5 p-4 flex items-start gap-3.5\">\n674 |         <Shield className=\"w-5 h-5 text-[#009DFF] shrink-0 mt-0.5\" />\n675 |         <div className=\"space-y-1\">\n676 |           <div className=\"text-[11px] font-mono uppercase font-bold text-[#009DFF] tracking-wider\">SIMULATION TELEMETRY STREAM ONLY — Standard sandbox compliance auditing mode active.</div>\n677 |           <p className=\"text-[11px] text-white/45 font-mono leading-relaxed max-w-5xl\">\n678 |             This administrative control console operates inside isolated volatile memory spaces. Telemetric streams, CPU partitions (Intel SGX / AMD SEV-SNP), and hardware logs represent verified GFF AI preview models. Actions taken (e.g., owner assignment, diagnostic checks) are modeled locally inside the browser context to demonstrate governance alignment.\n679 |           </p>\n680 |         </div>\n681 |       </div>\n682 | \n683 | \n684 |       {/* --- SECTION 2: HEALTH KPI CARDS GRID ---