{"ts":"2026-06-26T19:41:42.182Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"y5z3zpgd","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/roi/page.tsx","result":"  1 | \"use client\";\n  2 | \n  3 | import React, { useState, useEffect } from \"react\";\n  4 | import { motion, AnimatePresence } from \"motion/react\";\n  5 | import Link from \"next/link\";\n  6 | import { ToolPageShell, ToolHero } from \"@/components/build/components\";\n  7 | \n  8 | type Priority =\n  9 |   | \"cost_reduction\"\n 10 |   | \"compliance_security\"\n 11 |   | \"operational_speed\"\n 12 |   | \"customer_experience\"\n 13 |   | \"decision_automation\";\n 14 | \n 15 | export default function ROICalculatorPage() {\n 16 |   // 1. STATE & PARAMETERS\n 17 |   const [industry, setIndustry] = useState<string>(\"financial_services\");\n 18 |   const [companySize, setCompanySize] = useState<string>(\"enterprise\");\n 19 |   const [opFunction, setOpFunction] = useState<string>(\"customer_operations\");\n 20 |   const [annualCostBaseline, setAnnualCostBaseline] = useState<number>(1500000);\n 21 |   const [processVolume, setProcessVolume] = useState<number>(250000);\n 22 |   const [avgHandlingTime, setAvgHandlingTime] = useState<number | \"\">(15);\n 23 |   const [automationTarget, setAutomationTarget] = useState<number>(65);\n 24 |   const [manualEffort, setManualEffort] = useState<string>(\"high\");\n 25 |   const [productivityImprovement, setProductivityImprovement] = useState<number>(50);\n 26 |   const [implementationHorizon, setImplementationHorizon] = useState<string>(\"6_months\");\n 27 |   const [initialInvestment, setInitialInvestment] = useState<number>(350000);\n 28 |   const [priority, setPriority] = useState<Priority>(\"cost_reduction\");\n 29 |   const [copied, setCopied] = useState(false);\n 30 | \n 31 |   // Synchronize derived platform setup CapEx whenever scale or horizon shifts\n 32 |   useEffect(() => {\n 33 |     let base = 350000;\n 34 |     if (companySize === \"smb\") base = 75000;\n 35 |     else if (companySize === \"mid\") base = 150000;\n 36 |     else if (companySize === \"enterprise\") base = 350000;\n 37 |     else if (companySize === \"large_enterprise\") base = 750000;\n 38 |     else if (companySize === \"global_corp\") base = 1500000;\n 39 | \n 40 |     let multiplier = 1.0;\n 41 |     if (implementationHorizon === \"3_months\") multiplier = 1.1;\n 42 |     else if (implementationHorizon === \"6_months\") multiplier = 1.0;\n 43 |     else if (implementationHorizon === \"12_months\") multiplier = 0.9;\n 44 |     else if (implementationHorizon === \"18_months\") multiplier = 0.8;\n 45 | \n 46 |     setInitialInvestment(Math.round(base * multiplier));\n 47 |   }, [companySize, implementationHorizon]);\n 48 | \n 49 |   // 2. MATHEMATICAL MODEL FOR SOVEREIGN ROI CALCULATION\n 50 |   const industryBaseRate: Record<string, number> = {\n 51 |     financial_services: 95,\n 52 |     healthcare: 90,\n 53 |     energy_utilities: 85,\n 54 |     telecommunications: 75,\n 55 |     public_sector: 65,\n 56 |     retail_logistics: 55,\n 57 |     technology_media: 100\n 58 |   };\n 59 | \n 60 |   const functionMultiplier: Record<string, number> = {\n 61 |     customer_operations: 0.7,\n 62 |     legal_compliance: 1.4,\n 63 |     supply_chain: 0.9,\n 64 |     finance_accounting: 1.2,\n 65 |     it_engineering: 1.3,\n 66 |     hr_admin: 0.8\n 67 |   };\n 68 | \n 69 |   const loadedHourlyRate = Math.round(\n 70 |     (industryBaseRate[industry] || 80) * (functionMultiplier[opFunction] || 1.0)\n 71 |   );\n 72 | \n 73 |   const manualEffortFactor = {\n 74 |     low: 0.20,\n 75 |     medium: 0.40,\n 76 |     high: 0.65,\n 77 |     critical: 0.85\n 78 |   }[manualEffort] || 0.65;\n 79 | \n 80 |   const addressableCostBaseline = Math.round(annualCostBaseline * manualEffortFactor);\n 81 | \n 82 |   const manualHoursSpent = avgHandlingTime !== \"\" && avgHandlingTime > 0\n 83 |     ? Math.round(processVolume * (avgHandlingTime / 60))\n 84 |     : Math.round(addressableCostBaseline / loadedHourlyRate);\n 85 | \n 86 |   // EXPECTED GFF STANDARD CASE\n 87 |   const expectedAdoptionFactor = automationTarget / 100;\n 88 |   const expectedProductivityFactor = productivityImprovement / 100;\n 89 |   const expectedSavingsFactor = expectedAdoptionFactor * expectedProductivityFactor;\n 90 | \n 91 |   const expectedGrossSavings = Math.round(addressableCostBaseline * expectedSavingsFactor);\n 92 |   const expectedHoursSaved = Math.round(manualHoursSpent * expectedSavingsFactor);\n 93 |   const expectedNetSavings = Math.max(0, expectedGrossSavings - initialInvestment);\n 94 |   const expectedRoi = initialInvestment > 0 ? Math.round((expectedNetSavings / initialInvestment) * 100) : 0;\n 95 | \n 96 |   const expectedMonthlySavings = expectedGrossSavings / 12;\n 97 |   const expectedPaybackMonths = expectedMonthlySavings > 0\n 98 |     ? Math.max(0.1, Math.round((initialInvestment / expectedMonthlySavings) * 10) / 10)\n 99 |     : 0;\n100 | \n101 |   // CONSERVATIVE GFF CASE (Risk-Adjusted Setup)\n102 |   const conservativeAdoptionFactor = (automationTarget * 0.75) / 100;\n103 |   const conservativeProductivityFactor = Math.max(10, productivityImprovement - 15) / 100;\n104 |   const conservativeSavingsFactor = conservativeAdoptionFactor * conservativeProductivityFactor;\n105 | \n106 |   const conservativeGrossSavings = Math.round(addressableCostBaseline * conservativeSavingsFactor);\n107 |   const conservativeHoursSaved = Math.round(manualHoursSpent * conservativeSavingsFactor);\n108 |   const conservativeNetSavings = Math.max(0, conservativeGrossSavings - initialInvestment);\n109 |   const conservativeRoi = initialInvestment > 0 ? Math.round((conservativeNetSavings / initialInvestment) * 100) : 0;\n110 | \n111 |   const conservativeMonthlySavings = conservativeGrossSavings / 12;\n112 |   const conservativePaybackMonths = conservativeMonthlySavings > 0\n113 |     ? Math.max(0.1, Math.round((initialInvestment / conservativeMonthlySavings) * 10) / 10)\n114 |     : 0;\n115 | \n116 |   // AGGRESSIVE GFF CASE (Synergy & Cognitive Multipliers)\n117 |   const aggressiveAdoptionFactor = Math.min(98, automationTarget * 1.15) / 100;\n118 |   const aggressiveProductivityFactor = Math.min(95, productivityImprovement + 15) / 100;\n119 |   const aggressiveSavingsFactor = aggressiveAdoptionFactor * aggressiveProductivityFactor;\n120 | \n121 |   const aggressiveGrossSavings = Math.round(addressableCostBaseline * aggressiveSavingsFactor);\n122 |   const aggressiveHoursSaved = Math.round(manualHoursSpent * aggressiveSavingsFactor);\n123 |   const aggressiveNetSavings = Math.max(0, aggressiveGrossSavings - initialInvestment);\n124 |   const aggressiveRoi = initialInvestment > 0 ? Math.round((aggressiveNetSavings / initialInvestment) * 100) : 0;\n125 | \n126 |   const aggressiveMonthlySavings = aggressiveGrossSavings / 12;\n127 |   const aggressivePaybackMonths = aggressiveMonthlySavings > 0\n128 |     ? Math.max(0.1, Math.round((initialInvestment / aggressiveMonthlySavings) * 10) / 10)\n129 |     : 0;\n130 | \n131 |   // 3. PRIORITIES METADATA\n132 |   const priorities = [\n133 |     {\n134 |       id: \"cost_reduction\" as Priority,\n135 |       title: \"Cost Elimination\",\n136 |       desc: \"Remove manual operational overhead & SaaS redundancies.\",\n137 |       color: \"#E4000F\",\n138 |       bgHex: \"rgba(228, 0, 15, 0.08)\"\n139 |     },\n140 |     {\n141 |       id: \"compliance_security\" as Priority,\n142 |       title: \"Sovereign Compliance\",\n143 |       desc: \"Deploy zero-retention private enclaves to remove legal friction.\",\n144 |       color: \"#9D00FF\",\n145 |       bgHex: \"rgba(157, 0, 255, 0.08)\"\n146 |     },\n147 |     {\n148 |       id: \"operational_speed\" as Priority,\n149 |       title: \"Latency Optimization\",\n150 |       desc: \"Accelerate task completion times from days to milliseconds.\",\n151 |       color: \"#009DFF\",\n152 |       bgHex: \"rgba(0, 157, 255, 0.08)\"\n153 |     },\n154 |     {\n155 |       id: \"customer_experience\" as Priority,\n156 |       title: \"Experience Transformation\",\n157 |       desc: \"Establish instantaneous, context-aware customer resolution pipelines.\",\n158 |       color: \"#00FF9D\",\n159 |       bgHex: \"rgba(0, 255, 157, 0.08)\"\n160 |     },\n161 |     {\n162 |       id: \"decision_automation\" as Priority,\n163 |       title: \"Cognitive Multiplier\",\n164 |       desc: \"Delegate complex analytical operations directly to secure agent networks.\",\n165 |       color: \"#FFBD00\",\n166 |       bgHex: \"rgba(255, 189, 0, 0.08)\"\n167 |     }\n168 |   ];\n169 | \n170 |   const currentPriorityObj = priorities.find(p => p.id === priority) || priorities[0];\n171 | \n172 |   // 4. HELPERS FOR INPUT SAFE VALIDATION & FORMATTING\n173 |   const handleBaselineChange = (val: string) => {\n174 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n175 |     const parsed = parseInt(cleaned) || 0;\n176 |     setAnnualCostBaseline(parsed);\n177 |   };\n178 | \n179 |   const handleVolumeChange = (val: string) => {\n180 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n181 |     const parsed = parseInt(cleaned) || 0;\n182 |     setProcessVolume(parsed);\n183 |   };\n184 | \n185 |   const handleHandlingTimeChange = (val: string) => {\n186 |     if (val === \"\") {\n187 |       setAvgHandlingTime(\"\");\n188 |       return;\n189 |     }\n190 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n191 |     const parsed = parseInt(cleaned) || 0;\n192 |     setAvgHandlingTime(parsed);\n193 |   };\n194 | \n195 |   const handleInvestmentChange = (val: string) => {\n196 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n197 |     const parsed = parseInt(cleaned) || 0;\n198 |     setInitialInvestment(parsed);\n199 |   };\n200 | \n201 |   const formatCompactCurrency = (num: number) => {\n202 |     if (num >= 1000000) return `$${(num / 1000000).toFixed(2)}M`;\n203 |     if (num >= 1000) return `$${(num / 1000).toFixed(0)}K`;\n204 |     return `$${num}`;\n205 |   };\n206 | \n207 |   const formatPayback = (months: number) => {\n208 |     if (months <= 0) return \"Instant Amortization\";\n209 |     if (months < 1) return \"Within 1 Month\";\n210 |     return `${months} Months`;\n211 |   };\n212 | \n213 |   // 5. COPY TO CLIPBOARD ACTION\n214 |   const handleCopyReport = () => {\n215 |     const indName = {\n216 |       financial_services: \"Financial Services\",\n217 |       healthcare: \"Healthcare & Life Sciences\",\n218 |       energy_utilities: \"Energy & Utilities\",\n219 |       telecommunications: \"Telecommunications\",\n220 |       public_sector: \"Public Sector & Government\",\n221 |       retail_logistics: \"Retail & Logistics\",\n222 |       technology_media: \"Technology & Media\"\n223 |     }[industry] || \"Enterprise\";\n224 | \n225 |     const sizeName = {\n226 |       smb: \"< 100 FTE\",\n227 |       mid: \"100 - 500 FTE\",\n228 |       enterprise: \"500 - 2,000 FTE\",\n229 |       large_enterprise: \"2,000 - 10,000 FTE\",\n230 |       global_corp: \"10,000+ FTE\"\n231 |     }[companySize] || \"Enterprise Scale\";\n232 | \n233 |     const funcName = {\n234 |       customer_operations: \"Customer Support & Operations\",\n235 |       legal_compliance: \"Legal, Risk & Compliance\",\n236 |       supply_chain: \"Supply Chain & Logistics\",\n237 |       finance_accounting: \"Finance, Audit & Accounting\",\n238 |       it_engineering: \"IT Service & Infrastructure\",\n239 |       hr_admin: \"People & Administrative Services\"\n240 |     }[opFunction] || \"Operations\";\n241 | \n242 |     const reportMd = `# GFF AI // ENTERPRISE SOVEREIGN ROI SIMULATION REPORT\n243 | Generated: ${new Date().toLocaleDateString()}\n244 | Status: MODELLED - ILLUSTRATIVE ONLY\n245 | \n246 | ## I. ORGANIZATIONAL CONTEXT & PROFILE\n247 | - Industry Sector: ${indName}\n248 | - Enterprise Scale: ${sizeName}\n249 | - Operational Function: ${funcName}\n250 | - Implementation Horizon: ${implementationHorizon.replace(\"_\", \" \")}\n251 | \n252 | ## II. FINANCIAL & OPERATIONAL BASELINE (INPUTS)\n253 | - Annual Operational Cost Baseline: $${annualCostBaseline.toLocaleString()}\n254 | - Current Manual Friction Index: ${manualEffort.toUpperCase()}\n255 | - Modelled Addressable Manual Overhead: $${addressableCostBaseline.toLocaleString()}\n256 | - Annual Process Volume: ${processVolume.toLocaleString()} units\n257 | - Average Handling Time: ${avgHandlingTime ? avgHandlingTime + \" Minutes\" : \"Not Specified (estimated based on sector average)\"}\n258 | - Estimated Loaded Hourly Rate: $${loadedHourlyRate}/hr\n259 | - Estimated Current Manual Effort: ${manualHoursSpent.toLocaleString()} hours/year\n260 | \n261 | ## III. TARGET SOVEREIGN PARAMETERS\n262 | - Automation Target Rate: ${automationTarget}%\n263 | - Expected Productivity Boost: ${productivityImprovement}%\n264 | - Enclave Platform Investment CapEx: $${initialInvestment.toLocaleString()}\n265 | - Strategic Priority Lens: ${currentPriorityObj.title} (${priority.toUpperCase()})\n266 | \n267 | ## IV. KEY RECOVERY METRICS (EXPECTED CASE)\n268 | - Illustrative Annual Reclaimed Value: $${expectedGrossSavings.toLocaleString()}\n269 | - Estimated Annual Productive Hours Saved: ${expectedHoursSaved.toLocaleString()} hours\n270 | - Amortization / Payback Period: ${formatPayback(expectedPaybackMonths)}\n271 | - Net Sovereign Return on Investment (ROI): ${expectedRoi}%\n272 | \n273 | ## V. SCENARIO COMPARISON MATRIX\n274 | - CONSERVATIVE CASE (Risk-Adjusted Execution):\n275 |   * Annual Saved Hours: ${conservativeHoursSaved.toLocaleString()} hrs\n276 |   * Annual Recouped Value: $${conservativeGrossSavings.toLocaleString()}\n277 |   * Amortization Payback: ${formatPayback(conservativePaybackMonths)}\n278 |   * Sovereign ROI: ${conservativeRoi}%\n279 | - EXPECTED CASE (Standard GFF Execution):\n280 |   * Annual Saved Hours: ${expectedHoursSaved.toLocaleString()} hrs\n281 |   * Annual Recouped Value: $${expectedGrossSavings.toLocaleString()}\n282 |   * Amortization Payback: ${formatPayback(expectedPaybackMonths)}\n283 |   * Sovereign ROI: ${expectedRoi}%\n284 | - AGGRESSIVE CASE (Synergistic Multiplier Execution):\n285 |   * Annual Saved Hours: ${aggressiveHoursSaved.toLocaleString()} hrs\n286 |   * Annual Recouped Value: $${aggressiveGrossSavings.toLocaleString()}\n287 |   * Amortization Payback: ${formatPayback(aggressivePaybackMonths)}\n288 |   * Sovereign ROI: ${aggressiveRoi}%\n289 | \n290 | ## VI. FINANCIAL WATERFALL SUMMARY\n291 | - Addressable Manual Friction Loss: $${addressableCostBaseline.toLocaleString()}/yr\n292 | - GFF Sovereign Reclaimed Value (Expected): -$${expectedGrossSavings.toLocaleString()}/yr\n293 | - Enclave CapEx Investment Allocation: +$${initialInvestment.toLocaleString()}\n294 | - Net Annual Sovereign Dividend: $${expectedNetSavings.toLocaleString()}/yr\n295 | \n296 | * DISCLAIMER: All figures are generated for strategic modeling and simulation purposes based on mathematical formulas and illustrative enterprise assumptions. They do not constitute binding financial, commercial, or operational guarantees.`;\n297 | \n298 |     navigator.clipboard.writeText(reportMd);\n299 |     setCopied(true);\n300 |     setTimeout(() => setCopied(false), 2000);\n301 |   };\n302 | \n303 |   // 6. RESET ACTION\n304 |   const handleReset = () => {\n305 |     setIndustry(\"financial_services\");\n306 |     setCompanySize(\"enterprise\");\n307 |     setOpFunction(\"customer_operations\");\n308 |     setAnnualCostBaseline(1500000);\n309 |     setProcessVolume(250000);\n310 |     setAvgHandlingTime(15);\n311 |     setAutomationTarget(65);\n312 |     setManualEffort(\"high\");\n313 |     setProductivityImprovement(50);\n314 |     setImplementationHorizon(\"6_months\");\n315 |     setPriority(\"cost_reduction\");\n316 |   };\n317 | \n318 |   // 7. GET STRATEGIC NARRATIVE\n319 |   const indName = {\n320 |     financial_services: \"Financial Services\",\n321 |     healthcare: \"Healthcare & Life Sciences\",\n322 |     energy_utilities: \"Energy & Utilities\",\n323 |     telecommunications: \"Telecommunications\",\n324 |     public_sector: \"Public Sector & Government\",\n325 |     retail_logistics: \"Retail & Logistics\",\n326 |     technology_media: \"Technology & Media\"\n327 |   }[industry] || \"Enterprise\";\n328 | \n329 |   const funcName = {\n330 |     customer_operations: \"Customer Support & Operations\",\n331 |     legal_compliance: \"Legal, Risk & Compliance\",\n332 |     supply_chain: \"Supply Chain & Logistics\",\n333 |     finance_accounting: \"Finance, Audit & Accounting\",\n334 |     it_engineering: \"IT Service & Infrastructure\",\n335 |     hr_admin: \"People & Administrative Services\"\n336 |   }[opFunction] || \"Operations\";\n337 | \n338 |   return (\n339 |     <ToolPageShell showContact={true}>\n340 |       <ToolHero\n341 |         category=\"FINANCIAL ENGINEERING CORE\"\n342 |         title=\"Sovereign ROI Calculator\"\n343 |         highlightedWord=\"ROI\"\n344 |         description=\"Quantify the fiscal impact, cognitive hours reclaimed, and capital amortization curves achieved by shifting legacy operational friction to GFF secure multi-agent systems.\"\n345 |         metricLabel=\"MODEL VERSION\"\n346 |         metricValue=\"V2.8-SOVEREIGN\"\n347 |       />\n348 | \n349 |       <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n350 |         {/* LEFT COLUMN: Input Control Panel */}\n351 |         <div className=\"lg:col-span-5 space-y-6\">\n352 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 backdrop-blur-md space-y-6 relative group overflow-hidden\">\n353 |             {/* Top accent line */}\n354 |             <div className=\"absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[#009DFF]/40 to-transparent pointer-events-none\" />\n355 |             \n356 |             <div className=\"border-b border-white/5 pb-3\">\n357 |               <span className=\"text-[10px] font-mono text-white/40 block uppercase tracking-wider\">VARIABLE CONTEXT PANEL</span>\n358 |               <h2 className=\"text-sm font-bold text-white mt-1\">Configure Model Inputs</h2>\n359 |             </div>\n360 | \n361 |             {/* SECTION 1: CORPORATE FOOTPRINT */}\n362 |             <div className=\"space-y-4 border-b border-white/5 pb-5\">\n363 |               <div className=\"flex items-center gap-2\">\n364 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">01</span>\n365 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Corporate Profile</span>\n366 |               </div>\n367 | \n368 |               {/* Industry Dropdown */}\n369 |               <div className=\"space-y-1.5\">\n370 |                 <div className=\"flex justify-between items-center\">\n371 |                   <label htmlFor=\"industry-select\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n372 |                     Industry Sector\n373 |                   </label>\n374 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Base Rate Calibration</span>\n375 |                 </div>\n376 |                 <select\n377 |                   id=\"industry-select\"\n378 |                   value={industry}\n379 |                   onChange={(e) => setIndustry(e.target.value)}\n380 |                   className=\"w-full h-9 bg-white/5 border border-white/10 rounded-lg px-2.5 text-xs text-white focus:outline-none focus:border-[#009DFF]/50 transition-colors cursor-pointer\"\n381 |                 >\n382 |                   <option value=\"financial_services\">Financial Services</option>\n383 |                   <option value=\"healthcare\">Healthcare & Life Sciences</option>\n384 |                   <option value=\"energy_utilities\">Energy & Utilities</option>\n385 |                   <option value=\"telecommunications\">Telecommunications</option>\n386 |                   <option value=\"public_sector\">Public Sector & Government</option>\n387 |                   <option value=\"retail_logistics\">Retail & Logistics</option>\n388 |                   <option value=\"technology_media\">Technology & Media</option>\n389 |                 </select>\n390 |               </div>\n391 | \n392 |               {/* Enterprise Scale (Company Size) */}\n393 |               <div className=\"space-y-1.5\">\n394 |                 <div className=\"flex justify-between items-center\">\n395 |                   <label className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider\">\n396 |                     Enterprise Scale\n397 |                   </label>\n398 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Determines Setup CapEx</span>\n399 |                 </div>\n400 |                 <div className=\"grid grid-cols-5 gap-1\">\n401 |                   {[\n402 |                     { id: \"smb\", label: \"<100\", title: \"SMB (<100 FTE)\" },\n403 |                     { id: \"mid\", label: \"100-500\", title: \"Mid-Market (100-500 FTE)\" },\n404 |                     { id: \"enterprise\", label: \"500-2K\", title: \"Enterprise (500-2,000 FTE)\" },\n405 |                     { id: \"large_enterprise\", label: \"2K-10K\", title: \"Large Enterprise (2,000-10,000 FTE)\" },\n406 |                     { id: \"global_corp\", label: \"10K+\", title: \"Global Corporation (10,000+ FTE)\" }\n407 |                   ].map((item) => (\n408 |                     <button\n409 |                       key={item.id}\n410 |                       type=\"button\"\n411 |                       onClick={() => setCompanySize(item.id)}\n412 |                       className={`h-8 rounded text-[9px] font-semibold transition-all border ${\n413 |                         companySize === item.id\n414 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n415 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n416 |                       }`}\n417 |                       title={item.title}\n418 |                     >\n419 |                       {item.label}\n420 |                     </button>\n421 |                   ))}\n422 |                 </div>\n423 |               </div>\n424 | \n425 |               {/* Operational Function */}\n426 |               <div className=\"space-y-1.5\">\n427 |                 <div className=\"flex justify-between items-center\">\n428 |                   <label htmlFor=\"function-select\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n429 |                     Operational Function\n430 |                   </label>\n431 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Labor Complexity Factor</span>\n432 |                 </div>\n433 |                 <select\n434 |                   id=\"function-select\"\n435 |                   value={opFunction}\n436 |                   onChange={(e) => setOpFunction(e.target.value)}\n437 |                   className=\"w-full h-9 bg-white/5 border border-white/10 rounded-lg px-2.5 text-xs text-white focus:outline-none focus:border-[#009DFF]/50 transition-colors cursor-pointer\"\n438 |                 >\n439 |                   <option value=\"customer_operations\">Customer Support & Operations</option>\n440 |                   <option value=\"legal_compliance\">Legal, Risk & Compliance</option>\n441 |                   <option value=\"supply_chain\">Supply Chain & Logistics</option>\n442 |                   <option value=\"finance_accounting\">Finance, Audit & Accounting</option>\n443 |                   <option value=\"it_engineering\">IT Service & Infrastructure</option>\n444 |                   <option value=\"hr_admin\">People & Administrative Services</option>\n445 |                 </select>\n446 |               </div>\n447 |             </div>\n448 | \n449 |             {/* SECTION 2: CURRENT WORKLOAD & COSTS */}\n450 |             <div className=\"space-y-4 border-b border-white/5 pb-5\">\n451 |               <div className=\"flex items-center gap-2\">\n452 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">02</span>\n453 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Friction & Baseline</span>\n454 |               </div>\n455 | \n456 |               {/* Annual Cost Baseline */}\n457 |               <div className=\"space-y-2\">\n458 |                 <div className=\"flex justify-between items-center\">\n459 |                   <label htmlFor=\"cost-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n460 |                     Annual Cost Baseline\n461 |                   </label>\n462 |                   <div className=\"flex items-center gap-1.5\">\n463 |                     <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n464 |                     <input\n465 |                       id=\"cost-input\"\n466 |                       type=\"text\"\n467 |                       value={annualCostBaseline === 0 ? \"\" : annualCostBaseline.toLocaleString()}\n468 |                       onChange={(e) => handleBaselineChange(e.target.value)}\n469 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n470 |                     />\n471 |                   </div>\n472 |                 </div>\n473 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n474 |                   Annual expenses of targeted operational unit (labor + software tools).\n475 |                 </p>\n476 |                 <input\n477 |                   id=\"cost-slider\"\n478 |                   aria-label=\"Annual Cost Baseline range slider\"\n479 |                   type=\"range\"\n480 |                   min=\"50000\"\n481 |                   max=\"25000000\"\n482 |                   step=\"50000\"\n483 |                   value={annualCostBaseline}\n484 |                   onChange={(e) => setAnnualCostBaseline(parseInt(e.target.value))}\n485 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n486 |                 />\n487 |               </div>\n488 | \n489 |               {/* Process Volume */}\n490 |               <div className=\"space-y-2\">\n491 |                 <div className=\"flex justify-between items-center\">\n492 |                   <label htmlFor=\"volume-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n493 |                     Annual Process Volume\n494 |                   </label>\n495 |                   <div className=\"flex items-center gap-1.5\">\n496 |                     <input\n497 |                       id=\"volume-input\"\n498 |                       type=\"text\"\n499 |                       value={processVolume === 0 ? \"\" : processVolume.toLocaleString()}\n500 |                       onChange={(e) => handleVolumeChange(e.target.value)}\n501 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n502 |                     />\n503 |                   </div>\n504 |                 </div>\n505 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n506 |                   Annual requests, transactions, or tasks processed in this department.\n507 |                 </p>\n508 |                 <input\n509 |                   id=\"volume-slider\"\n510 |                   aria-label=\"Annual Process Volume range slider\"\n511 |                   type=\"range\"\n512 |                   min=\"1000\"\n513 |                   max=\"5000000\"\n514 |                   step=\"1000\"\n515 |                   value={processVolume}\n516 |                   onChange={(e) => setProcessVolume(parseInt(e.target.value))}\n517 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n518 |                 />\n519 |               </div>\n520 | \n521 |               {/* Average Handling Time */}\n522 |               <div className=\"space-y-2\">\n523 |                 <div className=\"flex justify-between items-center\">\n524 |                   <label htmlFor=\"aht-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n525 |                     Avg Handling Time (Mins)\n526 |                   </label>\n527 |                   <div className=\"flex items-center gap-2\">\n528 |                     <input\n529 |                       id=\"aht-input\"\n530 |                       type=\"text\"\n531 |                       placeholder=\"Sector Avg\"\n532 |                       value={avgHandlingTime}\n533 |                       onChange={(e) => handleHandlingTimeChange(e.target.value)}\n534 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50 placeholder:text-white/20\"\n535 |                     />\n536 |                     <span className=\"text-[8px] font-mono text-white/30\">MIN</span>\n537 |                   </div>\n538 |                 </div>\n539 |                 <p clas