({ success: false, error: \"Bad Request\", message: \"Invalid client_id specified.\" }, { status: 400 });\n          }\n          op.client_id = body.client_id;\n          op.client_name = getClientNameFromId(body.client_id);\n        } else {\n          (op as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n        }\n      }\n    }\n    op.lastUpdated = new Date().toISOString();\n    (API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id] = op;\n    return NextResponse.json({ success: true, operation: op });\n  } catch (err) {\n    return NextResponse.json(\n      { success: false, error: \"Internal Server Error\", message: \"An unexpected error occurred.\" }, \n      { status: 500 }\n    );\n  }\n}\n\nexport async function DELETE(req: Request, { params }: { params: any }) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) {\n      return NextResponse.json(\n        { success: false, error: auth.error, message: auth.msg }, \n        { status: auth.status }\n      );\n    }\n    const { caller } = auth;\n    if (caller.role !== \"gff_admin\") {\n      return NextResponse.json(\n        { success: false, error: \"Forbidden\", message: \"Only administrators can delete AI operations.\" }, \n        { status: 403 }\n      );\n    }\n    \n    const { id } = await params;\n    if (!(API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id]) {\n      return NextResponse.json({ success: false, error: \"Not Found\", message: \"AI operation not found.\" }, { status: 404 });\n    }\n    delete (API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id];\n    return NextResponse.json({ success: true, message: \"AI Operation deleted.\" });\n  } catch (err) {\n    return NextResponse.json(\n      { success: false, error: \"Internal Server Error\", message: \"An unexpected error occurred.\" }, \n      { status: 500 }\n    );\n  }\n}"}}}
