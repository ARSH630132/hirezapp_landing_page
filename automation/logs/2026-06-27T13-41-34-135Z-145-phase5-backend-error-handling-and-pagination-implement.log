{"ts":"2026-06-27T13:34:22.162Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"5ur9h1w3","output":[{"query":"backend/app/api/deps.py","result":"  1 | from typing import Generator, Optional, List\n  2 | from fastapi import Depends, HTTPException, status, Request\n  3 | from fastapi.security import OAuth2PasswordBearer\n  4 | from sqlalchemy.orm import Session\n  5 | \n  6 | from ..core.config import settings\n  7 | from ..core.security import decode_access_token\n  8 | from ..core.rbac import UserRole, PermissionGroup, ROLE_PERMISSIONS\n  9 | from ..db.session import get_db\n 10 | from ..models.user import User\n 11 | \n 12 | reusable_oauth2 = OAuth2PasswordBearer(\n 13 |     tokenUrl=f\"{settings.API_V1_STR}/auth/login\"\n 14 | )\n 15 | \n 16 | def get_current_user(\n 17 |     db: Session = Depends(get_db),\n 18 |     token: str = Depends(reusable_oauth2)\n 19 | ) -> User:\n 20 |     \"\"\"\n 21 |     Dependency to validate token and return the current active user.\n 22 |     \"\"\"\n 23 |     credentials_exception = HTTPException(\n 24 |         status_code=status.HTTP_401_UNAUTHORIZED,\n 25 |         detail=\"Could not validate credentials\",\n 26 |         headers={\"WWW-Authenticate\": \"Bearer\"},\n 27 |     )\n 28 |     \n 29 |     email = decode_access_token(token)\n 30 |     if email is None:\n 31 |         raise credentials_exception\n 32 |         \n 33 |     user = db.query(User).filter(User.email == email).first()\n 34 |     if user is None:\n 35 |         raise credentials_exception\n 36 |         \n 37 |     if not user.is_active:\n 38 |         raise HTTPException(\n 39 |             status_code=status.HTTP_400_BAD_REQUEST,\n 40 |             detail=\"Inactive user account\"\n 41 |         )\n 42 |         \n 43 |     return user\n 44 | \n 45 | def get_current_active_admin(\n 46 |     current_user: User = Depends(get_current_user),\n 47 | ) -> User:\n 48 |     \"\"\"\n 49 |     Dependency to validate that the active user is an admin.\n 50 |     \"\"\"\n 51 |     if current_user.role not in [\"admin\", \"gff_admin\"]:\n 52 |         raise HTTPException(\n 53 |             status_code=status.HTTP_403_FORBIDDEN,\n 54 |             detail=\"The user does not have enough privileges\"\n 55 |         )\n 56 |     return current_user\n 57 | \n 58 | def require_roles(allowed_roles: List[str]):\n 59 |     \"\"\"\n 60 |     FastAPI dependency that restricts route access to specific roles.\n 61 |     Accepts both strings and UserRole enums.\n 62 |     \"\"\"\n 63 |     normalized_roles = [r.value if hasattr(r, \"value\") else str(r) for r in allowed_roles]\n 64 |     def dependency(current_user: User = Depends(get_current_user)) -> User:\n 65 |         if current_user.role not in normalized_roles:\n 66 |             raise HTTPException(\n 67 |                 status_code=status.HTTP_403_FORBIDDEN,\n 68 |                 detail=\"Operation not permitted. Insufficient role privileges.\"\n 69 |             )\n 70 |         return current_user\n 71 |     return dependency\n 72 | \n 73 | def require_admin(current_user: User = Depends(get_current_user)) -> User:\n 74 |     \"\"\"\n 75 |     FastAPI dependency that restricts route access to GFF admins (or legacy admins).\n 76 |     \"\"\"\n 77 |     if current_user.role not in [\"gff_admin\", \"admin\"]:\n 78 |         raise HTTPException(\n 79 |             status_code=status.HTTP_403_FORBIDDEN,\n 80 |             detail=\"Operation not permitted. Administrative privileges required.\"\n 81 |         )\n 82 |     return current_user\n 83 | \n 84 | def require_client_access(\n 85 |     request: Request,\n 86 |     current_user: User = Depends(get_current_user)\n 87 | ) -> User:\n 88 |     \"\"\"\n 89 |     FastAPI dependency that enforces that the user has access to a requested client_id.\n 90 |     It automatically inspects path_params or query_params for client_id.\n 91 |     GFF admin is granted access automatically.\n 92 |     Client users must match the requested client_id.\n 93 |     \"\"\"\n 94 |     client_id_str = request.path_params.get(\"client_id\") or request.query_params.get(\"client_id\")\n 95 |     \n 96 |     # GFF admins have access to all clients\n 97 |     if current_user.role in [\"gff_admin\", \"admin\"]:\n 98 |         return current_user\n 99 | \n100 |     if client_id_str is None:\n101 |         # If client_id is not specified, default to checking if the user has any assigned client_id\n102 |         if current_user.client_id is None:\n103 |             raise HTTPException(\n104 |                 status_code=status.HTTP_403_FORBIDDEN,\n105 |                 detail=\"Operation not permitted. User does not belong to any client.\"\n106 |             )\n107 |         return current_user\n108 | \n109 |     try:\n110 |         client_id = int(client_id_str)\n111 |     except ValueError:\n112 |         raise HTTPException(\n113 |             status_code=status.HTTP_400_BAD_REQUEST,\n114 |             detail=\"Invalid client_id format.\"\n115 |         )\n116 | \n117 |     if current_user.client_id != client_id:\n118 |         raise HTTPException(\n119 |             status_code=status.HTTP_403_FORBIDDEN,\n120 |             detail=\"Operation not permitted. Access to this client's data is denied.\"\n121 |         )\n122 | \n123 |     return current_user\n124 | \n125 | def require_same_client_or_admin(\n126 |     request: Request,\n127 |     current_user: User = Depends(get_current_user)\n128 | ) -> User:\n129 |     \"\"\"\n130 |     Dependency that enforces that the user belongs to the same client_id\n131 |     as the one provided in the request (path or query params), OR is a GFF admin.\n132 |     \"\"\"\n133 |     client_id_str = request.path_params.get(\"client_id\") or request.query_params.get(\"client_id\")\n134 |     \n135 |     # GFF Admin can bypass\n136 |     if current_user.role in [\"gff_admin\", \"admin\"]:\n137 |         return current_user\n138 |    