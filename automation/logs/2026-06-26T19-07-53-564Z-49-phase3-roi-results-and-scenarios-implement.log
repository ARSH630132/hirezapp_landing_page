etPriority(item.id)}\n                      type=\"button\"\n                      className={`text-left p-2.5 rounded-lg border transition-all text-xs flex items-start gap-3 ${\n                        isActive\n                          ? \"bg-white/[0.03] border-white/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]\"\n                          : \"bg-transparent border-white/5 hover:border-white/10 hover:bg-white/[0.01]\"\n                      }`}\n                    >\n                      <div\n                        className=\"w-2 h-2 rounded-full shrink-0 mt-1\"\n                        style={{ backgroundColor: item.color }}\n                      />\n                      <div>\n                        <span className={`font-semibold block text-[11px] ${isActive ? \"text-white\" : \"text-white/70\"}`}>\n                          {item.title}\n                        </span>\n                        <span className=\"text-[9px] text-white/40 block leading-tight font-light mt-0.5\">\n                          {item.desc}\n                        </span>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n            </div>"}}}
