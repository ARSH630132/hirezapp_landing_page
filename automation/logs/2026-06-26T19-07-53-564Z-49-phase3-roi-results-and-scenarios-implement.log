{"ts":"2026-06-26T19:05:15.676Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"0hsu07xi","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/roi/page.tsx","old_text":"          {/* WATERFALL_CHART_PLACEHOLDER */}","new_text":"          {/* Section C: Pure CSS/SVG Waterfall-Style Value Breakdown Chart */}\n          <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 relative\">\n            <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/20 to-transparent\" />\n            \n            <div className=\"flex justify-between items-baseline border-b border-white/5 pb-4 mb-6\">\n              <div>\n                <span className=\"text-[9px] font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">VALUE CONSTRUCT MATRIX</span>\n                <h3 className=\"text-sm font-bold text-white mt-1\">Sovereign Financial Value Waterfall Chart</h3>\n              </div>\n              <span className=\"text-[9px] font-mono text-white/30 hidden md:inline\">UNIT: USD ($) // ANNUALIZED STACK MODEL</span>\n            </div>\n\n            {/* Waterfall SVG Chart */}\n            <div className=\"w-full\">\n              <svg viewBox=\"0 0 720 230\" className=\"w-full h-auto overflow-visible select-none\" fill=\"none\">\n                {/* Background Grid Lines */}\n                <line x1=\"30\" y1=\"20\" x2=\"690\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n                <line x1=\"30\" y1=\"70\" x2=\"690\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n                <line x1=\"30\" y1=\"120\" x2=\"690\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n                <line x1=\"30\" y1=\"170\" x2=\"690\" y2=\"170\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n                <line x1=\"30\" y1=\"200\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n\n                {/* Left/Right Borders for design */}\n                <line x1=\"30\" y1=\"20\" x2=\"30\" y2=\"200\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"1\" />\n                <line x1=\"690\" y1=\"20\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"1\" />\n\n                {/* Coordinate Math & Computations\n                    Bar 1: Operational Loss (starting point, represented as a positive overhead total cost)\n                    Bar 2: Reclaimed Savings (deducted from starting point)\n                    Bar 3: GFF Allocation (CapEx setup cost, added back)\n                    Bar 4: Net Dividends (outcome total, expectedGrossSavings - initialInvestment)\n                */}\n                {(() => {\n                  const maxAmt = Math.max(totalWastedCostPerYear, expectedGrossSavings, initialInvestment, expectedNetSavings, 1);\n                  \n                  // Scale helper: maps dollar amount to Y-coordinate within [20, 180] boundary\n                  const getY = (val: number) => {\n                    const pct = val / maxAmt;\n                    return 200 - pct * 160;\n                  };\n\n                  const getH = (val: number) => {\n                    return (val / maxAmt) * 160;\n                  };\n\n                  // Bar 1 values\n                  const b1Y = getY(totalWastedCostPerYear);\n                  const b1H = getH(totalWastedCostPerYear);\n\n                  // Bar 2 values (floating from top of Bar 1 downwards)\n                  const b2H = getH(expectedGrossSavings);\n                  const b2Y = b1Y; // starts from the top of Bar 1\n\n                  // Bar 3 values (floating slightly upwards from the bottom of Bar 2)\n                  const b3H = getH(initialInvestment);\n                  const b3Y = b2Y + b2H - b3H; // bottom of bar 2, offset upwards\n\n                  // Bar 4 values (grounded outcome bar)\n                  const b4Y = getY(expectedNetSavings);\n                  const b4H = getH(expectedNetSavings);\n\n                  return (\n                    <>\n                      {/* Dotted Connecting Flow Lines */}\n                      <line x1=\"120\" y1={b1Y} x2=\"210\" y2={b2Y} stroke=\"rgba(255, 255, 255, 0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n                      <line x1=\"290\" y1={b2Y + b2H} x2=\"380\" y2={b3Y + b3H} stroke=\"rgba(255, 255, 255, 0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n                      <line x1=\"460\" y1={b3Y} x2=\"550\" y2={b4Y} stroke=\"rgba(255, 255, 255, 0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n\n                      {/* Bar 1: Friction Overhead */}\n                      <g className=\"transition-all duration-300\">\n                        <rect x=\"50\" y={b1Y} width=\"70\" height={b1H} rx=\"3\" fill=\"url(#frictionGradient)\" stroke=\"rgba(255,255,255,0.05)\" />\n                        <text x=\"85\" y={Math.max(b1Y - 8, 15)} textAnchor=\"middle\" className=\"fill-white/80 font-mono text-[10px] font-bold\">\n                          {formatCompactCurrency(totalWastedCostPerYear)}\n                        </text>\n                      </g>\n\n                      {/* Bar 2: Autonomous Reclaim */}\n                      <g className=\"transition-all duration-300\">\n                        <rect x=\"220\" y={b2Y} width=\"70\" height={b2H} rx=\"3\" fill=\"url(#reclaimedGradient)\" stroke=\"rgba(0, 255, 157, 0.15)\" />\n                        <text x=\"255\" y={Math.max(b2Y - 8, 15)} textAnchor=\"middle\" className=\"fill-[#00FF9D] font-mono text-[10px] font-bold\">\n                          -{formatCompactCurrency(expectedGrossSavings)}\n                        </text>\n                      </g>\n\n                      {/* Bar 3: CapEx Investment */}\n                      <g className=\"transition-all duration-300\">\n                        <rect x=\"390\" y={b3Y} width=\"70\" height={b3H} rx=\"3\" fill=\"url(#capexGradient)\" stroke=\"rgba(228, 0, 15, 0.15)\" />\n                        <text x=\"425\" y={Math.max(b3Y - 8, 15)} textAnchor=\"middle\" className=\"fill-[#E4000F] font-mono text-[10px] font-bold\">\n                          +{formatCompactCurrency(initialInvestment)}\n                        </text>\n                      </g>\n\n                      {/* Bar 4: Net Dividends */}\n                      <g className=\"transition-all duration-300\">\n                        <rect x=\"560\" y={b4Y} width=\"70\" height={b4H} rx=\"3\" fill=\"url(#netGradient)\" stroke=\"rgba(0, 255, 157, 0.3)\" />\n                        <text x=\"595\" y={Math.max(b4Y - 8, 15)} textAnchor=\"middle\" className=\"fill-white font-mono text-[11px] font-extrabold\">\n                          {formatCompactCurrency(expectedNetSavings)}\n                        </text>\n                      </g>\n                    </>\n                  );\n                })()}\n\n                {/* Gradients declarations */}\n                <defs>\n                  <linearGradient id=\"frictionGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor=\"#ffffff\" stopOpacity=\"0.2\" />\n                    <stop offset=\"100%\" stopColor=\"#ffffff\" stopOpacity=\"0.03\" />\n                  </linearGradient>\n                  <linearGradient id=\"reclaimedGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.3\" />\n                    <stop offset=\"100%\" stopColor=\"#00FF9D\" stopOpacity=\"0.05\" />\n                  </linearGradient>\n                  <linearGradient id=\"capexGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor=\"#E4000F\" stopOpacity=\"0.3\" />\n                    <stop offset=\"100%\" stopColor=\"#E4000F\" stopOpacity=\"0.05\" />\n                  </linearGradient>\n                  <linearGradient id=\"netGradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.55\" />\n                    <stop offset=\"50%\" stopColor=\"#009DFF\" stopOpacity=\"0.3\" />\n                    <stop offset=\"100%\" stopColor=\"#000000\" stopOpacity=\"0\" />\n                  </linearGradient>\n                </defs>\n              </svg>\n\n              {/* Labels below chart columns */}\n              <div className=\"grid grid-cols-4 gap-2 pt-3 font-mono text-[9px] uppercase tracking-wider text-white/50 text-center select-none border-t border-white/[0.03] mt-2\">\n                <div>01. Operational Friction</div>\n                <div>02. GFF Optimization</div>\n                <div>03. Setup Expense</div>\n                <div className=\"text-white font-bold\">04. Sovereign Dividend</div>\n              </div>\n            </div>\n\n            <p className=\"text-[9px] text-white/30 font-light italic mt-4 text-center\">\n              * Modeled values are annualized estimates. All metrics are illustrative based on mathematical models and not performance guarantees.\n            </p>\n          </div>\n\n          {/* SCENARIO_COMPARISON_PLACEHOLDER */}"}}}
