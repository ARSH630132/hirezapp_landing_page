ntly.\"\n124 |     },\n125 |     {\n126 |       label: \"Multi-Agent Fleet Strategy\",\n127 |       score: fleetStrategy,\n128 |       description: fleetStrategy >= 4 ? \"Orchestrated DAG topology active\" : \"Ad-hoc task execution\",\n129 |       recommendation:\n130 |         fleetStrategy >= 4\n131 |           ? \"Scale to cross-department supervisor nodes.\"\n132 |           : \"Model multi-agent hierarchies using GFF Foundry Studio DAG designers.\"\n133 |     }\n134 |   ];\n135 | \n136 |   return {\n137 |     score,\n138 |     level,\n139 |     color,\n140 |     description,\n141 |     dimensionScores,\n142 |     strategicPriority:\n143 |       score >= 80\n144 |         ? \"Hardened production deployment & scale\"\n145 |         : score >= 55\n146 |         ? \"Isolation architecture validation\"\n147 |         : \"VPC topology design & basic sandboxing\",\n148 |     securityClearance: score >= 80 ? \"Sovereign Level 3\" : score >= 55 ? \"Strategic Level 2\" : \"Sandbox Level 1\"\n149 |   };\n150 | }\n151 | \n152 | export function calculateROIEstimate(inputs: ROIInputs): ROIResult {\n153 |   const { teamSize, avgHourlyRate, inefficientHoursPerWeek, initialInvestment, priority } = inputs;\n154 | \n155 |   const annualHoursSaved = Math.round(teamSize * inefficientHoursPerWeek * 52 * 0.85);\n156 |   const grossSavings = annualHoursSaved * avgHourlyRate;\n157 |   const netSavings = Math.max(0, grossSavings - initialInvestment);\n158 |   const roiPercentage = initialInvestment > 0 ? Math.round((netSavings / initialInvestment) * 100) : 0;\n159 | \n160 |   const monthlySavings = grossSavings / 12;\n161 |   const paybackMonths = monthlySavings > 0 ? Math.max(1, Math.round((initialInvestment / monthlySavings) * 10) / 10) : 12;\n162 | \n163 |   let computeCostPct = 15;\n164 |   let complianceCostPct = 20;\n165 | \n166 |   if (priority === \"compliance_security\") {\n167 |     complianceCostPct = 40;\n168 |     computeCostPct = 10;\n169 |   } else if (priority === \"cost_reduction\") {\n170 |     complianceCostPct = 15;\n171 |     computeCostPct = 25;\n172 |   } else if (priority === \"operational_speed\") {\n173 |     computeCostPct = 30;\n174 |   }\n175 | \n176 |   const laborSavedPct = 100 - (computeCostPct + complianceCostPct);\n177 | \n178 |   const costAllocations = [\n179 |     {\n180 |       label: \"Compute Node Infrastructure\",\n181 |       percentage: computeCostPct,\n182 |       amount: Math.round((initialInvestment * computeCostPct) / 100),\n183 |       color: \"#009DFF\"\n184 |     },\n185 |     {\n186 |       label: \"Sovereign Audit Pipelines\",\n187 |       percentage: complianceCostPct,\n188 |       amount: Math.round((initialInvestment * complianceCostPct) / 100),\n189 |       color: \"#E4000F\"\n190 |     },\n191 |     {\n192 |       label: \"Workforce Amplification Layer\",\n193 |       percentage: laborSavedPct,\n194 |       amount: Math.round((initialInvestment * laborSavedPct) / 100),\n195 |       color: \"#00FF9D\"\n196 |     }\n197 |   ];\n198 | \n199 |   let efficiencyMultiplier = \"1.8x Speedup\";\n200 |   if (teamSize > 500) efficiencyMultiplier = \"3.2x Scale\";\n201 |   else if (teamSize > 100) efficiencyMultiplier = \"2.4x Speedup\";\n202 | \n203 |   return {\n204 |     annualHoursSaved,\n205 |     grossSavings,\n206 |     netSavings,\n207 |     roiPercentage,\n208 |     paybackMonths,\n209 |     costAllocations,\n210 |     efficiencyMultiplier\n211 |   };\n212 | }\n213 | \n214 | \n215 | export function generateProposalBlueprint(inputs: ProposalInputs): ProposalResult {\n216 |   const { companyName, industry, companySize, dataReadiness, priorities } = inputs;\n217 | \n218 |   const resolvedName = companyName.trim() || \"Enterprise Client\";\n219 | \n220 |   let baseWeeks = 12;\n221 |   if (companySize === \"small\") baseWeeks = 6;\n222 |   else if (companySize === \"medium\") baseWeeks = 8;\n223 |   else if (companySize === \"global-conglomerate\") baseWeeks = 16;\n224 | \n225 |   if (dataReadiness === \"raw\") baseWeeks += 3;\n226 |   else if (dataReadiness === \"vectorized\") baseWeeks -= 2;\n227 |   else if (dataReadiness === \"fully-governed\") baseWeeks -= 3;\n228 | \n229 |   const implementationWeeks = Math.max(4, baseWeeks);\n230 | \n231 |   const p1 = Math.max(1, Math.round(implementationWeeks * 0.15));\n232 |   const p2 = Math.max(1, Math.round(implementationWeeks * 0.25));\n233 |   const p3 = Math.max(1, Math.round(implementationWeeks * 0.40));\n234 |   const p4 = implementationWeeks - (p1 + p2 + p3);\n235 | \n236 |   const architecturePhases = [\n237 |     {\n238 |       name: \"Phase 1: Local Enclave Discovery & Topology Layout\",\n239 |       weeks: p1,\n240 |       objectives: [\n241 |         `Audit legacy data endpoints for ${industry} compliance.`,\n242 |         \"Establish single-tenant secure networking perimeter within GFF virtual enclaves.\",\n243 |         \"Assess relational schemas for real-time vector capability.\"\n244 |       ],\n245 |       deliverables: [\"Isolated VPC configuration manifest\", \"Static DAG reference topology layout\"]\n246 |     },\n247 |     {\n248 |       name: \"Phase 2: OmniMesh Integration & Vector Pipeline Setup\",\n249 |       weeks: p2,\n250 |       objectives: [\n251 |         `Connect GFF OmniMesh drivers to source infrastructure.`,\n252 |         \"Initialize zero-retention embeddings stream with local token isolation.\",\n253 |         \"Perform initial policy scan checks on simulated transaction records.\"\n254 |       ],\n255 |       deliverables: [\"Unified Vector mesh connection keys\", \"Encryption policy baseline document\"]\n256 |     },\n257 |     {\n258 |       name: \"Phase 3: Multi-Agent Topology Compilation & Validation\",\n259 |       weeks: p3,\n260 |       objectives: [\n261 |         \"Synthesize custom supervisor nodes mapped to departmental rules.\",\n262 |         \"Execute high-throughput benchmark runs (up to 5,000 simulated tx/min).\",\n263 |         \"Verify consensus validation protocols on edge nodes.\"\n264 |       ],\n265 |       deliverables: [\"Active GFF Foundry DAG blueprint file\", \"Consensus telemetry logs\"]\n266 |     },\n267 |     {\n268 |       name: \"Phase 4: Sovereign Sandbox Promotion & Production Handoff\",\n269 |       weeks: p4,\n270 |       objectives: [\n271 |         \"Deploy governance guardrails for persistent autonomous runs.\",\n272 |         \"Hand over local administration keys to the primary security team.\",\n273 |         \"Schedule regular performance drift updates.\"\n274 |       ],\n275 |       deliverables: [\"Sovereign execution node license token\", \"Technical transition guide\"]\n276 |     }\n277 |   ];\n278 | \n279 |   const recommendedAgentTopologies = MOCK_MARKETPLACE_AGENTS.filter(\n280 |     (agent) => agent.compatibility.includes(industry) || priorities.some((p) => agent.badge?.toLowerCase().includes(p.replace(\"_\", \"\")))\n281 |   ).map((agent) => ({\n282 |     name: agent.name,\n283 |     role: agent.category,\n284 |     latency: agent.category === \"CONNECTOR\" ? \"< 2ms\" : \"< 150ms\",\n285 |     governanceMode: \"Decentralized consensus validation\"\n286 |   }));\n287 | \n288 |   if (recommendedAgentTopologies.length === 0) {\n289 |     recommendedAgentTopologies.push({\n290 |       name: \"GFF Policy Watchdog\",\n291 |       role: \"SUPERVISOR\",\n292 |       latency: \"< 100ms\",\n293 |       governanceMode: \"Strict sovereign compliance scanning\"\n294 |     });\n295 |   }\n296 | \n297 |   let licenseCost = \"$45,000 / Year\";\n298 |   if (companySize === \"global-conglomerate\") licenseCost = \"Custom Enterprise Tier\";\n299 |   else if (companySize === \"small\") licenseCost = \"$15,000 / Year\";\n300 | \n301 |   const exportOutline = [\n302 |     \"I. EXECUTIVE SUMMARY - THE GFF ARCHITECTURE PROPOSAL\",\n303 |     \"II. CLIENT ENVIRONMENT STATUS & READINESS METRICS\",\n304 |     `III. THE CUSTOM \"${resolvedName.toUpperCase()}\" AGENT TOPOLOGY`,\n305 |     \"IV. SECURITY AND COMPLIANCE BASELINE - ZERO LANDING RETENTION POLICY\",\n306 |     `V. DETAILED ${implementationWeeks}-WEEK DEPLOYMENT TIMELINE`,\n307 |     \"VI. ESTIMATED COMMERCIAL STRUCTURE AND LICENSING SCHEME\"\n308 |   ];\n309 | \n310 |   return {\n311 |     projectName: `GFF Sovereign Agent Topology - ${industry.toUpperCase()} STACK`,\n312 |     implementationWeeks,\n313 |     architecturePhases,\n314 |     recommendedAgentTopologies,\n315 |     estimatedLicenseCost: licenseCost,\n316 |     exportOutline\n317 |   };\n318 | }\n319 | \n320 | export function filterMarketplaceAgents(industry: Industry, search?: string): MarketplaceAgent[] {\n321 |   let list = MOCK_MARKETPLACE_AGENTS;\n322 | \n323 |   if (search) {\n324 |     const s = search.toLowerCase();\n325 |     list = list.filter((a) => a.name.toLowerCase().includes(s) || a.description.toLowerCase().includes(s));\n326 |   }\n327 | \n328 |   return [...list].sort((a, b) => {\n329 |     const aCompat = a.compatibility.includes(industry) ? 1 : 0;\n330 |     const bCompat = b.compatibility.includes(industry) ? 1 : 0;\n331 |     return bCompat - aCompat;\n332 |   });\n333 | }\n334 | \n335 | export function getInitialSandboxAgent(): SandboxAgent {\n336 |   return {\n337 |     id: \"sandbox-run-active\",\n338 |     name: \"Sovereign Audit Sandbox Node\",\n339 |     role: \"AUDITOR\",\n340 |     status: \"idle\",\n341 |     latency: \"0 ms\",\n342 |     successRate: \"100%\",\n343 |     steps: [\n344 |       { label: \"Initialize Virtual Hardware Enclave\", status: \"pending\", detail: \"Spawning local sandboxed environment.\" },\n345 |       { label: \"Load Zero-Retention Encryption Rules\", status: \"pending\", detail: \"Injecting temporary security rules.\" },\n346 |       { label: \"Ingest Mock Ledgers & Transactions\", status: \"pending\", detail: \"Streaming deterministic sandbox inputs.\" },\n347 |       { label: \"Verify Integrity via Consensus Signatures\", status: \"pending\", detail: \"Running cryptographic integrity checks.\" },\n348 |       { label: \"Excrete Compiled Simulation Reports\", status: \"pending\", detail: \"Generating trace logs for performance audit.\" }\n349 |     ]\n350 |   };\n351 | }\n352 | ","success":true}],"durationMs":3}}
