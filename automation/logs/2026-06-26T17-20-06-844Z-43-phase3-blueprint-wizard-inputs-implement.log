tCompilingStep((prev) => {\n        if (prev < compilingMessages.length - 1) {\n          return prev + 1;\n        } else {\n          clearInterval(interval);\n          setIsCompiling(false);\n          setReportGenerated(true);\n          setStep(7);\n          return prev;\n        }\n      });\n    }, 600);\n    return () => clearInterval(interval);\n  }, [isCompiling]);\n\n  const handlePriorityToggle = (val: string) => {\n    setError(\"\");\n    const current = [...answers.topPriorities];\n    if (current.includes(val)) {\n      setAnswers({ ...answers, topPriorities: current.filter((x) => x !== val) });\n    } else {\n      if (current.length >= 3) {\n        setError(\"You can select up to 3 strategic priorities.\");\n        return;\n      }\n      setAnswers({ ...answers, topPriorities: [...current, val] });\n    }\n  };\n\n  const validateAndNext = () => {\n    setError(\"\");\n    if (step === 1) {\n      if (!answers.industry || !answers.companySize) {\n        setError(\"Industry and Company Size are required fields.\");\n        return;\n      }\n      setStep(2);\n    } else if (step === 2) {\n      if (answers.topPriorities.length === 0) {\n        setError(\"Please select at least 1 priority (max 3).\");\n        return;\n      }\n      setStep(3);\n    } else if (step === 3) {\n      if (!answers.aiJourney) {\n        setError(\"Please select your AI journey stage.\");\n        return;\n      }\n      setStep(4);\n    } else if (step === 4) {\n      if (!answers.dataReadiness || !answers.leadershipCommitment) {\n        setError(\"Please complete data readiness and leadership commitment.\");\n        return;\n      }\n      setStep(5);\n    } else if (step === 5) {\n      if (!answers.biggestChallenge) {\n        setError(\"Please select a primary challenge category.\");\n        return;\n      }\n      if (!customChallengeText || customChallengeText.trim().length < 10) {\n        setError(\"Please describe your challenge in at least 10 characters.\");\n        return;\n      }\n      setStep(6);\n    }\n  };\n\n  const handleBack = () => {\n    setError(\"\");\n    if (step > 1) setStep(step - 1);\n  };\n\n  const requestOtp = () => {\n    setError(\"\");\n    if (!answers.email || !answers.email.includes(\"@\")) {\n      setError(\"Please enter a valid enterprise email address.\");\n      return;\n    }\n    setOtpSent(true);\n  };\n\n  const verifyOtpAndGenerate = () => {\n    setOtpError(\"\");\n    if (!enteredOtp) {\n      setOtpError(\"Please enter the verification PIN.\");\n      return;\n    }\n    if (enteredOtp.length < 4) {\n      setOtpError(\"PIN code must be at least 4 digits.\");\n      return;\n    }\n    setIsCompiling(true);\n  };\n\n  const score = calculateBlueprintScore(answers);\n  const category = getScoreCategory(score);\n  const opportunities = getRecommendedOpportunities(answers.industry);\n  const solution = getRecommendedSolution(answers.biggestChallenge);\n  const impact = getExpectedImpact(answers.topPriorities);\n\n  const getIndustryIcon = (val: string) => {\n    switch (val) {\n      case \"Banking\":\n        return <svg className=\"w-5 h-5 text-[#087DF3]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"1.5\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.5M4.5 21V10.5\" /></svg>;\n      case \"Retail\":\n        return <svg className=\"w-5 h-5 text-[#E98828]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"1.5\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12\" /></svg>;\n      case \"Healthcare\":\n        return <svg className=\"w-5 h-5 text-emerald-500\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"1.5\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M21 8.25c0-2.485-2.099-4.5-4.688-4.5\" /></svg>;\n      case \"Manufacturing\"