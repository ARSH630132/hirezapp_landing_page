nal Services\",\n455 |   \"Regulated / Legal\",\n456 |   \"Financial Services\",\n457 |   \"Government & Sovereign\",\n458 |   \"Telecom\",\n459 |   \"Heavy Industry & Mining\"\n460 | ];\n461 | \n462 | const FUNCTIONS = [\n463 |   \"All Functions\",\n464 |   \"Knowledge Search\",\n465 |   \"Procurement Copilot\",\n466 |   \"HR Assistant\",\n467 |   \"Contract Intelligence\",\n468 |   \"Executive Dashboard\",\n469 |   \"Compliance Assistant\",\n470 |   \"Customer Experience Agent\",\n471 |   \"Operations Copilot\"\n472 | ];\n473 | \n474 | const AGENT_TYPES = [\n475 |   \"All Agent Types\",\n476 |   \"Deep Reasoning / DAG\",\n477 |   \"Transactional / Actions\",\n478 |   \"Collaborative / HITL\",\n479 |   \"Analytical / Extraction\",\n480 |   \"Multi-Agent Synthesis\",\n481 |   \"Guardrail / Audit\",\n482 |   \"Real-time / Interactive\",\n483 |   \"Reactive / Hardware\"\n484 | ];\n485 | \n486 | export default function SandboxPage() {\n487 |   // Filter States\n488 |   const [selectedIndustry, setSelectedIndustry] = useState(\"All Industries\");\n489 |   const [selectedFunction, setSelectedFunction] = useState(\"All Functions\");\n490 |   const [selectedAgentType, setSelectedAgentType] = useState(\"All Agent Types\");\n491 |   const [searchQuery, setSearchQuery] = useState(\"\");\n492 | \n493 |   // Catalog Active Agent Selection\n494 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n495 | \n496 |   // Simulation Telemetry States\n497 |   const [isSimulating, setIsSimulating] = useState(false);\n498 |   const [simulationProgress, setSimulationProgress] = useState(0);\n499 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n500 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n501 | \n502 |   // Filter lists based on rules\n503 |   const filteredAgents = AGENTS.filter((agent) => {\n504 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n505 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n506 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n507 |     const matchSearch =\n508 |       searchQuery === \"\" ||\n509 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n510 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n511 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n512 | \n513 |     return matchIndustry && matchFunction && matchType && matchSearch;\n514 |   });\n515 | \n516 |   // Dynamically pull active agent object\n517 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n518 | \n519 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n520 |   useEffect(() => {\n521 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n522 |       setActiveAgentId(filteredAgents[0].id);\n523 |     }\n524 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n525 | \n526 |   // Reset simulation whenever active agent changes\n527 |   useEffect(() => {\n528 |     setIsSimulating(false);\n529 |     setSimulationProgress(0);\n530 |     setSimulatedLogs([]);\n531 |   }, [activeAgentId]);\n532 | \n533 |   // Handle dry-run simulation progress\n534 |   useEffect(() => {\n535 |     if (!isSimulating) return;\n536 | \n537 |     setSimulationProgress(0);\n538 |     setSimulatedLogs([]);\n539 | \n540 |     const totalDuration = 4800; // 4.8s simulation\n541 |     const intervalTime = 50; // update every 50ms\n542 |     let elapsed = 0;\n543 | \n544 |     const interval = setInterval(() => {\n545 |       elapsed += intervalTime;\n546 |       const progress = Math.min((elapsed / totalDuration) * 100, 100);\n547 |       setSimulationProgress(Math.round(progress));\n548 | \n549 |       // Stream logs matching current timeline progress\n550 |       const secondsElapsed = elapsed / 1000;\n551 |       const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n552 |       setSimulatedLogs(activeLogs);\n553 | \n554 |       if (elapsed >= totalDuration) {\n555 |         clearInterval(interval);\n556 |         setIsSimulating(false);\n557 |       }\n558 |     }, intervalTime);\n559 | \n560 |     return () => clearInterval(interval);\n561 |   }, [isSimulating, activeAgent]);\n562 | \n563 |   // Dynamic count generators for UI indicators\n564 |   const getIndustryCount = (ind: string) => {\n565 |     if (ind === \"All Industries\") return AGENTS.length;\n566 |     return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n567 |   };\n568 | \n569 |   const getFunctionCount = (func: string) => {\n570 |     if (func === \"All Functions\") return AGENTS.length;\n571 |     return AGENTS.filter((a) => a.category === func).length;\n572 |   };\n573 | \n574 |   const getAgentTypeCount = (type: string) => {\n575 |     if (type === \"All Agent Types\") return AGENTS.length;\n576 |     return AGENTS.filter((a) => a.agentType === type).length;\n577 |   };\n578 | \n579 |   // Render modern animated connection DAG inside Sovereign Architecture Tab\n580 |   const renderSVGArchitecture = (agent: AgentDemo) => {\n581 |     return (\n582 |       <svg className=\"w-full h-full min-h-[220px]\" viewBox=\"0 0 500 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n583 |         <defs>\n584 |           <linearGradient id=\"lineGlow\" x1=\"0\" y1=\"0\" x2=\"500\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n585 |             <stop stopColor=\"#E4000F\" />\n586 |             <stop offset=\"0.5\" stopColor=\"#009DFF\" />\n587 |             <stop offset=\"1\" stopColor=\"#00FF9D\" />\n588 |           </linearGradient>\n589 |           <filter id=\"glowEffect\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n590 |             <feGaussianBlur stdDeviation=\"5\" result=\"blur\" />\n591 |             <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n592 |           </filter>\n593 |         </defs>\n594 | \n595 |         {/* Outer Boundary Box: Cryptographic Enclave */}\n596 |         <rect x=\"130\" y=\"20\" width=\"240\" height=\"180\" rx=\"16\" fill=\"rgba(4,6,11,0.7)\" stroke=\"rgba(0,157,255,0.25)\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n597 |         <text x=\"250\" y=\"212\" fill=\"rgba(255,255,255,0.35)\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" letterSpacing=\"0.1em\">\n598 |           SOVEREIGN ENCLAVE HARDWARE BOUNDARY\n599 |         </text>\n600 | \n601 |         {/* Dynamic connection lines */}\n602 |         {/* Inbound path */}\n603 |         <path d=\"M 60 110 L 130 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n604 |         <circle cx=\"100\" cy=\"110\" r=\"3\" fill=\"#E4000F\">\n605 |           <animate attributeName=\"cx\" values=\"60;130\" dur=\"2s\" repeatCount=\"indefinite\" />\n606 |         </circle>\n607 | \n608 |         {/* Enclave internal routing path */}\n609 |         <path d=\"M 180 110 L 250 65 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n610 |         <path d=\"M 180 110 L 250 155 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n611 |         <circle cx=\"215\" cy=\"87\" r=\"2.5\" fill=\"#009DFF\">\n612 |           <animate attributeName=\"cx\" values=\"180;250;320\" dur=\"3s\" repeatCount=\"indefinite\" />\n613 |         </circle>\n614 | \n615 |         {/* Outbound path */}\n616 |         <path d=\"M 370 110 L 440 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n617 |         <circle cx=\"400\" cy=\"110\" r=\"3\" fill=\"#00FF9D\">\n618 |           <animate attributeName=\"cx\" values=\"370;440\" dur=\"2.5s\" repeatCount=\"indefinite\" />\n619 |         </circle>\n620 | \n621 |         {/* Left Node: Inbound Ingress Source */}\n622 |         <circle cx=\"40\" cy=\"110\" r=\"16\" fill=\"#0c0d12\" stroke=\"#E4000F\" strokeWidth=\"1.5\" />\n623 |         <text x=\"40\" y=\"113\" fill=\"#ffffff\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">IN</text>\n624 |         <text x=\"40\" y=\"142\" fill=\"rgba(255,255,255,0.5)\" fontSize=\"7\" fontFamily=\"sans-serif\" textAnchor=\"middle\">\n625 |           {agent.ingressLabel}\n626 |         </text>\n627 | \n628 |         {/* Enclave Nodes */}\n629 |         {/* Node A: Gateway Decryptor */}\n630 |         <circle cx=\"180\" cy=\"110\" r=\"14\" fill=\"#04060b\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n631 |         <text x=\"180\" y=\"113\" fill=\"#009DFF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">DEC</text>\n632 |         <text x=\"180\" y=\"136\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">INGRESS</text>\n633 | \n634 |         {/* Node B1: Graph/Vector Processor */}\n635 |         <circle cx=\"250\" cy=\"65\" r=\"14\" fill=\"#04060b\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n636 |         <text x=\"250\" y=\"68\" fill=\"#009DFF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">DAG</text>\n637 |         <text x=\"250\" y=\"91\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">ORCHESTRATOR</text>\n638 | \n639 |         {/* Node B2: Alignment & Policies */}\n640 |         <circle cx=\"250\" cy=\"155\" r=\"14\" fill=\"#04060b\" stroke=\"#9D00FF\" strokeWidth=\"1.5\" />\n641 |         <text x=\"250\" y=\"158\" fill=\"#9D00FF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">ALN</text>\n642 |         <text x=\"250\" y=\"181\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">ALIGNMENT</text>\n643 | \n644 |         {/* Node C: API Router & Egress */}\n645 |         <circle cx=\"320\" cy=\"110\" r=\"14\" fill=\"#04060b\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" />\n646 |         <text x=\"320\" y=\"113\" fill=\"#00FF9D\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">EGR</text>\n647 |         <text x=\"320\" y=\"136\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">EGRESS</text>\n648 | \n649 |         {/* Right Node: Sovereign Egress Target */}\n650 |         <circle cx=\"460\" cy=\"110\" r=\"16\" fill=\"#0c0d12\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" />\n651 |         <text x=\"460\" y=\"113\" fill=\"#ffffff\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">OUT</text>\n652 |         <text x=\"460\" y=\"142\" fill=\"rgba(255,255,255,0.5)\" fontSize=\"7\" fontFamily=\"sans-serif\" textAnchor=\"middle\">\n653 |           {agent.egressLabel}\n654 |         </text>\n655 |       </svg>\n656 |     );\n657 |   };\n658 | \n659 |   return (\n660 |     <InnerPageShell>\n661 |       <InnerPageHero\n662 |         category=\"Sovereign Sandbox\"\n663 |         title=\"Agent Deployment Sandbox\"\n664 |         highlightedWord=\"Sandbox\"\n665 |         description=\"Launch real-time isolated dry-runs of enterprise agent blueprints within cryptographic hardware boundaries. Test routing protocols, safety guardrails, and platform connections using local static mocks before staging.\"\n666 |         breadcrumbs={[\n667 |           { label: \"Build Suite\", href: \"/platforms\" },\n668 |           { label: \"Sandbox Catalog\" }\n669 |         ]}\n670 |       />\n671 | \n672 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-12 relative z-10\">\n673 |         \n674 |         {/* FILTERS & SEARCH MODULE */}\n675 |         <MotionReveal delay={0.1}>\n676 |           <div className=\"rounded-3xl border border-white/5 bg-[#030304]/80 backdrop-blur-[12px] p-6 lg:p-8 space-y-6\">\n677 |             <div className=\"flex flex-col lg:flex-row lg:item