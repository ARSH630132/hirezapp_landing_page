                   CLEAR\n708 |                   </button>\n709 |                 )}\n710 |               </div>\n711 |             </div>\n712 | \n713 |             {/* EXPENSIVE GRID OF DROPDOWNS & FILTER PILLS */}\n714 |             <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-2 border-t border-white/5\">\n715 |               \n716 |               {/* INDUSTRY FILTER */}\n717 |               <div className=\"space-y-2\">\n718 |                 <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest block\">RECOMMENDED SECTOR</span>\n719 |                 <div className=\"relative\">\n720 |                   <select\n721 |                     value={selectedIndustry}\n722 |                     onChange={(e) => setSelectedIndustry(e.target.value)}\n723 |                     className=\"w-full h-11 px-3 text-xs bg-[#05060c] border border-white/5 rounded-xl text-white/80 focus:outline-none focus:border-[#009DFF]/40 appearance-none cursor-pointer\"\n724 |                   >\n725 |                     {INDUSTRIES.map((ind) => (\n726 |                       <option key={ind} value={ind} className=\"bg-[#020203]\">\n727 |                         {ind} {ind !== \"All Industries\" ? `(${getIndustryCount(ind)})` : \"\"}\n728 |                       </option>\n729 |                     ))}\n730 |                   </select>\n731 |                   <div className=\"pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-white/40\">\n732 |                     <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n733 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 9l-7 7-7-7\" />\n734 |                     </svg>\n735 |                   </div>\n736 |                 </div>\n737 |               </div>\n738 | \n739 |               {/* FUNCTION/CATEGORY FILTER */}\n740 |               <div className=\"space-y-2\">\n741 |           