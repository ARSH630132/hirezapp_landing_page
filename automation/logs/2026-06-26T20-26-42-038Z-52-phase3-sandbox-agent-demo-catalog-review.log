th === 0 ? (\n838 |               <div className=\"rounded-3xl border border-white/5 bg-[#030304]/60 p-12 text-center space-y-4\">\n839 |                 <svg className=\"w-12 h-12 text-white/10 mx-auto\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n840 |                   <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636\" />\n841 |                 </svg>\n842 |                 <div className=\"space-y-1\">\n843 |                   <h4 className=\"font-bold text-white text-sm\">No Sandbox Blueprints Match Filters</h4>\n844 |                   <p className=\"text-xs text-white/40 max-w-sm mx-auto\">\n845 |                     Try loosening your industry, functional scope, or search queries to explore the standard GFF AI catalogue.\n846 |                   </p>\n847 |                 </div>\n848 |                 <button\n849 |                   onClick={() => {\n850 |                     setSelectedIndustry(\"All Industries\");\n851 |                     setSelectedFunction(\"All Functions\");\n852 |                     setSelectedAgentType(\"All Agent Types\");\n853 |                     setSearchQuery(\"\");\n854 |                   }}\n855 |                   className=\"px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold hover:bg-white/10 hover:border-white/15 transition-all\"\n856 |                 >\n857 |                   Reset Active Filters\n858 |                 </button>\n859 |               </div>\n860 |             ) : (\n\n[Showing lines 1-860 of 1223. Use start_line/end_line to read other sections.]","success":true}],"durationMs":12}}
