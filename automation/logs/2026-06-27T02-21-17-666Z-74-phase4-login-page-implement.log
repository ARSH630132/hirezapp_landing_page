ization uses client/admin roles for the correct routing.\n\n\n**Optimizing Visual Feedback**\n\nI'm now optimizing visual feedback for role selection, ensuring a dynamic representation of GFF AI's secure handshakes. I've successfully implemented dynamic styling, using the `isClientRole` state to define colors. I'm thrilled I can define inline CSS to make an animation! The Gateway visualization is awesome. I've incorporated the animation, and it works perfectly without customizing any global styles.\n\n\n**Designing SSO Flow**\n\nI'm now designing the custom SSO modal. If a user chooses an SSO provider, a dark overlay appears within the card. It will include the Okta/Azure AD logo, a spinner with \"Redirecting to Single Sign-On Gateway...\", and a step list detailing federation checks. After 1.5 seconds of success, automatic login happens! I'm reviewing `SecureLogin.tsx` and `app/login/page.tsx` to check for updates.\n\n\n**Verifying Role Overrides**\n\nI've verified the `defaultRole` prop is correctly supported, ensuring role overrides work as intended. I've confirmed in `app/admin/login/page.tsx` that `defaultRole=\"Administrator\"` correctly sets `selectedRole` to `\"gff_admin\"`. I've checked fallbacks, and reviewed mock users in `lib/preview-auth.ts`, so I can see user roles. Now I'll fully review `components/portal/SecureLogin.tsx`.\n\n\n"}}
{"ts":"2026-06-27T02:20:36.053Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"wvjshkgj","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/portal/SecureLogin.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useRef, useEffect } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  Lock, \n  Shield, \n  Key, \n  CheckCircle, \n  RefreshCw, \n  Layers, \n  Eye, \n  EyeOff, \n  Users, \n  Cpu, \n  FileText, \n  HelpCircle, \n  Mail, \n  Fingerprint, \n  ArrowRight, \n  ExternalLink,\n  AlertCircle,\n  Terminal,\n  Check\n} from \"lucide-react\";\nimport { setPreviewSession, PreviewRole, MOCK_PREVIEW_USERS } from \"@/lib/preview-auth\";\n\ninterface SecureLoginProps {\n  defaultRole?: string;\n}\n\nexport default function SecureLogin({ defaultRole }: SecureLoginProps) {\n  const router = useRouter();\n  \n  // Set default active simulated role based on route props\n  const [selectedRole, setSelectedRole] = useState<PreviewRole>(\n    defaultRole === \"Administrator\" ? \"gff_admin\" : \"client_admin\"\n  );\n\n  // Authentication Tab: 'password' | 'otp' | 'sso'\n  const [authMethod, setAuthMethod] = useState<\"password\" | \"otp\" | \"sso\">(\"password\");\n\n  // Form States\n  const [email, setEmail] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n  const [passwordShown, setPasswordShown] = useState(false);\n  const [rememberMe, setRememberMe] = useState(false);\n  const [otp, setOtp] = useState<string[]>([\"\", \"\", \"\", \"\", \"\", \"\"]);\n  \n  // Overlay/Modal States\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n  const [ssoProvider, setSsoProvider] = useState<string | null>(null);\n  const [forgotPasswordOpen, setForgotPasswordOpen] = useState(false);\n  const [supportOpen, setSupportOpen] = useState(false);\n  const [formError, setFormError] = useState<string | null>(null);\n\n  // References for OTP automatic input focusing\n  const otpRefs = useRef<(HTMLInputElement | null)[]>([]);\n\n  // Pre-populate fields when selected preview role changes\n  useEffect(() => {\n    const mockUser = MOCK_PREVIEW_USERS[selectedRole];\n    if (mockUser) {\n      setEmail(mockUser.email);\n      setPassword(\"••••••••••••\"); // Premium static placeholder to emulate credentials\n      setFormError(null);\n      // Fill in demo OTP code\n      setOtp([\"7\", \"3\", \"9\", \"2\", \"8\", \"4\"]);\n    }\n  }, [selectedRole]);\n\n  // Handle manual OTP input\n  const handleOtpChange = (value: string, index: number) => {\n    if (/[^0-9]/.test(value)) return; // Allow only numeric inputs\n    const newOtp = [...otp];\n    newOtp[index] = value;\n    setOtp(newOtp);\n\n    // Auto-focus next input box if filled\n    if (value !== \"\" && index < 5) {\n      otpRefs.current[index + 1]?.focus();\n    }\n  };\n\n  // Handle OTP key down (for backspace movement)\n  const handleOtpKeyDown = (e: React.KeyboardEvent<HTMLInputElement>, index: number) => {\n    if (e.key === \"Backspace\") {\n      if (otp[index] === \"\" && index > 0) {\n        const newOtp = [...otp];\n        newOtp[index - 1] = \"\";\n        setOtp(newOtp);\n        otpRefs.current[index - 1]?.focus();\n      } else {\n        const newOtp = [...otp];\n        newOtp[index] = \"\";\n        setOtp(newOtp);\n      }\n    }\n  };\n\n  // List of simulated roles for review/sandbox\n  const rolesList = [\n    { id: \"client_admin\" as PreviewRole, label: \"Client Admin\", clearance: \"Level III\", desc: \"Sovereign tenant portal root\", icon: Users, color: \"text-cyan-400\" },\n    { id: \"client_member\" as PreviewRole, label: \"Client Member\", clearance: \"Level II\", desc: \"Standard sandbox operator\", icon: Layers, color: \"text-blue-400\" },\n    { id: \"gff_admin\" as PreviewRole, label: \"GFF Admin\", clearance: \"Level V\", desc: \"Full GFF ecosystem control\", icon: Shield, color: \"text-red-400\" },\n    { id: \"gff_operator\" as PreviewRole, label: \"GFF Operator\", clearance: \"Level IV\", desc: \"Model fabric deployment lead\", icon: Cpu, color: \"text-purple-400\" },\n    { id: \"finance_admin\" as PreviewRole, label: \"Finance Admin\", clearance: \"Level III\", desc: \"Ecosystem ledger administrator\", icon: FileText, color: \"text-emerald-400\" },\n    { id: \"support_agent\" as PreviewRole, label: \"Support Agent\", clearance: \"Level III\", desc: \"SLA response wire agent\", icon: HelpCircle, color: \"text-orange-400\" },\n    { id: \"viewer\" as PreviewRole, label: \"Auditor (Viewer)\", clearance: \"Level I\", desc: \"Read-only workspace observer\", icon: Eye, color: \"text-slate-400\" },\n  ];\n\n  // Primary Gateway Authentication Handler\n  const handleAuthenticate = async (e?: React.FormEvent) => {\n    if (e) e.preventDefault();\n    \n    // Basic Form Validations (Only for Password and OTP modes)\n    if (authMethod === \"password\") {\n      if (!email || !email.includes(\"@\")) {\n        setFormError(\"Security handoff failed: A valid GFF enterprise email address is required.\");\n        return;\n      }\n      if (!password || password.length < 4) {\n        setFormError(\"Security handoff failed: Password credentials cannot be blank.\");\n        return;\n      }\n    } else if (authMethod === \"otp\") {\n      if (otp.some(digit => digit === \"\")) {\n        setFormError(\"Security handoff failed: 6-digit cryptographic security code is incomplete.\");\n        return;\n      }\n    }\n\n    setFormError(null);\n    setScanning(true);\n    setScanStep(0);\n\n    // Simulate standard security handshakes\n    const interval = setInterval(() => {\n      setScanStep(p => p < 3 ? p + 1 : p);\n    }, 250);\n\n    await new Promise(r => setTimeout(r, 1100));\n    clearInterval(interval);\n    setScanning(false);\n    \n    // Create preview session in localStorage\n    setPreviewSession(selectedRole);\n\n    // Redirect corresponding roles\n    const targetPath = selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\";\n    router.push(targetPath);\n  };\n\n  // Launch Simulated SSO flow\n  const handleSSOAuthenticate = async (provider: string) => {\n    setSsoProvider(provider);\n    await new Promise(r => setTimeout(r, 1400));\n    setSsoProvider(null);\n    \n    // Now trigger formal secure handoff\n    handleAuthenticate();\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n  const activeRoleObj = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n  \n  const scanMessages = [\n    \"Establishing zero-trust gateway handshake...\",\n    \"Isolating secure local sandbox enclaves...\",\n    \"Exchanging SHA-256 cryptographic keys...\",\n    \"Provisioning dynamic clearance certificate...\"\n  ];\n\n  const isClientRole = selectedRole.startsWith(\"client_\");\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative px-4 py-12 md:py-20 select-none font-sans overflow-hidden\">\n      {/* Ported portable keyframe animations */}\n      <style dangerouslySetInnerHTML={{ __html: `\n        @keyframes dash {\n          to {\n            stroke-dashoffset: -20;\n          }\n        }\n        @keyframes pulse-slow {\n          0%, 100% { opacity: 0.15; }\n          50% { opacity: 0.35; }\n        }\n      `}} />\n\n      {/* Modern Radial Glow Gradients */}\n      <div className=\"absolute top-0 left-1/4 w-[500px] h-[500px] rounded-full bg-[#009DFF]/3 blur-[120px] pointer-events-none animate-pulse-slow\" style={{ animationDuration: '8s' }} />\n      <div className=\"absolute bottom-0 right-1/4 w-[500px] h-[500px] rounded-full bg-[#E4000F]/2 blur-[120px] pointer-events-none animate-pulse-slow\" style={{ animationDuration: '12s' }} />\n      <div className=\"absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n\n      {/* Main Core Container */}\n      <div className=\"w-full max-w-6xl z-10 flex flex-col gap-8\">\n        \n        {/* Header Section */}\n        <header className=\"flex flex-col md:flex-row items-center justify-between border-b border-white/5 pb-6 gap-4\">\n          <div className=\"flex items-center gap-3\">\n            <img src=\"/footer/logo.svg\" alt=\"GFF AI Logo\" className=\"w-[50px] h-[50px] object-contain\" />\n            <div className=\"flex flex-col\">\n              <div className=\"text-white text-xl font-bold tracking-[0.03em] leading-none\">GFF AI</div>\n              <div className=\"flex items-center gap-[4px] text-[8px] font-extrabold tracking-[0.08em] mt-1.5\">\n                <span className=\"text-[#E4000F]\">GARAGE</span>\n                <span className=\"text-white/40\">|</span>\n                <span className=\"text-white\">FOUNDRY</span>\n                <span className=\"text-white/40\">|</span>\n                <span className=\"text-[#009DFF]\">FACTORY</span>\n              </div>\n            </div>\n          </div>\n          \n          <div className=\"flex items-center gap-3\">\n            <span className=\"inline-flex h-2 w-2 rounded-full bg-emerald-500 animate-ping\" />\n            <span className=\"text-[10px] font-mono text-zinc-400 uppercase tracking-widest border border-white/5 bg-zinc-950 px-3 py-1 rounded-full\">\n              Sovereign Handshake V2.6\n            </span>\n          </div>\n        </header>\n\n        {/* Dynamic Split Layout */}\n        <main className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\">\n          \n          {/* LEFT SIDE: Formal Enterprise Sign-In Gateway */}\n          <section className=\"lg:col-span-6 bg-zinc-950/65 border border-white/5 backdrop-blur-xl rounded-3xl p-6 sm:p-10 flex flex-col justify-between relative shadow-[0_30px_100px_rgba(0,0,0,0.85)] min-h-[580px]\">\n            \n            {/* Simulated Scanning Modal Overlay */}\n            {scanning && (\n              <div className=\"absolute inset-0 bg-black/95 rounded-3xl z-40 flex flex-col justify-center items-center p-8 space-y-6\">\n                <div className=\"relative h-16 w-16 bg-black border border-[#009DFF]/20 rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(0,157,255,0.1)]\">\n                  <div className=\"absolute left-0 right-0 h-[1.5px] bg-[#009DFF] animate-pulse\" style={{ top: \"45%\" }} />\n                  <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin\" />\n                </div>\n                \n                <div className=\"w-full max-w-sm space-y-3\">\n                  <div className=\"flex justify-between items-center text-[10px] font-mono text-zinc-500\">\n                    <span>SECURITY DECRYPTING HANDSHAKE</span>\n                    <span>{Math.round((scanStep + 1) * 25)}%</span>\n                  </div>\n                  <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\">\n                    <div className=\"h-full bg-gradient-to-r from-[#009DFF] to-[#E4000F] transition-all duration-300\" style={{ width: `${(scanStep + 1) * 25}%` }} />\n                  </div>\n                </div>\n\n                <div className=\"w-full max-w-sm p-4 rounded-xl border border-white/5 bg-zinc-900/40 min-h-[120px] text-[10px] space-y-2.5 font-mono text-left\">\n                  {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                    <div key={idx} className=\"flex items-center gap-2 text-white/80\">\n                      {idx < scanStep ? (\n                        <Check className=\"w-4 h-4 text-emerald-500 shrink-0\" />\n                      ) : (\n                        <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin shrink-0\" />\n                      )}\n                      <span className={idx < scanStep ? \"text-zinc-500 line-through\" : \"text-white font-medium\"}>{msg}</span>\n                    </div>\n                  ))}\n                </div>\n              </div>\n            )}\n\n            {/* Simulated SSO Provider Modal Overlay */}\n            {ssoProvider && (\n              <div className=\"absolute inset-0 bg-black/95 rounded-3xl z-40 flex flex-col justify-center items-center p-8 space-y-6\">\n                <div className=\"h-16 w-16 bg-white/5 border border-white/10 rounded-full flex items-center justify-center\">\n                  <Fingerprint className=\"w-8 h-8 text-[#009DFF] animate-pulse\" />\n                </div>\n                \n                <div className=\"text-center space-y-1.5\">\n                  <h3 className=\"text-sm font-semibold tracking-wide uppercase\">SAML Enterprise Gateway</h3>\n                  <p className=\"text-xs text-zinc-400\">Authenticating token via <span className=\"text-[#009DFF] font-medium\">{ssoProvider}</span> Integration...</p>\n                </div>\n\n                <div className=\"w-full max-w-xs space-y-2 p-4 rounded-xl border border-white/5 bg-zinc-900/30 text-[9.5px] font-mono text-zinc-500 text-left\">\n                  <div className=\"flex items-center gap-2\"><div className=\"h-1 w-1 rounded-full bg-emerald-500\" /> Connecting Identity Bridge...</div>\n                  <div className=\"flex items-center gap-2\"><div className=\"h-1 w-1 rounded-full bg-emerald-500\" /> Checking policy permissions on gff.ai...</div>\n                  <div className=\"flex items-center gap-2\"><div className=\"h-1 w-1 rounded-full bg-emerald-500 animate-ping\" /> Redirect token payload successfully validated!</div>\n                </div>\n              </div>\n            )}\n\n            {/* Top Area: Card title */}\n            <div className=\"space-y-6\">\n              <div>\n                <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-3 py-1 rounded-full uppercase tracking-wider\">\n                  Secure Access Handshake\n                </span>\n                <h1 className=\"text-xl sm:text-2xl font-semibold tracking-tight text-white mt-3 font-sans\">\n                  Sovereign Portal Entrance\n                </h1>\n                <p className=\"text-xs text-zinc-400 mt-2 leading-relaxed\">\n                  Provide authorized enterprise credentials or leverage the local development simulator to explore sandbox features.\n                </p>\n              </div>\n\n              {/* TAB SELECTION SYSTEM */}\n              <div className=\"grid grid-cols-3 bg-zinc-900/50 p-1 rounded-xl border border-white/5 text-xs font-medium\">\n                <button \n                  onClick={() => { setAuthMethod(\"password\"); setFormError(null); }}\n                  className={`py-2 rounded-lg cursor-pointer transition-all ${\n                    authMethod === \"password\" ? \"bg-white/10 text-white shadow-sm\" : \"text-zinc-400 hover:text-white\"\n                  }`}\n                >\n                  Password Auth\n                </button>\n                <button \n                  onClick={() => { setAuthMethod(\"otp\"); setFormError(null); }}\n                  className={`py-2 rounded-lg cursor-pointer transition-all ${\n                    authMethod === \"otp\" ? \"bg-white/10 text-white shadow-sm\" : \"text-zinc-400 hover:text-white\"\n                  }`}\n                >\n                  One-Time OTP\n                </button>\n                <button \n                  onClick={() => { setAuthMethod(\"sso\"); setFormError(null); }}\n                  className={`py-2 rounded-lg cursor-pointer transition-all ${\n                    authMethod === \"sso\" ? \"bg-white/10 text-white shadow-sm\" : \"text-zinc-400 hover:text-white\"\n                  }`}\n                >\n                  SSO Identity\n                </button>\n              </div>\n\n              {/* ERROR BLOCK */}\n              {formError && (\n                <div className=\"p-3 bg-[#E4000F]/5 border border-[#E4000F]/15 rounded-xl flex items-start gap-2.5 text-xs text-red-400\">\n                  <AlertCircle className=\"w-4 h-4 shrink-0 mt-0.5 text-[#E4000F]\" />\n                  <span className=\"leading-snug\">{formError}</span>\n                </div>\n              )}\n\n              {/* DYNAMIC FORM VIEWS */}\n              <form onSubmit={handleAuthenticate} className=\"space-y-4\">\n                {authMethod === \"password\" && (\n                  <div className=\"space-y-4\">\n                    <div className=\"space-y-1.5\">\n                      <label htmlFor=\"email\" className=\"text-[10px] font-mono text-zinc-400 uppercase tracking-wider block\">\n                        Enterprise Email\n                      </label>\n                      <div className=\"relative\">\n                        <span className=\"absolute left-3.5 top-3 text-zinc-500\">\n                          <Mail className=\"w-4 h-4\" />\n                        </span>\n                        <input\n                          id=\"email\"\n                          type=\"email\"\n                          placeholder=\"your-name@enterprise.com\"\n                          value={email}\n                          onChange={(e) => setEmail(e.target.value)}\n                          className=\"w-full bg-black/40 hover:bg-black/60 focus:bg-black/80 border border-white/5 focus:border-[#009DFF]/40 rounded-xl h-10.5 pl-10.5 pr-4 text-xs font-sans placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-[#009DFF]/30 transition-all text-white\"\n                        />\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-1.5\">\n                      <div className=\"flex justify-between items-center\">\n                        <label htmlFor=\"password\" className=\"text-[10px] font-mono text-zinc-400 uppercase tracking-wider\">\n                          Access Crypt-Key\n                        </label>\n                        <button\n                          type=\"button\"\n                          onClick={() => setForgotPasswordOpen(true)}\n                          className=\"text-[10px] font-medium text-zinc-400 hover:text-white transition-colors cursor-pointer\"\n                        >\n                          Forgot key?\n                        </button>\n                      </div>\n                      <div className=\"relative\">\n                        <span className=\"absolute left-3.5 top-3 text-zinc-500\">\n                          <Lock className=\"w-4 h-4\" />\n                        </span>\n                        <input\n                          id=\"password\"\n                          type={passwordShown ? \"text\" : \"password\"}\n                          placeholder=\"Enter secure password\"\n                          value={password}\n                          onChange={(e) => setPassword(e.target.value)}\n                          className=\"w-full bg-black/40 hover:bg-black/60 focus:bg-black/80 border border-white/5 focus:border-[#009DFF]/40 rounded-xl h-10.5 pl-10.5 pr-11 text-xs font-sans placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-[#009DFF]/30 transition-all text-white\"\n                        />\n                        <button\n                          type=\"button\"\n                          onClick={() => setPasswordShown(!passwordShown)}\n                          className=\"absolute right-3 top-3 text-zinc-500 hover:text-white transition-colors cursor-pointer\"\n                        >\n                          {passwordShown ? <EyeOff className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}\n                        </button>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center justify-between pt-1\">\n                      <label className=\"flex items-center gap-2 text-xs text-zinc-400 cursor-pointer select-none\">\n                        <input\n                          type=\"checkbox\"\n                          checked={rememberMe}\n                          onChange={(e) => setRememberMe(e.target.checked)}\n                          className=\"rounded border-white/10 bg-zinc-900/50 text-[#009DFF] focus:ring-0 focus:ring-offset-0 focus:outline-none cursor-pointer h-4 w-4\"\n                        />\n                        <span>Remember credentials</span>\n                      </label>\n                    </div>\n                  </div>\n                )}\n\n                {authMethod === \"otp\" && (\n                  <div className=\"space-y-4\">\n                    <div className=\"space-y-1.5\">\n                      <label className=\"text-[10px] font-mono text-zinc-400 uppercase tracking-wider block\">\n                        One-Time Passcode Verification\n                      </label>\n                      <p className=\"text-[11px] text-zinc-500\">\n                        Enter the 6-digit cryptographic security code dispatched to your authorized system key:\n                      </p>\n                    </div>\n\n                    {/* Numeric OTP code boxes */}\n                    <div className=\"flex items-center justify-between gap-2.5 py-2\">\n                      {otp.map((digit, idx) => (\n                        <input\n                          key={idx}\n                          type=\"text\"\n                          maxLength={1}\n                          ref={(el) => { otpRefs.current[idx] = el; }}\n                          value={digit}\n                          onChange={(e) => handleOtpChange(e.target.value, idx)}\n                          onKeyDown={(e) => handleOtpKeyDown(e, idx)}\n                          className=\"w-11 h-12 bg-black/40 border border-white/5 focus:border-[#009DFF]/40 rounded-xl text-center text-sm font-mono focus:outline-none focus:ring-1 focus:ring-[#009DFF]/30 transition-all text-white\"\n                        />\n                      ))}\n                    </div>\n\n                    <div className=\"text-right\">\n                      <button\n                        type=\"button\"\n                        onClick={() => {\n                          setOtp([\"7\", \"3\", \"9\", \"2\", \"8\", \"4\"]);\n                          setFormError(null);\n                        }}\n                        className=\"text-[10px] font-semibold text-[#009DFF] hover:text-white transition-colors cursor-pointer\"\n                      >\n                        Bypass OTP Code (Pre-fill)\n                      </button>\n                    </div>\n                  </div>\n                )}\n\n                {authMethod === \"sso\" && (\n                  <div className=\"space-y-4\">\n                    <div className=\"space-y-1.5\">\n                      <label className=\"text-[10px] font-mono text-zinc-400 uppercase tracking-wider block\">\n                        Enterprise Federation SSO\n                      </label>\n                      <p className=\"text-[11px] text-zinc-500\">\n                        Authenticate via your organization's integrated, single sign-on security provider.\n                      </p>\n                    </div>\n\n                    <div className=\"space-y-2.5 pt-2\">\n                      <button\n                        type=\"button\"\n                        onClick={() => handleSSOAuthenticate(\"Okta Security Router\")}\n                        className=\"w-full flex items-center justify-between px-4 h-11 rounded-xl bg-[#009DFF]/5 hover:bg-[#009DFF]/10 border border-[#009DFF]/20 text-white text-xs font-semibold cursor-pointer transition-all hover:-translate-y-0.5\"\n                      >\n                        <div className=\"flex items-center gap-2.5\">\n                          <span className=\"font-mono text-[9px] px-1.5 py-0.5 bg-[#009DFF]/20 text-[#009DFF] rounded\">SAML</span>\n                          <span>Sign in with Okta Suite</span>\n                        </div>\n                        <ArrowRight className=\"w-4 h-4 text-zinc-500\" />\n                      </button>\n\n                      <button\n                        type=\"button\"\n                        onClick={() => handleSSOAuthenticate(\"Azure Active Directory\")}\n                        className=\"w-full flex items-center justify-between px-4 h-11 rounded-xl bg-purple-500/5 hover:bg-purple-500/10 border border-purple-500/20 text-white text-xs font-semibold cursor-pointer transition-all hover:-translate-y-0.5\"\n                      >\n                        <div className=\"flex items-center gap-2.5\">\n                          <span className=\"font-mono text-[9px] px-1.5 py-0.5 bg-purple-500/20 text-purple-400 rounded\">OIDC</span>\n                          <span>Azure Active Directory SSO</span>\n                        </div>\n                        <ArrowRight className=\"w-4 h-4 text-zinc-500\" />\n                      </button>\n\n                      <button\n                        type=\"button\"\n                        onClick={() => handleSSOAuthenticate(\"Ping Federate Gate\")}\n                        className=\"w-full flex items-center justify-between px-4 h-11 rounded-xl bg-zinc-900 hover:bg-zinc-850 border border-white/5 text-white text-xs font-semibold cursor-pointer transition-all hover:-translate-y-0.5\"\n                      >\n                        <div className=\"flex items-center gap-2.5\">\n                          <span className=\"font-mono text-[9px] px-1.5 py-0.5 bg-zinc-800 text-zinc-400 rounded\">ADFS</span>\n                          <span>Ping Identity Federation</span>\n                        </div>\n                        <ArrowRight className=\"w-4 h-4 text-zinc-500\" />\n                      </button>\n                    </div>\n                  </div>\n                )}\n\n                {/* Primary Submit Button */}\n                {authMethod !== \"sso\" && (\n                  <button\n                    type=\"submit\"\n                    className=\"w-full h-11 mt-2 rounded-xl bg-white hover:bg-zinc-100 text-black font-semibold text-xs uppercase tracking-wider flex items-center justify-center gap-2 cursor-pointer transition-all active:scale-[0.98] hover:shadow-[0_0_25px_rgba(255,255,255,0.15)]\"\n                  >\n                    <Key className=\"w-4 h-4\" /> Authenticate Enclave\n                  </button>\n                )}\n              </form>\n            </div>\n\n            {/* Bottom Links & Notice Area */}\n            <div className=\"pt-8 border-t border-white/5 space-y-4\">\n              <div className=\"p-3 bg-blue-950/10 border border-blue-500/10 rounded-xl text-[10px] text-zinc-400 leading-normal flex gap-2\">\n                <Terminal className=\"w-4 h-4 text-[#009DFF] shrink-0 mt-0.5\" />\n                <span>\n                  <strong>PREVIEW GATEWAY:</strong> This is a front-end preview. Authentic access controls are sandbox-isolated. Real OAuth / SAML SSO and database authentication connect in production.\n                </span>\n              </div>\n\n              <div className=\"flex flex-wrap items-center justify-between gap-3 text-[11px] text-zinc-500\">\n                <button \n                  onClick={() => setSupportOpen(true)}\n                  className=\"hover:text-white transition-colors flex items-center gap-1 cursor-pointer\"\n                >\n                  <HelpCircle className=\"w-3.5 h-3.5\" /> GFF Security Support\n                </button>\n                <div className=\"flex items-center gap-1.5\">\n                  <span className=\"h-1 w-1 bg-zinc-700 rounded-full\" />\n                  <span className=\"text-zinc-600\">Localhost Mode</span>\n                </div>\n              </div>\n            </div>\n          </section>\n\n          {/* RIGHT SIDE: Interactive Sandbox Role Simulator Panel */}\n          <section className=\"lg:col-span-6 bg-zinc-950/30 border border-white/5 backdrop-blur-xl rounded-3xl p-6 sm:p-10 flex flex-col justify-between shadow-[0_30px_100px_rgba(0,0,0,0.4)] min-h-[580px]\">\n            <div className=\"space-y-6\">\n              <div>\n                <span className=\"text-[9px] font-mono font-bold text-[#E4000F] bg-[#E4000F]/5 border border-[#E4000F]/15 px-3 py-1 rounded-full uppercase tracking-wider\">\n                  DEVELOPMENT SANDBOX\n                </span>\n                <h2 className=\"text-xl font-semibold tracking-tight text-white mt-3 font-sans\">\n                  Zero-Trust Enclave Simulator\n                </h2>\n                <p className=\"text-xs text-zinc-400 mt-2 leading-relaxed\">\n                  Select a mock profile block below to instantly load different clearance credentials, dynamic scopes, and verify role-based permissions.\n                </p>\n              </div>\n\n              {/* LIST OF SIMULATED ROLES */}\n              <div className=\"space-y-2 max-h-[220px] overflow-y-auto pr-1 select-none scrollbar-thin scrollbar-thumb-zinc-800\">\n                {rolesList.map((r) => {\n                  const isSel = selectedRole === r.id;\n                  const RoleIcon = r.icon;\n                  return (\n                    <button\n                      key={r.id}\n                      type=\"button\"\n                      onClick={() => setSelectedRole(r.id)}\n                      className={`w-full p-2.5 rounded-xl border text-left cursor-pointer flex justify-between items-center transition-all text-xs group ${\n                        isSel \n                          ? isClientRole \n                            ? \"border-[#009DFF]/30 bg-[#009DFF]/5 text-white\" \n                            : \"border-[#E4000F]/30 bg-[#E4000F]/5 text-white\" \n                          : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-zinc-400 hover:text-white\"\n                      }`}\n                    >\n                      <div className=\"flex items-center gap-3 min-w-0\">\n                        <div className={`p-1.5 rounded-lg bg-black ${isSel ? \"border border-white/10\" : \"\"}`}>\n                          <RoleIcon className={`w-4 h-4 ${r.color} shrink-0`} />\n                        </div>\n                        <div className=\"min-w-0\">\n                          <span className=\"font-semibold block truncate text-zinc-200 group-hover:text-white\">{r.label}</span>\n                          <span className=\"text-[10px] text-zinc-500 font-sans block truncate mt-0.5\">{r.desc}</span>\n                        </div>\n                      </div>\n                      <span className={`text-[8px] font-mono font-semibold border rounded px-2 py-0.5 shrink-0 ${\n                        isSel \n                          ? isClientRole \n                            ? \"border-[#009DFF]/30 text-[#009DFF] bg-[#009DFF]/5\" \n                            : \"border-[#E4000F]/30 text-[#E4000F] bg-[#E4000F]/5\"\n                          : \"border-white/10 text-zinc-500\"\n                      }`}>\n                        {r.clearance}\n                      </span>\n                    </button>\n                  );\n                })}\n              </div>\n\n              {/* REAL-TIME DYNAMIC HANDSHAKE DIAGRAM (PUBLIC INNER DESIGN COMPONENT) */}\n              <div className=\"space-y-2\">\n                <span className=\"text-[9px] font-mono font-semibold text-zinc-500 uppercase tracking-widest block\">\n                  Active Security Handshake Topology\n                </span>\n                \n                <div className=\"w-full h-24 relative bg-black/40 rounded-xl border border-white/5 flex items-center justify-between p-4 overflow-hidden\">\n                  {/* Grid Background */}\n                  <div className=\"absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:10px_10px]\" />\n                  \n                  <div className=\"z-10 flex flex-col items-center gap-1.5\">\n                    <div className={`p-1.5 rounded-lg bg-black border transition-all ${\n                      isClientRole ? \"border-cyan-500/20 text-cyan-400\" : \"border-red-500/20 text-red-400\"\n                    }`}>\n                      <Users className=\"w-3.5 h-3.5\" />\n                    </div>\n                    <span className=\"text-[8px] font-mono font-medium text-zinc-400 uppercase tracking-wider\">IDENTITY</span>\n                  </div>\n\n                  {/* Connection Line 1 */}\n                  <div className=\"flex-1 h-0.5 relative mx-2\">\n                    <svg className=\"w-full h-4 absolute -top-1.5 overflow-visible\">\n                      <line x1=\"0%\" y1=\"50%\" x2=\"100%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1.5\" />\n                      <line \n                        x1=\"0%\" y1=\"50%\" x2=\"100%\" y2=\"50%\" \n                        stroke={isClientRole ? \"#009DFF\" : \"#E4000F\"} \n                        strokeWidth=\"1.5\" \n                        strokeDasharray=\"5, 5\" \n                        className=\"animate-[dash_1s_linear_infinite]\" \n                      />\n                    </svg>\n                  </div>\n\n                  <div className=\"z-10 flex flex-col items-center gap-1.5\">\n                    <div className=\"p-2 rounded-full border border-zinc-800 bg-black/90 relative\">\n                      <div className={`absolute inset-0 rounded-full animate-ping opacity-15 ${\n                        isClientRole ? \"bg-[#009DFF]\" : \"bg-[#E4000F]\"\n                      }`} />\n                      <Shield className={`w-4 h-4 ${isClientRole ? \"text-cyan-400\" : \"text-red-400\"}`} />\n                    </div>\n                    <span className=\"text-[8px] font-mono font-medium text-zinc-400 uppercase tracking-wider\">GATEWAY</span>\n                  </div>\n\n                  {/* Connection Line 2 */}\n                  <div className=\"flex-1 h-0.5 relative mx-2\">\n                    <svg className=\"w-full h-4 absolute -top-1.5 overflow-visible\">\n                      <line x1=\"0%\" y1=\"50%\" x2=\"100%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1.5\" />\n                      <line \n                        x1=\"0%\" y1=\"50%\" x2=\"100%\" y2=\"50%\" \n                        stroke={isClientRole ? \"#009DFF\" : \"#E4000F\"} \n                        strokeWidth=\"1.5\" \n                        strokeDasharray=\"5, 5\" \n                        className=\"animate-[dash_1s_linear_infinite]\" \n                      />\n                    </svg>\n                  </div>\n\n                  <div className=\"z-10 flex flex-col items-center gap-1.5 min-w-[70px]\">\n                    <div className={`p-1.5 rounded-lg bg-black border transition-all ${\n                      isClientRole ? \"border-cyan-500/20 text-cyan-400\" : \"border-red-500/20 text-red-400\"\n                    }`}>\n                      <Cpu className=\"w-3.5 h-3.5\" />\n                    </div>\n                    <span className=\"text-[8px] font-mono font-medium text-zinc-400 uppercase tracking-wider truncate max-w-[80px]\">\n                      {isClientRole ? \"/portal/db\" : \"/admin/db\"}\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            {/* CURRENT ACTIVE IDENTITY PROFILE DETAILS */}\n            <div className=\"pt-6 border-t border-white/5 space-y-4\">\n              <div className=\"p-4 rounded-2xl border border-white/5 bg-black/40 space-y-3\">\n                <div className=\"flex justify-between items-center\">\n                  <span className=\"text-[8px] font-mono font-bold text-zinc-500 uppercase tracking-widest\">Active Sim Credentials</span>\n                  <span className={`text-[8px] font-mono font-bold px-2 py-0.5 rounded ${\n                    isClientRole ? \"bg-[#009DFF]/10 text-[#009DFF]\" : \"bg-[#E4000F]/10 text-[#E4000F]\"\n                  }`}>\n                    {isClientRole ? \"CLIENT PORTAL\" : \"GFF INTERNAL\"}\n                  </span>\n                </div>\n                \n                <div className=\"space-y-1\">\n                  <h4 className=\"text-xs font-semibold text-white leading-none uppercase truncate\">{currentMockUser.name}</h4>\n                  <p className=\"text-[10px] text-zinc-500 font-mono truncate\">{currentMockUser.email}</p>\n                </div>\n                \n                <div className=\"h-[1px] bg-white/5 w-full\" />\n                \n                <div className=\"flex items-start justify-between text-[10px] text-zinc-400 leading-normal gap-4 font-sans\">\n                  <div>\n                    <span className=\"text-zinc-600 block text-[8px] uppercase font-mono tracking-wider\">Assigned Clearance</span>\n                    <strong className=\"text-zinc-200\">{activeRoleObj.clearance}</strong>\n                  </div>\n                  <div className=\"text-right\">\n                    <span className=\"text-zinc-600 block text-[8px] uppercase font-mono tracking-wider\">Access Route</span>\n                    <strong className=\"text-zinc-200\">{isClientRole ? \"/portal/dashboard\" : \"/admin/dashboard\"}</strong>\n                  </div>\n                </div>\n              </div>\n\n              {/* Instant Handshake Bypass button */}\n              <button\n                type=\"button\"\n                onClick={() => handleAuthenticate()}\n                className={`w-full h-10 rounded-xl font-bold text-[10px] uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer active:scale-[0.98] transition-all ${\n                  isClientRole \n                    ? \"bg-[#009DFF] hover:bg-[#009DFF]/90 text-white hover:shadow-[0_0_20px_rgba(0,157,255,0.2)]\" \n                    : \"bg-[#E4000F] hover:bg-[#E4000F]/90 text-white hover:shadow-[0_0_20px_rgba(228,0,15,0.2)]\"\n                }`}\n              >\n                <Fingerprint className=\"w-4 h-4 animate-pulse\" /> Instant Handshake Handover\n              </button>\n            </div>\n          </section>\n\n        </main>\n      </div>\n\n      {/* MODAL 1: Forgot Password System Alert Modal */}\n      {forgotPasswordOpen && (\n        <div className=\"fixed inset-0 bg-black/80 backdrop-blur-md z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-zinc-950 border border-white/10 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-[0_30px_70px_rgba(0,0,0,0.9)] animate-in fade-in duration-200\">\n            <div className=\"flex items-center gap-2.5 text-[#E4000F]\">\n              <Lock className=\"w-5 h-5\" />\n              <h3 className=\"text-sm font-semibold uppercase tracking-wider font-mono\">Enclave Clearance Restriction</h3>\n            </div>\n            \n            <p className=\"text-xs text-zinc-400 leading-relaxed font-sans\">\n              Self-service credential resets are strictly disabled under sovereign security policies. To register a new security key or update authorization tags, please request assistance from GFF Global Command.\n            </p>\n\n            <div className=\"p-3.5 rounded-xl border border-white/5 bg-black/40 text-[10px] font-mono text-zinc-500 space-y-1\">\n              <div>Reference Code: SEC-PASS-RESET-2026-A</div>\n              <div>Security Status: LEVEL III+ STRICT RESTRICTION</div>\n            </div>\n\n            <div className=\"flex justify-end gap-3 pt-2\">\n              <button\n                onClick={() => setForgotPasswordOpen(false)}\n                className=\"px-4 py-2 bg-white/10 hover:bg-white/15 text-white rounded-lg text-xs font-semibold cursor-pointer transition-all\"\n              >\n                Close Handshake\n              </button>\n              <button\n                onClick={() => {\n                  setForgotPasswordOpen(false);\n                  setSupportOpen(true);\n                }}\n                className=\"px-4 py-2 bg-[#009DFF] hover:bg-[#009DFF]/90 text-white rounded-lg text-xs font-semibold cursor-pointer transition-all\"\n              >\n                Contact Support\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* MODAL 2: Support Ticket Wire Modal */}\n      {supportOpen && (\n        <div className=\"fixed inset-0 bg-black/80 backdrop-blur-md z-50 flex items-center justify-center p-4\">\n          <div className=\"bg-zinc-950 border border-white/10 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-[0_30px_70px_rgba(0,0,0,0.9)] animate-in fade-in duration-200\">\n            <div className=\"flex items-center gap-2.5 text-[#009DFF]\">\n              <HelpCircle className=\"w-5 h-5\" />\n              <h3 className=\"text-sm font-semibold uppercase tracking-wider font-mono\">GFF AI Systems Desk</h3>\n            </div>\n            \n            <p className=\"text-xs text-zinc-400 leading-relaxed font-sans\">\n              The GFF Security Operations Center (SOC) is active 24/7/365 to triage federated SSO handshakes and assign temporary local clearance credentials.\n            </p>\n\n            <div className=\"p-3.5 rounded-xl border border-white/5 bg-black/40 text-[10px] font-mono text-zinc-400 space-y-1.5 leading-normal\">\n              <div className=\"text-[#009DFF] font-semibold\">Direct Communication Lines:</div>\n              <div>Global Support Wire: +1 (800) GFF-CORE</div>\n              <div>Secure Email Router: support@gff.ai</div>\n              <div>System Handshake Token: <code className=\"bg-zinc-900 px-1 py-0.5 rounded text-white font-mono text-[9px]\">GFF-SEC-GATE-2026-LOCAL</code></div>\n            </div>\n\n            <div className=\"flex justify-end pt-2\">\n              <button\n                onClick={() => setSupportOpen(false)}\n                className=\"px-4 py-2 bg-white/10 hover:bg-white/15 text-white rounded-lg text-xs font-semibold cursor-pointer transition-all\"\n              >\n                Acknowledge Wire\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}"}}}
