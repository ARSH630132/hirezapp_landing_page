abel: \"FastAPI MVP Setup\",\n 42 |     title: \"Local MVP Backend Gateway\",\n 43 |     subtitle: \"Install dependencies, run idempotent seeders, and boot local server.\",\n 44 |     code: `# 1. Automated Virtualenv Setup & Package Installation\n 45 | npm run backend:install\n 46 | \n 47 | # 2. Initialize and Seed SQLite Database (dev.db)\n 48 | npm run backend:seed\n 49 | \n 50 | # 3. Boot Uvicorn ASGI Server on http://localhost:8000\n 51 | npm run backend:dev\n 52 | \n 53 | # 4. Bind Frontend by adding to root .env:\n 54 | # NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1`,\n 55 |     notes: \"Requires Python v3.12+ and SQLite3. Creates local SQLite database file.\"\n 56 |   }\n 57 | };\n 58 | \n 59 | type TerminalKey = keyof typeof TERMINAL_TABS;\n 60 | \n 61 | // 2. Pre-Seeded Developer Accounts Data\n 62 | const DEV_USERS = [\n 63 |   {\n 64 |     email: \"gff_admin@gff.ai\",\n 65 |     role: \"gff_admin\",\n 66 |     tenant: \"Platform Global\",\n 67 |     pass: \"password123\",\n 68 |     desc: \"Oversee enterprise client registries, query system-wide usage logs, review support ticket queues, and verify network telemetry metrics.\"\n 69 |   },\n 70 |   {\n 71 |     email: \"client_admin@apex.com\",\n 72 |     role: \"client_admin\",\n 73 |     tenant: \"Apex Global\",\n 74 |     pass: \"password123\",\n 75 |     desc: \"Manage Apex-specific project sandboxes, audit dynamic LLM computational invoices, review secure service agreements, and issue support tickets.\"\n 76 |   },\n 77 |   {\n 78 |     email: \"client_member@apex.com\",\n 79 |     role: \"client_member\",\n 80 |     tenant: \"Apex Global\",\n 81 |     pass: \"password123\",\n 82 |     desc: \"Collaborate on multi-agent execution pipelines, raise developer support requests, and inspect real-time tenant compliance standards.\"\n 83 |   },\n 84 |   {\n 85 |     email: \"client@chevron.com\",\n 86 |     role: \"client\",\n 87 |     tenant: \"Chevron Corp\",\n 88 |     pass: \"chevron_secure_pass_