M_NODES = {\n132 |   frontend: {\n133 |     title: \"Next.js Frontend Workspace\",\n134 |     desc: \"Premium, Apple-like cockpit displaying multi-tenant dashboards, telemetry widgets, and sandbox configurations.\",\n135 |     details: \"Runs locally on port 3000. Communicates with local API endpoints using NEXT_PUBLIC_API_BASE_URL. Falls back to client-side mocks if the backend is down.\"\n136 |   },\n137 |   api: {\n138 |     title: \"FastAPI Local MVP Engine\",\n139 |     desc: \"Fast, asynchronous Python API routing secure handshakes, role authorizations (RBAC), and multi-tenant ledger synchronization.\",\n140 |     details: \"Runs locally on port 8000. Generates automated interactive API specifications via Swagger UI (/docs) and routes endpoints under /api/v1.\"\n141 |   },\n142 |   db: {\n143 |     title: \"Idempotent SQLite Database\",\n144 |     desc: \"Zero-configuration SQL engine storing relational records inside the 'backend/dev.db' binary payload file.\",\n145 |     details: \"Pre-populated with rich mock datasets including secure documents, project pipelines, compliance logs, and billing invoices via app/seed.py.\"\n146 |   }\n147 | };\n148 | \n149 | type DiagramKey = keyof typeof DIAGRAM_NODES;\n150 | \n151 | // 5. Troubleshooting Data\n152 | const FAQ_ITEMS = [\n153 |   {\n154 |     q: \"How do I resolve Cross-Origin Resource Sharing (CORS) connection errors?\",\n155 |     a: \"CORS blocks occur when the backend does not authorize requests originating from the frontend domain. Verify your backend/.env contains the exact frontend URL (usually CORS_ORIGINS='http://localhost:3000'). Separate multiple origins by commas with no spaces. Restart the FastAPI server to register modifications.\"\n156 |   },\n157 |   {\n158 |     q: \"The terminal displays 'SQLite OperationalError: no such table' — what is missing?\",\n159 |     a: \"Your SQLite database is not yet initialized or has missing schemas. Run the seeder from the root directory: 'npm run backend:seed' to bootstrap schemas and default multi-tenant accounts in the dev.db file. Make sure your Python venv is correctly activated.\"\n160 |   },\n161 |   {\n162 |     q: \"Why do subsequent queries return 401 Unauthorized or redirect back to login?\",\n163 |     a: \"Your local JSON Web Token (JWT) is invalid, expired, or was signed using a different secret key. If you modified JWT_SECRET in your backend/.env, open the browser developer console and execute 'localStorage.clear();' to clear expired tokens, then re-authenticate.\"\n164 |   },\n165 |   {\n166 |     q: \"The database seeder fails due to duplicate key or unique constraint violations.\",\n167 |     a: \"The seeder is designed to be idempotent and ignore duplicate keys under normal operations. If structural schema modifications have occurred, drop the tables and trigger a fresh database rebuild by executing 'npm run backend:seed -- --reset' from the root workspace.\"\n168 |   }\n169 | ];\n170 | \n171 | \n172 | export default function DeveloperDocsPage() {\n173 |   const [activeTab, setActiveTab] = useState<TerminalKey>(\"cli\");\n174 |   const [selectedNode, setSelectedNode] = useState<DiagramKey>(\"api\");\n175 |   const [copied, setCopied] = useState(false);\n176 |   const [activeFaq, setActiveFaq] = useState<number | null>(null);\n177 | \n178 |   const copyToClipboard = (text: string) => {\n179 |     navigator.clipboard.writeText(text);\n180 |     setCopied(true);\n181 |     setTimeout(() => setCopied(false), 2000);\n182 |   };\n183 | \n184 |   return (\n185 |     <InnerPageShell>\n186 |       <InnerPageHero\n187 |         category=\"Sovereign Developer Hub\"\n188 |         title=\"Local Sandbox & Developer Guide\"\n189 |         highlightedWord=\"Developer Guide\"\n190 |         description=\"Comprehensive setup specifications, cryptographic handshake protocols, and interactive references for configuring the Phase 5 local MVP backend.\"\n191 |         breadcrumbs={[\n192 |           { label: \"Home\", href