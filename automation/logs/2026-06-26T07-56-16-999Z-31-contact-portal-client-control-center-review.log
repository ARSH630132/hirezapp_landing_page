=\"1.5\" strokeOpacity=\"0.4\" strokeDasharray=\"5,5\" />\n                      <line x1=\"300\" y1=\"60\" x2=\"200\" y2=\"140\" stroke=\"#E4000F\" strokeWidth=\"1.5\" strokeOpacity=\"0.4\" strokeDasharray=\"5,5\" />\n                      <line x1=\"100\" y1=\"60\" x2=\"300\" y2=\"60\" stroke=\"white\" strokeWidth=\"1\" strokeOpacity=\"0.1\" />\n\n                      {/* Nodes */}\n                      {[\n                        { id: \"retail\", cx: 100, cy: 60, color: \"#009DFF\", label: \"RETAIL\" },\n                        { id: \"ore\", cx: 300, cy: 60, color: \"#E4000F\", label: \"ORE-MESH\" },\n                        { id: \"governance\", cx: 200, cy: 140, color: \"#a855f7\", label: \"GOV-CORE\" }\n                      ].map(n => {\n                        const active = selectedNode === n.id;\n                        return (\n                          <g key={n.id} className=\"cursor-pointer group\" onClick={() => setSelectedNode(n.id)}>\n                            {active && (\n                              <circle cx={n.cx} cy={n.cy} r=\"18\" fill={n.color} fillOpacity=\"0.15\" className=\"animate-pulse\" />\n                            )}\n                            <circle\n                              cx={n.cx}\n                              cy={n.cy}\n                              r={active ? \"11\" : \"7\"}\n                              fill=\"#050505\"\n                              stroke={active ? n.color : \"rgba(255,255,255,0.2)\"}\n                              strokeWidth=\"2\"\n                              className=\"transition-all duration-300 group-hover:stroke-white\"\n                            />\n                            <circle cx={n.cx} cy={n.cy} r=\"3\" fill={n.color} />\n                            <text x={n.cx} y={n.cy - 16} textAnchor=\"middle\" fill={active ? \"white\" : \"rgba(255,255,255,0.4)\"} className=\"text-[9px] font-mono font-bold tracking-wider transition-all duration-300 group-hover:fill-white\">\n                              {n.label}\n                            </text>\n                          </g>\n                        );\n                      })}\n                    </svg>\n                  </div>\n                  <div className=\"font-mono text-[9px] text-white/30 text-center mt-2\">\n                    ACTIVE NODES: 3 / REGISTRY COHORT v1.2\n                  </div>\n                </div>\n\n                {/* Node Telemetry Dashboard Readout (Col-7) */}\n                <div className=\"xl:col-span-7 p-5 rounded-xl border border-white/5 bg-[#020202]/50 font-mono space-y-4\">\n                  <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n                    <div>\n                      <span className=\"text-[10px] text-white/30 uppercase tracking-widest block\">Selected Diagnostic Node</span>\n                      <h4 className=\"text-sm font-bold text-white tracking-wide mt-0.5\">{nodesInfo[selectedNode].name}</h4>\n                    </div>\n                    <span className=\"px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded uppercase text-[9px] font-bold\">\n                      {nodesInfo[selectedNode].status}\n                    </span>\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-3 text-[11px]\">\n                    <div className=\"p-2.5 rounded bg-white/[0.01] border border-white/5\">\n                      <span className=\"text-[9px] text-white/40 block uppercase\">Core Load</span>\n                      <span className=\"text-white font-bold mt-1 block\">{nodesInfo[selectedNode].load}</span>\n                    </div>\n                    <div className=\"p-2.5 rounded bg-white/[0.01] border border-white/5\">\n                      <span className=\"text-[9px] text-white/40 block uppercase\">Memory State</span>\n                      <span className=\"text-white font-bold mt-1 block\">{nodesInfo[selectedNode].mem}</span>\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-2 mt-2\">\n                    <span className=\"text-[10px] text-white/40 block uppercase tracking-wider\">Real-time Node Event stream</span>\n                    <div className=\"p-3 bg-black/60 rounded border border-white/5 space-y-1.5 min-h-[90px] text-[11px] text-white/60\">\n                      {nodesInfo[selectedNode].logs.map((log, idx) => (\n                        <div key={idx} className=\"flex justify-between hover:text-white transition-colors\">\n                          <span className=\"truncate\">{log.split(\" (\")[0]}</span>\n                          {log.includes(\"SHA-256\") && (\n                            <span className=\"text-[#009DFF] text-[10px] uppercase font-bold shrink-0\">{log.split(\" (\")[1]?.replace(\")\", \"\")}</span>\n                          )}\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n            </div>\n          )}"}}}
