          {isScanning ? \"Scanning...\" : \"Scan Compliance Matrix\"}\n429 |           </button>\n430 |         </div>\n431 |       </div>\n432 | \n433 |       {/* Scan Drawer */}\n434 |       {isScanning && (\n435 |         <motion.div initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: \"auto\" }} className=\"border border-white/5 bg-black/40 rounded-xl p-3 space-y-2 overflow-hidden\">\n436 |           <div className=\"flex items-center justify-between text-[9px] text-amber-400\"><span>SECURE LIVE SCAN RUN</span><span>{scanProgress}% SECURED</span></div>\n437 |           <div className=\"w-full bg-white/5 h-1 rounded-full overflow-hidden\"><div className=\"bg-amber-500 h-full transition-all\" style={{ width: `${scanProgress}%` }} /></div>\n438 |           <pre className=\"text-[9.5px] text-white/50 leading-relaxed max-h-[100px] overflow-y-auto p-2 bg-black/80 rounded border border-white/5 font-mono\">{scanLog}</pre>\n439 |         </motion.div>\n440 |       )}\n441 | \n442 |       {/* Metrics Grid */}\n443 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n444 |         <WorkspaceCard className=\"border-[#009DFF]/10\">\n445 |           <div className=\"space-y-1\">\n446 |             <div className=\"text-[9px] text-white/40 uppercase\">Active Sandbox Escapes</div>\n447 |             <div className=\"text-xl font-bold text-white flex items-baseline gap-1.5\"><span>{activeAlertsCount}</span><span className=\"text-[8px] text-rose-400 px-1 rounded bg-rose-500/10 border border-rose-500/20\">FLAGS</span></div>\n448 |             <div className=\"text-[9px] text-white/45 pt-2 border-t border-white/5 mt-2 flex justify-between\"><span>Awaiting review</span><span className=\"text-[#009DFF] font-bold\">Priority High</span></div>\n449 |           </div>\n450 |         </WorkspaceCard>\n451 | \n452 |         <WorkspaceCard className=\"border-[#00FFC2]/10\">\n453 |           <div className=\"space-y-1\">\n454 |             <div className=\"text-[9px] text-white/40 uppercase\">System Compliance Score</div>\n455 |             <div className=\"text-xl font-bold text-[#00FFC2]\">{overallScore}%</div>\n456 |             <div className=\"text-[9px] text-white/45 pt-2 border-t border-white/5 mt-2 flex justify-between\"><span>Active policies</span><span className=\"text-[#00FFC2] font-bold\">{policies.filter(p => p.enforced).length} Rules</span></div>\n457 |           </div>\n458 |         </WorkspaceCard>\n459 | \n460 |         <WorkspaceCard className=\"border-amber-500/10\">\n461 |           <div className=\"space-y-1\">\n462 |             <div className=\"text-[9px] text-white/40 uppercase\">Hardware Key Sealing</div>\n463 |             <div className=\"text-xl font-bold\"><span className={hsmStatus === \"ROTATING\" ? \"text-amber-400 animate-pulse\" : \"text-emerald-400\"}>{hsmStatus === \"ROTATING\" ? \"ROTATING...\" : hsmStatus === \"ROTATED\" ? \"RE-SEALED\" : \"SEALED\"}</span></div>\n464 |             <div className=\"text-[9px] text-white/45 pt-2 border-t border-white/5 mt-2 flex justify-between items-center\"><span>Dual-signatory HSM</span><span className=\"text-white/50\">v4.1.8</span></div>\n465 |           </div>\n466 |         </WorkspaceCard>\n467 | \n468 |         <WorkspaceCard className=\"border-white/5\">\n469 |           <div className=\"space-y-1\">\n470 |             <div className=\"text-[9px] text-white/40 uppercase\">Continuous Tracing</div>\n471 |             <div className=\"text-xl font-bold text-white\">18 Nodes</div>\n472 |             <div className=\"text-[9px] text-white/45 pt-2 border-t border-white/5 mt-2 flex justify-between\"><span>eBPF telemetry pipe</span><span className=\"text-emerald-400 font-bold\">99.998% Sync</span></div>\n473 |           </div>\n474 |         </WorkspaceCard>\n475 |       </div>\n476 | \n477 |       <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-start\">\n478 |         <div className=\"lg:col-span-2 space-y-4\">\n479 |           <div className=\"flex border-b border-white/5 gap-4\">\n480 |             <button\n481 |               onClick={() => setActiveTab(\"alert-ledger\")}\n482 |               className={`pb-2.5 font-bold uppercase text-[9.5px] tracking-wider relative flex items-center gap-1.5 cursor-pointer ${\n483 |                 activeTab === \"alert-ledger\" ? \"text-[#009DFF]\" : \"text-white/45 hover:text-white\"\n484 |               }`}\n485 |             >\n486 |               <ShieldAlert className=\"w-3.5 h-3.5\" />\n487 |               <span>Alert Ledger ({filteredAlerts.length})</span>\n488 |               {activeTab === \"alert-ledger\" && <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />}\n489 |             </button>\n490 | \n491 |             <button\n492 |               onClick={() => setActiveTab(\"guardrail-matrix\")}\n493 |               className={`pb-2.5 font-bold uppercase text-[9.5px] tracking-wider relative flex items-center gap-1.5 cursor-pointer ${\n494 |                 activeTab === \"guardrail-matrix\" ? \"text-[#009DFF]\" : \"text-white/45 hover:text-white\"\n495 |               }`}\n496 |             >\n497 |               <Settings className=\"w-3.5 h-3.5\" />\n498 |               <span>Guardrail Matrix</span>\n499 |               {activeTab === \"guardrail-matrix\" && <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />}\n500 |             </button>","success":true}],"durationMs":3}}
