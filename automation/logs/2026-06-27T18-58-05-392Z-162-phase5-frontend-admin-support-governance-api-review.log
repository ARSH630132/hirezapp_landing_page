ll communication lines are clear or filters yielded no active handshakes.</p>\n548 |         </div>\n549 |       ) : (\n550 |         <>\n551 |           <div className=\"hidden md:block border border-white/5 rounded-xl bg-[#050505]/20 overflow-hidden\">\n552 |           <table className=\"w-full text-left border-collapse font-mono text-[11px]\">\n553 |             <thead>\n554 |               <tr className=\"border-b border-white/5 bg-white/[0.01] text-[9.5px] text-white/40 uppercase tracking-wider\">\n555 |                 <th className=\"py-3 px-4 font-semibold\">ID</th>\n556 |                 <th className=\"py-3 px-4 font-semibold\">Subject & Client</th>\n557 |                 <th className=\"py-3 px-4 font-semibold\">Priority</th>\n558 |                 <th className=\"py-3 px-4 font-semibold\">Category</th>\n559 |                 <th className=\"py-3 px-4 font-semibold\">Status</th>\n560 |                 <th className=\"py-3 px-4 font-semibold\">Assigned Engineer</th>\n561 |                 <th className=\"py-3 px-4 font-semibold\">Assets</th>\n562 |                 <th className=\"py-3 px-4 font-semibold text-right\">SLA countdown</th>\n563 |               </tr>\n564 |             </thead>\n565 |             <tbody>\n566 |               {filteredTickets.map((t) => (\n567 |               <tr \n568 |                 key={t.id}\n569 |                 onClick={() => setSelectedTicketId(t.id)}\n570 |                 onKeyDown={(e) => {\n571 |                   if (e.key === \"Enter\" || e.key === \" \") {\n572 |                     e.preventDefault();\n573 |                     setSelectedTicketId(t.id);\n574 |                   }\n575 |                 }}\n576 |                 tabIndex={0}\n577 |                 role=\"button\"\n578 |                 aria-pressed={selectedTicketId === t.id}\n579 |                 className={`border-b border-white/[0.02] last:border-0 hover:bg-white/[0.02] focus:bg-white/[0.03] outline-none cursor-pointer transition-colors ${selectedTicketId === t.id ? \"bg-white/[0.02]\" : \"\"}`}\n580 |               >\n581 |                 <td className=\"py-3 px-4 font-bold text-[#009DFF]\">\n582 |                   <div className=\"flex items-center gap-1.5\">\n583 |                     <span>{t.id}</span>\n584 |                     <button \n585 |                       onClick={(e) => handleCopyId(e, t.id)} \n586 |                       className=\"opacity-40 hover:opacity-100 p-0.5 focus:opacity-100 outline-none rounded hover:bg-white/5\" \n587 |                       title=\"Copy SLA Wire ID\"\n588 |                     >\n589 |                       {copiedTicketId === t.id ? <Check className=\"w-3 h-3 text-emerald-400\" /> : <Copy className=\"w-3 h-3\" />}\n590 |                     </button>\n591 |                   </div>\n592 |                 </td>\n593 |                 <td className=\"py-3 px-4\">\n594 |                   <div className=\"space-y-0.5\">\n595 |                     <span className=\"text-white font-semibold block truncate max-w-[250px]\">{t.subject}</span>\n596 |                     <span className=\"text-white/30 text-[9.5px] block uppercase\">{t.client.split(\" [\")[0]}</span>\n597 |                   </div>\n598 |                 </td>\n599 |                 <td className=\"py-3 px-4\">\n600 |                   <span className={`inline-flex px-1.5 py-0.5 rounded border text-[9px] font-bold ${getPriorityBadgeStyles(t.priority)}`}>\n601 |                     {t.priority} SLA\n602 |                   </span>\n603 |                 </td>\n604 |                 <td className=\"py-3 px-4 text-white/70\">{t.category.toUpperCase()}</td>\n605 |                 <td className=\"py-3 px-4\">\n606 |                   {(() => {\n607 |                     const styles = getStatusStyles(t.status);\n608 |                     return (\n609 |                       <span className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded border text-[9px] font-bold ${styles.bgClass} ${styles.t