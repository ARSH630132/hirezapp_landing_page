xport async function PATCH(req: Request, { params }: { params: any }) {\n36 |   try {\n37 |     const caller = getAuthCaller(req);\n38 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n39 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n40 |     const { id } = await params;\n41 |     const project = (API_MOCK_PROJECTS as Record<string, ApiProject>)[id];\n42 |     if (!project) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n43 |     const body = await req.json().catch(() => null);\n44 |     if (!body) return NextResponse.json({ success: false, error: \"Bad Request\" }, { status: 400 });\n45 | \n46 |     const fields = [\"name\", \"phase\", \"status\", \"health\", \"owner\", \"nodesCount\", \"enclaveType\", \"desc\", \"client_id\"];\n47 |     for (const key of fields) {\n48 |       if (body[key] !== undefined) {\n49 |         if (key === \"name\" && (typeof body.name !== \"string\" || !body.name.trim())) {\n50 |           return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid name\" }, { status: 400 });\n51 |         }\n52 |         if (key === \"client_id\") {\n53 |           const valids = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n54 |           if (!valids.includes(body.client_id)) {\n55 |             return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id\" }, { status: 400 });\n56 |           }\n57 |           project.client_id = body.client_id;\n58 |           project.client_name = getClientNameFromId(body.client_id);\n59 |         } else if (key === \"nodesCount\") {\n60 |           if (typeof body.nodesCount !== \"number\") return NextResponse.json({ success: false, error: \"Bad Request\" }, { status: 400 });\n61 |           project.nodesCount = body.nodesCount;\n62 |         } else {\n63 |           (project as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n64 |         }\n65 |       }\n66 |     }\n67 |     project.lastUpdated = new Date().toISOString();\n68 |     (API_MOCK_PROJECTS as Record<string, ApiProject>)[id] = project;\n69 |     return NextResponse.json({ success: true, project });\n70 |   } catch (err) {\n71 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n72 |   }\n73 | }\n74 | \n75 | export async function DELETE(req: Request, { params }: { params: any }) {\n76 |   try {\n77 |     const caller = getAuthCaller(req);\n78 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n79 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n80 |     const { id } = await params;\n81 |     if (!(API_MOCK_PROJECTS as Record<string, ApiProject>)[id]) {\n82 |       return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n83 |     }\n84 |     delete (API_MOCK_PROJECTS as Record<string, ApiProject>)[id];\n85 |     return NextResponse.json({ success: true, message: \"Project deleted.\" });\n86 |   } catch (err) {\n87 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n88 |   }\n89 | }","success":true}],"durationMs":4}}
