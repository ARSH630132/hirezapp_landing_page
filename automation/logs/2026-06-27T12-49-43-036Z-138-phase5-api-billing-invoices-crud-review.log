div>\n216 |             ))}\n217 |           </div>\n218 |         </div>\n219 |       )}\n220 | \n221 |       {/* Drawer Overlay for Single Invoice detailed audit */}\n222 |       {selInvoice && (\n223 |         <div className=\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex justify-end\">\n224 |           <div className=\"w-full max-w-md h-full bg-[#050505] border-l border-white/10 p-6 overflow-y-auto space-y-6 flex flex-col justify-between\">\n225 |             <div className=\"space-y-6\">\n226 |               <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n227 |                 <div>\n228 |                   <span className=\"text-[9px] bg-blue-500/10 border border-blue-500/20 text-[#009DFF] px-1.5 py-0.5 rounded font-mono font-bold uppercase\">Enclave verification</span>\n229 |                   <h3 className=\"text-lg font-bold text-white font-mono mt-1\">{selInvoice.id}</h3>\n230 |                   <span className=\"text-[10px] text-white/40 font-mono block mt-0.5 font-bold font-mono\">Project: {PROJECTS[selInvoice.id]}</span>\n231 |                 </div>\n232 |                 <button \n233 |                   onClick={() => {\n234 |                     setSelInvoice(null);\n235 |                     setContactSuccess(false);\n236 |                   }}\n237 |                   className=\"p-1 text-white/40 hover:text-white cursor-pointer text-sm font-mono\"\n238 |                 >\n239 |                   [CLOSE]\n240 |                 </button>\n241 |               </div>\n242 | \n243 |               <div className=\"space-y-4 font-mono text-[11px]\">\n244 |                 <div className=\"p-3.5 rounded bg-black border border-white/5 space-y-2\">\n245 |                   <div className=\"flex justify-between text-white/40 text-[10px]\">\n246 |                     <span>LEDGER CRYPTO SEAL</span>\n247 |                     <button onClick={() => handleCopy(selInvoice.hash, \"sel\")} className=\"text-[#009DFF] hov