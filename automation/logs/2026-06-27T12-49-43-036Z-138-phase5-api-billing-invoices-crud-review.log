4\">\n218 |           <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n219 |             <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Epoch Statements</h3>\n220 |             <Link \n221 |               href=\"/portal/billing/invoices\" \n222 |               className=\"text-[10px] font-mono text-[#009DFF] hover:underline flex items-center gap-1\"\n223 |             >\n224 |               <span>View All</span>\n225 |               <ArrowRight className=\"w-3 h-3\" />\n226 |             </Link>\n227 |           </div>\n228 | \n229 |           <div className=\"space-y-2.5\">\n230 |             {invoices.map((inv) => (\n231 |               <div \n232 |                 key={inv.id} \n233 |                 className={`p-3 rounded-lg border transition-all font-mono text-[10.5px] cursor-pointer ${\n234 |                   selProjectKey === inv.id \n235 |                     ? \"bg-white/[0.03] border-white/15\" \n236 |                     : \"bg-[#020202]/30 border-white/5 hover:border-white/10\"\n237 |                 }`}\n238 |                 onClick={() => setSelProjectKey(inv.id)}\n239 |               >\n240 |                 <div className=\"flex justify-between items-start\">\n241 |                   <div>\n242 |                     <span className=\"font-bold text-white block\">{inv.id}</span>\n243 |                     <span className=\"text-[9.5px] text-white/40 block mt-0.5\">{PROJECTS[inv.id]}</span>\n244 |                   </div>\n245 |                   <span className={`px-1.5 py-0.5 rounded text-[8px] font-bold uppercase ${\n246 |                     inv.status === \"paid\" ? \"bg-green-500/10 border border-green-500/20 text-green-400\" :\n247 |                     inv.status === \"processing\" ? \"bg-blue-500/10 border border-blue-500/20 text-[#009DFF]\" :\n248 |                     \"bg-amber-500/10 border border-amber-500/20 text-amber-400\"\n249 |                   }`}>\n250 |                     {inv.status}\n251 |                   </span>\n252 |                 </div>\n253 |                 \n254 |                 <div className=\"flex justify-between items-center mt-3 pt-2 border-t border-white/[0.03] text-[9.5px]\">\n255 |                   <span className=\"text-white/40\">{inv.category}</span>\n256 |                   <span className=\"text-white font-semibold\">{inv.amount}</span>\n257 |                 </div>\n258 | \n259 |                 <div className=\"flex justify-between items-center mt-2 text-[9.5px]\">\n260 |                   <button \n261 |                     onClick={(e) => {\n262 |                       e.stopPropagation();\n263 |                       setSelInvoice(inv);\n264 |                     }}\n265 |                     className=\"text-[#009DFF] hover:underline font-bold\"\n266 |                   >\n267 |                     Audit Drawer &gt;\n268 |                   </button>\n269 |                   <button \n270 |                     onClick={(e) => {\n271 |                       e.stopPropagation();\n272 |                       handleCopy(inv.hash, inv.id);\n273 |                     }}\n274 |                     className=\"text-white/30 hover:text-white\"\n275 |                   >\n276 |                     {copiedId === inv.id ? \"Copied Hash\" : \"Copy Hash\"}\n277 |                   </button>\n278 |                 </div>\n279 |               </div>\n280 |             ))}\n281 |           </div>\n282 |         </div>\n283 | \n284 |         {/* Contact Treasury Card */}\n285 |         <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n286 |           <div className=\"border-b border-white/5 pb-2\">\n287 |             <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Treasury Liaison Desk</h3>\n288 |             <p className=\"text-[10px] text-white/40 font-mono mt-0.5\">Encrypted non-automated wire support.</p>\n289 |   