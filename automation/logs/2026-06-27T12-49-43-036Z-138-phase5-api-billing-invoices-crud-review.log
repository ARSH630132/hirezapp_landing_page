d\");\n 56 |   const [month, setMonth] = useState(\"2026-06\");\n 57 | \n 58 |   // Signing State\n 59 |   const [signing, setSigning] = useState(false);\n 60 |   const [step, setStep] = useState(0);\n 61 | \n 62 |   const [isDownloading, setIsDownloading] = useState(false);\n 63 |   const [isProcessing, setIsProcessing] = useState(false);\n 64 | \n 65 |   const triggerToast = (m: string) => {\n 66 |     setToast(m);\n 67 |     setTimeout(() => setToast(null), 3000);\n 68 |   };\n 69 | \n 70 |   useEffect(() => {\n 71 |     let t: NodeJS.Timeout;\n 72 |     if (signing) {\n 73 |       t = setInterval(() => {\n 74 |         setStep(s => {\n 75 |           if (s < HSM_SIGNING_LOGS.length - 1) return s + 1;\n 76 |           clearInterval(t);\n 77 |           const cl = previewClientAccounts.find(x => x.id === cId);\n 78 |           const pr = previewProjects.find(x => x.id === pId);\n 79 |           const id = `GFF-2026-${String(invoices.length + 900).padStart(4, \"0\")}`;\n 80 |           const hash = `0x${Math.random().toString(16).slice(2, 12).toUpperCase()}`;\n 81 | \n 82 |           setInvoices(prev => [{\n 83 |             id, date: new Date().toISOString().split(\"T\")[0], amount: parseFloat(amount) || 0,\n 84 |             status, dueDate: due || \"2026-07-15\", category: \"Compute Epoch\", clientId: cId,\n 85 |             clientName: cl ? cl.name : \"Sovereign Client\", projectId: pId,\n 86 |             projectName: pr ? pr.name : \"Enclave Sandbox\", hash, billingMonth: month\n 87 |           }, ...prev]);\n 88 |           setSigning(false);\n 89 |           setStep(0);\n 90 |           setIsOpen(false);\n 91 |           setCId(\"\"); setAmount(\"\");\n 92 |           triggerToast(`Sealed invoice ${id} successfully.`);\n 93 |           return 0;\n 94 |         });\n 95 |       }, 600);\n 96 |     }\n 97 |     return () => clearInterval(t);\n 98 |   }, [signing, cId, pId, amount, due, status, month, invoices.length]);\n 99 | \n100 |   const projects = useMem