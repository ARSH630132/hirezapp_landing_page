      onClick={triggerReboot}\n 77 |           disabled={rebooting}\n 78 |           className=\"flex-grow inline-flex h-8 items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.01] text-[10.5px] font-bold text-white hover:bg-white/[0.04] hover:border-white/25 transition-all disabled:opacity-50 cursor-pointer select-none font-mono\"\n 79 |         >\n 80 |           {rebooting ? (\n 81 |             <>\n 82 |               <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#009DFF]\" />\n 83 |               <span>CYCLING HARDWARE...</span>\n 84 |             </>\n 85 |           ) : (\n 86 |             <>\n 87 |               <RefreshCw className=\"w-3.5 h-3.5\" />\n 88 |               <span>RECYCLE CORE ENCLAVE</span>\n 89 |             </>\n 90 |           )}\n 91 |         </button>\n 92 |       </div>\n 93 |     </WorkspaceCard>\n 94 |   );\n 95 | }\n 96 | \n 97 | // ==========================================\n 98 | // 2. PROJECT CARD\n 99 | // ==========================================\n100 | export function ProjectCard({ \n101 |   project \n102 | }: { \n103 |   project: ProjectSpec;\n104 | }) {\n105 |   return (\n106 |     <WorkspaceCard className=\"flex flex-col h-full justify-between\">\n107 |       <div className=\"space-y-3\">\n108 |         <div className=\"flex justify-between items-start select-none\">\n109 |           <div className=\"p-2 rounded bg-emerald-500/10 border border-emerald-500/20 text-emerald-400\">\n110 |             <Layers className=\"w-5 h-5\" />\n111 |           </div>\n112 |           <StatusBadge state={project.status === \"verified\" ? \"active\" : \"warning\"} label={project.status} />\n113 |         </div>\n114 |         <div>\n115 |           <h4 className=\"text-[13.5px] font-bold text-white font-mono tracking-tight\">{project.name.toUpperCase()}</h4>\n116 |           <p className=\"text-[11px] font-mono text-white/50 mt-1 leading-relaxed\">{project.desc}</p>\n117 |         </div>\n118 |       </div>