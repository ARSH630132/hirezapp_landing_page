  isRebooting: false\n    }))\n  );\n\n  const [projectFilter, setProjectFilter] = useState(\"all\");\n  const [typeFilter, setTypeFilter] = useState(\"all\");\n  const [statusFilter, setStatusFilter] = useState(\"all\");\n  const [stageFilter, setStageFilter] = useState(\"all\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [liveLog, setLiveLog] = useState(`[${new Date().toLocaleTimeString()}] Handshake established securely on Enclave 02`);\n\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const logs = [\n        \"Enclave 04: Syncing local context state\",\n        \"Guardrail: Prompt payload parsed - 0 anomalies\",\n        \"eBPF Telemetry: Memory footprint optimized at 27.2 GB\",\n        \"Ledger Seal: Committed SHA-256 block hash\"\n      ];\n      setLiveLog(`[${new Date().toLocaleTimeString()}] ${logs[Math.floor(Math.random() * logs.length)]}`);\n    }, 4500);\n    return () => clearInterval(timer);\n  }, []);\n\n  const handleReboot = (id: string) => {\n    setAgents(prev => prev.map(a => a.id === id ? { ...a, status: \"evaluating\", isRebooting: true, logs: [...a.logs, `[${new Date().toLocaleTimeString()}] REBOOTING CO-PROCESSOR ENCLAVE...`] } : a));\n    setTimeout(() => {\n      setAgents(prev => prev.map(a => a.id === id ? { \n        ...a, status: \"active\", isRebooting: false, cpu: Math.floor(Math.random() * 30) + 20, \n        logs: [...a.logs, `[${new Date().toLocaleTimeString()}] REBOOT OK. HANDSHAKE RESTORED.`] \n      } : a));\n    }, 1500);\n  };\n\n  const filtered = agents.filter(a => {\n    return (searchQuery === \"\" || a.name.toLowerCase().includes(searchQuery.toLowerCase())) &&\n      (projectFilter === \"all\" || a.projectId === projectFilter) &&\n      (typeFilter === \"all\" || a.type.toLowerCase() === typeFilter.toLowerCase()) &&\n      (statusFilter === \"all\" || a.status.toLowerCase() === statusFilter.toLowerCase()) &&\n      (stageFilter === \"all\" || a.stage.toLowerCase() === stageFilter.toLowerCase());\n  });\n\n  return (\n    <div className=\"space-y-6 max-w-[1700px] mx-auto pb-12 select-none\">\n      \n      {/* Disclaimer Banner */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-2.5 flex flex-col sm:flex-row items-center justify-between gap-3 font-mono text-[10.5px]\">\n        <div className=\"flex items-center gap-2 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span><strong className=\"text-white\">PREVIEW TELEMETRY COMMAND:</strong> Displaying isolated deterministic sandbox states and logs. No real-time mutative control.</span>\n        </div>\n        <span className=\"text-[9px] text-[#009DFF] font-bold bg-[#009DFF]/10 border border-[#009DFF]/25 px-1.5 py-0.5 rounded uppercase shrink-0\">DEMO ACTIVE</span>\n      </div>\n\n      <PrivatePageHeader\n        title=\"AI Operations Command Center\"\n        desc=\"Audit high-integrity multi-agent runtimes, inspect context caches, monitor secure boundaries, and trigger isolated core reboots.\"\n        badgeLabel=\"Level IV clearance\"\n        actions={\n          <Link href=\"/portal/control-center\" className=\"inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)]\">\n            <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>Sovereign Control Center</span>\n          </Link>\n        }\n      />\n\n      {/* Aggregate metrics */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-4.5\">\n          <div className=\"space-y-0.5\">\n            <span className=\"text-[10px] font-mono text-white/35 uppercase\">Consensus Uptime</span>\n            <div className=\"text-[20px