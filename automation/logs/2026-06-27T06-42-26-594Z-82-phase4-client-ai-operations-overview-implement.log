okeLinecap=\"round\" fill=\"transparent\" />\n      </svg>\n      <span className=\"absolute text-[10px] font-mono font-bold text-white/90\">{value}%</span>\n    </div>\n  );\n}\n\nexport default function ClientAiOperationsPage() {\n  const [activeTab, setActiveTab] = useState<\"cockpit\" | \"telemetry\" | \"governance\">(\"cockpit\");\n  \n  // Enriched Active Agents State\n  const [agents, setAgents] = useState<EnrichedAgent[]>(() => {\n    return previewAgentOperations.map((agent, index) => {\n      const types = [\"Cognitive\", \"Guardrail\", \"Geological\", \"Medical\", \"Transactional\"];\n      const stages = [\"Execution\", \"Validation\", \"Attestation\", \"Execution\", \"Suspended\"];\n      const cpus = [42, 18, 65, 88, 0];\n      const memoryPercentage = [52, 77, 80, 89, 0];\n      const latencies = [12, 24, 14, 45, 0];\n      const uptimes = [99.998, 99.982, 99.991, 99.811, 100];\n      \n      return {\n        ...agent,\n        type: types[index % types.length],\n        stage: stages[index % stages.length],\n        cpu: cpus[index % cpus.length],\n        memPercent: memoryPercentage[index % memoryPercentage.length],\n        latency: latencies[index % latencies.length],\n        uptime: uptimes[index % uptimes.length],\n        isRebooting: false\n      };\n    });\n  });\n\n  // Filter States\n  const [projectFilter, setProjectFilter] = useState(\"all\");\n  const [typeFilter, setTypeFilter] = useState(\"all\");\n  const [statusFilter, setStatusFilter] = useState(\"all\");\n  const [stageFilter, setStageFilter] = useState(\"all\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n\n  // Simulated Global Events Ticker\n  const [liveLogTicker, setLiveLogTicker] = useState<string[]>(() => [\n    `[${new Date().toLocaleTimeString()}] Handshake sequence initialized on Sovereign Enclave 02`,\n    `[${new Date().toLocaleTimeString()}] HSM Cryptographic Roll key generated securely`,\n    `[${new Date().toLocaleTimeString()}] NIST compliance scoring algorithm completed: 98.6% PASS`\n  ]);\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      const activities = [\n        \"Enclave 04: Synchronizing local context stack state\",\n        \"Guardrail Audit: Prompt payload parsed, 0 violations detected\",\n        \"Hardware Check: AMD SEV memory encryption lock verified\",\n        \"Telemetry Sync: Sandbox memory usage stabilized at 27.2 GB\"\n      ];\n      const randomActivity = activities[Math.floor(Math.random() * activities.length)];\n      setLiveLogTicker(prev => [`[${new Date().toLocaleTimeString()}] ${randomActivity}`, ...prev.slice(0, 2)]);\n    }, 5000);\n    return () => clearInterval(interval);\n  }, []);\n\n  const triggerReboot = (agentId: string) => {\n    setAgents(prev => prev.map(agent => {\n      if (agent.id === agentId) {\n        return {\n          ...agent,\n          status: \"evaluating\",\n          isRebooting: true,\n          logs: [\n            ...agent.logs,\n            `[${new Date().toLocaleTimeString()}] INITIATING PHYSICAL ENCLAVE HARDWARE CYCLE...`,\n            `[${new Date().toLocaleTimeString()}] TEARING DOWN MEMORY SECTOR LOOPS`,\n            `[${new Date().toLocaleTimeString()}] FLUSHING CRYPTOGRAPHIC HANDSHAKE CACHES`\n          ]\n        };\n      }\n      return agent;\n    }));\n\n    setTimeout(() => {\n      setAgents(prev => prev.map(agent => {\n        if (agent.id === agentId) {\n          return {\n            ...agent,\n            status: \"active\",\n            isRebooting: false,\n            cpu: Math.floor(Math.random() * 30) + 20,\n            logs: [\n              ...agent.logs,\n              `[${new Date().toLocaleTimeString()}] ENCLAVE RE-ESTABLISHED ON CO-PROCESSOR`,\n              `[${new Date().toLocaleTimeString()}] MEMORY SECTORS RE-ALIGNED SUCCESSFULLY`,\n              `[${new Date().toLocaleTimeString()}] HANDSHAKE VERIFIED: STATUS ACTIVE`\n            ]\n          };\n        }\n        return agent;\n      }));\n    }, 1800);\n  };\n\n  const resetFilters = () => {\n    setProjectFilter(\"all\"); setTypeFilter(\"all\"); setStatusFilter(\"all\"); setStageFilter(\"all\"); setSearchQuery(\"\");\n  };\n\n  const filteredAgents = agents.filter(agent => {\n    const matchesSearch = searchQuery === \"\" || agent.name.toLowerCase().includes(searchQuery.toLowerCase()) || agent.id.toLowerCase().includes(searchQuery.toLowerCase());\n    const matchesProject = projectFilter === \"all\" || agent.projectId === projectFilter;\n    const matchesType = typeFilter === \"all\" || agent.type.toLowerCase() === typeFilter.toLowerCase();\n    const matchesStatus = statusFilter === \"all\" || agent.status.toLowerCase() === statusFilter.toLowerCase();\n    const matchesStage = stageFilter === \"all\" || agent.stage.toLowerCase() === stageFilter.toLowerCase();\n    return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n  });\n\n  const totalThreads = agents.reduce((acc, a) => acc + a.threads, 0);\n\n  return (\n    <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n      \n      {/* 1. SECURE DISCLOSURE BANNER */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2.5 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span>\n            <strong className=\"text-white\">PREVIEW TELEMETRY COMMAND CENTER:</strong> Monitoring sandbox containers and simulated hardware enclaves. This panel coordinates deterministic transaction logs and mock operations without direct runtime mutations.\n          </span>\n        </div>\n        <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0\">\n          DEMO ENVIRONMENT ACTIVE\n        </span>\n      </div>\n\n      {/* 2. PRIVATE PAGE HEADER */}\n      <PrivatePageHeader\n        title=\"AI Operations & Telemetry Command\"\n        desc=\"Audit high-integrity multi-agent runtimes, monitor secure memory boundaries, inspect active model guardrails, and execute localized sandboxed core reboot workflows.\"\n        badgeLabel=\"Level IV clearance\"\n        actions={\n          <div className=\"flex gap-2 w-full md:w-auto\">\n            <Link\n              href=\"/portal/control-center\"\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)]\"\n            >\n              <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n              <span>Sovereign Control Center</span>\n            </Link>\n          </div>\n        }\n      />\n\n      {/* 3. AGENT HEALTH OVERVIEW */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Consensus Health</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white flex items-baseline gap-1\">\n              98.6% <span className=\"text-[11px] font-normal text-emerald-400 font-mono\">Stable</span>\n            </div>\n            <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40\">\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-ping\" />\n              <span>All enclaves in agreement</span>\n            </div>\n          </div>\n          <HealthRing value={98} size={54} strokeWidth={4} colorClass=\"text-emerald-400\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Allocated Threads</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              {totalThreads} Loops\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Across {agents.length} provisioned nodes\n            </div>\n          </div>\n          <div className=\"p-3 bg-[#009DFF]/10 rounded-full text-[#009DFF] border border-[#009DFF]/20\">\n            <Activity className=\"w-5 h-5 animate-pulse\" />\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Enclave RAM Pools</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              27.2 GB\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Of 52.0 GB absolute allocation cap\n            </div>\n          </div>\n          <HealthRing value={52} size={54} strokeWidth={4} colorClass=\"text-[#009DFF]\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Audit Verification</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-emerald-400 font-mono\">\n              SECURE\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40 flex items-center gap-1\">\n              <Lock className=\"w-3 h-3 text-emerald-400\" />\n              <span>eBPF Boundaries locked</span>\n            </div>\n          </div>\n          <div className=\"p-3 bg-emerald-500/10 rounded-full text-emerald-400 border border-emerald-500/20\">\n            <ShieldCheck className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* 4. MANAGED OPERATIONS STATUS RAILS */}\n      <WorkspaceCard className=\"border border-white/5 bg-[#030303]/40 p-4\">\n        <div className=\"font-mono text-[10px] text-white/30 uppercase tracking-widest mb-3 flex items-center gap-2\">\n          <Server className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n          <span>MANAGED CO-PROCESSOR INFRASTRUCTURE STATUS RAILS</span>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Physical Isolation Layer</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">AMD SEV SEALED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Dynamic Prompt Guardrails</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">ZERO DRIFT</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-[92%]\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">eBPF System Telemetry</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">100% AUDITED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">HSM Secure Key Rotations</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">SYNCHRONIZED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n        </div>\n      </WorkspaceCard>\n\n      {/* 5. LIVE ACTIVITY LEDGER STREAM */}\n      <div className=\"bg-black/40 border border-white/5 rounded-xl px-4 py-2.5 flex items-center justify-between gap-4 font-mono text-[10.5px]\">\n        <div className=\"flex items-center gap-2 overflow-hidden w-full\">\n          <Terminal className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n          <span className=\"text-white/30 uppercase shrink-0 font-bold select-none text-[9.5px]\">Attestation Stream:</span>\n          <div className=\"text-white/70 truncate flex items-center gap-2\">\n            <span className=\"w-1 h-1 rounded-full bg-emerald-500 animate-ping inline-block shrink-0\" />\n            <span>{liveLogTicker[0] || \"Awaiting hardware handshake...\"}</span>\n          </div>\n        </div>\n        <div className=\"text-white/30 hidden md:block select-none text-[9px] uppercase tracking-wider shrink-0\">\n          Continuous Audit Loop Active\n        </div>\n      </div>\n\n      {/* PLACEHOLDER_FOR_PART_2 */}\n\n    </div>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { \n  Bot, Cpu, ShieldCheck, Terminal, SlidersHorizontal, Lock, \n  RefreshCw, Compass, Clock, ArrowUpRight, CheckCircle2, AlertTriangle, \n  XCircle, Server, Activity, Search, ShieldAlert\n} from \"lucide-react\";\nimport { WorkspaceCard, StatusBadge, PrivatePageHeader } from \"@/components/private-app\";\nimport { previewProjects, previewAgentOperations, previewGovernanceItems, AgentOperation } from \"@/lib/mock-data-model\";\n\ninterface EnrichedAgent extends AgentOperation {\n  type: string; stage: string; cpu: number; memPercent: number; isRebooting: boolean;\n}\n\nfunction HealthRing({ value, size = 48, colorClass = \"text-[#009DFF]\" }: { value: number; size?: number; colorClass?: string }) {\n  const radius = (size - 3) / 2;\n  const circumference = radius * 2 * Math.PI;\n  const strokeDashoffset = circumference - (value / 100) * circumference;\n  return (\n    <div className=\"relative flex items-center justify-center\" style={{ width: size, height: size }}>\n      <svg className=\"transform -rotate-90\" width={size} height={size}>\n        <circle cx={size/2} cy={size/2} r={radius} className=\"stroke-white/5 animate-pulse\" strokeWidth=\"2.5\" fill=\"transparent\" />\n        <circle cx={size/2} cy={size/2} r={radius} className={`transition-all duration-700 ${colorClass}`} strokeWidth=\"2.5\" strokeDasharray={circumference} strokeDashoffset={strokeDashoffset} strokeLinecap=\"round\" fill=\"transparent\" />\n      </svg>\n      <span className=\"absolute text-[9.5px] font-mono font-bold text-white/90\">{value}%</span>\n    </div>\n  );\n}\n\nexport default function ClientAiOperationsPage() {\n  const [activeTab, setActiveTab] = useState<\"cockpit\" | \"telemetry\" | \"governance\">(\"cockpit\");\n  const [agents, setAgents] = useState<EnrichedAgent[]>(() => \n    previewAgentOperations.map((a, i) => ({\n      ...a,\n      type: [\"Cognitive\", \"Guardrail\", \"Geological\", \"Medical\", \"Transactional\"][i % 5],\n      stage: [\"Execution\", \"Validation\", \"Attestation\", \"Execution\", \"Suspended\"][i % 5],\n      cpu: [42, 18, 65, 88, 0][i % 5],\n      memPercent: [52, 77, 80, 89, 0][i % 5],\n      isRebooting: false\n    }))\n  );\n\n  const [projectFilter, setProjectFilter] = useState(\"all\");\n  const [typeFilter, setTypeFilter] = useState(\"all\");\n  const [statusFilter, setStatusFilter] = useState(\"all\");\n  const [stageFilter, setStageFilter] = useState(\"all\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [liveLog, setLiveLog] = useState(`[${new Date().toLocaleTimeString()}] Handshake established securely on Enclave 02`);\n\n  useEffect(() => {\n    const timer = setInterval(() => {\n      const logs = [\n        \"Enclave 04: Syncing local context state\",\n        \"Guardrail: Prompt payload parsed - 0 anomalies\",\n        \"eBPF Telemetry: Memory footprint optimized at 27.2 GB\",\n        \"Ledger Seal: Committed SHA-256 block hash\"\n      ];\n      setLiveLog(`[${new Date().toLocaleTimeString()}] ${logs[Math.floor(Math.random() * logs.length)]}`);\n    }, 4500);\n    return () => clearInterval(timer);\n  }, []);\n\n  const handleReboot = (id: string) => {\n    setAgents(prev => prev.map(a => a.id === id ? { ...a, status: \"evaluating\", isRebooting: true, logs: [...a.logs, `[${new Date().toLocaleTimeString()}] REBOOTING CO-PROCESSOR ENCLAVE...`] } : a));\n    setTimeout(() => {\n      setAgents(prev => prev.map(a => a.id === id ? { \n        ...a, status: \"active\", isRebooting: false, cpu: Math.floor(Math.random() * 30) + 20, \n        logs: [...a.logs, `[${new Date().toLocaleTimeString()}] REBOOT OK. HANDSHAKE RESTORED.`] \n      } : a));\n    }, 1500);\n  };\n\n  const filtered = agents.filter(a => {\n    return (searchQuery === \"\" || a.name.toLowerCase().includes(searchQuery.toLowerCase())) &&\n      (projectFilter === \"all\" || a.projectId === projectFilter) &&\n      (typeFilter === \"all\" || a.type.toLowerCase() === typeFilter.toLowerCase()) &&\n      (statusFilter === \"all\" || a.status.toLowerCase() === statusFilter.toLowerCase()) &&\n      (stageFilter === \"all\" || a.stage.toLowerCase() === stageFilter.toLowerCase());\n  });\n\n  return (\n    <div className=\"space-y-6 max-w-[1700px] mx-auto pb-12 select-none\">\n      \n      {/* Disclaimer Banner */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-2.5 flex flex-col sm:flex-row items-center justify-between gap-3 font-mono text-[10.5px]\">\n        <div className=\"flex items-center gap-2 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span><strong className=\"text-white\">PREVIEW TELEMETRY COMMAND:</strong> Displaying isolated deterministic sandbox states and logs. No real-time mutative control.</span>\n        </div>\n        <span className=\"text-[9px] text-[#009DFF] font-bold bg-[#009DFF]/10 border border-[#009DFF]/25 px-1.5 py-0.5 rounded uppercase shrink-0\">DEMO ACTIVE</span>\n      </div>\n\n      <PrivatePageHeader\n        title=\"AI Operations Command Center\"\n        desc=\"Audit high-integrity multi-agent runtimes, inspect context caches, monitor secure boundaries, and trigger isolated core reboots.\"\n        badgeLabel=\"Level IV clearance\"\n        actions={\n          <Link href=\"/portal/control-center\" className=\"inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)]\">\n            <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>Sovereign Control Center</span>\n          </Link>\n        }\n      />\n\n      {/* Aggregate metrics */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-4.5\">\n          <div className=\"space-y-0.5\">\n            <span className=\"text-[10px] font-mono text-white/35 uppercase\">Consensus Uptime</span>\n            <div className=\"text-[20px] font-bold text-white\">98.6% <span className=\"text-[10px] text-emerald-400 font-mono font-normal\">Stable</span></div>\n            <div className=\"text-[9.5px] font-mono text-white/40 flex items-center gap-1\"><span className=\"w-1 h-1 rounded-full bg-emerald-400 animate-ping\" />Enclaves aligned</div>\n          </div>\n          <HealthRing value={98} size={46} colorClass=\"text-emerald-400\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-4.5\">\n          <div className=\"space-y-0.5\">\n            <span className=\"text-[10px] font-mono text-white/35 uppercase\">Active Threads</span>\n            <div className=\"text-[20px] font-bold text-white\">{agents.reduce((acc, x) => acc + x.threads, 0)} Loops</div>\n            <div className=\"text-[9.5px] font-mono text-white/40\">Across {agents.length} nodes</div>\n          </div>\n          <div className=\"p-2.5 bg-[#009DFF]/10 rounded-full text-[#009DFF] border border-[#009DFF]/20\"><Activity className=\"w-4 h-4 animate-pulse\" /></div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-4.5\">\n          <div className=\"space-y-0.5\">\n            <span className=\"text-[10px] font-mono text-white/35 uppercase\">RAM Pools Footprint</span>\n            <div className=\"text-[20px] font-bold text-white\">27.2 GB</div>\n            <div className=\"text-[9.5px] font-mono text-white/40\">Of 52.0 GB allocation cap</div>\n          </div>\n          <HealthRing value={52} size={46} colorClass=\"text-[#009DFF]\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-4.5\">\n          <div className=\"space-y-0.5\">\n            <span className=\"text-[10px] font-mono text-white/35 uppercase\">eBPF Attestation</span>\n            <div className=\"text-[20px] font-bold text-emerald-400 font-mono\">SECURE</div>\n            <div className=\"text-[9.5px] font-mono text-white/40 flex items-center gap-1\"><Lock className=\"w-2.5 h-2.5 text-emerald-400\" />Boundaries verified</div>\n          </div>\n          <div className=\"p-2.5 bg-emerald-500/10 rounded-full text-emerald-400 border border-emerald-500/20\"><ShieldCheck className=\"w-4 h-4\" /></div>\n        </WorkspaceCard>\n      </div>\n\n      {/* Status Rails */}\n      <WorkspaceCard className=\"p-4 border border-white/5 bg-[#030303]/40 space-y-3\">\n        <div className=\"font-mono text-[9px] text-white/30 uppercase tracking-widest flex items-center gap-1.5\">\n          <Server className=\"w-3 h-3 text-[#009DFF]\" />\n          <span>MANAGED INFRASTRUCTURE STATUS RAILS</span>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n          {[\n            { label: \"Physical Isolation\", status: \"AMD SEV SEALED\", w: \"w-full\", c: \"text-emerald-400 bg-emerald-500/10 border-emerald-500/20\", progress: \"bg-emerald-400\" },\n            { label: \"Dynamic Guardrails\", status: \"ZERO DRIFT ACTIVE\", w: \"w-[92%]\", c: \"text-[#009DFF] bg-[#009DFF]/10 border-[#009DFF]/20\", progress: \"bg-[#009DFF]\" },\n            { label: \"eBPF Core Filters\", status: \"100% AUDITED\", w: \"w-full\", c: \"text-[#009DFF] bg-[#009DFF]/10 border-[#009DFF]/20\", progress: \"bg-[#009DFF]\" },\n            { label: \"HSM Secure Rollovers\", status: \"SYNCHRONIZED\", w: \"w-full\", c: \"text-emerald-400 bg-emerald-500/10 border-emerald-500/20\", progress: \"bg-emerald-400\" }\n          ].map((rail, i) => (\n            <div key={i} className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-1.5\">\n              <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                <span className=\"text-white/60\">{rail.label}</span>\n                <span className={`text-[8px] border px-1 py-0.2 rounded font-bold ${rail.c}`}>{rail.status}</span>\n              </div>\n              <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\"><div className={`h-full ${rail.progress} ${rail.w}`} /></div>\n            </div>\n          ))}\n        </div>\n      </WorkspaceCard>\n\n      {/* Attestation Ticker */}\n      <div className=\"bg-black/30 border border-white/5 rounded-xl px-4 py-2.5 flex items-center justify-between gap-4 font-mono text-[10px]\">\n        <div className=\"flex items-center gap-2 overflow-hidden w-full text-white/70\">\n          <Terminal className=\"w-3.5 h-3.5 text-[#009DFF] shrink-0\" />\n          <span className=\"text-white/30 uppercase shrink-0 font-bold text-[9px]\">eBPF HANDSHAKE:</span>\n          <span className=\"truncate flex items-center gap-1.5\"><span className=\"w-1 h-1 rounded-full bg-emerald-500 animate-ping inline-block shrink-0\" />{liveLog}</span>\n        </div>\n        <span className=\"text-[8.5px] uppercase tracking-wider text-white/20 shrink-0 hidden sm:inline select-none\">AUDITING STACK LIVE</span>\n      </div>\n\n      {/* Tabs */}\n      <div className=\"space-y-4\">\n        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-white/5 pb-2.5 gap-3\">\n          <div className=\"flex gap-1.5 p-1 bg-white/[0.02] border border-white/5 rounded-lg w-full sm:w-auto font-mono\">\n            {[\n              { id: \"cockpit\", label: \"Active Agent Cockpit\", icon: Compass },\n              { id: \"telemetry\", label: \"Runtime Architecture\", icon: Activity },\n              { id: \"governance\", label: \"Governance Checklist\", icon: ShieldCheck }\n            ].map(tab => {\n              const Icon = tab.icon;\n              return (\n                <button\n                  key={tab.id}\n                  onClick={() => setActiveTab(tab.id as any)}\n                  className={`flex-1 sm:flex-none inline-flex items-center justify-center gap-1.5 px-3 py-1 text-[10.5px] uppercase font-bold rounded-md transition-all cursor-pointer ${\n                    activeTab === tab.id ? \"bg-white/[0.06] text-white border border-white/10\" : \"text-white/50 hover:text-white\"\n                  }`}\n                >\n                  <Icon className=\"w-3 h-3\" />\n                  <span>{tab.label} {tab.id === \"cockpit\" && `(${filtered.length})`}</span>\n                </button>\n              );\n            })}\n          </div>\n          <span className=\"text-[10px] font-mono text-white/30 uppercase flex items-center gap-1\"><Clock className=\"w-3 h-3 text-[#009DFF]\" />SECURE AGENT TIMESTAMPS SYNCED</span>\n        </div>\n\n        {/* Tab 1: Cockpit Grid */}\n        {activeTab === \"cockpit\" && (\n          <div className=\"space-y-5\">\n            {/* Filters */}\n            <WorkspaceCard className=\"p-4 border border-white/5 bg-[#030303]/20 space-y-3\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-1.5 text-[11px] font-mono font-bold text-white uppercase tracking-wider\">\n                <div className=\"flex items-center gap-1.5\"><SlidersHorizontal className=\"w-3.5 h-3.5 text-[#009DFF]\" /><span>Filter Cockpit</span></div>\n                {(projectFilter !== \"all\" || typeFilter !== \"all\" || statusFilter !== \"all\" || stageFilter !== \"all\" || searchQuery !== \"\") && (\n                  <button onClick={resetFilters} className=\"text-[9.5px] text-[#009DFF] hover:underline cursor-pointer uppercase font-bold flex items-center gap-0.5\"><XCircle className=\"w-3 h-3\" />RESET</button>\n                )}\n              </div>\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] font-mono text-white/40 uppercase font-bold\">Search Node</label>\n                  <div className=\"relative\">\n                    <input type=\"text\" placeholder=\"Filter agents...\" value={searchQuery} onChange={e => setSearchQuery(e.target.value)} className=\"w-full h-8 bg-[#020202] border border-white/10 rounded px-2 pl-7 text-[10.5px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40\" />\n                    <Search className=\"w-3 h-3 text-white/35 absolute left-2 top-2.5\" />\n                  </div>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] font-mono text-white/40 uppercase font-bold\">Project Bounds</label>\n                  <select value={projectFilter} onChange={e => setProjectFilter(e.target.value)} className=\"w-full h-8 bg-[#020202] border border-white/10 rounded px-2 text-[10.5px] font-mono text-white focus:outline-none cursor-pointer\">\n                    <option value=\"all\">All Sandbox Projects</option>\n                    {previewProjects.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}\n                  </select>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] font-mono text-white/40 uppercase font-bold\">Agent Type</label>\n                  <select value={typeFilter} onChange={e => setTypeFilter(e.target.value)} className=\"w-full h-8 bg-[#020202] border border-white/10 rounded px-2 text-[10.5px] font-mono text-white focus:outline-none cursor-pointer\">\n                    <option value=\"all\">All Types</option>\n                    {[\"Cognitive\", \"Guardrail\", \"Geological\", \"Medical\", \"Transactional\"].map(t => <option key={t} value={t}>{t}</option>)}\n                  </select>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] font-mono text-white/40 uppercase font-bold\">Pulse State</label>\n                  <select value={statusFilter} onChange={e => setStatusFilter(e.target.value)} className=\"w-full h-8 bg-[#020202] border border-white/10 rounded px-2 text-[10.5px] font-mono text-white focus:outline-none cursor-pointer\">\n                    <option value=\"all\">All Statuses</option>\n                    {[\"active\", \"evaluating\", \"warning\", \"decoupled\"].map(s => <option key={s} value={s}>{s}</option>)}\n                  </select>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[8.5px] font-mono text-white/40 uppercase font-bold\">Operating Stage</label>\n                  <select value={stageFilter} onChange={e => setStageFilter(e.target.value)} className=\"w-full h-8 bg-[#020202] border border-white/10 rounded px-2 text-[10.5px] font-mono text-white focus:outline-none cursor-pointer\">\n                    <option value=\"all\">All Stages</option>\n                    {[\"Execution\", \"Validation\", \"Attestation\", \"Suspended\"].map(st => <option key={st} value={st}>{st}</option>)}\n                  </select>\n                </div>\n              </div>\n            </WorkspaceCard>\n\n            {/* Grid */}\n            {filtered.length === 0 ? (\n              <div className=\"border border-white/5 bg-[#050505]/40 rounded-xl p-10 text-center max-w-md mx-auto space-y-3 font-mono\">\n                <Bot className=\"w-8 h-8 text-white/20 mx-auto\" />\n                <h4 className=\"text-xs font-bold text-white uppercase\">No Agents Match Filters</h4>\n                <p className=\"text-[10.5px] text-white/40\">Adjust parameters or reset options to view sandbox runtimes.</p>\n                <button onClick={resetFilters} className=\"h-7.5 px-3 rounded border border-white/10 text-[10px] text-white hover:bg-white/[0.04]\">Reset Filters</button>\n              </div>\n            ) : (\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-4\">\n                {filtered.map(agent => {\n                  const proj = previewProjects.find(p => p.id === agent.projectId);\n                  const isDecoupled = agent.status === \"decoupled\";\n                  return (\n                    <WorkspaceCard key={agent.id} className=\"p-4 border border-white/5 flex flex-col justify-between space-y-3\">\n                      <div className=\"space-y-2.5\">\n                        <div className=\"flex justify-between items-start border-b border-white/5 pb-2\">\n                          <div className=\"space-y-0.5\">\n                            <span className=\"text-[8.5px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1 py-0.2 rounded uppercase\">{agent.type} NODE</span>\n                            <h4 className=\"text-[12.5px] font-bold text-white font-mono\">{agent.name}</h4>\n                          </div>\n                          <StatusBadge state={agent.isRebooting ? \"warning\" : agent.status} label={agent.isRebooting ? \"REBOOTING\" : agent.status} />\n                        </div>\n\n                        <div className=\"grid grid-cols-3 gap-3 items-center\">\n                          <div className=\"col-span-2 grid grid-cols-2 gap-2 font-mono text-[10px]\">\n                            <div className=\"p-1.5 bg-white/[0.01] border border-white/5 rounded\">\n                              <span className=\"text-white/35 block text-[8px] uppercase\">Loops</span>\n                              <span className=\"text-white font-bold block\">{agent.isRebooting ? \"0\" : agent.threads} CORES</span>\n                            </div>\n                            <div className=\"p-1.5 bg-white/[0.01] border border-white/5 rounded\">\n                              <span className=\"text-white/35 block text-[8px] uppercase\">Stage</span>\n                              <span className=\"text-emerald-400 font-bold block truncate\">{agent.isRebooting ? \"REBOOTING\" : agent.stage}</span>\n                            </div>\n                            <div className=\"p-1.5 bg-white/[0.01] border border-white/5 rounded\">\n                              <span className=\"text-white/35 block text-[8px] uppercase\">Enclave</span>\n                              <span className=\"text-white font-bold block truncate\">{proj?.enclaveType || \"Intel SGX\"}</span>\n                            </div>\n                            <div className=\"p-1.5 bg-white/[0.01] border border-white/5 rounded\">\n                              <span className=\"text-white/35 block text-[8px] uppercase\">Cache Limit</span>\n                              <span className=\"text-white font-bold block truncate\">{agent.memory}</span>\n                            </div>\n                          </div>\n                          <div className=\"flex flex-col items-center border-l border-white/5 pl-2\">\n                            <span className=\"text-[8px] font-mono text-white/35 uppercase mb-1\">CPU Load</span>\n                            <HealthRing value={agent.isRebooting ? 0 : agent.cpu} size={42} colorClass={agent.status === \"warning\" ? \"text-amber-400\" : isDecoupled ? \"text-white/10\" : \"text-[#009DFF]\"} />\n                          </div>\n                        </div>\n\n                        {/* Logs console */}\n                        <div className=\"border border-white/5 bg-black/50 rounded p-2 h-20 overflow-y-auto font-mono text-[9px] text-white/55 space-y-1\">\n                          {agent.logs.map((log, idx) => (\n                            <div key={idx} className=\"truncate\"><span className=\"text-white/20 mr-1\">&gt;</span>{log}</div>\n                          ))}\n                        </div>\n                      </div>\n\n                      <button onClick={() => handleReboot(agent.id)} disabled={agent.isRebooting || isDecoupled} className=\"w-full inline-flex h-8 items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.01] text-[10px] font-bold text-white hover:bg-white/[0.04] transition-all disabled:opacity-20 font-mono cursor-pointer select-none\">\n                        {agent.isRebooting ? <RefreshCw className=\"w-3 h-3 animate-spin text-[#009DFF]\" /> : <RefreshCw className=\"w-3 h-3 text-[#009DFF]\" />}\n                        <span>{agent.isRebooting ? \"CYCLING HARDWARE...\" : isDecoupled ? \"LOCK ENFORCED\" : \"RECYCLE RUNTIME ENCLAVE\"}</span>\n                      </button>\n                    </WorkspaceCard>\n                  );\n                })}\n              </div>\n            )}\n          </div>\n        )}\n\n        {/* Tab 2: Telemetry Architecture Map */}\n        {activeTab === \"telemetry\" && (\n          <WorkspaceCard className=\"p-5 border border-white/5 bg-[#030303]/30 space-y-4 font-mono text-xs\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h4 className=\"text-sm font-bold text-white uppercase flex items-center gap-1.5\"><Activity className=\"w-3.5 h-3.5 text-[#009DFF]\" />eBPF Pipeline Schema</h4>\n              <p className=\"text-[10.5px] text-white/40 mt-0.5\">Sovereign model weight isolation and system syscall telemetry map.</p>\n            </div>\n            \n            <div className=\"p-5 bg-black/60 border border-white/5 rounded-xl flex justify-center py-8\">\n              <svg viewBox=\"0 0 720 120\" className=\"w-full max-w-3xl\">\n                <rect x=\"10\" y=\"30\" width=\"100\" height=\"50\" rx=\"4\" fill=\"#090909\" stroke=\"#333\" strokeWidth=\"1\" />\n                <text x=\"60\" y=\"55\" fill=\"#fff\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">USER GATEWAY</text>\n                <text x=\"60\" y=\"68\" fill=\"#666\" fontSize=\"7.5\" textAnchor=\"middle\">Prompt Payload</text>\n\n                <line x1=\"110\" y1=\"55\" x2=\"160\" y2=\"55\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n\n                <rect x=\"160\" y=\"30\" width=\"120\" height=\"50\" rx=\"4\" fill=\"#009DFF\" fillOpacity=\"0.04\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                <text x=\"220\" y=\"55\" fill=\"#009DFF\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">GUARDRAIL SHIELD</text>\n                <text x=\"220\" y=\"68\" fill=\"#fff\" fillOpacity=\"0.4\" fontSize=\"7.5\" textAnchor=\"middle\">Weight Boundary checks</text>\n\n                <line x1=\"280\" y1=\"55\" x2=\"330\" y2=\"55\" stroke=\"#10b981\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n\n                <rect x=\"330\" y=\"25\" width=\"150\" height=\"60\" rx=\"4\" fill=\"#10b981\" fillOpacity=\"0.04\" stroke=\"#10b981\" strokeWidth=\"1\" />\n                <text x=\"405\" y=\"50\" fill=\"#10b981\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\">CO-PROCESSOR ENCLAVE</text>\n                <text x=\"405\" y=\"63\" fill=\"#fff\" fillOpacity=\"0.4\" fontSize=\"7.5\" textAnchor=\"middle\">AMD SEV Memory isolation</text>\n\n                <line x1=\"480\" y1=\"55\" x2=\"530\" y2=\"55\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n\n                <rect x=\"530\" y=\"30\" width=\"110\" height=\"50\" rx=\"4\" fill=\"#090909\" stroke=\"#333\" strokeWidth=\"1\" />\n                <text x=\"585\" y=\"55\" fill=\"#fff\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">TELEMETRY LEDGER</text>\n                <text x=\"585\" y=\"68\" fill=\"#666\" fontSize=\"7.5\" textAnchor=\"middle\">SHA-256 Seal Hash</text>\n              </svg>\n            </div>\n\n            <div className=\"space-y-1.5 pt-2\">\n              <div className=\"flex justify-between items-center text-[10.5px] text-white/40 uppercase border-b border-white/5 pb-1\"><div className=\"flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5 text-[#009DFF]\" /><span>eBPF NET CALL STREAM</span></div><span className=\"text-emerald-400 font-bold text-[9px]\">LIVE SYNC</span></div>\n              <div className=\"bg-[#020202] border border-white/5 rounded p-4 h-36 overflow-y-auto font-mono text-[10px] text-white/70 space-y-1 select-text\">\n                <div>[09:12:10.4] sys_call: execve(\"/usr/bin/gff-agent-node\") enclave=Intel-SGX <span className=\"text-emerald-400\">ALLOW</span></div>\n                <div className=\"text-[#009DFF]\">[09:12:11.1] eBPF-Net: TLS Handshake validated (AES-256-GCM) endpoint=gateway-west-1</div>\n                <div className=\"text-emerald-400\">[09:12:12.8] attestation_core: Cryptographic hardware seal verified (Block 402,109)</div>\n                <div className=\"text-amber-400\">[09:12:14.0] guardrail_core: Prompt injection check matched score 0.001</div>\n                <div className=\"text-white/30\">[09:12:15.5] telemetry_stream: Synchronized memory state block with Ledger</div>\n              </div>\n            </div>\n          </WorkspaceCard>\n        )}\n\n        {/* Tab 3: Governance Checklist */}\n        {activeTab === \"governance\" && (\n          <WorkspaceCard className=\"p-5 border border-white/5 bg-[#030303]/30 space-y-4 font-mono text-xs\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h4 className=\"text-sm font-bold text-white uppercase flex items-center gap-1.5\"><ShieldCheck className=\"w-3.5 h-3.5 text-[#009DFF]\" />Compliance Checkpoints</h4>\n              <p className=\"text-[10.5px] text-white/40 mt-0.5\">NIST AI Risk Management and ISO-27001 standard logs verified under strict cryptographic hygiene.</p>\n            </div>\n            <div className=\"space-y-2.5\">\n              {previewGovernanceItems.map(item => {\n                const ok = item.status === \"compliant\";\n                return (\n                  <div key={item.id} className={`p-3 rounded-lg border flex items-center justify-between gap-3 ${ok ? \"bg-emerald-500/5 border-emerald-500/10\" : \"bg-amber-400/5 border-amber-400/10\"}`}>\n                    <div className=\"space-y-1\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <span className={`text-[8.5px] px-1.5 py-0.2 rounded font-bold ${ok ? \"bg-emerald-500/10 text-emerald-400\" : \"bg-amber-400/10 text-amber-400\"}`}>{item.standard}</span>\n                        <h5 className=\"font-bold text-white text-[11.5px]\">{item.name}</h5>\n                      </div>\n                      <p className=\"text-[10.5px] text-white/50 leading-relaxed\">{item.desc}</p>\n                    </div>\n                    <div className=\"shrink-0 flex items-center gap-1.5 font-bold uppercase text-[10px]\">\n                      {ok ? <CheckCircle2 className=\"w-3.5 h-3.5 text-emerald-400\" /> : <AlertTriangle className=\"w-3.5 h-3.5 text-amber-400\" />}\n                      <span className={ok ? \"text-emerald-400\" : \"text-amber-400\"}>{ok ? \"Verified\" : \"Warning\"}</span>\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </WorkspaceCard>\n        )}\n      </div>\n\n      {/* Control Center Gateway CTA */}\n      <div className=\"relative overflow-hidden rounded-xl border border-[#009DFF]/30 bg-gradient-to-br from-[#009DFF]/10 via-[#020202]/50 to-transparent p-5 md:p-6 flex flex-col md:flex-row items-center justify-between gap-5\">\n        <div className=\"absolute top-0 right-0 w-64 h-64 bg-[#009DFF]/5 blur-[60px] rounded-full pointer-events-none\" />\n        <div className=\"space-y-1.5 max-w-xl\">\n          <div className=\"inline-flex items-center 