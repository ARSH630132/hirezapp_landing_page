{"ts":"2026-06-27T06:39:02.980Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"kjtxps4j","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/ai-operations/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { \n  Bot, \n  Cpu, \n  ShieldCheck, \n  Terminal, \n  Settings, \n  SlidersHorizontal, \n  Layers, \n  Lock, \n  RefreshCw, \n  Compass, \n  Clock, \n  ArrowUpRight, \n  CheckCircle2, \n  AlertTriangle, \n  XCircle, \n  Server, \n  Activity, \n  Search, \n  ShieldAlert,\n  ChevronRight,\n  Database\n} from \"lucide-react\";\n\nimport { \n  MetricTile, \n  WorkspaceCard, \n  StatusBadge,\n  PrivatePageHeader\n} from \"@/components/private-app\";\n\nimport { \n  previewProjects,\n  previewAgentOperations,\n  previewGovernanceItems,\n  AgentOperation\n} from \"@/lib/mock-data-model\";\n\n// 1. Types & Interfaces\ninterface EnrichedAgent extends AgentOperation {\n  type: string;\n  stage: string;\n  cpu: number;\n  memPercent: number;\n  latency: number;\n  uptime: number;\n  isRebooting: boolean;\n}\n\n// 2. Circular Health Ring Component\nfunction HealthRing({ \n  value, \n  size = 56, \n  strokeWidth = 4, \n  colorClass = \"text-[#009DFF]\" \n}: { \n  value: number; \n  size?: number; \n  strokeWidth?: number; \n  colorClass?: string;\n}) {\n  const radius = (size - strokeWidth) / 2;\n  const circumference = radius * 2 * Math.PI;\n  const strokeDashoffset = circumference - (value / 100) * circumference;\n  \n  return (\n    <div className=\"relative flex items-center justify-center shrink-0\" style={{ width: size, height: size }}>\n      <svg className=\"transform -rotate-90\" width={size} height={size}>\n        <circle\n          cx={size / 2}\n          cy={size / 2}\n          r={radius}\n          className=\"stroke-white/5\"\n          strokeWidth={strokeWidth}\n          fill=\"transparent\"\n        />\n        <circle\n          cx={size / 2}\n          cy={size / 2}\n          r={radius}\n          className={`transition-all duration-1000 ease-out ${colorClass}`}\n          strokeWidth={strokeWidth}\n          strokeDasharray={circumference}\n          strokeDashoffset={strokeDashoffset}\n          strokeLinecap=\"round\"\n          fill=\"transparent\"\n        />\n      </svg>\n      <span className=\"absolute text-[10px] font-mono font-bold text-white/95\">{value}%</span>\n    </div>\n  );\n}\n\n// 3. Main Operations Component\nexport default function ClientAiOperationsPage() {\n  const [activeTab, setActiveTab] = useState<\"cockpit\" | \"telemetry\" | \"governance\">(\"cockpit\");\n  \n  // Enriched Active Agents State with Simulate Reboot Capability\n  const [agents, setAgents] = useState<EnrichedAgent[]>(() => {\n    return previewAgentOperations.map((agent, index) => {\n      const types = [\"Cognitive\", \"Guardrail\", \"Geological\", \"Medical\", \"Transactional\"];\n      const stages = [\"Execution\", \"Validation\", \"Attestation\", \"Execution\", \"Suspended\"];\n      const cpus = [42, 18, 65, 88, 0];\n      const memoryPercentage = [52, 77, 80, 89, 0];\n      const latencies = [12, 24, 14, 45, 0];\n      const uptimes = [99.998, 99.982, 99.991, 99.811, 100];\n      \n      return {\n        ...agent,\n        type: types[index % types.length],\n        stage: stages[index % stages.length],\n        cpu: cpus[index % cpus.length],\n        memPercent: memoryPercentage[index % memoryPercentage.length],\n        latency: latencies[index % latencies.length],\n        uptime: uptimes[index % uptimes.length],\n        isRebooting: false\n      };\n    });\n  });\n\n  // Filter States\n  const [projectFilter, setProjectFilter] = useState(\"all\");\n  const [typeFilter, setTypeFilter] = useState(\"all\");\n  const [statusFilter, setStatusFilter] = useState(\"all\");\n  const [stageFilter, setStageFilter] = useState(\"all\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n\n  // Simulated Global Events Stream state\n  const [liveLogTicker, setLiveLogTicker] = useState<string[]>(() => [\n    `[${new Date().toLocaleTimeString()}] Handshake sequence initialized on Sovereign Enclave 02`,\n    `[${new Date().toLocaleTimeString()}] HSM Cryptographic Roll key generated securely`,\n    `[${new Date().toLocaleTimeString()}] NIST compliance scoring algorithm completed: 98.6% PASS`,\n    `[${new Date().toLocaleTimeString()}] eBPF system call filtering rules compiled successfully`\n  ]);\n\n  // Rotate ticker logs periodically to make the app feel dynamic\n  useEffect(() => {\n    const interval = setInterval(() => {\n      const activities = [\n        \"Enclave 04: Synchronizing local context stack state\",\n        \"Guardrail Audit: Prompt payload parsed, 0 violations detected\",\n        \"Hardware Check: AMD SEV memory encryption lock verified\",\n        \"NIST Check: eBPF security boundary verification pass 1.0\",\n        \"Telemetry Sync: Sandbox memory usage stabilized at 27.2 GB\",\n        \"Ledger Seal: SHA-256 block hash verified and committed\"\n      ];\n      const randomActivity = activities[Math.floor(Math.random() * activities.length)];\n      setLiveLogTicker(prev => [\n        `[${new Date().toLocaleTimeString()}] ${randomActivity}`,\n        ...prev.slice(0, 4)\n      ]);\n    }, 4500);\n    return () => clearInterval(interval);\n  }, []);\n\n  // Trigger Local Agent Core Reboot Simulation\n  const triggerReboot = (agentId: string) => {\n    setAgents(prev => prev.map(agent => {\n      if (agent.id === agentId) {\n        return {\n          ...agent,\n          status: \"evaluating\",\n          isRebooting: true,\n          logs: [\n            ...agent.logs,\n            `[${new Date().toLocaleTimeString()}] INITIATING PHYSICAL ENCLAVE HARDWARE CYCLE...`,\n            `[${new Date().toLocaleTimeString()}] TEARING DOWN MEMORY SECTOR LOOPS`,\n            `[${new Date().toLocaleTimeString()}] FLUSHING CRYPTOGRAPHIC HANDSHAKE CACHES`\n          ]\n        };\n      }\n      return agent;\n    }));\n\n    setTimeout(() => {\n      setAgents(prev => prev.map(agent => {\n        if (agent.id === agentId) {\n          return {\n            ...agent,\n            status: \"active\",\n            isRebooting: false,\n            cpu: Math.floor(Math.random() * 30) + 20,\n            logs: [\n              ...agent.logs,\n              `[${new Date().toLocaleTimeString()}] ENCLAVE RE-ESTABLISHED ON CO-PROCESSOR`,\n              `[${new Date().toLocaleTimeString()}] MEMORY SECTORS RE-ALIGNED SUCCESSFULLY`,\n              `[${new Date().toLocaleTimeString()}] CRYPTOGRAPHIC BOUNDARY LOCK ESTABLISHED`,\n              `[${new Date().toLocaleTimeString()}] HANDSHAKE VERIFIED: STATUS ACTIVE`\n            ]\n          };\n        }\n        return agent;\n      }));\n    }, 1800);\n  };\n\n  // Reset Filters\n  const resetFilters = () => {\n    setProjectFilter(\"all\");\n    setTypeFilter(\"all\");\n    setStatusFilter(\"all\");\n    setStageFilter(\"all\");\n    setSearchQuery(\"\");\n  };\n\n  // Filter the Enriched Agent List\n  const filteredAgents = agents.filter(agent => {\n    const matchesSearch = searchQuery === \"\" || \n      agent.name.toLowerCase().includes(searchQuery.toLowerCase()) || \n      agent.id.toLowerCase().includes(searchQuery.toLowerCase());\n    const matchesProject = projectFilter === \"all\" || agent.projectId === projectFilter;\n    const matchesType = typeFilter === \"all\" || agent.type.toLowerCase() === typeFilter.toLowerCase();\n    const matchesStatus = statusFilter === \"all\" || agent.status.toLowerCase() === statusFilter.toLowerCase();\n    const matchesStage = stageFilter === \"all\" || agent.stage.toLowerCase() === stageFilter.toLowerCase();\n    \n    return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n  });\n\n  // Calculate Metrics\n  const activeCount = agents.filter(a => a.status === \"active\").length;\n  const warningCount = agents.filter(a => a.status === \"warning\").length;\n  const totalThreads = agents.reduce((acc, a) => acc + a.threads, 0);\n  const activePercent = Math.round((activeCount / agents.length) * 100);\n\n  return (\n    <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n      \n      {/* 1. SECURE DISCLOSURE BANNER */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2.5 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span>\n            <strong className=\"text-white\">PREVIEW TELEMETRY COMMAND CENTER:</strong> Monitoring sandbox containers and simulated hardware enclaves. This panel coordinates deterministic transaction logs and mock operations without direct runtime mutations.\n          </span>\n        </div>\n        <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0\">\n          DEMO ENVIRONMENT ACTIVE\n        </span>\n      </div>\n\n      {/* 2. PRIVATE PAGE HEADER */}\n      <PrivatePageHeader\n        title=\"AI Operations & Telemetry Command\"\n        desc=\"Audit high-integrity multi-agent runtimes, monitor secure memory boundaries, inspect active model guardrails, and execute localized sandboxed core reboot workflows.\"\n        badgeLabel=\"Level IV clearance\"\n        actions={\n          <div className=\"flex gap-2 w-full md:w-auto\">\n            <Link\n              href=\"/portal/control-center\"\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)]\"\n            >\n              <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n              <span>Sovereign Control Center</span>\n            </Link>\n          </div>\n        }\n      />\n\n      {/* 3. AGENT HEALTH OVERVIEW & PRESET STATUS RAILS */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n        \n        {/* Consensus Health */}\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Consensus Health</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white flex items-baseline gap-1\">\n              98.6% <span className=\"text-[11px] font-normal text-emerald-400 font-mono\">Stable</span>\n            </div>\n            <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40\">\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-ping\" />\n              <span>All enclaves in agreement</span>\n            </div>\n          </div>\n          <HealthRing value={98} size={54} strokeWidth={4} colorClass=\"text-emerald-400\" />\n        </WorkspaceCard>\n\n        {/* Total Allocated Threads */}\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Allocated Threads</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              {totalThreads} Loops\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Across {agents.length} provisioned nodes\n            </div>\n          </div>\n          <div className=\"p-3 bg-[#009DFF]/10 rounded-full text-[#009DFF] border border-[#009DFF]/20\">\n            <Activity className=\"w-5 h-5 animate-pulse\" />\n          </div>\n        </WorkspaceCard>\n\n        {/* Global Memory Footprint */}\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Enclave RAM Pools</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              27.2 GB\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Of 52.0 GB absolute allocation cap\n            </div>\n          </div>\n          <HealthRing value={52} size={54} strokeWidth={4} colorClass=\"text-[#009DFF]\" />\n        </WorkspaceCard>\n\n        {/* System Attestation Status */}\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Audit Verification</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-emerald-400 font-mono\">\n              SECURE\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40 flex items-center gap-1\">\n              <Lock className=\"w-3 h-3 text-emerald-400\" />\n              <span>eBPF Boundaries locked</span>\n            </div>\n          </div>\n          <div className=\"p-3 bg-emerald-500/10 rounded-full text-emerald-400 border border-emerald-500/20\">\n            <ShieldCheck className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n\n      </div>\n\n      {/* 4. MANAGED OPERATIONS STATUS RAILS */}\n      <WorkspaceCard className=\"border border-white/5 bg-[#030303]/40 p-4\">\n        <div className=\"font-mono text-[10px] text-white/30 uppercase tracking-widest mb-3 flex items-center gap-2\">\n          <Server className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n          <span>MANAGED CO-PROCESSOR INFRASTRUCTURE STATUS RAILS</span>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n          \n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Physical Isolation Layer</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">AMD SEV SEALED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Dynamic Prompt Guardrails</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">ZERO DRIFT</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-[92%]\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">eBPF System Telemetry</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">100% AUDITED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">HSM Secure Key Rotations</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">SYNCHRONIZED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n\n        </div>\n      </WorkspaceCard>\n\n      {/* 5. LIVE ACTIVITY LEDGER STREAM */}\n      <div className=\"bg-black/40 border border-white/5 rounded-xl px-4 py-2.5 flex items-center justify-between gap-4 font-mono text-[10.5px]\">\n        <div className=\"flex items-center gap-2 overflow-hidden w-full\">\n          <Terminal className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n          <span className=\"text-white/30 uppercase shrink-0 font-bold select-none text-[9.5px]\">Attestation Stream:</span>\n          <div className=\"text-white/70 truncate flex items-center gap-2\">\n            <span className=\"w-1 h-1 rounded-full bg-emerald-500 animate-ping inline-block shrink-0\" />\n            <span>{liveLogTicker[0] || \"Awaiting hardware handshake...\"}</span>\n          </div>\n        </div>\n        <div className=\"text-white/30 hidden md:block select-none text-[9px] uppercase tracking-wider shrink-0\">\n          Continuous Audit Loop Active\n        </div>\n      </div>\n\n      {/* 6. COCKPIT INTERACTIVE TABS & CONTROLS */}\n      <div className=\"space-y-6\">\n        \n        {/* Navigation Tabs */}\n        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-white/5 pb-2.5 gap-4\">\n          <div className=\"flex gap-2 p-1 bg-white/[0.02] border border-white/5 rounded-lg w-full sm:w-auto\">\n            <button\n              onClick={() => setActiveTab(\"cockpit\")}\n              className={`flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-4 py-1.5 text-[11px] font-mono uppercase font-bold rounded-md transition-all cursor-pointer ${\n                activeTab === \"cockpit\" \n                  ? \"bg-white/[0.06] text-white border border-white/10\" \n                  : \"text-white/50 hover:text-white\"\n              }`}\n            >\n              <Compass className=\"w-3.5 h-3.5\" />\n              <span>Active Agent Cockpit ({filteredAgents.length})</span>\n            </button>\n            <button\n              onClick={() => setActiveTab(\"telemetry\")}\n              className={`flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-4 py-1.5 text-[11px] font-mono uppercase font-bold rounded-md transition-all cursor-pointer ${\n                activeTab === \"telemetry\" \n                  ? \"bg-white/[0.06] text-white border border-white/10\" \n                  : \"text-white/50 hover:text-white\"\n              }`}\n            >\n              <Activity className=\"w-3.5 h-3.5\" />\n              <span>Runtime Architecture</span>\n            </button>\n            <button\n              onClick={() => setActiveTab(\"governance\")}\n              className={`flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-4 py-1.5 text-[11px] font-mono uppercase font-bold rounded-md transition-all cursor-pointer ${\n                activeTab === \"governance\" \n                  ? \"bg-white/[0.06] text-white border border-white/10\" \n                  : \"text-white/50 hover:text-white\"\n              }`}\n            >\n              <ShieldCheck className=\"w-3.5 h-3.5\" />\n              <span>Governance Checklist</span>\n            </button>\n          </div>\n\n          <div className=\"text-[11px] font-mono text-white/40 flex items-center gap-1.5\">\n            <Clock className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>LAST HEARTBEAT SYNC: JUST NOW [DETERMINISTIC]</span>\n          </div>\n        </div>\n\n        {/* TAB CONTENT 1: COCKPIT (THE LIVE RUNTIME GRID WITH INTERACTIVE FILTERS) */}\n        {activeTab === \"cockpit\" && (\n          <div className=\"space-y-6\">\n            \n            {/* Filter Cockpit Card */}\n            <WorkspaceCard className=\"p-5 border border-white/5 bg-[#030303]/30 space-y-4\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n                <div className=\"flex items-center gap-2 text-[12px] font-mono font-bold text-white uppercase tracking-wider\">\n                  <SlidersHorizontal className=\"w-4 h-4 text-[#009DFF]\" />\n                  <span>Telemetry Filter Cockpit</span>\n                </div>\n                {(projectFilter !== \"all\" || typeFilter !== \"all\" || statusFilter !== \"all\" || stageFilter !== \"all\" || searchQuery !== \"\") && (\n                  <button \n                    onClick={resetFilters}\n                    className=\"text-[10px] font-mono text-[#009DFF] hover:underline cursor-pointer uppercase font-bold flex items-center gap-1\"\n                  >\n                    <XCircle className=\"w-3.5 h-3.5\" /> Reset All Filters\n                  </button>\n                )}\n              </div>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4\">\n                \n                {/* Search query */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">Search Identifier</label>\n                  <div className=\"relative\">\n                    <input\n                      type=\"text\"\n                      placeholder=\"Filter agents...\"\n                      value={searchQuery}\n                      onChange={(e) => setSearchQuery(e.target.value)}\n                      className=\"w-full h-9 bg-[#020202] border border-white/10 rounded-lg px-3 pl-8 text-[11px] font-mono text-white placeholder-white/30 focus:outline-none focus:border-[#009DFF]/40\"\n                    />\n                    <Search className=\"w-3.5 h-3.5 text-white/35 absolute left-2.5 top-2.5\" />\n                  </div>\n                </div>\n\n                {/* Project selector */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">Project Sandbox</label>\n                  <select\n                    value={projectFilter}\n                    onChange={(e) => setProjectFilter(e.target.value)}\n                    className=\"w-full h-9 bg-[#020202] border border-white/10 rounded-lg px-3 text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 cursor-pointer\"\n                  >\n                    <option value=\"all\">All Sandbox Projects</option>\n                    {previewProjects.map(proj => (\n                      <option key={proj.id} value={proj.id}>{proj.name}</option>\n                    ))}\n                  </select>\n                </div>\n\n                {/* Agent Type selector */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">Agent Loop Type</label>\n                  <select\n                    value={typeFilter}\n                    onChange={(e) => setTypeFilter(e.target.value)}\n                    className=\"w-full h-9 bg-[#020202] border border-white/10 rounded-lg px-3 text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 cursor-pointer\"\n                  >\n                    <option value=\"all\">All Agent Types</option>\n                    <option value=\"cognitive\">Cognitive Core</option>\n                    <option value=\"guardrail\">Safety Guardrail</option>\n                    <option value=\"geological\">Geological Parser</option>\n                    <option value=\"medical\">Medical Enclave</option>\n                    <option value=\"transactional\">Transactional Loop</option>\n                  </select>\n                </div>\n\n                {/* Status selector */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">Pulse State</label>\n                  <select\n                    value={statusFilter}\n                    onChange={(e) => setStatusFilter(e.target.value)}\n                    className=\"w-full h-9 bg-[#020202] border border-white/10 rounded-lg px-3 text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 cursor-pointer\"\n                  >\n                    <option value=\"all\">All Pulse States</option>\n                    <option value=\"active\">Active State</option>\n                    <option value=\"evaluating\">Evaluating State</option>\n                    <option value=\"warning\">Warning Alert</option>\n                    <option value=\"decoupled\">Decoupled State</option>\n                  </select>\n                </div>\n\n                {/* Operating Stage selector */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-[10px] font-mono text-white/40 uppercase font-bold\">Operating Stage</label>\n                  <select\n                    value={stageFilter}\n                    onChange={(e) => setStageFilter(e.target.value)}\n                    className=\"w-full h-9 bg-[#020202] border border-white/10 rounded-lg px-3 text-[11px] font-mono text-white focus:outline-none focus:border-[#009DFF]/40 cursor-pointer\"\n                  >\n                    <option value=\"all\">All Execution Stages</option>\n                    <option value=\"execution\">Execution Block</option>\n                    <option value=\"validation\">Validation Audit</option>\n                    <option value=\"attestation\">Ledger Attestation</option>\n                    <option value=\"suspended\">Suspended Core</option>\n                  </select>\n                </div>\n\n              </div>\n            </WorkspaceCard>\n\n            {/* Active Agents Grid */}\n            {filteredAgents.length === 0 ? (\n              <div className=\"border border-white/5 bg-[#050505]/40 rounded-2xl p-12 text-center max-w-xl mx-auto space-y-4\">\n                <Bot className=\"w-10 h-10 text-white/20 mx-auto\" />\n                <h4 className=\"text-sm font-bold text-white font-mono uppercase\">No Active Agents Match Filters</h4>\n                <p className=\"text-xs text-white/40 leading-relaxed font-mono\">\n                  There are currently no sandboxed runtime multi-agents matching the selected parameter mapping inside GFF AI’s active cryptographic boundaries.\n                </p>\n                <button\n                  onClick={resetFilters}\n                  className=\"inline-flex h-8 items-center justify-center gap-1 px-4 rounded border border-white/10 bg-white/[0.01] text-[10.5px] font-mono font-bold text-white hover:bg-white/[0.04] transition-all cursor-pointer\"\n                >\n                  Clear Active Filters\n                </button>\n              </div>\n            ) : (\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\n                {filteredAgents.map(agent => {\n                  const projectObj = previewProjects.find(p => p.id === agent.projectId);\n                  const isWarning = agent.status === \"warning\";\n                  const isDecoupled = agent.status === \"decoupled\";\n                  const ringColor = isWarning \n                    ? \"text-amber-400\" \n                    : isDecoupled \n                      ? \"text-white/10\" \n                      : agent.isRebooting \n                        ? \"text-[#009DFF]/40\" \n                        : \"text-[#009DFF]\";\n                  \n                  return (\n                    <WorkspaceCard key={agent.id} className=\"space-y-4 border border-white/5 hover:border-white/10 transition-all flex flex-col justify-between\">\n                      \n                      {/* Agent Header Block */}\n                      <div className=\"space-y-3\">\n                        <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n                          <div className=\"space-y-1\">\n                            <div className=\"flex items-center gap-2 font-mono text-[9px] font-bold text-white/40\">\n                              <span className=\"text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.2 rounded uppercase\">\n                                {agent.type.toUpperCase()} NODE\n                              </span>\n                              <span>•</span>\n                              <span className=\"truncate max-w-[150px]\">{projectObj?.name || agent.projectId}</span>\n                            </div>\n                            <h4 className=\"text-[13px] font-bold text-white font-mono tracking-tight mt-1\">\n                              {agent.name}\n                            </h4>\n                          </div>\n\n                          <StatusBadge \n                            state={agent.isRebooting ? \"warning\" : agent.status} \n                            label={agent.isRebooting ? \"REBOOTING\" : agent.status} \n                          />\n                        </div>\n\n                        {/* Mid telemetry: Left attributes & Right Health ring */}\n                        <div className=\"grid grid-cols-3 gap-4 items-center\">\n                          \n                          <div className=\"col-span-2 grid grid-cols-2 gap-3 font-mono text-[10.5px]\">\n                            <div className=\"p-2 rounded border border-white/5 bg-white/[0.01]\">\n                              <span className=\"text-white/35 block text-[8.5px] uppercase font-bold\">Inference Threads</span>\n                              <span className=\"text-white font-bold block mt-0.5\">{agent.isRebooting ? \"0\" : `${agent.threads} CORES`}</span>\n                            </div>\n                            <div className=\"p-2 rounded border border-white/5 bg-white/[0.01]\">\n                              <span className=\"text-white/35 block text-[8.5px] uppercase font-bold\">Operating Stage</span>\n                              <span className=\"text-emerald-400 font-bold block mt-0.5 uppercase text-[9.5px]\">{agent.isRebooting ? \"REBOOTING\" : agent.stage}</span>\n                            </div>\n                            <div className=\"p-2 rounded border border-white/5 bg-white/[0.01]\">\n                              <span className=\"text-white/35 block text-[8.5px] uppercase font-bold\">Isolation Enclave</span>\n                              <span className=\"text-white font-bold block mt-0.5 uppercase truncate\">{projectObj?.enclaveType || \"Intel SGX\"}</span>\n                            </div>\n                            <div className=\"p-2 rounded border border-white/5 bg-white/[0.01]\">\n                              <span className=\"text-white/35 block text-[8.5px] uppercase font-bold\">Context Cache</span>\n                              <span className=\"text-white font-bold block mt-0.5 truncate\">{agent.memory}</span>\n                            </div>\n                          </div>\n\n                          {/* SVG Health Ring & Status */}\n                          <div className=\"flex flex-col items-center justify-center border-l border-white/5 pl-2\">\n                            <span className=\"text-[8.5px] font-mono text-white/35 uppercase font-bold mb-2 block text-center\">Core CPU Utilization</span>\n                            <HealthRing \n                              value={agent.isRebooting ? 0 : agent.cpu} \n                              size={52} \n                              strokeWidth={3} \n                              colorClass={ringColor} \n                            />\n                          </div>\n\n                        </div>\n\n                        {/* Expanding local event logs ledger */}\n                        <div className=\"border border-white/5 rounded-lg overflow-hidden bg-black/50 p-3 h-28 overflow-y-auto font-mono text-[10px] text-white/55 space-y-1.5\">\n                          {agent.logs.map((log, idx) => (\n                            <div key={idx} className=\"leading-relaxed border-b border-white/[0.01] pb-1\">\n                              <span className=\"text-white/20 mr-1.5 select-none\">&gt;&gt;</span>\n                              <span className={log.includes(\"REBOOT\") || log.includes(\"CYCLING\") ? \"text-[#009DFF] font-bold\" : log.includes(\"SUCCESSFULLY\") || log.includes(\"established\") ? \"text-emerald-400\" : \"\"}>\n                                {log}\n                              </span>\n                            </div>\n                          ))}\n                        </div>\n\n                      </div>\n\n                      {/* Reboot button action */}\n                      <div className=\"pt-2\">\n                        <button \n                          onClick={() => triggerReboot(agent.id)}\n                          disabled={agent.isRebooting || agent.status === \"decoupled\"}\n                          className=\"w-full inline-flex h-8.5 items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.01] text-[10.5px] font-bold text-white hover:bg-white/[0.04] hover:border-white/20 transition-all disabled:opacity-30 cursor-pointer select-none font-mono\"\n                        >\n                          {agent.isRebooting ? (\n                            <>\n                              <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#009DFF]\" />\n                              <span>CYCLING HARDWARE SLOTS...</span>\n                            </>\n                          ) : isDecoupled ? (\n                            <>\n                              <Lock className=\"w-3.5 h-3.5 text-white/35\" />\n                              <span>ENCLAVE LOCKED & DECOUPLED</span>\n                            </>\n                          ) : (\n                            <>\n                              <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                              <span>RECYCLE SECURE RUNTIME ENCLAVE</span>\n                            </>\n                          )}\n                        </button>\n                      </div>\n\n                    </WorkspaceCard>\n                  );\n                })}\n              </div>\n            )}\n\n            {/* Narrative Timeline of recent operational actions */}\n            <WorkspaceCard className=\"p-5 border border-white/5 bg-[#030303]/30\">\n              <div className=\"flex items-center gap-2 text-[12px] font-mono font-bold text-white uppercase tracking-wider mb-5 border-b border-white/5 pb-2\">\n                <Clock className=\"w-4 h-4 text-[#009DFF]\" />\n                <span>Deterministic Operations Audit Timeline</span>\n              </div>\n              <div className=\"relative border-l border-white/5 pl-5 ml-2.5 space-y-6\">\n                \n                <div className=\"relative\">\n                  <span className=\"absolute -left-[25px] top-1 h-2.5 w-2.5 rounded-full bg-emerald-400 border border-black\" />\n                  <div className=\"space-y-1 font-mono text-[11px]\">\n                    <div className=\"flex justify-between text-white font-bold\">\n                      <span>Model Boundary Alignment Checked</span>\n                      <span className=\"text-white/30 text-[10px]\">10:30 AM (Today)</span>\n                    </div>\n                    <p className=\"text-white/50 text-[10.5px] leading-relaxed\">\n                      Continuous NIST-compliant audit run successfully scanned all prompt weights inside Sovereign Core Sandbox 02. Output alignment rated 100% compliant, zero injection vulnerabilities recorded.\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"relative\">\n                  <span className=\"absolute -left-[25px] top-1 h-2.5 w-2.5 rounded-full bg-[#009DFF] border border-black animate-pulse\" />\n                  <div className=\"space-y-1 font-mono text-[11px]\">\n                    <div className=\"flex justify-between text-white font-bold\">\n                      <span>ISO-27001 Key Rotation Completed</span>\n                      <span className=\"text-white/30 text-[10px]\">Yesterday</span>\n                    </div>\n                    <p className=\"text-white/50 text-[10.5px] leading-relaxed\">\n                      HSM key storage partition triggered automatic 30-day cryptographic seal rollover across all regional multi-agent nodes. Sandbox caches re-authenticated seamlessly.\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"relative\">\n                  <span className=\"absolute -left-[25px] top-1 h-2.5 w-2.5 rounded-full bg-amber-400 border border-black\" />\n                  <div className=\"space-y-1 font-mono text-[11px]\">\n                    <div className=\"flex justify-between text-white font-bold\">\n                      <span>eBPF Telemetry Leak Warning Flagged</span>\n                      <span className=\"text-white/30 text-[10px]\">2 days ago</span>\n                    </div>\n                    <p className=\"text-white/50 text-[10.5px] leading-relaxed\">\n                      Node MED-CLINIC-H9 sandbox container output buffer reported peak disk space saturation. System auto-allocated context cache re-allocator to scale virtual enclaves.\n                    </p>\n                  </div>\n                </div>\n\n              </div>\n            </WorkspaceCard>\n\n          </div>\n        )}\n\n        {/* TAB CONTENT 2: STATE ARCHITECTURE & EBPF TELEMETRY MAP */}\n        {activeTab === \"telemetry\" && (\n          <div className=\"space-y-6\">\n            \n            <WorkspaceCard className=\"p-6 border border-white/5 bg-[#030303]/30 space-y-6\">\n              \n              <div className=\"border-b border-white/5 pb-3\">\n                <h4 className=\"text-sm font-bold font-mono text-white uppercase tracking-wider flex items-center gap-1.5\">\n                  <Activity className=\"w-4 h-4 text-[#009DFF]\" />\n                  <span>Sovereign eBPF Telemetry Pipeline Schema</span>\n                </h4>\n                <p className=\"text-xs text-white/50 mt-1 font-mono leading-relaxed\">\n                  GFF AI secures and isolates dynamic model runtimes. This visual represents our deterministic data flow, from untrusted user prompt to HSM-sealed compliant transaction block.\n                </p>\n              </div>\n\n              {/* Architectural SVG Map with animated pulse effects */}\n              <div className=\"p-6 rounded-2xl bg-[#020202]/60 border border-white/5 flex flex-col items-center justify-center py-10\">\n                <svg viewBox=\"0 0 800 200\" className=\"w-full max-w-4xl text-white font-mono\">\n                  \n                  {/* Step 1: User Prompt Ingest */}\n                  <rect x=\"20\" y=\"60\" width=\"120\" height=\"60\" rx=\"6\" fill=\"#0c0c0c\" stroke=\"#333\" strokeWidth=\"1.5\" />\n                  <text x=\"80\" y=\"90\" fill=\"#fff\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\">UNTARGE PORTAL</text>\n                  <text x=\"80\" y=\"105\" fill=\"#666\" fontSize=\"8\" textAnchor=\"middle\">User Request</text>\n\n                  {/* Arrow 1 */}\n                  <path d=\"M 140 90 L 180 90\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1.5\" markerEnd=\"url(#arrow)\" strokeDasharray=\"3 3\" className=\"animate-pulse\" />\n\n                  {/* Step 2: Decoupled Safety Filter */}\n                  <rect x=\"180\" y=\"60\" width=\"140\" height=\"60\" rx=\"6\" fill=\"#009DFF\" fillOpacity=\"0.05\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n                  <text x=\"250\" y=\"90\" fill=\"#009DFF\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\">GUARDRAIL SHIELD</text>\n                  <text x=\"250\" y=\"105\" fill=\"#fff\" fillOpacity=\"0.4\" fontSize=\"8\" textAnchor=\"middle\">Prompt Cleanse Check</text>\n\n                  {/* Arrow 2 */}\n                  <path d=\"M 320 90 L 360 90\" fill=\"none\" stroke=\"#10b981\" strokeWidth=\"1.5\" strokeDasharray=\"3 3\" />\n\n                  {/* Step 3: Hardware Enclave Execution */}\n                  <rect x=\"360\" y=\"50\" width=\"160\" height=\"80\" rx=\"8\" fill=\"#10b981\" fillOpacity=\"0.05\" stroke=\"#10b981\" strokeWidth=\"1.5\" />\n                  <text x=\"440\" y=\"85\" fill=\"#10b981\" fontSize=\"11\" textAnchor=\"middle\" fontWeight=\"bold\">CO-PROCESSOR ENCLAVE</text>\n                  <text x=\"440\" y=\"100\" fill=\"#fff\" fillOpacity=\"0.5\" fontSize=\"8\" textAnchor=\"middle\">AMD SEV Memory Block</text>\n                  <text x=\"440\" y=\"115\" fill=\"#fff\" fillOpacity=\"0.4\" fontSize=\"8\" textAnchor=\"middle\">Llama-70B Weights</text>\n\n                  {/* Arrow 3 */}\n                  <path d=\"M 520 90 L 560 90\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1.5\" strokeDasharray=\"3 3\" />\n\n                  {/* Step 4: Ledger Audit & Seal */}\n                  <rect x=\"560\" y=\"60\" width=\"140\" height=\"60\" rx=\"6\" fill=\"#0c0c0c\" stroke=\"#333\" strokeWidth=\"1.5\" />\n                  <text x=\"630\" y=\"90\" fill=\"#fff\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\">TELEMETRY LEDGER</text>\n                  <text x=\"630\" y=\"105\" fill=\"#666\" fontSize=\"8\" textAnchor=\"middle\">SHA-256 Block Commit</text>\n\n                  {/* Marker definitions for Arrows */}\n                  <defs>\n                    <marker id=\"arrow\" viewBox=\"0 0 10 10\" refX=\"6\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n                      <path d=\"M 0 1.5 L 10 5 L 0 8.5 z\" fill=\"#009DFF\" />\n                    </marker>\n                  </defs>\n                </svg>\n\n                <div className=\"mt-6 grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-4xl text-[11px] font-mono leading-relaxed text-white/50 border-t border-white/5 pt-6\">\n                  <div>\n                    <span className=\"text-[#009DFF] font-bold block mb-1\">1. Decoupled Context Isolation</span>\n                    Unverified inputs are processed by GFF AI’s decoupled context caching framework to guarantee that model runtimes are strictly insulated against arbitrary prompts.\n                  </div>\n                  <div>\n                    <span className=\"text-emerald-400 font-bold block mb-1\">2. Hardware Key Enforces Keys</span>\n                    Hardware-sealed cryptographic registers within isolated AMD SEV co-processors contain model weight parameters, blocking read/write actions from the hypervisor.\n                  </div>\n                  <div>\n                    <span className=\"text-[#009DFF] font-bold block mb-1\">3. Immutable Telemetry Logs</span>\n                    All system-level system calls (via eBPF hooks) are continuously structured and written directly into an integrated transaction ledger block for offline audibility.\n                  </div>\n                </div>\n\n              </div>\n\n              {/* Mock System Telemetry Stream (Detailed Console) */}\n              <div className=\"space-y-2\">\n                <div className=\"flex justify-between items-center font-mono text-[11px] text-white/40 uppercase tracking-wider border-b border-white/5 pb-1 select-none\">\n                  <div className=\"flex items-center gap-1\">\n                    <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n                    <span>eBPF SYSTEM SYSCALL TELEMETRY EVENT STREAM</span>\n                  </div>\n                  <div className=\"flex items-center gap-1.5 text-emerald-400 text-[10px] font-bold\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n                    <span>AUDITOR LINK ACTIVE</span>\n                  </div>\n                </div>\n                \n                <div className=\"bg-[#020202] border border-white/5 rounded-xl p-5 h-64 overflow-y-auto font-mono text-[10.5px] text-white/70 space-y-2 select-text\">\n                  <div className=\"text-white/30\">[09:12:10.420] sys_call: execve(\"/usr/bin/gff-agent-node\") enclave=Intel-SGX status=ALLOW</div>\n                  <div className=\"text-[#009DFF]/80\">[09:12:11.104] eBPF-Net: TLS Handshake validated (CIPHER: AES-256-GCM) endpoint=gateway-west-1</div>\n                  <div className=\"text-emerald-400\">[09:12:12.891] attestation_core: AMD SEV cryptographic hardware seal verified (Block 402,109)</div>\n                  <div className=\"text-white/30\">[09:12:13.112] sys_call: read(\"/var/run/secrets/hsm-key\") locked=true status=ALLOW</div>\n                  <div className=\"text-amber-400\">[09:12:14.004] guardrail_core: Prompt injection check matched score 0.001 (Boundary threshold: 0.15)</div>\n                  <div className=\"text-[#009DFF]/80\">[09:12:15.520] telemetry_stream: Synchronized memory state block with Sovereign Core Ledger (SHA: 4F1A)</div>\n                  <div className=\"text-white/30\">[09:12:16.890] sys_call: close(\"/usr/bin/gff-agent-node\") code=0</div>\n                  <div className=\"text-emerald-400 font-bold\">[09:12:17.102] audit_daemon: Verification loop finished. Uptime 99.998% compliant. No anomalies.</div>\n                </div>\n              </div>\n\n            </WorkspaceCard>\n\n          </div>\n        )}\n\n        {/* TAB CONTENT 3: GOVERNANCE STANDARDS */}\n        {activeTab === \"governance\" && (\n          <div className=\"space-y-6\">\n            \n            <WorkspaceCard className=\"p-6 border border-white/5 bg-[#030303]/30 space-y-6\">\n              \n              <div className=\"border-b border-white/5 pb-3 flex justify-between items-start md:items-center flex-col md:flex-row gap-4\">\n                <div>\n                  <h4 className=\"text-sm font-bold font-mono text-white uppercase tracking-wider flex items-center gap-1.5\">\n                    <ShieldCheck className=\"w-4 h-4 text-[#009DFF]\" />\n                    <span>Compliance Checkpoints & Regulatory Ledger</span>\n                  </h4>\n                  <p className=\"text-xs text-white/50 mt-1 font-mono leading-relaxed\">\n                    Verify physical isolation, cryptographic hygiene, and prompt-filtering compliance rules validated under NIST AI Risk Management and ISO-27001 standards.\n                  </p>\n                </div>\n                \n                <button\n                  onClick={() => alert(\"Simulated compliance audit completed. Status is compliant.\")}\n                  className=\"inline-flex h-8.5 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 text-[10.5px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer px-4 shadow-[0_0_12px_rgba(0,157,255,0.1)]\"\n                >\n                  <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  <span>Execute Compliance Audit</span>\n                </button>\n              </div>\n\n              {/* Checkpoint list rendered directly from mock items */}\n              <div className=\"space-y-4\">\n                {previewGovernanceItems.map((item) => {\n                  const isCompliant = item.status === \"compliant\";\n                  const isWarning = item.status === \"warning\";\n                  \n                  return (\n                    <div \n                      key={item.id} \n                      className={`p-4 rounded-xl border transition-all ${\n                        isCompliant \n                          ? \"bg-emerald-500/5 border-emerald-500/10 hover:border-emerald-500/20\" \n                          : \"bg-amber-400/5 border-amber-400/10 hover:border-amber-400/20\"\n                      } flex flex-col md:flex-row md:items-center justify-between gap-4`}\n                    >\n                      <div className=\"space-y-1.5 max-w-3xl\">\n                        <div className=\"flex items-center gap-2\">\n                          <span className={`text-[9px] font-mono font-bold px-1.5 py-0.2 rounded ${\n                            isCompliant ? \"bg-emerald-500/10 text-emerald-400\" : \"bg-amber-400/10 text-amber-400\"\n                          }`}>\n                            {item.standard}\n                          </span>\n                          <h5 className=\"text-[12.5px] font-bold text-white font-mono\">{item.name}</h5>\n                        </div>\n                        <p className=\"text-xs text-white/50 font-mono leading-relaxed\">{item.desc}</p>\n                        <div className=\"text-[9.5px] text-white/30 font-mono\">\n                          LAST ATTRIBUTED RUN: {new Date(item.lastChecked).toLocaleString(\"en-US\", { month: \"short\", day: \"numeric\", hour: \"2-digit\", minute: \"2-digit\" })}\n                        </div>\n                      </div>\n\n                      <div className=\"shrink-0 flex items-center gap-2\">\n                        {isCompliant ? (\n                          <>\n                            <CheckCircle2 className=\"w-4 h-4 text-emerald-400\" />\n                            <span className=\"text-[11px] font-mono font-bold text-emerald-400 uppercase\">Compliant</span>\n                          </>\n                        ) : (\n                          <>\n                            <AlertTriangle className=\"w-4 h-4 text-amber-400\" />\n                            <span className=\"text-[11px] font-mono font-bold text-amber-400 uppercase\">Warning Flag</span>\n                          </>\n                        )}\n                      </div>\n\n                    </div>\n                  );\n                })}\n              </div>\n\n              {/* Physical Security Disclosures */}\n              <div className=\"p-4 rounded-xl border border-white/5 bg-black/40 flex items-start gap-3\">\n                <Lock className=\"w-5 h-5 text-[#009DFF] shrink-0 mt-0.5\" />\n                <div className=\"font-mono text-[11px] text-white/50 leading-relaxed space-y-1\">\n                  <span className=\"text-white font-bold block uppercase text-[10px] text-[#009DFF]\">Physical Hardware Attestation Policy</span>\n                  Every sandbox container operating within GFF AI parameters is sealed with HSM cryptographically keys stored outside user context bounds. No direct hypervisor, network agent, or local administrator has physical capability to inspect enclave registers. Multi-agent state is permanently decoupled.\n                </div>\n              </div>\n\n            </WorkspaceCard>\n\n          </div>\n        )}\n\n      </div>\n\n      {/* 7. INTEGRATED CONTROL HUB GATEWAY CTA SECTION */}\n      <div className=\"relative overflow-hidden rounded-2xl border border-[#009DFF]/30 bg-gradient-to-br from-[#009DFF]/10 via-[#020202]/50 to-transparent p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6\">\n        <div className=\"absolute top-0 right-0 w-80 h-80 bg-[#009DFF]/5 blur-[80px] rounded-full pointer-events-none\" />\n        <div className=\"space-y-2 max-w-xl\">\n          <div className=\"inline-flex items-center gap-1.5 px-2 py-0.5 rounded border border-[#009DFF]/30 bg-[#009DFF]/10 text-[#009DFF] text-[9.5px] font-mono font-bold uppercase tracking-wider\">\n            INTEGRATED CONTROL HUB\n          </div>\n          <h3 className=\"text-xl md:text-2xl font-bold font-mono tracking-tight text-white\">Sovereign Control Center Gateway</h3>\n          <p className=\"text-xs text-white/50 leading-relaxed font-mono\">\n            Manage complete platform variables, coordinate high-level model weights isolation, authorize hardware key rollover procedures, and inspect real-time eBPF event telemetry logs inside GFF AI’s global network.\n          </p>\n        </div>\n        <Link\n          href=\"/portal/control-center\"\n          className=\"inline-flex h-11 items-center justify-center gap-2 rounded-xl bg-white text-[12px] font-mono font-bold text-black hover:bg-white/90 transition-all px-6 shrink-0 shadow-[0_0_20px_rgba(255,255,255,0.15)] hover:scale-[1.02]\"\n        >\n          <span>Enter Control Center</span>\n          <ArrowUpRight className=\"w-4 h-4\" />\n        </Link>\n      </div>\n\n    </div>\n  );\n}\n","insert_line":null}}}
