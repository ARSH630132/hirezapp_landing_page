{"ts":"2026-06-27T06:40:00.148Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"s6swjtlv","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/ai-operations/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { DataTable, previewAgentOperations, TableColumn, AgentOperation } from \"@/components/private-app\";\n\nexport default function ClientAiOperationsPage() {\n  const columns: TableColumn<AgentOperation>[] = [\n    { key: \"id\", header: \"Agent ID\", sortable: true },\n    { key: \"name\", header: \"Identifier Name\", sortable: true },\n    { key: \"projectId\", header: \"Project Bounds\", sortable: true },\n    { key: \"threads\", header: \"Thread Count\", sortable: true },\n    { key: \"memory\", header: \"Isolated RAM\" },\n    { key: \"status\", header: \"Pulse State\", sortable: true }\n  ];\n\n  return (\n    <div className=\"space-y-6\">\n      <div>\n        <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">AI Operations Ledger</h2>\n        <p className=\"text-xs text-white/50 mt-1\">Configure and coordinate active sandboxed multi-agent runtimes, context states, and memory allocations.</p>\n      </div>\n\n      <DataTable \n        columns={columns}\n        data={previewAgentOperations}\n        pageSize={5}\n        searchPlaceholder=\"Filter agents by name, project, or status...\"\n        searchKeys={[\"id\", \"name\", \"projectId\", \"status\"]}\n        statusField=\"status\"\n        typeField=\"projectId\"\n        categoryLabel=\"AGENT TELEMETRY\"\n        detailTitle={(row) => `Runtime: ${row.name}`}\n      />\n    </div>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { \n  Bot, Cpu, ShieldCheck, Terminal, SlidersHorizontal, Layers, Lock, \n  RefreshCw, Compass, Clock, ArrowUpRight, CheckCircle2, AlertTriangle, \n  XCircle, Server, Activity, Search, ShieldAlert, ChevronRight\n} from \"lucide-react\";\n\nimport { \n  WorkspaceCard, StatusBadge, PrivatePageHeader \n} from \"@/components/private-app\";\n\nimport { \n  previewProjects, previewAgentOperations, previewGovernanceItems, AgentOperation \n} from \"@/lib/mock-data-model\";\n\n// 1. Interfaces\ninterface EnrichedAgent extends AgentOperation {\n  type: string;\n  stage: string;\n  cpu: number;\n  memPercent: number;\n  latency: number;\n  uptime: number;\n  isRebooting: boolean;\n}\n\n// 2. SVG Health Ring Component\nfunction HealthRing({ value, size = 52, strokeWidth = 3, colorClass = \"text-[#009DFF]\" }: { value: number; size?: number; strokeWidth?: number; colorClass?: string }) {\n  const radius = (size - strokeWidth) / 2;\n  const circumference = radius * 2 * Math.PI;\n  const strokeDashoffset = circumference - (value / 100) * circumference;\n  \n  return (\n    <div className=\"relative flex items-center justify-center shrink-0\" style={{ width: size, height: size }}>\n      <svg className=\"transform -rotate-90\" width={size} height={size}>\n        <circle cx={size / 2} cy={size / 2} r={radius} className=\"stroke-white/5\" strokeWidth={strokeWidth} fill=\"transparent\" />\n        <circle cx={size / 2} cy={size / 2} r={radius} className={`transition-all duration-1000 ease-out ${colorClass}`} strokeWidth={strokeWidth} strokeDasharray={circumference} strokeDashoffset={strokeDashoffset} strokeLinecap=\"round\" fill=\"transparent\" />\n      </svg>\n      <span className=\"absolute text-[10px] font-mono font-bold text-white/90\">{value}%</span>\n    </div>\n  );\n}\n\nexport default function ClientAiOperationsPage() {\n  const [activeTab, setActiveTab] = useState<\"cockpit\" | \"telemetry\" | \"governance\">(\"cockpit\");\n  \n  // Enriched Active Agents State\n  const [agents, setAgents] = useState<EnrichedAgent[]>(() => {\n    return previewAgentOperations.map((agent, index) => {\n      const types = [\"Cognitive\", \"Guardrail\", \"Geological\", \"Medical\", \"Transactional\"];\n      const stages = [\"Execution\", \"Validation\", \"Attestation\", \"Execution\", \"Suspended\"];\n      const cpus = [42, 18, 65, 88, 0];\n      const memoryPercentage = [52, 77, 80, 89, 0];\n      const latencies = [12, 24, 14, 45, 0];\n      const uptimes = [99.998, 99.982, 99.991, 99.811, 100];\n      \n      return {\n        ...agent,\n        type: types[index % types.length],\n        stage: stages[index % stages.length],\n        cpu: cpus[index % cpus.length],\n        memPercent: memoryPercentage[index % memoryPercentage.length],\n        latency: latencies[index % latencies.length],\n        uptime: uptimes[index % uptimes.length],\n        isRebooting: false\n      };\n    });\n  });\n\n  // Filter States\n  const [projectFilter, setProjectFilter] = useState(\"all\");\n  const [typeFilter, setTypeFilter] = useState(\"all\");\n  const [statusFilter, setStatusFilter] = useState(\"all\");\n  const [stageFilter, setStageFilter] = useState(\"all\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n\n  // Simulated Global Events Ticker\n  const [liveLogTicker, setLiveLogTicker] = useState<string[]>(() => [\n    `[${new Date().toLocaleTimeString()}] Handshake sequence initialized on Sovereign Enclave 02`,\n    `[${new Date().toLocaleTimeString()}] HSM Cryptographic Roll key generated securely`,\n    `[${new Date().toLocaleTimeString()}] NIST compliance scoring algorithm completed: 98.6% PASS`\n  ]);\n\n  useEffect(() => {\n    const interval = setInterval(() => {\n      const activities = [\n        \"Enclave 04: Synchronizing local context stack state\",\n        \"Guardrail Audit: Prompt payload parsed, 0 violations detected\",\n        \"Hardware Check: AMD SEV memory encryption lock verified\",\n        \"Telemetry Sync: Sandbox memory usage stabilized at 27.2 GB\"\n      ];\n      const randomActivity = activities[Math.floor(Math.random() * activities.length)];\n      setLiveLogTicker(prev => [`[${new Date().toLocaleTimeString()}] ${randomActivity}`, ...prev.slice(0, 2)]);\n    }, 5000);\n    return () => clearInterval(interval);\n  }, []);\n\n  const triggerReboot = (agentId: string) => {\n    setAgents(prev => prev.map(agent => {\n      if (agent.id === agentId) {\n        return {\n          ...agent,\n          status: \"evaluating\",\n          isRebooting: true,\n          logs: [\n            ...agent.logs,\n            `[${new Date().toLocaleTimeString()}] INITIATING PHYSICAL ENCLAVE HARDWARE CYCLE...`,\n            `[${new Date().toLocaleTimeString()}] TEARING DOWN MEMORY SECTOR LOOPS`,\n            `[${new Date().toLocaleTimeString()}] FLUSHING CRYPTOGRAPHIC HANDSHAKE CACHES`\n          ]\n        };\n      }\n      return agent;\n    }));\n\n    setTimeout(() => {\n      setAgents(prev => prev.map(agent => {\n        if (agent.id === agentId) {\n          return {\n            ...agent,\n            status: \"active\",\n            isRebooting: false,\n            cpu: Math.floor(Math.random() * 30) + 20,\n            logs: [\n              ...agent.logs,\n              `[${new Date().toLocaleTimeString()}] ENCLAVE RE-ESTABLISHED ON CO-PROCESSOR`,\n              `[${new Date().toLocaleTimeString()}] MEMORY SECTORS RE-ALIGNED SUCCESSFULLY`,\n              `[${new Date().toLocaleTimeString()}] HANDSHAKE VERIFIED: STATUS ACTIVE`\n            ]\n          };\n        }\n        return agent;\n      }));\n    }, 1800);\n  };\n\n  const resetFilters = () => {\n    setProjectFilter(\"all\"); setTypeFilter(\"all\"); setStatusFilter(\"all\"); setStageFilter(\"all\"); setSearchQuery(\"\");\n  };\n\n  const filteredAgents = agents.filter(agent => {\n    const matchesSearch = searchQuery === \"\" || agent.name.toLowerCase().includes(searchQuery.toLowerCase()) || agent.id.toLowerCase().includes(searchQuery.toLowerCase());\n    const matchesProject = projectFilter === \"all\" || agent.projectId === projectFilter;\n    const matchesType = typeFilter === \"all\" || agent.type.toLowerCase() === typeFilter.toLowerCase();\n    const matchesStatus = statusFilter === \"all\" || agent.status.toLowerCase() === statusFilter.toLowerCase();\n    const matchesStage = stageFilter === \"all\" || agent.stage.toLowerCase() === stageFilter.toLowerCase();\n    return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n  });\n\n  const totalThreads = agents.reduce((acc, a) => acc + a.threads, 0);\n\n  return (\n    <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n      \n      {/* 1. SECURE DISCLOSURE BANNER */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2.5 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n          <span>\n            <strong className=\"text-white\">PREVIEW TELEMETRY COMMAND CENTER:</strong> Monitoring sandbox containers and simulated hardware enclaves. This panel coordinates deterministic transaction logs and mock operations without direct runtime mutations.\n          </span>\n        </div>\n        <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0\">\n          DEMO ENVIRONMENT ACTIVE\n        </span>\n      </div>\n\n      {/* 2. PRIVATE PAGE HEADER */}\n      <PrivatePageHeader\n        title=\"AI Operations & Telemetry Command\"\n        desc=\"Audit high-integrity multi-agent runtimes, monitor secure memory boundaries, inspect active model guardrails, and execute localized sandboxed core reboot workflows.\"\n        badgeLabel=\"Level IV clearance\"\n        actions={\n          <div className=\"flex gap-2 w-full md:w-auto\">\n            <Link\n              href=\"/portal/control-center\"\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-[#009DFF]/30 bg-[#009DFF]/10 px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/20 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)]\"\n            >\n              <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n              <span>Sovereign Control Center</span>\n            </Link>\n          </div>\n        }\n      />\n\n      {/* 3. AGENT HEALTH OVERVIEW */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Consensus Health</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white flex items-baseline gap-1\">\n              98.6% <span className=\"text-[11px] font-normal text-emerald-400 font-mono\">Stable</span>\n            </div>\n            <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40\">\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-ping\" />\n              <span>All enclaves in agreement</span>\n            </div>\n          </div>\n          <HealthRing value={98} size={54} strokeWidth={4} colorClass=\"text-emerald-400\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Allocated Threads</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              {totalThreads} Loops\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Across {agents.length} provisioned nodes\n            </div>\n          </div>\n          <div className=\"p-3 bg-[#009DFF]/10 rounded-full text-[#009DFF] border border-[#009DFF]/20\">\n            <Activity className=\"w-5 h-5 animate-pulse\" />\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Enclave RAM Pools</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-white\">\n              27.2 GB\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40\">\n              Of 52.0 GB absolute allocation cap\n            </div>\n          </div>\n          <HealthRing value={52} size={54} strokeWidth={4} colorClass=\"text-[#009DFF]\" />\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"flex items-center justify-between gap-4 p-5\">\n          <div className=\"space-y-1\">\n            <span className=\"text-[10.5px] font-mono tracking-widest text-white/35 uppercase block\">Audit Verification</span>\n            <div className=\"text-[22px] font-bold tracking-tight text-emerald-400 font-mono\">\n              SECURE\n            </div>\n            <div className=\"text-[10px] font-mono text-white/40 flex items-center gap-1\">\n              <Lock className=\"w-3 h-3 text-emerald-400\" />\n              <span>eBPF Boundaries locked</span>\n            </div>\n          </div>\n          <div className=\"p-3 bg-emerald-500/10 rounded-full text-emerald-400 border border-emerald-500/20\">\n            <ShieldCheck className=\"w-5 h-5\" />\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* 4. MANAGED OPERATIONS STATUS RAILS */}\n      <WorkspaceCard className=\"border border-white/5 bg-[#030303]/40 p-4\">\n        <div className=\"font-mono text-[10px] text-white/30 uppercase tracking-widest mb-3 flex items-center gap-2\">\n          <Server className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n          <span>MANAGED CO-PROCESSOR INFRASTRUCTURE STATUS RAILS</span>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Physical Isolation Layer</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">AMD SEV SEALED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">Dynamic Prompt Guardrails</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">ZERO DRIFT</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-[92%]\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">eBPF System Telemetry</span>\n              <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold\">100% AUDITED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-[#009DFF] w-full\" />\n            </div>\n          </div>\n\n          <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-2\">\n            <div className=\"flex justify-between items-center text-[11px] font-mono\">\n              <span className=\"text-white/60 font-semibold\">HSM Secure Key Rotations</span>\n              <span className=\"text-[9px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\">SYNCHRONIZED</span>\n            </div>\n            <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"h-full bg-emerald-400 w-full\" />\n            </div>\n          </div>\n        </div>\n      </WorkspaceCard>\n\n      {/* 5. LIVE ACTIVITY LEDGER STREAM */}\n      <div className=\"bg-black/40 border border-white/5 rounded-xl px-4 py-2.5 flex items-center justify-between gap-4 font-mono text-[10.5px]\">\n        <div className=\"flex items-center gap-2 overflow-hidden w-full\">\n          <Terminal className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n          <span className=\"text-white/30 uppercase shrink-0 font-bold select-none text-[9.5px]\">Attestation Stream:</span>\n          <div className=\"text-white/70 truncate flex items-center gap-2\">\n            <span className=\"w-1 h-1 rounded-full bg-emerald-500 animate-ping inline-block shrink-0\" />\n            <span>{liveLogTicker[0] || \"Awaiting hardware handshake...\"}</span>\n          </div>\n        </div>\n        <div className=\"text-white/30 hidden md:block select-none text-[9px] uppercase tracking-wider shrink-0\">\n          Continuous Audit Loop Active\n        </div>\n      </div>\n\n      {/* PLACEHOLDER_FOR_PART_2 */}\n\n    </div>\n  );\n}"}}}
