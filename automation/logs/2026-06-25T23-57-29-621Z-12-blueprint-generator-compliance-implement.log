ssNeedScore,\n257 |     dataReadinessScore,\n258 |     processComplexityScore,\n259 |     transformationReadinessScore,\n260 |   } = input;\n261 |   \n262 |   const score = \n263 |     (aiMaturityScore * 0.20) + \n264 |     (businessNeedScore * 0.25) + \n265 |     (dataReadinessScore * 0.20) + \n266 |     (processComplexityScore * 0.20) + \n267 |     (transformationReadinessScore * 0.15);\n268 |     \n269 |   return Math.round(score);\n270 | }\n271 | \n272 | export function getScoreCategory(score: number) {\n273 |   if (score <= 25) return \"AI Beginner\";\n274 |   if (score <= 50) return \"AI Explorer\";\n275 |   if (score <= 70) return \"AI Adopter\";\n276 |   if (score <= 85) return \"AI Transformer\";\n277 |   return \"AI-Native Leader\";\n278 | }\n279 | \n280 | export function getRecommendedOpportunities(industry: string, priorities: string[]) {\n281 |   const defaults = [\n282 |     \"Procurement Copilot\",\n283 |     \"HR Assistant\",\n284 |     \"Contract Intelligence\",\n285 |     \"Knowledge Search\",\n286 |     \"Executive Dashboard\"\n287 |   ];\n288 |   \n289 |   if (industry === \"Banking\" && priorities.includes(\"Strengthen Compliance\")) {\n290 |     return [\"Contract Intelligence\", \"Compliance Copilot\", \"Executive Dashboard\", \"Knowledge Search\", \"Risk Operations Assistant\"];\n291 |   }\n292 |   \n293 |   if (industry === \"Retail\" && (priorities.includes(\"Increase Revenue\") || priorities.includes(\"Improve Customer Experience\"))) {\n294 |     return [\"Customer Experience Copilot\", \"Store Operations Assistant\", \"Merchandising Intelligence\", \"Knowledge Search\", \"Executive Dashboard\"];\n295 |   }\n296 |   \n297 |   if (industry === \"Manufacturing\" && (priorities.includes(\"Improve Productivity\") || priorities.includes(\"Automate Processes\"))) {\n298 |     return [\"Maintenance Copilot\", \"Production Knowledge Search\", \"Procurement Copilot\", \"Quality Intelligence\", \"Executive Dashboard\"];\n299 |   }\n300 |   \n301 | 