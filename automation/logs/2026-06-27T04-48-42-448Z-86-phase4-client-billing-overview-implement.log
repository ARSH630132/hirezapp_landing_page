tween pt-1\">\n              <span className=\"text-white/45\">Payment Status:</span>\n              <span className=\"text-green-400 font-bold uppercase text-[11px] bg-green-400/5 border border-green-400/25 px-1.5 py-0.5 rounded\">Good Standing</span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between\">\n          <div className=\"space-y-3\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n              <ShieldCheck className=\"w-5 h-5 text-green-400\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Cryptographic Invoices</h3>\n            </div>\n            <p className=\"text-xs text-white/50 leading-relaxed\">\n              Every billing cycle is cryptographically verified and signed by the GFF Treasury. Inspect settled epoch invoices, verify ledger references, and pull verified PDF receipts.\n            </p>\n          </div>\n          <div className=\"pt-4\">\n            <Link\n              href=\"/portal/billing/invoices\"\n              className=\"inline-flex h-10 px-5 rounded bg-white hover:bg-white/90 text-black font-semibold text-[11px] uppercase tracking-wider items-center gap-1.5 transition-all cursor-pointer\"\n            >\n              <span>View Invoice Ledger</span>\n              <ArrowRight className=\"w-3.5 h-3.5\" />\n            </Link>\n          </div>\n        </div>\n      </div>\n    </div>\n  );","new_text":"  return (\n    <div className=\"space-y-6\">\n      {/* Premium Title Segment */}\n      <div className=\"relative overflow-hidden rounded-xl border border-white/5 bg-[#030303] p-6\">\n        <div className=\"relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4\">\n          <div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Sovereign Spend & Bill Ledger</h2>\n            <p className=\"text-xs text-white/50 mt-1 max-w-xl\">\n              Manage cryptographic subscriptions, monitor SLA quotas, and view verified epoch ledgers sealed by GFF Treasury.\n            </p>\n          </div>\n          <Link\n            href=\"/portal/billing/invoices\"\n            className=\"inline-flex h-9 px-4 rounded bg-white hover:bg-white/90 text-black font-semibold text-[11px] uppercase tracking-wider items-center gap-1.5 transition-all cursor-pointer\"\n          >\n            <span>View All Invoices</span>\n            <ArrowRight className=\"w-3.5 h-3.5\" />\n          </Link>\n        </div>\n      </div>\n\n      {/* Metrics Bento Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n            <CreditCard className=\"w-4 h-4 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Plan Parameters</h3>\n          </div>\n          <div className=\"space-y-2 font-mono text-[11px] text-white/70\">\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Active Tier:</span>\n              <span className=\"text-white font-bold\">Enterprise Infinite</span>\n            </div>\n            <div className=\"flex justify-between\">\n              <span className=\"text-white/40\">Sandbox Cores:</span>\n              <span className=\"text-white\">4 Cores Active</span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n            <Briefcase className=\"w-4 h-4 text-[#00FFC2]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Summary</h3>\n          </div>\n          <div className=\"space-y-2 font-mono text-[11px] text-white/70\">\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Total Spent:</span>\n              <span className=\"text-[#009DFF] font-bold\">$51,470.00 USD</span>\n            </div>\n            <div className=\"flex justify-between\">\n              <span className=\"text-white/40\">Settled (Paid):</span>\n              <span className=\"text-green-400\">$18,320.00 USD</span>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between space-y-3\">\n          <div className=\"space-y-1\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n              <ShieldCheck className=\"w-4 h-4 text-green-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Integrity</h3>\n            </div>\n            <p className=\"text-[10px] text-white/50 leading-relaxed font-mono\">\n              Invoices are cryptographically co-signed under isolated hardware security.\n            </p>\n          </div>\n          <button \n            onClick={() => {\n              setVerifying(true);\n              setTimeout(() => setVerifying(false), 1000);\n            }}\n            disabled={verifying}\n            className=\"w-full h-8 flex items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.02] text-[10px] font-mono font-bold text-white hover:bg-white/[0.05] transition-all cursor-pointer disabled:opacity-50\"\n          >\n            {verifying ? (\n              <RefreshCw className=\"w-3 h-3 animate-spin text-[#009DFF]\" />\n            ) : (\n              <ShieldCheck className=\"w-3 h-3 text-green-400\" />\n            )}\n            <span>{verifying ? \"VERIFYING SEALS...\" : \"LEDGER SEAL VALID\"}</span>\n          </button>\n        </div>\n      </div>\n\n      {/* Invoice Ledger Section */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div>\n            <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Recent Certified Invoices</h3>\n            <p className=\"text-xs text-white/40 mt-0.5 font-mono\">Verified statements and corresponding localized project mappings.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            {invoices.map((inv) => (\n              <div key={inv.id} className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/50 hover:border-white/10 transition-all space-y-3 font-mono text-[11px]\">\n                <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2\">\n                  <div className=\"flex items-center gap-2.5\">\n                    <span className=\"font-bold text-white\">{inv.id}</span>\n                    <span className=\"text-white/30\">|</span>\n                    <span className=\"text-white/50\">{inv.category}</span>\n                  </div>\n                  <span className={`inline-block px-2 py-0.5 rounded text-[9px] font-bold uppercase ${\n                    inv.status === \"paid\" ? \"bg-green-500/10 border border-green-500/20 text-green-400\" :\n                    inv.status === \"processing\" ? \"bg-blue-500/10 border border-blue-500/20 text-[#009DFF]\" :\n                    \"bg-amber-500/10 border border-amber-500/20 text-amber-400\"\n                  }`}>\n                    {inv.status}\n                  </span>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3 text-white/60 text-[10.5px] border-t border-b border-white/[0.03] py-2\">\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">PROJECT ANCHOR</span>\n                    <span className=\"text-white font-bold\">{PROJECTS[inv.id]}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">DUE DATE</span>\n                    <span>{inv.dueDate}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">AMOUNT PREVIEW</span>\n                    <span className=\"text-[#009DFF] font-bold\">{inv.amount}</span>\n                  </div>\n                </div>\n\n                <div className=\"flex justify-between items-center pt-1 text-[10px]\">\n                  <button \n                    onClick={() => setSelInvoice(inv)}\n                    className=\"text-white hover:text-[#009DFF] hover:underline font-bold transition-all cursor-pointer\"\n                  >\n                    View invoice preview &gt;\n                  </button>\n                  <button \n                    onClick={() => handleCopy(inv.hash, inv.id)}\n                    className=\"text-white/40 hover:text-white cursor-pointer\"\n                  >\n                    {copiedId === inv.id ? \"COPIED REF\" : \"Copy ledger hash\"}\n                  </button>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Contact Treasury Card */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-4\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Treasury Liaison Desk</h3>\n              <p className=\"text-[10px] text-white/40 font-mono mt-0.5\">Encrypted non-automated 