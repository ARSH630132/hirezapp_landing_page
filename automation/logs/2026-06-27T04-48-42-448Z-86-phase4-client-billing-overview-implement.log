{"ts":"2026-06-27T04:42:37.917Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"r70dpvv9","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/billing/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport Link from \"next/link\";\nimport { ArrowRight, CreditCard, ShieldCheck, RefreshCw, Copy, Check, Briefcase, HelpCircle, Download } from \"lucide-react\";\n\nconst PROJECTS_MAPPING: Record<string, string> = {\n  \"GFF-2026-0899\": \"Retail Mesh Core A1\",\n  \"GFF-2026-0914\": \"Sovereign Mining Loop\",\n  \"GFF-2026-0945\": \"Singapore Sandbox Enclave\",\n  \"GFF-2026-0988\": \"Multi-Agent Inference Cluster\",\n};\n\nexport default function ClientBillingPage() {\n  const [verifying, setVerifying] = useState(false);\n  const [sigOk, setSigOk] = useState(true);\n  const [copiedId, setCopiedId] = useState<string | null>(null);\n  const [selInvoice, setSelInvoice] = useState<any | null>(null);\n  const [inquirySent, setInquirySent] = useState(false);\n\n  const previewInvoices = [\n    { id: \"GFF-2026-0899\", date: \"2026-06-01\", amount: \"14,820.00 USD\", status: \"paid\", dueDate: \"2026-06-15\", category: \"Compute Epoch\", hash: \"0xDE897FF021BC8102C019FFAD998E1256E3B890CC7FFADE138EE87A02FF90A11B\" },\n    { id: \"GFF-2026-0914\", date: \"2026-06-15\", amount: \"3,500.00 USD\", status: \"paid\", dueDate: \"2026-06-30\", category: \"SLA Support\", hash: \"0x11B8A02FEE907C10BDE8267FEE10BC91A23D4FFA289F02ECBC12A349CDE150FA\" },\n    { id: \"GFF-2026-0945\", date: \"2026-06-25\", amount: \"24,900.00 USD\", status: \"processing\", dueDate: \"2026-07-10\", category: \"Telemetry Stream\", hash: \"0x8FDE3102C130D7B2D26788AB0E8A850CE3207FFCDE10B74E824A45B12A4F23AA\" },\n    { id: \"GFF-2026-0988\", date: \"2026-06-27\", amount: \"8,250.00 USD\", status: \"unpaid\", dueDate: \"2026-07-15\", category: \"Compute Epoch\", hash: \"0x3FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89FBC10492\" }\n  ];\n\n  const handleVerify = () => {\n    setVerifying(true);\n    setTimeout(() => {\n      setVerifying(false);\n      setSigOk(true);\n    }, 1200);\n  };\n\n  const handleCopy = (text: string, id: string) => {\n    navigator.clipboard.writeText(text);\n    setCopiedId(id);\n    setTimeout(() => setCopiedId(null), 1500);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header section with narrative context */}\n      <div className=\"relative overflow-hidden rounded-xl border border-white/5 bg-[#030303] p-6\">\n        <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#009DFF]/5 rounded-full filter blur-2xl pointer-events-none\" />\n        <div className=\"relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4\">\n          <div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Billing & Sovereign Quotas</h2>\n            <p className=\"text-xs text-white/50 mt-1 max-w-xl\">\n              Manage cryptographic subscriptions, monitor SLA quotas, and view verified epoch ledgers sealed by GFF Treasury.\n            </p>\n          </div>\n          <Link\n            href=\"/portal/billing/invoices\"\n            className=\"inline-flex h-9 px-4 rounded bg-white hover:bg-white/90 text-black font-semibold text-[11px] uppercase tracking-wider items-center gap-1.5 transition-all cursor-pointer\"\n          >\n            <span>View All Invoices</span>\n            <ArrowRight className=\"w-3.5 h-3.5\" />\n          </Link>\n        </div>\n      </div>\n\n      {/* Metrics Bento Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        {/* Metric 1: Plan Parameters */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-2\">\n              <CreditCard className=\"w-4 h-4 text-[#009DFF]\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Plan Parameters</h3>\n            </div>\n            <span className=\"text-[9px] bg-green-500/10 border border-green-500/20 text-green-400 px-1.5 py-0.5 rounded font-mono font-bold uppercase\">Good Standing</span>\n          </div>\n          <div className=\"space-y-2.5 font-mono text-[11px] text-white/70\">\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Active Tier:</span>\n              <span className=\"text-white font-bold\">Enterprise Infinite</span>\n            </div>\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Cycle:</span>\n              <span className=\"text-white\">Monthly Enclave</span>\n            </div>\n            <div className=\"flex justify-between\">\n              <span className=\"text-white/40\">Sandbox Cores:</span>\n              <span className=\"text-white\">4 Cores Active</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Metric 2: Financial Standing Summary */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-2\">\n              <Briefcase className=\"w-4 h-4 text-[#00FFC2]\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Summary</h3>\n            </div>\n            <span className=\"text-[9px] text-white/55 font-mono\">YTD 2026</span>\n          </div>\n          <div className=\"space-y-2.5 font-mono text-[11px] text-white/70\">\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Total Spent YTD:</span>\n              <span className=\"text-[#009DFF] font-bold\">$51,470.00 USD</span>\n            </div>\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Settled (Paid):</span>\n              <span className=\"text-green-400\">$18,320.00 USD</span>\n            </div>\n            <div className=\"flex justify-between\">\n              <span className=\"text-white/40\">Due & Pending:</span>\n              <span className=\"text-amber-400 font-bold\">$33,150.00 USD</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Metric 3: Cryptographic Integrity */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between space-y-3\">\n          <div className=\"space-y-2\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n              <ShieldCheck className=\"w-4 h-4 text-green-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Integrity</h3>\n            </div>\n            <p className=\"text-[10px] text-white/50 leading-relaxed font-mono\">\n              Invoices are cryptographically sealed under isolated HSM security architectures.\n            </p>\n          </div>\n          <button \n            onClick={handleVerify}\n            disabled={verifying}\n            className=\"w-full h-8 flex items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.02] text-[10px] font-mono font-bold text-white hover:bg-white/[0.05] transition-all cursor-pointer disabled:opacity-50\"\n          >\n            {verifying ? (\n              <>\n                <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#009DFF]\" />\n                <span>EXCHANGING SEALS...</span>\n              </>\n            ) : sigOk ? (\n              <>\n                <ShieldCheck className=\"w-3.5 h-3.5 text-green-400\" />\n                <span className=\"text-green-400\">LEDGER SEAL VALID</span>\n              </>\n            ) : (\n              <span>VERIFY COVENANT SEAL</span>\n            )}\n          </button>\n        </div>\n      </div>\n\n      {/* Invoice list with project association & actions */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div>\n            <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Recent Certified Invoices</h3>\n            <p className=\"text-xs text-white/40 mt-0.5 font-mono\">Verified statements and corresponding localized project mappings.</p>\n          </div>\n\n          <div className=\"space-y-3\">\n            {previewInvoices.map((inv) => (\n              <div \n                key={inv.id} \n                className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/50 hover:border-white/10 transition-all space-y-3 font-mono text-[11px]\"\n              >\n                <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-2\">\n                  <div className=\"flex items-center gap-2.5\">\n                    <span className=\"font-bold text-white\">{inv.id}</span>\n                    <span className=\"text-white/30\">|</span>\n                    <span className=\"text-white/50\">{inv.category}</span>\n                  </div>\n                  <span className={`inline-block self-start sm:self-auto px-2 py-0.5 rounded text-[9px] font-bold uppercase ${\n                    inv.status === \"paid\" ? \"bg-green-500/10 border border-green-500/20 text-green-400\" :\n                    inv.status === \"processing\" ? \"bg-blue-500/10 border border-blue-500/20 text-[#009DFF]\" :\n                    \"bg-amber-500/10 border border-amber-500/20 text-amber-400\"\n                  }`}>\n                    {inv.status}\n                  </span>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3 text-white/60 text-[10.5px] border-t border-b border-white/[0.03] py-2\">\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">PROJECT ANCHOR</span>\n                    <span className=\"text-white font-bold\">{PROJECTS_MAPPING[inv.id]}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">DUE DATE</span>\n                    <span>{inv.dueDate}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/30 block text-[9px]\">AMOUNT PREVIEW</span>\n                    <span className=\"text-[#009DFF] font-bold\">{inv.amount}</span>\n                  </div>\n                </div>\n\n                <div className=\"flex justify-between items-center pt-1 text-[10px]\">\n                  <button \n                    onClick={() => setSelInvoice(inv)}\n                    className=\"text-white hover:text-[#009DFF] hover:underline font-bold transition-all cursor-pointer\"\n                  >\n                    View invoice preview &gt;\n                  </button>\n                  <button \n                    onClick={() => handleCopy(inv.hash, inv.id)}\n                    className=\"text-white/40 hover:text-white flex items-center gap-1 cursor-pointer\"\n                  >\n                    {copiedId === inv.id ? (\n                      <span className=\"text-green-400 font-bold\">COPIED REFERENCE HASH</span>\n                    ) : (\n                      <span>Copy ledger hash</span>\n                    )}\n                  </button>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Billing Contact & Wire Parameters Card */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-4\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Treasury Liaison Desk</h3>\n              <p className=\"text-[10px] text-white/40 font-mono mt-0.5\">Encrypted non-automated wire support.</p>\n            </div>\n\n            <div className=\"p-4 rounded border border-white/5 bg-black space-y-2.5 font-mono text-[10.5px]\">\n              <div>\n                <span className=\"text-white/30 block text-[9px]\">SWIFT ROUTER CODE</span>\n                <span className=\"text-white font-bold\">GFF-AI-TREAS-BER</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block text-[9px]\">SECURE EMAIL CHANNEL</span>\n                <span className=\"text-white\">treasury@gff.ai</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block text-[9px]\">SWIFT TELEMETRY INDEX</span>\n                <span className=\"text-white font-mono\">0xTRUST-BER-88</span>\n              </div>\n            </div>\n\n            {inquirySent ? (\n              <div className=\"p-3 rounded border border-green-500/20 bg-green-500/5 text-green-400 font-mono text-[10.5px] text-center\">\n                Inquiry registered. GFF treasury desk notified.\n              </div>\n            ) : (\n              <div className=\"space-y-2 pt-1\">\n                <span className=\"text-[10px] text-white/45 font-mono uppercase\">Direct Escalation</span>\n                <button \n                  onClick={() => {\n                    setInquirySent(true);\n                    setTimeout(() => setInquirySent(false), 4000);\n                  }}\n                  className=\"w-full h-8 bg-white hover:bg-white/90 text-black text-[10.5px] font-bold uppercase rounded transition-all cursor-pointer\"\n                >\n                  Contact GFF Treasury Desk\n                </button>\n              </div>\n            )}\n          </div>\n\n          <p className=\"text-[9.5px] text-white/30 leading-relaxed font-mono\">\n            Always specify invoice ledger references in SWIFT metadata to enable instant AMD SEV enclave automated receipt matching.\n          </p>\n        </div>\n      </div>\n\n      {/* Dynamic invoice detail overlay */}\n      {selInvoice && (\n        <div className=\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex justify-end\">\n          <div className=\"w-full max-w-md h-full bg-[#050505] border-l border-white/10 p-6 overflow-y-auto space-y-6 flex flex-col justify-between\">\n            <div className=\"space-y-6\">\n              <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n                <div>\n                  <span className=\"text-[9px] bg-blue-500/10 border border-blue-500/20 text-[#009DFF] px-1.5 py-0.5 rounded font-mono font-bold uppercase\">Statement preview</span>\n                  <h3 className=\"text-lg font-bold text-white font-mono mt-1\">{selInvoice.id}</h3>\n                  <span className=\"text-[10px] text-white/40 font-mono block mt-0.5\">Project: {PROJECTS_MAPPING[selInvoice.id]}</span>\n                </div>\n                <button \n                  onClick={() => setSelInvoice(null)}\n                  className=\"p-1 rounded text-white/40 hover:text-white cursor-pointer text-sm font-mono\"\n                >\n                  [CLOSE]\n                </button>\n              </div>\n\n              <div className=\"space-y-4 font-mono text-[11px]\">\n                <div className=\"p-3.5 rounded bg-black border border-white/5 space-y-2\">\n                  <div className=\"flex justify-between text-white/40 text-[10px]\">\n                    <span>LEDGER CRYPTO SEAL</span>\n                    <button \n                      onClick={() => handleCopy(selInvoice.hash, \"sel\")}\n                      className=\"text-[#009DFF] hover:underline\"\n                    >\n                      COPY\n                    </button>\n                  </div>\n                  <div className=\"text-[9px] text-white/80 break-all select-all font-mono leading-relaxed bg-white/[0.02] p-2 rounded\">\n                    {selInvoice.hash}\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <h4 className=\"text-[10.5px] font-bold text-white uppercase border-b border-white/5 pb-1\">Resource Breakdown</h4>\n                  <div className=\"space-y-1.5 text-white/70\">\n                    <div className=\"flex justify-between\">\n                      <span>{selInvoice.category} SLA Allocation</span>\n                      <span className=\"text-white font-bold\">{selInvoice.amount}</span>\n                    </div>\n                    <div className=\"flex justify-between text-[10px] text-white/40\">\n                      <span>Sovereign Enclave Memory Limits</span>\n                      <span>Verified Bound</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"p-3 rounded border border-white/[0.03] bg-white/[0.01] space-y-2 text-[10.5px] text-white/50\">\n                  <div className=\"flex justify-between\">\n                    <span>Invoice Timestamp:</span>\n                    <span className=\"text-white\">{selInvoice.date}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>Epoch Due Date:</span>\n                    <span className=\"text-white\">{selInvoice.dueDate}</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"space-y-3 pt-6 border-t border-white/5\">\n              <button \n                onClick={() => alert(\"This simulates pulling secure audit logs for ledger: \" + selInvoice.id)}\n                className=\"w-full h-9 rounded bg-white hover:bg-white/95 text-black font-semibold text-[11px] uppercase tracking-wider flex items-center justify-center gap-1.5 transition-all cursor-pointer\"\n              >\n                <Download className=\"w-3.5 h-3.5\" />\n                <span>Download Certified PDF receipt</span>\n              </button>\n              <button \n                onClick={() => {\n                  setInquirySent(true);\n                  setSelInvoice(null);\n                  setTimeout(() => setInquirySent(false), 4000);\n                }}\n                className=\"w-full h-9 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-white font-semibold text-[11px] uppercase tracking-wider transition-all cursor-pointer\"\n              >\n                Contact Finance Desk\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
