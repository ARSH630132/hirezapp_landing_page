ler.clientAssociation);\n28 |       if (op.client_id !== cid) {\n29 |         return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n30 |       }\n31 |     }\n32 |     return NextResponse.json({ success: true, operation: op });\n33 |   } catch (err) {\n34 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n35 |   }\n36 | }\n37 | \n38 | export async function PATCH(req: Request, { params }: { params: any }) {\n39 |   try {\n40 |     const caller = getAuthCaller(req);\n41 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n42 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n43 |     \n44 |     const { id } = await params;\n45 |     const op = (API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id];\n46 |     if (!op) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n47 |     \n48 |     const body = await req.json().catch(() => null);\n49 |     if (!body) return NextResponse.json({ success: false, error: \"Bad Request\" }, { status: 400 });\n50 | \n51 |     const fields = [\"name\", \"project_id\", \"status\", \"health\", \"agent_type\", \"governance_status\", \"owner\", \"desc\", \"client_id\"];\n52 |     for (const key of fields) {\n53 |       if (body[key] !== undefined) {\n54 |         if (key === \"name\" && (typeof body.name !== \"string\" || !body.name.trim())) {\n55 |           return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid name\" }, { status: 400 });\n56 |         }\n57 |         if (key === \"client_id\") {\n58 |           const valids = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n59 |           if (!valids.includes(body.client_id)) {\n60 |             return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id\" }, { status: 400 });\n61 |           }\n62 |           op.client_id = body.client_id;\n63 |           op.client_name = getClientNameFromId(body.client_id);\n64 |         } else {\n65 |           (op as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n66 |         }\n67 |       }\n68 |     }\n69 |     op.lastUpdated = new Date().toISOString();\n70 |     (API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id] = op;\n71 |     return NextResponse.json({ success: true, operation: op });\n72 |   } catch (err) {\n73 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n74 |   }\n75 | }\n76 | \n77 | export async function DELETE(req: Request, { params }: { params: any }) {\n78 |   try {\n79 |     const caller = getAuthCaller(req);\n80 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n81 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n82 |     \n83 |     const { id } = await params;\n84 |     if (!(API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id]) {\n85 |       return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n86 |     }\n87 |     delete (API_MOCK_AI_OPERATIONS as Record<string, ApiAiOperation>)[id];\n88 |     return NextResponse.json({ success: true, message: \"AI Operation deleted.\" });\n89 |   } catch (err) {\n90 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n91 |   }\n92 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-ai-operations-apis.js","result":" 1 | const { execSync } = require('child_process');\n 2 | const fs = require('fs');\n 3 | const path = require('path');\n 4 | const T = path.join(__dirname, '..', 'temp-ai-op-build');\n 5 | if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n 6 | try {\n 7 |   execSync('npx tsc lib/api-auth.ts app/api/v1/ai-operations/route.ts app/api/v1/ai-operations/[id]/route.ts --outDir temp-ai-op-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n 8 | } catch (e) {\n 9 |   process.exit(1);\n10 | }\n11 | const apiAuth = require('../temp-ai-op-build/lib/api-auth.js');\n12 | const opR = require('../temp-ai-op-build/app/api/v1/ai-operations/route.js');\n13 | const opIdR = require('../temp-ai-op-build/app/api/v1/ai-operations/[id]/route.js');\n14 | function getAuth(email) {\n15 |   const u = apiAuth.API_MOCK_USERS[email];\n16 |   return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n17 | }\n18 | async function run() {\n19 |   try {\n20 |     const admin = getAuth(\"s.vance@governance.gff.ai\");\n21 |     const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n22 |     const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n23 |     const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n24 |     let r = await opR.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": inactive } }));\n25 |     if (r.status !== 403) throw new Error(\"1\");\n26 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations\"));\n27 |     if (r.status !== 401) throw new Error(\"2\");\n28 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": admin } }));\n29 |     let d = await r.json();\n30 |     if (r.status !== 200 || d.operations.length < 4) throw new Error(\"3\");\n31 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": member } }));\n32 |     d = await r.json();\n33 |     if (d.operations.some(o => o.client_id !== \"client-004\")) throw new Error(\"4\");\n34 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations?client_id=client-001&status=active&health=healthy&agent_type=autonomous&governance_status=compliant\", { headers: { \"Authorization\": admin } }));\n35 |     d = await r.json();\n36 |     if (d.operations.some(o => o.client_id !== \"client-001\" || o.status !== \"active\")) throw new Error(\"5\");\n37 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations?project_id=proj-003\", { headers: { \"Authorization\": admin } }));\n38 |     d = await r.json();\n39 |     if (d.operations.some(o => o.project_id !== \"proj-003\")) throw new Error(\"6\");\n40 |     r = await opR.GET(new Request(\"http://l/api/v1/ai-operations?search=Logistics\", { headers: { \"Authorization\": admin } }));\n41 |     d = await r.json();\n42 |     if (!d.operations[0]?.name.toLowerCase().includes(\"logistics\")) throw new Error(\"7\");\n43 |     r = await opIdR.GET(new Request(\"http://l/api/v1/ai-operations/op-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"op-001\" }) });\n44 |     d = await r.json();\n45 |     if (r.status !== 200 || d.operation.id !== \"op-001\") throw new Error(\"8\");\n46 |     r = await opIdR.GET(new Request(\"http://l/api/v1/ai-operations/op-004\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"op-004\" }) });\n47 |     if (r.status !== 403) throw new Error(\"9\");\n48 |     const pData = { name: \"Sovereign Market Predictor\", client_id: \"client-002\", project_id: \"proj-002\", desc: \"Sandbox loop\" };\n49 |     r = await opR.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(pData) }));\n50 |     if (r.status !== 403) throw new Error(\"10\");\n51 |     r = await opR.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(pData) }));\n52 |     if (r.status !== 201) throw new Error(\"11\");\n53 |     d = await r.json();\n54 |     const createdId = d.operation.id;\n55 |     if (d.operation.client_name !== \"Global Retail Enclave [Preview Client]\") throw new Error(\"12\");\n56 |     r = await opIdR.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ name: \"Hacked\" }) }), { params: Promise.resolve({ id: createdId }) });\n57 |     if (r.status !== 403) throw new Error(\"13\");\n58 |     r = await opIdR.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ name: \"Sandbox Run\", health: \"critical\" }) }), { params: Promise.resolve({ id: createdId }) });\n59 |     if (r.status !== 200) throw new Error(\"14\");\n60 |     d = await r.json();\n61 |     if (d.operation.name !== \"Sandbox Run\" || d.operation.health !== \"critical\") throw new Error(\"15\");\n62 |     r = await opIdR.DELETE(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"DELETE\", headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: createdId }) });\n63 |     if (r.status !== 403) throw new Error(\"16\");\n64 |     r = await opIdR.DELETE(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n65 |     if (r.status !== 200) throw new Error(\"17\");\n66 |     r = await opIdR.GET(new Request(`http://l/api/v1/ai-operations/${createdId}`, { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n67 |     if (r.status !== 404) throw new Error(\"18\");\n68 |     console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: AI Operations CRUD APIs verified flawlessly!\\x1b[0m\");\n69 |     process.exit(0);\n70 |   } catch (err) {\n71 |     console.error(\"\\x1b[31m✖ Validation test failed:\\x1b[0m\", err.stack || err.message);\n72 |     process.exit(1);\n73 |   } finally {\