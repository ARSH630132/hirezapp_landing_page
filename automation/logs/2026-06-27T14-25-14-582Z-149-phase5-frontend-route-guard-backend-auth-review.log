              </div>\n761 |             </div>\n762 | \n763 |             {/* Bottom Actions */}\n764 |             <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n765 |               <button \n766 |                 onClick={() => router.push(type === \"portal\" ? \"/portal/dashboard\" : \"/admin/dashboard\")}\n767 |                 className=\"flex-1 h-10 rounded-lg border border-white/10 hover:border-white/20 bg-transparent text-white text-[10px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center justify-center gap-1.5 focus-visible:outline focus-visible:outline-1 focus-visible:outline-white\"\n768 |               >\n769 |                 <ArrowRight className=\"w-3.5 h-3.5 transform rotate-180\" />\n770 |                 <span>Return to Workspace Safety</span>\n771 |               </button>\n772 |               \n773 |               <button \n774 |                 onClick={() => handleBypass(\"gff_admin\")}\n775 |                 disabled={negotiating !== null}\n776 |                 className=\"flex-1 h-10 rounded-lg bg-gradient-to-r from-red-600 to-red-700 hover:from-red-500 hover:to-red-600 text-white text-[10px] font-bold uppercase tracking-wider flex items-center justify-center gap-2 cursor-pointer shadow-lg shadow-red-950/30 transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-red-500 disabled:opacity-40\"\n777 |               >\n778 |                 {negotiating === \"gff_admin\" ? (\n779 |                   <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n780 |                 ) : (\n781 |                   <Key className=\"w-3.5 h-3.5\" />\n782 |                 )}\n783 |                 <span>Override with GFF Sovereign</span>\n784 |               </button>\n785 |             </div>\n786 |           </div>\n787 |         </div>\n788 |       </div>\n789 |     );\n790 |   }\n791 | \n792 |   const isAdminInPortal = type === \"portal\" && session && session.role.startsWith(\"gff_\");\n793 | \n794 |   return (\n795 |     <>\n796 |       {/* Sovereign Admin Simulation banner block */}\n797 |       {isAdminInPortal && !dismissBanner && (\n798 |         <div className=\"sticky top-0 z-50 bg-[#06151d]/85 border-b border-cyan-500/15 px-4 md:px-6 py-2.5 flex flex-col sm:flex-row gap-2 sm:items-center justify-between text-[10px] font-mono text-cyan-200 backdrop-blur-md select-none\">\n799 |           <div className=\"flex items-center gap-2.5\">\n800 |             <span className=\"relative flex h-2 w-2\">\n801 |               <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\"></span>\n802 |               <span className=\"relative inline-flex rounded-full h-2 w-2 bg-cyan-500\"></span>\n803 |             </span>\n804 |             <span>\n805 |               <strong className=\"text-cyan-100 uppercase tracking-wider\">Sovereign Simulation Console:</strong> Active in Client Workspace (L5 clearance).\n806 |             </span>\n807 |           </div>\n808 |           <div className=\"flex items-center gap-4 justify-between sm:justify-end\">\n809 |             <button \n810 |               onClick={() => handleBypass(\"client_admin\")}\n811 |               disabled={negotiating !== null}\n812 |               className=\"px-3 py-1 rounded-lg bg-cyan-500/10 hover:bg-cyan-500/20 border border-cyan-400/20 text-cyan-300 hover:text-cyan-200 text-[9px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center gap-1.5\"\n813 |             >\n814 |               {negotiating ? <RefreshCw className=\"w-2.5 h-2.5 animate-spin\" /> : <Sparkles className=\"w-2.5 h-2.5 text-cyan-400 animate-pulse\" />}\n815 |               <span>De-escalate to Client Admin</span>\n816 |             </button>\n817 |             <button \n818 |               onClick={() => setDismissBanner(true)} \n819 |               className=\"text-cyan-400/50 hover:text-cyan-200 transition-colors text-[9px] uppercase tracking-wider font-bold cursor-pointer\"\n820 |             >\n821 |               Dismiss [X]\n822 |             </button>\n823 |           </div>\n824 |         </div>\n825 |       )}\n826 |       {children}\n827 |     </>\n828 |   );\n829 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/preview-auth.ts","result":"  1 | \"use client\";\n  2 | \n  3 | export type PreviewRole =\n  4 |   | \"client_admin\"\n  5 |   | \"client_member\"\n  6 |   | \"gff_admin\"\n  7 |   | \"gff_operator\"\n  8 |   | \"finance_admin\"\n  9 |   | \"support_agent\"\n 10 |   | \"viewer\";\n 11 | \n 12 | export interface PreviewSession {\n 13 |   name: string;\n 14 |   email: string;\n 15 |   role: PreviewRole;\n 16 |   clearance: string;\n 17 |   isMock: boolean;\n 18 |   label: string;\n 19 | }\n 20 | \n 21 | export const MOCK_PREVIEW_USERS: Record<PreviewRole, PreviewSession> = {\n 22 |   client_admin: {\n 23 |     name: \"INTERNAL-PREVIEW-CLIENT-ADMIN\",\n 24 |     email: \"preview-client-admin@internal.gff.ai\",\n 25 |     role: \"client_admin\",\n 26 |     clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\",\n 27 |     isMock: true,\n 28 |     label: \"PREVIEW ONLY - MOCK CLIENT ADMIN\",\n 29 |   },\n 30 |   client_member: {\n 31 |     name: \"INTERNAL-PREVIEW-CLIENT-MEMBER\",\n 32 |     email: \"preview-client-member@internal.gff.ai\",\n 33 |     role: \"client_member\",\n 34 |     clearance: \"CLEARANCE LEVEL II (SANDBOX WORKER)\",\n 35 |     isMock: true,\n 36 |     label: \"PREVIEW ONLY - MOCK CLIENT MEMBER\",\n 37 |   },\n 38 |   gff_admin: {\n 39 |     name: \"INTERNAL-PREVIEW-GFF-ADMIN\",\n 40 |     email: \"preview-gff-admin@internal.gff.ai\",\n 41 |     role: \"gff_admin\",\n 42 |     clearance: \"CLEARANCE LEVEL V (SECURE SUPERUSER)\",\n 43 |     isMock: true,\n 44 |     label: \"PREVIEW ONLY - GFF SUPER-ADMIN\",\n 45 |   },\n 46 |   gff_operator: {\n 47 |     name: \"INTERNAL-PREVIEW-GFF-OPERATOR\",\n 48 |     email: \"preview-gff-operator@internal.gff.ai\",\n 49 |     role: \"gff_operator\",\n 50 |     clearance: \"CLEARANCE LEVEL IV (GFF TECHNICAL OPERATOR)\",\n 51 |     isMock: true,\n 52 |     label: \"PREVIEW ONLY - GFF TECHNICAL OPERATOR\",\n 53 |   },\n 54 |   finance_admin: {\n 55 |     name: \"INTERNAL-PREVIEW-FINANCE-ADMIN\",\n 56 |     email: \"preview-finance-admin@internal.gff.ai\",\n 57 |     role: \"finance_admin\",\n 58 |     clearance: \"CLEARANCE LEVEL III (GFF FINANCIAL CONTROLLER)\",\n 59 |     isMock: true,\n 60 |     label: \"PREVIEW ONLY - GFF FINANCIAL CONTROLLER\",\n 61 |   },\n 62 |   support_agent: {\n 63 |     name: \"INTERNAL-PREVIEW-SUPPORT-AGENT\",\n 64 |     email: \"preview-support-agent@internal.gff.ai\",\n 65 |     role: \"support_agent\",\n 66 |     clearance: \"CLEARANCE LEVEL III (GFF SUPPORT WIRE)\",\n 67 |     isMock: true,\n 68 |     label: \"PREVIEW ONLY - GFF SUPPORT REPRESENTATIVE\",\n 69 |   },\n 70 |   viewer: {\n 71 |     name: \"INTERNAL-PREVIEW-VIEWER-AUDITOR\",\n 72 |     email: \"preview-viewer@internal.gff.ai\",\n 73 |     role: \"viewer\",\n 74 |     clearance: \"CLEARANCE LEVEL I (READ-ONLY AUDITOR)\",\n 75 |     isMock: true,\n 76 |     label: \"PREVIEW ONLY - READ-ONLY AUDITOR\",\n 77 |   },\n 78 | };\n 79 | \n 80 | const SESSION_KEY = \"gff_ai_preview_session_v1\";\n 81 | \n 82 | export function getPreviewSession(): PreviewSession | null {\n 83 |   if (typeof window === \"undefined\") return null;\n 84 |   try {\n 85 |     const data = localStorage.getItem(SESSION_KEY);\n 86 |     if (!data) return null;\n 87 |     const parsed = JSON.parse(data);\n 88 |     if (parsed) {\n 89 |       return parsed as PreviewSession;\n 90 |     }\n 91 |   } catch (e) {\n 92 |     console.error(\"Error parsing preview session\", e);\n 93 |   }\n 94 |   return null;\n 95 | }\n 96 | \n 97 | export function setPreviewSession(role: PreviewRole): PreviewSession {\n 98 |   const session = MOCK_PREVIEW_USERS[role];\n 99 |   if (typeof window !== \"undefined\") {\n100 |     localStorage.setItem(SESSION_KEY, JSON.stringify(session));\n101 |     // Dispatch custom event to let other components know the session updated\n102 |     window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n103 |   }\n104 |   return session;\n105 | }\n106 | \n107 | export function clearPreviewSession(): void {\n108 |   if (typeof window !== \"undefined\") {\n109 |     localStorage.removeItem(SESSION_KEY);\n110 |     localStorage.removeItem(\"gff_ai_access_token\");\n111 |     localStorage.removeItem(\"gff_api_token\");\n112 |     window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n113 |   }\n114 | }\n115 | \n116 | export function hasRole(session: PreviewSession | null, allowedRoles: PreviewRole[]): boolean {\n117 |   if (!session) return false;\n118 |   return allowedRoles.includes(session.role);\n119 | }\n120 | \n121 | // Check access rules for Client Portal sections (/portal/[sectionId])\n122 | export function canAccessPortalSection(role: PreviewRole, sectionId: string): boolean {\n123 |   // GFF admin can access everything\n124 |   if (role === \"gff_admin\") return true;\n125 |   \n126 |   if (role === \"viewer\") {\n127 |     // Read-only auditor can view general stats but not settings/billing or write tools\n128 |     return [\"dashboard\", \"analytics\", \"governance\", \"activity\"].includes(sectionId);\n129 |   }\n130 |   \n131 |   if (role === \"client_member\") {\n132 |     // Client members can access everything except billing and settings\n133 |     return ![\"billing\", \"settings\"].includes(sectionId);\n134 |   }\n135 |   \n136 |   if (role === \"client_admin\") {\n137 |     // Client Admin can access all client portal sections\n138 |     return true;\n139 |   }\n140 | \n141 |   // GFF internal roles inside client portal layout:\n142 |   if (role === \"finance_admin\") {\n143 |     return [\"dashboard\", \"billing\", \"analytics\", \"activity\"].includes(sectionId);\n144 |   }\n145 |   if (role === \"support_agent\") {\n146 |     return [\"dashboard\", \"support\", \"activity\"].includes(sectionId);\n147 |   }\n148 |   if (role === \"gff_operator\") {\n149 |     return [\"dashboard\", \"projects\", \"ai-operations\", \"governance\", \"activity\"].includes(sectionId);\n150 |   }\n151 |   \n152 |   return false;\n153 | }\n154 | \n155 | // Check access rules for Admin Oversight Console (/admin/[sectionId])\n156 | export function canAccessAdminSection(role: PreviewRole, sectionId: string): boolean {\n157 |   // Only GFF internal roles and auditor can access admin panel\n158 |   if (role === \"gff_admin\") return true;\n159 |   \n160 |   if (role === \"gff_operator\") {\n161 |     // Operator cannot access billing, settings, or users management\n162 |     return ![\"billing\", \"settings\", \"users\"].includes(sectionId);\n163 |   }\n164 |   \n165 |   if (role === \"finance_admin\") {\n166 |     // Finance can access dashboard, clients, billing, analytics, activity, settings\n167 |     return [\"dashboard\", \"clients\", \"billing\", \"analytics\", \"activity\", \"settings\"].includes(sectionId);\n168 |   }\n169 |   \n170 |   if (role === \"support_agent\") {\n171 |     // Support agent can access dashboard, clients, support, activity, users\n172 |     return [\"dashboard\", \"clients\", \"support\", \"activity\", \"users\"].includes(sectionId);\n173 |   }\n174 |   \n175 |   if (role === \"viewer\") {\n176 |     // Auditor can view dashboards, activity, governance read-only\n177 |     return [\"dashboard\", \"clients\", \"projects\", \"analytics\", \"governance\", \"activity\"].includes(sectionId);\n178 |   }\n179 |   \n180 |   // Clients (client_admin, client_member) cannot access admin section AT ALL\n181 |   return false;\n182 | }","success":true}],"durationMs":9}}
