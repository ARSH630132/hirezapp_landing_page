m(TOKEN_KEY, token); };\\n150 | export const clearStoredToken = (): void => { if (typeof window !== \\\"undefined\\\") localStorage.removeItem(TOKEN_KEY); };\\n151 | \\n152 | export async function ensureValidToken(): Promise<string | null> {\\n153 |   if (typeof window === \\\"undefined\\\") return null;\\n154 |   const session = getPreviewSession();\\n155 |   if (!session) return getStoredToken();\\n156 |   \\n157 |   const currentToken = getStoredToken();\\n158 |   if (currentToken) {\\n159 |     try {\\n160 |       const parts = currentToken.split(\\\".\\\");\\n161 |       if (parts.length === 3) {\\n162 |         const payload = JSON.parse(atob(parts[1]));\\n163 |         if (payload.email && payload.email.toLowerCase() === session.email.toLowerCase()) {\\n164 |           return currentToken;\\n165 |         }\\n166 |       }\\n167 |     } catch (e) {\\n168 |       // Decode failed\\n169 |     }\\n170 |   }\\n171 |   \\n172 |   try {\\n173 |     const res = await fetch(`${getApiBaseUrl().replace(/\\\\/$/, \\\"\\\")}/auth/login`, {\\n174 |       method: \\\"POST\\\",\\n175 |       headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n176 |       body: JSON.stringify({\\n177 |         email: session.email,\\n178 |         password: \\\"gff-secure-2026!\\\"\\n179 |       })\\n180 |     });\\n181 |     if (res.ok) {\\n182 |       const data = await res.json();\\n183 |       if (data.success && data.accessToken) {\\n184 |         setStoredToken(data.accessToken);\\n185 |         localStorage.setItem(\\\"gff_ai_access_token\\\", data.accessToken);\\n186 |         return data.accessToken;\\n187 |       }\\n188 |     }\\n189 |   } catch (err) {\\n190 |     console.error(\\\"Auto token sync failed:\\\", err);\\n191 |   }\\n192 |   return getStoredToken();\\n193 | }\\n194 | \\n195 | export async function request<T>(path: string, options: RequestInit = {}): Promise<T> {\\n196 |   await ensureValidToken();\\n197 |   const token = getStoredToken();\\n198 |   const h