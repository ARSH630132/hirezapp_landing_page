 }}\n369 |                 transition={{ duration: 0.3 }}\n370 |                 className=\"max-w-2xl mx-auto rounded-[28px] border border-white/5 bg-[#030303]/40 p-8 sm:p-10 text-center backdrop-blur-md shadow-2xl\"\n371 |               >\n372 |                 <div className=\"inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/5 mb-4 text-white/30\">\n373 |                   <Search className=\"h-5 w-5\" />\n374 |                 </div>\n375 |                 <h3 className=\"text-lg font-semibold text-white tracking-wide\">No custom AI paths found</h3>\n376 |                 <p className=\"mt-2 text-sm text-white/50 max-w-md mx-auto leading-relaxed\">\n377 |                   We couldn't find matching capabilities for <span className=\"text-[#009DFF] font-medium\">\"{searchQuery}\"</span>. Try typing other terms or clicking one of the templates above.\n378 |                 </p>\n379 |                 <button\n380 |                   onClick={() => setSearchQuery(\"\")}\n381 |                   className=\"mt-6 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 text-white/80 hover:text-white text-xs sm:text-sm font-semibold transition-all cursor-pointer\"\n382 |                 >\n383 |                   Reset Concierge Search\n384 |                 </button>\n385 |               </motion.div>\n386 |             )}\n387 | \n388 |             {/* 3. Search Results State */}\n389 |             {searchQuery && filteredResults.length > 0 && (\n390 |               <motion.div\n391 |                 key=\"results-grid\"\n392 |                 initial={{ opacity: 0 }}\n393 |                 animate={{ opacity: 1 }}\n394 |                 exit={{ opacity: 0 }}\n395 |                 transition={{ duration: 0.3 }}\n396 |                 className=\"grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto\"\n397 |               >\n398 |                 {filteredResults.map((result, idx) => {\n399 |                   const color = categoryColors[result.category] || \"#009DFF\";\n400 |                   return (\n401 |                     <motion.div\n402 |                       key={result.title}\n403 |                       initial={{ opacity: 0, y: 12 }}\n404 |                       animate={{ opacity: 1, y: 0 }}\n405 |                       transition={{ duration: 0.4, delay: Math.min(idx * 0.05, 0.25) }}\n406 |                       className=\"group relative h-full rounded-[24px] border border-white/5 bg-[#050505] p-6 hover:bg-[#070707] hover:border-white/15 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(0,157,255,0.06)] flex flex-col justify-between\"\n407 |                     >\n408 |                       {/* Left border accent line representing the category color */}\n409 |                       <div\n410 |                         className=\"absolute left-0 top-6 bottom-6 w-[3px] rounded-r-[4px] transition-all duration-300 group-hover:scale-y-110\"\n411 |                         style={{ backgroundColor: color }}\n412 |                       />\n413 | \n414 |                       <div className=\"pl-4 flex flex-col h-full justify-between\">\n415 |                         <div>\n416 |                           <div className=\"flex items-center justify-between gap-3\">\n417 |                             <span\n418 |                               className=\"text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.15em]\"\n419 |                               style={{ color }}\n420 |                             >\n421 |                               {result.category}\n422 |                             </span>\n423 |                           </div>\n424 | \n425 |                           <h4 className=\"mt-2 text-base sm:text-[18px] font-semibold text-white tracking-wide group-hover:text-[#009DFF] transition-colors duration-300\">\n426 |                             {result.title}\n427 |                           </h4>\n428 | \n429 |                