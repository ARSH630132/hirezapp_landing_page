se().includes(term);\n244 |         const inDesc = item.description.toLowerCase().includes(term);\n245 |         const inCat = item.category.toLowerCase().includes(term);\n246 |         const inKeywords = item.keywords.some((kw) => kw.toLowerCase().includes(term));\n247 |         return inTitle || inDesc || inCat || inKeywords;\n248 |       });\n249 |     });\n250 |   }, [searchQuery]);\n251 | \n252 |   return (\n253 |     <section className=\"w-full bg-black px-6 lg:px-16 lg:py-24 py-16 border-t border-white/5 relative overflow-hidden\">\n254 |       {/* Dynamic Background subtle grid and radial glow */}\n255 |       <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,157,255,0.03)_0%,transparent_70%)] pointer-events-none\" />\n256 |       <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#111_1px,transparent_1px),linear-gradient(to_bottom,#111_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30 pointer-events-none\" />\n257 | \n258 |       <div className=\"max-w-[1795px] mx-auto relative z-10\">\n259 |         <SectionHeading\n260 |           title={\n261 |             <h2 className=\"text-[24px] sm:text-[32px] leading-none font-medium text-center uppercase text-white tracking-wider\">\n262 |               ENTERPRISE <span className=\"text-[#009DFF]\">QUICK SEARCH</span>\n263 |             </h2>\n264 |           }\n265 |           titleClassName=\"text-center\"\n266 |           dividerWidthClassName=\"w-[260px]\"\n267 |         />\n268 | \n269 |         <p className=\"mt-5 mx-auto max-w-[800px] text-center text-white/60 text-[14px] sm:text-[16px] leading-relaxed\">\n270 |           Ask our AI Concierge or select an enterprise blueprint template below. Explore customized frameworks, pre-built platforms, and engineering models instantly.\n271 |         </p>\n272 | \n273 |         {/* AI Concierge Search Box */}\n274 |         <div className=\"mt