\" : t.status === \"in_progress\" ? \"warning\" : \"stable\"} label={t.status} />\n266 |                       </div>\n267 |                       <h4 className=\"text-[11.5px] font-bold text-white leading-snug\">{t.title}</h4>\n268 |                       <div className=\"flex items-center gap-2 text-[9px] text-white/40 pt-1 border-t border-white/[0.03]\">\n269 |                         <span className=\"flex items-center gap-1\">\n270 |                           {getCatIcon(t.category)}\n271 |                           <span className=\"uppercase text-[8px]\">{t.category}</span>\n272 |                         </span>\n273 |                         {proj && <span className=\"text-[#00FFC2] bg-[#00FFC2]/5 px-1 py-0.5 rounded text-[8px] font-bold\">PROJ: {proj.tag}</span>}\n274 |                         <span className=\"text-white/20 ml-auto\">{new Date(t.createdAt).toLocaleDateString()}</span>\n275 |                       </div>\n276 |                     </div>\n277 |                   </div>\n278 |                 );\n279 |               })\n280 |             )}\n281 |           </div>\n282 |         </div>\n283 |         <div id=\"support-right-detail-block\" className={`xl:sticky xl:top-6 ${selectedTicketId ? \"xl:col-span-7\" : \"xl:col-span-5\"}`}>\n284 |           {activeTicket ? (\n285 |             <div className=\"rounded-xl border border-white/10 bg-[#050505]/50 backdrop-blur-sm overflow-hidden flex flex-col h-[650px] font-mono text-left\">\n286 |               <div className=\"p-4 border-b border-white/5 bg-black/20 flex justify-between items-start\">\n287 |                 <div className=\"space-y-1\">\n288 |                   <div className=\"flex items-center gap-1.5\">\n289 |                     <button onClick={() => setSelectedTicketId(null)} className=\"p-1 rounded hover:bg-white/5 border border-white/5 mr-1 text-white/40 hover:text-white\">\n290 |                       <ArrowLeft className=\"w-3 h-3\" />\n291 |                     </button>\n292 |                     <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded font-bold uppercase\">SECURE WIRE</span>\n293 |                     <span className=\"text-[9px] text-white/40 font-bold\">{activeTicket.id}</span>\n294 |                   </div>\n295 |                   <h3 className=\"text-[12px] font-bold text-white uppercase mt-1\">{activeTicket.title}</h3>\n296 |                 </div>\n297 |                 <button onClick={() => setSelectedTicketId(null)} className=\"p-1 text-white/40 hover:text-white\"><X className=\"w-4 h-4\" /></button>\n298 |               </div>\n299 | \n300 |               <div className=\"flex-1 overflow-y-auto p-4 space-y-4\">\n301 |                 <div className=\"grid grid-cols-2 gap-2 text-[9px]\">\n302 |                   <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n303 |                     <span className=\"text-white/30 font-bold block uppercase text-[8px]\">Enclave Attestation</span>\n304 |                     <div className=\"flex items-center gap-1 text-emerald-400 font-bold mt-1\">\n305 |                       <Lock className=\"w-3.5 h-3.5\" />\n306 |                       <span>Intel SGX Signed</span>\n307 |                     </div>\n308 |                   </div>\n309 |                   <div className=\"p-2.5 rounded-lg border border-white/5 bg-black/40\">\n310 |                     <span className=\"text-white/30 font-bold block uppercase text-[8px]\">SLA Response Window</span>\n311 |                     <div className=\"flex items-center gap-1 text-amber-400 font-bold mt-1\">\n312 |                       <Clock className=\"w-3.5 h-3.5 animate-pulse\" />\n313 |                       <span>{activeTicket.priority === \"critical\" ? \"P1 (15m window)\" : \"P2 (1h window)\"}</span>\n314 |                     </div>\n315 |                   </div>\n316 |                 </div>\n317 | \n318 |                 <div className=\"space-y