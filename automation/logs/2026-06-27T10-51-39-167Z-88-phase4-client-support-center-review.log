            </div>\n240 |                 </div>\n241 |               ))}\n242 |             </div>\n243 |           </div>\n244 | \n245 |           {/* Ticket list */}\n246 |           <div className=\"space-y-3 max-h-[600px] overflow-y-auto pr-1\">\n247 |             {filtered.length === 0 ? (\n248 |               <div className=\"p-8 rounded-xl border border-white/5 bg-[#050505]/20 text-center space-y-2 font-mono\">\n249 |                 <p className=\"text-xs text-white/30\">No active wires match filter parameters.</p>\n250 |                 <button onClick={() => { setSearch(\"\"); setStatusFilter(\"ALL\"); setCatFilter(\"ALL\"); setPriFilter(\"ALL\"); setProjFilter(\"ALL\"); }} className=\"text-[10px] text-[#009DFF] underline uppercase font-bold\">Reset filters</button>\n251 |               </div>\n252 |             ) : (\n253 |               filtered.map(t => {\n254 |                 const isSelected = t.id === selectedTicketId;\n255 |                 const proj = previewProjects.find(p => p.id === t.projectId);\n256 |                 return (\n257 |                   <div key={t.id} onClick={() => setSelectedTicketId(t.id)} className={`relative cursor-pointer rounded-xl border transition-all p-4 ${isSelected ? \"border-[#009DFF]/40 bg-[#009DFF]/5\" : \"border-white/5 bg-[#050505]/40 hover:border-white/10\"}`}>\n258 |                     {isSelected && <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-[#009DFF] rounded-l-xl\" />}\n259 |                     <div className=\"space-y-2 font-mono text-left\">\n260 |                       <div className=\"flex justify-between items-center text-[9px]\">\n261 |                         <div className=\"flex items-center gap-1.5\">\n262 |                           <span className={`px-1.5 py-0.5 rounded border font-bold text-[8px] uppercase ${getPriorityStyle(t.priority)}`}>{t.priority}</span>\n263 |                           <span className=\"text-white/40 font-bold\">{t.id}</span>\n264 |                       