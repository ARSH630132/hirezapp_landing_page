t_id.\n 91 |     GFF admin is granted access automatically.\n 92 |     Client users must match the requested client_id.\n 93 |     \"\"\"\n 94 |     client_id_str = request.path_params.get(\"client_id\") or request.query_params.get(\"client_id\")\n 95 |     \n 96 |     # GFF admins have access to all clients\n 97 |     if current_user.role in [\"gff_admin\", \"admin\"]:\n 98 |         return current_user\n 99 | \n100 |     if client_id_str is None:\n101 |         # If client_id is not specified, default to checking if the user has any assigned client_id\n102 |         if current_user.client_id is None:\n103 |             raise HTTPException(\n104 |                 status_code=status.HTTP_403_FORBIDDEN,\n105 |                 detail=\"Operation not permitted. User does not belong to any client.\"\n106 |             )\n107 |         return current_user\n108 | \n109 |     try:\n110 |         client_id = int(client_id_str)\n111 |     except ValueError:\n112 |         raise HTTPException(\n113 |             status_code=status.HTTP_400_BAD_REQUEST,\n114 |             detail=\"Invalid client_id format.\"\n115 |         )\n116 | \n117 |     if current_user.client_id != client_id:\n118 |         raise HTTPException(\n119 |             status_code=status.HTTP_403_FORBIDDEN,\n120 |             detail=\"Operation not permitted. Access to this client's data is denied.\"\n121 |         )\n122 | \n123 |     return current_user\n124 | \n125 | def require_same_client_or_admin(\n126 |     request: Request,\n127 |     current_user: User = Depends(get_current_user)\n128 | ) -> User:\n129 |     \"\"\"\n130 |     Dependency that enforces that the user belongs to the same client_id\n131 |     as the one provided in the request (path or query params), OR is a GFF admin.\n132 |     \"\"\"\n133 |     client_id_str = request.path_params.get(\"client_id\") or request.query_params.get(\"client_id\")\n134 |     \n135 |     # GFF Admin can bypass\n136 |     if current_user.role in [\"gff_admin\",