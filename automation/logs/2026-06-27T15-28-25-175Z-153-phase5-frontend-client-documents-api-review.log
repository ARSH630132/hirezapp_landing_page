     doc.hash.toLowerCase().includes(query) ||\n488 |         doc.owner.toLowerCase().includes(query) ||\n489 |         doc.desc.toLowerCase().includes(query);\n490 |       if (!matchText) return false;\n491 |     }\n492 |     // 2. Category\n493 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n494 |     // 3. Related Project\n495 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n496 |     // 4. File Format (Type)\n497 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) return false;\n498 |     // 5. Status\n499 |     if (selectedStatus !== \"\" && doc.status !== selectedStatus) return false;\n500 | \n501 |     return true;\n502 |   });\n503 | \n504 |   // Calculate quick document statistics\n505 |   const totalSeals = documents.length;\n506 |   const activeSows = documents.filter(d => d.category === \"SOW\").length;\n507 |   const auditReports = documents.filter(d => d.category === \"Reports\" || d.category === \"Architecture\").length;\n508 |   const pendingReviews = documents.filter(d => d.status === \"Pending Review\" || d.status === \"In Review\").length;\n509 | \n510 |   const getStatusColor = (status: string) => {\n511 |     const s = status.toLowerCase();\n512 |     if (s === \"approved\" || s === \"signed\" || s === \"active\") return \"text-[#00FFC2] border-[#00FFC2]/20 bg-[#00FFC2]/5\";\n513 |     if (s === \"in review\" || s === \"pending review\") return \"text-amber-400 border-amber-400/20 bg-amber-400/5\";\n514 |     return \"text-white/40 border-white/10 bg-white/5\";\n515 |   };\n516 | \n517 |   const getFormatBadgeColor = (fmt: string) => {\n518 |     const f = fmt.toLowerCase();\n519 |     if (f === \"pdf\") return \"text-red-400 border-red-500/20 bg-red-500/5\";\n520 |     if (f === \"yaml\" || f === \"json\") return \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\";\n521 |     if (f === \"zip\") return \"text-indigo-400 border-indigo-500/20 bg-indigo-500/5\";\n522 |     return \"text-white/60 border-white/10 bg-white/5\";\n523 |   };\n524 | \n525 |   const hasActiveFilters = searchQuery !== \"\" || selectedCategory !== \"\" || selectedProject !== \"\" || selectedFormat !== \"\" || selectedStatus !== \"\";\n526 | \n527 |   return (\n528 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none relative\">\n529 |       \n530 |       {/* 1. TOAST NOTIFICATION WINDOW */}\n531 |       {toastMessage && (\n532 |         <div className=\"fixed bottom-20 lg:bottom-6 right-4 lg:right-6 z-50 animate-in fade-in slide-in-from-bottom duration-300\">\n533 |           <div className={`p-4 rounded-xl border backdrop-blur-xl shadow-2xl flex items-center gap-3 font-mono text-[12px] max-w-sm ${\n534 |             toastType === \"warning\" ? \"border-amber-500/30 bg-amber-950/70 text-amber-300\" :\n535 |             toastType === \"success\" ? \"border-[#00FFC2]/30 bg-black/80 text-[#00FFC2]\" :\n536 |             \"border-white/10 bg-black/80 text-white/80\"\n537 |           }`}>\n538 |             <Shield className={`w-4 h-4 shrink-0 ${\n539 |               toastType === \"warning\" ? \"text-amber-400\" :\n540 |               toastType === \"success\" ? \"text-[#00FFC2]\" :\n541 |               \"text-[#009DFF]\"\n542 |             }`} />\n543 |             <div>\n544 |               <span className=\"font-bold uppercase tracking-wider block text-[10px]\">\n545 |                 {toastType === \"warning\" ? \"SECURITY ALIGNMENT LOCK\" : toastType === \"success\" ? \"INTEGRITY ATTESTED\" : \"SYSTEM MESSAGE\"}\n546 |               </span>\n547 |               <p className=\"mt-0.5 font-sans leading-snug\">{toastMessage}</p>\n548 |             </div>\n549 |             <button onClick={() => setToastMessage(null)} className=\"p-0.5 text-white/40 hover:text-white rounded shrink-0 transition-colors ml-auto\">\n550 |               <X className=\"w-3.5 h-3.5\" />\n551 |             </button>\n552 |           </div>\n553 |         </div>\n554 |       )}\n555 | \n556 |       {/* 2. DEMO RESTRICTED BANNER */}\n557 |       <div className=\"border border-white/5 bg-[#050505]/30 rounded-xl px-4 py-3 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-mono text-[11px] backdrop-blur-sm\">\n558 |         <div className=\"flex items-center gap-2.5 text-white/50\">\n559 |           <Info className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n560 |           <span>\n561 |             <strong className=\"text-white/80\">AIRGAPPED DOCUMENT REPOSITORY:</strong> In alignment with SOC2 and ISO27001 policies, download and upload actions are cryptographically suspended inside client preview portals.\n562 |           </span>\n563 |         </div>\n564 |         <span className=\"text-[9.5px] text-[#009DFF] font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2.5 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n565 |           SECURE SIMULATION ACTIVE\n566 |         </span>\n567 |       </div>\n568 | \n569 |       {/* 3. BREADCRUMBED HEADER */}\n570 |       <PrivatePageHeader\n571 |         title=\"Document Repository & Seals\"\n572 |         desc=\"Access cryptographically sealed Master Service Agreements, Statements of Work, and Sovereign System Architecture Reports.\"\n573 |         badgeLabel=\"SECURE_VAULT_v2.6\"\n574 |         actions={\n575 |           <button \n576 |             onClick={handleSimulatedUploadClick}\n577 |             className=\"h-9 px-4 rounded border border-white/10 hover:border-[#009DFF]/30 hover:bg-[#009DFF]/5 text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-2 cursor-pointer bg-white/[0.01]\"\n578 |           >\n579 |             <UploadCloud className=\"w-4 h-4 text-[#009DFF]\" />\n580 |             <span>Upload Document</span>\n581 |           </button>\n582 |         }\n583 |       />\n584 | \n585 |       {/* 4. EXECUTIVE SUMMARY METRIC TILES */}\n586 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n587 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n588 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">CRYPTOGRAPHIC SEALS</span>\n589 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{totalSeals} <span className=\"text-white/20 text-sm font-sans font-normal\">Active</span></div>\n590 |           <span className=\"text-[10px] text-[#00FFC2] font-mono flex items-center gap-1\"><ShieldCheck className=\"w-3 h-3\" /> 100% Attested</span>\n591 |         </div>\n592 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n593 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">SOVEREIGN SOW CONTRACTS</span>\n594 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{activeSows} <span className=\"text-white/20 text-sm font-sans font-normal\">Stored</span></div>\n595 |           <span className=\"text-[10px] text-white/45 font-mono\">Executed and archived</span>\n596 |         </div>\n597 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n598 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">ATTESTED SYSTEM REPORTS</span>\n599 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{auditReports} <span className=\"text-white/20 text-sm font-sans font-normal\">Audits</span></div>\n600 |           <span className=\"text-[10px] text-[#009DFF] font-mono\">AMD SEV Topology Logs</span>\n601 |         </div>\n602 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm space-y-1\">\n603 |           <span className=\"text-[9.5px] font-mono tracking-widest text-white/30 uppercase block\">REVIEWS IN PROGRESS</span>\n604 |           <div className=\"text-xl md:text-2xl font-bold tracking-tight text-white font-mono\">{pendingReviews} <span className=\"text-white/20 text-sm font-sans font-normal\">Pending</span></div>\n605 |           <span className=\"text-[10px] text-amber-400 font-mono\">Awaiting client signature</span>\n606 |         </div>\n607 |       </div>\n608 | \n609 |       {/* 5. MULTI-DIMENSIONAL SEARCH & FILTER BOARD */}\n610 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n611 |         <div className=\"flex flex-col xl:flex-row gap-4 justify-between items-stretch xl:items-center\">\n612 |           \n613 |           {/* Main Search Input */}\n614 |           <div className=\"relative flex-grow max-w-xl\">\n615 |             <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-white/30\" />\n616 |             <input \n617 |               type=\"text\" \n618 |               value={searchQuery} \n619 |               onChange={(e) => setSearchQuery(e.target.value)} \n620 |               placeholder=\"Search by title, security hash, owner, or details...\"\n621 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-10 pr-10 text-[12px] font-mono text-white placeholder-white/25 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n622 |             />\n623 |             {searchQuery && (\n624 |               <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-3.5 top-2.5 text-white/40 hover:text-white transition-colors\">\n625 |                 <X className=\"w-4 h-4\" />\n626 |               </button>\n627 |             )}\n628 |           </div>\n629 | \n630 |           {/* Controls Right Alignment: Layout Switch & Clear */}\n631 |           <div className=\"flex flex-wrap items-center gap-3 self-end xl:self-auto\">\n632 |             {hasActiveFilters && (\n633 |               <button \n634 |                 onClick={handleResetFilters}\n635 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-[11px] font-mono font-bold text-red-400 uppercase transition-all flex items-center gap-1.5 cursor-pointer\"\n636 |               >\n637 |                 <X className=\"w-3.5 h-3.5\" />\n638 |                 <span>Reset Filters</span>\n639 |               </button>\n640 |             )}\n641 | \n642 |             {/* Layout Toggler (Segmented Control style) */}\n643 |             <div className=\"flex items-center rounded-lg border border-white/5 p-1 bg-black/40\">\n644 |               <button \n645 |                 onClick={() => setLayoutMode(\"grid\")}\n646 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n647 |                   layoutMode === \"grid\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n648 |                 }`}\n649 |               >\n650 |                 <LayoutGrid className=\"w-3.5 h-3.5\" />\n651 |                 <span className=\"hidden sm:inline\">Bento Grid</span>\n652 |               </button>\n653 |               <button \n654 |                 onClick={() => setLayoutMode(\"list\")}\n655 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n656 |                   layoutMode === \"list\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n657 |                 }`}\n658 |               >\n659 |                 <List className=\"w-3.5 h-3.5\" />\n660 |                 <span className=\"hidden sm:inline\">Sovereign Ledger</span>\n661 |               </button>\n662 |             </div>\n663 | \n664 |           </div>\n665 |         </div>\n666 | \n667 |         {/* Dr