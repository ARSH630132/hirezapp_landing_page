ull);\n339 | \n340 |   // Filter States\n341 |   const [searchQuery, setSearchQuery] = useState(\"\");\n342 |   const [selectedCategory, setSelectedCategory] = useState(\"\");\n343 |   const [selectedProject, setSelectedProject] = useState(\"\");\n344 |   const [selectedFormat, setSelectedFormat] = useState(\"\");\n345 |   const [selectedStatus, setSelectedStatus] = useState(\"\");\n346 |   \n347 |   const fetchDocuments = useCallback(async () => {\n348 |     setLoading(true);\n349 |     setError(null);\n350 |     try {\n351 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n352 |       if (!token) {\n353 |         setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n354 |         router.push(\"/portal/login\");\n355 |         return;\n356 |       }\n357 | \n358 |       const res = await fetch(\"/api/v1/documents\", {\n359 |         headers: {\n360 |           \"Authorization\": `Bearer ${token}`,\n361 |           \"Content-Type\": \"application/json\"\n362 |         }\n363 |       });\n364 | \n365 |       if (!res.ok) {\n366 |         throw new Error(`Enclave sync failed with status ${res.status}`);\n367 |       }\n368 | \n369 |       const data = await res.json();\n370 |       if (data.success && Array.isArray(data.documents)) {\n371 |         const mapped = data.documents.map((d: any) => mapApiDocToPortalDoc(d));\n372 |         setDocuments(mapped);\n373 |       } else {\n374 |         throw new Error(\"Handshake returned malformed enclave register.\");\n375 |       }\n376 |     } catch (err: any) {\n377 |       console.error(\"Error fetching documents:\", err);\n378 |       setError(err.message || \"Decentralized ledger handshake timed out.\");\n379 |     } finally {\n380 |       setLoading(false);\n381 |     }\n382 |   }, [router]);\n383 | \n384 |   useEffect(() => {\n385 |     fetchDocuments();\n386 |   }, [fetchDocuments]);\n387 | \n388 |   // Layout States\n389 |   const [layoutMode, setLayoutMode] = useState<\"grid\" | \"list\">(\"grid\");\n390 | \n391 |   // Drawer & Attestation Log States\n392 |   const [selectedDoc, setSelectedDoc] = useState<PortalDocument | null>(null);\n393 |   const [terminalLogs, setTerminalLogs] = useState<string[]>([]);\n394 |   const [isLogsSyncing, setIsLogsSyncing] = useState(false);\n395 |   const [copiedHash, setCopiedHash] = useState(false);\n396 | \n397 |   // Custom Toast Notification States\n398 |   const [toastMessage, setToastMessage] = useState<string | null>(null);\n399 |   const [toastType, setToastType] = useState<\"info\" | \"warning\" | \"success\" | null>(null);\n400 | \n401 |   // Trigger Toast Helper\n402 |   const showToast = (message: string, type: \"info\" | \"warning\" | \"success\" = \"info\") => {\n403 |     setToastMessage(message);\n404 |     setToastType(type);\n405 |   };\n406 | \n407 |   // Close Toast automatically after 3.5 seconds\n408 |   useEffect(() => {\n409 |     if (toastMessage) {\n410 |       const timer = setTimeout(() => {\n411 |         setToastMessage(null);\n412 |         setToastType(null);\n413 |       }, 3500);\n414 |       return () => clearTimeout(timer);\n415 |     }\n416 |   }, [toastMessage]);\n417 | \n418 |   // Terminal Handshake Log Simulator inside Drawer\n419 |   useEffect(() => {\n420 |     if (!selectedDoc) {\n421 |       setTerminalLogs([]);\n422 |       return;\n423 |     }\n424 | \n425 |     setIsLogsSyncing(true);\n426 |     setTerminalLogs([\n427 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n428 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n429 |     ]);\n430 | \n431 |     const logsArray = [\n432 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n433 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n434 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n435 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n436 |     ];\n437 | \n438 |     let timerIndex = 0;\n439 |     const interval = setInterval(() => {\n440 |       if (timerIndex < logsArray.length) {\n441 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n442 |         timerIndex++;\n443 |       } else {\n444 |         setIsLogsSyncing(false);\n445 |         clearInterval(interval);\n446 |       }\n447 |     }, 450);\n448 | \n449 |     return () => clearInterval(interval);\n450 |   }, [selectedDoc]);\n451 | \n452 |   // Copy Clipboard Helper\n453 |   const handleCopyHash = (text: string) => {\n454 |     navigator.clipboard.writeText(text);\n455 |     setCopiedHash(true);\n456 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n457 |     setTimeout(() => setCopiedHash(false), 1500);\n458 |   };\n459 | \n460 |   // Reset Filters Helper\n461 |   const handleResetFilters = () => {\n462 |     setSearchQuery(\"\");\n463 |     setSelectedCategory(\"\");\n464 |     setSelectedProject(\"\");\n465 |     setSelectedFormat(\"\");\n466 |     setSelectedStatus(\"\");\n467 |     showToast(\"All filters reset successfully.\", \"info\");\n468 |   };\n469 | \n470 |   // Simulated Actions\n471 |   const handleSimulatedDownload = (doc: PortalDocument) => {\n472 |     showToast(`DEMO SHIELD: File transfer blocked. '${doc.name}' cannot be downloaded in telemetry preview.`, \"warning\");\n473 |   };\n474 | \n475 |   const handleSimulatedUploadClick = () => {\n476 |     showToast(\"SECURE GATEWAY: Upload restricted. Local sandbox is currently in read-only audit mode.\", \"warning\");\n477 |   };\n478 | \n479 |   // Filtering Logic\n480 |   const filteredDocuments = documents.filter((doc) => {\n481 |     // 1. Text Search query (checks title, hash, id, owner)\n482 |     if (searchQuery.trim() !== \"\") {\n483 |       const query = searchQuery.toLowerCase();\n484 |       const matchText = \n485 |         doc.name.toLowerCase().includes(query) ||\n486 |         doc.id.toLowerCase().includes(query) ||\n487 |         doc.hash.toLowerCase().includes(query) ||\n488 |         doc.owner.toLowerCase().includes(query) ||\n489 |         doc.desc.toLowerCase().includes(query);\n490 |       if (!matchText) return false;\n491 |     }\n492 |     // 2. Category\n493 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n494 |     // 3. Related Project\n495 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n496 |     // 4. File Format (Type)\n497 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) return false;\n498 |     // 5. Status\n499 |     if (selectedStatus !== \"\" && doc.status !== selectedStatus) return false;\n500 | \n501 |     return true;\n502 |   });\n503 | \n504 |   // Calculate quick document statistics\n505 |   const totalSeals = documents.length;\n506 |   const activeSows = documents.filter(d => d.category === \"SOW\").length;\n507 |   const auditReports = documents.filter(d => d.category === \"Reports\" || d.category === \"Architecture\").length;\n508 |   const pendingReviews = documents.filter(d => d.status === \"Pending Review\" || d.status === \"In Review\").length;\n509 | \n510 |   const getStatusColor = (status: string) => {\n511 |     const s = status.toLowerCase();\n512 |     if (s === \"approved\" || s === \"signed\" || s === \"active\") return \"text-[#00FFC2] border-[#00FFC2]/20 bg-[#00FFC2]/5\";\n513 |     if (s === \"in review\" || s === \"pending review\") return \"text-amber-400 border-amber-400/20 bg-amber-400/5\";\n514 |     return \"text-white/40 border-white/10 bg-white/5\";\n515 |   };\n516 | \n517 |   const getFormatBadgeColor = (fmt: string) => {\n518 |     const f = fmt.toLowerCase();\n519 |     if (f === \"pdf\") return \"text-red-400 border-red-500/20 bg-red-500/5\";\n520 |     if (f === \"yaml\" || f === \"json\") return \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\";\n521 |     if (f === \"zip\") return \"text-indigo-400 border-indigo-500/20 bg-indigo-500/5\";\n522 |     return \"text-white/60 border-white/10 bg-white/5\";\n523 |   };\n524 | \n525 |   const hasActiveFilters = searchQuery !== \"\" || selectedCategory !== \"\" || selectedProject !== \"\" || selectedFormat !== \"\" || selectedStatus !== \"\";\n526 | \n527 |   return (\n528 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none relative\">\n529 |       \n530 |       {/* 1. TOAST NOTIFICATION WINDOW */}\n531 |       {toastMessage && (\n532 |         <div className=\"fixed bottom-20 lg:bottom-6 right-4 lg:right-6 z-50 animate-in fade-in slide-in-from-bottom duration-300\">\n533 |           <div className={`p-4 rounded-xl border backdrop-blur-xl shadow-2xl flex items-center gap-3 font-mono text-[12px] max-w-sm ${\n534 |             toastType === \"warning\" ? \"border-amber-500/30 bg-amber-950/70 text-amber-300\" :\n535 |             toastType === \"success\" ? \"border-[#00FFC2]/30 bg-black/80 text-[#00FFC2]\" :\n536 |             \"border-white/10 bg-black/80 text-white/80\"\n537 |           }`}>\n538 |             <Shield className={`w-4 h-4 shrink-0 ${\n539 |               toastType === \"warning\" ? \"text-amber-400\" :\n540 |               toastType === \"success\" ? \"text-[#00FFC2]\" :\n541 |               \"text-[#009DFF]\"\n542 |             }`} />\n543 |             <div>\n544 |               <span className=\"font-bold uppercase tracking-wider block text-[10px]\">\n545 |                 {toastType === \"warning\" ? \"SECURITY ALIGNMENT LOCK\" : toastType === \"success\" ? \"INTEGRITY ATTESTED\" : \"SYSTEM MESSAGE\"}\n546 |               </span>\n547 |               <p className=\"mt