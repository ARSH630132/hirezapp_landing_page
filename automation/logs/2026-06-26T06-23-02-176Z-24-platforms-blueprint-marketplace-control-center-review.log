{"ts":"2026-06-26T06:17:33.482Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ksohoaca","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/blueprint/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport Link from \"next/link\";\nimport { ShieldCheck, Database, Cpu, ArrowRight, AlertCircle, CheckCircle2 } from \"lucide-react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport { BentoGrid, BentoCard } from \"@/components/inner-pages/BentoGrid\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nconst DIMS = [\n  { \n    id: \"gov\", \n    t: \"Governance & Security\", \n    s: 84, \n    i: ShieldCheck, \n    g: \"Fragmented security checks without automated kernel logs.\", \n    r: \"Deploy custom Sovereign Guardrail policies with zero-trust eBPF telemetry.\", \n    tc: [\"eBPF Shield\", \"Guardrails\"] \n  },\n  { \n    id: \"dat\", \n    t: \"Data Surface Density\", \n    s: 42, \n    i: Database, \n    g: \"Corporate intellectual property locked across legacy CSVs and siloed databases.\", \n    r: \"Orchestrate a sovereign hybrid vector-graph index using Neo4j and pgvector.\", \n    tc: [\"GFF Data Fabric\", \"Graph-Vector\"] \n  },\n  { \n    id: \"cmp\", \n    t: \"Compute Scalability\", \n    s: 65, \n    i: Cpu, \n    g: \"Compute workloads are statically provisioned leading to excessive idle costs.\", \n    r: \"Implement dynamic SLA-based compute scaling dynamically across containers.\", \n    tc: [\"K8s Scalers\", \"vLLM Runtime\"] \n  }\n];\n\nexport default function BlueprintPage() {\n  const [actId, setActId] = useState(\"dat\");\n  const act = DIMS.find((d) => d.id === actId) || DIMS[0];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Tier 0 • Diagnostics\"\n        title=\"Enterprise AI Blueprints\"\n        highlightedWord=\"Blueprints\"\n        description=\"Audit existing data structures, analyze regulatory boundaries, and design mathematically structured multi-agent topologies before writing code.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"Blueprint\" }]}\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n        \n        {/* Editorial Strategic Framework */}\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-12 border-y border-white/5 items-center bg-white/[0.01] px-6 lg:px-10 rounded-2xl\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-semibold\">Strategic Framework</span>\n            <h2 className=\"text-3xl font-bold text-white mt-3 tracking-tight\">The Diagnostic Foundation</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light text-sm sm:text-base leading-relaxed\">\n              We believe successful enterprise AI is an architectural discipline, not a series of prompt experiments. Before GFF deploys an agent, we model your entire system topology, audit your data surfaces, and design a deterministic roadmap to convert objectives into secure sovereign software blueprints.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Interactive Readiness Assessor */}\n        <MotionReveal className=\"space-y-12\">\n          <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n            <span className=\"px-3 py-1 text-[9px] font-bold tracking-[0.15em] text-[#009DFF] border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-full uppercase\">\n              Operational Assessor\n            </span>\n            <h2 className=\"text-2xl sm:text-3xl font-bold tracking-tight text-white\">Interactive Readiness Assessor</h2>\n            <p className=\"text-white/50 text-xs sm:text-sm font-light\">\n              Select an enterprise operational dimension to audit gaps and inspect corresponding GFF architectural recommendations.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-5xl mx-auto items-stretch\">\n            {/* Dimensions Buttons Selector */}\n            <div className=\"lg:col-span-5 flex flex-col gap-4\">\n              {DIMS.map((d) => {\n                const Icon = d.i;\n                const isSelected = actId === d.id;\n                return (\n                  <button \n                    key={d.id} \n                    onClick={() => setActId(d.id)} \n                    className={`p-5 rounded-2xl border text-left transition-all duration-300 flex items-center justify-between cursor-pointer group relative ${\n                      isSelected \n                        ? \"text-[#009DFF] border-[#009DFF]/40 bg-[#009DFF]/5 shadow-[0_0_20px_rgba(0,157,255,0.05)]\" \n                        : \"border-white/5 bg-black/40 hover:border-white/10 hover:bg-black/60\"\n                    }`}\n                  >\n                    <div className=\"flex items-center gap-4\">\n                      <div className={`p-2.5 rounded-xl border transition-all ${\n                        isSelected \n                          ? \"border-[#009DFF]/30 bg-[#009DFF]/10 text-[#009DFF]\" \n                          : \"border-white/5 bg-white/5 text-white/40 group-hover:text-white\"\n                      }`}>\n                        <Icon className=\"w-5 h-5\" />\n                      </div>\n                      <div>\n                        <span className=\"text-xs font-mono text-white/40 uppercase block tracking-wider\">Dimension</span>\n                        <span className=\"text-sm font-bold text-white mt-0.5 block\">{d.t}</span>\n                      </div>\n                    </div>\n                    <div className=\"flex flex-col items-end\">\n                      <span className=\"text-[10px] font-mono text-white/30 uppercase tracking-widest\">Score</span>\n                      <span className={`text-base font-mono font-bold mt-0.5 ${isSelected ? \"text-[#009DFF]\" : \"text-white/80\"}`}>{d.s}%</span>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n\n            {/* Premium Assessment Panel with Custom Vector Topology Graph */}\n            <div className=\"lg:col-span-7 bg-[#04060b] rounded-2xl border border-white/10 p-6 sm:p-8 flex flex-col justify-between shadow-2xl relative overflow-hidden\">\n              <div className=\"absolute top-0 right-0 w-[50%] h-[50%] bg-gradient-to-bl from-[#009DFF]/5 to-transparent blur-[50px] pointer-events-none\" />\n              \n              <div className=\"space-y-6\">\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n                  <div>\n                    <span className=\"text-[9px] uppercase tracking-widest font-mono text-[#009DFF] font-semibold\">Readiness Diagnostic Core</span>\n                    <h3 className=\"text-base font-bold text-white mt-1\">{act.t}</h3>\n                  </div>\n                  <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/10 px-2 py-0.5 border border-[#009DFF]/20 rounded\">\n                    GAP-ID: {act.id}_audit_v4\n                  </span>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6 items-center\">\n                  <div className=\"space-y-4\">\n                    <div>\n                      <span className=\"flex items-center gap-1.5 text-red-400 font-mono text-[9px] uppercase tracking-wider font-semibold\">\n                        <AlertCircle className=\"w-3.5 h-3.5\" /> Identified Gap\n                      </span>\n                      <p className=\"text-xs text-white/60 leading-relaxed mt-1.5 font-light\">{act.g}</p>\n                    </div>\n                    <div>\n                      <span className=\"flex items-center gap-1.5 text-green-400 font-mono text-[9px] uppercase tracking-wider font-semibold\">\n                        <CheckCircle2 className=\"w-3.5 h-3.5\" /> GFF Recommendation\n                      </span>\n                      <p className=\"text-xs text-white/80 leading-relaxed mt-1.5 font-light\">{act.r}</p>\n                    </div>\n                  </div>\n\n                  {/* CUSTOM PAGE-SPECIFIC DYNAMIC TOPOLOGY SVG */}\n                  <div className=\"border border-white/5 bg-black/50 rounded-xl p-4 flex flex-col items-center justify-center min-h-[160px] relative\">\n                    <span className=\"text-[8px] font-mono text-white/30 absolute top-2 right-2 uppercase\">Topology Graph</span>\n                    {actId === \"gov\" && (\n                      <svg className=\"w-full h-[120px]\" viewBox=\"0 0 200 120\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                        {/* Governance Topology SVG */}\n                        <rect x=\"15\" y=\"45\" width=\"40\" height=\"30\" rx=\"6\" fill=\"#0c0e14\" stroke=\"#E4000F\" strokeWidth=\"1\" />\n                        <text x=\"35\" y=\"63\" fill=\"#E4000F\" fontSize=\"8\" textAnchor=\"middle\" fontWeight=\"bold\">Ingress</text>\n                        \n                        <path d=\"M55 60 L85 60\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n                        \n                        <circle cx=\"100\" cy=\"60\" r=\"16\" fill=\"#009DFF\" className=\"animate-pulse\" opacity=\"0.1\" />\n                        <circle cx=\"100\" cy=\"60\" r=\"12\" fill=\"#009DFF\" opacity=\"0.2\" />\n                        <shield-icon>\n                          <path d=\"M94 54 L100 51 L106 54 L106 59 C106 64 100 68 100 68 C100 68 94 64 94 59 Z\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        </shield-icon>\n                        \n                        <path d=\"M115 60 L145 60\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        \n                        <rect x=\"145\" y=\"45\" width=\"40\" height=\"30\" rx=\"6\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <text x=\"165\" y=\"63\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">eBPF Log</text>\n                        \n                        <text x=\"100\" y=\"105\" fill=\"#009DFF\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">SOVEREIGN GUARDRAILS</text>\n                      </svg>\n                    )}\n                    {actId === \"dat\" && (\n                      <svg className=\"w-full h-[120px]\" viewBox=\"0 0 200 120\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                        {/* Data Topology SVG */}\n                        <circle cx=\"30\" cy=\"35\" r=\"10\" fill=\"#0c0e14\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                        <text x=\"30\" y=\"38\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" opacity=\"0.5\">CSV</text>\n                        \n                        <circle cx=\"30\" cy=\"85\" r=\"10\" fill=\"#0c0e14\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                        <text x=\"30\" y=\"88\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" opacity=\"0.5\">SQL</text>\n                        \n                        <path d=\"M40 35 L90 50\" stroke=\"#E4000F\" strokeWidth=\"1\" strokeDasharray=\"3 2\" />\n                        <path d=\"M40 85 L90 70\" stroke=\"#E4000F\" strokeWidth=\"1\" strokeDasharray=\"3 2\" />\n                        \n                        <rect x=\"90\" y=\"45\" width=\"80\" height=\"30\" rx=\"6\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <text x=\"130\" y=\"60\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">Neo4j + pgvector</text>\n                        <text x=\"130\" y=\"70\" fill=\"#009DFF\" fontSize=\"6\" textAnchor=\"middle\" fontFamily=\"monospace\">Hybrid Mesh</text>\n                        \n                        <path d=\"M170 60 L185 60\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <circle cx=\"185\" cy=\"60\" r=\"2\" fill=\"#009DFF\" />\n                        \n                        <text x=\"100\" y=\"105\" fill=\"#009DFF\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">INTELLIGENT DATA FABRIC</text>\n                      </svg>\n                    )}\n                    {actId === \"cmp\" && (\n                      <svg className=\"w-full h-[120px]\" viewBox=\"0 0 200 120\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                        {/* Compute Topology SVG */}\n                        <rect x=\"20\" y=\"50\" width=\"30\" height=\"20\" rx=\"4\" fill=\"#0c0e14\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                        <text x=\"35\" y=\"62\" fill=\"white\" fontSize=\"7\" textAnchor=\"middle\" opacity=\"0.4\">Queue</text>\n                        \n                        <path d=\"M50 60 L85 60\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        \n                        {/* Animated cluster pods */}\n                        <g>\n                          <rect x=\"85\" y=\"30\" width=\"30\" height=\"16\" rx=\"3\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                          <text x=\"100\" y=\"40\" fill=\"white\" fontSize=\"7\" textAnchor=\"middle\">Pod A</text>\n                          \n                          <rect x=\"85\" y=\"52\" width=\"30\" height=\"16\" rx=\"3\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                          <text x=\"100\" y=\"62\" fill=\"white\" fontSize=\"7\" textAnchor=\"middle\">Pod B</text>\n                          \n                          <rect x=\"85\" y=\"74\" width=\"30\" height=\"16\" rx=\"3\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 1\" className=\"opacity-60\" />\n                          <text x=\"100\" y=\"84\" fill=\"#009DFF\" fontSize=\"6\" textAnchor=\"middle\">Pod C</text>\n                        </g>\n                        \n                        <path d=\"M115 40 L150 60\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <path d=\"M115 60 L150 60\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <path d=\"M115 82 L150 60\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 1\" />\n                        \n                        <rect x=\"150\" y=\"45\" width=\"35\" height=\"30\" rx=\"6\" fill=\"#0c0e14\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                        <text x=\"167\" y=\"63\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">vLLM</text>\n                        \n                        <text x=\"100\" y=\"108\" fill=\"#009DFF\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">ELASTIC K8S WORKLOADS</text>\n                      </svg>\n                    )}\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"mt-8 pt-4 border-t border-white/5 relative z-10 flex items-center justify-between flex-wrap gap-4\">\n                <div className=\"flex gap-2\">\n                  {act.tc.map((t) => (\n                    <span key={t} className=\"px-2.5 py-1 rounded bg-white/5 border border-white/10 text-[10px] font-mono text-white/60\">\n                      {t}\n                    </span>\n                  ))}\n                </div>\n                <Link \n                  href=\"/build/blueprint\" \n                  className=\"text-xs text-[#009DFF] hover:text-white transition-colors flex items-center gap-1 font-semibold group\"\n                >\n                  Configure Simulator <ArrowRight className=\"w-3.5 h-3.5 group-hover:translate-x-1 transition-transform\" />\n                </Link>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        {/* Solution Topologies Bento Grid */}\n        <MotionReveal className=\"space-y-10\">\n          <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n            <span className=\"px-3 py-1 text-[9px] font-bold tracking-[0.15em] text-[#009DFF] border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-full uppercase\">\n              Topology Outcomes\n            </span>\n            <h2 className=\"text-2xl sm:text-3xl font-bold tracking-tight text-white\">Solution Topologies & Expected Impact</h2>\n            <p className=\"text-white/50 text-xs sm:text-sm font-light\">\n              High-precision modular systems mapped during the Blueprint phase to secure your compute footprint.\n            </p>\n          </div>\n          <BentoGrid>\n            <BentoCard \n              title=\"Autonomous Compliance Core\" \n              description=\"Continuous eBPF kernel monitors scanning live database transactions, auto-redacting PII leaks and validating regulatory schemas.\" \n              badge=\"Security Mesh\" \n              glowColor=\"red\" \n              metric={{ value: \"-98%\", label: \"PII Leakage Risk\" }} \n            />\n            <BentoCard \n              title=\"Cognitive Pipeline Mesh\" \n              description=\"Sovereign multi-agent router connecting multi-modal models to parse complex regulatory compliance requests.\" \n              badge=\"Reasoning Loop\" \n              glowColor=\"blue\" \n              metric={{ value: \"10x\", label: \"Workload Throughput\" }} \n            />\n            <BentoCard \n              title=\"Action Gateway Network\" \n              description=\"Cryptographically signed outbound brokers executing idempotent operations in legacy SAP systems with human-approval gates.\" \n              badge=\"Deterministic Execution\" \n              glowColor=\"purple\" \n              metric={{ value: \"Zero-Risk\", label: \"State Recoverability\" }} \n            />\n          </BentoGrid>\n        </MotionReveal>\n\n        {/* Narrative Roadmap Timeline */}\n        <MotionReveal className=\"space-y-12\">\n          <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n            <span className=\"px-3 py-1 text-[9px] font-bold tracking-[0.15em] text-[#009DFF] border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-full uppercase\">\n              The Journey\n            </span>\n            <h2 className=\"text-2xl sm:text-3xl font-bold tracking-tight text-white font-bold text-center\">90-Day Enterprise Roadmap</h2>\n            <p className=\"text-white/50 text-xs sm:text-sm font-light\">\n              Our structured process to transition from design phase to full-scale containerized operations.\n            </p>\n          </div>\n          \n          <div className=\"max-w-4xl mx-auto relative pl-4 sm:pl-10\">\n            {/* Horizontal timeline connecting line */}\n            <div className=\"absolute left-[20px] sm:left-[39px] top-4 bottom-4 w-[1px] bg-gradient-to-b from-[#009DFF] via-white/10 to-[#E4000F] opacity-30\" />\n            \n            <div className=\"space-y-10\">\n              {[\n                { \n                  p: \"Phase 1: Days 1-30\", \n                  t: \"Diagnostics & Topology Design\", \n                  d: \"Conduct deep-dive stakeholder architecture workshops, execute comprehensive GFF Readiness Assessments, and establish rigid compliance/security boundary definitions.\",\n                  icon: \"01\",\n                  highlight: \"border-[#009DFF]/20 hover:border-[#009DFF]/50 hover:shadow-[0_0_20px_rgba(0,157,255,0.05)]\"\n                },\n                { \n                  p: \"Phase 2: Days 31-60\", \n                  t: \"Sandbox Prototype & DAG Coding\", \n                  d: \"Establish dedicated, isolated sandbox cluster environments inside GFF Garage. Formulate system prompts, model multi-agent routing DAGs inside Foundry, and load secure corporate knowledge vector-graphs.\",\n                  icon: \"02\",\n                  highlight: \"border-white/10 hover:border-white/30 hover:shadow-[0_0_20px_rgba(255,255,255,0.02)]\"\n                },\n                { \n                  p: \"Phase 3: Days 61-90\", \n                  t: \"Cluster Scaling & Production Delivery\", \n                  d: \"Promote validated multi-agent solutions into elastic production clusters in GFF Factory. Connect live data streams, establish outbound SAP or SQL action gates, and transition to unified control console tracking.\",\n                  icon: \"03\",\n                  highlight: \"border-[#E4000F]/20 hover:border-[#E4000F]/50 hover:shadow-[0_0_20px_rgba(228,0,15,0.05)]\"\n                }\n              ].map((ph, idx) => (\n                <div key={idx} className=\"relative group\">\n                  {/* Timeline bullet */}\n                  <div className=\"absolute -left-[11px] sm:-left-[15px] top-4 w-6 h-6 rounded-full bg-black border-2 border-white/20 group-hover:border-[#009DFF] transition-colors z-10 flex items-center justify-center\">\n                    <span className=\"w-1.5 h-1.5 rounded-full bg-white group-hover:bg-[#009DFF]\" />\n                  </div>\n\n                  <div className={`p-6 sm:p-8 rounded-2xl border bg-black/40 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 transition-all duration-300 ${ph.highlight}`}>\n                    <div className=\"space-y-2 flex-grow max-w-2xl\">\n                      <div className=\"flex items-center gap-3\">\n                        <span className=\"text-[10px] font-mono font-bold text-[#009DFF] uppercase tracking-wider\">{ph.p}</span>\n                        <span className=\"w-1.5 h-[1px] bg-white/20\" />\n                        <span className=\"text-[9px] font-mono text-white/40 uppercase\">Milestone</span>\n                      </div>\n                      <h3 className=\"font-bold text-white text-lg sm:text-xl tracking-tight mt-1\">{ph.t}</h3>\n                      <p className=\"text-xs sm:text-sm text-white/50 leading-relaxed font-light mt-1.5\">{ph.d}</p>\n                    </div>\n                    <div className=\"hidden sm:flex text-4xl font-mono font-bold text-white/5 shrink-0 select-none group-hover:text-white/10 transition-colors\">\n                      {ph.icon}\n                    </div>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        </MotionReveal>\n\n        {/* Premium CTA */}\n        <PremiumCTA\n          title=\"Scale Your Enterprise Topology Design\"\n          description=\"Ready to design your custom sovereign system? Launch our interactive, frontend-only simulator to instantly model execution boundaries.\"\n          primaryLabel=\"Launch Blueprint Generator\"\n          primaryHref=\"/build/blueprint\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
