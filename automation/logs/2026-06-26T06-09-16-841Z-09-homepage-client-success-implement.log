ing ? \"animate-pulse\" : \"\"} />\n\n                    <circle cx=\"100\" cy=\"90\" r=\"12\" stroke={activeColor} strokeWidth=\"1\" strokeOpacity=\"0.3\" />\n                    <circle cx=\"100\" cy=\"90\" r=\"4\" fill={activeColor} />\n\n                    <circle cx=\"160\" cy=\"60\" r=\"12\" stroke={activeColor} strokeWidth=\"1\" strokeOpacity=\"0.3\" />\n                    <circle cx=\"160\" cy=\"60\" r=\"4\" fill={activeColor} />\n\n                    {/* Glowing Paths */}\n                    <path d=\"M48 56 L92 34\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                    <path d=\"M48 64 L92 86\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                    <path d=\"M108 34 L152 56\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n                    <path d=\"M108 86 L152 64\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n\n                    {/* Laser pulses along path lines when playing */}\n                    {isPlaying && (\n                      <>\n                        <circle cx=\"70\" cy=\"45\" r=\"2\" fill=\"#fff\" className=\"animate-ping\" style={{ animationDuration: \"1.5s\" }} />\n                        <circle cx=\"130\" cy=\"45\" r=\"2\" fill=\"#fff\" className=\"animate-ping\" style={{ animationDuration: \"2s\" }} />\n                      </>\n                    )}\n\n                    {/* Pulsing overlay scan radar */}\n                    <circle cx=\"100\" cy=\"60\" r={isPlaying ? \"45\" : \"20\"} stroke={activeColor} strokeWidth=\"0.5\" strokeDasharray=\"3 3\" className={isPlaying ? \"transition-all duration-[2000ms] ease-out animate-pulse\" : \"\"} />\n                  </svg>\n                </div>\n\n                {/* Simulated Terminal Outputs (Right Column) */}\n                <div className=\"w-1/2 p-4 bg-[#030303] overflow-hidden flex flex-col justify-start select-none font-mono text-[9px] leading-relaxed text-white/50\">\n                  <div className=\"text-white/30 uppercase border-b border-white/5 pb-1 mb-2 font-bold tracking-widest flex items-center justify-between\">\n                    <span>Active Telemetry Logs</span>\n                    <span className=\"text-[7px]\" style={{ color: activeColor }}>SYNCED</span>\n                  </div>\n                  <div className=\"flex flex-col gap-1.5 overflow-hidden max-h-[140px] text-left\">\n                    {visibleLogs.map((log, lIdx) => (\n                      <div \n                        key={lIdx} \n                        className={`transition-all duration-300 ${\n                          lIdx === visibleLogs.length - 1 ? \"text-white font-semibold\" : \"text-white/60\"\n                        }`}\n                      >\n                        {log}\n                      </div>\n                    ))}\n                    {isPlaying && (\n                      <div className=\"w-1.5 h-3 bg-white/40 animate-pulse mt-0.5\" />\n                    )}\n                  </div>\n                </div>\n\n                {/* Overlay Play State Cover */}\n                <AnimatePresence>\n                  {!isPlaying && (\n                    <motion.div \n                      initial={{ opacity: 0 }}\n                      animate={{ opacity: 1 }}\n                      exit={{ opacity: 0 }}\n                      className=\"absolute inset-0 bg-black/80 backdrop-blur-[4px] flex flex-col items-center justify-center p-6 cursor-pointer\"\n                      onClick={() => setIsPlaying(true)}\n                    >\n                      <div className=\"w-12 h-12 rounded-full border border-white/20 flex items-center justify-center bg-white/5 group-hover:scale-110 transition-transform duration-300 shadow-2xl relative\">\n                        <div className=\"absolute -inset-2 rounded-full border border-white/5 animate-pulse\" />\n                        <svg className=\"w-4 h-4 text-white fill-current ml-1\" viewBox=\"0 0 24 24\">\n                          <path d=\"M8 5v14l11-7z\" />\n                        </svg>\n                      </div>\n                      <span className=\"text-[12px] font-mono tracking-wider font-bold text-white uppercase mt-4\">\n                        Watch Simulated Walkthrough\n                      </span>\n                      <span className=\"text-[9px] text-[#A0A0A0] mt-1 font-mono tracking-wider\">\n                        {pattern.videoTitle} ({pattern.videoDuration})\n                      </span>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n\n              </div>\n\n              {/* Controls bar */}\n              <div className=\"bg-black px-5 py-3 border-t border-white/5 flex items-center justify-between\">\n                <div className=\"flex items-center gap-4\">\n                  <button \n                    onClick={() => setIsPlaying(!isPlaying)}\n                    className=\"p-1 rounded text-white/60 hover:text-white hover:bg-white/5 transition-colors cursor-pointer\"\n                  >\n                    {isPlaying ? (\n                      <svg className=\"w-4 h-4 fill-current\" viewBox=\"0 0 24 24\">\n                        <path d=\"M6 19h4V5H6v14zm8-14v14h4V5h-4z\" />\n                      </svg>\n                    ) : (\n                      <svg className=\"w-4 h-4 fill-current\" viewBox=\"0 0 24 24\">\n                        <path d=\"M8 5v14l11-7z\" />\n                      </svg>\n                    )}\n                  </button>\n\n                  <div className=\"text-[10px] font-mono text-white/40\">\n                    <span className=\"text-white/80\">00:{videoProgress < 10 ? `0${videoProgress}` : videoProgress}</span> / 01:00\n                  </div>\n                </div>\n\n                {/* Progress bar line */}\n                <div className=\"flex-grow mx-6 h-[2px] bg-white/10 rounded overflow-hidden relative\">\n                  <div \n              