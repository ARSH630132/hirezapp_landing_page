      </h5>\n                      <p className=\"text-[12px] text-[#808080] leading-relaxed mt-0.5 font-light group-hover:text-white/80 transition-colors duration-300\">\n                        {pattern.outcomes.improvedEmployeeExperience}\n                      </p>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              {/* Anonymized Data Disclaimer */}\n              <div className=\"text-[10px] font-mono text-white/30 tracking-wide text-center pt-2 italic\">\n                * Representative pattern metrics and configurations are anonymized to strictly respect enterprise client non-disclosure agreements.\n              </div>\n\n            </div>\n\n          </div>\n\n        </div>\n\n      </div>\n    </motion.section>\n  );\n}\n"}}}
