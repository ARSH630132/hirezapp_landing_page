{"ts":"2026-06-26T06:08:49.000Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"32ius3u3","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/ClientSuccessSection.tsx","new_text":"\"use client\";\nimport React, { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\n\nconst PATTERNS = [\n  {\n    n: \"Global Banking Transformation\", c: \"#009DFF\", g: \"Finance\",\n    t: \"Multi-Agent Compliance & AML Audit Shield\",\n    d: \"Autonomous compliance agents evaluating SWIFT transaction paths in real-time.\",\n    ch: \"Processing heavy transaction volumes under constantly shifting international AML rules.\",\n    sl: \"Secure, multi-layered compliance validation pipelines with automated audit report generation.\",\n    o: [\n      \"Accelerates compliance audit times and risk checks from several business days to operational minutes.\",\n      \"Automates dense regulatory paperwork, replacing tedious manual validation checks.\",\n      \"Indexes global regulatory updates and KYC policies into an active semantic memory graph.\",\n      \"Implements automated validation checkpoints that systematically stop regulatory compliance leaks.\",\n      \"Shifts compliance officers from slow manual parsing to complex anomaly forensic investigations.\"\n    ],\n    tech: \"gRPC • vLLM • Temporal\",\n    logs: [\"[INGEST] Port 443 active\", \"[COMPLIANCE] Verification pass\", \"[LEDGER] Neo4j matched in 4ms\", \"[GATEWAY] Secure logs emitted\"]\n  },\n  {\n    n: \"Healthcare Knowledge Operations\", c: \"#E98828\", g: \"Clinical\",\n    t: \"Clinical Graph Orchestration & EHR Ingestion\",\n    d: \"HIPAA-compliant ingestion framework mapping disparate EHR files into an active search mesh.\",\n    ch: \"Fragmented health database silos and unstructured medical transcripts slowing patient analysis.\",\n    sl: \"Custom semantic pipeline parsers extracting notes into an integrated care topology.\",\n    o: [\n      \"Provides clinical teams with instant patient record summaries and medical histories.\",\n      \"Extracts unstructured clinical files, removing hours of redundant manual logging.\",\n      \"Merges siloed EHR records and journals into a single queryable semantic knowledge layer.\",\n      \"Maintains absolute data lineage and continuous HIPAA boundary audits.\",\n      \"Saves valuable clinical attention, reducing documentation-induced physician fatigue.\"\n    ],\n    tech: \"Apache NiFi • pgvector • Neo4j\",\n    logs: [\"[EHR-GATEWAY] Connected to hospital nodes\", \"[EXTRACT] Parsing clinical PDFs\", \"[GRAPH] Patient timelines linked\", \"[SECURE] HIPAA locked & synchronized\"]\n  },\n  {\n    n: \"Manufacturing AI Factory\", c: \"#E4000F\", g: \"Industrial\",\n    t: \"Predictive Assembly & Telemetry Agent Grid\",\n    d: \"Bridging machine PLC telemetry with active maintenance and supply-chain logistics.\",\n    ch: \"High costs of sudden machinery breakdowns and static supply line schedules.\",\n    sl: \"Sub-millisecond IoT telemetry streams feeding reactive predictive dispatch agents.\",\n    o: [\n      \"Translates real-time sensor variables into preventative diagnostic warning flags.\",\n      \"Auto-generates repair tasks and schedules spare parts before downtime occurs.\",\n      \"Indexes telemetry histories and machine blueprints into an interactive dashboard.\",\n      \"Enforces continuous telemetry validation against safety and green compliance metrics.\",\n      \"Moves floor supervisors from high-stress crisis response to planned maintenance.\"\n    ],\n    tech: \"MQTT • Flink • Rust-WASM\",\n    logs: [\"[IOT] Subscribed to floor telemetry\", \"[ANALYST] Shaft fatigue alert\", \"[NEO4J] Mapped asset dependencies\", \"[ENGINE] Dispatching repair technician\"]\n  },\n  {\n    n: \"Retail Agent Operations\", c: \"#10B981\", g: \"Commerce\",\n    t: \"Contextual Commerce & Shipping Broker\",\n    d: \"State-aware commerce agents integrated directly with localized product stock indexes.\",\n    ch: \"High customer support volumes and static order tracking platforms.\",\n    sl: \"Intelligent retail assistants with permissioned write-back to logistics channels.\",\n    o: [\n      \"Resolves parcel tracking delays and refund requests instantly at the customer gateway.\",\n      \"Handles repetitive shipping and adjustment queries with zero manual queues.\",\n      \"Synthesizes extensive product lists and return policies directly into chat context.\",\n      \"Assesses return permissions automatically against localized commerce laws.\",\n      \"Drops tier-1 support tickets, focusing service personnel on premium consulting.\"\n    ],\n    tech: \"Kafka • LangGraph • Stripe API\",\n    logs: [\"[OMNI-HANDLER] Webhook triggered #90a\", \"[ROUTER] Intent: Track shipment\", \"[VECTOR-MESH] Finding catalog stock\", \"[DISPATCH] Return label created\"]\n  }\n];\n\nconst THEMES = [\n  \"Faster Decision Making\",\n  \"Reduced Manual Effort\",\n  \"Better Knowledge Access\",\n  \"Improved Compliance Workflows\",\n  \"Improved Employee Experience\"\n];\n\nexport default function ClientSuccessSection() {\n  const [tab, setTab] = useState(0);\n  const [step, setStep] = useState(1);\n  const [play, setPlay] = useState(true);\n  const [prog, setProg] = useState(15);\n  const p = PATTERNS[tab];\n\n  useEffect(() => {\n    if (!play) return;\n    const interval = setInterval(() => setProg((pr) => (pr >= 100 ? 0 : pr + 2)), 180);\n    return () => clearInterval(interval);\n  }, [play]);\n\n  const lines = p.logs.slice(0, Math.min(Math.floor((prog / 100) * p.logs.length) + 1, p.logs.length));\n\n  return (\n    <motion.section \n      id=\"client-success\"\n      initial={{ opacity: 0 }} whileInView={{ opacity: 1 }} viewport={{ once: true }}\n      className=\"w-full bg-[#020202] px-6 lg:px-16 py-20 relative overflow-hidden border-t border-white/5\"\n    >\n      <div className=\"absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_50%_50%,rgba(233,136,40,0.02)_0%,transparent_60%)]\" />\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        \n        <div className=\"text-center mb-16\">\n          <SectionHeading\n            title={<h2 className=\"text-[32px] sm:text-[44px] font-bold uppercase text-white tracking-widest\">CLIENT <span className=\"text-[#E98828]\">SUCCESS</span></h2>}\n            titleClassName=\"text-center\" dividerWidthClassName=\"w-[300px]\"\n          />\n          <p className=\"mt-6 text-center text-[16px] lg:text-[18px] text-[#A0A0A0] max-w-3xl mx-auto font-light leading-relaxed\">\n            We don't build generic SaaS software. We design secure enterprise AI frameworks. Inspect our representative patterns.\n          </p>\n        </div>\n\n        {/* Tab Switcher */}\n        <div className=\"flex flex-col items-center gap-4 mb-12\">\n          <span className=\"text-[10px] font-mono uppercase tracking-[0.2em] text-[#E98828] font-semibold\">Select Representative Pattern</span>\n          <div className=\"w-full max-w-4xl bg-[#090909] border border-white/5 p-1.5 rounded-[16px] overflow-x-auto scrollbar-none flex gap-2 sm:grid sm:grid-cols-4\">\n            {PATTERNS.map((item, idx) => (\n              <button\n                key={item.n} onClick={() => { setTab(idx); setStep(1); setProg(15); }}\n                className={`flex flex-col items-center py-3 px-4 rounded-[12px] transition-all cursor-pointer ${tab === idx ? \"bg-white/5 border border-white/10\" : \"border border-transparent hover:bg-white/2\"}`}\n              >\n                <div className=\"flex items-center gap-2 mb-1\">\n                  <span className=\"w-1.5 h-1.5 rounded-full\" style={{ backgroundColor: item.c, boxShadow: tab === idx ? `0 0 8px ${item.c}` : \"none\" }} />\n                  <span className={`text-[13px] font-bold tracking-wide ${tab === idx ? \"text-white\" : \"text-white/40\"}`}>{item.g}</span>\n                </div>\n                <span className=\"text-[9px] font-mono text-white/30 uppercase\">{item.g} Ops</span>\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Main Columns */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          \n          {/* Left Block */}\n          <div className=\"lg:col-span-7 flex flex-col gap-6\">\n            <div className=\"flex justify-between border border-white/5 bg-[#050505] rounded-xl px-5 py-3 text-[11px] font-mono text-white/40\">\n              <div className=\"flex items-center gap-2\">\n                <span className={`w-2 h-2 rounded-full ${play ? \"animate-pulse\" : \"\"}`} style={{ backgroundColor: p.c }} />\n                <span>STATE: {play ? \"SIMULATOR ONLINE\" : \"PAUSED\"}</span>\n              </div>\n              <span className=\"hidden sm:inline\">SPEED: 1.0x</span>\n            </div>\n\n            {/* Architecture preview */}\n            <div className=\"rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] p-6 flex flex-col gap-6 relative\">\n              <div className=\"absolute top-0 right-0 px-3 py-1 bg-white/5 border-l border-b border-white/5 text-[8px] font-mono text-white/40 rounded-bl-lg uppercase\">Topology</div>\n              <div>\n                <span className=\"px-2 py-0.5 text-[9px] font-mono font-bold text-white/50 bg-white/5 rounded\">PIPELINE FLOW</span>\n                <h4 className=\"mt-2 text-[18px] font-bold text-white uppercase\">{p.n} Architecture</h4>\n              </div>\n\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n                {[\"Ingest gateway\", \"Cognitive core\", \"Memory index\", \"Action broker\"].map((blk, i) => (\n                  <button\n                    key={blk} onClick={() => setStep(i)}\n                    className={`text-left rounded-xl p-4 transition-all border cursor-pointer min-h-[90px] flex flex-col justify-between ${step === i ? \"bg-[#0A0A0A]\" : \"bg-black/20 border-white/5\"}`}\n                    style={{ borderColor: step === i ? p.c : \"rgba(255,255,255,0.05)\" }}\n                  >\n                    <span className=\"text-[9px] font-mono text-white/30 font-bold\">0{i+1}</span>\n                    <h5 className=\"text-[12px] font-bold text-white leading-tight uppercase tracking-wider\">{blk}</h5>\n                  </button>\n                ))}\n              </div>\n\n              <div className=\"border-t border-white/5 pt-4 mt-2\">\n                <span className=\"text-[9px] font-mono text-white/30 uppercase\">Parameters</span>\n                <h5 className=\"text-[14px] font-bold text-white mt-0.5\">\n                  {step === 0 ? \"Ingestion Gateway\" : step === 1 ? \"Cognitive Core Routing\" : step === 2 ? \"Semantic Memory Mesh\" : \"Action execution handler\"}\n                </h5>\n                <p className=\"text-[12.5px] text-[#808080] mt-1 font-light leading-relaxed\">\n                  {step === 0 ? \"Ensures multi-modal input processing, sanitizing raw data flows directly from secure pipelines.\" :\n                   step === 1 ? \"Routes semantic intent payloads into orchestrator graphs to resolve sub-tasks.\" :\n                   step === 2 ? \"Indexes vector mappings and long-term context data for rapid relational lookups.\" :\n                   \"Transfers confirmed execution states into destination enterprise systems and ERP nodes safely.\"}\n                </p>\n                <div className=\"mt-3 text-[10px] font-mono\"><span className=\"text-white/30 mr-2 uppercase\">STACK:</span><span className=\"text-white/70\">{p.tech}</span></div>\n              </div>\n            </div>\n\n            {/* Video walkthrough */}\n            <div className=\"rounded-[24px] border border-white/5 bg-[#050505]/60 overflow-hidden flex flex-col\">\n              <div className=\"bg-black border-b border-white/5 px-5 py-3 flex justify-between text-[10px] font-mono text-white/60\">\n                <span>● WALKTHROUGH SIMULATOR</span>\n                <span className=\"text-[8px] bg-white/5 border border-white/10 px-1 py-0.5 rounded uppercase\">REPRESENTATIVE VIDEO</span>\n              </div>\n              <div className=\"relative aspect-video w-full bg-black flex items-stretch overflow-hidden\">\n                <div className=\"w-1/2 border-r border-white/5 p-4 flex items-center justify-center relative bg-black/40\">\n                  <svg className=\"w-full h-full max-h-[140px]\" viewBox=\"0 0 200 120\">\n                    <circle cx=\"40\" cy=\"60\" r=\"4\" fill={p.c} />\n                    <circle cx=\"100\" cy=\"30\" r=\"4\" fill={p.c} className={play ? \"animate-pulse\" : \"\"} />\n                    <circle cx=\"100\" cy=\"90\" r=\"4\" fill={p.c} />\n                    <circle cx=\"160\" cy=\"60\" r=\"4\" fill={p.c} />\n                    <path d=\"M48 55 L92 34 M48 65 L92 86 M108 34 L152 55 M108 86 L152 65\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    {play && <circle cx=\"100\" cy=\"60\" r=\"35\" stroke={p.c} strokeWidth=\"0.5\" strokeDasharray=\"3 3\" className=\"animate-pulse\" />}\n                  </svg>\n                </div>\n                <div className=\"w-1/2 p-4 bg-[#030303] flex flex-col text-[9px] font-mono text-white/50 text-left\">\n                  <div className=\"border-b border-white/5 pb-1 mb-2 font-bold uppercase text-white/30 flex justify-between\">\n                    <span>Logs</span><span style={{ color: p.c }}>LIVE</span>\n                  </div>\n                  <div className=\"flex flex-col gap-1.5 overflow-hidden\">\n                    {lines.map((l, idx) => <div key={idx} className={idx === lines.length - 1 ? \"text-white\" : \"text-white/60\"}>{l}</div>)}\n                    {play && <div className=\"w-1.5 h-3 bg-white/40 animate-pulse mt-0.5\" />}\n                  </div>\n                </div>\n                {!play && (\n                  <div className=\"absolute inset-0 bg-black/85 backdrop-blur-[2px] flex flex-col items-center justify-center cursor-pointer\" onClick={() => setPlay(true)}>\n                    <div className=\"w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white\"><svg className=\"w-3.5 h-3.5 fill-current ml-0.5\" viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg></div>\n                    <span className=\"text-[11px] font-mono text-white uppercase mt-3\">Watch Video Playback</span>\n                  </div>\n                )}\n              </div>\n              <div className=\"bg-black px-5 py-3.5 border-t border-white/5 flex items-center justify-between text-[10px] font-mono text-white/50\">\n                <button onClick={() => setPlay(!play)} className=\"hover:text-white cursor-pointer\">{play ? \"PAUSE\" : \"PLAY\"}</button>\n                <span>00:{prog < 10 ? `0${prog}` : prog} / 01:00</span>\n                <div className=\"flex-grow mx-4 h-[2px] bg-white/10 rounded\"><div className=\"h-full\" style={{ width: `${prog}%`, backgroundColor: p.c }} /></div>\n                <span className=\"px-1 py-0.2 rounded bg-white/5 text-[8px] border border-white/10 text-white/50\">HD</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Block */}\n          <div className=\"lg:col-span-5 flex flex-col justify-between gap-6\">\n            <div className=\"flex flex-col\">\n              <span className=\"text-[9px] font-mono font-bold text-[#E98828] uppercase tracking-wider\">REPRESENTATIVE PATTERN</span>\n              <h3 className=\"mt-3 text-[26px] lg:text-[32px] font-bold text-white uppercase tracking-tight\">{p.n}</h3>\n              <p className=\"mt-1 text-[13.5px] font-mono text-white/70 font-semibold\">{p.t}</p>\n              <p className=\"mt-3 text-[13.5px] text-[#A0A0A0] leading-relaxed font-light\">{p.d}</p>\n            </div>\n\n            <div className=\"flex flex-col gap-3\">\n              <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4\">\n                <span className=\"text-[8.5px] font-mono font-bold text-red-400 uppercase tracking-widest block mb-1\">Challenge</span>\n                <p className=\"text-[12.5px] text-[#A0A0A0] font-light leading-relaxed\">{p.ch}</p>\n              </div>\n              <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4\">\n                <span className=\"text-[8.5px] font-mono font-bold text-emerald-400 uppercase tracking-widest block mb-1\">GFF Solution</span>\n                <p className=\"text-[12.5px] text-[#A0A0A0] font-light leading-relaxed\">{p.sl}</p>\n              </div>\n            </div>\n\n            <div className=\"flex flex-col gap-3\">\n              <span className=\"text-[9px] font-mono uppercase tracking-wider text-white/50 font-bold border-b border-white/5 pb-2\">Business Outcomes</span>\n              <div className=\"flex flex-col gap-2.5\">\n                {THEMES.map((th, idx) => (\n                  <div key={th} className=\"group rounded-lg border border-white/5 bg-black/20 hover:border-white/10 p-3 transition-all\">\n                    <div className=\"flex items-start gap-2.5\">\n                      <span className=\"mt-1 w-1.5 h-1.5 rounded-full bg-orange-500 flex-shrink-0\" />\n                      <div>\n                        <h5 className=\"text-[12px] font-bold text-white uppercase tracking-wider\">{th}</h5>\n                        <p className=\"text-[11.5px] text-[#808080] leading-relaxed mt-0.5 font-light group-hover:text-white/80 transition-colors\">{p.o[idx]}</p>\n                      </div>\n                    </div>\n                  </div>\n                ))}\n              </div>\n              <span className=\"text-[9px] font-mono text-white/30 text-center block pt-2 italic\">\n                * Representative pattern anonymized. No fake ROI or names used.\n              </span>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n    </motion.section>\n  );\n}\n"}}}
