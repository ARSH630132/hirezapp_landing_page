    <div className=\"flex items-center gap-2 mb-1.5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-red-500\" />\n                  <span className=\"text-[10px] font-mono font-bold text-white/40 uppercase tracking-widest\">\n                    Strategic Operational Challenge\n                  </span>\n                </div>\n                <p className=\"text-[13px] leading-relaxed text-[#A0A0A0] font-light\">\n                  {pattern.challenge}\n                </p>\n              </div>\n\n              <div className=\"rounded-[16px] border border-white/5 bg-[#050505]/50 p-4.5\">\n                <div className=\"flex items-center gap-2 mb-1.5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse\" />\n                  <span className=\"text-[10px] font-mono font-bold text-white/40 uppercase tracking-widest\">\n                    GFF AI Orchestrated Solution\n                  </span>\n                </div>\n                <p className=\"text-[13px] leading-relaxed text-[#A0A0A0] font-light\">\n                  {pattern.solution}\n                </p>\n              </div>\n            </div>\n\n            {/* 5 Key Outcome Themes */}\n            <div className=\"flex flex-col gap-4\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n                <span className=\"text-[10px] font-mono uppercase tracking-[0.1em] text-white/50 font-bold\">\n                  Validated Business Outcome Themes\n                </span>\n                <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 text-white/40 border border-white/10 uppercase\">\n                  Verified Patterns\n                </span>\n              </div>\n\n              <div className=\"flex flex-col gap-3\">\n                {/* 1. Faster Decision Making */}\n                <div className=\"group relative rounded-xl border border-white/5 bg-black/20 hover:border-white/10 p-3.5 transition-all\">\n                  <div className=\"flex items-start gap-3\">\n                    <span className=\"mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-orange-500\" />\n                    <div>\n                      <h5 className=\"text-[12.5px] font-bold text-white uppercase tracking-wider\">\n                        Faster Decision Making\n                      </h5>\n                      <p className=\"text-[12px] text-[#808080] leading-relaxed mt-0.5 font-light group-hover:text-white/80 transition-colors duration-300\">\n                        {pattern.outcomes.fasterDecisioning}\n                      </p>\n                    </div>\n                  </div>\n                </div>\n\n                {/* 2. Reduced Manual Effort */}\n                <div className=\"group relative rounded-xl border border-white/5 bg-black/20 hover:border-white/10 p-3.5 transition-all\">\n                  <div className=\"flex items-start gap-3\">\n                    <span className=\"mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-orange-500\" />\n                    <div>\n                      <h5 className=\"text-[12.5px] font-bold text-white uppercase tracking-wider\">\n                        Reduced Manual Effort\n                      </h5>\n                      <p className=\"text-[12px] text-[#808080] leading-relaxed mt-0.5 font-light group-hover:text-white/80 transition-colors duration-300\">\n                        {pattern.outcomes.reducedManualEffort}\n                      </p>\n                    </div>\n                  </div>\n                </div>\n\n                {/* 3. Better Knowledge Access */}\n                <div className=\"group relative rounded-xl border border-white/5 bg-black/20 hover:border-white/10 p-3.5 transition-all\">\n                  <div className=\"flex items-start gap-3\">\n                    <span className=\"mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-orange-500\" />\n              