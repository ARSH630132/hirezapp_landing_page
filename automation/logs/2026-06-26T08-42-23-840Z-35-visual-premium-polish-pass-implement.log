          className=\"w-full h-[46px] rounded-lg bg-[#E98828] text-sm font-bold text-white hover:bg-[#E98828]/80 transition\"\n388 |                   >\n389 |                     Verify & Build Blueprint\n390 |                   </button>\n391 |                 </div>\n392 |               )}\n393 |             </div>\n394 |           </div>\n395 |         )}\n396 | \n397 | \n398 |         {/* Compile Loading Screen */}\n399 |         {isCompiling && (\n400 |           <div className=\"fixed inset-0 z-[10000] bg-black/95 backdrop-blur-md flex flex-col justify-center items-center text-center p-4 animate-fadeIn\">\n401 |             <div className=\"relative w-20 h-20 mb-6\">\n402 |               <div className=\"absolute inset-0 rounded-full border-4 border-white/10\"></div>\n403 |               <div className=\"absolute inset-0 rounded-full border-4 border-t-[#087DF3] animate-spin\"></div>\n404 |             </div>\n405 |             <h4 className=\"text-lg font-bold text-white mb-2\">Compiling Custom AI Blueprint</h4>\n406 |             <p className=\"text-sm font-semibold text-[#087DF3] h-6 transition-all animate-pulse\">\n407 |               {compilingMessages[compilingStep]}\n408 |             </p>\n409 |           </div>\n410 |         )}\n411 | \n412 |         {/* Bottom Wizard Controls */}\n413 |         {step < 4 && (\n414 |           <div className=\"mt-8 pt-4 border-t border-white/5 flex justify-between items-center\">\n415 |             {error && <p className=\"text-xs md:text-sm text-red-400 font-semibold max-w-[70%]\">{error}</p>}\n416 |             <div className=\"flex gap-4 ml-auto\">\n417 |               {step > 1 && (\n418 |                 <button\n419 |                   type=\"button\"\n420 |                   onClick={() => setStep(step - 1)}\n421 |                   className=\"px-5 h-[42px] rounded-lg border border-white/15 text-xs font-semibold text-white hover:bg-white/5 transition\"\n422 |                 >\n423 |                   Back\n4