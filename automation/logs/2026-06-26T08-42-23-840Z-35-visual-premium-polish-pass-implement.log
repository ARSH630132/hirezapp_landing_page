chnical reports, security specifications, and sovereign AI readiness assessments.\",\n192 |     link: \"/resources\",\n193 |     keywords: [\"whitepapers\", \"reports\", \"download\", \"technical\", \"security\", \"sovereign\", \"compliance\", \"assessment\"]\n194 |   },\n195 | \n196 |   // Company\n197 |   {\n198 |     title: \"Why GFF AI - Philosophy\",\n199 |     category: \"Company\",\n200 |     description: \"Discover our distinct engineering philosophy, trusted corporate oversight, and productized blueprint delivery models.\",\n201 |     link: \"/why-gff-ai\",\n202 |     keywords: [\"why gff ai\", \"philosophy\", \"approach\", \"value\", \"blueprints\", \"trust\", \"advantage\"]\n203 |   },\n204 |   {\n205 |     title: \"Company Overview & GFF Hubs\",\n206 |     category: \"Company\",\n207 |     description: \"Learn how GFF AI delivers comprehensive transformation from Garage (ideation) to Foundry (forging) to Factory (production scale).\",\n208 |     link: \"/company\",\n209 |     keywords: [\"company\", \"overview\", \"garage\", \"foundry\", \"factory\", \"hubs\", \"delivery\", \"locations\", \"presence\", \"leadership\", \"mission\", \"values\"]\n210 |   }\n211 | ];\n212 | \n213 | const categoryColors: Record<string, string> = {\n214 |   \"Industries\": \"#4F8CFF\",     // Premium blue\n215 |   \"Capabilities\": \"#9D00FF\",   // Purple\n216 |   \"Platforms\": \"#E4000F\",      // Vibrant Red\n217 |   \"Build With GFF\": \"#009DFF\", // Cyan/Light Blue\n218 |   \"Resources\": \"#E98828\",      // Warm Orange\n219 |   \"Company\": \"#24D39B\"         // Emerald Green\n220 | };\n221 | \n222 | const exampleSearches = [\n223 |   \"Build AI for Banking\",\n224 |   \"Create University AI Lab\",\n225 |   \"Insurance AI\",\n226 |   \"Mining AI\",\n227 |   \"Retail AI\",\n228 |   \"Build AI GCC\"\n229 | ];\n230 | \n231 | export default function QuickSearchSection() {\n232 |   const [searchQuery, setSearchQuery] = useState(\"\");\n233 | \n234 |   const filteredResults = useMemo(() => {\n235 |     const query = searchQuery.trim().toLowerCase();\n236 |     if (!query) return [];\n237 | \n238 |     const terms = query.split(/\\s+/).filter(Boolean);\n239 |     if (terms.length === 0) return [];\n240 | \n241 |     return staticSearchDatabase.filter((item) => {\n242 |       return terms.every((term) => {\n243 |         const inTitle = item.title.toLowerCase().includes(term);\n244 |         const inDesc = item.description.toLowerCase().includes(term);\n245 |         const inCat = item.category.toLowerCase().includes(term);\n246 |         const inKeywords = item.keywords.some((kw) => kw.toLowerCase().includes(term));\n247 |         return inTitle || inDesc || inCat || inKeywords;\n248 |       });\n249 |     });\n250 |   }, [searchQuery]);\n251 | \n252 |   return (\n253 |     <section className=\"w-full bg-black px-6 lg:px-16 lg:py-24 py-16 border-t border-white/5 relative overflow-hidden\">\n254 |       {/* Dynamic Background subtle grid and radial glow */}\n255 |       <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,157,255,0.03)_0%,transparent_70%)] pointer-events-none\" />\n256 |       <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#111_1px,transparent_1px),linear-gradient(to_bottom,#111_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30 pointer-events-none\" />\n257 | \n258 |       <div className=\"max-w-[1795px] mx-auto relative z-10\">\n259 |         <SectionHeading\n260 |           title={\n261 |             <h2 className=\"text-[24px] sm:text-[32px] leading-none font-medium text-center uppercase text-white tracking-wider\">\n262 |               ENTERPRISE <span className=\"text-[#009DFF]\">QUICK SEARCH</span>\n263 |             </h2>\n264 |           }\n265 |           titleClassName=\"text-center\"\n266 |           dividerWidthClassName=\"w-[260px]\"\n267 |         />\n268 | \n269 |         <p clas