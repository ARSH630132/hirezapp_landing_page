se().includes(term);\n244 |         const inDesc = item.description.toLowerCase().includes(term);\n245 |         const inCat = item.category.toLowerCase().includes(term);\n246 |         const inKeywords = item.keywords.some((kw) => kw.toLowerCase().includes(term));\n247 |         return inTitle || inDesc || inCat || inKeywords;\n248 |       });\n249 |     });\n250 |   }, [searchQuery]);\n251 | \n252 |   return (\n253 |     <section className=\"w-full bg-black px-6 lg:px-16 lg:py-24 py-16 border-t border-white/5 relative overflow-hidden\">\n254 |       {/* Dynamic Background subtle grid and radial glow */}\n255 |       <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,157,255,0.03)_0%,transparent_70%)] pointer-events-none\" />\n256 |       <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#111_1px,transparent_1px),linear-gradient(to_bottom,#111_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30 pointer-events-none\" />\n257 | \n258 |       <div className=\"max-w-[1795px] mx-auto relative z-10\">\n259 |         <SectionHeading\n260 |           title={\n261 |             <h2 className=\"text-[24px] sm:text-[32px] leading-none font-medium text-center uppercase text-white tracking-wider\">\n262 |               ENTERPRISE <span className=\"text-[#009DFF]\">QUICK SEARCH</span>\n263 |             </h2>\n264 |           }\n265 |           titleClassName=\"text-center\"\n266 |           dividerWidthClassName=\"w-[260px]\"\n267 |         />\n268 | \n269 |         <p className=\"mt-5 mx-auto max-w-[800px] text-center text-white/60 text-[14px] sm:text-[16px] leading-relaxed\">\n270 |           Ask our AI Concierge or select an enterprise blueprint template below. Explore customized frameworks, pre-built platforms, and engineering models instantly.\n271 |         </p>\n272 | \n273 |         {/* AI Concierge Search Box */}\n274 |         <div className=\"mt-10 relative max-w-3xl mx-auto group\">\n275 |           <div className=\"absolute -inset-[1px] rounded-[24px] bg-gradient-to-r from-white/10 via-[#009DFF]/20 to-white/10 opacity-75 blur-[2px] group-focus-within:from-[#E4000F]/30 group-focus-within:to-[#009DFF]/40 transition-all duration-500 pointer-events-none\" />\n276 |           \n277 |           <div className=\"relative flex items-center rounded-[24px] bg-[#050505] border border-white/10 text-white focus-within:border-white/20 transition-all duration-300 shadow-[0_0_30px_rgba(0,0,0,0.85)]\">\n278 |             <div className=\"absolute left-6 pointer-events-none text-white/40 group-focus-within:text-[#009DFF] transition-colors duration-300\">\n279 |               <Search className=\"h-5 w-5\" />\n280 |             </div>\n281 | \n282 |             <input\n283 |               type=\"text\"\n284 |               value={searchQuery}\n285 |               onChange={(e) => setSearchQuery(e.target.value)}\n286 |               aria-label=\"Search GFF AI solutions\"\n287 |               placeholder=\"Ask GFF AI (e.g. Build AI for Banking or Mining)...\"\n288 |               className=\"w-full pl-15 pr-14 py-5 bg-transparent text-white text-[15px] sm:text-[17px] leading-relaxed focus:outline-none placeholder-white/25 font-normal tracking-wide\"\n289 |             />\n290 | \n291 |             <AnimatePresence>\n292 |               {searchQuery && (\n293 |                 <motion.button\n294 |                   initial={{ opacity: 0, scale: 0.8 }}\n295 |                   animate={{ opacity: 1, scale: 1 }}\n296 |                   exit={{ opacity: 0, scale: 0.8 }}\n297 |                   onClick={() => setSearchQuery(\"\")}\n298 |                   className=\"absolute right-6 p-1.5 rounded-full text-white/40 hover:text-white hover:bg-white/5 transition-all cursor-pointer\"\n299 |                   title=\"Clear search\"\n300 |                 >\n301 |                   <X className=\"h-4.5 w-4.5\" />\n302 |                 </motion.button>\n303 |               )}\n304 |             </AnimatePresence>\n305 |           </div>\n306 |         </div>\n307 | \n308 |         {/* Clickable Templates */}\n309 |         <div className=\"mt-6 flex flex-wrap items-center justify-center gap-2 sm:gap-3 text-sm max-w-3xl mx-auto\">\n310 |           <span className=\"text-white/45 font-medium mr-1 text-[13px] sm:text-sm\">Click examples:</span>\n311 |           {exampleSearches.map((example) => {\n312 |             const isActive = searchQuery.toLowerCase().trim() === example.toLowerCase().trim();\n313 |             return (\n314 |               <button\n315 |                 key={example}\n316 |                 onClick={() => setSearchQuery(example)}\n317 |                 className={`px-4 py-2 rounded-[98px] text-[12px] sm:text-[13px] font-medium border transition-all duration-300 cursor-pointer ${\n318 |                   isActive\n319 |                     ? \"bg-[#009DFF]/10 border-[#009DFF]/30 text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.1)]\"\n320 |                     : \"bg-white/[0.02] border-white/5 text-white/60 hover:text-white hover:border-white/15 hover:bg-white/[0.04]\"\n321 |                 }`}\n322 |               >\n323 |                 {example}\n324 |               </button>\n325 |             );\n326 |           })}\n327 |         </div>\n328 | \n329 |         {/* Dynamic Display Area */}\n330 |         <div className=\"mt-12 min-h-[160px] relative\">\n331 |           <AnimatePresence mode=\"wait\">\n332 |             {/* 1. Empty/Awaiting State */}\n333 |             {!searchQuery && (\n334 |               <motion.div\n335 |                 key=\"empty-waiting\"\n336 |                 initial={{ opacity: 0, y: 15 }}\n337 |                 animate={{ opacity: 1, y: 0 }}\n338 |                 exit={{ opacity: 0, y: -15 }}\n339 |                 transition={{ duration: 0.3 }}\n340 |                 className=\"max-w-4xl mx-auto rounded-[28px] border border-white/5 bg-[#