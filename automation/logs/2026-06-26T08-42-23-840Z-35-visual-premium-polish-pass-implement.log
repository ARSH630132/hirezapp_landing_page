      ))}\n359 |                 </div>\n360 |               </motion.div>\n361 |             )}\n362 | \n363 |             {/* 2. No Match State */}\n364 |             {searchQuery && filteredResults.length === 0 && (\n365 |               <motion.div\n366 |                 key=\"no-match\"\n367 |                 initial={{ opacity: 0, y: 15 }}\n368 |                 animate={{ opacity: 1, y: 0 }}\n369 |                 exit={{ opacity: 0, y: -15 }}\n370 |                 transition={{ duration: 0.3 }}\n371 |                 className=\"max-w-2xl mx-auto rounded-[28px] border border-white/5 bg-[#030303]/40 p-8 sm:p-10 text-center backdrop-blur-md shadow-2xl\"\n372 |               >\n373 |                 <div className=\"inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/5 mb-4 text-white/30\">\n374 |                   <Search className=\"h-5 w-5\" />\n375 |                 </div>\n376 |                 <h3 className=\"text-lg font-semibold text-white tracking-wide\">No custom AI paths found</h3>\n377 |                 <p className=\"mt-2 text-sm text-white/50 max-w-md mx-auto leading-relaxed\">\n378 |                   We couldn't find matching capabilities for <span className=\"text-[#009DFF] font-medium\">\"{searchQuery}\"</span>. Try typing other terms or clicking one of the templates above.\n379 |                 </p>\n380 |                 <button\n381 |                   onClick={() => setSearchQuery(\"\")}\n382 |                   className=\"mt-6 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 text-white/80 hover:text-white text-xs sm:text-sm font-semibold transition-all cursor-pointer\"\n383 |                 >\n384 |                   Reset Concierge Search\n385 |                 </button>\n386 |               </motion.div>\n387 |             )}\n388 | \n389 |             {/* 3. Search Results State */}\n390 |             {searchQuery && filteredResults.length > 0 && (\n391 |               <motion.div\n392 |                 key=\"results-grid\"\n393 |                 initial={{ opacity: 0 }}\n394 |                 animate={{ opacity: 1 }}\n395 |                 exit={{ opacity: 0 }}\n396 |                 transition={{ duration: 0.3 }}\n397 |                 className=\"grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto\"\n398 |               >\n399 |                 {filteredResults.map((result, idx) => {\n400 |                   const color = categoryColors[result.category] || \"#009DFF\";\n401 |                   return (\n402 |                     <motion.div\n403 |                       key={result.title}\n404 |                       initial={{ opacity: 0, y: 12 }}\n405 |                       animate={{ opacity: 1, y: 0 }}\n406 |                       transition={{ duration: 0.4, delay: Math.min(idx * 0.05, 0.25) }}\n407 |                       className=\"group relative h-full rounded-[24px] border border-white/5 bg-[#050505] p-6 hover:bg-[#070707] hover:border-white/15 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(0,157,255,0.06)] flex flex-col justify-between\"\n408 |                     >\n409 |                       {/* Left border accent line representing the category color */}\n410 |                       <div\n411 |                         className=\"absolute left-0 top-6 bottom-6 w-[3px] rounded-r-[4px] transition-all duration-300 group-hover:scale-y-110\"\n412 |                         style={{ backgroundColor: color }}\n413 |                       />\n414 | \n415 |                       <div className=\"pl-4 flex flex-col h-full justify-between\">\n416 |                         <div>\n417 |                           <div className=\"flex items-center justify-between gap-3\">\n418 |                             <span\n419 |                               className=\"text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.15em]\"\n420 |                               style={{ color }}\n421 |                             >\n422 |                               {result.category}\n423 |                             </span>\n424 |                           </div>\n425 | \n426 |                           <h4 className=\"mt-2 text-base sm:text-[18px] font-semibold text-white tracking-wide group-hover:text-[#009DFF] transition-colors duration-300\">\n427 |                             {result.title}\n428 |                           </h4>\n429 | \n430 |                           <p className=\"mt-3 text-[13px] sm:text-[14px] text-white/60 leading-relaxed font-normal\">\n431 |                             {result.description}\n432 |                           </p>\n433 |                         </div>\n434 | \n435 |                         <div className=\"mt-6 pt-4 border-t border-white/[0.03] flex items-center justify-between text-xs sm:text-[13px] font-medium text-white/40 group-hover:text-white transition-colors duration-300\">\n436 |                           <span>Explore Solution Specs</span>\n437 |                           <Link href={result.link} className=\"flex items-center gap-1 text-[#009DFF] hover:underline\">\n438 |                             Explore <ArrowRight className=\"h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1\" />\n439 |                           </Link>\n440 |                         </div>\n441 |                       </div>\n442 |                     </motion.div>\n443 |                   );\n444 |                 })}\n445 |               </motion.div>\n446 |             )}\n447 |           </AnimatePresence>\n448 |         </div>\n449 |       </div>\n450 |     </section>\n451 |   );\n452 | }","success":true}],"durationMs":9}}
