port default function SecureLogin({ defaultRole }: { defaultRole?: string }) {\n  const router = useRouter();\n  const [selectedRole, setSelectedRole] = useState<PreviewRole>(\"client_admin\");\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n\n  const rolesList: { id: PreviewRole; label: string; clearance: string; icon: any; desc: string }[] = [\n    { id: \"client_admin\", label: \"Client Admin\", clearance: \"Level III\", icon: Users, desc: \"Full Client Sandbox Admin\" },\n    { id: \"client_member\", label: \"Client Member\", clearance: \"Level II\", icon: Layers, desc: \"Read/Write workspace member\" },\n    { id: \"gff_admin\", label: \"GFF Admin\", clearance: \"Level V\", icon: Shield, desc: \"System Superuser Override\" },\n    { id: \"gff_operator\", label: \"GFF Operator\", clearance: \"Level IV\", icon: Cpu, desc: \"Technical systems operator\" },\n    { id: \"finance_admin\", label: \"Finance Admin\", clearance: \"Level III\", icon: FileText, desc: \"Ledgers & billing controller\" },\n    { id: \"support_agent\", label: \"Support Agent\", clearance: \"Level III\", icon: HelpCircle, desc: \"Priority support wire helper\" },\n    { id: \"viewer\", label: \"Auditor (Viewer)\", clearance: \"Level I\", icon: Eye, desc: \"Read-only compliance auditor\" },\n  ];\n\n  const scanMessages = [\n    \"Establishing local localstorage sandbox...\",\n    \"Registering cryptographic credentials in browser...\",\n    \"Generating zero-trust simulation key (SHA-256)...\",\n    \"Pre-compiling simulated clearance privileges...\"\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => setScanStep(p => p < 3 ? p + 1 : p), 250);\n    await new Promise(r => setTimeout(r, 1100));\n    clearInterval(interval);\n    setScanning(false);\n    setPreviewSession(selectedRole);\n    router.push(selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative px-4 py-8 select-none font-mono\">\n      <div className=\"absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:24px_24px]\" />\n      <div className=\"w-full max-w-2xl z-10 space-y-6\">\n        <div className=\"text-center space-y-2\">\n          <div className=\"inline-flex h-9 w-9 items-center justify-center rounded-xl border border-white/5 bg-[#0a0a0a] text-[#009DFF]\"><Shield className=\"w-4 h-4\" /></div>\n          <div><span className=\"text-[8px] font-bold tracking-widest text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded-full\">ZERO-TRUST IDENTITY DECK</span></div>\n          <h1 className=\"text-sm font-bold uppercase tracking-wide\">Sovereign <span className=\"text-[#009DFF]\">Access Gateway</span></h1>\n          <p className=\"text-[10px] text-white/50\">Select a simulated enterprise persona to inspect the workspace.</p>\n        </div>\n\n        <div className=\"p-5 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-md space-y-5\">\n          {!scanning ? (\n            <div className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n                {rolesList.map((r) => {\n                  const Icon = r.icon;\n                  const isSel = selectedRole === r.id;\n                  return (\n                    <button\n                      key={r.id}\n                      onClick={() => setSelectedRole(r.id)}\n                      className={`p-2.5 rounded-xl border text-left cursor-pointer flex gap-3 transition-all ${\n                        isSel ? \"border-[#009DFF]/40 bg-[#009DFF]/5\" : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.02]\"\n                      }`}\n                    >\n                      <div className={`h-8 w-8 rounded-lg border flex items-center justify-center shrink-0 ${isSel ? \"text-[#009DFF] border-[#009DFF]/30\" : \"text-white/40 border-white/5\"}`}><Icon className=\"w-4 h-4\" /></div>\n                      <div className=\"space-y-0.5 min-w-0\">\n                        <div className=\"flex items-center justify-between gap-2\">\n                          <span className=\"text-[11px] font-bold text-white truncate\">{r.label}</span>\n                          <span className=\"text-[7px] border border-white/10 rounded-sm text-white/40 px-1\">{r.clearance}</span>\n                        </div>\n                        <p className=\"text-[9px] text-white/40 truncate leading-tight\">{r.desc}</p>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n\n              <div className=\"p-3 rounded-xl border border-white/5 bg-black/40 text-[9.5px] space-y-1\">\n                <span className=\"text-[7.5px] font-bold text-[#009DFF]\">SIMULATED DETAILS</span>\n                <div className=\"grid grid-cols-2 gap-4 text-white/70\">\n                  <div>\n                    <span className=\"text-white/35 block text-[8px]\">PROFILE NAME:</span>\n                    <span className=\"font-bold text-white\">{currentMockUser.name}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/35 block text-[8px]\">SIMULATED CLEARANCE:</span>\n                    <span className=\"font-bold text-[#009DFF]\">{currentMockUser.clearance}</span>\n                  </div>\n                </div>\n              </div>\n\n              <button onClick={handleAuthenticate} className=\"w-full h-11 rounded-lg bg-white text-black font-bold text-[10px] uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer hover:bg-white/90\">\n                <Key className=\"w-3.5 h-3.5\" /> Authenticate Simulated Session\n              </button>\n\n              <div className=\"p-3 bg-blue-950/10 border border-blue-500/10 text-blue-400 rounded-xl flex gap-3 text-[9.5px] leading-relaxed\">\n                <Shield className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                <div>\n                  <strong className=\"text-white\">FRONTEND PREVIEW MODE:</strong> This is a browser-only simulation. Session states are stored locally. Real server-side identity (OAuth, Cognito, Azure AD) will connect during the backend integration phase.\n                </div>\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-4 py-4\">\n              <div className=\"relative h-14 bg-black/50 border border-white/5 rounded-xl flex items-center justify-center overflow-hidden\">\n                <div className=\"absolute inset-0 bg-[radial-gradient(rgba(0,157,255,0.05)_1px,transparent_1px)] bg-[size:8px_8px]\" />\n                <div className=\"w-6 h-6 rounded-full border border-dashed border-[#009DFF]/30 animate-spin\" />\n              </div>\n              <div className=\"space-y-1 p-3.5 bg-black/30 border border-white/5 rounded-xl text-[9px] min-h-[76px]\">\n                {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                  <div key={idx} className=\"flex items-center gap-2 text-white/80\">\n                    {idx < scanStep ? <CheckCircle className=\"w-3 h-3 text-emerald-400 shrink-0\" /> : <RefreshCw className=\"w-3 h-3 text-[#009DFF] animate-spin shrink-0\" />}\n                    <span className={idx < scanStep ? \"text-white/30 line-through\" : \"text-white\"}>{msg}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
