ext-[11px] text-white/55 font-mono text-center\">Select a simulated enterprise persona to inspect corresponding workspace dashboards.</p>\n        </div>\n\n        <div className=\"p-6 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-6\">\n          {!scanning && (\n            <div className=\"space-y-4\">\n              <span className=\"text-[9px] font-mono font-bold tracking-widest text-white/30 uppercase\">Simulated Role Profiles</span>\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n                {rolesList.map((r) => {\n                  const Icon = r.icon;\n                  const isSelected = selectedRole === r.id;\n                  return (\n                    <button\n                      key={r.id}\n                      onClick={() => setSelectedRole(r.id)}\n                      className={`p-3 rounded-xl border text-left transition-all cursor-pointer flex gap-3 ${\n                        isSelected \n                          ? \"border-[#009DFF]/40 bg-[#009DFF]/5 shadow-[0_0_15px_rgba(0,157,255,0.03)]\" \n                          : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.02]\"\n                      }`}\n                    >\n                      <div className={`h-8 w-8 rounded-lg border flex items-center justify-center shrink-0 ${r.color}`}>\n                        <Icon className=\"w-4 h-4\" />\n                      </div>\n                      <div className=\"space-y-0.5 min-w-0\">\n                        <div className=\"flex items-center justify-between gap-2\">\n                          <span className=\"text-[11.5px] font-bold text-white font-mono truncate\">{r.label}</span>\n                          <span className=\"text-[7.5px] font-mono px-1 border border-white/10 rounded-sm text-white/40 block shrink-0\">{r.clearance}</span>\n                        </div>\n                        <p className=\"text-[9px] text-white/50 leading-tight truncate\">{r.desc}</p>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n\n              <div className=\"p-3.5 rounded-xl border border-white/5 bg-black/40 font-mono text-[10px] space-y-2\">\n                <span className=\"text-[8px] font-bold text-[#009DFF] uppercase tracking-wider\">Simulated User Details</span>\n                <div className=\"grid grid-cols-2 gap-4 text-white/70\">\n                  <div>\n                    <span className=\"text-white/35 block text-[8.5px]\">PROFILE NAME:</span>\n                    <span className=\"font-bold text-white\">{currentMockUser.name}</span>\n                  </div>\n                  <div>\n                    <span className=\"text-white/35 block text-[8.5px]\">SIMULATED CLEARANCE:</span>\n                    <span className=\"font-bold text-[#009DFF]\">{currentMockUser.clearance}</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {scanning ? (\n            <div className=\"space-y-4\">\n              <div className=\"relative h-20 bg-black/50 border border-white/5 rounded-xl flex items-center justify-center overflow-hidden\">\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:8px_8px]\" />\n                <div className=\"absolute left-0 right-0 h-[1px] bg-[#009DFF]/60 animate-pulse\" style={{ top: \"50%\" }} />\n                <div className=\"w-10 h-10 rounded-full border border-dashed border-[#009DFF]/30 animate-spin\" />\n              </div>\n\n              <div className=\"space-y-1 p-4 bg-black/30 border border-white/5 rounded-xl font-mono text-[9px] min-h-[85px]\">\n                {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                  <div key={idx} className=\"flex items-center gap-2 text-white/80\">\n                    {idx < scanStep ? (\n                      <CheckCircle className=\"w-3 h-3 text-emerald-400 shrink-0\" />\n                    ) : (\n                      <RefreshCw className=\"w-3 h-3 text-[#009DFF] animate-spin shrink-0\" />\n                    )}\n                    <span className={idx < scanStep ? \"text-white/30 line-through\" : \"text-white\"}>{msg}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-3\">\n              <button\n                onClick={handleAuthenticate}\n                className=\"w-full h-11 rounded-lg bg-white hover:bg-white/90 text-black font-semibold text-[11px] uppercase tracking-wider font-mono transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n              >\n                <Key className=\"w-3.5 h-3.5\" />\n                <span>Authenticate Simulated Session</span>\n              </button>\n\n              <div className=\"p-3 bg-blue-950/10 border border-blue-500/10 text-blue-400 rounded-xl flex gap-3 text-[10px] font-mono leading-relaxed\">\n                <Shield className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                <div>\n                  <strong className=\"text-white\">FRONTEND PREVIEW MODE:</strong> This is a browser-only simulation workspace. Simulated identity structures reside in localStorage and prevent server interactions. Real production OAuth, JWT tokens, and LDAP directory mappings will connect during the backend integration phase.\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
