{"ts":"2026-06-27T01:51:57.792Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"a7cycydp","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/PreviewRouteGuard.tsx","new_text":"\"use client\";\n\nimport React, { useEffect, useState } from \"react\";\nimport { usePathname, useRouter } from \"next/navigation\";\nimport { ShieldAlert, Lock, ArrowLeft, RefreshCw, Key } from \"lucide-react\";\nimport { \n  getPreviewSession, \n  canAccessPortalSection, \n  canAccessAdminSection, \n  PreviewSession,\n  MOCK_PREVIEW_USERS,\n  setPreviewSession\n} from \"@/lib/preview-auth\";\n\ninterface PreviewRouteGuardProps {\n  children: React.ReactNode;\n  type: \"portal\" | \"admin\";\n}\n\nexport function PreviewRouteGuard({ children, type }: PreviewRouteGuardProps) {\n  const router = useRouter();\n  const pathname = usePathname();\n  const [session, setSession] = useState<PreviewSession | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [hasAccess, setHasAccess] = useState(false);\n  const [activeSection, setActiveSection] = useState(\"\");\n\n  // Re-verify permission whenever session or pathname changes\n  const verifyAccess = () => {\n    const currentSession = getPreviewSession();\n    setSession(currentSession);\n\n    if (!currentSession) {\n      setHasAccess(false);\n      setLoading(false);\n      // Wait a moment before redirecting to show premium handshake check\n      setTimeout(() => {\n        router.push(\"/login\");\n      }, 800);\n      return;\n    }\n\n    // Parse active tab/section from pathname\n    const segments = pathname.split(\"/\");\n    let section = \"dashboard\";\n    if (segments.length >= 3) {\n      section = segments[2];\n    }\n    setActiveSection(section);\n\n    let allowed = false;\n    if (type === \"portal\") {\n      allowed = canAccessPortalSection(currentSession.role, section);\n    } else {\n      allowed = canAccessAdminSection(currentSession.role, section);\n    }\n\n    setHasAccess(allowed);\n    setLoading(false);\n  };\n\n  useEffect(() => {\n    verifyAccess();\n\n    // Listen to simulated session changes (e.g. from role-switcher)\n    const handleSessionChanged = () => {\n      verifyAccess();\n    };\n\n    window.addEventListener(\"gff_preview_session_changed\", handleSessionChanged);\n    return () => {\n      window.removeEventListener(\"gff_preview_session_changed\", handleSessionChanged);\n    };\n  }, [pathname, router]);\n\n  if (loading) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative font-mono select-none\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(rgba(0,157,255,0.015)_1px,transparent_1px)] bg-[size:24px_24px]\" />\n        <div className=\"z-10 space-y-4 text-center max-w-sm px-4\">\n          <div className=\"w-10 h-10 rounded-full border border-[#009DFF]/30 bg-[#009DFF]/5 flex items-center justify-center mx-auto text-[#009DFF] animate-spin\">\n            <RefreshCw className=\"w-4 h-4\" />\n          </div>\n          <p className=\"text-[10px] font-bold uppercase tracking-widest text-white/40\">\n            Verifying Simulated Clearance\n          </p>\n          <p className=\"text-[11px] text-white/60 leading-relaxed\">\n            Polling active sandbox enclaves and checking client compliance permissions...\n          </p>\n        </div>\n      </div>\n    );\n  }\n\n  if (!session) {\n    return (\n      <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative font-mono select-none\">\n        <div className=\"absolute inset-0 bg-[radial-gradient(rgba(228,0,15,_0.015)_1px,transparent_1px)] bg-[size:24px_24px]\" />\n        <div className=\"z-10 space-y-4 text-center max-w-md px-6 py-8 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-md\">\n          <div className=\"w-12 h-12 rounded-xl border border-red-500/20 bg-red-500/5 flex items-center justify-center mx-auto text-red-400\">\n            <Lock className=\"w-5 h-5\" />\n          </div>\n          <div>\n            <span className=\"text-[8px] font-mono font-bold tracking-widest text-red-500 bg-red-500/5 border border-red-500/15 px-2.5 py-0.5 rounded-full uppercase\">\n              AUTHENTICATION REQUIRED\n            </span>\n          </div>\n          <h2 className=\"text-sm font-bold uppercase text-white tracking-wide\">\n            Enclave Handshake Expired\n          </h2>\n          <p className=\"text-[11px] text-white/50 leading-relaxed\">\n            No simulated local preview session detected. Please authenticate through the Zero-Trust identity gateway.\n          </p>\n          <div className=\"pt-2\">\n            <button\n              onClick={() => router.push(\"/login\")}\n              className=\"w-full h-10 rounded-lg bg-white text-black font-semibold text-[11px] uppercase tracking-wider font-mono transition-all flex items-center justify-center gap-1.5 cursor-pointer hover:bg-white/90\"\n            >\n              <Key className=\"w-3.5 h-3.5\" />\n              <span>Go to Identity Gateway</span>\n            </button>\n          </div>\n          <div className=\"text-[8.5px] text-white/35 leading-relaxed bg-white/[0.02] border border-white/5 rounded-lg p-2.5\">\n            <strong>FRONTEND PREVIEW ONLY:</strong> No server-side auth exists. Real production environments will be connected with OAuth/Azure AD in subsequent stages.\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  if (!hasAccess) {\n    const formattedRole = session.role.replace(\"_\", \" \").toUpperCase();\n    const targetSystem = type === \"portal\" ? \"Sovereign Portal\" : \"Oversight Console\";\n\n    return (\n      <div className=\"min-h-[calc(100vh-2rem)] w-full flex items-center justify-center font-mono select-none px-4 md:px-6\">\n        <div className=\"max-w-2xl w-full p-6 md:p-8 rounded-[20px] border border-[#E4000F]/15 bg-[#050505]/60 backdrop-blur-md relative overflow-hidden space-y-6\">\n          <div className=\"absolute top-0 left-0 w-full h-1 bg-[#E4000F]/40\" />\n          <div className=\"absolute top-0 right-0 w-48 h-48 rounded-full bg-[#E4000F]/5 blur-[60px]\" />\n\n          <div className=\"flex flex-col md:flex-row md:items-center gap-5\">\n            <div className=\"w-14 h-14 shrink-0 rounded-xl border border-[#E4000F]/30 bg-[#E4000F]/5 flex items-center justify-center text-[#E4000F] shadow-[0_0_20px_rgba(228,0,15,0.08)]\">\n              <ShieldAlert className=\"w-6 h-6 animate-pulse\" />\n            </div>\n            <div>\n              <div className=\"inline-flex items-center gap-1.5 rounded-full bg-[#E4000F]/10 border border-[#E4000F]/20 px-2 py-0.5 text-[8px] font-bold uppercase tracking-wider text-[#E4000F] mb-1.5\">\n                RESTRICTED COMPLIANCE BOUNDARY\n              </div>\n              <h2 className=\"text-base md:text-lg font-bold text-white uppercase tracking-tight\">\n                Simulated Clearances Insufficient\n              </h2>\n            </div>\n          </div>\n\n          <div className=\"space-y-3.5 border-t border-b border-white/5 py-4 text-[12px] leading-relaxed text-white/70\">\n            <p>\n              Your simulated sandbox role <span className=\"text-[#E4000F] font-bold\">{formattedRole}</span> does not possess operational clearance to access the <span className=\"text-white font-semibold\">/{type}/{activeSection}</span> segment.\n            </p>\n            <p className=\"text-[11px] text-white/45\">\n              This sandbox isolation mimics the real multi-tenant role-based access control (RBAC) boundaries built into the GFF AI sovereign framework. Under this model, clients and external vendors are sealed within their respective sandboxes, while GFF system operators possess modular oversight.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n            <div className=\"p-3 bg-white/[0.02] border border-white/5 rounded-xl space-y-1.5\">\n              <span className=\"text-[9px] text-white/40 block font-bold\">CURRENT SIMULATED SESSION</span>\n              <div className=\"text-white font-bold text-[11px]\">{session.name}</div>\n              <div className=\"text-white/45 text-[10px] truncate\">{session.email}</div>\n              <div className=\"text-[10px] font-bold text-white/30\">{session.clearance}</div>\n            </div>\n\n            <div className=\"p-3 bg-white/[0.02] border border-white/5 rounded-xl space-y-1.5\">\n              <span className=\"text-[9px] text-white/40 block font-bold\">HOW TO BYPASS IN PREVIEW</span>\n              <p className=\"text-[10px] text-white/50 leading-normal\">\n                Use the <span className=\"text-[#009DFF] font-semibold\">Role Switcher</span> in the top-right header to switch to a role that has permission:\n              </p>\n              <ul className=\"text-[9.5px] text-white/45 list-disc pl-4 space-y-0.5\">\n                <li><strong className=\"text-white\">client_admin</strong> for all portal pages</li>\n                <li><strong className=\"text-white\">gff_admin</strong> for global admin override</li>\n              </ul>\n            </div>\n          </div>\n\n          <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n            <button\n              onClick={() => {\n                if (type === \"portal\") {\n                  router.push(\"/portal/dashboard\");\n                } else {\n                  router.push(\"/admin/dashboard\");\n                }\n              }}\n              className=\"flex-1 h-10 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.02] text-white text-[11px] font-bold uppercase transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n            >\n              <ArrowLeft className=\"w-3.5 h-3.5\" />\n              <span>Return to {targetSystem} Dashboard</span>\n            </button>\n          </div>\n\n          <div className=\"text-center text-[9px] text-white/30\">\n            <strong>FRONTEND PREVIEW ONLY:</strong> Real identity boundaries will connect via server-side identity models in the backend stage.\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  return <>{children}</>;\n}\n"}}}
