ace member\" },\n    { id: \"gff_admin\", label: \"GFF Admin\", clearance: \"Level V\", icon: Shield, color: \"text-red-400 border-red-500/20 bg-red-950/10\", desc: \"System Superuser Override\" },\n    { id: \"gff_operator\", label: \"GFF Operator\", clearance: \"Level IV\", icon: Cpu, color: \"text-purple-400 border-purple-500/20 bg-purple-950/10\", desc: \"Technical systems operator\" },\n    { id: \"finance_admin\", label: \"Finance Admin\", clearance: \"Level III\", icon: FileText, color: \"text-emerald-400 border-emerald-500/20 bg-emerald-950/10\", desc: \"Ledgers & billing controller\" },\n    { id: \"support_agent\", label: \"Support Agent\", clearance: \"Level III\", icon: HelpCircle, color: \"text-orange-400 border-orange-500/20 bg-orange-950/10\", desc: \"Priority support wire helper\" },\n    { id: \"viewer\", label: \"Auditor (Viewer)\", clearance: \"Level I\", icon: Eye, color: \"text-gray-400 border-gray-500/20 bg-gray-950/10\", desc: \"Read-only compliance auditor\" },\n  ];\n\n  const scanMessages = [\n    \"Establishing local localstorage sandbox...\",\n    \"Registering cryptographic credentials in browser...\",\n    \"Generating zero-trust simulation key (SHA-256)...\",\n    \"Pre-compiling simulated clearance privileges...\"\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => {\n      setScanStep(prev => (prev < 3 ? prev + 1 : prev));\n    }, 250);\n\n    await new Promise(r => setTimeout(r, 1100));\n    clearInterval(interval);\n    setScanning(false);\n    \n    setPreviewSession(selectedRole);\n    \n    if (selectedRole === \"client_admin\" || selectedRole === \"client_member\") {\n      router.push(\"/portal/dashboard\");\n    } else {\n      router.push(\"/admin/dashboard\");\n    }\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center 