lick={handleAuthenticate} className=\"w-full h-10 rounded-lg bg-white text-black font-bold text-[10px] uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer hover:bg-white/90\">\n                <Key className=\"w-3.5 h-3.5\" /> Authenticate Simulated Session\n              </button>\n\n              <div className=\"p-2.5 bg-blue-950/10 border border-blue-500/10 text-blue-400 rounded-lg text-[8.5px] leading-relaxed\">\n                <strong>FRONTEND PREVIEW MODE:</strong> Local simulator only. States are saved in localStorage. Production OAuth/AD connects in backend implementation.\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-3 py-2 text-center text-[10px]\">\n              <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto\" />\n              <p className=\"text-white/40\">Isolating local browser enclaves and key hooks...</p>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
