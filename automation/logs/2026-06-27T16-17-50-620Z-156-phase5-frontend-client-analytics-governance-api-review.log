n interlock points, and certified document audit records.\n332 |           </p>\n333 |         </div>\n334 |         <div className=\"flex items-center gap-3 font-mono\">\n335 |           <button\n336 |             onClick={() => fetchGovernanceAndDocs(true)}\n337 |             className=\"flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-[10px] text-white cursor-pointer transition-colors\"\n338 |           >\n339 |             <RefreshCw className=\"w-3 h-3 text-[#009DFF]\" />\n340 |             <span>Sync Registry</span>\n341 |           </button>\n342 |           <div className=\"text-[10px] text-white/45 bg-white/[0.01] border border-white/5 px-2.5 py-1.5 rounded-lg\">\n343 |             Enclave Epoch: <span className=\"text-white font-bold font-mono\">2026.E3</span>\n344 |           </div>\n345 |         </div>\n346 |       </div>\n347 | \n348 |       {/* Bento Grid: Metrics and Interceptor Diagram */}\n349 |       <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n350 |         \n351 |         {/* Metric Cards */}\n352 |         <div className=\"flex flex-col gap-4\">\n353 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px] border-[#00FFC2]/10\">\n354 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n355 |               <span className=\"text-white/45 uppercase tracking-wider\">Dynamic Trust Index</span>\n356 |               <StatusBadge state=\"active\" label=\"continuous check\" />\n357 |             </div>\n358 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n359 |               <div className=\"text-3xl font-bold text-white font-mono\">{trustScore}%</div>\n360 |               <span className=\"text-[9.5px] text-emerald-400 flex items-center gap-1\">\n361 |                 Optimized <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n362 |               </span>\n363 |             </div>\n364 |           </WorkspaceCard>\n365 | \n366 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px]\">\n367 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n368 |               <span className=\"text-white/45 uppercase tracking-wider\">AI Guardrails & Policies</span>\n369 |               <span className=\"text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20\">ACTIVE</span>\n370 |             </div>\n371 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n372 |               <div className=\"text-3xl font-bold text-white\">{policies.length}</div>\n373 |               <span className=\"text-[9.5px] text-white/40\">\n374 |                 {policies.filter(p => p.status === \"compliant\").length} Safe • {policies.filter(p => p.status !== \"compliant\").length} Alerts\n375 |               </span>\n376 |             </div>\n377 |           </WorkspaceCard>\n378 | \n379 |           <WorkspaceCard className={`flex flex-col justify-between h-[105px] transition-all ${pendingCount > 0 ? \"border-amber-500/20 bg-amber-500/[0.01]\" : \"\"}`}>\n380 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n381 |               <span className=\"text-white/45 uppercase tracking-wider\">Pending Interlocks</span>\n382 |               {pendingCount > 0 ? (\n383 |                 <span className=\"text-amber-400 bg-amber-400/10 px-1.5 py-0.5 rounded border border-amber-400/20 animate-pulse\">SIGN REQUIRED</span>\n384 |               ) : (\n385 |                 <span className=\"text-white/30\">ALL SIGNED</span>\n386 |               )}\n387 |             </div>\n388 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n389 |               <div className=\"text-3xl font-bold text-white\">{pendingCount}</div>\n390 |               <span className=\"text-[9.5px] text-white/40\">Awaiting client credentials</span>\n391 |             </div>\n392 |           </WorkspaceCard>\n393 |         </div>\n394 | \n395 |         {/* Dynamic Topology Flow Diagram */}\n396 |         <div className=\"lg:col-span-2\">\n397 |           <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n398 |             <style dangerouslySetInnerHTML={{ __html: `\n399 |               @keyframes flow { to { stroke-dashoffset: -20; } }\n400 |               .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n401 |             `}} />\n402 | \n403 |             <div className=\"flex-grow flex flex-col justify-between gap-4\">\n404 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n405 |                 <div className=\"flex items-center gap-1.5 font-mono text-[11px]\">\n406 |                   <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n407 |                   <span className=\"font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n408 |                 </div>\n409 |                 <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology</span>\n410 |               </div>\n411 | \n412 |               <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n413 |                 <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n414 |                   <svg className=\"w-full h-[2px] overflow-visible\">\n415 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n416 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n417 |                   </svg>\n418 |                 </div>\n419 | \n420 |                 {steps.map((st, idx) => {\n421 |                   const isActive = step === st.id;\n422 |                   const clr = \n423 |                     st.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n424 |                     st.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n425 |                     st.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n426 |                     st.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" : \"border-emerald-500/10 text-emerald-400\";\n427 |                   \n428 |                   const activeStyle = isActive \n429 |                     ? \"shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102\" \n430 |                     : \"bg-black/45 hover:border-white/10\";\n431 | \n432 |                   return (\n433 |                     <button \n434 |                       key={st.id} \n435 |                       onClick={() => setStep(st.id)}\n436 |                       className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${clr} ${activeStyle}`}\n437 |                     >\n438 |                       <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"}`}>\n439 |                         {st.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n440 |                         {st.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n441 |                         {st.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n442 |                         {st.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n443 |                         {st.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n444 |                       </div>\n445 |                       <div className=\"text-center font-mono select-none\">\n446 |                         <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n447 |                         <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">{st.id === \"step-1\" ? \"Ingress\" : st.id === \"step-2\" ? \"Guardrail\" : st.id === \"step-3\" ? \"Enclave\" : st.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}</span>\n448 |                       </div>\n449 |                     </button>\n450 |                   );\n451 |                 })}\n452 |               </div>\n453 |             </div>\n454 | \n455 |             {/* Node Telemetry Details card */}\n456 |             <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n457 |               {(() => {\n458 |                 const info = steps.find(s => s.id === step) || steps[0];\n459 |                 return (\n460 |                   <div className=\"space-y-3 h-full flex flex-col justify-between\">\n461 |                     <div className=\"space-y-1.5\">\n462 |                       <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">REALTIME METRICS</span>\n463 |                       <p className=\"text-white font-bold text-[11px] leading-tight\">{info.title}</p>\n464 |                       \n465 |                       <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n466 |                         <span className={`w-1 h-1 rounded-full ${step === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n467 |                         <span className=\"text-white/40\">Status:</span>\n468 |                         <span className={`font-bold ${step === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>{info.val}</span>\n469 |                       </div>\n470 |                       <p className=\"text-[10px] text-white/50 leading-normal pt-1\">{info.desc}</p>\n471 |                     </div>\n472 |                     \n473 |                     <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 select-none\">\n474 |                       <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n475 |                       <span>Mathematical boundary verified</span>\n476 |                     </div>\n477 |                   </div>\n478 |                 );\n479 |               })()}\n480 |             </div>\n481 | \n482 |           </div>\n483 |         </div>\n484 | \n485 |       </div>\n486 | \n487 |       {/* Dynamic Filters panel */}\n488 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#070707]/60 backdrop-blur-sm space-y-3 font-mono\">\n489 |         <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n490 |           <div className=\"flex items-center gap-1.5\">\n491 |             <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/50\" />\n492 |             <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Workspace Filters</h3>\n493 |           </div>\n494 |           {(selProj || selAgent || selStatus || selSeverity || search) && (\n495 |             <button onClick={resetAll} className=\"flex items-center gap-1 text-[10px] text-amber-500 hover:text-amber-400 cursor-pointer\">\n496 |               <RotateCcw className=\"w-3 h-3\" /> Reset Filters\n497 |             </button>\n498 |           )}\n499 |         </div>\n500 | \n501 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n502 |           \n503 |           <div>\n504 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Project Target</label>\n505 |             <select \n506 |               value={selProj} \n507 |               onChange={(e) => { setSelProj(e.target.value); triggerToast(\"Filter: Project target updated\", \"info\"); }}\n508 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n509 |             >\n510 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL PROJECTS</option>\n511 |               {projectOptions.map(p => <option key={p.id} value={p.id} className=\"bg-[#0c0c0c] text-white\">{p.name.toUpperCase()}</option>)}\n512 |             </select>\n513 |           </div>\n514 | \n515 |           <div>\n516 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Sovereign Agent</label>\n517 |             <select \n518 |               value={selAgent} \n519 |               onChange={(e) => { setSelAgent(e.target.value); triggerToast(\"Filter: Agent target updated\", \"info\"); }}\n520 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n521 |             >\n522 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL AGENTS</option>\n523 |               {agentOptions.map(a => <option key={a.id} value={a.id} className=\"bg-[#0c0c0c] text-white\">{a.name}</option>)}\n524 |             </select>\n525 |           </div>\n526 | \n527 |           <div>\n528 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Compliance State</label>\n529 |             <select \n530 |               value={selStatus} \n531 |               onChange={(e) => { setSelStatus(e.target.value); triggerToast(\"Filter: State updated\", \"info\"); }}\n532 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n533 |             >\n534 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL STATES</option>\n535 |               <option value=\"compliant\" className=\"bg-[#0c0c0c] text-green-400\">COMPLIANT</option>\n536 |               <option value=\"warning\" className=\"bg-[#0c0c0c] text-amber-400\">WARNING ALERT</option>\n537 |               <option value=\"critical\" className=\"bg-[#0c0c0c] text-red-400\">CRITICAL FAULT</option>\n538 |             </select>\n539 |           </div>\n540 | \n541 |           <div>\n542 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Risk Severity</label>\n543 |             <select \n544 |               value={selSeverity} \n545 |               onChange={(e) => { setSelSeverity(e.target.value); triggerToast(\"Filter: Severity updated\", \"info\"); }}\n546 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n547 |             >\n548 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL SEVERITIES</option>\n549 |               <option value=\"high\" className=\"bg-[#0c0c0c] text-red-400 font-bold\">HIGH RISK</option>\n550 |               <option value=\"medium\" className=\"bg-[#0c0c0c] text-amber-400\">MEDIUM RISK</option>\n551 |               <option value=\"low\" className=\"bg-[#0c0c0c] text-blue-400\">LOW RISK</option>\n552 |             </select>\n553 |           </div>\n554 | \n555 |           <div>\n556 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Log Search</label>\n557 |             <div className=\"relative\">\n558 |               <Search className=\"absolute left-2 top-2.5 w-3.5 h-3.5 text-white/35 font-mono\" />\n559 |               <input \n560 |                 type=\"text\" \n561 |                 value={search} \n562 |                 onChange={(e) => setSearch(e.target.value)}\n563 |                 placeholder=\"Search rule standard or ID...\"\n564 |                 className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] pl-7.5 pr-7 text-[10.5px] text-white outline-none focus:border-white/10\"\n565 |               />\n566 |               {search && <X className=\"absolute right-2 top-2.5 w-3.5 h-3.5 text-white/40 cursor-pointer font-mono\" onClick={() => setSearch(\"\")} />}\n567 |             </div>\n568 |           </div>\n569 | \n570 |         </div>\n571 |       </div>\n572 | \n573 |       {/* Tabs list */}\n574 |       <div className=\"space-y-4 font-mono\">\n575 |         <div className=\"flex border-b border-white/5 gap-6 select-none text-xs\">\n576 |           <button onClick={() => setTab(\"pols\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"pols\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n577 |             <span>AI Checks & Policies</span>\n578 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredPols.length}</span>\n579 |             {tab === \"pols\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n580 |           </button>\n581 |           \n582 |           <button onClick={() => setTab(\"oversight\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"oversight\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n583 |             <span>Human Oversight Interlocks</span>\n584 |             <span className={`px-1 rounded text-[9px] ${pendingCount > 0 ? \"bg-amber-400/10 text-amber-500\" : \"bg-white/5 text-white/50\"}`}>{filteredOversights.length}</span>\n585 |             {tab === \"oversight\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n586 |           </button>\n587 | \n588 |           <button onClick={() => setTab(\"docs\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"docs\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n589 |             <span>Document Ledger</span>\n590 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredDocs.length}</span>\n591 |             {tab === \"docs\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n592 |           </button>\n593 |         </div>\n594 | \n595 |         {/* Tab interiors */}\n596 |         <div className=\"space-y-3 font-mono\">\n597 |           \n598 |           {tab === \"pols\" && (\n599 |             <div className=\"space-y-3\">\n600 |               {filteredPols.length === 0 ? (\n601 |                 <div className=\"p-10 border border-dashed border-white/5 rounded-2xl text-center max-w-md mx-auto space-y-2\">\n602 |                   <ShieldAlert className=\"w-6 h-6 text-white/20 mx-auto\" />\n603 |                   <p className=\"text-white font-bold text-xs\">NO POLICIES MATCH FILTERS</p>\n604 |                   <p className=\"text-white/40 text-[10px]\">Try adjusting your active workspace filters.</p>\n605 |                 </div>\n606 |               ) : (\n607 |                 filteredPols.map(policy => {\n608 |                   const isExp = expId === policy.id;\n609 |                   return (\n610 |                     <div key={policy.id} className={`rounded-xl border transition-all ${isExp ? \"border-white/10 bg-white/[0.02]\" : \"border-white/5 bg-[#050505]/20\"}`}>\n611 |                       <div onClick={() => setExpId(isExp ? null : policy.id)} className=\"p-3.5 flex items-center justify-between gap-3 cursor-pointer text-xs select-none\">\n612 |                         <div className=\"flex items-center gap-2.5 min-w-0\">\n613 |                           {policy.status === \"compliant\" ? <CheckCircle className=\"w-4 h-4 text-[#00FFC2] shrink-0\" /> : policy.status === \"warning\" ? <AlertCircle className=\"w-4 h-4 text-amber-400 shrink-0\" /> : <ShieldAlert className=\"w-4 h-4 text-red-400 shrink-0\" />}\n614 |                           <div className=\"min-w-0\">\n615 |                             <div className=\"flex items-center gap-1.5 flex-wrap\">\n616 |                               <span className=\"text-[10px] text-white/40 font-bold shrink-0\">{policy.id}</span>\n617 |                               <span className=\"text-white font-bold truncate\">{policy.name}</span>\n618 |                               <span className={`text-[8.5px] px-1 border rounded shrink-0 ${policy.severity === \"high\" ? \"text-red-400 border-red-500/10 bg-red-500/5\" : \"text-amber-400 border-amber-500/10 bg-amber-500/5\"}`}>{policy.severity.toUpperCase()}</span>\n619 |                             </div>\n620 |                             <div className=\"flex items-center gap-2 mt-0.5 text-[9.5px] text-white/45 flex-wrap\">\n621 |                               <span>Std: <strong className=\"text-white/70\">{policy.standard}</strong></span>\n622 |                               <span>•</span>\n623 |                               <span>Project: <strong className=\"text-white/70\">{policy.projectName}</strong></span>\n624 |                             </div>\n625 |                           </div>\n626 |                         </div>\n627 |                         <div className=\"flex items-center gap-3 shrink-0\">\n628 |                           <span className={`text-[9px] font-bold uppercase ${policy.status === \"compliant\" ? \"text-[#00FFC2]\" : \"text-amber-400\"}`}>{policy.status.toUpperCase()}</span>\n629 |                           {isExp ? <ChevronDown className=\"w-4 h-4 text-white/40\" /> : <ChevronRight className=\"w-4 h-4 text-white/40\" />}\n630 |                         </div>\n631 |                       </div>\n632 | \n633 |                       {isExp && (\n634 |                         <div className=\"px-3.5 pb-4.5 border-t border-white/5 pt-3.5 text-xs text-white/80 space-y-3 select-text\">\n635 |                           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n636 |                             <div className=\"md:col-span-2 p-3 rounded-lg border border-white/5 bg-[#020202]/60\">\n637 |                               <span className=\"text-[8.5px] text-[#009DFF] font-bold uppercase block mb-1\">Enforcement Boundary Spec</span>\n638 |                               <p className=\"text-[11px] leading-relaxed text-white/70\">{policy.desc}</p>\n639 |                             </div>\n640 |                             <div className=\"p-3 rounded-lg border border-white/5 bg-[#020202]/60 flex flex-col justify-between\">\n641 |                               <div className=\"text-[10px] space-y-0.5 text-white/60 mb-2\">\n642 |                                 <div className=\"flex justify-between\"><span>Audit Scope:</span> <span className=\"text-white\">{policy.agentName}</span></div>\n643 |                                 <div className=\"flex justify-between\"><span>Last Checked:</span> <span className=\"text-white\">{policy.lastChecked}</span></div>\n644 |                               </div>\n645 |                               <button \n646 |                                 onClick={() => handleVerify(policy.id)} \n647 |                                 disabled={verId !== null}\n648 |                                 className=\"w-full h-7.5 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 flex items-center justify-center gap-1 cursor-pointer disabled:opacity-40\"\n649 |                               >\n650 |                                 {verId === policy.id ? <RefreshCw className=\"w-3 h-3 animate-spin text-[#00FFC2]\" /> : <ShieldCheck className=\"w-3.5 h-3.5 text-[#00FFC2]\" />}\n651 |                                 {verId === policy.id ? \"Checking...\" : \"Recheck Boundary\"}\n652 |                               </button>\n653 |                             </div>\n654 |                           </div>\n655 | \n656 |         