.getItem(\\\"gff_ai_access_token\\\") : null;\n      if (!token) {\n        setLoading(false);\n        setIsRef(false);\n        return;\n      }\n      const res = await fetch(\\\"/api/v1/analytics/client\\\", { headers: { \\\"Authorization\\\": `Bearer ${token}` } });\n      const json = await res.json();\n      if (json.success) setData(json);\n    } catch (err) {\n      console.error(\\\"Error fetching analytics:\\\", err);\n    } finally {\n      setLoading(false);\n      setIsRef(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchAnalytics();\n    const handleSess = () => fetchAnalytics();\n    window.addEventListener(\\\"gff_preview_session_changed\\\", handleSess);\n    return () => window.removeEventListener(\\\"gff_preview_session_changed\\\", handleSess);\n  }, [fetchAnalytics]);\n\n  useEffect(() => {\n    const inv = setInterval(() => {\n      setPts(p => {\n        const last = p[p.length - 1];\n        const drift = Math.floor(Math.random() * 12) - 6;\n        const corrective = Math.round((selectedNode.baseCpu - last) * 0.15);\n        const nextVal = Math.min(100, Math.max(10, last + drift + corrective));\n        return [...p.slice(1), nextVal];\n      });\n\n      const actions = [\n        \\\"eBPF packet verified through proxy boundary\\\",\n        \\\"HSM cryptographic seal checked\\\",\n        \\\"Enclave heap alignment optimized\\\",\n        \\\"Zero-knowledge verification loop complete\\\"\n      ];\n      const selectedAction = actions[Math.floor(Math.random() * actions.length)];\n      const ts = new Date().toLocaleTimeString([], { hour12: false });\n      setLogs(prev => [...prev.slice(-2), `[${ts}] [SYS] ${selectedAction} - node ${selectedNode.id}`]);\n    }, 2000);\n    return () => clearInterval(inv);\n  }, [selectedNode]);\n\n  if (loading) {\n    return (\n      <div className=\\\"p-8 font-mono text-white flex flex-col items-center justify-center min-h-[300px] space-y-4\\\">\n        <RefreshCw className=\\\"w-5 h-5 animate-spin text-[#009DFF]\\\" />\n        <div className=\\\"text-[10px] uppercase tracking-widest text-white/40 animate-pulse\\\">Establishing Telemetry Link...</div>\n      </div>\n    );\n  }\n\n  const s = data?.summary || {\n    projects: { totalCount: 2, byPhase: { \\\"Phase V: Production-Live\\\": 1, \\\"Phase I: Planning\\\": 1 } },\n    aiOperations: { totalCount: 3, byHealth: { healthy: 3 } },\n    governance: { totalCount: 4, byStatus: { compliant: 3, active: 1 } },\n    invoices: { totalCount: 2, byStatus: { paid: 2 } }\n  };\n\n  return (\n    <div className=\\\"space-y-6 font-mono text-white\\\">\n      <div className=\\\"flex justify-between items-center border-b border-white/5 pb-4\\\">\n        <div>\n          <h2 className=\\\"text-sm font-bold uppercase tracking-wider flex items-center gap-2\\\">\n            <Radio className=\\\"w-3.5 h-3.5 text-[#009DFF] animate-pulse\\\" />\n            Telemetry Analytics\n          </h2>\n          <p className=\\\"text-[10px] text-white/50 mt-1\\\">Real-time workloads, secure eBPF network tunnels, and active workspace governance.</p>\n        </div>\n        <button onClick={() => { setIsRef(true); fetchAnalytics(true); }} className=\\\"flex items-center gap-1.5 px-2.5 py-1 rounded border border-white/10 bg-white/5 hover:bg-white/10 text-[10px] transition-colors cursor-pointer select-none\\\">\n          <RefreshCw className={`w-3 h-3 ${isRef ? \\\"animate-spin text-[#009DFF]\\\" : \\\"\\\"}`} />\n          <span>Sync</span>\n        </button>\n      </div>\n\n      <div className=\\\"grid grid-cols-2 lg:grid-cols-4 gap-4\\\">\n        {[\n          { label: \\\"Sovereign Enclaves\\\", val: s.projects?.totalCount, badge: \\\"ACTIVE\\\", detail: Object.entries(s.projects?.byPhase || {}).map(([p, c]) => `${p.split(\\\":\\\")[0]}: ${c}`).join(\\\" • \\\"), icon: Server, color: \\\"text-[#009DFF]\\\" },\n          { label: \\\"Running AI Ops\\\", val: s.aiOperations?.totalCount, badge: \\\"STREAMING\\\", detail: `${s.aiOperations?.byHealth?.healthy || s.aiOperations?.totalCount} Healthy`, icon: Activity, color: \\\"text-emerald-400\\\" },\n          { label: \\\"Governance Health\\\", val: s.governance?.totalCount, badge: \\\"SECURE\\\", detail: `Compliant: ${s.governance?.byStatus?.compliant || s.governance?.byStatus?.active || s.governance?.byStatus?.resolved || 0}`, icon: Shield, color: \\\"text-[#00FFC2]\\\" },\n          { label: \\\"Financials & Audit\\\", val: s.invoices?.totalCount, badge: \\\"VERIFIED\\\", detail: `Paid: ${s.invoices?.byStatus?.paid || 0}`, icon: FileText, color: \\\"text-purple-400\\\" }\n        ].map((item, idx) => (\n          <div key={idx} className=\\\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex flex-col justify-between hover:border-white/10 transition-all group\\\">\n            <div className=\\\"flex justify-between items-center text-[8.5px] text-white/40 uppercase tracking-wider\\\">\n              <span>{item.label}</span>\n              <item.icon className={`w-3.5 h-3.5 ${item.color} group-hover:scale-110 transition-transform`} />\n            </div>\n            <div className=\\\"mt-2 flex items-baseline gap-1.5\\\">\n              <span className=\\\"text-xl font-bold tracking-tight\\\">{item.val || 0}</span>\n              <span className=\\\"text-[8px] text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.2 rounded font-bold\\\">{item.badge}</span>\n            </div>\n            <div className=\\\"mt-2 text-[8.5px] text-white/45 truncate select-all\\\">{item.detail}</div>\n          </div>\n        ))}\n      </div>\n\n      <div className=\\\"grid grid-cols-1 lg:grid-cols-3 gap-6\\\">\n        <div className=\\\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 space-y-4 relative overflow-hidden\\\">\n          <div className=\\\"absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.01)_1px,trans