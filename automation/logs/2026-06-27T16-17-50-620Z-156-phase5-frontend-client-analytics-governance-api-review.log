{"ts":"2026-06-27T16:15:20.554Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"cpaoe0yj","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","old_text":"\"use client\";\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { RefreshCw, Cpu, Activity, Shield, FileText, Server } from \"lucide-react\";\n\nexport default function ClientAnalyticsPage() {\n  const [loading, setLoading] = useState(true);\n  const [data, setData] = useState<any>(null);\n  const [pts, setPts] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n  const [isRef, setIsRef] = useState(false);\n\n  const fetchAnalytics = useCallback(async (silent = false) => {\n    if (!silent) setLoading(true);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) return;\n      const res = await fetch(\"/api/v1/analytics/client\", { headers: { \"Authorization\": `Bearer ${token}` } });\n      const json = await res.json();\n      if (json.success) setData(json);\n    } catch (err) {} finally { setLoading(false); setIsRef(false); }\n  }, []);\n\n  useEffect(() => { fetchAnalytics(); }, [fetchAnalytics]);\n  useEffect(() => {\n    const inv = setInterval(() => {\n      setPts(p => [...p.slice(1), Math.min(100, Math.max(20, p[p.length-1] + Math.floor(Math.random()*14)-7))]);\n    }, 1500);\n    return () => clearInterval(inv);\n  }, []);\n\n  if (loading) return <div className=\"p-6 font-mono text-white animate-pulse\">Loading telemetry data...</div>;\n  const s = data?.summary || { projects: { totalCount: 0 }, aiOperations: { totalCount: 0 }, governance: { totalCount: 0 }, invoices: { totalCount: 0 } };","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { RefreshCw, Cpu, Activity, Shield, FileText, Server, Radio, Network } from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface Node {\n  id: string;\n  name: string;\n  region: string;\n  ip: string;\n  basePing: number;\n  baseCpu: number;\n}\n\nconst ENCLAVE_NODES: Node[] = [\n  { id: \"APEX-SEC-G4\", name: \"Sovereign London Lattice\", region: \"London Zone C\", ip: \"10.244.12.80\", basePing: 3, baseCpu: 38 },\n  { id: \"MED-CLINIC-H9\", name: \"Apex Singapore Sandbox\", region: \"Singapore Zone A\", ip: \"10.244.14.99\", basePing: 4, baseCpu: 52 },\n  { id: \"RETAIL-CORE-A1\", name: \"Global Retail Mesh Node\", region: \"Local Enclave Mesh\", ip: \"127.0.0.1\", basePing: 5, baseCpu: 45 },\n];\n\nexport default function ClientAnalyticsPage() {\n  const [loading, setLoading] = useState(true);\n  const [data, setData] = useState<any>(null);\n  const [isRef, setIsRef] = useState(false);\n  const [selectedNode, setSelectedNode] = useState<Node>(ENCLAVE_NODES[0]);\n  const [pts, setPts] = useState<number[]>([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n  const [hoveredPt, setHoveredPt] = useState<{ val: number; idx: number } | null>(null);\n\n  const [logs, setLogs] = useState<string[]>([\n    \"[00:01:22] [SYS] Telemetry pipeline established via encrypted gRPC loop.\",\n    \"[00:01:23] [SEC] eBPF socket listeners active. Monitoring kernel rings.\",\n    \"[00:01:24] [NET] Wireguard tunnel secured. Local enclaves pinging healthy.\"\n  ]);\n  \n  const fetchAnalytics = useCallback(async (silent = false) => {\n    if (!silent) setLoading(true);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        setLoading(false);\n        setIsRef(false);\n        return;\n      }\n      const res = await fetch(\"/api/v1/analytics/client\", { headers: { \"Authorization\": `Bearer ${token}` } });\n      const json = await res.json();\n      if (json.success) setData(json);\n    } catch (err) {\n      console.error(\"Error fetching analytics:\", err);\n    } finally {\n      setLoading(false);\n      setIsRef(false);\n    }\n  }, []);\n\n  useEffect(() => {\n    fetchAnalytics();\n    const handleSess = () => fetchAnalytics();\n    window.addEventListener(\"gff_preview_session_changed\", handleSess);\n    return () => window.removeEventListener(\"gff_preview_session_changed\", handleSess);\n  }, [fetchAnalytics]);\n\n  useEffect(() => {\n    const inv = setInterval(() => {\n      setPts(p => {\n        const last = p[p.length - 1];\n        const drift = Math.floor(Math.random() * 12) - 6;\n        const corrective = Math.round((selectedNode.baseCpu - last) * 0.15);\n        const nextVal = Math.min(100, Math.max(10, last + drift + corrective));\n        return [...p.slice(1), nextVal];\n      });\n\n      const actions = [\n        \"eBPF packet verified through proxy boundary\",\n        \"HSM cryptographic seal checked\",\n        \"Enclave heap alignment optimized\",\n        \"Zero-knowledge verification loop complete\",\n        \"Sovereign node health handshake successful\"\n      ];\n      const selectedAction = actions[Math.floor(Math.random() * actions.length)];\n      const ts = new Date().toLocaleTimeString([], { hour12: false });\n      setLogs(prev => [...prev.slice(-2), `[${ts}] [SYS] ${selectedAction} - node ${selectedNode.id}`]);\n    }, 2000);\n    return () => clearInterval(inv);\n  }, [selectedNode]);\n\n  if (loading) {\n    return (\n      <div className=\"p-8 font-mono text-white flex flex-col items-center justify-center min-h-[300px] space-y-4\">\n        <RefreshCw className=\"w-5 h-5 animate-spin text-[#009DFF]\" />\n        <div className=\"text-[10px] uppercase tracking-widest text-white/40 animate-pulse\">Establishing Telemetry Link...</div>\n      </div>\n    );\n  }\n\n  const s = data?.summary || {\n    projects: { totalCount: 2, byPhase: { \"Phase V: Production-Live\": 1, \"Phase I: Planning\": 1 } },\n    aiOperations: { totalCount: 3, byHealth: { healthy: 3 } },\n    governance: { totalCount: 4, byStatus: { compliant: 3, active: 1 } },\n    invoices: { totalCount: 2, byStatus: { paid: 2 } }\n  };"}}}
