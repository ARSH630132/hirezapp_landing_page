s, setSelStatus] = useState(\"\");\n175 |   const [selSeverity, setSelSeverity] = useState(\"\");\n176 |   const [search, setSearch] = useState(\"\");\n177 | \n178 |   const [tab, setTab] = useState<\"pols\" | \"oversight\" | \"docs\">(\"pols\");\n179 |   const [expId, setExpId] = useState<string | null>(\"GOV-27001-A\");\n180 |   const [step, setStep] = useState(\"step-4\");\n181 |   const [toasts, setToasts] = useState<{ id: string; msg: string; type: \"success\" | \"info\" | \"warning\" }[]>([]);\n182 |   const [verId, setVerId] = useState<string | null>(null);\n183 |   const [expIdDoc, setExpIdDoc] = useState<string | null>(null);\n184 | \n185 |   const triggerToast = (msg: string, type: \"success\" | \"info\" | \"warning\" = \"success\") => {\n186 |     const id = generateToastId();\n187 |     setToasts(prev => [...prev, { id, msg, type }]);\n188 |     setTimeout(() => setToasts(prev => prev.filter(t => t.id !== id)), 3000);\n189 |   };\n190 | \n191 |   // Dynamic filter application across all categories\n192 |   const filteredPols = policies.filter(p => {\n193 |     if (selProj && p.projectId !== selProj) return false;\n194 |     if (selAgent && p.agentId !== selAgent) return false;\n195 |     if (selStatus && p.status !== selStatus) return false;\n196 |     if (selSeverity && p.severity !== selSeverity) return false;\n197 |     if (search && !p.name.toLowerCase().includes(search.toLowerCase()) && !p.id.toLowerCase().includes(search.toLowerCase())) return false;\n198 |     return true;\n199 |   });\n200 | \n201 |   const filteredOversights = oversights.filter(o => {\n202 |     if (selProj && o.projectId !== selProj) return false;\n203 |     if (selAgent && o.agentId !== selAgent) return false;\n204 |     if (selStatus && o.status !== selStatus) return false;\n205 |     if (selSeverity && o.severity !== selSeverity) return false;\n206 |     if (search && !o.title.toLowerCase().includes(search.toLowerCase()) && !o.id.toLowerCase().includes(search.toLowerCase())) return false;\n207 |     return true;\n208 |   });\n209 | \n210 |   const filteredDocs = documents.filter(d => {\n211 |     if (selProj && d.projectId !== selProj) return false;\n212 |     if (selAgent && d.agentId !== selAgent) return false;\n213 |     if (selSeverity && d.clearanceLevel !== selSeverity) return false;\n214 |     if (search && !d.name.toLowerCase().includes(search.toLowerCase())) return false;\n215 |     return true;\n216 |   });\n217 | \n218 |   // Extract select options dynamically\n219 |   const projectOptions = Array.from(new Set([\n220 |     ...policies.map(p => JSON.stringify({ id: p.projectId, name: p.projectName })),\n221 |     ...oversights.map(a => JSON.stringify({ id: a.projectId, name: a.project })),\n222 |     ...documents.map(d => JSON.stringify({ id: d.projectId, name: d.projectName }))\n223 |   ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n224 | \n225 |   const agentOptions = Array.from(new Set([\n226 |     ...policies.map(p => JSON.stringify({ id: p.agentId, name: p.agentName })),\n227 |     ...oversights.map(a => JSON.stringify({ id: a.agentId, name: a.agent })),\n228 |     ...documents.map(d => JSON.stringify({ id: d.agentId, name: d.agentName }))\n229 |   ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n230 | \n231 |   // Calculate dynamic trust index in real time\n232 |   const criticalCount = policies.filter(p => p.status === \"critical\").length;\n233 |   const warningCount = policies.filter(p => p.status === \"warning\").length;\n234 |   const pendingCount = oversights.filter(o => o.status === \"pending\").length;\n235 |   const approvedCount = oversights.filter(o => o.status === \"approved\").length;\n236 |   const trustScore = Math.min(100, Math.max(0, 99 - (criticalCount * 7.5) - (warningCount * 3) - (pendingCount * 1.5) + (approvedCount * 0.8))).toFixed(1);\n237 | \n238 |   const resetAll = () => {\n239 |     setSelProj(\"\"); setSelAgent(\"\"); setSelStatus(\"\"); setSelSeverity(\"\"); setSearch(\"\");\n240 |     triggerToast(\"Filters cleared\", \"info\");\n241 |   };\n242 | \n243 |   // Enclave Handshake Simulations\n244 |   const handleVerify = (id: string) => {\n245 |     if (verId) return;\n246 |     setVerId(id);\n247 |     triggerToast(`Cryptographic handshake check running for ${id}...`, \"info\");\n248 |     setTimeout(() => {\n249 |       setPolicies(prev => prev.map(p => p.id === id ? { ...p, status: \"compliant\", logs: [`[${new Date().toLocaleTimeString()}] RE-VERIFIED: Validated via hardware proof.`, ...p.logs] } : p));\n250 |       setVerId(null);\n251 |       triggerToast(`Boundary verified: ${id} is locked and fully compliant.`, \"success\");\n252 |     }, 1200);\n253 |   };\n254 | \n255 |   const handleResolveOversight = (id: string, state: \"approved\" | \"rejected\") => {\n256 |     setOversights(prev => prev.map(o => o.id === id ? { ...o, status: state } : o));\n257 |     if (state === \"approved\") triggerToast(`Signature committed. Interlock ${id} approved.`, \"success\");\n258 |     else triggerToast(`Interlock request ${id} rejected by client keys.`, \"warning\");\n259 |   };\n260 | \n261 |   const handleDocExport = (id: string) => {\n262 |     if (expIdDoc) return;\n263 |     setExpIdDoc(id);\n264 |     triggerToast(`Compiling signed attestation file for ${id}...`, \"info\");\n265 |     setTimeout(() => {\n266 |       setExpIdDoc(null);\n267 |       triggerToast(`Certified file package compiled and downloaded successfully.`, \"success\");\n268 |     }, 1500);\n269 |   };\n270 | \n271 |   const steps = [\n272 |     { id: \"step-1\", title: \"1. Prompt Ingress Node\", val: \"0.4ms latency\", desc: \"Inference transaction streams are parsed inside localized secure process loops.\" },\n273 |     { id: \"step-2\", title: \"2. Guardrail Interceptor\", val: \"99.8% pass rate\", desc: \"Validates payload streams against active compliance rulesets and redacts PII.\" },\n274 |     { id: \"step-3\", title: \"3. Isolated Secur