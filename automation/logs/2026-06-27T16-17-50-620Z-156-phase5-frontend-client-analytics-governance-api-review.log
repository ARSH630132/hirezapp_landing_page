lex items-center gap-1.5 shadow-xl z-20 backdrop-blur\\\">\n                  <span className=\\\"text-white/40\\\">Pt {hoveredPt.idx + 1}:</span>\n                  <span className=\\\"text-[#00FFC2] font-bold\\\">{hoveredPt.val}%</span>\n                </motion.div>\n              )}\n            </AnimatePresence>\n          </div>\n        </div>\n\n        <div className=\\\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 space-y-4 font-mono\\\">\n          <div className=\\\"flex items-center gap-1.5 border-b border-white/5 pb-2\\\">\n            <Network className=\\\"w-3.5 h-3.5 text-[#009DFF]\\\" />\n            <h3 className=\\\"text-[11px] font-bold uppercase\\\">eBPF Mesh Latencies</h3>\n          </div>\n          \n          <div className=\\\"space-y-3 text-[9.5px] text-white/60\\\">\n            {ENCLAVE_NODES.map((node) => {\n              const isSel = selectedNode.id === node.id;\n              const jitter = isSel ? Math.floor(Math.random() * 2) - 1 : 0;\n              return (\n                <div key={node.id} onClick={() => setSelectedNode(node)} className={`flex justify-between items-center border-b border-white/5 pb-2 last:border-b-0 last:pb-0 cursor-pointer p-1 rounded transition-colors ${isSel ? \\\"bg-white/[0.02] border-l border-l-[#009DFF] pl-1.5\\\" : \\\"hover:bg-white/[0.01]\\\"}`}>\n                  <div className=\\\"min-w-0\\\">\n                    <span className=\\\"text-white block font-bold truncate\\\">{node.name}</span>\n                    <span className=\\\"text-[7.5px] text-[#009DFF]/60 block font-mono truncate\\\">{node.ip}</span>\n                  </div>\n                  <span className={`font-bold ${isSel ? \\\"text-emerald-400\\\" : \\\"text-white/40\\\"}`}>{Math.max(1, node.basePing + jitter)}ms</span>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n      </div>\n\n      <div className=\\\"p-3.5 rounded-xl border border-white/5 bg-black/85 font-mono text-[8.5