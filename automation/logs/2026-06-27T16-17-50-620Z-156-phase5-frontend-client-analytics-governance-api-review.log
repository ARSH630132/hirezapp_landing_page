\"text-white/40 text-[10px]\">No active governance documents match your selections.</p>\n730 |                 </div>\n731 |               ) : (\n732 |                 filteredDocs.map(doc => (\n733 |                   <div key={doc.id} className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/20 flex flex-col sm:flex-row sm:items-center justify-between gap-3 text-xs\">\n734 |                     <div className=\"flex items-start gap-2.5 min-w-0\">\n735 |                       <div className=\"w-8 h-8 rounded bg-white/[0.02] border border-white/5 flex items-center justify-center shrink-0\">\n736 |                         <FileText className=\"w-4 h-4 text-white/50\" />\n737 |                       </div>\n738 |                       <div className=\"min-w-0\">\n739 |                         <div className=\"flex items-center gap-2 flex-wrap\">\n740 |                           <span className=\"font-bold text-white text-[12px] truncate select-text\">{doc.name}</span>\n741 |                           <span className=\"text-[8.5px] px-1.5 py-0.2 rounded bg-white/5 border border-white/10 text-white/50\">{doc.format}</span>\n742 |                           <span className=\"text-[8px] px-1.5 py-0.2 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF]\">{doc.clearanceLevel}</span>\n743 |                         </div>\n744 |                         <div className=\"text-[9.5px] text-white/40 mt-0.5\">Size: {doc.size} • Category: {doc.category.toUpperCase()}</div>\n745 |                       </div>\n746 |                     </div>\n747 | \n748 |                     <div className=\"flex items-center gap-2 shrink-0\">\n749 |                       <button \n750 |                         onClick={() => { navigator.clipboard.writeText(doc.hash); triggerToast(\"Hash seal copied\", \"success\"); }}\n751 |                         className=\"h-7.5 rounded bg-black border border-white/5 hover:border-white/10 px-2 text-[9.5px] text-white/50 hover:text-white flex 