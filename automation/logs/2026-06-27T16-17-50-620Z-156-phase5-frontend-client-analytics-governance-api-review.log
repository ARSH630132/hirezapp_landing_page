n101 |             id: item.id,\n102 |             name: item.title,\n103 |             standard: (item.standard || \"ISO-27001\") as any,\n104 |             status: fStatus,\n105 |             severity: ([\"critical\", \"high\"].includes(sev) ? \"high\" : sev === \"medium\" ? \"medium\" : \"low\") as any,\n106 |             projectId: item.project_id || \"proj-001\",\n107 |             projectName: item.project_name || \"Sovereign Core Sandbox 02\",\n108 |             agentId: item.nodeId || \"agent-001\",\n109 |             agentName: item.nodeId || \"RETAIL-CORE-A1\",\n110 |             desc: item.description,\n111 |             lastChecked: item.lastUpdated ? new Date(item.lastUpdated).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : \"11:00 AM\",\n112 |             logs: item.logs || []\n113 |           };\n114 |         });\n115 | \n116 |         const mappedOversights = rawGov.map((item: any) => {\n117 |           let fStatus: \"pending\" | \"approved\" | \"rejected\" = \"pending\";\n118 |           const s = (item.status || \"\").toLowerCase();\n119 |           if ([\"compliant\", \"completed\", \"remediated\", \"suppressed\", \"approved\"].includes(s)) fStatus = \"approved\";\n120 |           else if (s === \"rejected\") fStatus = \"rejected\";\n121 | \n122 |           return {\n123 |             id: item.id,\n124 |             title: item.title,\n125 |             project: item.project_name || \"Sovereign Core Sandbox 02\",\n126 |             projectId: item.project_id || \"proj-001\",\n127 |             agent: item.nodeId || \"RETAIL-CORE-A1\",\n128 |             agentId: item.nodeId || \"agent-001\",\n129 |             requester: item.owner || \"System\",\n130 |             status: fStatus,\n131 |             severity: ([\"critical\", \"high\"].includes(item.severity?.toLowerCase()) ? \"high\" : item.severity?.toLowerCase() === \"medium\" ? \"medium\" : \"low\") as any,\n132 |             requestDate: item.lastUpdated || new Date().toISOS