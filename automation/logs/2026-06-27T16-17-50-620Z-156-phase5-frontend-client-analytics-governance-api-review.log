{"ts":"2026-06-27T16:11:12.859Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"auptu1z1","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/layout.tsx","result":" 1 | \"use client\";\n 2 | \n 3 | import React, { useEffect, useState } from \"react\";\n 4 | import { usePathname, useRouter } from \"next/navigation\";\n 5 | import { PrivateAppShell, BreadcrumbItem } from \"@/components/private-app\";\n 6 | import { clientUser, clientSidebarLinks, clientLinkToRoute } from \"@/components/private-app/routes-config\";\n 7 | import { PreviewRouteGuard } from \"@/components/private-app/PreviewRouteGuard\";\n 8 | import { getPreviewSession, PreviewSession } from \"@/lib/preview-auth\";\n 9 | \n10 | export default function ClientPortalLayout({\n11 |   children,\n12 | }: {\n13 |   children: React.ReactNode;\n14 | }) {\n15 |   const pathname = usePathname();\n16 |   const router = useRouter();\n17 |   const [session, setSession] = useState<PreviewSession | null>(null);\n18 | \n19 |   useEffect(() => {\n20 |     setSession(getPreviewSession());\n21 |     const handleSessionChanged = () => {\n22 |       setSession(getPreviewSession());\n23 |     };\n24 |     window.addEventListener(\"gff_preview_session_changed\", handleSessionChanged);\n25 |     return () => {\n26 |       window.removeEventListener(\"gff_preview_session_changed\", handleSessionChanged);\n27 |     };\n28 |   }, []);\n29 | \n30 |   // If it's an auth page, we render it directly without the app shell\n31 |   const isAuthPage = pathname === \"/portal\" || pathname === \"/portal/login\" || pathname === \"/login\";\n32 | \n33 |   if (isAuthPage) {\n34 |     return <>{children}</>;\n35 |   }\n36 | \n37 |   // Parse active tab from pathname\n38 |   const segments = pathname.split(\"/\");\n39 |   let activeTab = \"dashboard\";\n40 |   if (segments.length >= 3) {\n41 |     activeTab = segments[2];\n42 |   }\n43 | \n44 |   // Map \"ai-operations\" pathname segment back to \"ai-operations\" link id\n45 |   const activeLinkId = activeTab;\n46 | \n47 |   const breadcrumbs: BreadcrumbItem[] = [\n48 |     { label: \"Sovereign Gateway\", href: \"/portal/dashboard\" },\n49 |     { label: activeTab.replace(\"-\", \" \").toUpperCase() }\n50 |   ];\n51 | \n52 |   const handleLinkChange = (id: string) => {\n53 |     const route = clientLinkToRoute[id] || `/portal/${id}`;\n54 |     router.push(route);\n55 |   };\n56 | \n57 |   const handleRoleChange = (role: \"Client\" | \"Administrator\") => {\n58 |     if (role === \"Administrator\") {\n59 |       router.push(\"/admin/dashboard\");\n60 |     } else {\n61 |       router.push(\"/portal/dashboard\");\n62 |     }\n63 |   };\n64 | \n65 |   // Build current user representation\n66 |   const activeUser = session ? {\n67 |     name: session.name,\n68 |     email: session.email,\n69 |     role: (session.role === \"client_admin\" || session.role === \"client_member\") ? (\"Client\" as const) : (\"Administrator\" as const),\n70 |     clearance: session.clearance\n71 |   } : clientUser;\n72 | \n73 |   return (\n74 |     <PreviewRouteGuard type=\"portal\">\n75 |       <PrivateAppShell\n76 |         user={activeUser}\n77 |         breadcrumbs={breadcrumbs}\n78 |         links={clientSidebarLinks}\n79 |         activeLink={activeLinkId}\n80 |         onLinkChange={handleLinkChange}\n81 |         role=\"Client\"\n82 |         onRoleChange={handleRoleChange}\n83 |       >\n84 |         {children}\n85 |       </PrivateAppShell>\n86 |     </PreviewRouteGuard>\n87 |   );\n88 | }\n89 | ","success":true}],"durationMs":6}}
