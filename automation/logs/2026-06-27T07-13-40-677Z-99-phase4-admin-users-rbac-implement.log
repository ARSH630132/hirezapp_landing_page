        {Object.entries(selRow).filter(([k]) => k !== \"id\" && k !== \"logs\").map(([k, v]) => (\n244 |                       <div key={k} className=\"p-3 rounded-lg border border-white/5 bg-[#020202]/40 flex flex-col gap-1 font-mono text-[11.5px]\">\n245 |                         <span className=\"text-white/30 text-[9px] uppercase font-semibold\">{k.replace(/([A-Z])/g, \" $1\").toUpperCase()}</span>\n246 |                         <div className=\"flex items-center justify-between gap-4\">\n247 |                           <span className=\"text-white font-bold truncate\">{typeof v === \"object\" && v !== null ? (\"name\" in v ? String((v as any).name) : JSON.stringify(v)) : String(v ?? \"N/A\")}</span>\n248 |                           {k.toLowerCase().includes(\"status\") && <span className={`w-1.5 h-1.5 rounded-full ${getStatusDot(String(v))}`} />}\n249 |                         </div>\n250 |                       </div>\n251 |                     ))}\n252 |                   </div>\n253 |                 </div>\n254 |               )}\n255 | \n256 |               <div className=\"space-y-3 pt-2\">\n257 |                 <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n258 |                   <div className=\"flex items-center gap-1.5 font-mono text-[10px] text-white/40 uppercase font-semibold\">\n259 |                     <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n260 |                     <span>SECURE ATTESTATION FLUX</span>\n261 |                   </div>\n262 |                   {sync ? <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin\" /> : (\n263 |                     <div className=\"flex items-center gap-1 text-[9px] font-mono text-green-400\">\n264 |                       <span className=\"w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse\" />\n265 |                       <span>TELEMETRY STREAM LIVE</span>\n266 |                     </div>\n267 |                   )}\n268 |                 </div>\n269 |                 <div className=\"p-4 rounded-xl border border-white/5 bg-[#020202] text-[10.5px] font-mono text-white/75 space-y-2 h-[150px] overflow-y-auto select-text\">\n270 |                   {logs.map((log, idx) => (\n271 |                     <div key={idx} className=\"leading-relaxed border-b border-white/[0.01] pb-1 font-mono\"><span className=\"text-[#009DFF]/80\">&gt;</span> {log}</div>\n272 |                   ))}\n273 |                   <div className=\"text-[9.5px] text-white/30 pt-1 flex items-center gap-1\"><Shield className=\"w-3 h-3 text-[#00FFC2]\" /><span>Policy enforcement bounds locked</span></div>\n274 |                 </div>\n275 |               </div>\n276 |             </div>\n277 | \n278 |             <div className=\"p-5 border-t border-white/5 bg-black/[0.15] space-y-3\">\n279 |               <div className=\"flex items-center gap-2 text-[10.5px] font-mono text-white/40\"><Lock className=\"w-3.5 h-3.5 text-[#00FFC2]\" /><span>Isolated Enclave Memory Lock Active</span></div>\n280 |               <div className=\"grid grid-cols-2 gap-3\">\n281 |                 <button onClick={() => copy(`0xSHA256_${selRow ? String(selRow.id).toUpperCase() : \"\"}_2026`)} className=\"h-9 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer\">\n282 |                   <Copy className=\"w-3.5 h-3.5\" />\n283 |                   <span>Copy Seal Hash</span>\n284 |                 </button>\n285 |                 <button onClick={() => setSelRow(null)} className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase text-white flex items-center justify-center transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\">\n286 |                   <span>Close Ledger</span>\n287 |                 </button>\n288 |               </div>\n289 |             </div>\n290 |          