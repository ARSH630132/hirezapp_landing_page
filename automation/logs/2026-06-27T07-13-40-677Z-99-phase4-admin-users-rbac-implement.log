 if (!match) return false;\n 70 |     }\n 71 |     if (status && statusField && String(row[statusField as keyof T] || \"\").toLowerCase() !== status.toLowerCase()) return false;\n 72 |     if (type && typeField && String(row[typeField as keyof T] || \"\").toLowerCase() !== type.toLowerCase()) return false;\n 73 |     return true;\n 74 |   });\n 75 | \n 76 |   const sorted = [...filtered];\n 77 |   if (sortKey) {\n 78 |     sorted.sort((a, b) => {\n 79 |       const aV = String(a[sortKey as keyof T] || \"\");\n 80 |       const bV = String(b[sortKey as keyof T] || \"\");\n 81 |       return sortOrder === \"asc\" ? aV.localeCompare(bV, undefined, { numeric: true }) : bV.localeCompare(aV, undefined, { numeric: true });\n 82 |     });\n 83 |   }\n 84 | \n 85 |   const paginated = sorted.slice((page - 1) * pageSize, page * pageSize);\n 86 |   const totalPages = Math.ceil(sorted.length / pageSize) || 1;\n 87 | \n 88 |   const getStatusDot = (st: string) => {\n 89 |     const s = st.toLowerCase();\n 90 |     if ([\"active\", \"healthy\", \"compliant\", \"verified\", \"paid\", \"resolved\", \"settled\", \"on track\", \"stable\"].includes(s)) return \"bg-[#00FFC2] shadow-[0_0_8px_rgba(0,255,194,0.4)]\";\n 91 |     if ([\"warning\", \"evaluating\", \"in_progress\", \"processing\", \"pending\", \"open\"].includes(s)) return \"bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.4)]\";\n 92 |     return \"bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]\";\n 93 |   };\n 94 | \n 95 |   return (\n 96 |     <div className=\"space-y-4\">\n 97 |       {/* 1. FILTERS BAR */}\n 98 |       <div className=\"flex flex-col xl:flex-row xl:items-center justify-between gap-4 p-4 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm\">\n 99 |         <div className=\"relative flex-grow max-w-xl\">\n100 |           <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n101 |           <input \n102 |             type=\"text\" value={query} onChange={(e) => setQuery(e.targ