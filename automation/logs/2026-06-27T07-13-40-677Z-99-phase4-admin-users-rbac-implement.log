 className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n125 |             </div>\n126 |           )}\n127 |         </div>\n128 |       </div>\n129 | \n130 |       {paginated.length === 0 ? (\n131 |         <EmptyState title=\"No Matching Records\" description=\"No active ledger entries match your filter rules.\" actionLabel=\"Clear Filters\" onAction={() => { setQuery(\"\"); setStatus(\"\"); setType(\"\"); }} />\n132 |       ) : (\n133 |         <div className=\"space-y-4\">\n134 |           <div className=\"hidden md:block overflow-hidden rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm\">\n135 |             <table className=\"w-full text-left border-collapse\" role=\"grid\">\n136 |               <thead>\n137 |                 <tr className=\"border-b border-white/5 bg-white/[0.01]\" role=\"row\">\n138 |                   {columns.map((col) => (\n139 |                     <th key={String(col.key)} role=\"columnheader\" onClick={() => handleSort(col.key, col.sortable)} className={`p-4 text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase ${col.sortable ? \"cursor-pointer hover:text-white\" : \"\"}`}>\n140 |                       <div className=\"flex items-center gap-1.5\">\n141 |                         <span>{col.header}</span>\n142 |                         {col.sortable && <ArrowUpDown className={`w-3.5 h-3.5 ${sortKey === col.key ? \"text-white\" : \"opacity-30\"}`} />}\n143 |                       </div>\n144 |                     </th>\n145 |                   ))}\n146 |                   <th className=\"p-4 text-right text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase w-10\">Ledger</th>\n147 |                 </tr>\n148 |               </thead>\n149 |               <tbody>\n150 |                 {paginated.map((row, rIdx) => (\n151 |                   <tr\n152 |                     key={row.id} role=\"row\" tabIndex={0} ref={(el) => { rowRefs.current[rIdx] = el; }}\n