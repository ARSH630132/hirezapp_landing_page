74 |                         key={alert.id}\n475 |                         onClick={() => handleSelectAlert(alert)}\n476 |                         className={`p-3.5 rounded-xl border transition-all cursor-pointer text-left select-none relative group ${\n477 |                           isSelected \n478 |                             ? \"border-[#009DFF] bg-[#009DFF]/[0.02]\" \n479 |                             : isUrgent\n480 |                               ? \"border-rose-500/10 bg-rose-500/[0.01] hover:border-rose-500/20\"\n481 |                               : \"border-white/5 bg-[#050505]/20 hover:border-white/10\"\n482 |                         }`}\n483 |                       >\n484 |                         <div className=\"flex justify-between items-center gap-2\">\n485 |                           <div className=\"flex items-center gap-1.5 text-[9px]\">\n486 |                             <span className=\"font-bold text-white/30\">{alert.id}</span>\n487 |                             <span className=\"text-white/20\">•</span>\n488 |                             <span className=\"text-[#009DFF] font-bold\">{alert.standard}</span>\n489 |                           </div>\n490 |                           \n491 |                           <div className=\"flex items-center gap-1.5\">\n492 |                             <span className={`px-1 py-0.2 rounded font-bold uppercase text-[8px] border ${\n493 |                               alert.sev === \"Critical\" ? \"bg-rose-500/10 text-rose-400 border-rose-500/20\" :\n494 |                               alert.sev === \"High\" ? \"bg-amber-500/10 text-amber-500 border-amber-500/20\" :\n495 |                               \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\"\n496 |                             }`}>\n497 |                               {alert.sev}\n498 |                             </span>\n499 |                             <span className={`h-1.5 w-1.5 rounded-full ${\n500 |                               a