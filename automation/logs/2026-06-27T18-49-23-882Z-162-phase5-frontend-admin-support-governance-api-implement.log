left-3 top-2.5 w-4 h-4 text-white/30\" />\n407 |           <input \n408 |             type=\"text\"\n409 |             value={searchQuery}\n410 |             onChange={(e) => setSearchQuery(e.target.value)}\n411 |             placeholder=\"Search by SLA identifier, subject, or client...\"\n412 |             className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-9 pr-4 text-[11px] font-mono text-white placeholder-white/30 outline-none focus:border-white/10 focus:bg-white/[0.02]\"\n413 |           />\n414 |         </div>\n415 |         <div className=\"flex flex-wrap gap-2\">\n416 |           <select value={filterClient} onChange={(e) => setFilterClient(e.target.value)} className=\"h-9 rounded-lg border border-white/5 bg-[#050505] px-2 text-[10px] font-mono text-white/70 outline-none cursor-pointer font-bold\">\n417 |             <option value=\"\">ALL CLIENTS</option>\n418 |             {AVAILABLE_CLIENTS.map((c) => <option key={c} value={c}>{c.split(\" [\")[0].toUpperCase()}</option>)}\n419 |           </select>\n420 |           <select value={filterPriority} onChange={(e) => setFilterPriority(e.target.value)} className=\"h-9 rounded-lg border border-white/5 bg-[#050505] px-2 text-[10px] font-mono text-white/70 outline-none cursor-pointer font-bold\">\n421 |             <option value=\"\">ALL PRIORITY</option>\n422 |             <option value=\"P1\">P1 SLA</option>\n423 |             <option value=\"P2\">P2 SLA</option>\n424 |             <option value=\"P3\">P3 SLA</option>\n425 |           </select>\n426 |           <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className=\"h-9 rounded-lg border border-white/5 bg-[#050505] px-2 text-[10px] font-mono text-white/70 outline-none cursor-pointer font-bold\">\n427 |             <option value=\"\">ALL STATUS</option>\n428 |             <option value=\"OPEN\">OPEN</option>\n429 |             <option value=\"INVESTIGATING\">INVESTIGATING</option>\n430 |             <option value=\"HOLD\">ON HOLD</option>\n431 |             <option value=\"RESOLVED\">RESOLVED</option>\n432 |           </select>\n433 |         </div>\n434 |       </div>\n435 | \n436 |       <div className=\"hidden md:block border border-white/5 rounded-xl bg-[#050505]/20 overflow-hidden\">\n437 |         <table className=\"w-full text-left border-collapse font-mono text-[11px]\">\n438 |           <thead>\n439 |             <tr className=\"border-b border-white/5 bg-white/[0.01] text-[9.5px] text-white/40 uppercase tracking-wider\">\n440 |               <th className=\"py-3 px-4 font-semibold\">ID</th>\n441 |               <th className=\"py-3 px-4 font-semibold\">Subject & Client</th>\n442 |               <th className=\"py-3 px-4 font-semibold\">Priority</th>\n443 |               <th className=\"py-3 px-4 font-semibold\">Category</th>\n444 |               <th className=\"py-3 px-4 font-semibold\">Status</th>\n445 |               <th className=\"py-3 px-4 font-semibold\">Assigned Engineer</th>\n446 |               <th className=\"py-3 px-4 font-semibold\">Assets</th>\n447 |               <th className=\"py-3 px-4 font-semibold text-right\">SLA countdown</th>\n448 |             </tr>\n449 |           </thead>\n450 |           <tbody>\n451 |             {filteredTickets.map((t) => (\n452 |               <tr \n453 |                 key={t.id}\n454 |                 onClick={() => setSelectedTicketId(t.id)}\n455 |                 onKeyDown={(e) => {\n456 |                   if (e.key === \"Enter\" || e.key === \" \") {\n457 |                     e.preventDefault();\n458 |                     setSelectedTicketId(t.id);\n459 |                   }\n460 |                 }}\n461 |                 tabIndex={0}\n462 |                 role=\"button\"\n463 |                 aria-pressed={selectedTicketId === t.id}\n464 |                 className={`border-b border-white/[0.02] last:border-0 hover:bg-white/[0.02] focus:bg-white/[0.03] outline-none cursor-pointer transition-colors ${selectedTicketId === t.id ? \"bg-white/[0.02]\" : \"\"}`}\n465 |               >\n466 |                 <td className=\"py-3 px-4 font-bold text-[#009DFF]\">\n467 |                   <div className=\"flex items-center gap-1.5\">\n468 |                     <span>{t.id}</span>\n469 |                     <button \n470 |                       onClick={(e) => handleCopyId(e, t.id)} \n471 |                       className=\"opacity-40 hover:opacity-100 p-0.5 focus:opacity-100 outline-none rounded hover:bg-white/5\" \n472 |                       title=\"Copy SLA Wire ID\"\n473 |                     >\n474 |                       {copiedTicketId === t.id ? <Check className=\"w-3 h-3 text-emerald-400\" /> : <Copy className=\"w-3 h-3\" />}\n475 |                     </button>\n476 |                   </div>\n477 |                 </td>\n478 |                 <td className=\"py-3 px-4\">\n479 |                   <div className=\"space-y-0.5\">\n480 |                     <span className=\"text-white font-semibold block truncate max-w-[250px]\">{t.subject}</span>\n481 |                     <span className=\"text-white/30 text-[9.5px] block uppercase\">{t.client.split(\" [\")[0]}</span>\n482 |                   </div>\n483 |                 </td>\n484 |                 <td className=\"py-3 px-4\">\n485 |                   <span className={`inline-flex px-1.5 py-0.5 rounded border text-[9px] font-bold ${getPriorityBadgeStyles(t.priority)}`}>\n486 |                     {t.priority} SLA\n487 |                   </span>\n488 |                 </td>\n489 |                 <td className=\"py-3 px-4 text-white/70\">{t.category.toUpperCase()}</td>\n490 |                 <td className=\"py-3 px-4\">\n491 |                   {(() => {\n492 |                     const styles = getStatusStyles(t.status);\n493 |                     return (\n494 |                       <span className={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded border text-[9px] font-bold ${styles.bgClass} ${styles.textClass}`}>\n495 |                         <span className={`w-1 h-1 rounded-full ${styles.dotClass}`} />\n496 |                         <span>{t.status}</span>\n497 |                       </span>\n498 |                     );\n499 |                   })()}\n500 |                 </td>\n501 |                 <td className=\"py-3 px-4 text-white/80\">{t.assignedAgent}</td>\n502 |                 <td className=\"py-3 px-4\">\n503 |                   <div className=\"flex gap-1.5 text-white/40\">\n504 |                     {t.linkedProjectId !== \"None\" && (\n505 |                       <span title=\"Linked Project\" className=\"flex items-center\">\n506 |                         <Folder className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n507 |                       </span>\n508 |                     )}\n509 |                     {t.linkedDocId !== \"None\" && (\n510 |                       <span title=\"Linked Document\" className=\"flex items-center\">\n511 |                         <FileText className=\"w-3.5 h-3.5 text-amber-400\" />\n512 |                       </span>\n513 |                     )}\n514 |                   </div>\n515 |                 </td>\n516 |                 <td className=\"py-3 px-4 text-right font-bold\">\n517 |                   {renderSlaBadge(t)}\n518 |                 </td>\n519 |               </tr>\n520 |             ))}\n521 |           </tbody>\n522 |         </table>\n523 |       </div>\n524 | \n525 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 md:hidden\">\n526 |         {filteredTickets.map((t) => (\n527 |           <div \n528 |             key={t.id} \n529 |             onClick={() => setSelectedTicketId(t.id)} \n530 |             onKeyDown={(e) => {\n531 |               if (e.key === \"Enter\" || e.key === \" \") {\n532 |                 e.preventDefault();\n533 |                 setSelectedTicketId(t.id);\n534 |               }\n535 |             }}\n536 |             tabIndex={0}\n537 |             role=\"button\"\n538 |             aria-pressed={selectedTicketId === t.id}\n539 |             className={`border rounded-xl p-4 space-y-3 bg-[#050505]/40 backdrop-blur-sm cursor-pointer hover:bg-[#050505]/60 focus:border-[#009DFF] outline-none transition-all ${selectedTicketId === t.id ? \"border-[#009DFF]\" : \"border-white/5\"}`}\n540 |           >\n541 |             <div className=\"flex justify-between items-center\">\n542 |               <span className=\"text-[#009DFF] font-bold font-mono text-[11px]\">{t.id}</span>\n543 |               <span className={`inline-flex px-1.5 py-0.5 rounded border text-[8px] font-bold ${getPriorityBadgeStyles(t.priority)}`}>\n544 |                 {t.priority}\n545 |               </span>\n546 |             </div>\n547 |             <h4 className=\"text-white font-semibold text-xs leading-snug\">{t.subject}</h4>\n548 |             <p className=\"text-[9.5px] font-mono text-white/30 uppercase mt-1\">{t.client.split(\" [\")[0]}</p>\n549 |             <div className=\"flex justify-between items-center pt-2 border-t border-white/5 font-mono text-[10px]\">\n550 |               <span className=\"text-white/40 uppercase\">STATUS: {t.status}</span>\n551 |               <span>{renderSlaBadge(t)}</span>\n552 |             </div>\n553 |           </div>\n554 |         ))}\n555 |       </div>\n556 | \n557 |       {selectedTicket && (\n558 |         <>\n559 |           <div onClick={() => setSelectedTicketId(null)} className=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-40 transition-all\" />\n560 |           <div className=\"fixed inset-y-0 right-0 z-50 w-full sm:w-[500px] md:w-[600px] bg-[#070708] border-l border-white/10 shadow-2xl p-6 overflow-y-auto flex flex-col justify-between\">\n561 |             <div className=\"space-y-5\">\n562 |               <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n563 |                 <div>\n564 |                   <span className=\"text-[10px] font-mono text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded font-bold\">{selectedTicket.id}</span>\n565 |                   <h3 className=\"text-sm font-bold text-white mt-2 leading-snug\">{selectedTicket.subject}</h3>\n566 |                   <p className=\"text-[9.5px] font-mono text-white/40 uppercase mt-1\">CLIENT: {selectedTicket.client}</p>\n567 |                 </div>\n568 |                 <button onClick={() => setSelectedTicketId(null)} className=\"p-1 hover:bg-white/5 rounded text-white/40 cursor-pointer\"><X className=\"w-5 h-5\" /></button>\n569 |               </div>\n570 | \n571 |               {/* Secure Enclave Diagnostics Bridge Visualizer */}\n572 |               <div className=\"border border-white/5 rounded-xl bg-black/40 p-4 font-mono text-[10px] space-y-3 relative overflow-hidden\">\n573 |                 <style>{`\n574 |                   @keyframes flowP { to { stroke-dashoffset: -20; } }\n575 |                   .fl-f { stroke-dasharray:6,6; animation:flowP .6s linear infinite; }\n576 |                   .fl-n { stroke-dasharray:6,6; animation:flowP 1.5s linear infinite; }\n577 |                   .fl-s { stroke-dasharray:6,6; animation:flowP 3.5s linear infinite; }\n578 |                 `}</style>\n579 |                 \n580 |                 <div className=\"flex justify-between items-center text-[8.5px] text-white/40 uppercase tracking-wider\">\n581 |                   <span>Enclave Telemetry Bridge</span>\n582 |                   <span className=\"flex items-center gap-1\">\n583 |                     <span className={`w-1.5 h-1.5 rounded-full ${selectedTicket.status === \"RESOLVED\" ? \"bg-white/20\" : selectedTicket.priority === \"P1\" ? \"bg-red-500 animate-ping\" : \"bg-cyan-400 animate-pulse\"}`} />\n584 |                     <span className={selectedTicket.status === \"RESOLVED\" ? \"text-white/40\" : selectedTicket.priority === \"P1\" ? \"text-red-400 font-bold\" : \"text-cyan-400\"}>\n585 |                       {selectedTicket.status === \"RESOLVED\" ? \"TERMINATED\" : `${selectedTicket.priority} STREAM ACTIVE`}\n586 |                     </span>\n587 |                   </span>\n588 |                 </div>\n589 | \n590 |                 <div className=\"relative h-20 w-full flex items-center justify-center\">\n591 |                   <svg className=\"w-full h-full overflow-visible\" viewBox=\"0 0 400 80\" fill=\"none\">\n592 |                     <path d=\"M 40 40 Q 200 10 360 40\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"3\" strokeLinecap=\"round\" />\n593 |                     {selectedTicket.status !== \"RESOLVED\" && (\n594 |                       <path \n595 |                         d=\"M 40 40 Q 200 10 360 40\" \n596 |                         stroke={selectedTicket.status === \"HOLD\" ? \"#FBBF24\" : selectedTicket.priority === \"P1\" ? \"#F87171\" : \"#22D3EE\"} \n597 |                         strokeWidth=\"1.5\" \n598 |                         strokeLinecap=\"round\"\n599 |                         className={selectedTicket.status === \"HOLD\" ? \"fl-s\" : selectedTicket.priority === \"P1\" ? \"fl-f\" : \"fl-n\"}\n600 |                       />\n601 |                     )}\n602 |                     <g transform=\"translate(40, 40)\">\n603 |                       <circle r=\"12\" fill=\"#070708\" stroke={selectedTicket.status === \"RESOLVED\" ? \"rgba(255,255,255,0.1)\" : selectedTicket.priority === \"P1\" ? \"#EF4444\" : \"#06B6D4\"} strokeWidth=\"1.5\" />\n604 |                       <circle r=\"6\" fill={selectedTicket.status === \"RESOLVED\" ? \"rgba(255,255,255,0.2)\" : selectedTicket.priority === \"P1\" ? \"#EF4444\" : \"#06B6D4\"} className={selectedTicket.status !== \"RESOLVED\" ? \"animate-pulse\" : \"\"} />\n605 |                       {selectedTicket.status !== \"RESOLVED\" && selectedTicket.priority === \"P1\" && (\n606 |                         <circle r=\"18\" fill=\"none\" stroke=\"#EF4444\" strokeWidth=\"1\" className=\"animate-ping opacity-30\" />\n607 |                       )}\n608 |                     </g>\n609 |                     <g transform=\"translate(360, 40)\">\n610 |                       <circle r=\"12\" fill=\"#070708\" stroke={selectedTicket.status === \"RESOLVED\" ? \"rgba(255,255,255,0.1)\" : selectedTicket.assignedAgent === \"Unassigned\" ? \"#F59E0B\" : \"#10B981\"} strokeWidth=\"1.5\" />\n611 |                       <circle r=\"6\" fill={selectedTicket.status === \"RESOLVED\" ? \"rgba(255,255,255,0.2)\" : selectedTicket.assignedAgent === \"Unassigned\" ? \"#F59E0B\" : \"#10B981\"} />\n612 |                     </g>\n613 |                     <text x=\"40\" y=\"68\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">ENCLAVE</text>\n614 |                     <text x=\"360\" y=\"68\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">TERMINAL</text>\n615 |                     <rect x=\"150\" y=\"28\" width=\"100\" height=\"14\" rx=\"3\" fill=\"#070708\" stroke=\"rgba(255,255,255,0.1)\" />\n616 |                     <text x=\"200\" y=\"37\" fill={selectedTicket.status === \"RESOLVED\" ? \"rgba(255,255,255,0.3)\" : \"#00FFC2\"} fontSize=\"6.5\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">\n617 |                       {selectedTicket.status === \"RESOLVED\" ? \"ATTESTATION_OFF\" : \"TLS_1.3_SECURE\"}\n618 |                     </text>\n619 |                   </svg>\n620 |                 </div>\n621 | \n622 |                 <div className=\"grid grid-cols-2 gap-3 pt-1 border-t border-white/5 text-[9px] text-white/50\">\n623 |                   <div>\n624 |                     <div>CLIENT: <span className=\"text-white font-bold\">{selectedTicket.client.split(\" [\")[0]}</span></div>\n625 |                     <div>SEALING: <span className=\"text-white font-bold\">Intel SGX v2</span></div>\n626 |                   </div>\n627 |                   <div className=\"text-right\">\n628 |                     <div>GATEWAY: <span className=\"text-white font-bold\">{selectedTicket.id}-GW</span></div>\n629 |                     <div>LATENCY: <span className=\"text-emerald-400 font-bold\">{selectedTicket.priority === \"P1\" ? \"145ms (HIGH)\" : \"42ms (NOMINAL)\"}</span></div>\n630 |                   </div>\n631 |                 </div>\n632 |               </div>\n633 | \n634 |               <div className=\"flex border-b border-white/5 font-mono text-[9.5px] select-none\">\n635 |                 <button onClick={() => setDrawerTab(\"wire\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"wire\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n636 |                   <MessageSquare className=\"w-3.5 h-3.5\" /><span>Secure wire</span>\n637 |                 </button>\n638 |                 <button onClick={() => setDrawerTab(\"assets\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"assets\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n639 |                   <Folder className=\"w-3.5 h-3.5\" /><span>Sovereign assets</span>\n640 |                 </button>\n641 |                 <button onClick={() => setDrawerTab(\"diagnostic\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"diagnostic\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n642 |                   <Terminal className=\"w-3.5 h-3.5\" /><span>Diagnostics</span>\n643 |                 </button>\n644 |               </div>\n645 | \n646 |               {drawerTab === \"wire\" && (\n647 |                 <div className=\"space-y-4 font-mono\">\n648 |                   <div className=\"border border-emerald-500/10 rounded-lg bg-emerald-500/[0.01] p-2.5 text-[10.5px] text-emerald-400 flex gap-1.5\">\n649 |                     <Shield className=\"w-4 h-4 shrink-0 mt-0