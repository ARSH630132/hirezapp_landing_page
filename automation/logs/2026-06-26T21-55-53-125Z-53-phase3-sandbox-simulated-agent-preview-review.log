inejoin=\"round\" strokeWidth={1.5} d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n1293 |                       </svg>\n1294 |                       <p className=\"text-center max-w-xs font-light text-[10px] uppercase tracking-wider\">\n1295 |                         Secure Enclave Ready. Click Launch to simulate dry-run telemetry outputs locally.\n1296 |                       </p>\n1297 |                     </div>\n1298 |                   ) : (\n1299 |                     <div className=\"space-y-2\">\n1300 |                       {simulatedLogs.map((log, idx) => {\n1301 |                         const getLogColor = () => {\n1302 |                           switch (log.type) {\n1303 |                             case \"success\": return \"text-[#00FF9D]\";\n1304 |                             case \"warning\": return \"text-amber-400\";\n1305 |                             case \"agent\": return \"text-[#009DFF]\";\n1306 |                             case \"system\": return \"text-purple-400 font-bold\";\n1307 |                             default: return \"text-white/70\";\n1308 |                           }\n1309 |                         };\n1310 |                         return (\n1311 |                           <div key={idx} className=\"flex gap-2 border-l border-white/10 pl-2 text-[10px]\">\n1312 |                             <span className=\"text-white/20\">+{log.timeOffset.toFixed(1)}s</span>\n1313 |                             <span className=\"text-white/40\">[{log.type.toUpperCase()}]</span>\n1314 |                             <span className={getLogColor()}>{log.text}</span>\n1315 |                           </div>\n1316 |                         );\n1317 |                       })}\n1318 | \n1319 |                       {isSimulating && (\n1320 |                         <div className=\"flex gap-2 items-center text-white/20 text-[9px]\">\n1321 |                           <span>•</span>\