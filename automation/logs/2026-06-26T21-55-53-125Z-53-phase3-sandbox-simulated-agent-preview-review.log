ervices\",\n547 |   \"Regulated / Legal\",\n548 |   \"Financial Services\",\n549 |   \"Government & Sovereign\",\n550 |   \"Telecom\",\n551 |   \"Heavy Industry & Mining\"\n552 | ];\n553 | \n554 | const FUNCTIONS = [\n555 |   \"All Functions\",\n556 |   \"Knowledge Search\",\n557 |   \"Procurement Copilot\",\n558 |   \"HR Assistant\",\n559 |   \"Contract Intelligence\",\n560 |   \"Executive Dashboard\",\n561 |   \"Compliance Assistant\",\n562 |   \"Customer Experience Agent\",\n563 |   \"Operations Copilot\"\n564 | ];\n565 | \n566 | const AGENT_TYPES = [\n567 |   \"All Agent Types\",\n568 |   \"Deep Reasoning / DAG\",\n569 |   \"Transactional / Actions\",\n570 |   \"Collaborative / HITL\",\n571 |   \"Analytical / Extraction\",\n572 |   \"Multi-Agent Synthesis\",\n573 |   \"Guardrail / Audit\",\n574 |   \"Real-time / Interactive\",\n575 |   \"Reactive / Hardware\"\n576 | ];\n577 | \n578 | export default function SandboxPage() {\n579 |   // Filter States\n580 |   const [selectedIndustry, setSelectedIndustry] = useState(\"All Industries\");\n581 |   const [selectedFunction, setSelectedFunction] = useState(\"All Functions\");\n582 |   const [selectedAgentType, setSelectedAgentType] = useState(\"All Agent Types\");\n583 |   const [searchQuery, setSearchQuery] = useState(\"\");\n584 | \n585 |   // Catalog Active Agent Selection\n586 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n587 | \n588 |   // Simulation Telemetry States\n589 |   const [isSimulating, setIsSimulating] = useState(false);\n590 |   const [simulationProgress, setSimulationProgress] = useState(0);\n591 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n592 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n593 | \n594 |   // Filter lists based on rules\n595 |   const filteredAgents = AGENTS.filter((agent) => {\n596 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n597 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n598 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n599 |     const matchSearch =\n600 |       searchQuery === \"\" ||\n601 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n602 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n603 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n604 | \n605 |     return matchIndustry && matchFunction && matchType && matchSearch;\n606 |   });\n607 | \n608 |   // Dynamically pull active agent object\n609 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n610 | \n611 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n612 |   useEffect(() => {\n613 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n614 |       setActiveAgentId(filteredAgents[0].id);\n615 |     }\n616 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n617 | \n618 |   // Reset simulation whenever active agent changes\n619 |   useEffect(() => {\n620 |     setIsSimulating(false);\n621 |     setSimulationProgress(0);\n622 |     setSimulatedLogs([]);\n623 |   }, [activeAgentId]);\n624 | \n625 |   // Handle dry-run simulation progress\n626 |   useEffect(() => {\n627 |     if (!isSimulating) return;\n628 | \n629 |     setSimulationProgress(0);\n630 |     setSimulatedLogs([]);\n631 | \n632 |     const totalDuration = 4800; // 4.8s simulation\n633 |     const intervalTime = 50; // update every 50ms\n634 |     let elapsed = 0;\n635 | \n636 |     const interval = setInterval(() => {\n637 |       elapsed += intervalTime;\n638 |       const progress = Math.min((elapsed / totalDuration) * 100, 100);\n639 |       setSimulationProgress(Math.round(progress));\n640 | \n641 |       // Stream logs matching current timeline progress\n642 |       const secondsElapsed = elapsed / 1000;\n643 |       const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n644 |       setSimulatedLogs(activeLogs);\n645 | \n646 |       if (elapsed >= totalDuration) {\n647 |         clearInterval(interval);\n648 |         setIsSimulating(false);\n649 |       }\n650 |     }, intervalTime);\n651 | \n652 |     return () => clearInterval(interval);\n653 |   }, [isSimulating, activeAgent]);\n654 | \n655 |   const [copiedStatus, setCopiedStatus] = useState(false);\n656 | \n657 |   const handleCopySchema = () => {\n658 |     if (!activeAgent.outputPreview) return;\n659 |     navigator.clipboard.writeText(activeAgent.outputPreview);\n660 |     setCopiedStatus(true);\n661 |     setTimeout(() => setCopiedStatus(false), 2000);\n662 |   };\n663 | \n664 |   // Dynamic count generators for UI indicators\n665 |   const getIndustryCount = (ind: string) => {\n666 |     if (ind === \"All Industries\") return AGENTS.length;\n667 |     return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n668 |   };\n669 | \n670 |   const getFunctionCount = (func: string) => {\n671 |     if (func === \"All Functions\") return AGENTS.length;\n672 |     return AGENTS.filter((a) => a.category === func).length;\n673 |   };\n674 | \n675 |   const getAgentTypeCount = (type: string) => {\n676 |     if (type === \"All Agent Types\") return AGENTS.length;\n677 |     return AGENTS.filter((a) => a.agentType === type).length;\n678 |   };\n679 | \n680 |   // Render modern animated connection DAG inside Sovereign Architecture Tab\n681 |   const renderSVGArchitecture = (agent: AgentDemo) => {\n682 |     return (\n683 |       <svg className=\"w-full h-full min-h-[220px]\" viewBox=\"0 0 500 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n684 |         <defs>\n685 |           <linearGradient id=\"lineGlow\" x1=\"0\" y1=\"0\" x2=\"500\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n686 |             <stop stopColor=\"#E4000F\" />\n687 |             <stop offset=\"0.5\" stopColor=\"#009DFF\" />\n688 |             <stop offset=\"1\" stopColor=\"#00FF9D\" />\n689 |           </linearGradient>\n690 |           <filter id=\"glowEffect\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n691 |             <feGaussianBlur stdDeviation=\"5\" result=\"blur\" />\n692 |             <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n693 |           </filter>\n694 |         </defs>\n695 | \n696 |         {/* Outer Boundary Box: Cryptographic Enclave */}\n697 |         <rect x=\"130\" y=\"20\" width=\"240\" height=\"180\" rx=\"16\" fill=\"rgba(4,6,11,0.7)\" stroke=\"rgba(0,157,255,0.25)\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n698 |         <text x=\"250\" y=\"212\" fill=\"rgba(255,255,255,0.35)\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" letterSpacing=\"0.1em\">\n699 |           SOVEREIGN ENCLAVE HARDWARE BOUNDARY\n700 |         </text>\n701 | \n702 |         {/* Dynamic connection lines */}\n703 |         {/* Inbound path */}\n704 |         <path d=\"M 60 110 L 130 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n705 |         <circle cx=\"100\" cy=\"110\" r=\"3\" fill=\"#E4000F\">\n706 |           <animate attributeName=\"cx\" values=\"60;130\" dur=\"2s\" repeatCount=\"indefinite\" />\n707 |         </circle>\n708 | \n709 |         {/* Enclave internal routing path */}\n710 |         <path d=\"M 180 110 L 250 65 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n711 |         <path d=\"M 180 110 L 250 155 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n712 |         <circle cx=\"215\" cy=\"87\" r=\"2.5\" fill=\"#009DFF\">\n713 |           <animate attributeName=\"cx\" values=\"180;250;320\" dur=\"3s\" repeatCount=\"indefinite\" />\n714 |         </circle>\n715 | \n716 |         {/* Outbound path */}\n717 |         <path d=\"M 370 110 L 440 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n718 |         <circle cx=\"400\" cy=\"110\" r=\"3\" fill=\"#00FF9D\">\n719 |           <animate attributeName=\"cx\" values=\"370;440\" dur=\"2.5s\" repeatCount=\"indefinite\" />\n720 |         </circle>\n721 | \n722 |         {/* Left Node: Inbound Ingress Source */}\n723 |         <circle cx=\"40\" cy=\"110\" r=\"16\" fill=\"#0c0d12\" stroke=\"#E4000F\" strokeWidth=\"1.5\" />\n724 |         <text x=\"40\" y=\"113\" fill=\"#ffffff\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">IN</text>\n725 |         <text x=\"40\" y=\"142\" fill=\"rgba(255,255,255,0.5)\" fontSize=\"7\" fontFamily=\"sans-serif\" textAnchor=\"middle\">\n726 |           {agent.ingressLabel}\n727 |         </text>\n728 | \n729 |         {/* Enclave Nodes */}\n730 |         {/* Node A: Gateway Decryptor */}\n731 |         <circle cx=\"180\" cy=\"110\" r=\"14\" fill=\"#04060b\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n732 |         <text x=\"180\" y=\"113\" fill=\"#009DFF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">DEC</text>\n733 |         <text x=\"180\" y=\"136\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">INGRESS</text>\n734 | \n735 |         {/* Node B1: Graph/Vector Processor */}\n736 |         <circle cx=\"250\" cy=\"65\" r=\"14\" fill=\"#04060b\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n737 |         <text x=\"250\" y=\"68\" fill=\"#009DFF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">DAG</text>\n738 |         <text x=\"250\" y=\"91\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">ORCHESTRATOR</text>\n739 | \n740 |         {/* Node B2: Alignment & Policies */}\n741 |         <circle cx=\"250\" cy=\"155\" r=\"14\" fill=\"#04060b\" stroke=\"#9D00FF\" strokeWidth=\"1.5\" />\n742 |         <text x=\"250\" y=\"158\" fill=\"#9D00FF\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">ALN</text>\n743 |         <text x=\"250\" y=\"181\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">ALIGNMENT</text>\n744 | \n745 |         {/* Node C: API Router & Egress */}\n746 |         <circle cx=\"320\" cy=\"110\" r=\"14\" fill=\"#04060b\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" />\n747 |         <text x=\"320\" y=\"113\" fill=\"#00FF9D\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\">EGR</text>\n748 |         <text x=\"320\" y=\"136\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">EGRESS</text>\n749 | \n750 |         {/* Right Node: Sovereign Egress Target */}\n751 |         <circle cx=\"460\" cy=\"110\" r=\"16\" fill=\"#0c0d12\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" />\n752 |         <text x=\"460\" y=\"113\" fill=\"#ffffff\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">OUT</text>\n753 |         <text x=\"460\" y=\"142\" fill=\"rgba(255,255,255,0.5)\" fontSize=\"7\" fontFamily=\"sans-serif\" textAnchor=\"middle\">\n754 |           {agent.egressLabel}\n755 |         </text>\n756 |       </svg>\n757 |     );\n758 |   };\n759 | \n760 |   return (\n761 |     <InnerPageShell>\n762 |       <InnerPageHero\n763 |         category=\"Sovereign Sandbox\"\n764 |         title=\"Agent Deployment Sandbox\"\n765 |         highlightedWord=\"Sandbox\"\n766 |         description=\"Launch real-time isolated dry-runs of enterprise agent blueprints within cryptographic hardware boundaries. Test routing protocols, safety guardrails, and platform connections using local static mocks before staging.\"\n767 |         breadcrumbs={[\n768 |           { label: \"Build Suite\", href: \"/platforms\" },\n769 |           { label: \"Sandbox Catalog\" }\n770 |         ]}\n771 |       />\n772 | \n\n[Showing lines 1-772 of 1378. Use start_line/end_line to 