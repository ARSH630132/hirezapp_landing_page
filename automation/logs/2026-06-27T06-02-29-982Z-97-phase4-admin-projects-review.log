ABLE_OWNERS.map((o) => (\n453 |                 <option key={o} value={o} className=\"text-white\">\n454 |                   {o.toUpperCase()}\n455 |                 </option>\n456 |               ))}\n457 |             </select>\n458 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n459 |           </div>\n460 |         </div>\n461 | \n462 |         {/* Filters Active Pill Indicator */}\n463 |         {(searchQuery || selectedClient || selectedPhase || selectedStatus || selectedOwner) && (\n464 |           <div className=\"flex items-center justify-between px-3.5 py-2 rounded-lg border border-dashed border-white/10 bg-white/[0.01] text-[10.5px] font-mono text-white/50 animate-in fade-in duration-200\">\n465 |             <div className=\"flex items-center gap-2\">\n466 |               <SlidersHorizontal className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n467 |               <span className=\"truncate\">\n468 |                 Active filters applied:{\" \"}\n469 |                 {[\n470 |                   searchQuery && `\"${searchQuery}\"`,\n471 |                   selectedClient && `Client: ${selectedClient.replace(\" [Preview Client]\", \"\")}`,\n472 |                   selectedPhase && `Phase: ${selectedPhase}`,\n473 |                   selectedStatus && `Status: ${selectedStatus}`,\n474 |                   selectedOwner && `Owner: ${selectedOwner}`\n475 |                 ].filter(Boolean).join(\" | \")}\n476 |               </span>\n477 |             </div>\n478 |             <button\n479 |               onClick={handleResetFilters}\n480 |               className=\"text-[#009DFF] hover:text-[#0082d4] font-bold uppercase transition-colors shrink-0 outline-none\"\n481 |             >\n482 |               Reset Filters\n483 |             </button>\n484 |           </div>\n485 |         )}\n486 |       </div>\n487 | \n488 |       {/* 4. Desktop Table View */}\n489 |       <div className=\"hidden lg:block 