{"ts":"2026-06-27T05:58:57.276Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"wr4402ez","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/projects/[id]/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { \n  ArrowLeft, Cpu, ShieldCheck, Activity, Clock, User, Briefcase, \n  Network, CheckCircle2, AlertTriangle, Terminal, Sliders, Lock, \n  RefreshCw, Play, Square, Settings, ShieldAlert\n} from \"lucide-react\";\n\ninterface AdminProject {\n  id: string;\n  name: string;\n  client: string;\n  phase: string;\n  status: string;\n  owner: string;\n  nodesCount: number;\n  enclaveType: string;\n  desc: string;\n  lastUpdated: string;\n}\n\nconst PROJECTS_REGISTRY: Record<string, AdminProject> = {\n  \"PROJ-201\": { id: \"PROJ-201\", name: \"Apex Sovereign Multi-Agent Lattice\", client: \"Apex Sovereign Group\", phase: \"Phase V: Production-Live\", status: \"On Track\", owner: \"Dr. Sarah Vance\", nodesCount: 8, enclaveType: \"Intel SGX\", desc: \"High-throughput isolated core loop with secure localized kernel telemetry and dual-layer TLS 1.3 socket.\", lastUpdated: \"2026-06-27T15:20:00Z\" },\n  \"PROJ-202\": { id: \"PROJ-202\", name: \"Global Retail Real-Time Audit Ring\", client: \"Global Retail Enclave\", phase: \"Phase IV: User Acceptance Testing\", status: \"At Risk\", owner: \"Alexander Mercer\", nodesCount: 5, enclaveType: \"AMD SEV-SNP\", desc: \"Continuous model alignment sandbox simulating extreme load, prompt injections, and runtime governance audits.\", lastUpdated: \"2026-06-27T14:10:00Z\" },\n  \"PROJ-203\": { id: \"PROJ-203\", name: \"Sovereign Logistics AI Route Optimizer\", client: \"Sovereign Logistics Unit\", phase: \"Phase III: Agent Alignment\", status: \"Paused\", owner: \"Marcus Vance\", nodesCount: 4, enclaveType: \"AWS Nitro Enclave\", desc: \"Airgapped telemetry network running geological route optimizations inside ephemeral containerized enclaves.\", lastUpdated: \"2026-06-26T18:05:00Z\" },\n  \"PROJ-204\": { id: \"PROJ-204\", name: \"Federal Treasury Multi-Enclave Ledger\", client: \"Federal Treasury Division\", phase: \"Phase II: Sandbox Provisioning\", status: \"Delayed\", owner: \"Evelyn Carter\", nodesCount: 12, enclaveType: \"Intel SGX\", desc: \"NIST-compliant hardware enclave isolating state estimation and cryptographic treasury signatures from host execution.\", lastUpdated: \"2026-06-27T09:30:00Z\" },\n  \"PROJ-205\": { id: \"PROJ-205\", name: \"National Health Secure Diagnostics Loop\", client: \"National Health Enclave\", phase: \"Phase I: Planning\", status: \"On Track\", owner: \"Auditor Jenkins\", nodesCount: 3, enclaveType: \"AMD SEV-SNP\", desc: \"Zero-Trust medical agent handshake validating eBPF kernel event streams on medical imaging diagnostic models.\", lastUpdated: \"2026-06-27T11:45:00Z\" }\n};\n\nconst PHASES_LIST = [\n  \"Phase I: Planning\",\n  \"Phase II: Sandbox Provisioning\",\n  \"Phase III: Agent Alignment\",\n  \"Phase IV: User Acceptance Testing\",\n  \"Phase V: Production-Live\"\n];\n\nexport default function AdminProjectDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const projectId = typeof id === \"string\" ? id : \"PROJ-201\";\n\n  const project: AdminProject = PROJECTS_REGISTRY[projectId] || {\n    id: projectId,\n    name: \"Dynamic Hardware Enclave Sandbox\",\n    client: \"Preview Client Enclave\",\n    phase: \"Phase III: Agent Alignment\",\n    status: \"On Track\",\n    owner: \"Dr. Sarah Vance\",\n    nodesCount: 6,\n    enclaveType: \"Intel SGX\",\n    desc: \"Transient isolated telemetry loop monitoring real-time agent handshakes and cryptographic state estimation bounds.\",\n    lastUpdated: new Date().toISOString()\n  };\n\n  const [activeTab, setActiveTab] = useState<\"architecture\" | \"compliance\" | \"resources\">(\"architecture\");\n  const [isTelemetryLive, setIsTelemetryLive] = useState(true);\n  const [isAttesting, setIsAttesting] = useState(false);\n  const [attestationCount, setAttestationCount] = useState(0);\n  const [logs, setLogs] = useState<string[]>([]);\n\n  useEffect(() => {\n    setLogs([\n      `[${new Date().toLocaleTimeString()}] INITIATING HARDWARE ROOT HANDSHAKE ON ${project.enclaveType.toUpperCase()}...`,\n      `[${new Date().toLocaleTimeString()}] ZERO-TRUST ATTESTATION: STABLE SHA-256 PARITY VERIFIED.`,\n      `[${new Date().toLocaleTimeString()}] eBPF KERNEL DETECTOR: ACTIVE ON ${project.nodesCount} CLUSTER NODES.`,\n      `[${new Date().toLocaleTimeString()}] REGISTRY STATUS: RESOLVED [${project.status.toUpperCase()}]`\n    ]);\n  }, [project]);\n\n  useEffect(() => {\n    if (!isTelemetryLive) return;\n    const interval = setInterval(() => {\n      const templates = [\n        `[${new Date().toLocaleTimeString()}] [TELEMETRY] Node cluster ${project.id}-node-${Math.floor(Math.random() * project.nodesCount) + 1} synchronized.`,\n        `[${new Date().toLocaleTimeString()}] [SECURITY] Guardrail audit: NO VIOLATIONS (Policy v4.2).`,\n        `[${new Date().toLocaleTimeString()}] [METRIC] Isolation bounds overhead: CPU 0.05%, memory stable.`,\n        `[${new Date().toLocaleTimeString()}] [ATTEST] Decoupled state cache signature verified: ${Math.random().toString(16).substring(2, 8).toUpperCase()}`\n      ];\n      setLogs(prev => [templates[Math.floor(Math.random() * templates.length)], ...prev.slice(0, 8)]);\n    }, 4500);\n    return () => clearInterval(interval);\n  }, [isTelemetryLive, project]);\n\n  const triggerAttestation = () => {\n    if (isAttesting) return;\n    setIsAttesting(true);\n    setLogs(prev => [`[${new Date().toLocaleTimeString()}] [ATTEST] Triggering hardware attestation sequence...`, ...prev]);\n    setTimeout(() => {\n      setLogs(prev => [\n        `[${new Date().toLocaleTimeString()}] [ATTEST] Parity Match: Intel/AMD keys certified (100% verified).`,\n        `[${new Date().toLocaleTimeString()}] [ATTEST] Hardware root cryptographic bounds sealed.`,\n        ...prev\n      ]);\n      setIsAttesting(false);\n      setAttestationCount(c => c + 1);\n    }, 1500);\n  };\n\n  const getStatusColor = (status: string) => {\n    if (status === \"On Track\") return \"text-emerald-400 bg-emerald-500/10 border-emerald-500/20\";\n    if (status === \"At Risk\") return \"text-amber-400 bg-amber-500/10 border-amber-500/20\";\n    if (status === \"Delayed\") return \"text-rose-400 bg-rose-500/10 border-rose-500/20\";\n    return \"text-purple-400 bg-purple-500/10 border-purple-500/20\";\n  };\n\n  const activePhaseIndex = PHASES_LIST.findIndex(p => p.startsWith(project.phase.split(\":\")[0]));\n\n  return (\n    <div className=\"space-y-6 max-w-7xl mx-auto font-mono text-xs\">\n      {/* Breadcrumb & Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n        <div className=\"flex items-start gap-3\">\n          <button\n            onClick={() => router.push(\"/admin/projects\")}\n            className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer transition-colors\"\n            title=\"Back to ledger\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">\n                Oversight Console\n              </span>\n              <span className=\"text-[9px] font-bold text-emerald-400 bg-emerald-500/5 border border-emerald-500/15 px-2 py-0.5 rounded uppercase\">\n                {project.enclaveType} Active\n              </span>\n            </div>\n            <h2 className=\"text-lg font-bold text-white tracking-tight uppercase mt-1\">\n              {project.name} <span className=\"text-white/40\">({project.id})</span>\n            </h2>\n            <p className=\"text-[11px] text-white/50 mt-0.5 leading-relaxed\">\n              Airgapped cluster telemetry and model alignment logs on global host partitions.\n            </p>\n          </div>\n        </div>\n        <Link\n          href=\"/admin/projects\"\n          className=\"h-8 px-3 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-[10px] font-bold text-white/70 hover:text-white flex items-center justify-center transition-all\"\n        >\n          Return to Registry\n        </Link>\n      </div>\n\n      {/* Stats Cards */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Sovereign Client Instance\", val: project.client.replace(\" [Preview Client]\", \"\"), desc: \"Dedicated Isolated Tenant\", icon: Briefcase },\n          { label: \"Airgapped Host Nodes\", val: `${project.nodesCount} Nodes`, desc: `${project.enclaveType} Execution Space`, icon: Network, color: \"text-[#00FFC2]\" },\n          { label: \"SLA Alignment Index\", val: project.status.toUpperCase(), desc: \"Continuous Compliance Health\", icon: Activity, pill: true },\n          { label: \"Sovereign Custodian Lead\", val: project.owner, desc: \"Clearance Level V (Oversight)\", icon: User, color: \"text-purple-400\" }\n        ].map((stat, idx) => (\n          <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-1\">\n            <div className=\"flex items-center justify-between text-white/40 text-[9px] font-bold uppercase tracking-wider\">\n              <span>{stat.label}</span>\n              <stat.icon className=\"w-3.5 h-3.5 opacity-40\" />\n            </div>\n            <div className={`text-sm font-bold truncate mt-1 ${stat.color || \"text-white\"}`}>\n              {stat.pill ? (\n                <span className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-bold ${getStatusColor(project.status)}`}>\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-current animate-pulse\" />\n                  {stat.val}\n                </span>\n              ) : stat.val}\n            </div>\n            <div className=\"text-[10px] text-white/45\">{stat.desc}</div>\n          </div>\n        ))}\n      </div>\n\n      {/* Lifecycle Timeline */}\n      <div className=\"p-4 border border-white/5 bg-[#030303]/40 rounded-xl space-y-3\">\n        <div className=\"flex items-center justify-between text-[10px]\">\n          <span className=\"font-bold text-white uppercase flex items-center gap-1.5\">\n            <Clock className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            Sovereign Lifecyle Pipeline\n          </span>\n          <span className=\"text-white/40\">Active: <strong className=\"text-white\">{project.phase}</strong></span>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-5 gap-2 pt-1\">\n          {PHASES_LIST.map((ph, idx) => {\n            const isComp = idx < activePhaseIndex;\n            const isCurr = idx === activePhaseIndex;\n            return (\n              <div key={idx} className={`p-2.5 rounded-lg border ${isCurr ? \"border-white/15 bg-white/[0.02]\" : \"border-white/5 bg-transparent\"} flex flex-col justify-between gap-2`}>\n                <div className=\"flex items-center justify-between text-[9px] text-white/30\">\n                  <span>STEP 0{idx + 1}</span>\n                  <span className={`px-1 py-0.2 rounded text-[8px] font-bold ${isComp ? \"bg-[#00FFC2]/10 text-[#00FFC2]\" : isCurr ? \"bg-[#009DFF]/10 text-[#009DFF]\" : \"bg-white/5 text-white/30\"}`}>\n                    {isComp ? \"PASSED\" : isCurr ? \"ACTIVE\" : \"QUEUED\"}\n                  </span>\n                </div>\n                <h4 className={`font-bold leading-tight ${isComp ? \"text-[#00FFC2]/80\" : isCurr ? \"text-[#009DFF]\" : \"text-white/30\"}`}>\n                  {ph.split(\": \").pop()}\n                </h4>\n                <div className=\"w-full h-1 bg-white/5 rounded-full overflow-hidden relative\">\n                  <div className={`absolute inset-y-0 left-0 transition-all duration-1000 ${isComp ? \"w-full bg-[#00FFC2]\" : isCurr ? \"w-1/2 bg-[#009DFF]\" : \"w-0\"}`} />\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </div>\n\n      {/* Double Column Grid */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        {/* Main Content Pane */}\n        <div className=\"lg:col-span-2 border border-white/5 rounded-xl bg-[#020202]/40 backdrop-blur-sm overflow-hidden shadow-[0_4px_25px_rgba(0,0,0,0.4)]\">\n          <div className=\"flex border-b border-white/5 bg-white/[0.01]\">\n            {[\n              { id: \"architecture\", label: \"Cluster Topology\", icon: Server },\n              { id: \"compliance\", label: \"Alignment Ledger\", icon: ShieldCheck },\n              { id: \"resources\", label: \"Silicon Allocations\", icon: Sliders }\n            ].map(tab => (\n              <button\n                key={tab.id}\n                onClick={() => setActiveTab(tab.id as any)}\n                className={`flex-1 py-2.5 text-center font-bold uppercase border-b-2 transition-all cursor-pointer flex items-center justify-center gap-1.5 ${\n                  activeTab === tab.id \n                    ? \"text-[#009DFF] border-[#009DFF] bg-white/[0.01]\" \n                    : \"text-white/40 border-transparent hover:text-white/60\"\n                }`}\n              >\n                <tab.icon className=\"w-3.5 h-3.5\" />\n                <span>{tab.label}</span>\n              </button>\n            ))}\n          </div>\n\n          {/* Tab contents */}\n          <div className=\"p-4 space-y-4\">\n            {activeTab === \"architecture\" && (\n              <div className=\"space-y-4 animate-in fade-in duration-200\">\n                <div className=\"relative py-6 px-4 rounded-xl border border-white/5 bg-[#040404]/80 flex flex-wrap items-center justify-center gap-5 min-h-[160px]\">\n                  <div className=\"absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.015)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.015)_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none\" />\n                  {Array.from({ length: project.nodesCount }).map((_, nIdx) => (\n                    <div key={nIdx} className=\"flex flex-col items-center gap-1 relative group\">\n                      <div className={`w-9 h-9 rounded border flex items-center justify-center transition-all relative ${\n                        !isTelemetryLive ? \"border-white/10 bg-white/5 text-white/30\" : \n                        project.status === \"On Track\" ? \"border-emerald-500/25 bg-emerald-500/5 text-emerald-400\" :\n                        project.status === \"Paused\" ? \"border-purple-500/25 bg-purple-500/5 text-purple-400\" : \"border-rose-500/25 bg-rose-500/5 text-rose-400 animate-pulse\"\n                      }`}>\n                        <Cpu className=\"w-4 h-4\" />\n                        {isTelemetryLive && (\n                          <span className={`absolute -inset-0.5 rounded border animate-ping opacity-15 ${\n                            project.status === \"On Track\" ? \"border-emerald-400\" : project.status === \"Paused\" ? \"border-purple-400\" : \"border-rose-400\"\n                          }`} style={{ animationDuration: `${2 + nIdx * 0.4}s` }} />\n                        )}\n                      </div>\n                      <span className=\"text-[8px] text-white/30 font-bold\">N-0{nIdx + 1}</span>\n                    </div>\n                  ))}\n                  <div className=\"absolute bottom-2 left-2.5 text-[8.5px] text-white/40 flex items-center gap-1.5\">\n                    <span className={`w-1 h-1 rounded-full ${isTelemetryLive ? \"bg-[#00FFC2]\" : \"bg-white/20\"}`} />\n                    <span>Telemetry pipeline: <strong className={isTelemetryLive ? \"text-[#00FFC2]\" : \"text-white/30\"}>{isTelemetryLive ? \"LIVE\" : \"PAUSED\"}</strong></span>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <div className=\"flex items-center justify-between text-[10px] text-white/50 uppercase\">\n                    <span className=\"flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5\" />eBPF Kernel audit loop</span>\n                    <button onClick={() => setLogs([`[${new Date().toLocaleTimeString()}] Logs cleared.`])} className=\"text-white/30 hover:text-white transition-colors cursor-pointer\">Clear</button>\n                  </div>\n                  <div className=\"p-3 rounded-lg bg-black border border-white/5 text-[9.5px] leading-relaxed text-white/70 h-32 overflow-y-auto space-y-1 font-mono\">\n                    {logs.map((log, idx) => (\n                      <div key={idx} className={log.includes(\"[SECURITY]\") ? \"text-[#00FFC2]\" : log.includes(\"[ATTEST]\") ? \"text-[#009DFF]\" : log.includes(\"VIOLATION\") ? \"text-rose-400\" : \"text-white/60\"}>\n                        {log}\n                      </div>\n                    ))}\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {activeTab === \"compliance\" && (\n              <div className=\"space-y-2 animate-in fade-in duration-200\">\n                {[\n                  { id: \"POL-01\", name: \"Hardware Root Attestation Signature Check\", pass: true, desc: \"NIST compliance validation of local root enclave key bounds.\" },\n                  { id: \"POL-02\", name: \"Dynamic Model Input Injection Filtering\", pass: project.status !== \"At Risk\", desc: \"Monitors agent context states for prompt jailing / overrides.\" },\n                  { id: \"POL-03\", name: \"Dual-Layer Ephemeral TLS 1.3 Handshake\", pass: project.status !== \"Delayed\", desc: \"Dynamic cryptographic pipeline alignment checks.\" },\n                  { id: \"POL-04\", name: \"eBPF Kernel Event Hook Security Audit\", pass: true, desc: \"Validates host process memory boundaries are completely airgapped.\" }\n                ].map(p => (\n                  <div key={p.id} className=\"p-2.5 rounded-lg border border-white/5 bg-black/20 flex items-start justify-between gap-3\">\n                    <div className=\"space-y-0.5\">\n                      <div className=\"flex items-center gap-1.5\">\n                        <span className=\"text-[8.5px] font-bold text-[#009DFF] bg-[#009DFF]/10 px-1 rounded\">{p.id}</span>\n                        <h4 className=\"font-bold text-white\">{p.name}</h4>\n                      </div>\n                      <p className=\"text-[9.5px] text-white/40 leading-relaxed\">{p.desc}</p>\n                    </div>\n                    {p.pass ? (\n                      <span className=\"text-[8.5px] font-bold text-emerald-400 bg-emerald-500/10 px-1.5 py-0.5 rounded border border-emerald-500/20\">VERIFIED</span>\n                    ) : (\n                      <span className=\"text-[8.5px] font-bold text-rose-400 bg-rose-500/10 px-1.5 py-0.5 rounded border border-rose-500/20 animate-pulse\">DRIFT WARNING</span>\n                    )}\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {activeTab === \"resources\" && (\n              <div className=\"space-y-3.5 animate-in fade-in duration-200\">\n                {[\n                  { title: \"Isolated EPC Memory Partition\", val: \"42.8 / 64.0 GB\", pct: \"66.8%\", color: \"bg-emerald-400\" },\n                  { title: \"Transient Secure Context Cache\", val: \"12.5 / 16.0 MB\", pct: \"78.1%\", color: \"bg-[#009DFF]\" },\n                  { title: \"Silicon Core Coreload Threshold\", val: project.status === \"At Risk\" ? \"91.2%\" : \"28.4%\", pct: project.status === \"At Risk\" ? \"91.2%\" : \"28.4%\", color: project.status === \"At Risk\" ? \"bg-rose-500\" : \"bg-purple-500\" }\n                ].map((res, i) => (\n                  <div key={i} className=\"p-3 rounded-lg border border-white/5 bg-black/10 space-y-2\">\n                    <div className=\"flex justify-between font-bold text-[10px]\">\n                      <span className=\"text-white/40 uppercase\">{res.title}</span>\n                      <span className=\"text-white\">{res.val} ({res.pct})</span>\n                    </div>\n                    <div className=\"h-1.5 bg-white/5 rounded-full overflow-hidden\">\n                      <div className={`h-full rounded-full transition-all duration-1000 ${res.color}`} style={{ width: res.pct }} />\n                    </div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Quick Actions Panel */}\n        <div className=\"space-y-5\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n              <Settings className=\"w-4 h-4 text-[#009DFF]\" />\n              <h3 className=\"font-bold text-white uppercase\">Control Deck</h3>\n            </div>\n\n            <div className=\"space-y-2\">\n              <button\n                onClick={() => {\n                  setIsTelemetryLive(!isTelemetryLive);\n                  setLogs(prev => [`[${new Date().toLocaleTimeString()}] [USER_CMD] Telemetry stream ${!isTelemetryLive ? \"RESUMED\" : \"PAUSED\"}.`, ...prev]);\n                }}\n                className={`w-full h-9 px-3 rounded border text-[10px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer ${\n                  isTelemetryLive ? \"border-amber-500/20 bg-amber-500/5 text-amber-400 hover:bg-amber-500/10\" : \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400 hover:bg-emerald-500/10\"\n                }`}\n              >\n                <span className=\"flex items-center gap-1\">{isTelemetryLive ? <Square className=\"w-3.5 h-3.5\" /> : <Play className=\"w-3.5 h-3.5\" />} Telemetry Stream</span>\n                <span className=\"text-[8px] px-1 bg-black/60 rounded border border-white/5\">{isTelemetryLive ? \"LIVE\" : \"PAUSED\"}</span>\n              </button>\n\n              <button\n                onClick={triggerAttestation}\n                disabled={isAttesting}\n                className=\"w-full h-9 px-3 rounded border border-[#009DFF]/25 bg-[#009DFF]/5 text-[#009DFF] hover:bg-[#009DFF]/10 text-[10px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer disabled:opacity-50\"\n              >\n                <span className=\"flex items-center gap-1\">\n                  <RefreshCw className={`w-3.5 h-3.5 ${isAttesting ? \"animate-spin\" : \"\"}`} />\n                  {isAttesting ? \"Attesting hardware...\" : \"Verify Attestation\"}\n                </span>\n                <span className=\"text-[8px] px-1 bg-black/60 rounded border border-white/5\">\n                  {attestationCount > 0 ? `PASS x${attestationCount}` : \"SEALED\"}\n                </span>\n              </button>\n\n              {(project.status === \"At Risk\" || project.status === \"Delayed\") && (\n                <div className=\"p-2.5 rounded border border-rose-500/20 bg-rose-500/5 text-rose-400 text-[10px] space-y-1 animate-in fade-in\">\n                  <div className=\"flex items-center gap-1 font-bold uppercase\"><ShieldAlert className=\"w-3.5 h-3.5\" /> SLA drift flag active</div>\n                  <p className=\"text-white/50 text-[9px] leading-relaxed\">Continuous governance reports compliance offsets. Please verify attestation or contact owner.</p>\n                </div>\n              )}\n            </div>\n          </div>\n\n          {/* Secure Ownership Credentials */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-3 font-mono\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n              <Lock className=\"w-4 h-4 text-purple-400\" />\n              <h3 className=\"font-bold text-white uppercase\">Sovereign Authority</h3>\n            </div>\n            <div className=\"flex items-center gap-2.5\">\n              <div className=\"w-8 h-8 rounded-full bg-purple-500/10 border border-purple-500/20 text-[#009DFF] flex items-center justify-center font-bold text-[11px]\">\n                {project.owner.split(\" \").pop()?.substring(0, 2).toUpperCase() || \"CN\"}\n              </div>\n              <div>\n                <h4 className=\"font-bold text-white\">{project.owner}</h4>\n                <span className=\"text-[8.5px] text-purple-400 font-bold uppercase block mt-0.5\">Sovereign Delivery Lead</span>\n              </div>\n            </div>\n            <div className=\"space-y-1.5 text-[9px] text-white/45 pt-2 border-t border-white/5\">\n              <div className=\"flex justify-between\"><span>Authority credentials:</span><span className=\"text-white\">CLEARANCE L-V (SECURE)</span></div>\n              <div className=\"flex justify-between\"><span>Audit certificate:</span><span className=\"text-white\">0xDF741AA8</span></div>\n              <div className=\"flex justify-between\"><span>Owner instance e-wire:</span><span className=\"text-white/80\">{project.owner.toLowerCase().replace(\"dr. \", \"\").replace(\" \", \".\")}@governance.gff.ai</span></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
