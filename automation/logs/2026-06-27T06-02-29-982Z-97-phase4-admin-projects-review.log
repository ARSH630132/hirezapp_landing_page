{"ts":"2026-06-27T05:59:25.255Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"rhukjlwm","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/projects/[id]/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { \n  ArrowLeft, Cpu, ShieldCheck, Activity, Clock, User, Briefcase, \n  Network, CheckCircle2, Terminal, Sliders, Lock, RefreshCw, Play, Square, Settings\n} from \"lucide-react\";\n\ninterface AdminProject {\n  id: string;\n  name: string;\n  client: string;\n  phase: string;\n  status: string;\n  owner: string;\n  nodesCount: number;\n  enclaveType: string;\n  desc: string;\n}\n\nconst REGISTRY: Record<string, AdminProject> = {\n  \"PROJ-201\": { id: \"PROJ-201\", name: \"Apex Sovereign Multi-Agent Lattice\", client: \"Apex Sovereign Group\", phase: \"Phase V: Production-Live\", status: \"On Track\", owner: \"Dr. Sarah Vance\", nodesCount: 8, enclaveType: \"Intel SGX\", desc: \"Isolated core loop with secure kernel telemetry.\" },\n  \"PROJ-202\": { id: \"PROJ-202\", name: \"Global Retail Real-Time Audit Ring\", client: \"Global Retail Enclave\", phase: \"Phase IV: UAT\", status: \"At Risk\", owner: \"Alexander Mercer\", nodesCount: 5, enclaveType: \"AMD SEV-SNP\", desc: \"Continuous model alignment sandbox simulating extreme loads.\" },\n  \"PROJ-203\": { id: \"PROJ-203\", name: \"Sovereign Logistics Route Optimizer\", client: \"Sovereign Logistics Unit\", phase: \"Phase III: Alignment\", status: \"Paused\", owner: \"Marcus Vance\", nodesCount: 4, enclaveType: \"AWS Nitro Enclave\", desc: \"Airgapped geological optimization route network.\" },\n  \"PROJ-204\": { id: \"PROJ-204\", name: \"Federal Treasury Multi-Enclave Ledger\", client: \"Federal Treasury Division\", phase: \"Phase II: Provisioning\", status: \"Delayed\", owner: \"Evelyn Carter\", nodesCount: 12, enclaveType: \"Intel SGX\", desc: \"NIST-compliant hardware enclave isolating signatures.\" },\n  \"PROJ-205\": { id: \"PROJ-205\", name: \"National Health Secure Diagnostics Loop\", client: \"National Health Enclave\", phase: \"Phase I: Planning\", status: \"On Track\", owner: \"Auditor Jenkins\", nodesCount: 3, enclaveType: \"AMD SEV-SNP\", desc: \"Zero-Trust medical agent handshake validating diagnostics.\" }\n};\n\nconst PHASES = [\"Planning\", \"Sandbox Provisioning\", \"Agent Alignment\", \"User Acceptance Testing\", \"Production-Live\"];\n\nexport default function AdminProjectDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const projId = typeof id === \"string\" ? id : \"PROJ-201\";\n  const project = REGISTRY[projId] || { id: projId, name: \"Sovereign Enclave Sandbox\", client: \"Sovereign Tenant Instance\", phase: \"Phase III: Agent Alignment\", status: \"On Track\", owner: \"Dr. Sarah Vance\", nodesCount: 6, enclaveType: \"Intel SGX\", desc: \"Dynamic isolated sandbox telemetry loop.\" };\n\n  const [activeTab, setActiveTab] = useState<\"topology\" | \"ledger\" | \"resources\">(\"topology\");\n  const [isLive, setIsLive] = useState(true);\n  const [isAttesting, setIsAttesting] = useState(false);\n  const [attestOk, setAttestOk] = useState(0);\n  const [logs, setLogs] = useState<string[]>([]);\n\n  useEffect(() => {\n    setLogs([\n      `[${new Date().toLocaleTimeString()}] HARDWARE ROOT HANDSHAKE ACTIVE ON ${project.enclaveType.toUpperCase()}...`,\n      `[${new Date().toLocaleTimeString()}] ZERO-TRUST ATTESTATION: STABLE PARITY MATCH.`,\n      `[${new Date().toLocaleTimeString()}] ACTIVE TELEMETRY BOUNDED ON ${project.nodesCount} CPU NODES.`,\n      `[${new Date().toLocaleTimeString()}] STATUS RESOLVED: [${project.status.toUpperCase()}]`\n    ]);\n  }, [project]);\n\n  useEffect(() => {\n    if (!isLive) return;\n    const t = setInterval(() => {\n      const templates = [\n        `[${new Date().toLocaleTimeString()}] [TELEMETRY] Node ${project.id}-node-${Math.floor(Math.random()*project.nodesCount)+1} synchronized.`,\n        `[${new Date().toLocaleTimeString()}] [SECURITY] Guardrail audit execution: NOMINAL.`,\n        `[${new Date().toLocaleTimeString()}] [METRIC] Isolation bounds overhead: CPU 0.04% stable.`,\n        `[${new Date().toLocaleTimeString()}] [ATTEST] Decoupled state cache signature verified: ${Math.random().toString(16).substring(2,8).toUpperCase()}`\n      ];\n      setLogs(p => [templates[Math.floor(Math.random()*templates.length)], ...p.slice(0, 6)]);\n    }, 5000);\n    return () => clearInterval(t);\n  }, [isLive, project]);\n\n  return (\n    <div className=\"space-y-6 max-w-7xl mx-auto font-mono text-xs text-white\">\n      {/* Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div className=\"flex items-start gap-3\">\n          <button onClick={() => router.push(\"/admin/projects\")} className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] hover:text-white text-white/50 cursor-pointer transition-colors\">\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.5 rounded uppercase\">Oversight Deck</span>\n              <span className=\"text-[9px] font-bold text-emerald-400 bg-emerald-500/5 border border-emerald-500/15 px-1.5 py-0.5 rounded uppercase\">{project.enclaveType}</span>\n            </div>\n            <h2 className=\"text-base font-bold tracking-tight uppercase mt-1\">{project.name} <span className=\"text-white/40\">({project.id})</span></h2>\n          </div>\n        </div>\n        <Link href=\"/admin/projects\" className=\"h-8 px-3 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-[10px] font-bold text-white/70 hover:text-white flex items-center justify-center transition-all\">Return to Ledger</Link>\n      </div>\n\n      {/* Grid Specs */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Tenant Client Instance\", val: project.client, desc: \"Isolated Session Domain\", icon: Briefcase },\n          { label: \"Enclave Silicon Nodes\", val: `${project.nodesCount} Nodes`, desc: `Airgapped ${project.enclaveType}`, icon: Network, color: \"text-[#00FFC2]\" },\n          { label: \"SLA Health Index\", val: project.status, desc: \"Continuous Audits Live\", icon: Activity, pill: true },\n          { label: \"Custodian Overseer\", val: project.owner, desc: \"Clearance Level V Super\", icon: User, color: \"text-purple-400\" }\n        ].map((stat, idx) => (\n          <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-1\">\n            <div className=\"flex items-center justify-between text-white/40 text-[9px] font-bold uppercase tracking-wider\">\n              <span>{stat.label}</span>\n              <stat.icon className=\"w-3.5 h-3.5 opacity-40\" />\n            </div>\n            <div className={`text-xs font-bold truncate mt-1 ${stat.color || \"text-white\"}`}>\n              {stat.pill ? (\n                <span className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[9px] font-bold ${project.status === \"On Track\" ? \"text-emerald-400 bg-emerald-500/10 border border-emerald-500/20\" : project.status === \"At Risk\" ? \"text-amber-400 bg-amber-500/10 border border-amber-500/20\" : \"text-rose-400 bg-rose-500/10 border border-rose-500/20\"}`}>\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-current animate-pulse\" /> {stat.val.toUpperCase()}\n                </span>\n              ) : stat.val}\n            </div>\n            <div className=\"text-[10px] text-white/45\">{stat.desc}</div>\n          </div>\n        ))}\n      </div>\n\n      {/* Timeline */}\n      <div className=\"p-4 border border-white/5 bg-[#030303]/40 rounded-xl space-y-2\">\n        <span className=\"font-bold text-white uppercase flex items-center gap-1 text-[10px]\"><Clock className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Sovereign Lifecycle</span>\n        <div className=\"grid grid-cols-1 md:grid-cols-5 gap-2 pt-1 text-[10px]\">\n          {PHASES.map((p, idx) => (\n            <div key={idx} className=\"p-2 rounded border border-white/5 bg-transparent space-y-1\">\n              <div className=\"flex justify-between text-[8px] text-white/30\"><span>STEP 0{idx+1}</span><span className=\"font-bold text-white/60\">{idx === 2 ? \"ACTIVE\" : \"VERIFIED\"}</span></div>\n              <h4 className=\"font-bold text-white/70 truncate\">{p}</h4>\n              <div className=\"h-0.5 bg-white/5 rounded\"><div className={`h-full bg-[#009DFF] ${idx <= 2 ? \"w-full\" : \"w-0\"}`} /></div>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Main Panel */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 border border-white/5 rounded-xl bg-[#020202]/40 backdrop-blur-sm overflow-hidden\">\n          <div className=\"flex border-b border-white/5 bg-white/[0.01]\">\n            {[\n              { id: \"topology\", label: \"Cluster Nodes\", icon: Network },\n              { id: \"ledger\", label: \"Policy Ledger\", icon: ShieldCheck },\n              { id: \"resources\", label: \"Silicon Memory\", icon: Sliders }\n            ].map(tab => (\n              <button key={tab.id} onClick={() => setActiveTab(tab.id as any)} className={`flex-1 py-2 text-center font-bold uppercase border-b-2 transition-all cursor-pointer flex items-center justify-center gap-1.5 ${activeTab === tab.id ? \"text-[#009DFF] border-[#009DFF] bg-white/[0.01]\" : \"text-white/40 border-transparent hover:text-white/60\"}`}>\n                <tab.icon className=\"w-3.5 h-3.5\" /> {tab.label}\n              </button>\n            ))}\n          </div>\n\n          <div className=\"p-4\">\n            {activeTab === \"topology\" && (\n              <div className=\"space-y-4\">\n                <div className=\"relative py-6 rounded border border-white/5 bg-[#040404]/80 flex flex-wrap items-center justify-center gap-4 min-h-[120px]\">\n                  {Array.from({ length: project.nodesCount }).map((_, i) => (\n                    <div key={i} className=\"flex flex-col items-center gap-0.5\">\n                      <div className={`w-8 h-8 rounded border flex items-center justify-center ${isLive ? \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400\" : \"border-white/10 bg-white/5 text-white/35\"}`}>\n                        <Cpu className=\"w-3.5 h-3.5\" />\n                      </div>\n                      <span className=\"text-[8px] text-white/30\">N-0{i+1}</span>\n                    </div>\n                  ))}\n                  <span className=\"absolute bottom-1.5 left-2 text-[8px] text-white/40 flex items-center gap-1\"><span className={`w-1 h-1 rounded-full ${isLive ? \"bg-[#00FFC2]\" : \"bg-white/20\"}`} /> Telemetry Link: {isLive ? \"ACTIVE\" : \"PAUSED\"}</span>\n                </div>\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between text-[9px] text-white/40 uppercase font-bold\"><span><Terminal className=\"w-3.5 h-3.5 inline mr-1\" />eBPF Live Stream Logs</span><button onClick={() => setLogs([`[${new Date().toLocaleTimeString()}] Logs reset.`])} className=\"hover:text-white transition-colors cursor-pointer\">Scrub</button></div>\n                  <div className=\"p-3 rounded-lg bg-black border border-white/5 text-[9px] leading-relaxed text-white/70 h-28 overflow-y-auto space-y-1 font-mono\">\n                    {logs.map((log, idx) => (\n                      <div key={idx} className={log.includes(\"[TELEMETRY]\") ? \"text-[#00FFC2]\" : log.includes(\"[ATTEST]\") ? \"text-[#009DFF]\" : \"text-white/55\"}>{log}</div>\n                    ))}\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {activeTab === \"ledger\" && (\n              <div className=\"space-y-2\">\n                {[\n                  { id: \"POL-01\", name: \"Silicon Hardware Key Attestation Trace\", pass: true },\n                  { id: \"POL-02\", name: \"Dynamic Host Jailbreak Input Sniffer Check\", pass: project.status !== \"At Risk\" },\n                  { id: \"POL-03\", name: \"TLS 1.3 Ephemeral Cryptographic Key Socket Check\", pass: true }\n                ].map(p => (\n                  <div key={p.id} className=\"p-2 rounded border border-white/5 bg-black/15 flex items-center justify-between text-[10px]\">\n                    <div>\n                      <span className=\"text-[8.5px] text-[#009DFF] bg-[#009DFF]/10 px-1 rounded mr-1.5 font-bold\">{p.id}</span>\n                      <span className=\"font-bold text-white/80\">{p.name}</span>\n                    </div>\n                    <span className={`text-[8px] font-bold px-1 rounded border ${p.pass ? \"text-emerald-400 border-emerald-500/25 bg-emerald-500/5\" : \"text-rose-400 border-rose-500/25 bg-rose-500/5\"}`}>{p.pass ? \"PASSED\" : \"ALERT\"}</span>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {activeTab === \"resources\" && (\n              <div className=\"space-y-3\">\n                {[\n                  { title: \"EPC Isolated Memory Page Allocation\", val: \"42.8 GB / 64 GB\", pct: \"66.8%\", col: \"bg-emerald-400\" },\n                  { title: \"State Context Cache Register Buffer\", val: \"12.5 MB / 16 MB\", pct: \"78.1%\", col: \"bg-[#009DFF]\" }\n                ].map((res, idx) => (\n                  <div key={idx} className=\"p-2.5 rounded border border-white/5 bg-black/5 space-y-1.5\">\n                    <div className=\"flex justify-between text-[9px] text-white/40 font-bold uppercase\"><span>{res.title}</span><span className=\"text-white\">{res.val}</span></div>\n                    <div className=\"h-1 bg-white/5 rounded-full\"><div className={`h-full rounded-full ${res.col}`} style={{ width: res.pct }} /></div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Controls */}\n        <div className=\"space-y-4\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-3\">\n            <div className=\"flex items-center gap-1 border-b border-white/5 pb-2\"><Settings className=\"w-3.5 h-3.5 text-[#009DFF]\" /><h3 className=\"font-bold text-white uppercase\">Control Desk</h3></div>\n            <div className=\"space-y-2\">\n              <button onClick={() => { setIsLive(!isLive); setLogs(l => [`[${new Date().toLocaleTimeString()}] Telemetry flow toggled ${!isLive ? \"ON\" : \"OFF\"}.`, ...l]); }} className={`w-full h-8 px-2.5 rounded border text-[9px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer ${isLive ? \"border-amber-500/20 text-amber-400 bg-amber-500/5\" : \"border-emerald-500/20 text-emerald-400 bg-emerald-500/5\"}`}>\n                <span className=\"flex items-center gap-1\">{isLive ? <Square className=\"w-3 h-3\" /> : <Play className=\"w-3 h-3\" />} Telemetry stream</span>\n                <span className=\"text-[8px] px-1 bg-black/60 border border-white/5 rounded\">{isLive ? \"LIVE\" : \"PAUSED\"}</span>\n              </button>\n\n              <button onClick={triggerAttestation} disabled={isAttesting} className=\"w-full h-8 px-2.5 rounded border border-[#009DFF]/25 bg-[#009DFF]/5 text-[#009DFF] text-[9px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer disabled:opacity-50\">\n                <span className=\"flex items-center gap-1\"><RefreshCw className={`w-3 h-3 ${isAttesting ? \"animate-spin\" : \"\"}`} /> {isAttesting ? \"Attesting Hardware...\" : \"Verify Attestation\"}</span>\n                <span className=\"text-[8px] px-1 bg-black/60 border border-white/5 rounded\">{attestOk > 0 ? `PASS x${attestOk}` : \"SEALED\"}</span>\n              </button>\n            </div>\n          </div>\n\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 text-[9px] text-white/45 font-mono\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-1.5\"><Lock className=\"w-3.5 h-3.5 text-purple-400\" /><h3 className=\"font-bold text-white uppercase\">Secure Custodian</h3></div>\n            <div className=\"flex items-center gap-2\">\n              <div className=\"w-7 h-7 rounded-full bg-purple-500/10 border border-purple-500/20 text-[#009DFF] flex items-center justify-center font-bold text-[10px]\">{project.owner.split(\" \").pop()?.substring(0,2).toUpperCase()}</div>\n              <div><h4 className=\"font-bold text-white\">{project.owner}</h4><span className=\"text-[8px] text-purple-400 font-bold uppercase mt-0.5 block\">SLA Lead Custodian</span></div>\n            </div>\n            <div className=\"space-y-1 pt-1.5 border-t border-white/5\">\n              <div className=\"flex justify-between\"><span>Authority:</span><span className=\"text-white\">CLEARANCE L-V (SECURE)</span></div>\n              <div className=\"flex justify-between\"><span>Audit Key:</span><span className=\"text-white\">0xDF741AA8</span></div>\n              <div className=\"flex justify-between truncate\"><span>E-wire:</span><span className=\"text-white/80\">{project.owner.toLowerCase().replace(\"dr. \", \"\").replace(\" \", \".\")}@governance.gff.ai</span></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
