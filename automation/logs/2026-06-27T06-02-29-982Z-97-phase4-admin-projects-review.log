{"ts":"2026-06-27T05:59:50.637Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ge53pe1l","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/projects/[id]/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { ArrowLeft, Cpu, ShieldCheck, Activity, Clock, User, Briefcase, Network, Terminal, Sliders, Lock, RefreshCw, Play, Square, Settings } from \"lucide-react\";\n\ninterface Proj { id: string; name: string; client: string; phase: string; status: string; owner: string; nodes: number; type: string; }\n\nconst REGISTRY: Record<string, Proj> = {\n  \"PROJ-201\": { id: \"PROJ-201\", name: \"Apex Sovereign Multi-Agent Lattice\", client: \"Apex Sovereign Group\", phase: \"Phase V: Production-Live\", status: \"On Track\", owner: \"Dr. Sarah Vance\", nodes: 8, type: \"Intel SGX\" },\n  \"PROJ-202\": { id: \"PROJ-202\", name: \"Global Retail Real-Time Audit Ring\", client: \"Global Retail Enclave\", phase: \"Phase IV: UAT\", status: \"At Risk\", owner: \"Alexander Mercer\", nodes: 5, type: \"AMD SEV-SNP\" },\n  \"PROJ-203\": { id: \"PROJ-203\", name: \"Sovereign Logistics AI Optimizer\", client: \"Sovereign Logistics Unit\", phase: \"Phase III: Alignment\", status: \"Paused\", owner: \"Marcus Vance\", nodes: 4, type: \"AWS Nitro Enclave\" },\n  \"PROJ-204\": { id: \"PROJ-204\", name: \"Federal Treasury Multi-Enclave Ledger\", client: \"Federal Treasury Division\", phase: \"Phase II: Provisioning\", status: \"Delayed\", owner: \"Evelyn Carter\", nodes: 12, type: \"Intel SGX\" },\n  \"PROJ-205\": { id: \"PROJ-205\", name: \"National Health Secure Diagnostics\", client: \"National Health Enclave\", phase: \"Phase I: Planning\", status: \"On Track\", owner: \"Auditor Jenkins\", nodes: 3, type: \"AMD SEV-SNP\" }\n};\n\nconst PHASES = [\"Planning\", \"Sandbox Provisioning\", \"Agent Alignment\", \"User Acceptance Testing\", \"Production-Live\"];\n\nexport default function AdminProjectDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const projId = typeof id === \"string\" ? id : \"PROJ-201\";\n  const p = REGISTRY[projId] || { id: projId, name: \"Sovereign Enclave Sandbox\", client: \"Tenant Instance\", phase: \"Phase III: Agent Alignment\", status: \"On Track\", owner: \"Dr. Sarah Vance\", nodes: 6, type: \"Intel SGX\" };\n\n  const [activeTab, setActiveTab] = useState<\"topology\" | \"ledger\" | \"resources\">(\"topology\");\n  const [isLive, setIsLive] = useState(true);\n  const [isAttesting, setIsAttesting] = useState(false);\n  const [attestOk, setAttestOk] = useState(0);\n  const [logs, setLogs] = useState<string[]>([]);\n\n  useEffect(() => {\n    setLogs([\n      `[${new Date().toLocaleTimeString()}] ROOT HANDSHAKE ACTIVE ON ${p.type.toUpperCase()}...`,\n      `[${new Date().toLocaleTimeString()}] ZERO-TRUST ATTESTATION: STABLE PARITY MATCH.`,\n      `[${new Date().toLocaleTimeString()}] ACTIVE TELEMETRY BOUNDED ON ${p.nodes} CPU NODES.`,\n      `[${new Date().toLocaleTimeString()}] STATUS RESOLVED: [${p.status.toUpperCase()}]`\n    ]);\n  }, [p]);\n\n  useEffect(() => {\n    if (!isLive) return;\n    const t = setInterval(() => {\n      const templates = [\n        `[${new Date().toLocaleTimeString()}] [TELEMETRY] Node ${p.id}-node-${Math.floor(Math.random()*p.nodes)+1} synchronized.`,\n        `[${new Date().toLocaleTimeString()}] [SECURITY] Guardrail audit execution: NOMINAL.`,\n        `[${new Date().toLocaleTimeString()}] [METRIC] Isolation bounds overhead: CPU 0.04% stable.`,\n        `[${new Date().toLocaleTimeString()}] [ATTEST] State cache verified: ${Math.random().toString(16).substring(2,8).toUpperCase()}`\n      ];\n      setLogs(prev => [templates[Math.floor(Math.random()*templates.length)], ...prev.slice(0, 5)]);\n    }, 5000);\n    return () => clearInterval(t);\n  }, [isLive, p]);\n\n  return (\n    <div className=\"space-y-6 max-w-7xl mx-auto font-mono text-xs text-white\">\n      {/* Header */}\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div className=\"flex items-start gap-3\">\n          <button onClick={() => router.push(\"/admin/projects\")} className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] hover:text-white text-white/50 cursor-pointer transition-colors\">\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.5 rounded uppercase\">Oversight Deck</span>\n              <span className=\"text-[9px] font-bold text-emerald-400 bg-emerald-500/5 border border-emerald-500/15 px-1.5 py-0.5 rounded uppercase\">{p.type}</span>\n            </div>\n            <h2 className=\"text-base font-bold tracking-tight uppercase mt-1\">{p.name} <span className=\"text-white/40\">({p.id})</span></h2>\n          </div>\n        </div>\n        <Link href=\"/admin/projects\" className=\"h-8 px-3 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-[10px] font-bold text-white/70 hover:text-white flex items-center justify-center transition-all\">Return to Ledger</Link>\n      </div>\n\n      {/* Grid Specs */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Tenant Client Instance\", val: p.client, desc: \"Isolated Session Domain\", icon: Briefcase },\n          { label: \"Enclave Silicon Nodes\", val: `${p.nodes} Nodes`, desc: `Airgapped ${p.type}`, icon: Network, color: \"text-[#00FFC2]\" },\n          { label: \"SLA Health Index\", val: p.status, desc: \"Continuous Audits Live\", icon: Activity, pill: true },\n          { label: \"Custodian Overseer\", val: p.owner, desc: \"Clearance Level V Super\", icon: User, color: \"text-purple-400\" }\n        ].map((stat, idx) => (\n          <div key={idx} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-1\">\n            <div className=\"flex items-center justify-between text-white/40 text-[9px] font-bold uppercase tracking-wider\">\n              <span>{stat.label}</span>\n              <stat.icon className=\"w-3.5 h-3.5 opacity-40\" />\n            </div>\n            <div className={`text-xs font-bold truncate mt-1 ${stat.color || \"text-white\"}`}>\n              {stat.pill ? (\n                <span className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[9px] font-bold ${p.status === \"On Track\" ? \"text-emerald-400 bg-emerald-500/10 border border-emerald-500/20\" : p.status === \"At Risk\" ? \"text-amber-400 bg-amber-500/10 border border-amber-500/20\" : \"text-rose-400 bg-rose-500/10 border border-rose-500/20\"}`}>\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-current animate-pulse\" /> {stat.val.toUpperCase()}\n                </span>\n              ) : stat.val}\n            </div>\n            <div className=\"text-[10px] text-white/45\">{stat.desc}</div>\n          </div>\n        ))}\n      </div>\n\n      {/* Timeline */}\n      <div className=\"p-4 border border-white/5 bg-[#030303]/40 rounded-xl space-y-2\">\n        <span className=\"font-bold text-white uppercase flex items-center gap-1 text-[10px]\"><Clock className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Sovereign Lifecycle</span>\n        <div className=\"grid grid-cols-1 md:grid-cols-5 gap-2 pt-1 text-[10px]\">\n          {PHASES.map((phase, idx) => (\n            <div key={idx} className=\"p-2 rounded border border-white/5 bg-transparent space-y-1\">\n              <div className=\"flex justify-between text-[8px] text-white/30\"><span>STEP 0{idx+1}</span><span className=\"font-bold text-white/60\">{idx === 2 ? \"ACTIVE\" : \"VERIFIED\"}</span></div>\n              <h4 className=\"font-bold text-white/70 truncate\">{phase}</h4>\n              <div className=\"h-0.5 bg-white/5 rounded\"><div className={`h-full bg-[#009DFF] ${idx <= 2 ? \"w-full\" : \"w-0\"}`} /></div>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Main Panel */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 border border-white/5 rounded-xl bg-[#020202]/40 backdrop-blur-sm overflow-hidden\">\n          <div className=\"flex border-b border-white/5 bg-white/[0.01]\">\n            {[\n              { id: \"topology\", label: \"Cluster Nodes\", icon: Network },\n              { id: \"ledger\", label: \"Policy Ledger\", icon: ShieldCheck },\n              { id: \"resources\", label: \"Silicon Memory\", icon: Sliders }\n            ].map(tab => (\n              <button key={tab.id} onClick={() => setActiveTab(tab.id as any)} className={`flex-1 py-2 text-center font-bold uppercase border-b-2 transition-all cursor-pointer flex items-center justify-center gap-1.5 ${activeTab === tab.id ? \"text-[#009DFF] border-[#009DFF] bg-white/[0.01]\" : \"text-white/40 border-transparent hover:text-white/60\"}`}>\n                <tab.icon className=\"w-3.5 h-3.5\" /> {tab.label}\n              </button>\n            ))}\n          </div>\n\n          <div className=\"p-4\">\n            {activeTab === \"topology\" && (\n              <div className=\"space-y-4\">\n                <div className=\"relative py-6 rounded border border-white/5 bg-[#040404]/80 flex flex-wrap items-center justify-center gap-4 min-h-[120px]\">\n                  {Array.from({ length: p.nodes }).map((_, i) => (\n                    <div key={i} className=\"flex flex-col items-center gap-0.5\">\n                      <div className={`w-8 h-8 rounded border flex items-center justify-center ${isLive ? \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400\" : \"border-white/10 bg-white/5 text-white/35\"}`}>\n                        <Cpu className=\"w-3.5 h-3.5\" />\n                      </div>\n                      <span className=\"text-[8px] text-white/30\">N-0{i+1}</span>\n                    </div>\n                  ))}\n                  <span className=\"absolute bottom-1.5 left-2.5 text-[8px] text-white/40 flex items-center gap-1\"><span className={`w-1 h-1 rounded-full ${isLive ? \"bg-[#00FFC2]\" : \"bg-white/20\"}`} /> Telemetry Link: {isLive ? \"ACTIVE\" : \"PAUSED\"}</span>\n                </div>\n                <div className=\"space-y-1\">\n                  <div className=\"flex justify-between text-[9px] text-white/40 uppercase font-bold\"><span><Terminal className=\"w-3.5 h-3.5 inline mr-1\" />eBPF Live Stream Logs</span><button onClick={() => setLogs([`[${new Date().toLocaleTimeString()}] Logs reset.`])} className=\"hover:text-white transition-colors cursor-pointer\">Scrub</button></div>\n                  <div className=\"p-3 rounded-lg bg-black border border-white/5 text-[9px] leading-relaxed text-white/70 h-28 overflow-y-auto space-y-1 font-mono\">\n                    {logs.map((log, idx) => (\n                      <div key={idx} className={log.includes(\"[TELEMETRY]\") ? \"text-[#00FFC2]\" : log.includes(\"[ATTEST]\") ? \"text-[#009DFF]\" : \"text-white/55\"}>{log}</div>\n                    ))}\n                  </div>\n                </div>\n              </div>\n            )}\n\n            {activeTab === \"ledger\" && (\n              <div className=\"space-y-2\">\n                {[\n                  { id: \"POL-01\", name: \"Silicon Hardware Key Attestation Trace\", pass: true },\n                  { id: \"POL-02\", name: \"Dynamic Host Jailbreak Input Sniffer Check\", pass: p.status !== \"At Risk\" },\n                  { id: \"POL-03\", name: \"TLS 1.3 Ephemeral Cryptographic Key Socket Check\", pass: true }\n                ].map(policy => (\n                  <div key={policy.id} className=\"p-2 rounded border border-white/5 bg-black/15 flex items-center justify-between text-[10px]\">\n                    <div>\n                      <span className=\"text-[8.5px] text-[#009DFF] bg-[#009DFF]/10 px-1 rounded mr-1.5 font-bold\">{policy.id}</span>\n                      <span className=\"font-bold text-white/80\">{policy.name}</span>\n                    </div>\n                    <span className={`text-[8px] font-bold px-1 rounded border ${policy.pass ? \"text-emerald-400 border-emerald-500/25 bg-emerald-500/5\" : \"text-rose-400 border-rose-500/25 bg-rose-500/5\"}`}>{policy.pass ? \"PASSED\" : \"ALERT\"}</span>\n                  </div>\n                ))}\n              </div>\n            )}\n\n            {activeTab === \"resources\" && (\n              <div className=\"space-y-3\">\n                {[\n                  { title: \"EPC Isolated Memory Page Allocation\", val: \"42.8 GB / 64 GB\", pct: \"66.8%\", col: \"bg-emerald-400\" },\n                  { title: \"State Context Cache Register Buffer\", val: \"12.5 MB / 16 MB\", pct: \"78.1%\", col: \"bg-[#009DFF]\" }\n                ].map((res, idx) => (\n                  <div key={idx} className=\"p-2.5 rounded border border-white/5 bg-black/5 space-y-1.5\">\n                    <div className=\"flex justify-between text-[9px] text-white/40 font-bold uppercase\"><span>{res.title}</span><span className=\"text-white\">{res.val}</span></div>\n                    <div className=\"h-1 bg-white/5 rounded-full\"><div className={`h-full rounded-full ${res.col}`} style={{ width: res.pct }} /></div>\n                  </div>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Controls */}\n        <div className=\"space-y-4\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-3\">\n            <div className=\"flex items-center gap-1 border-b border-white/5 pb-2\"><Settings className=\"w-3.5 h-3.5 text-[#009DFF]\" /><h3 className=\"font-bold text-white uppercase\">Control Deck</h3></div>\n            <div className=\"space-y-2\">\n              <button onClick={() => { setIsLive(!isLive); setLogs(l => [`[${new Date().toLocaleTimeString()}] Telemetry stream toggled ${!isLive ? \"ON\" : \"OFF\"}.`, ...l]); }} className={`w-full h-8 px-2.5 rounded border text-[9px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer ${isLive ? \"border-amber-500/20 text-amber-400 bg-amber-500/5\" : \"border-emerald-500/20 text-emerald-400 bg-emerald-500/5\"}`}>\n                <span className=\"flex items-center gap-1\">{isLive ? <Square className=\"w-3 h-3\" /> : <Play className=\"w-3 h-3\" />} Telemetry stream</span>\n                <span className=\"text-[8px] px-1 bg-black/60 border border-white/5 rounded\">{isLive ? \"LIVE\" : \"PAUSED\"}</span>\n              </button>\n\n              <button onClick={() => { if (isAttesting) return; setIsAttesting(true); setTimeout(() => { setIsAttesting(false); setAttestOk(c => c + 1); }, 1500); }} disabled={isAttesting} className=\"w-full h-8 px-2.5 rounded border border-[#009DFF]/25 bg-[#009DFF]/5 text-[#009DFF] text-[9px] font-bold uppercase transition-all flex items-center justify-between cursor-pointer disabled:opacity-50\">\n                <span className=\"flex items-center gap-1\"><RefreshCw className={`w-3 h-3 ${isAttesting ? \"animate-spin\" : \"\"}`} /> {isAttesting ? \"Attesting...\" : \"Verify Attestation\"}</span>\n                <span className=\"text-[8px] px-1 bg-black/60 border border-white/5 rounded\">{attestOk > 0 ? `PASS x${attestOk}` : \"SEALED\"}</span>\n              </button>\n            </div>\n          </div>\n\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 text-[9px] text-white/45 font-mono\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-1.5\"><Lock className=\"w-3.5 h-3.