   ))}\n421 |               </select>\n422 |               <SlidersHorizontal className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n423 |             </div>\n424 | \n425 |             {(statusFilter || regionFilter || industryFilter || searchQuery) && (\n426 |               <button \n427 |                 onClick={() => {\n428 |                   setStatusFilter(\"\");\n429 |                   setRegionFilter(\"\");\n430 |                   setIndustryFilter(\"\");\n431 |                   setSearchQuery(\"\");\n432 |                 }}\n433 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 hover:bg-red-500/5 text-red-400 font-mono text-[11px] transition-all cursor-pointer uppercase font-bold\"\n434 |               >\n435 |                 Reset Filters\n436 |               </button>\n437 |             )}\n438 | \n439 |           </div>\n440 | \n441 |         </div>\n442 |       </div>\n443 | \n444 |       {/* TENANT REGISTRY TABLE */}\n445 |       {filteredClients.length === 0 ? (\n446 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm p-12 text-center font-mono space-y-3\">\n447 |           <div className=\"mx-auto w-12 h-12 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center text-white/30\">\n448 |             <ShieldAlert className=\"w-6 h-6\" />\n449 |           </div>\n450 |           <h3 className=\"text-white font-semibold text-[13px] uppercase\">No Matching Sovereign Tenants</h3>\n451 |           <p className=\"text-white/40 text-[11px] max-w-md mx-auto\">\n452 |             No active administrative partitions meet the specified search query or enclave filter parameters.\n453 |           </p>\n454 |           <button \n455 |             onClick={() => {\n456 |               setStatusFilter(\"\");\n457 |               setRegionFilter(\"\");\n458 |               setIndustryFilter(\"\");\n459 |               setSearchQuery(\"\");\n460 |             }}\n461 |             className=\"px-3 py-1.5 rounded border border-white/10 hover:bg-white/5 text-white text-[11px] transition-all cursor-pointer uppercase font-bold\"\n462 |           >\n463 |             Clear Active Filter Parameters\n464 |           </button>\n465 |         </div>\n466 |       ) : (\n467 |         <div className=\"overflow-hidden rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm\">\n468 |           <div className=\"overflow-x-auto\">\n469 |             <table className=\"w-full text-left border-collapse font-mono text-[11.5px]\" role=\"grid\">\n470 |               <thead>\n471 |                 <tr className=\"border-b border-white/5 bg-white/[0.01]\" role=\"row\">\n472 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Tenant / Namespace</th>\n473 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Industry</th>\n474 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Region & Tier</th>\n475 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Account Owner</th>\n476 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Enclaves</th>\n477 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Billing Preview</th>\n478 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Health Status</th>\n479 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-right\">Actions</th>\n480 |                 </tr>\n481 |               </thead>\n482 |               <tbody className=\"divide-y divide-white/[0.03]\">\n483 |                 {filteredClients.map((client) => {\n484 |                   const projectsCount = getProjectsForClient(client.id).length;\n485 |                   const agentsCount = getAgentOpsForClient(client.id).length;\n486 | \n487 |                   return (\n488 |                     <tr \n489 |                       key={client.id}\n490 |                       onClick={() => {\n491 |                         setSelectedClient(client);\n492 |                         setDrawerTab(\"overview\");\n493 |                       }}\n494 |                       className=\"hover:bg-white/[0.01] transition-all cursor-pointer group\"\n495 |                       role=\"row\"\n496 |                     >\n497 |                       \n498 |                       {/* Name / Domain */}\n499 |                       <td className=\"p-4\">\n500 |                         <div className=\"space-y-1 max-w-[200px]\">\n501 |                           <div className=\"flex items-center gap-1.5\">\n502 |                             <span className=\"font-bold text-white group-hover:text-[#009DFF] transition-colors\">{client.name}</span>\n503 |                             {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400 shrink-0\" />}\n504 |                           </div>\n505 |                           <div className=\"text-[10px] text-white/40 flex items-center gap-1.5 font-mono\">\n506 |                             <span className=\"text-[#009DFF]\">{client.domain}</span>\n507 |                             <span>•</span>\n508 |                             <span \n509 |                               onClick={(e) => handleCopyId(client.id, e)}\n510 |                               className=\"hover:text-white transition-colors cursor-pointer flex items-center gap-0.5\"\n511 |                             >\n512 |                               {client.id.toUpperCase()}\n513 |                               {copiedId === client.id ? <Check className=\"w-2.5 h-2.5 text-emerald-400\" /> : <Copy className=\"w-2.5 h-2.5 opacity-50 hover:opacity-100\" />}\n514 |                             </span>\n515 |                           </div>\n516 |                         </div>\n517 |                       </td>\n518 | \n519 |                       {/* Industry */}\n520 |                       <td className=\"p-4 text-white/70\">\n521 |                         <div className=\"flex items-center gap-1.5\">\n522 |                           <Building className=\"w-3.5 h-3.5 text-white/30\" />\n523 |                           <span>{client.industry}</span>\n524 |                         </div>\n525 |                       </td>\n526 | \n527 |                       {/* Region & Tier */}\n528 |                       <td className=\"p-4\">\n529 |                         <div className=\"space-y-1\">\n530 |                           <div className=\"flex items-center gap-1.5 text-white/80\">\n531 |                             <Globe className=\"w-3.5 h-3.5 text-white/30\" />\n532 |                             <span>{client.region}</span>\n533 |                           </div>\n534 |                           <div>{getTierBadge(client.tier)}</div>\n535 |                         </div>\n536 |                       </td>\n537 | \n538 |                       {/* Account Owner */}\n539 |                       <td className=\"p-4\">\n540 |                         <div className=\"flex items-center gap-2\">\n541 |                           <div className=\"w-5 h-5 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 font-mono text-[9px] font-bold\">\n542 |                             {client.accountOwner.split(\" \").pop()?.[0]}\n543 |                           </div>\n544 |                           <div className=\"space-y-0.5\">\n545 |                             <span className=\"text-white font-medium\">{client.accountOwner}</span>\n546 |                             <span \n547 |                               onClick={(e) => handleOpenAssignOwner(client, e)}\n548 |                               className=\"text-[9px] text-[#009DFF] hover:underline cursor-pointer block\"\n549 |                             >\n550 |                               Re-assign owner\n551 |                             </span>\n552 |                           </div>\n553 |                         </div>\n554 |                       </td>\n555 | \n556 |                       {/* Active Counts */}\n557 |                       <td className=\"p-4 text-center\">\n558 |                         <div className=\"inline-flex flex-col items-center gap-1\">\n559 |                           <span className=\"text-white font-bold\">{projectsCount}</span>\n560 |                           <span className=\"text-[9px] text-white/30 uppercase tracking-wider\">{projectsCount === 1 ? \"Project\" : \"Projects\"}</span>\n561 |                           {agentsCount > 0 && (\n562 |                             <span className=\"text-[9px] text-emerald-400/80 font-semibold uppercase\">\n563 |                               {agentsCount} Live {agentsCount === 1 ? \"Agent\" : \"Agents\"}\n564 |                             </span>\n565 |                           )}\n566 |                         </div>\n567 |                       </td>\n568 | \n569 |                       {/* Billing Status */}\n570 |                       <td className=\"p-4 text-center\">\n571 |                         {getBillingBadge(client.billingStatus)}\n572 |                       </td>\n573 | \n574 |                       {/* Health Status */}\n575 |                       <td className=\"p-4 text-center\">\n576 |                         {getHealthBadge(client.healthStatus)}\n577 |                       </td>\n578 | \n579 |                       {/* Actions */}\n580 |                       <td className=\"p-4 text-right\" onClick={(e) => e.stopPropagation()}>\n581 |                         <div className=\"flex items-center justify-end gap-2\">\n582 |                           <button\n583 |                             onClick={(e) => handleInitiateHandshake(client, e)}\n584 |                             className=\"h-7 px-2.5 rounded border border-[#009DFF]/30 bg-[#009DFF]/5 hover:bg-[#009DFF]/15 text-[#009DFF] text-[10px] font-bold uppercase flex items-center gap-1 transition-all cursor-pointer\"\n585 |                             title=\"Mirror Client Portal\"\n586 |                           >\n587 |                             <ExternalLink className=\"w-3 h-3\" />\n588 |                             <span>Preview Portal</span>\n589 |                           </button>\n590 |                           \n591 |                           <button\n592 |                             onClick={() => {\n593 |                               setSelectedClient(client);\n594 |                               setDrawerTab(\"overview\");\n595 |                             }}\n596 |                             className=\"h-7 w-7 rounded border border-white/5 hover:border-white/15 hover:bg-white/5 text-white/50 hover:text-white flex items-center justify-center transition-all cursor-pointer\"\n597 |                             title=\"Open Telemetry Ledger\"\n598 |                           >\n599 |                             <ChevronRight className=\"w-4 h-4\" />\n600 |                           </button>\n601 |                         </div>\n602 |                       </td>\n603 | \n604 |                     </tr>\n605 |                   );\n606 |                 })}\n607 |               </tbody>\n608 |             </table>\n609 |           </div>\n610 |           <div className=\"p-4 border-t border-white/5 bg-[#050505]/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-[11px] font-mono\">\n611 |             <span className=\"text-white/40\">\n612 |               Showing <span className=\"text-white/70 font-semibold\">{filteredClients.length}</span> of <span className=\"text-white/70 font-semibold\">{clients.length}</span> sovereign domains configured\n613 |             </span>\n614 |             <div className=\"text-white/30 text-[10px] flex items-center gap-1\">\n615 |               <Shield className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n616 |               <span>Attestation registry locked with administrative cryptographic keys</span>\n617 |             </div>\n618 |           </div>\n619 |         </div>\n620 |       )}\n621 | \n622 |       {/* -----------------------------------------------------------------------\n623 |           5. DETAILS SIDE-DRAWER\n624 |           ----------------------------------------------------------------------- */}\n625 |       {selectedClient && (\n626 |         <div className=\"fixed inset-0 z-50 flex justify-end\">\n627 |           \n628 |           {/* Backdrop */}\n629 |           <div \n630 |             onClick={() => setSelectedClient(null)}\n631 |             className=\"absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300\"\n632 |           />\n633 | \n634 |           {/* Drawer Panel */}\n635 |           <div className=\"relative z-10 w-full sm:w-[500px] border-l border-white/10 bg-[#060606]/95 backdrop-blur-md shadow-2xl flex flex-col h-full overflow-hidden\">\n636 |             \n637 |             {/* Drawer Header */}\n638 |             <div className=\"p-5 border-b border-white/5 bg-[#090909]\">\n639 |               <div className=\"flex items-start justify-between gap-4\">\n640 |                 <div className=\"space-y-1.5 text-left\">\n641 |                   <div className=\"flex items-center gap-2\">\n642 |                     <span className=\"text-[9px] font-mono font-bold text-[#009DFF] uppercase tracking-widest px-1.5 py-0.5 bg-[#009DFF]/10 rounded border border-[#009DFF]/20\">Sovereign Partition</span>\n643 |                     <span className=\"text-[10px] font-mono text-white/40\">{selectedClient.id.toUpperCase()}</span>\n644 |                   </div>\n645 |                   <h3 className=\"text-base font-bold text-white font-mono\">{selectedClient.name}</h3>\n646 |                   <div className=\"text-[11px] text-[#009DFF] font-mono\">{selectedClient.domain}</div>\n647 |                 </div>\n648 |                 <button \n649 |                   onClick={() => setSelectedClient(null)}\n650 |                   className=\"w-7 h-7 rounded border border-white/5 bg-white/[0.01] hover:bg-white/5 flex items-center justify-center text-white/50 hover:text-white transition-all cursor-pointer\"\n651 |                 >\n652 |                   <X className=\"w-4 h-4\" />\n653 |                 </button>\n654 |               </div>\n655 | \n656 |               {/* Drawer Tabs */}\n657 |               <div className=\"grid grid-cols-4 gap-1 mt-6 border-b border-white/5 pb-px font-mono text-[10px]\">\n658 |                 {([\"overview\", \"projects\", \"agents\", \"billing\"] as const).map((tab) => (\n659 |                   <button\n660 |                     key={tab}\n661 |                     onClick={() => setDrawerTab(tab)}\n662 |                     className={`pb-2.5 font-bold uppercase transition-all border-b-2 text-center cursor-pointer bg-transparent border-none ${\n663 |                       drawerTab === tab \n664 |                         ? \"border-[#009DFF] text-white\" \n665 |                         : \"border-transparent text-white/40 hover:text-white/70\"\n666 |                     }`}\n667 |                   >\n668 |                     {tab}\n669 |                   </button>\n670 |                 ))}\n671 |               </div>\n672 |             </div>\n673 | \n674 |             {/* Drawer Content */}\n675 |             <div className=\"flex-1 overflow-y-auto p-5 space-y-5 font-mono text-[11.5px] text-left\">\n676 |               \n677 |               {/* TAB 1: OVERVIEW */}\n678 |               {drawerTab === \"overview\" && (\n679 |                 <div className=\"space-y-5\">\n680 |                   \n681 |                   {/* Status telemetry block */}\n682 |                   <div className=\"grid grid-cols-2 gap-3\">\n683 |                     <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-1.5\">\n684 |                       <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Telemetry Health</span>\n685 |                       <div>{getHealthBadge(selectedClient.healthStatus)}</div>\n686 |                     </div>\n687 |                     <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-1.5\">\n688 |                       <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Epoch Settlement</span>\n689 |                       <div>{getBillingBadge(selectedClient.billingStatus)}</div>\n690 |                     </div>\n691 |                   </div>\n692 | \n693 |                   {/* Core parameters */}\n694 |                   <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n695 |                     <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold border-b border-white/5 pb-1\">\n696 |                       <Shield className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n697 |                       <span>Sovereign Identity Bounds</span>\n698 |                     </div>\n699 |                     <div className=\"grid grid-cols-2 gap-y-3 gap-x-2 text-[11px]\">\n700 |                       <div>\n701 |                         <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Account Custodian</span>\n702 |                         <span className=\"text-white font-semibold\">{selectedClient.accountOwner}</span>\n703 |                       </div>\n704 |                       <div>\n705 |                         <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Enclave Tier</span>\n706 |                         <span className=\"text-amber-300 font-bold\">{selectedClient.tier.toUpperCase()}</span>\n707 |                       </div>\n708 |                       <div>\n709 |                         <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Mapped Enclave Region</span>\n710 |                         <span className=\"text-white\">{selectedClient.region}</span>\n711 |                       </div>\n712 |                       <div>\n713 |                         <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Created Epoch</span>\n714 |                         <span className=\"text-white\">{new Date(selectedClient.createdAt).toLocaleDateString()}</span>\n715 |                       </div>\n716 |                       <div className=\"col-span-2\">\n717 |                         <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Active Compliance Standard</span>\n718 |                         <span className=\"text-[#00FFC2] font-semibold\">{selectedClient.complianceLevel}</span>\n719 |                       </div>\n720 |                     </div>\n721 |                   </div>\n722 | \n723 |                   {/* Primary Contact */}\n724 |                   <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n725 |                     <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold border-b border-white/5 pb-1\">\n726 |                       <User className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n727 |                       <span>Tenant Enclave Admin</span>\n728 |                     </div>\n729 |                     <div className=\"space-y-1\">\n730 |                       <div className=\"text-white font-bold\">{selectedClient.contactName}</div>\n731 |                       <div className=\"text-white/50 text-[10.5px]\">{selectedClient.contactEmail}</div>\n732 |                     </div>\n733 |                   </div>\n734 | \n735 |                   {/* Cryptographic Attestation Block */}\n736 |                   <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-2\">\n737 |                     <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold\">\n738 |                       <Lock className=\"w-3.5 h-3.5 text-amber-500\" />\n739 |                       <span>PKI Root Attestation Seal</span>\n740 |                     </div>\n741 |                     <p className=\"text-[10px] text-white/50 leading-relaxed\">\n742 |                       Sovereign partition cryptographic handshake bound to Hardware Security Module (HSM).\n743 |                     </p>\n744 |                     <div className=\"p-2.5 rounded bg-[#020202] border border-white/5 flex items-center justify-between text-[9.5px] font-mono text-[#009DFF] select-text\">\n745 |                       <span className=\"truncate\">0xSHA256_{selectedClient.id.toUpperCase()}_ROOT_CERTIFICATE_SEAL_V26</span>\n746 |                       <CheckCircle2 className=\"w-4 h-4 text-[#00FFC2] shrink-0\" />\n747 |                     </div>\n748 |                   </div>\n749 | \n750 |                 </div>\n751 |               )}\n752 | \n753 |               {/* TAB 2: PROJECTS */}\n754 |               {drawerTab === \"projects\" && (\n755 |                 <div className=\"space-y-4\">\n756 |                   <div className=\"flex items-center justify-between text-white/40 text-[10px] uppercase font-bold border-b border-white/5 pb-1\">\n757 |                     <span>Provisioned Enclaves</span>\n758 |                     <span>{getProjectsForClient(selectedClient.id).length} Active</span>\n759 |                   </div>\n760 | \n761 |                   {getProjectsForClient(selectedClient.id).length === 0 ? (\n762 |                     <div className=\"p-8 text-center border border-dashed border-white/10 rounded-lg text-white/40 space-y-2\">\n763 |                       <Layers className=\"w-8 h-8 mx-auto opacity-35\" />\n764 |                       <div>No Hard