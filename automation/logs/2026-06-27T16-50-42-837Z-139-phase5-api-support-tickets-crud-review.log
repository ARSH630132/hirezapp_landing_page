\n41 |         get_client(client_id=999999, db=db, current_user=usr)\n42 |         assert False, \"Should have raised 404\"\n43 |     except HTTPException as e:\n44 |         assert e.status_code == 404\n45 |         \n46 |     print(\"Testing list_clients and filtering...\")\n47 |     c2 = create_client(client_in=ClientAccountCreate(\n48 |         name=\"TEST_CLIENT_BETA\", industry=\"BioTech\", region=\"Asia\", status=\"pending\", account_owner=\"GFF Beta\"\n49 |     ), db=db, current_user=usr)\n50 |     \n51 |     assert len(list_clients(db=db, current_user=usr, limit=100, skip=0)) >= 2\n52 |     assert len(list_clients(search=\"BETA\", db=db, current_user=usr, limit=100, skip=0)) == 1\n53 |     assert all(c.status == \"pending\" for c in list_clients(status=\"pending\", db=db, current_user=usr, limit=100, skip=0))\n54 |     assert all(c.region == \"Europe\" for c in list_clients(region=\"Europe\", db=db, current_user=usr, limit=100, skip=0))\n55 |     \n56 |     print(\"Testing update_client...\")\n57 |     upd = update_client(client_id=c2.id, client_in=ClientAccountUpdate(\n58 |         region=\"North America\", status=\"active\"\n59 |     ), db=db, current_user=usr)\n60 |     assert upd.region == \"North America\" and upd.status == \"active\"\n61 |     \n62 |     print(\"Testing delete_client (soft archive)...\")\n63 |     soft = delete_client(client_id=c1.id, hard_delete=False, db=db, current_user=usr)\n64 |     assert soft.status == \"archived\"\n65 |     assert db.query(ClientAccount).filter(ClientAccount.id == c1.id).first().status == \"archived\"\n66 |     \n67 |     print(\"Testing delete_client (hard delete)...\")\n68 |     hard = delete_client(client_id=c1.id, hard_delete=True, db=db, current_user=usr)\n69 |     assert hard.status == \"deleted\"\n70 |     assert db.query(ClientAccount).filter(ClientAccount.id == c1.id).first() is None\n71 |     \n72 |     delete_client(client_id=c2.id, hard_delete=True, db=db, current_user=usr)\n73 |     db.close()\n74 |     print(\"All ClientAccount CRUD API tests completed successfully!\")\n75 | \n76 | if __name__ == \"__main__\":\n77 |     try:\n78 |         run_api_tests()\n79 |         sys.exit(0)\n80 |     except AssertionError:\n81 |         import traceback\n82 |         traceback.print_exc()\n83 |         sys.exit(1)\n84 |     except Exception as e:\n85 |         print(f\"Failed: {e}\")\n86 |         import traceback\n87 |         traceback.print_exc()\n88 |         sys.exit(1)\n89 | ","success":true}],"durationMs":6}}
