{"ts":"2026-06-27T16:49:12.464Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"qm4z8cqq","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-support-apis.js","old_text":null,"new_text":"/* eslint-disable */\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\n\nconst T = path.join(__dirname, '..', 'temp-api-build');\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n\ntry {\n  console.log(\"Compiling support ticket route files...\");\n  execSync('npx tsc lib/api-auth.ts app/api/v1/support/route.ts app/api/v1/support/[id]/route.ts app/api/v1/support/[id]/status/route.ts app/api/v1/support/[id]/assign/route.ts --outDir temp-api-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'inherit' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  console.error(\"Compile failed:\", e);\n  process.exit(1);\n}\n\nconst apiAuth = require('../temp-api-build/lib/api-auth.js');\nconst supportRoute = require('../temp-api-build/app/api/v1/support/route.js');\nconst supportIdRoute = require('../temp-api-build/app/api/v1/support/[id]/route.js');\nconst statusRoute = require('../temp-api-build/app/api/v1/support/[id]/status/route.js');\nconst assignRoute = require('../temp-api-build/app/api/v1/support/[id]/assign/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  if (!u) throw new Error(\"User email not found: \" + email);\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client1 = getAuth(\"a.mercer@apex-sovereign.gff.ai\"); // client-001\n    const client2 = getAuth(\"e.carter@global-retail.gff.ai\"); // client-002\n    const agent = getAuth(\"preview-support-agent@internal.gff.ai\");\n\n    console.log(\"\\n--- Testing GET List ---\");\n    // Client 1 should get client-001 tickets (e.g. T-882)\n    let res = await supportRoute.GET(new Request(\"http://localhost/api/v1/support\", { headers: { \"Authorization\": client1 } }));\n    if (res.status !== 200) throw new Error(\"Expected client1 GET list to be 200\");\n    let data = await res.json();\n    if (!data.success) throw new Error(\"Expected success: true\");\n    if (!data.tickets.every(t => t.client_id === \"client-001\")) throw new Error(\"Client 1 saw tickets not matching their client_id!\");\n    console.log(\"✔ Client 1 scoped GET list successfully returned client-001 tickets.\");\n\n    // Admin should get all tickets\n    res = await supportRoute.GET(new Request(\"http://localhost/api/v1/support\", { headers: { \"Authorization\": admin } }));\n    if (res.status !== 200) throw new Error(\"Expected admin GET list to be 200\");\n    data = await res.json();\n    if (data.tickets.length < 2) throw new Error(\"Admin should see all mock tickets\");\n    console.log(\"✔ Admin GET list returned all tickets.\");\n\n    console.log(\"\\n--- Testing POST Create ---\");\n    // Client 1 creates a valid ticket\n    const ticketPayload = {\n      subject: \"Test Support Ticket ID-139\",\n      description: \"This is a detailed simulation of secure ledger validation delay.\",\n      priority: \"high\",\n      category: \"Infrastructure\"\n    };\n    res = await supportRoute.POST(new Request(\"http://localhost/api/v1/support\", {\n      method: \"POST\",\n      headers: { \"Authorization\": client1, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify(ticketPayload)\n    }));\n    if (res.status !== 201) throw new Error(\"Expected Client 1 ticket creation to be 201\");\n    data = await res.json();\n    if (!data.success || !data.ticket.id) throw new Error(\"Invalid ticket creation response\");\n    const newId = data.ticket.id;\n    console.log(`✔ Created ticket: ${newId} with priority mapped to ${data.ticket.priority}`);\n\n    // Client 2 attempts to create ticket for Client 1\n    res = await supportRoute.POST(new Request(\"http://localhost/api/v1/support\", {\n      method: \"POST\",\n      headers: { \"Authorization\": client2, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ ...ticketPayload, client_id: \"client-001\" })\n    }));\n    if (res.status !== 403) throw new Error(\"Expected 403 when Client 2 tries to create ticket for Client 1\");\n    console.log(\"✔ Client 2 prevented from creating Client 1 ticket (403 Forbidden).\");\n\n    console.log(\"\\n--- Testing GET Single ---\");\n    // Client 1 retrieves their new ticket\n    res = await supportIdRoute.GET(new Request(`http://localhost/api/v1/support/${newId}`, {\n      headers: { \"Authorization\": client1 }\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(`Expected Client 1 to get ${newId} (200)`);\n    data = await res.json();\n    if (data.ticket.id !== newId) throw new Error(\"Retrieved wrong ticket ID\");\n    console.log(\"✔ Client 1 retrieved their own ticket successfully.\");\n\n    // Client 2 attempts to retrieve Client 1's new ticket\n    res = await supportIdRoute.GET(new Request(`http://localhost/api/v1/support/${newId}`, {\n      headers: { \"Authorization\": client2 }\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 403) throw new Error(\"Expected Client 2 to be blocked from viewing Client 1's ticket (403)\");\n    console.log(\"✔ Client 2 prevented from retrieving Client 1's ticket (403 Forbidden).\");\n\n    console.log(\"\\n--- Testing PATCH Update ---\");\n    // Client 1 updates ticket description\n    res = await supportIdRoute.PATCH(new Request(`http://localhost/api/v1/support/${newId}`, {\n      method: \"PATCH\",\n      headers: { \"Authorization\": client1, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ description: \"Updated security ledger validation simulation description.\" })\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(\"Expected Client 1 PATCH to be 200\");\n    data = await res.json();\n    if (data.ticket.description !== \"Updated security ledger validation simulation description.\") throw new Error(\"PATCH description didn't persist\");\n    console.log(\"✔ Client 1 updated their ticket successfully.\");\n\n    // Client 1 attempts to update client_id of ticket (forbidden)\n    res = await supportIdRoute.PATCH(new Request(`http://localhost/api/v1/support/${newId}`, {\n      method: \"PATCH\",\n      headers: { \"Authorization\": client1, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ client_id: \"client-002\" })\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 403) throw new Error(\"Expected Client 1 updating client_id to be blocked (403)\");\n    console.log(\"✔ Client 1 prevented from updating client_id on ticket (403 Forbidden).\");\n\n    console.log(\"\\n--- Testing POST Comment ---\");\n    // Client 1 adds comment\n    res = await supportIdRoute.POST(new Request(`http://localhost/api/v1/support/${newId}`, {\n      method: \"POST\",\n      headers: { \"Authorization\": client1, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ text: \"Hello from client 1 support test.\" })\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(\"Expected Client 1 comment POST to be 200\");\n    data = await res.json();\n    if (data.ticket.replies.length < 3) throw new Error(\"Expected more comments including system agent response\");\n    console.log(\"✔ Client 1 added comment, agent bot responder auto-replied successfully.\");\n\n    console.log(\"\\n--- Testing PATCH Status ---\");\n    // Admin updates status\n    res = await statusRoute.PATCH(new Request(`http://localhost/api/v1/support/${newId}/status`, {\n      method: \"PATCH\",\n      headers: { \"Authorization\": admin, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ status: \"RESOLVED\" })\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(\"Expected status patch to succeed (200)\");\n    data = await res.json();\n    if (data.ticket.status !== \"RESOLVED\") throw new Error(\"Status didn't update to RESOLVED\");\n    console.log(\"✔ Admin updated ticket status to RESOLVED successfully.\");\n\n    console.log(\"\\n--- Testing PATCH Assign ---\");\n    // Admin updates assignment\n    res = await assignRoute.PATCH(new Request(`http://localhost/api/v1/support/${newId}/assign`, {\n      method: \"PATCH\",\n      headers: { \"Authorization\": admin, \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ assigned_to: \"Dr. Sarah Vance\" })\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(\"Expected assign patch to succeed (200)\");\n    data = await res.json();\n    if (data.ticket.assignedAgent !== \"Dr. Sarah Vance\") throw new Error(\"Assignment didn't update to Dr. Sarah Vance\");\n    console.log(\"✔ Admin updated ticket assignment to Dr. Sarah Vance successfully.\");\n\n    console.log(\"\\n--- Testing DELETE Support Ticket ---\");\n    // Client attempts to delete ticket (forbidden)\n    res = await supportIdRoute.DELETE(new Request(`http://localhost/api/v1/support/${newId}`, {\n      method: \"DELETE\",\n      headers: { \"Authorization\": client1 }\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 403) throw new Error(\"Expected client deletion attempt to be 403 Forbidden\");\n    console.log(\"✔ Client prevented from deleting ticket (403 Forbidden).\");\n\n    // Admin deletes ticket\n    res = await supportIdRoute.DELETE(new Request(`http://localhost/api/v1/support/${newId}`, {\n      method: \"DELETE\",\n      headers: { \"Authorization\": admin }\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 200) throw new Error(\"Expected admin deletion to succeed (200)\");\n    console.log(\"✔ Admin deleted ticket successfully (200 OK).\");\n\n    // Retrieve deleted ticket should be 404\n    res = await supportIdRoute.GET(new Request(`http://localhost/api/v1/support/${newId}`, {\n      headers: { \"Authorization\": admin }\n    }), { params: Promise.resolve({ id: newId }) });\n    if (res.status !== 404) throw new Error(\"Expected retrieved deleted ticket to return 404\");\n    console.log(\"✔ Retrieval of deleted ticket successfully returned 404 Not Found.\");\n\n    console.log(\"\\x1b[32m\\n✔ All Support CRUD API tests completed successfully!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m\\n✖ Test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\n\nrun();\n"}}}
