                      type=\"button\"\n741 |                         onClick={handleNext}\n742 |                         className=\"px-6 h-10 rounded-lg text-xs font-bold uppercase bg-[#009DFF] text-black hover:bg-[#009DFF]/90 font-mono shadow-[0_0_15px_rgba(0,157,255,0.25)] flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-[#009DFF]\"\n743 |                       >\n744 |                         Next Gate\n745 |                       </button>\n746 |                     ) : (\n747 |                       <button\n748 |                         type=\"submit\"\n749 |                         className=\"px-6 h-10 rounded-lg text-xs font-bold uppercase bg-[#009DFF] text-black hover:bg-[#009DFF]/90 font-mono shadow-[0_0_15px_rgba(0,157,255,0.25)] flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-[#009DFF]\"\n750 |                       >","success":true}],"durationMs":22}}
