ce\", label: \"Finance, Audit & Accounting\" },\n168 |     { id: \"CX\", label: \"Customer Experience & Support\" },\n169 |     { id: \"Legal\", label: \"Legal, Compliance & HR\" },\n170 |     { id: \"Engineering\", label: \"Engineering, Product & IT\" },\n171 |   ];\n172 | \n173 |   const aiStageOptions = [\n174 |     { id: \"None\", label: \"Initial Exploration (No active AI)\" },\n175 |     { id: \"Wrappers\", label: \"Legacy API wrappers / Simple pilots\" },\n176 |     { id: \"Active\", label: \"Active proprietary models & vector databases\" },\n177 |     { id: \"Production\", label: \"Production-grade multi-agent swarms\" },\n178 |   ];\n179 | \n180 |   const compilerMessages = [\n181 |     \"Establishing isolated client-side memory sandbox...\",\n182 |     \"Inspecting bottleneck description syntactic structures...\",\n183 |     \"Scanning selected industry domain compliance rules...\",\n184 |     \"Evaluating target scaling parameters and VPC constraints...\",\n185 |     \"Synthesizing customized multi-agent squad topology...\",\n186 |     \"Compiling indicative 90-day sandbox execution timeline...\",\n187 |     \"Sandbox telemetry finalized. Compiling output packages...\",\n188 |   ];\n189 | \n190 |   const handleNext = () => {\n191 |     setValidationError(null);\n192 |     if (currentStep === 1) {\n193 |       if (!data.desc || data.desc.trim().length < 15) {\n194 |         setValidationError(\"Please describe your bottleneck challenge (minimum 15 characters) so GFF can model a precise strategy.\");\n195 |         if (textareaRef.current) {\n196 |           textareaRef.current.focus();\n197 |         }\n198 |         return;\n199 |       }\n200 |       setCurrentStep(2);\n201 |     } else if (currentStep === 2) {\n202 |       setCurrentStep(3);\n203 |     }\n204 |   };\n205 | \n206 |   const handleBack = () => {\n207 |     setValidationError(null);\n208 |     if (currentStep > 1) {\n209 |       setCurrentStep((prev) => (prev - 1) as any);\n210 |     }\n211