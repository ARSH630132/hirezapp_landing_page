4 | \n625 |                       <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n626 |                         {/* Geography Selection */}\n627 |                         <div className=\"space-y-2\">\n628 |                           <label htmlFor=\"geo-select\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n629 |                             Target Geography (Optional)\n630 |                           </label>\n631 |                           <select\n632 |                             id=\"geo-select\"\n633 |                             value={data.geography}\n634 |                             onChange={(e) => setData((prev) => ({ ...prev, geography: e.target.value }))}\n635 |                             className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 text-xs outline-none focus:border-[#009DFF] transition-all\"\n636 |                           >\n637 |                             <option value=\"\">No explicit geographical boundary</option>\n638 |                             {geoOptions.map((opt) => (\n639 |                               <option key={opt.id} value={opt.id}>{opt.label}</option>\n640 |                             ))}\n641 |                           </select>\n642 |                         </div>\n643 | \n644 |                         {/* Deployment Urgency */}\n645 |                         <div className=\"space-y-2\">\n646 |                           <label htmlFor=\"urgency-select\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n647 |                             Launch Schedule Urgency (Optional)\n648 |                           </label>\n649 |                           <select\n650 |                             id=\"urgency-select\"\n651 |                             value={data.urgency}\n652 |                             onChange={(e) => setData((prev) => ({ ...prev, urgency: e.target.value }))}\n653 |                             className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 text-xs outline-none focus:border-[#009DFF] transition-all\"\n654 |                           >\n655 |                             <option value=\"\">Not strictly scheduled</option>\n656 |                             {urgencyOptions.map((opt) => (\n657 |                               <option key={opt.id} value={opt.id}>{opt.label}</option>\n658 |                             ))}\n659 |                           </select>\n660 |                         </div>\n661 | \n662 |                         {/* Target Department / Function */}\n663 |                         <div className=\"space-y-2\">\n664 |                           <label htmlFor=\"function-select\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n665 |                             Target Team Function (Optional)\n666 |                           </label>\n667 |                           <select\n668 |                             id=\"function-select\"\n669 |                             value={data.functionTeam}\n670 |                             onChange={(e) => setData((prev) => ({ ...prev, functionTeam: e.target.value }))}\n671 |                             className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 text-xs outline-none focus:border-[#009DFF] transition-all\"\n672 |                           >\n673 |                             <option value=\"\">Cross-department focus</option>\n674 |                             {functionOptions.map((opt) => (\n675 |                               <option key={opt.id} value={opt.id}>{opt.label}</option>\n676 |                             ))}\n677 |                           </select>\n678 |                         </div>\n679 | \n680 |                         {/* Current AI Stage */}\n681 |                         <div className=\"space-y-2\">\n682 |                           <label htmlFor=\"stage-select\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wider block\">\n683 |                             Current AI Implementation Stage (Optional)\n684 |                           </label>\n685 |                           <select\n686 |                             id=\"stage-select\"\n687 |                             value={data.aiStage}\n688 |                             onChange={(e) => setData((prev) => ({ ...prev, aiStage: e.target.value }))}\n689 |                             className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 text-xs outline-none focus:border-[#009DFF] transition-all\"\n690 |                           >\n691 |                             <option value=\"\">No current frameworks assessed</option>\n692 |                             {aiStageOptions.map((opt) => (\n693 |                               <option key={opt.id} value={opt.id}>{opt.label}</option>\n694 |                             ))}\n695 |                           </select>\n696 |                         </div>\n697 |                       </div>\n698 | \n699 |                       {/* Summary recap box */}\n700 |                       <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex justify-between items-center\">\n701 |                         <div className=\"space-y-1\">\n702 |                           <span className=\"text-[9px] font-mono text-white/45 uppercase tracking-widest block\">INTEGRATED RECAP</span>\n703 |                           <p className=\"text-[11px] text-white/70 leading-normal font-light\">\n704 |                             Compiling strategy for <span className=\"text-white font-bold\">{indOptions.find(o => o.id === data.ind)?.title}</span> ({data.size} bracket) addressing your manual friction details.\n705 |                           </p>\n706 |                         </div>\n707 |                         <span className=\"text-xs font-mono font-bold text-[#009DFF] ml-4 shrink-0\">READY_FOR_CO