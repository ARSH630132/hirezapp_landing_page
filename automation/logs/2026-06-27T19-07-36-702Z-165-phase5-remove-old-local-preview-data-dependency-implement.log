cess: false, error: auth.error, message: auth.msg }, { status: auth.status });\n 47 |     }\n 48 |     const { caller } = auth;\n 49 | \n 50 |     let callerClientId = getClientIdFromAssociation(caller.clientAssociation);\n 51 |     const { searchParams } = new URL(req.url);\n 52 |     const requestedClientId = searchParams.get(\"client_id\");\n 53 | \n 54 |     if (caller.role === \"gff_admin\") {\n 55 |       if (requestedClientId) callerClientId = requestedClientId;\n 56 |       else callerClientId = \"client-001\";\n 57 |     } else {\n 58 |       if (requestedClientId && requestedClientId !== callerClientId) {\n 59 |         return NextResponse.json(\n 60 |           { success: false, error: \"Forbidden\", message: \"Access denied to requested client's dashboard.\" },\n 61 |           { status: 403 }\n 62 |         );\n 63 |       }\n 64 |     }\n 65 | \n 66 |     const clientProjects = (Object.values(API_MOCK_PROJECTS) as ApiProject[]).filter(p => p.client_id === callerClientId);\n 67 |     const clientOps = (Object.values(API_MOCK_AI_OPERATIONS) as ApiAiOperation[]).filter(o => o.client_id === callerClientId);\n 68 |     const clientDocs = (Object.values(API_MOCK_DOCUMENTS) as ApiDocumentItem[]).filter(d => d.client_id === callerClientId);\n 69 |     const clientInvoices = (Object.values(API_MOCK_INVOICES) as ApiInvoice[]).filter(i => i.client_id === callerClientId);\n 70 |     const clientTickets = (Object.values(API_MOCK_SUPPORT_TICKETS) as ApiSupportTicket[]).filter(t => t.client_id === callerClientId);\n 71 |     const clientGov = (Object.values(API_MOCK_GOVERNANCE) as ApiGovernanceItem[]).filter(g => g.client_id === callerClientId);\n 72 | \n 73 |     const activeProjectsCount = clientProjects.filter(p => p.status === \"active\").length;\n 74 |     const activeOperationsCount = clientOps.filter(o => o.status === \"active\").length;\n 75 |     const verifiedDocsCount = clientDocs.filter(d => d.status === \"Verified\").length;\n 76 |     const unpaidInvoicesCount = clientInvoices.filter(i => i.status === \"unpaid\" || i.status === \"processing\").length;\n 77 |     const openSupportTicketsCount = clientTickets.filter(t => t.status !== \"RESOLVED\").length;\n 78 |     const flaggedGovCount = clientGov.filter(g => g.status === \"Flagged\" || g.status === \"Critical\" || g.severity === \"Critical\").length;\n 79 | \n 80 |     const recentProjects = [...clientProjects].sort((a, b) => new Date(b.lastUpdated || \"\").getTime() - new Date(a.lastUpdated || \"\").getTime()).slice(0, 5);\n 81 |     const recentOperations = [...clientOps].sort((a, b) => new Date(b.lastUpdated || \"\").getTime() - new Date(a.lastUpdated || \"\").getTime()).slice(0, 5);\n 82 |     const recentDocuments = [...clientDocs].sort((a, b) => new Date(b.lastUpdated || \"\").getTime() - new Date(a.lastUpdated || \"\").getTime()).slice(0, 5);\n 83 |     const recentInvoices = [...clientInvoices].sort((a, b) => new Date(b.lastUpdated || \"\").getTime() - new Date(a.lastUpdated || \"\").getTime()).slice(0, 5);\n 84 |     const recentSupportTickets = [...clientTickets].sort((a, b) => new Date(b.createdDate || \"\").getTime() - new Date(a.createdDate || \"\").getTime()).slice(0, 5);\n 85 |     const recentGovernanceItems = [...clientGov].sort((a, b) => new Date(b.lastUpdated || \"\").getTime() - new Date(a.lastUpdated || \"\").getTime()).slice(0, 5);\n 86 | \n 87 |     return NextResponse.json({\n 88 |       success: true,\n 89 |       client_id: callerClientId,\n 90 |       summary: {\n 91 |         projects: { activeCount: activeProjectsCount, totalCount: clientProjects.length, recent: recentProjects },\n 92 |         aiOperations: { activeCount: activeOperationsCount, totalCount: clientOps.length, recent: recentOperations },\n 93 |         documents: { verifiedCount: verifiedDocsCount, totalCount: clientDocs.length, recent: recentDocuments },\n 94 |         invoices: { unpaidCount: unpaidInvoicesCount, totalCount: clientInvoices.length, recent: recentInvoices },\n 95 |         supportTickets: { openCount: openSupportTicketsCount, totalCount: clientTickets.length, recent: recentSupportTickets },\n 96 |         governance: { flaggedCount: flaggedGovCount, totalCount: clientGov.length, recent: recentGovernanceItems }\n 97 |       }\n 98 |     });\n 99 |   } catch (err) {\n100 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n101 |   }\n102 | }\n103 | \n104 | ","success":true}],"durationMs":2}}
