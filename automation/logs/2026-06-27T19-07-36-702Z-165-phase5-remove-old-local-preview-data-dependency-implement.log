nt_id: string;\n 59 |   client_name: string;\n 60 |   project_id?: string;\n 61 |   project_name?: string;\n 62 |   amount: number;\n 63 |   currency: string;\n 64 |   status: \"paid\" | \"unpaid\" | \"processing\" | \"void\";\n 65 |   issue_date: string;\n 66 |   due_date: string;\n 67 |   category: string;\n 68 |   hash: string;\n 69 |   signature: string;\n 70 |   description: string;\n 71 |   lastUpdated: string;\n 72 | }\n 73 | \n 74 | export interface ApiGovernanceItem {\n 75 |   id: string;\n 76 |   client_id: string;\n 77 |   client_name?: string;\n 78 |   project_id?: string;\n 79 |   project_name?: string;\n 80 |   title: string;\n 81 |   severity: string;\n 82 |   status: string;\n 83 |   owner: string;\n 84 |   due_date: string;\n 85 |   description: string;\n 86 |   nodeId?: string;\n 87 |   standard?: string;\n 88 |   hash?: string;\n 89 |   logs?: string[];\n 90 |   lastUpdated?: string;\n 91 | }\n 92 | \n 93 | export interface ApiDocumentItem {\n 94 |   id: string;\n 95 |   title: string;\n 96 |   fileSize: string;\n 97 |   type: string;\n 98 |   sha256: string;\n 99 |   client_id: string;\n100 |   client_name: string;\n101 |   projectId?: string;\n102 |   status: \"Verified\" | \"Under Review\" | \"Action Required\" | \"Superseded\" | string;\n103 |   owner: string;\n104 |   version: string;\n105 |   lastUpdated: string;\n106 |   description: string;\n107 | }\n108 | \n109 | export interface ApiSupportTicket {\n110 |   id: string;\n111 |   subject: string;\n112 |   client_id: string;\n113 |   client_name: string;\n114 |   priority: string;\n115 |   category: string;\n116 |   status: \"INVESTIGATING\" | \"OPEN\" | \"RESOLVED\" | \"IN_PROGRESS\" | string;\n117 |   assignedAgent: string;\n118 |   linkedProjectId?: string;\n119 |   linkedDocId?: string;\n120 |   slaSeconds: number;\n121 |   description: string;\n122 |   createdDate: string;\n123 | }\n124 | \n125 | export interface ClientAccount {\n126 |   id: string;\n127 |   name: string;\n128 |   status: string;\n129 |   tier: string;\n130 |   region: string;\n131 |   createdAt: string;\n132 | }\n133 | \n134 | // ============================================================================\n135 | // CORE AUTHORIZATION & FETCH UTILITIES\n136 | // ============================================================================\n137 | \n138 | import { getPreviewSession } from \"./preview-auth\";\n139 | \n140 | const TOKEN_KEY = \"gff_api_token\";\n141 | \n142 | export const getApiBaseUrl = (): string => {\n143 |   if (process.env.NEXT_PUBLIC_API_BASE_URL) return process.env.NEXT_PUBLIC_API_BASE_URL;\n144 |   if (typeof window !== \"undefined\") return `${window.location.origin}/api/v1`;\n145 |   return \"http://localhost:3000/api/v1\";\n146 | };\n147 | \n148 | export const getStoredToken = (): string | null => typeof window !== \"undefined\" ? localStorage.getItem(TOKEN_KEY) : null;\n149 | export const setStoredToken = (token: string): void => { if (typeof window !== \"undefined\") localStorage.setItem(TOKEN_KEY, token); };\n150 | export const clearStoredToken = (): void => { if (typeof window !== \"undefined\") localStorage.removeItem(TOKEN_KEY); };\n151 | \n152 | export async function ensureValidToken(): Promise<string | null> {\n153 |   if (typeof window === \"undefined\") return null;\n154 |   const session = getPreviewSession();\n155 |   if (!session) return getStoredToken();\n156 |   \n157 |   const currentToken = getStoredToken();\n158 |   if (currentToken) {\n159 |     try {\n160 |       const parts = currentToken.split(\".\");\n161 |       if (parts.length === 3) {\n162 |         const payload = JSON.parse(atob(parts[1]));\n163 |         if (payload.email && payload.email.toLowerCase() === session.email.toLowerCase()) {\n164 |           return currentToken;\n165 |         }\n166 |       }\n167 |     } catch (e) {\n168 |       // Decode failed\n169 |     }\n170 |   }\n171 |   \n172 |   try {\n173 |     const res = await fetch(`${getApiBaseUrl().replace(/\\/$/, \"