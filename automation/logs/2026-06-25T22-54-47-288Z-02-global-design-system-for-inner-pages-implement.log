{"ts":"2026-06-25T22:52:37.745Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ltb5gb39","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/PlatformProductPreview.tsx","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\n\nconst LOGS_DATA = [\n  { id: \"tx-4029\", agent: \"Strategy Expert\", status: \"SUCCESS\", latency: \"124ms\", tokenCount: \"1,240\" },\n  { id: \"tx-4030\", agent: \"Compliance Check\", status: \"SUCCESS\", latency: \"84ms\", tokenCount: \"512\" },\n  { id: \"tx-4031\", agent: \"Architect-Node 3\", status: \"SUCCESS\", latency: \"410ms\", tokenCount: \"3,890\" },\n  { id: \"tx-4032\", agent: \"Outbound Webhook\", status: \"REPAIRING\", latency: \"950ms\", tokenCount: \"128\" },\n];\n\nexport default function PlatformProductPreview() {\n  const [activeTab, setActiveTab] = useState<\"overview\" | \"logs\" | \"rules\">(\"overview\");\n  const [rules, setRules] = useState({ pii: true, toxicity: true, auditLog: false });\n\n  return (\n    <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] overflow-hidden flex flex-col md:flex-row shadow-2xl\">\n      {/* Mini Mock Dashboard Sidebar */}\n      <div className=\"w-full md:w-[220px] bg-black/40 border-r border-white/5 p-4 flex flex-col gap-1 shrink-0\">\n        <div className=\"px-3 pb-4 border-b border-white/5 mb-4 flex items-center gap-2\">\n          <div className=\"w-2.5 h-2.5 rounded-full bg-[#E4000F] animate-pulse\" />\n          <span className=\"text-[11px] font-bold tracking-[0.1em] text-white/50 uppercase font-mono\">GFF Core Engine</span>\n        </div>\n\n        {[\n          { id: \"overview\", label: \"Overview Hub\" },\n          { id: \"logs\", label: \"Agent Telemetry Logs\" },\n          { id: \"rules\", label: \"Guardrail Policy\" },\n        ].map((tab) => (\n          <button\n            key={tab.id}\n            onClick={() => setActiveTab(tab.id as any)}\n            className={`w-full text-left px-3 py-2 rounded-[8px] text-[12px] font-medium transition-all ${\n              activeTab === tab.id\n                ? \"bg-white/5 text-white border-l-2 border-[#009DFF]\"\n                : \"text-white/50 hover:text-white hover:bg-white/2\"\n            }`}\n          >\n            {tab.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Main Panel */}\n      <div className=\"flex-grow p-6 lg:p-8 bg-black/20 min-h-[300px] flex flex-col justify-between\">\n        {activeTab === \"overview\" && (\n          <div className=\"flex-grow flex flex-col justify-between gap-6\">\n            <div>\n              <span className=\"text-[10px] uppercase font-mono text-white/40 tracking-wider\">Metrics Snapshot</span>\n              <h4 className=\"text-[18px] font-semibold text-white mt-1\">Live Computation Metrics</h4>\n            </div>\n\n            {/* Premium Interactive Line Chart (SVG) */}\n            <div className=\"w-full h-[120px] relative rounded-[12px] border border-white/5 bg-black/40 p-2 overflow-hidden flex items-end\">\n              <svg className=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n                {/* Chart path */}\n                <path d=\"M0 100 Q 100 20, 200 80 T 400 30 T 500 40\" fill=\"none\" stroke=\"url(#chartGrad)\" strokeWidth=\"2.5\" />\n                <path d=\"M0 100 Q 100 20, 200 80 T 400 30 T 500 40 L 500 120 L 0 120 Z\" fill=\"url(#chartArea)\" opacity=\"0.1\" />\n                \n                {/* Horizontal reference lines */}\n                <line x1=\"0\" y1=\"40\" x2=\"500\" y2=\"40\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n                <line x1=\"0\" y1=\"80\" x2=\"500\" y2=\"80\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n\n                <defs>\n                  <linearGradient id=\"chartGrad\" x1=\"0\" y1=\"0\" x2=\"500\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n                  </linearGradient>\n                  <linearGradient id=\"chartArea\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"120\" gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#009DFF\" stopOpacity=\"0.4\" /><stop offset=\"1\" stopColor=\"#009DFF\" stopOpacity=\"0\" />\n                  </linearGradient>\n                </defs>\n              </svg>\n              <div className=\"absolute top-2 right-2 flex gap-3 text-[10px] font-mono text-white/40\">\n                <span>PEAK LATENCY: 94ms</span>\n                <span>AVAILABILITY: 99.98%</span>\n              </div>\n            </div>\n\n            <div className=\"grid grid-cols-3 gap-4 pt-4 border-t border-white/5\">\n              {[\n                { value: \"481,209\", label: \"Queries Routed\" },\n                { value: \"2.4B\", label: \"Tokens Processed\" },\n                { value: \"12ms\", label: \"System Overhead\" },\n              ].map((m, i) => (\n                <div key={i} className=\"flex flex-col\">\n                  <span className=\"text-[18px] font-bold text-white tracking-tight\">{m.value}</span>\n                  <span className=\"text-[9px] uppercase text-white/40 mt-0.5 tracking-wider\">{m.label}</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {activeTab === \"logs\" && (\n          <div className=\"flex-grow flex flex-col justify-between\">\n            <div>\n              <span className=\"text-[10px] uppercase font-mono text-white/40 tracking-wider\">Telemetry Stream</span>\n              <h4 className=\"text-[18px] font-semibold text-white mt-1\">Real-time Node Executions</h4>\n            </div>\n\n            <div className=\"mt-4 overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse text-[11px] font-mono\">\n                <thead>\n                  <tr className=\"border-b border-white/5 text-white/40 uppercase tracking-wider\">\n                    <th className=\"pb-2\">TX ID</th>\n                    <th className=\"pb-2\">Target Node</th>\n                    <th className=\"pb-2\">Latency</th>\n                    <th className=\"pb-2 text-right\">Tokens</th>\n                  </tr>\n                </thead>\n                <tbody>\n                  {LOGS_DATA.map((log) => (\n                    <tr key={log.id} className=\"border-b border-white/5 last:border-0 hover:bg-white/2\">\n                      <td className=\"py-2.5 text-white/80\">{log.id}</td>\n                      <td className=\"py-2.5 text-white font-medium\">{log.agent}</td>\n                      <td className=\"py-2.5 text-white/60\">{log.latency}</td>\n                      <td className=\"py-2.5 text-right text-white/80\">{log.tokenCount}</td>\n                    </tr>\n                  ))}\n                </tbody>\n              </table>\n            </div>\n          </div>\n        )}\n\n        {activeTab === \"rules\" && (\n          <div className=\"flex-grow flex flex-col justify-between\">\n            <div>\n              <span className=\"text-[10px] uppercase font-mono text-white/40 tracking-wider\">Policy Configuration</span>\n              <h4 className=\"text-[18px] font-semibold text-white mt-1\">Zero-Trust Security Policies</h4>\n            </div>\n\n            <div className=\"mt-4 flex flex-col gap-3\">\n              {[\n                { id: \"pii\", title: \"Automated PII Obfuscation\", desc: \"Instantly scrubs personal fields (SSN, credit cards) before parsing metadata.\" },\n                { id: \"toxicity\", title: \"Toxicity & Profanity Block\", desc: \"Filters inappropriate language/threats at API input & response boundaries.\" },\n                { id: \"auditLog\", title: \"Encrypted Cloud Archival\", desc: \"Backup encrypted logs to secure off-site sandboxes daily.\" },\n              ].map((rule) => (\n                <div key={rule.id} className=\"flex items-center justify-between p-3 rounded-[12px] border border-white/5 bg-black/20\">\n                  <div className=\"flex flex-col max-w-[80%]\">\n                    <span className=\"text-[12px] font-semibold text-white\">{rule.title}</span>\n                    <span className=\"text-[10px] text-white/55 mt-0.5 leading-normal\">{rule.desc}</span>\n                  </div>\n                  <button\n                    onClick={() => setRules((prev) => ({ ...prev, [rule.id]: !prev[rule.id as keyof typeof prev] }))}\n                    className={`w-9 h-5 rounded-full p-0.5 transition-all duration-300 relative ${\n                      rules[rule.id as keyof typeof rules] ? \"bg-[#009DFF]\" : \"bg-white/10\"\n                    }`}\n                  >\n                    <div\n                      className={`w-4 h-4 rounded-full bg-white shadow-md transition-all duration-300 transform ${\n                        rules[rule.id as keyof typeof rules] ? \"translate-x-4\" : \"translate-x-0\"\n                      }`}\n                    />\n                  </button>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n"}}}
