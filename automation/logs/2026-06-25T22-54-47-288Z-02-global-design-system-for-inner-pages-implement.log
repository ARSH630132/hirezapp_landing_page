{"ts":"2026-06-25T22:51:26.229Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ohj135bi","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/ArchitectureDiagram.tsx","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\n\ninterface LayerDetail {\n  id: string;\n  name: string;\n  shortDesc: string;\n  features: string[];\n  techStack: string[];\n}\n\nconst LAYERS: LayerDetail[] = [\n  {\n    id: \"ingest\",\n    name: \"Data Ingestion & Gateway\",\n    shortDesc: \"Secure, high-throughput pipelines for enterprise data, files, and live APIs.\",\n    features: [\"Real-time CDC Sync\", \"JWT & TLS 1.3 Gateways\", \"Multi-modal pre-processing\"],\n    techStack: [\"gRPC\", \"Apache Kafka\", \"eBPF Firewalls\"],\n  },\n  {\n    id: \"cognitive\",\n    name: \"Orchestration & Agentic Layer\",\n    shortDesc: \"The cognitive hub coordinating routing, tool execution, and guardrail checks.\",\n    features: [\"Semantic Routing\", \"Self-Correction Loops\", \"PII & Toxicity Guardrails\"],\n    techStack: [\"GFF Custom Router\", \"vLLM Engine\", \"Guardrails SDK\"],\n  },\n  {\n    id: \"memory\",\n    name: \"Enterprise Knowledge & Memory\",\n    shortDesc: \"Long-term and short-term state managers keeping track of client context safely.\",\n    features: [\"Hybrid Graph-Vector Search\", \"Role-Based Access Memory\", \"Cold storage backup\"],\n    techStack: [\"pgvector\", \"Neo4j Graph\", \"Redis Cluster\"],\n  },\n  {\n    id: \"action\",\n    name: \"Action Gateways & Outbound\",\n    shortDesc: \"Secure execution modules delivering payloads back to legacy systems or clients.\",\n    features: [\"Human-in-the-Loop Audit\", \"Idempotent Webhooks\", \"OAuth Sandbox Execution\"],\n    techStack: [\"Kubernetes Sandboxes\", \"Temporal\", \"Secured Webhooks\"],\n  },\n];\n\nexport default function ArchitectureDiagram() {\n  const [activeLayer, setActiveLayer] = useState<string>(\"cognitive\");\n\n  const activeData = LAYERS.find((l) => l.id === activeLayer) || LAYERS[1];\n\n  return (\n    <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] p-6 lg:p-8\">\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n        \n        {/* SVG Diagram Column */}\n        <div className=\"lg:col-span-7 flex flex-col items-center\">\n          <p className=\"text-[11px] font-bold tracking-[0.15em] text-[#009DFF] uppercase mb-4 text-center\">\n            INTERACTIVE SYSTEM BLUEPRINT (CLICK NODES TO INSPECT)\n          </p>\n\n          <svg className=\"w-full max-w-[500px] h-[320px]\" viewBox=\"0 0 500 320\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            {/* Pulsing connections */}\n            <path d=\"M250 50 L250 110 M250 150 L250 190 M250 230 L250 270\" stroke=\"url(#pipeGlow)\" strokeWidth=\"2\" strokeDasharray=\"6 4\" className=\"animate-[dash_12s_linear_infinite]\" />\n\n            {/* Ingestion Layer Box */}\n            <g onClick={() => setActiveLayer(\"ingest\")} className=\"cursor-pointer group\">\n              <rect x=\"100\" y=\"20\" width=\"300\" height=\"40\" rx=\"10\" \n                fill={activeLayer === \"ingest\" ? \"#E4000F\" : \"#0A0A0C\"} \n                stroke={activeLayer === \"ingest\" ? \"white\" : \"rgba(255,255,255,0.1)\"} \n                strokeWidth=\"1.5\" className=\"transition-all duration-300\" \n              />\n              <text x=\"250\" y=\"45\" fill=\"white\" fontSize=\"12\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase tracking-[0.05em]\">\n                1. Data Ingestion & Gateway\n              </text>\n            </g>\n\n            {/* Cognitive Orchestration Box */}\n            <g onClick={() => setActiveLayer(\"cognitive\")} className=\"cursor-pointer group\">\n              <rect x=\"80\" y=\"100\" width=\"340\" height=\"50\" rx=\"12\" \n                fill={activeLayer === \"cognitive\" ? \"url(#brandG)\" : \"#0A0A0C\"} \n                stroke={activeLayer === \"cognitive\" ? \"white\" : \"rgba(255,255,255,0.1)\"} \n                strokeWidth=\"1.5\" className=\"transition-all duration-300\" \n              />\n              <text x=\"250\" y=\"130\" fill=\"white\" fontSize=\"13\" fontWeight=\"700\" textAnchor=\"middle\" className=\"pointer-events-none uppercase tracking-[0.05em]\">\n                2. Cognitive Orchestrator (GFF Hub)\n              </text>\n            </g>\n\n            {/* Memory / Context Box */}\n            <g onClick={() => setActiveLayer(\"memory\")} className=\"cursor-pointer group\">\n              <rect x=\"100\" y=\"180\" width=\"300\" height=\"40\" rx=\"10\" \n                fill={activeLayer === \"memory\" ? \"#009DFF\" : \"#0A0A0C\"} \n                stroke={activeLayer === \"memory\" ? \"white\" : \"rgba(255,255,255,0.1)\"} \n                strokeWidth=\"1.5\" className=\"transition-all duration-300\" \n              />\n              <text x=\"250\" y=\"205\" fill=\"white\" fontSize=\"12\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase tracking-[0.05em]\">\n                3. Enterprise Memory Network\n              </text>\n            </g>\n\n            {/* Action Gateways Box */}\n            <g onClick={() => setActiveLayer(\"action\")} className=\"cursor-pointer group\">\n              <rect x=\"100\" y=\"260\" width=\"300\" height=\"40\" rx=\"10\" \n                fill={activeLayer === \"action\" ? \"#E4000F\" : \"#0A0A0C\"} \n                stroke={activeLayer === \"action\" ? \"white\" : \"rgba(255,255,255,0.1)\"} \n                strokeWidth=\"1.5\" className=\"transition-all duration-300\" \n              />\n              <text x=\"250\" y=\"285\" fill=\"white\" fontSize=\"12\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase tracking-[0.05em]\">\n                4. Action Execution Gateway\n              </text>\n            </g>\n\n            {/* Definitions */}\n            <defs>\n              <linearGradient id=\"brandG\" x1=\"0\" y1=\"0\" x2=\"340\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" />\n                <stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n              <linearGradient id=\"pipeGlow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"320\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" />\n                <stop offset=\"0.5\" stopColor=\"#FFFFFF\" />\n                <stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n            </defs>\n          </svg>\n          <style jsx>{`\n            @keyframes dash {\n              to { stroke-dashoffset: -20; }\n            }\n          `}</style>\n        </div>\n\n        {/* Info Detail Sidebar Column */}\n        <div className=\"lg:col-span-5 flex flex-col border-l border-white/5 lg:pl-8 min-h-[220px] justify-between\">\n          <div>\n            <span className=\"px-2.5 py-0.5 text-[10px] font-bold text-white/50 bg-white/5 rounded-full uppercase tracking-widest\">\n              Blueprint Inspector\n            </span>\n            <h4 className=\"mt-3 text-[18px] font-semibold text-white tracking-tight\">\n              {activeData.name}\n            </h4>\n            <p className=\"mt-2 text-[13px] leading-[1.6] text-white/60 font-light\">\n              {activeData.shortDesc}\n            </p>\n\n            <ul className=\"mt-4 flex flex-col gap-2\">\n              {activeData.features.map((feat, i) => (\n                <li key={i} className=\"flex items-center gap-2 text-[12px] text-white/80 font-mono\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#E4000F]\" />\n                  {feat}\n                </li>\n              ))}\n            </ul>\n          </div>\n\n          <div className=\"mt-6 pt-4 border-t border-white/5\">\n            <span className=\"text-[10px] uppercase text-white/30 tracking-wider\">Engineered With</span>\n            <div className=\"mt-1.5 flex flex-wrap gap-1.5\">\n              {activeData.techStack.map((tech, i) => (\n                <span key={i} className=\"px-2 py-0.5 rounded-[4px] bg-white/5 border border-white/10 text-[11px] font-mono text-white/70\">\n                  {tech}\n                </span>\n              ))}\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n"}}}
