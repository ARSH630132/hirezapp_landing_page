{"ts":"2026-06-25T22:51:02.488Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"pz3id3qf","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/NarrativeSection.tsx","new_text":"\"use client\";\n\nimport React from \"react\";\n\ninterface BulletItem {\n  text: string;\n  boldText?: string;\n}\n\ninterface NarrativeSectionProps {\n  tag?: string;\n  title: string;\n  subtitle?: string;\n  paragraphs: string[];\n  bullets?: BulletItem[];\n  reversed?: boolean;\n  visualPanel?: React.ReactNode;\n}\n\nexport default function NarrativeSection({\n  tag,\n  title,\n  subtitle,\n  paragraphs,\n  bullets,\n  reversed = false,\n  visualPanel,\n}: NarrativeSectionProps) {\n  return (\n    <section className=\"relative w-full px-6 lg:px-16 py-16 lg:py-24 overflow-hidden\">\n      <div className=\"max-w-[1795px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center\">\n        \n        {/* Text Content Block */}\n        <div className={`lg:col-span-6 flex flex-col ${reversed ? \"lg:order-2\" : \"\"}`}>\n          {tag && (\n            <span className=\"text-[11px] font-bold tracking-[0.15em] text-[#E4000F] uppercase mb-4\">\n              {tag}\n            </span>\n          )}\n\n          <h2 className=\"text-[28px] sm:text-[36px] lg:text-[44px] leading-[1.2] font-semibold text-white tracking-tight\">\n            {title}\n          </h2>\n\n          {subtitle && (\n            <p className=\"mt-3 text-[16px] sm:text-[18px] text-[#009DFF] font-medium\">\n              {subtitle}\n            </p>\n          )}\n\n          {/* Editorial Paragraphs */}\n          <div className=\"mt-6 flex flex-col gap-4\">\n            {paragraphs.map((p, idx) => (\n              <p key={idx} className=\"text-[14px] sm:text-[15px] leading-[1.7] text-white/70 font-light\">\n                {p}\n              </p>\n            ))}\n          </div>\n\n          {/* Bulleted Insights with Custom SVG Accents */}\n          {bullets && bullets.length > 0 && (\n            <ul className=\"mt-8 flex flex-col gap-4\">\n              {bullets.map((bullet, idx) => (\n                <li key={idx} className=\"flex items-start gap-3\">\n                  <div className=\"mt-1 shrink-0 flex items-center justify-center w-5 h-5 rounded-full bg-[#009DFF]/10 border border-[#009DFF]/30\">\n                    <svg className=\"w-3 h-3 text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                    </svg>\n                  </div>\n                  <p className=\"text-[14px] leading-[1.6] text-white/80 font-light\">\n                    {bullet.boldText && (\n                      <strong className=\"font-semibold text-white mr-1.5\">{bullet.boldText}</strong>\n                    )}\n                    {bullet.text}\n                  </p>\n                </li>\n              ))}\n            </ul>\n          )}\n        </div>\n\n        {/* Visual Panel Block */}\n        <div className={`lg:col-span-6 flex justify-center items-center ${reversed ? \"lg:order-1\" : \"\"}`}>\n          {visualPanel ? (\n            <div className=\"w-full\">{visualPanel}</div>\n          ) : (\n            /* Default Abstract Cybernetics Visual Box */\n            <div className=\"relative w-full aspect-[4/3] max-w-[540px] rounded-[24px] border border-white/5 bg-gradient-to-b from-[#060608] to-[#020203] p-6 overflow-hidden flex flex-col justify-between group\">\n              {/* Pulsing grid ambient glow */}\n              <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgba(228,0,15,0.04),transparent_50%)]\" />\n              <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_30%_70%,rgba(0,157,255,0.04),transparent_50%)]\" />\n\n              {/* Dynamic Scrolling Console Log Simulation */}\n              <div className=\"w-full h-full rounded-[16px] border border-white/5 bg-black/60 backdrop-blur-[4px] p-4 flex flex-col justify-between relative overflow-hidden\">\n                <div className=\"flex items-center justify-between border-b border-white/5 pb-2 mb-3\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-red-500/80\" />\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-yellow-500/80\" />\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-green-500/80\" />\n                  </div>\n                  <span className=\"text-[10px] tracking-[0.1em] text-white/30 uppercase font-mono\">\n                    orchestrator.telemetry\n                  </span>\n                </div>\n\n                <div className=\"flex-grow font-mono text-[11px] leading-[1.6] text-white/50 flex flex-col gap-2.5\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[#009DFF]\">[SYS]</span>\n                    <span className=\"text-white/80\">Initializing Enterprise Sandbox Gateways...</span>\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-green-400\">[OK]</span>\n                    <span className=\"text-white/60\">Zero-Trust Security layer active (ISO-27001)</span>\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[#E4000F]\">[WARN]</span>\n                    <span className=\"text-white/60\">Heuristic anomaly scanning initiated...</span>\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[#009DFF]\">[AGENT]</span>\n                    <span className=\"text-white/80\">Consensus reached across 12 distributed pipelines</span>\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-green-400\">[LIVE]</span>\n                    <span className=\"text-[#009DFF] animate-pulse\">Syncing GFF telemetry to factory cluster...</span>\n                  </div>\n                </div>\n\n                {/* Cyber decorative mini metrics bar */}\n                <div className=\"mt-4 pt-3 border-t border-white/5 flex items-center justify-between text-[10px] font-mono text-white/30 uppercase\">\n                  <span>LATENCY: 12ms</span>\n                  <span>CPU LOAD: 14.2%</span>\n                  <span>NODE: GFF-09</span>\n                </div>\n              </div>\n\n              {/* Decorative Corner Borders */}\n              <div className=\"absolute top-0 left-0 w-6 h-6 border-t border-l border-white/10 rounded-tl-[24px]\" />\n              <div className=\"absolute top-0 right-0 w-6 h-6 border-t border-r border-white/10 rounded-tr-[24px]\" />\n              <div className=\"absolute bottom-0 left-0 w-6 h-6 border-b border-l border-white/10 rounded-bl-[24px]\" />\n              <div className=\"absolute bottom-0 right-0 w-6 h-6 border-b border-r border-white/10 rounded-br-[24px]\" />\n            </div>\n          )}\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"}}}
