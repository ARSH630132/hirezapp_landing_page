     </svg>\n              </h4>\n              <p className=\"mt-2 text-[12.5px] leading-[1.5] text-white/55 font-light\">\n                {link.desc}\n              </p>\n            </div>\n          </a>\n        ))}\n      </div>\n    </div>\n  );\n}\n"}}}
