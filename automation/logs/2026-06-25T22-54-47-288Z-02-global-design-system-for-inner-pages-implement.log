{"ts":"2026-06-25T22:51:48.781Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"hqx7cptq","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/OperatingModelTimeline.tsx","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\n\ninterface TimelineStep {\n  phase: string;\n  title: string;\n  subtitle: string;\n  duration: string;\n  focus: string;\n  outputs: string[];\n  color: string;\n  glow: string;\n}\n\nconst STAGES: TimelineStep[] = [\n  {\n    phase: \"PHASE 01\",\n    title: \"GARAGE\",\n    subtitle: \"Rapid Prototyping & Scoping\",\n    duration: \"1 - 2 WEEKS\",\n    focus: \"Discovery workshop, architectural sandbox framing, and live technical feasibility validation.\",\n    outputs: [\"Interactive Architecture Blueprint\", \"High-fidelity UX mock sandbox\", \"Production ROI report\"],\n    color: \"#E4000F\",\n    glow: \"rgba(228,0,15,0.25)\",\n  },\n  {\n    phase: \"PHASE 02\",\n    title: \"FOUNDRY\",\n    subtitle: \"Secure Implementation & Hardening\",\n    duration: \"4 - 6 WEEKS\",\n    focus: \"Concrete multi-agent engineering, zero-trust containerization, and continuous telemetry pipeline setup.\",\n    outputs: [\"Production-ready API endpoints\", \"SOC2 security audit reports\", \"High-throughput performance logs\"],\n    color: \"#FFFFFF\",\n    glow: \"rgba(255,255,255,0.15)\",\n  },\n  {\n    phase: \"PHASE 03\",\n    title: \"FACTORY\",\n    subtitle: \"Continuous Scale & Optimization\",\n    duration: \"ENTERPRISE LIFECYCLE\",\n    focus: \"Deploying models to production clusters with real-time heuristic monitoring, self-healing code runs, and automated updates.\",\n    outputs: [\"24/7 autonomous node monitoring\", \"Dynamic compute provisioning\", \"Continuous learning updates\"],\n    color: \"#009DFF\",\n    glow: \"rgba(0,157,255,0.25)\",\n  },\n];\n\nexport default function OperatingModelTimeline() {\n  const [activeStep, setActiveStep] = useState<number>(0);\n  const activeData = STAGES[activeStep];\n\n  return (\n    <div className=\"w-full py-10\">\n      {/* Horizontal timeline bar (Hidden on mobile) */}\n      <div className=\"hidden md:flex items-center justify-between relative max-w-[1200px] mx-auto mb-12\">\n        <div className=\"absolute top-[38px] left-[10%] right-[10%] h-[1px] bg-white/10 z-0\">\n          <div \n            className=\"h-full bg-gradient-to-r from-[#E4000F] via-white to-[#009DFF] transition-all duration-500 ease-out\"\n            style={{ width: `${(activeStep / (STAGES.length - 1)) * 100}%` }}\n          />\n        </div>\n\n        {STAGES.map((stage, idx) => (\n          <button\n            key={stage.title}\n            onClick={() => setActiveStep(idx)}\n            className=\"flex flex-col items-center relative z-10 focus:outline-none group\"\n            style={{ width: \"30%\" }}\n          >\n            <span className=\"text-[10px] tracking-widest font-mono text-white/40 group-hover:text-white/60 transition-colors\">\n              {stage.phase}\n            </span>\n            \n            {/* Step circle */}\n            <div \n              className={`mt-2 w-8 h-8 rounded-full border-2 flex items-center justify-center transition-all duration-300 ${\n                activeStep === idx \n                  ? \"bg-black border-white shadow-[0_0_15px_rgba(255,255,255,0.25)] scale-110\" \n                  : \"bg-[#0c0c0e] border-white/20 hover:border-white/50\"\n              }`}\n              style={{ borderColor: activeStep === idx ? stage.color : undefined }}\n            >\n              <div \n                className=\"w-2.5 h-2.5 rounded-full\" \n                style={{ backgroundColor: stage.color }}\n              />\n            </div>\n\n            <span className=\"mt-3 text-[14px] font-bold tracking-[0.05em] text-white\">\n              {stage.title}\n            </span>\n            <span className=\"text-[11px] text-white/50 font-mono mt-0.5\">\n              {stage.duration}\n            </span>\n          </button>\n        ))}\n      </div>\n\n      {/* Interactive Phase Details Card */}\n      <div className=\"max-w-[880px] mx-auto rounded-[24px] border border-white/5 bg-[#050505]/65 backdrop-blur-[8px] p-6 lg:p-8 relative overflow-hidden\">\n        {/* Dynamic ambient highlight glow */}\n        <div \n          className=\"absolute top-[-20%] right-[-20%] w-[50%] h-[50%] rounded-full blur-[80px] opacity-30 transition-all duration-500 pointer-events-none\"\n          style={{ backgroundColor: activeData.color }}\n        />\n\n        {/* Header containing Phase titles */}\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n          <div>\n            <span className=\"text-[10px] font-mono tracking-widest uppercase\" style={{ color: activeData.color }}>\n              {activeData.phase} — {activeData.duration}\n            </span>\n            <h3 className=\"text-[24px] lg:text-[28px] font-bold text-white tracking-tight mt-1 flex items-center gap-3\">\n              {activeData.title}\n              <span className=\"text-[12px] font-normal text-white/50 font-mono\">({activeData.subtitle})</span>\n            </h3>\n          </div>\n\n          {/* Quick toggle for mobile screens */}\n          <div className=\"flex md:hidden gap-1 bg-white/5 p-1 rounded-full border border-white/10 self-start\">\n            {STAGES.map((s, i) => (\n              <button\n                key={s.title}\n                onClick={() => setActiveStep(i)}\n                className={`px-3 py-1 text-[11px] font-bold rounded-full transition-colors ${\n                  activeStep === i ? \"bg-white text-black\" : \"text-white/60 hover:text-white\"\n                }`}\n              >\n                {s.title}\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Content details split */}\n        <div className=\"mt-6 grid grid-cols-1 md:grid-cols-2 gap-8\">\n          <div>\n            <h4 className=\"text-[12px] uppercase text-white/40 tracking-wider font-semibold\">Strategic Focus</h4>\n            <p className=\"mt-2 text-[14px] leading-[1.6] text-white/70 font-light\">\n              {activeData.focus}\n            </p>\n          </div>\n\n          <div>\n            <h4 className=\"text-[12px] uppercase text-white/40 tracking-wider font-semibold\">Key Outputs & Deliverables</h4>\n            <ul className=\"mt-3 flex flex-col gap-2.5\">\n              {activeData.outputs.map((out, idx) => (\n                <li key={idx} className=\"flex items-center gap-2.5 text-[13px] text-white/80\">\n                  <svg className=\"w-4 h-4 shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" style={{ color: activeData.color }}>\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 12l2 2 4-4\" />\n                  </svg>\n                  <span className=\"font-light\">{out}</span>\n                </li>\n              ))}\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"}}}
