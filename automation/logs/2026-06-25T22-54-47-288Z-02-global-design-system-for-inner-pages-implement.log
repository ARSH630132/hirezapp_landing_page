{"ts":"2026-06-25T22:53:18.327Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"5mg8gru0","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/ResearchLibraryGrid.tsx","new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\n\ninterface ResearchPaper {\n  title: string;\n  category: \"Agentic AI\" | \"Security\" | \"Scalability\";\n  readTime: string;\n  abstract: string;\n  fileSize: string;\n}\n\nconst PAPERS: ResearchPaper[] = [\n  {\n    title: \"GFF Heuristic Agent Orchestration Framework v1.4\",\n    category: \"Agentic AI\",\n    readTime: \"12 min read\",\n    abstract: \"A reference implementation guide outlining dynamic task routing, sub-agent spawning, and transactional isolation layers in distributed networks.\",\n    fileSize: \"2.4 MB PDF\"\n  },\n  {\n    title: \"Zero-Trust Agentic Security: Multi-Layer Sanboxing\",\n    category: \"Security\",\n    readTime: \"18 min read\",\n    abstract: \"Technical analysis of secure memory boundaries, PII token obfuscation, and runtime isolation techniques to safely execute external API calls.\",\n    fileSize: \"4.1 MB PDF\"\n  },\n  {\n    title: \"Horizontal Multi-Agent Scaling & Latency Benchmarks\",\n    category: \"Scalability\",\n    readTime: \"15 min read\",\n    abstract: \"Empirical study on microsecond-level synchronization of shared graph databases and custom semantic cache configurations for sub-10ms response loops.\",\n    fileSize: \"1.8 MB PDF\"\n  },\n  {\n    title: \"Ensuring System Alignment: Safety Loops & Audits\",\n    category: \"Security\",\n    readTime: \"10 min read\",\n    abstract: \"Exploring Human-in-the-Loop execution patterns, validation logic fallback states, and compliance monitoring metrics.\",\n    fileSize: \"3.2 MB PDF\"\n  }\n];\n\nexport default function ResearchLibraryGrid() {\n  const [search, setSearch] = useState(\"\");\n  const [selectedCat, setSelectedCat] = useState<string>(\"All\");\n  const [downloading, setDownloading] = useState<Record<string, boolean>>({});\n\n  const filteredPapers = useMemo(() => {\n    return PAPERS.filter((p) => {\n      const matchSearch = p.title.toLowerCase().includes(search.toLowerCase()) || \n                          p.abstract.toLowerCase().includes(search.toLowerCase());\n      const matchCat = selectedCat === \"All\" || p.category === selectedCat;\n      return matchSearch && matchCat;\n    });\n  }, [search, selectedCat]);\n\n  const handleDownload = (title: string) => {\n    if (downloading[title]) return;\n    setDownloading((prev) => ({ ...prev, [title]: true }));\n    setTimeout(() => {\n      setDownloading((prev) => ({ ...prev, [title]: false }));\n      alert(`Success: \"${title}\" reference schema is preparing for local transmission.`);\n    }, 1500);\n  };\n\n  return (\n    <div className=\"w-full flex flex-col gap-6\">\n      {/* Filtering and search row */}\n      <div className=\"flex flex-col md:flex-row gap-4 items-center justify-between border-b border-white/5 pb-6\">\n        {/* Category toggles */}\n        <div className=\"flex flex-wrap gap-1.5 self-start md:self-auto\">\n          {[\"All\", \"Agentic AI\", \"Security\", \"Scalability\"].map((cat) => (\n            <button\n              key={cat}\n              onClick={() => setSelectedCat(cat)}\n              className={`px-3 py-1.5 rounded-lg text-[11px] font-semibold tracking-wider transition-colors uppercase ${\n                selectedCat === cat\n                  ? \"bg-white text-black\"\n                  : \"bg-white/5 text-white/60 hover:text-white\"\n              }`}\n            >\n              {cat}\n            </button>\n          ))}\n        </div>\n\n        {/* Text Search Bar */}\n        <div className=\"relative w-full md:w-[280px]\">\n          <input\n            type=\"text\"\n            placeholder=\"Search papers/abstracts...\"\n            value={search}\n            onChange={(e) => setSearch(e.target.value)}\n            className=\"w-full bg-[#050505] border border-white/10 rounded-full px-4 py-2 text-[12px] text-white focus:outline-none focus:border-[#009DFF] font-light\"\n          />\n        </div>\n      </div>\n\n      {/* Grid of papers */}\n      {filteredPapers.length > 0 ? (\n        <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          {filteredPapers.map((paper) => (\n            <div\n              key={paper.title}\n              className=\"rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] p-6 flex flex-col justify-between group hover:border-white/12 transition-all duration-300\"\n            >\n              <div>\n                <div className=\"flex items-center justify-between text-[10px] font-mono tracking-wider uppercase text-white/40 mb-4\">\n                  <span className=\"text-[#009DFF] font-semibold\">{paper.category}</span>\n                  <span>{paper.readTime}</span>\n                </div>\n\n                <h3 className=\"text-[17px] font-semibold text-white tracking-tight leading-snug group-hover:text-[#009DFF] transition-colors\">\n                  {paper.title}\n                </h3>\n\n                <p className=\"mt-3 text-[13px] leading-[1.5] text-white/55 font-light\">\n                  {paper.abstract}\n                </p>\n              </div>\n\n              <div className=\"mt-6 pt-4 border-t border-white/5 flex items-center justify-between text-[11px]\">\n                <span className=\"text-white/40 font-mono\">{paper.fileSize}</span>\n                \n                <button\n                  onClick={() => handleDownload(paper.title)}\n                  className=\"flex items-center gap-1.5 text-white hover:text-[#009DFF] font-semibold uppercase tracking-wider\"\n                >\n                  {downloading[paper.title] ? (\n                    <>\n                      <svg className=\"animate-spin h-3.5 w-3.5\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\">\n                        <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n                        <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\" />\n                      </svg>\n                      <span>Transmitting...</span>\n                    </>\n                  ) : (\n                    <>\n                      <span>Download Specs</span>\n                      <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n                      </svg>\n                    </>\n                  )}\n                </button>\n              </div>\n            </div>\n          ))}\n        </div>\n      ) : (\n        <div className=\"text-center py-12 text-white/40 text-[13px] font-light\">\n          No whitepapers matching selected parameters. Try resetting filters.\n        </div>\n      )}\n    </div>\n  );\n}\n"}}}
