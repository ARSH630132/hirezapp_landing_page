{"ts":"2026-06-25T22:52:12.125Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"28pfmcjw","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/EnterpriseFlowDiagram.tsx","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\n\nconst NODES = [\n  {\n    id: \"route\",\n    title: \"Semantic Router\",\n    desc: \"Analyzes intent, security risk, and selects specialized agents.\",\n    role: \"GATEWAY\",\n  },\n  {\n    id: \"agent\",\n    title: \"Multi-Agent Cluster\",\n    desc: \"Executes computations, accesses vector memories, and generates payloads.\",\n    role: \"COMPUTE\",\n  },\n  {\n    id: \"guard\",\n    title: \"AI Safety Guardrails\",\n    desc: \"Heuristics & LLMs scan outputs for PII leaks, safety compliance, or format errors.\",\n    role: \"COMPLIANCE\",\n  },\n  {\n    id: \"audit\",\n    title: \"Human-in-the-Loop Audit\",\n    desc: \"Ensures critical actions (e.g. wire transfers, medical edits) are approved by managers.\",\n    role: \"HUMAN BLOCK\",\n  },\n  {\n    id: \"dispatch\",\n    title: \"Gateway Dispatcher\",\n    desc: \"Encrypts and safely executes the validated action on your core database or CRM.\",\n    role: \"EXECUTION\",\n  },\n];\n\nexport default function EnterpriseFlowDiagram() {\n  const [hovered, setHovered] = useState<string | null>(null);\n\n  const activeNode = NODES.find((n) => n.id === hovered) || NODES[0];\n\n  return (\n    <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] p-6 lg:p-8\">\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n        \n        {/* SVG Interactive Flow */}\n        <div className=\"lg:col-span-8 flex flex-col items-center\">\n          <p className=\"text-[11px] font-bold tracking-[0.15em] text-[#009DFF] uppercase mb-6 text-center\">\n            AGENT ORCHESTRATION LOOP (HOVER NODES TO INSPECT)\n          </p>\n\n          <svg className=\"w-full max-w-[550px] h-[280px]\" viewBox=\"0 0 550 280\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            {/* Flow Connecting Lines */}\n            <path d=\"M70 140 L160 140 M240 140 L310 140 M390 140 L460 140 M480 120 L480 60 L200 60 L200 110\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n            <path d=\"M240 140 L310 140\" stroke=\"#009DFF\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" className=\"animate-[dash_6s_linear_infinite]\" />\n            <path d=\"M480 120 L480 60 L200 60 L200 110\" stroke=\"#E4000F\" strokeWidth=\"1\" strokeDasharray=\"5 5\" className=\"animate-[dash_8s_linear_infinite]\" />\n\n            {/* Ingestion Hook */}\n            <circle cx=\"40\" cy=\"140\" r=\"15\" fill=\"#E4000F\" className=\"animate-pulse\" />\n            <text x=\"40\" y=\"143\" fill=\"white\" fontSize=\"9\" fontWeight=\"bold\" textAnchor=\"middle\">IN</text>\n\n            {/* Semantic Router Node */}\n            <g onMouseEnter={() => setHovered(\"route\")} onMouseLeave={() => setHovered(null)} className=\"cursor-pointer group\">\n              <rect x=\"130\" y=\"110\" width=\"100\" height=\"60\" rx=\"12\" fill={hovered === \"route\" ? \"#009DFF\" : \"#0A0A0C\"} stroke={hovered === \"route\" ? \"white\" : \"rgba(255,255,255,0.1)\"} strokeWidth=\"1.5\" className=\"transition-all duration-200\" />\n              <text x=\"180\" y=\"140\" fill=\"white\" fontSize=\"10\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase\">Router</text>\n              <text x=\"180\" y=\"152\" fill=\"white\" fontSize=\"7\" opacity=\"0.5\" textAnchor=\"middle\" className=\"pointer-events-none\">GATEWAY</text>\n            </g>\n\n            {/* Agent Cluster Node */}\n            <g onMouseEnter={() => setHovered(\"agent\")} onMouseLeave={() => setHovered(null)} className=\"cursor-pointer group\">\n              <rect x=\"280\" y=\"110\" width=\"100\" height=\"60\" rx=\"12\" fill={hovered === \"agent\" ? \"url(#loopGrad)\" : \"#0A0A0C\"} stroke={hovered === \"agent\" ? \"white\" : \"rgba(255,255,255,0.1)\"} strokeWidth=\"1.5\" className=\"transition-all duration-200\" />\n              <text x=\"330\" y=\"140\" fill=\"white\" fontSize=\"10\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase\">Agent Pool</text>\n              <text x=\"330\" y=\"152\" fill=\"white\" fontSize=\"7\" opacity=\"0.5\" textAnchor=\"middle\" className=\"pointer-events-none\">COMPUTE</text>\n            </g>\n\n            {/* Safety Guardrails Node */}\n            <g onMouseEnter={() => setHovered(\"guard\")} onMouseLeave={() => setHovered(null)} className=\"cursor-pointer group\">\n              <rect x=\"430\" y=\"110\" width=\"100\" height=\"60\" rx=\"12\" fill={hovered === \"guard\" ? \"#E4000F\" : \"#0A0A0C\"} stroke={hovered === \"guard\" ? \"white\" : \"rgba(255,255,255,0.1)\"} strokeWidth=\"1.5\" className=\"transition-all duration-200\" />\n              <text x=\"480\" y=\"140\" fill=\"white\" fontSize=\"10\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase\">Guardrails</text>\n              <text x=\"480\" y=\"152\" fill=\"white\" fontSize=\"7\" opacity=\"0.5\" textAnchor=\"middle\" className=\"pointer-events-none\">SECURITY</text>\n            </g>\n\n            {/* Conditional Branch Indicator (Audit or Dispatch) */}\n            <path d=\"M480 170 L480 210 L330 210 M480 170 L480 250\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n            \n            {/* Audit node */}\n            <g onMouseEnter={() => setHovered(\"audit\")} onMouseLeave={() => setHovered(null)} className=\"cursor-pointer group\">\n              <circle cx=\"310\" cy=\"210\" r=\"18\" fill={hovered === \"audit\" ? \"white\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1.5\" className=\"transition-all duration-200\" />\n              <text x=\"310\" y=\"213\" fill={hovered === \"audit\" ? \"black\" : \"white\"} fontSize=\"8\" fontWeight=\"bold\" textAnchor=\"middle\">AUDIT</text>\n            </g>\n\n            {/* Out dispatcher */}\n            <g onMouseEnter={() => setHovered(\"dispatch\")} onMouseLeave={() => setHovered(null)} className=\"cursor-pointer group\">\n              <rect x=\"430\" y=\"235\" width=\"100\" height=\"30\" rx=\"6\" fill={hovered === \"dispatch\" ? \"#009DFF\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" className=\"transition-all duration-200\" />\n              <text x=\"480\" y=\"253\" fill=\"white\" fontSize=\"9\" fontWeight=\"600\" textAnchor=\"middle\" className=\"pointer-events-none uppercase\">DISPATCH</text>\n            </g>\n\n            <defs>\n              <linearGradient id=\"loopGrad\" x1=\"280\" y1=\"110\" x2=\"380\" y2=\"170\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        </div>\n\n        {/* Info Column */}\n        <div className=\"lg:col-span-4 flex flex-col border-l border-white/5 lg:pl-6 min-h-[180px] justify-between\">\n          <div>\n            <span className=\"text-[9px] font-mono tracking-widest text-[#009DFF] uppercase font-bold\">{activeNode.role} Node</span>\n            <h4 className=\"text-[17px] font-semibold text-white mt-1.5\">{activeNode.title}</h4>\n            <p className=\"text-[13px] leading-[1.5] text-white/60 mt-2 font-light\">{activeNode.desc}</p>\n          </div>\n          <div className=\"mt-4 pt-3 border-t border-white/5 text-[9px] text-white/30 font-mono\">\n            FLOW HEURISTIC: ACTIVE\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}\n"}}}
