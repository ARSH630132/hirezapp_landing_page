{"ts":"2026-06-25T22:50:24.523Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"htrc1o36","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/InnerPageHero.tsx","new_text":"\"use client\";\n\nimport React from \"react\";\nimport { motion } from \"motion/react\";\n\ninterface InnerPageHeroProps {\n  category?: string;\n  title: string;\n  highlightedWord?: string;\n  highlightColor?: \"red\" | \"blue\" | \"gradient\";\n  description: string;\n  breadcrumbs?: Array<{ label: string; href?: string }>;\n  centered?: boolean;\n}\n\nexport default function InnerPageHero({\n  category,\n  title,\n  highlightedWord,\n  highlightColor = \"gradient\",\n  description,\n  breadcrumbs,\n  centered = false,\n}: InnerPageHeroProps) {\n  const getHighlightClass = () => {\n    switch (highlightColor) {\n      case \"red\":\n        return \"text-[#E4000F]\";\n      case \"blue\":\n        return \"text-[#009DFF]\";\n      case \"gradient\":\n      default:\n        return \"bg-clip-text text-transparent bg-gradient-to-r from-[#E4000F] to-[#009DFF]\";\n    }\n  };\n\n  const formattedTitle = () => {\n    if (!highlightedWord) return title;\n    const parts = title.split(highlightedWord);\n    if (parts.length < 2) return title;\n    return (\n      <>\n        {parts[0]}\n        <span className={getHighlightClass()}>{highlightedWord}</span>\n        {parts[1]}\n      </>\n    );\n  };\n\n  return (\n    <section className=\"relative w-full px-6 lg:px-16 pt-12 pb-16 lg:pt-20 lg:pb-28 overflow-hidden\">\n      {/* Decorative top ambient grid line */}\n      <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-[1795px] h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent\" />\n\n      <div className=\"max-w-[1795px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center relative z-10\">\n        {/* Left / Center content panel */}\n        <div className={`${centered ? \"lg:col-span-12 text-center\" : \"lg:col-span-7\"} flex flex-col`}>\n          {/* Breadcrumbs */}\n          {breadcrumbs && breadcrumbs.length > 0 && (\n            <nav className={`flex items-center gap-2 mb-6 text-[12px] uppercase tracking-[0.1em] text-white/50 ${centered ? \"justify-center\" : \"\"}`}>\n              {breadcrumbs.map((crumb, idx) => (\n                <React.Fragment key={idx}>\n                  {idx > 0 && <span>/</span>}\n                  {crumb.href ? (\n                    <a href={crumb.href} className=\"hover:text-white transition-colors\">\n                      {crumb.label}\n                    </a>\n                  ) : (\n                    <span className=\"text-white/80\">{crumb.label}</span>\n                  )}\n                </React.Fragment>\n              ))}\n            </nav>\n          )}\n\n          {/* Premium tag pill */}\n          {category && (\n            <div className={`mb-4 flex ${centered ? \"justify-center\" : \"\"}`}>\n              <span className=\"px-3 py-1 text-[11px] font-bold tracking-[0.12em] text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 rounded-full uppercase\">\n                {category}\n              </span>\n            </div>\n          )}\n\n          {/* Page Headline */}\n          <h1 className=\"text-[36px] sm:text-[54px] lg:text-[68px] leading-[1.1] font-bold text-white tracking-tight\">\n            {formattedTitle()}\n          </h1>\n\n          {/* Subtitle Description */}\n          <p className={`mt-6 text-[16px] sm:text-[18px] lg:text-[20px] leading-[1.6] text-white/70 font-light max-w-[800px] ${centered ? \"mx-auto\" : \"\"}`}>\n            {description}\n          </p>\n\n          {/* Actions placeholder */}\n          {!centered && (\n            <div className=\"mt-8 flex flex-wrap gap-4 items-center\">\n              <a\n                href=\"#deepdive\"\n                className=\"px-6 py-3 rounded-full text-[14px] font-semibold text-white transition-all bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 flex items-center gap-2\"\n              >\n                <span>Learn More</span>\n                <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 13l-7 7-7-7m14-6l-8 8-8-8\" />\n                </svg>\n              </a>\n            </div>\n          )}\n        </div>\n\n        {/* Right decoration panel (Only shown if layout is split and not centered) */}\n        {!centered && (\n          <div className=\"lg:col-span-5 flex justify-center items-center relative\">\n            <div className=\"relative w-full aspect-square max-w-[400px] sm:max-w-[450px] rounded-[32px] border border-white/5 bg-gradient-to-br from-[#0c0c0e] to-[#040405] p-6 shadow-2xl flex items-center justify-center overflow-hidden group\">\n              {/* Inner ambient glow */}\n              <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70%] h-[70%] bg-gradient-to-tr from-[#E4000F]/10 to-[#009DFF]/10 rounded-full blur-[40px] opacity-70 group-hover:opacity-90 transition-opacity duration-500\" />\n\n              {/* Dynamic interactive mathematical neural SVG mesh */}\n              <svg className=\"w-full h-full relative z-10\" viewBox=\"0 0 400 400\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                <g className=\"animate-[spin_60s_linear_infinite] origin-center\">\n                  {/* Outer Rings */}\n                  <circle cx=\"200\" cy=\"200\" r=\"160\" stroke=\"url(#gradientRing1)\" strokeWidth=\"1\" strokeDasharray=\"5 15\" className=\"opacity-40\" />\n                  <circle cx=\"200\" cy=\"200\" r=\"120\" stroke=\"url(#gradientRing2)\" strokeWidth=\"1\" strokeDasharray=\"30 10\" className=\"opacity-20\" />\n                  <circle cx=\"200\" cy=\"200\" r=\"80\" stroke=\"url(#gradientRing1)\" strokeWidth=\"1.5\" className=\"opacity-15\" />\n\n                  {/* Flow Nodes and Lines */}\n                  <path d=\"M200 40 L200 360 M40 200 L360 200 M87 87 L313 313 M87 313 L313 87\" stroke=\"white\" strokeWidth=\"0.5\" className=\"opacity-10\" />\n\n                  <circle cx=\"200\" cy=\"40\" r=\"4\" fill=\"#E4000F\" className=\"animate-pulse\" />\n                  <circle cx=\"200\" cy=\"360\" r=\"4\" fill=\"#009DFF\" />\n                  <circle cx=\"40\" cy=\"200\" r=\"4\" fill=\"#009DFF\" />\n                  <circle cx=\"360\" cy=\"200\" r=\"4\" fill=\"#E4000F\" className=\"animate-pulse\" />\n                  \n                  <circle cx=\"87\" cy=\"87\" r=\"5\" fill=\"#ffffff\" className=\"opacity-80\" />\n                  <circle cx=\"313\" cy=\"313\" r=\"5\" fill=\"#ffffff\" className=\"opacity-80\" />\n                  <circle cx=\"87\" cy=\"313\" r=\"3\" fill=\"#009DFF\" />\n                  <circle cx=\"313\" cy=\"87\" r=\"3\" fill=\"#E4000F\" />\n                </g>\n\n                {/* Central Orchestrator Core */}\n                <circle cx=\"200\" cy=\"200\" r=\"42\" fill=\"#050505\" stroke=\"url(#gradientCore)\" strokeWidth=\"2.5\" className=\"shadow-2xl\" />\n                <circle cx=\"200\" cy=\"200\" r=\"28\" fill=\"url(#coreGlow)\" />\n                <path d=\"M190 200 L210 200 M200 190 L200 210\" stroke=\"white\" strokeWidth=\"2\" className=\"opacity-70\" />\n\n                {/* Definitions */}\n                <defs>\n                  <linearGradient id=\"gradientRing1\" x1=\"0\" y1=\"0\" x2=\"400\" y2=\"400\" gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#E4000F\" />\n                    <stop offset=\"1\" stopColor=\"#009DFF\" />\n                  </linearGradient>\n                  <linearGradient id=\"gradientRing2\" x1=\"400\" y1=\"0\" x2=\"0\" y2=\"400\" gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#009DFF\" />\n                    <stop offset=\"1\" stopColor=\"#E4000F\" />\n                  </linearGradient>\n                  <linearGradient id=\"gradientCore\" x1=\"150\" y1=\"150\" x2=\"250\" y2=\"250\" gradientUnits=\"userSpaceOnUse\">\n                    <stop stopColor=\"#E4000F\" />\n                    <stop offset=\"0.5\" stopColor=\"#FFFFFF\" />\n                    <stop offset=\"1\" stopColor=\"#009DFF\" />\n                  </linearGradient>\n                  <radialGradient id=\"coreGlow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n                    <stop offset=\"0%\" stopColor=\"#009DFF\" stopOpacity=\"0.4\" />\n                    <stop offset=\"100%\" stopColor=\"#E4000F\" stopOpacity=\"0\" />\n                  </radialGradient>\n                </defs>\n              </svg>\n\n              {/* Glowing Corner Accents */}\n              <div className=\"absolute top-0 left-0 w-8 h-8 border-t border-l border-white/15 rounded-tl-[32px]\" />\n              <div className=\"absolute top-0 right-0 w-8 h-8 border-t border-r border-white/15 rounded-tr-[32px]\" />\n              <div className=\"absolute bottom-0 left-0 w-8 h-8 border-b border-l border-white/15 rounded-bl-[32px]\" />\n              <div className=\"absolute bottom-0 right-0 w-8 h-8 border-b border-r border-white/15 rounded-br-[32px]\" />\n            </div>\n          </div>\n        )}\n      </div>\n    </section>\n  );\n}\n"}}}
