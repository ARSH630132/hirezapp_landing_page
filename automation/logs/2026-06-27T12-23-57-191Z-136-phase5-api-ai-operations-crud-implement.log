{"ts":"2026-06-27T12:21:56.808Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"e5uac41g","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-ai-operations-apis.js","new_text":"/* eslint-disable */\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-ai-op-build');\n\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n\ntry {\n  console.log(\"Compiling TypeScript files...\");\n  execSync('npx tsc lib/api-auth.ts app/api/v1/ai-operations/route.ts app/api/v1/ai-operations/[id]/route.ts --outDir temp-ai-op-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'inherit' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  process.exit(1);\n}\n\nconst apiAuth = require('../temp-ai-op-build/lib/api-auth.js');\nconst opRoute = require('../temp-ai-op-build/app/api/v1/ai-operations/route.js');\nconst opIdRoute = require('../temp-ai-op-build/app/api/v1/ai-operations/[id]/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    // 1. Auth guards\n    let res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": inactive } }));\n    if (res.status !== 403) throw new Error(\"Inactive user must be 403\");\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\"));\n    if (res.status !== 401) throw new Error(\"No token must be 401\");\n\n    // 2. Admin GET & Tenant checks\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.operations.length < 4) throw new Error(\"Admin list failed\");\n\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": member } }));\n    d = await res.json();\n    if (d.operations.some(o => o.client_id !== \"client-004\")) throw new Error(\"Tenant leakage\");\n\n    // 3. Filters\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?client_id=client-001&status=active&health=healthy&agent_type=autonomous&governance_status=compliant\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.client_id !== \"client-001\" || o.status !== \"active\" || o.health !== \"healthy\")) throw new Error(\"Combined filters failed\");\n\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?project_id=proj-003\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.project_id !== \"proj-003\")) throw new Error(\"Project filter failed\");\n\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?search=Logistics\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (!d.operations[0]?.name.toLowerCase().includes(\"logistics\")) throw new Error(\"Search filter failed\");\n\n    // 4. GET single & Cross-tenant GET\n    res = await opIdRoute.GET(new Request(\"http://l/api/v1/ai-operations/op-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"op-001\" }) });\n    d = await res.json();\n    if (res.status !== 200 || d.operation.id !== \"op-001\") throw new Error(\"GET single failed\");\n\n    res = await opIdRoute.GET(new Request(\"http://l/api/v1/ai-operations/op-004\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"op-004\" }) });\n    if (res.status !== 403) throw new Error(\"Cross-tenant GET must be 403\");\n\n    // 5. POST create\n    const newOpData = { name: \"Sovereign Market Predictor\", client_id: \"client-002\", project_id: \"proj-002\", desc: \"Sandbox loop\" };\n    res = await opRoute.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(newOpData) }));\n    if (res.status !== 403) throw new Error(\"Client POST must be 403\");\n\n    res = await opRoute.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(newOpData) }));\n    if (res.status !== 201) throw new Error(\"Admin POST failed\");\n    d = await res.json();\n    const createdId = d.operation.id;\n    if (d.operation.client_name !== \"Global Retail Enclave [Preview Client]\") throw new Error(\"Client mapping failed\");\n\n    // 6. PATCH update\n    res = await opIdRoute.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ name: \"Hacked\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client PATCH must be 403\");\n\n    res = await opIdRoute.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ name: \"Sovereign Sandbox Run\", health: \"critical\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"Admin PATCH failed\");\n    d = await res.json();\n    if (d.operation.name !== \"Sovereign Sandbox Run\" || d.operation.health !== \"critical\") throw new Error(\"PATCH update failed\");\n\n    // 7. DELETE\n    res = await opIdRoute.DELETE(new Request(`http://l/api/