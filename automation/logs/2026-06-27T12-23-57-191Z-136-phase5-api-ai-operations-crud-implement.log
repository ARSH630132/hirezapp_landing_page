{"ts":"2026-06-27T12:21:44.818Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"269is5cq","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-ai-operations-apis.js","new_text":"/* eslint-disable */\n\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-ai-op-build');\n\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n\ntry {\n  console.log(\"Compiling TypeScript files for testing...\");\n  execSync('npx tsc lib/api-auth.ts app/api/v1/ai-operations/route.ts app/api/v1/ai-operations/[id]/route.ts --outDir temp-ai-op-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'inherit' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  console.error(\"TypeScript compilation failed:\", e);\n  process.exit(1);\n}\n\nconst apiAuth = require('../temp-ai-op-build/lib/api-auth.js');\nconst opRoute = require('../temp-ai-op-build/app/api/v1/ai-operations/route.js');\nconst opIdRoute = require('../temp-ai-op-build/app/api/v1/ai-operations/[id]/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    // 1. Auth guards: inactive user must be 403\n    let res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": inactive } }));\n    if (res.status !== 403) throw new Error(\"Inactive user must be 403\");\n\n    // 2. Auth guards: no token must be 401\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\"));\n    if (res.status !== 401) throw new Error(\"No token must be 401\");\n\n    // 3. Admin GET list: should fetch all operations\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.operations.length < 4) throw new Error(\"Admin list failed to fetch all records\");\n\n    // 4. Client tenant boundary checks: client member should only see operations matching their client_id\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations\", { headers: { \"Authorization\": member } }));\n    d = await res.json();\n    if (d.operations.some(o => o.client_id !== \"client-004\")) throw new Error(\"Client list leakage: member saw other clients' operations\");\n\n    // 5. Filter by client_id as admin\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?client_id=client-001\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.client_id !== \"client-001\")) throw new Error(\"Admin client filter failed\");\n\n    // 6. Filter by project_id\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?project_id=proj-003\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.project_id !== \"proj-003\")) throw new Error(\"Project filter failed\");\n\n    // 7. Filter by status\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?status=paused\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.status !== \"paused\")) throw new Error(\"Status filter failed\");\n\n    // 8. Filter by health\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?health=critical\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.health !== \"critical\")) throw new Error(\"Health filter failed\");\n\n    // 9. Filter by agent_type\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?agent_type=autonomous\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.agent_type !== \"autonomous\")) throw new Error(\"Agent type filter failed\");\n\n    // 10. Filter by governance_status\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?governance_status=flagged\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.some(o => o.governance_status !== \"flagged\")) throw new Error(\"Governance status filter failed\");\n\n    // 11. Generic Search filter\n    res = await opRoute.GET(new Request(\"http://l/api/v1/ai-operations?search=Logistics\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.operations.length === 0 || !d.operations[0].name.toLowerCase().includes(\"logistics\")) throw new Error(\"Search filter failed\");\n\n    // 12. GET single operation\n    res = await opIdRoute.GET(new Request(\"http://l/api/v1/ai-operations/op-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"op-001\" }) });\n    d = await res.json();\n    if (res.status !== 200 || d.operation.id !== \"op-001\") throw new Error(\"GET single operation failed\");\n\n    // 13. Cross-tenant GET validation: a client user from client-001 trying to fetch op-004 (client-004) should be 403\n    res = await opIdRoute.GET(new Request(\"http://l/api/v1/ai-operations/op-004\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"op-004\" }) });\n    if (res.status !== 403) throw new Error(\"Cross-tenant GET must be 403 Forbidden\");\n\n    // 14. POST create: client role is forbidden (403)\n    const newOpData = {\n      name: \"Sovereign Market Predictor\",\n      client_id: \"client-002\",\n      project_id: \"proj-002\",\n      desc: \"Isolated GPU sandbox verifying market estimation loops.\",\n      agent_type: \"autonomous\"\n    };\n    res = await opRoute.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(newOpData) }));\n    if (res.status !== 403) throw new Error(\"Client POST must be 403 Forbidden\");\n\n    // 15. POST create: admin role succeeds (201)\n    res = await opRoute.POST(new Request(\"http://l/api/v1/ai-operations\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(newOpData) }));\n    if (res.status !== 201) throw new Error(\"Admin POST failed\");\n    d = await res.json();\n    const createdId = d.operation.id;\n    if (d.operation.client_name !== \"Global Retail Enclave [Preview Client]\") throw new Error(\"Client name mapping failed during POST\");\n\n    // 16. PATCH update: client role is forbidden (403)\n    res = await opIdRoute.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ name: \"Malicious Tampering\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client PATCH must be 403 Forbidden\");\n\n    // 17. PATCH update: admin role succeeds (200)\n    res = await opIdRoute.PATCH(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ name: \"Sovereign Market Sandbox Run\", health: \"critical\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"Admin PATCH failed\");\n    d = await res.json();\n    if (d.operation.name !== \"Sovereign Market Sandbox Run\" || d.operation.health !== \"critical\") throw new Error(\"PATCH field updates failed to register\");\n\n    // 18. DELETE: client role is forbidden (403)\n    res = await opIdRoute.DELETE(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"DELETE\", headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client DELETE must be 403 Forbidden\");\n\n    // 19. DELETE: admin role succeeds (200)\n    res = await opIdRoute.DELETE(new Request(`http://l/api/v1/ai-operations/${createdId}`, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"Admin DELETE failed\");\n\n    // 20. Post-delete lookup must return 404\n    res = await opIdRoute.GET(new Request(`http://l/api/v1/ai-operations/${createdId}`, { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 404) throw new Error(\"Lookup of deleted record must return 404 Not Found\");\n\n    console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: AI Operations CRUD APIs verified flawlessly!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Validation test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\n\nrun();\n"}}}
