1 : -1);\n 47 |     });\n 48 |   }\n 49 | \n 50 |   const paginatedData = processedData.slice(\n 51 |     (currentPage - 1) * pageSize,\n 52 |     currentPage * pageSize\n 53 |   );\n 54 | \n 55 |   return (\n 56 |     <div className=\"border border-white/5 rounded-xl overflow-hidden bg-black/20 backdrop-blur-sm\">\n 57 |       <div className=\"overflow-x-auto\">\n 58 |         <table className=\"w-full text-left font-mono text-[11.5px] text-white/70\">\n 59 |           <thead>\n 60 |             <tr className=\"bg-white/[0.02] border-b border-white/5 text-white/40 text-[9.5px] uppercase select-none\">\n 61 |               {columns.map((col, idx) => (\n 62 |                 <th \n 63 |                   key={idx} \n 64 |                   onClick={() => handleSort(col.key, col.sortable)}\n 65 |                   className={`p-4 font-bold tracking-wider ${col.sortable ? \"hover:text-white cursor-pointer\" : \"\"}`}\n 66 |                 >\n 67 |                   <div className=\"flex items-center gap-1\">\n 68 |                     <span>{col.header}</span>\n 69 |                     {col.sortable && sortKey === col.key && (\n 70 |                       <span className=\"text-[9px] text-[#009DFF]\">{sortOrder === \"asc\" ? \"▲\" : \"▼\"}</span>\n 71 |                     )}\n 72 |                   </div>\n 73 |                 </th>\n 74 |               ))}\n 75 |             </tr>\n 76 |           </thead>\n 77 |           <tbody className=\"divide-y divide-white/5\">\n 78 |             {paginatedData.length === 0 ? (\n 79 |               <tr>\n 80 |                 <td colSpan={columns.length} className=\"p-8 text-center text-[11px] text-white/35\">\n 81 |                   No core records match current queries.\n 82 |                 </td>\n 83 |               </tr>\n 84 |             ) : (\n 85 |               paginatedData.map((row, rIdx) => (\n 86 |                 <tr \n 87 |                   key={row.id || rIdx} \n 88 |                   onClick={() => on