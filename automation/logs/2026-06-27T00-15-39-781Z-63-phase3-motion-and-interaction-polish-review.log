          <h3 className=\"text-sm font-bold text-white mt-1\">Sovereign Financial Value Waterfall Chart</h3>\n1048 |               </div>\n1049 |               <span className=\"text-[9px] font-mono text-white/30 hidden md:inline\">UNIT: USD ($) // ANNUALIZED MODEL</span>\n1050 |             </div>\n1051 |             <div className=\"w-full overflow-x-auto scrollbar-none\">\n1052 |               <svg viewBox=\"0 0 720 230\" className=\"w-full min-w-[580px] h-auto overflow-visible select-none\" fill=\"none\">\n1053 |                 <line x1=\"30\" y1=\"20\" x2=\"690\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n1054 |                 <line x1=\"30\" y1=\"70\" x2=\"690\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1055 |                 <line x1=\"30\" y1=\"120\" x2=\"690\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1056 |                 <line x1=\"30\" y1=\"170\" x2=\"690\" y2=\"170\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1057 |                 <line x1=\"30\" y1=\"200\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n1058 |                 {(() => {\n1059 |                   const maxAmt = Math.max(addressableCostBaseline, expectedGrossSavings, initialInvestment, expectedNetSavings, 1);\n1060 |                   const getY = (v: number) => 200 - (v / maxAmt) * 160;\n1061 |                   const getH = (v: number) => (v / maxAmt) * 160;\n1062 |                   const b1Y = getY(addressableCostBaseline), b1H = getH(addressableCostBaseline);\n1063 |                   const b2H = getH(expectedGrossSavings), b2Y = b1Y;\n1064 |                   const b3H = getH(initialInvestment), b3Y = b2Y + b2H - b3H;\n1065 |                   const b4Y = getY(expectedNetSavings), b4H = getH(expectedNetSavings);\n1066 |                   return (\n1067 |                     <>\n1068 |                       <line x1=\"120\" y1={b1Y} x2=\"210\" y2={b2Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1069 |                       <line x1=\"290\" y1={b2Y+b2H} x2=\"380\" y2={b3Y+b3H} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1070 |                       <line x1=\"460\" y1={b3Y} x2=\"550\" y2={b4Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1071 |                       <g>\n1072 |                         <motion.rect \n1073 |                           x=\"50\" \n1074 |                           y={b1Y} \n1075 |                           width=\"70\" \n1076 |                           height={b1H} \n1077 |                           rx=\"3\" \n1078 |                           fill=\"url(#fG)\" \n1079 |                           stroke=\"rgba(255,255,255,0.05)\"\n1080 |                           initial={{ height: 0, y: 200 }}\n1081 |                           animate={{ height: b1H, y: b1Y }}\n1082 |                           transition={{ duration: 0.8, ease: \"easeOut\" }}\n1083 |                         />\n1084 |                         <motion.text \n1085 |                           x=\"85\" \n1086 |                           y={Math.max(b1Y-8,15)} \n1087 |                           textAnchor=\"middle\" \n1088 |                           className=\"fill-white/80 font-mono text-[10px] font-bold\"\n1089 |                           initial={{ opacity: 0 }}\n1090 |                           animate={{ opacity: 1 }}\n1091 |                           transition={{ delay: 0.4, duration: 0.3 }}\n1092 |                         >\n1093 |                           {formatCompactCurrency(addressableCostBaseline)}\n1094 |                         </motion.text>\n1095 |                       </g>\n1096 |                       <g>\n1097 |                         <motion.rect \n1098 |                           x=\"220\" \n1099 |                           y={b2Y} \n110