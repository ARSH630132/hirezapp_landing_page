            const act = activeStage.n === stg.n;\n389 |                   return (\n390 |                     <button \n391 |                       key={stg.n} \n392 |                       onClick={() => setActiveStage(stg)} \n393 |                       className=\"flex flex-col items-center relative z-10 group focus:outline-none w-[95px] shrink-0\"\n394 |                     >\n395 |                       <div className={`w-11 h-11 rounded-full border-2 flex items-center justify-center text-xs font-mono font-bold transition-all duration-300 ${\n396 |                         act \n397 |                           ? \"bg-black border-[#009DFF] text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.4)] scale-110\" \n398 |                           : stg.n < activeStage.n \n399 |                             ? \"bg-gradient-to-r from-[#E4000F] to-[#009DFF] border-transparent text-white\" \n400 |                             : \"bg-[#020202] border-white/10 text-white/40 group-hover:border-white/30\"\n401 |                       }`}>\n402 |                         {stg.n}\n403 |                       </div>\n404 |                       <span className={`text-[10px] mt-2.5 font-bold tracking-tight truncate w-full text-center transition-colors ${\n405 |                         act ? \"text-[#009DFF]\" : \"text-white/60 group-hover:text-white\"\n406 |                       }`}>\n407 |                         {stg.name}\n408 |                       </span>\n409 |                     </button>\n410 |                   );\n411 |                 })}\n412 |               </div>\n413 |             </div>\n414 | \n415 |             {/* Active Stage Details Panel */}\n416 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 pt-4\">\n417 |               <div className=\"lg:col-span-8 space-y-4\">\n418 |                 <div className=\"flex items-center gap-2 text-[11px] font-mono text-white/50\">\n419 |                   <span className=\"text-[#E4000F] font-bold\">PHASE 0{activeStage.n}</span>\n420 |                   <span>|</span>\n421 |                   <span className=\"text-[#00FF9D] font-semibold\">{activeStage.metric}</span>\n422 |                 </div>\n423 |                 <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">\n424 |                   {activeStage.name} Milestone Target\n425 |                 </h3>\n426 |                 <p className=\"text-white/70 text-xs leading-relaxed max-w-[720px] font-light\">\n427 |                   {activeStage.desc}\n428 |                 </p>\n429 |                 <div className=\"pt-2\">\n430 |                   <Link \n431 |                     href={activeStage.tool} \n432 |                     className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF]/30 transition group\"\n433 |                   >\n434 |                     <span>Launch {activeStage.btn} Helper</span>\n435 |                     <svg className=\"w-3 h-3 group-hover:translate-x-1 transition-transform text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n436 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n437 |                     </svg>\n438 |                   </Link>\n439 |                 </div>\n440 |               </div>\n441 |               \n442 |               <div className=\"lg:col-span-4 p-5 rounded-2xl bg-white/[0.01] border border-white/5 flex flex-col justify-between\">\n443 |                 <div>\n444 |                   <h4 className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mb-2\">EXPECTED PIPELINE OUTCOME</h4>\n445 |                   <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n446 |                     {activeStage.artifact}\n447 |                   </p>\n448 |                 </div>\n449 |                 <div