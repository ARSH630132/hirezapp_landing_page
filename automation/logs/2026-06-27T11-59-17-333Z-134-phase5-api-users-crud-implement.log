earance, client association, status, and role. I will be sure to add error messages to the responses. For example, status and role have constraints.\n\n\n**Refining Role Updates**\n\nI'm now focusing on role updates within the `PATCH` implementation. I'm handling cases for role changes, including associated permission updates. I am handling scenarios that require specific permission sets. I'm validating the new role and, if valid, updating the user's role and associated permissions. I've also implemented error responses for invalid role.\n\n\n\n"}}
{"ts":"2026-06-27T11:51:34.874Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"r133l5l8","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/api/v1/users/[id]/route.ts","new_text":"import { NextResponse } from \"next/server\";\nimport { API_MOCK_USERS, verifyJwt, hashPassword, MockUserDbEntry } from \"@/lib/api-auth\";\n\nexport const runtime = \"nodejs\";\n\nfunction getAuthCaller(req: Request) {\n  const auth = req.headers.get(\"authorization\");\n  if (!auth?.startsWith(\"Bearer \")) return { status: 401, error: \"Unauthorized\", msg: \"Missing/malformed Authorization header.\" };\n  const decoded = verifyJwt(auth.substring(7));\n  if (!decoded?.email) return { status: 401, error: \"Unauthorized\", msg: \"Invalid/expired access token.\" };\n  const user = API_MOCK_USERS[decoded.email.toLowerCase().trim()];\n  if (!user) return { status: 401, error: \"Unauthorized\", msg: \"Authorized user not found.\" };\n  if (user.status === \"inactive\") return { status: 403, error: \"Forbidden\", msg: \"This account is inactive.\" };\n  return { caller: user };\n}\n\n// GET by id\nexport async function GET(req: Request, { params }: { params: any }) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n    \n    if (auth.caller.role !== \"gff_admin\" && auth.caller.role !== \"client_admin\") {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Admin role required.\" }, { status: 403 });\n    }\n\n    const { id } = await params;\n    const userEntry = Object.values(API_MOCK_USERS).find(u => u.id === id);\n    if (!userEntry) {\n      return NextResponse.json({ success: false, error: \"Not Found\", message: \"User not found.\" }, { status: 404 });\n    }\n\n    // Client admin can only view users inside their own clientAssociation\n    if (auth.caller.role === \"client_admin\" && userEntry.clientAssociation !== auth.caller.clientAssociation) {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Access denied to user of another client.\" }, { status: 403 });\n    }\n\n    const { passwordHash, ...userRes } = userEntry;\n    return NextResponse.json({ success: true, user: userRes });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\n// PATCH update user details\nexport async function PATCH(req: Request, { params }: { params: any }) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n\n    // Only gff_admin should update user profiles or change roles if possible\n    if (auth.caller.role !== \"gff_admin\") {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Only GFF platform administrators can update user details.\" }, { status: 403 });\n    }\n\n    const { id } = await params;\n    const userEntry = Object.entries(API_MOCK_USERS).find(([_, u]) => u.id === id);\n    if (!userEntry) {\n      return NextResponse.json({ success: false, error: \"Not Found\", message: \"User not found.\" }, { status: 404 });\n    }\n\n    const [emailKey, existingUser] = userEntry;\n    const body = await req.json().catch(() => null);\n    if (!body) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid JSON.\" }, { status: 400 });\n\n    const { name, email, role, clientAssociation, status, clearance, password } = body;\n\n    const updatedUser: MockUserDbEntry = { ...existingUser };\n\n    if (name !== undefined) {\n      if (typeof name !== \"string\" || name.trim().length < 2) {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Name must be at least 2 characters.\" }, { status: 400 });\n      }\n      updatedUser.name = name.trim();\n    }\n\n    if (clearance !== undefined) updatedUser.clearance = clearance;\n    if (clientAssociation !== undefined) updatedUser.clientAssociation = clientAssociation;\n\n    if (status !== undefined) {\n      if (status !== \"active\" && status !== \"inactive\") {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Status must be 'active' or 'inactive'.\" }, { status: 400 });\n      }\n      updatedUser.status = status;\n    }\n\n    if (role !== undefined) {\n      const allowedRoles = [\"gff_admin\", \"client_admin\", \"client_member\"];\n      if (!allowedRoles.includes(role)) {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid role specified.\" }, { status: 400 });\n      }\n      updatedUser.role = role as any;\n\n      // Update default permissions if role changes\n      if (role === \"gff_admin\") {\n        updatedUser.permissions = [\"all:*\", \"read:telemetry\", \"write:telemetry\", \"read:projects\", \"write:projects\", \"read:users\", \"write:users\", \"read:clients\", \"write:clients\", \"write:governance\"];\n      } else if (role === \"client_admin\") {\n        updatedUser.permissions = [\"read:telemetry\", \"read:projects\", \"write:projects\", \"read:ai-operations\", \"write:ai-operations\", \"read:documents\", \"write:documents\", \"write:support\"];\n      } else {\n        updatedUser.permissions = [\"read:telemetry\", \"read:projects\", \"read:ai-operations\", \"read:documents\", \"write:support\"];\n      }\n    }\n\n    if (password !== undefined) {\n      if (typeof password !== \"string\" || password.trim().length < 6) {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Password must be at least 6 characters.\" }, { status: 400 });\n      }\n      updatedUser.passwordHash = hashPassword(password);\n    }\n\n    if (email !== undefined) {\n      if (typeof email !== \"string\" || !email.includes(\"@\")) {\n        return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid email format.\" }, { status: 400 });\n      }\n      const newEmail = email.toLowerCase().trim();\n      if (newEmail !== emailKey) {\n        if (API_MOCK_USERS[newEmail]) {\n          return NextResponse.json({ success: false, error: \"Conflict\", message: \"Email already taken by another account.\" }, { status: 409 });\n        }\n        updatedUser.email = newEmail;\n        delete API_MOCK_USERS[emailKey];\n        API_MOCK_USERS[newEmail] = updatedUser;\n      } else {\n        API_MOCK_USERS[emailKey] = updatedUser;\n      }\n    } else {\n      API_MOCK_USERS[emailKey] = updatedUser;\n    }\n\n    const { passwordHash: _, ...userRes } = updatedUser;\n    return NextResponse.json({ success: true, user: userRes });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\n// DELETE user\nexport async function DELETE(req: Request, { params }: { params: any }) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n\n    if (auth.caller.role !== \"gff_admin\") {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Only GFF platform administrators can delete users.\" }, { status: 403 });\n    }\n\n    const { id } = await params;\n    const userEntry = Object.entries(API_MOCK_USERS).find(([_, u]) => u.id === id);\n    if (!userEntry) {\n      return NextResponse.json({ success: false, error: \"Not Found\", message: \"User not found.\" }, { status: 404 });\n    }\n\n    const [emailKey, existingUser] = userEntry;\n\n    // Prevent self-deletion\n    if (existingUser.email === auth.caller.email) {\n      return NextResponse.json({ success: false, error: \"Forbidden\", message: \"You cannot delete your own account.\" }, { status: 403 });\n    }\n\n    delete API_MOCK_USERS[emailKey];\n\n    return NextResponse.json({ success: true, message: \"User successfully deleted from the system.\" });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}"}}}
