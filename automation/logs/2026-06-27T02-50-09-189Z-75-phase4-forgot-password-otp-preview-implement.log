><span className=\"uppercase\">Reference ID:</span> <span className=\"text-[#009DFF]\">RECOVERY_0x8F9B2C</span></div>\n            </div>\n            <div className=\"flex justify-end pt-2\">\n              <button\n                type=\"button\"\n                onClick={() => setShowForgot(false)}\n                className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-sans font-bold text-xs uppercase tracking-wider rounded-lg transition-all cursor-pointer focus:outline-none focus:ring-1 focus:ring-white\"\n              >\n                Close Handshake\n              </button>\n            </div>\n          </div>\n        </div>\n      )}","new_text":"      {showForgot && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md p-4 animate-fade-in\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"forgot-title\">\n          <div className=\"bg-zinc-950 border border-zinc-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n            \n            {/* Header */}\n            <div className=\"flex justify-between items-start\">\n              <div className=\"flex items-center gap-2.5 text-zinc-200\">\n                <div className=\"p-1.5 rounded-lg bg-[#009DFF]/10 text-[#009DFF]\">\n                  <Fingerprint className=\"w-5 h-5\" />\n                </div>\n                <h3 id=\"forgot-title\" className=\"font-mono font-bold text-xs uppercase tracking-wider\">Passphrase Key Recovery</h3>\n              </div>\n              <button \n                onClick={() => {\n                  setShowForgot(false);\n                  setForgotSubmitted(false);\n                  setForgotEmail(\"\");\n                  setForgotError(\"\");\n                }} \n                className=\"text-zinc-500 hover:text-zinc-300 transition-colors cursor-pointer p-1 rounded-md hover:bg-zinc-900 focus:outline-none\"\n                aria-label=\"Close recovery dialog\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            <AnimatePresence mode=\"wait\">\n              {!forgotSubmitted ? (\n                <motion.form \n                  key=\"forgot-form\"\n                  initial={{ opacity: 0, y: 10 }}\n                  animate={{ opacity: 1, y: 0 }}\n                  exit={{ opacity: 0, y: -10 }}\n                  onSubmit={async (e) => {\n                    e.preventDefault();\n                    if (!forgotEmail || !forgotEmail.includes(\"@\")) {\n                      setForgotError(\"Please enter a valid enterprise email address.\");\n                      return;\n                    }\n                    setForgotError(\"\");\n                    setForgotLoading(true);\n                    \n                    // Simulate processing\n                    await new Promise(resolve => setTimeout(resolve, 800));\n                    \n                    setForgotLoading(false);\n                    setForgotSubmitted(true);\n                    logTelemetry(`[RECOVERY] Dispatched isolated recovery simulation vector to ${forgotEmail}.`);\n                  }}\n                  className=\"space-y-4\"\n                >\n                  <p className=\"text-xs text-zinc-400 leading-relaxed font-sans text-left\">\n                    GFF AI Zero-Trust Enclaves enforce rigorous defense protocols. Request an out-of-band passphrase reset vector for your sovereign identity profile.\n                  </p>\n\n                  <div className=\"space-y-1.5 text-left\">\n                    <label htmlFor=\"forgot-email\" className=\"text-[9.5px] font-mono text-zinc-400 uppercase tracking-widest block font-bold\">\n                      Registered Enterprise Email\n                    </label>\n                    <input\n                      id=\"forgot-email\"\n                      type=\"email\"\n                      value={forgotEmail}\n                     