s:ring-[#009DFF] text-zinc-200 text-xs placeholder-zinc-700 transition-all outline-none font-mono tracking-widest focus:bg-zinc-950\"\n                            required\n                          />\n                          <button\n                            type=\"button\"\n                            onClick={() => setShowPassword(!showPassword)}\n                            className=\"absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 transition-colors focus:outline-none cursor-pointer\"\n                            aria-label={showPassword ? \"Hide password\" : \"Show password\"}\n                          >\n                            {showPassword ? <EyeOff className=\"w-3.5 h-3.5\" /> : <Eye className=\"w-3.5 h-3.5\" />}\n                          </button>\n                        </div>\n                      </div>\n                    ) : (\n                      <div className=\"space-y-3 p-4 rounded-xl bg-zinc-900/30 border border-zinc-900 relative overflow-hidden\">\n                        {/* Interactive Grid Header */}\n                        <div className=\"flex justify-between items-center\">\n                          <label htmlFor=\"auth-otp\" className=\"text-[9.5px] font-mono text-zinc-400 uppercase tracking-widest block font-bold flex items-center gap-1.5\">\n                            <Key className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Multi-Factor OTP Code\n                          </label>\n                          <div className=\"px-2 py-0.5 rounded bg-[#009DFF]/5 border border-[#009DFF]/10 text-zinc-500 font-mono text-[8px] tracking-wide font-bold\">\n                            SIMULATED MFA\n                          </div>\n                        </div>\n\n                        {/* Input Block */}\n                        <div className=\"space-y-2\">\n                          <input\n                            id=\"auth-otp\"\n                            type=\"text\"\n                            inputMode=\"numeric\"\n                            pattern=\"[0-9]*\"\n                            value={otpCode}\n                            onChange={(e) => handleInputChange(\"otp\", e.target.value)}\n                            placeholder=\"102486\"\n                            maxLength={6}\n                            className=\"w-full h-11 px-4 rounded-lg bg-zinc-950 border border-zinc-800 focus:border-[#009DFF] focus:ring-1 focus:ring-[#009DFF] text-zinc-100 text-sm font-semibold tracking-[0.6em] text-center focus:bg-zinc-950 transition-all outline-none font-mono\"\n                            required\n                          />\n                        </div>\n\n                        {/* Microcopy & Notice */}\n                        <p className=\"text-[10px] text-zinc-500 leading-relaxed font-sans\">\n                          <span className=\"text-[#009DFF] font-semibold\">Preview Note:</span> GFF AI Multi-Factor verification is running in UI design preview mode. Enter any 6-digit numeric sequence to proceed, or click \"Generate Code\" to fill the simulation payload.\n                        </p>\n\n                        {/* Helper Actions Group */}\n                        <div className=\"flex justify-between items-center pt-1 border-t border-zinc-900/80\">\n                          <button\n                            type=\"button\"\n                            onClick={() => {\n                              logTelemetry(\"[SYS] Loaded mock multi-factor key: 102486.\");\n                              setOtpCode(\"102486\");\n                              setError(\"\");\n                            }}\n                            className=\"text-[9.5px] font-mono text-[#009DFF] hover:text-[#0086db] font-semibold transition-colors focus:outline-none cursor-pointer flex items-center gap-1\"\n                          >\n                            <RefreshCw className=\"w-3 h-3\" /> Generate Code\n                          </button>\n                          \n                          <div className=\"flex items-center gap-3\">\n                            {otpCode && (\n                              <button\n                                type=\"button\"\n                                onClick={() => {\n                                  setOtpCode(\"\");\n                                  logTelemetry(\"[SYS] Reset simulated multi-factor payload.\");\n                                }}\n                                className=\"text-[9.5px] font-mono text-zinc-500 hover:text-zinc-300 transition-colors focus:outline-none cursor-pointer\"\n                              >\n                                Clear\n                              </button>\n                            )}\n                            \n                            <button\n                              type=\"button\"\n                              onClick={() => {\n                                setAuthMethod(\"credentials\");\n                                setError(\"\");\n                                logTelemetry(\"[TAB] Reverted authorization vector to Secure Keycard.\");\n                              }}\n                              className=\"text-[9.5px] font-mono text-zinc-500 hover:text-zinc-300 hover:underline transition-colors focus:outline-none cursor-pointer\"\n                            >\n                              Keycard Login\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    )}"}}}
