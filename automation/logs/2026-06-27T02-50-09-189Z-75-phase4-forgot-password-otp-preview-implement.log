><span className=\"uppercase\">Reference ID:</span> <span className=\"text-[#009DFF]\">RECOVERY_0x8F9B2C</span></div>\n            </div>\n            <div className=\"flex justify-end pt-2\">\n              <button\n                type=\"button\"\n                onClick={() => setShowForgot(false)}\n                className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-sans font-bold text-xs uppercase tracking-wider rounded-lg transition-all cursor-pointer focus:outline-none focus:ring-1 focus:ring-white\"\n              >\n                Close Handshake\n              </button>\n            </div>\n          </div>\n        </div>\n      )}","new_text":"      {showForgot && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md p-4 animate-fade-in\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"forgot-title\">\n          <div className=\"bg-zinc-950 border border-zinc-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n            <div className=\"flex justify-between items-start\">\n              <div className=\"flex items-center gap-2.5 text-zinc-200 text-left\">\n                <div className=\"p-1.5 rounded-lg bg-[#009DFF]/10 text-[#009DFF]\">\n                  <Fingerprint className=\"w-5 h-5\" />\n                </div>\n                <h3 id=\"forgot-title\" className=\"font-mono font-bold text-xs uppercase tracking-wider\">Passphrase Key Recovery</h3>\n              </div>\n              <button \n                onClick={() => {\n                  setShowForgot(false);\n                  setForgotSubmitted(false);\n                  setForgotEmail(\"\");\n                  setForgotError(\"\");\n                }} \n                className=\"text-zinc-500 hover:text-zinc-300 transition-colors cursor-pointer p-1 rounded-md hover:bg-zinc-900 focus:outline-none\"\n                aria-label=\"Close recovery dialog\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            {!forgotSubmitted ? (\n              <form onSubmit={async (e) => {\n                e.preventDefault();\n                if (!forgotEmail.includes(\"@\")) { setForgotError(\"Valid enterprise email required.\"); return; }\n                setForgotError(\"\"); setForgotLoading(true);\n                await new Promise(r => setTimeout(r, 800));\n                setForgotLoading(false); setForgotSubmitted(true);\n                logTelemetry(`[RECOVERY] Dispatched isolated recovery simulation to ${forgotEmail}.`);\n              }} className=\"space-y-4\">\n                <p className=\"text-xs text-zinc-400 leading-relaxed font-sans text-left\">\n                  GFF AI Zero-Trust Enclaves enforce rigorous defense protocols. Request an out-of-band reset handshake for your sovereign identity profile.\n                </p>\n                <div className=\"space-y-1.5 text-left font-mono\">\n                  <label htmlFor=\"forgot-email\" className=\"text-[9.5px] text-zinc-400 uppercase tracking-widest block font-bold\">Registered Email</label>\n                  <input id=\"forgot-email\" type=\"email\" value={forgotEmail} onChange={(e) => setForgotEmail(e.target.value)} placeholder=\"employee@gff.ai\" className=\"w-full h-10 px-3 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-200 text-xs placeholder-zinc-700 outline-none focus:border-[#009DFF]\" required />\n                </div>\n                {forgotError && (\n                  <div className=\"p-2.5 bg-rose-950/20 border border-rose-900/35 text-rose-400 rounded-lg text-[11px] flex items-center gap-2 font-sans\"><AlertCircle className=\"w-4 h-4 shrink-0\" /><span>{forgotError}</span></div>\n                )}\n                <div className=\"flex justify-between items-center pt-1 gap-3 font-sans\">\n                  <button type=\"button\" onClick={() => { setShowForgot(false); setForgotSubmitted(false); setForgotEmail(\"\"); }} className=\"flex-1 h-9 bg-transparent hover:bg-zinc-900 border border-zinc-800 text-zinc-400 hover:text-white font-bold text-xs uppercase tracking-wider rounded-lg\">Cancel</button>\n                  <button type=\"submit\" disabled={forgotLoading} className=\"flex-1 h-9 bg-[#009DFF] hover:bg-[#0086db] text-black font-bold text-xs uppercase tracking-wider rounded-lg flex items-center justify-center gap-1.5\">{forgotLoading ? \"Verifying...\" : \"Request Reset\"}</button>\n                </div>\n              </form>\n            ) : (\n              <div className=\"space-y-4 text-left font-sans\">\n                <div className=\"p-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-lg text-xs flex items-start gap-2.5\">\n                  <CheckCircle className=\"w-4.5 h-4.5 shrink-0 mt-0.5\" />\n                  <div>\n                    <span className=\"font-bold block uppercase tracking-wider text-[10px] mb-0.5\">Simulation Vector Confirmed</span>\n                    <p className=\"leading-relaxed\">A secure reset handshake has been provisioned for <span className=\"font-semibold text-white\">{forgotEmail}</span>.</p>\n                  </div>\n                </div>\n                <div className=\"bg-zinc-900/60 p-3.5 rounded-xl border border-zinc-800/80 font-mono text-[10px] text-zinc-500 space-y-1.5\">\n                  <div className=\"flex justify-between\"><span className=\"uppercase\">Notice:</span> <span className=\"text-[#009DFF] font-semibold text-right\">Connected in backend phase</span></div>\n                  <div className=\"flex justify-between\"><span className=\"uppercase\">Ref Hash:</span> <span className=\"text-zinc-400\">0x{getDeterministicHash(forgotEmail, 8)}</span></div>\n                </div>\n                <p className=\"text-[10px] text-zinc-500 leading-relaxed font-sans\"><span className=\"font-bold\">Honest Disclaimer:</span> This is a frontend-only design preview. Password resets and automated email alerts will be configured during the backend integration phase.</p>\n                <div className=\"flex justify-end pt-1\">\n                  <button type=\"button\" onClick={() => { setShowForgot(false); setForgotSubmitted(false); setForgotEmail(\"\"); }} className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-bold text-xs uppercase tracking-wider rounded-lg\">Return to Login</button>\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      )}"}}}
