{"ts":"2026-06-27T12:57:43.498Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"6st6o2xe","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/api-auth.ts:290-325","result":"290 |     })\n291 |     .filter(id => id > 0);\n292 |   const maxId = ids.length > 0 ? Math.max(...ids) : 5;\n293 |   return `proj-${String(maxId + 1).padStart(3, \"0\")}`;\n294 | }\n295 | \n296 | export function getClientNameFromId(clientId: string): string {\n297 |   switch (clientId) {\n298 |     case \"client-001\": return \"Apex Sovereign Group [Preview Client]\";\n299 |     case \"client-002\": return \"Global Retail Enclave [Preview Client]\";\n300 |     case \"client-003\": return \"Sovereign Logistics Unit [Preview Client]\";\n301 |     case \"client-004\": return \"Federal Treasury Division [Preview Client]\";\n302 |     default: return \"GFF AI Platform Core (Global Root)\";\n303 |   }\n304 | }\n305 | \n306 | export function getClientIdFromAssociation(association: string): string {\n307 |   const assoc = association.toLowerCase();\n308 |   if (assoc.includes(\"apex-sovereign\") || assoc.includes(\"apex sovereign\")) return \"client-001\";\n309 |   if (assoc.includes(\"global-retail\") || assoc.includes(\"global retail\")) return \"client-002\";\n310 |   if (assoc.includes(\"sovereign-logistics\") || assoc.includes(\"sovereign logistics\")) return \"client-003\";\n311 |   if (assoc.includes(\"fed-treasury\") || assoc.includes(\"federal treasury\")) return \"client-004\";\n312 |   return \"client-unknown\";\n313 | }\n314 | \n315 | // --- AI OPERATIONS CRUD API MODELS & SEED DATA ---\n316 | \n317 | export interface ApiAiOperation {\n318 |   id: string;\n319 |   name: string;\n320 |   client_id: string;\n321 |   client_name: string;\n322 |   project_id: string;\n323 |   status: string; // e.g. \"active\" | \"completed\" | \"paused\" | \"archived\"\n324 |   health: string; // e.g. \"healthy\" | \"warning\" | \"critical\" | \"offline\"\n325 |   agent_type: string; // e.g. \"autonomous\" | \"human-in-the-loop\" | \"validator\"","success":true}],"durationMs":5}}
