{"ts":"2026-06-27T12:58:36.873Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"snyg2c8y","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-support-apis.js","new_text":"/* eslint-disable */\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\n\nconst T = path.join(__dirname, '..', 'temp-support-test-build');\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n\ntry {\n  console.log(\"Compiling support APIs...\");\n  execSync('npx tsc lib/api-auth.ts app/api/v1/support/route.ts app/api/v1/support/[id]/route.ts app/api/v1/support/[id]/status/route.ts app/api/v1/support/[id]/assign/route.ts app/api/v1/support/[id]/comments/route.ts --outDir temp-support-test-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  console.error(\"✖ Compilation failed:\", e.message);\n  process.exit(1);\n}\n\nconst apiAuth = require('../temp-support-test-build/lib/api-auth.js');\nconst supportRoute = require('../temp-support-test-build/app/api/v1/support/route.js');\nconst idRoute = require('../temp-support-test-build/app/api/v1/support/[id]/route.js');\nconst statusRoute = require('../temp-support-test-build/app/api/v1/support/[id]/status/route.js');\nconst assignRoute = require('../temp-support-test-build/app/api/v1/support/[id]/assign/route.js');\nconst commentsRoute = require('../temp-support-test-build/app/api/v1/support/[id]/comments/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const clientMercer = getAuth(\"a.mercer@apex-sovereign.gff.ai\"); // client-001\n    const clientCarter = getAuth(\"e.carter@global-retail.gff.ai\"); // client-002\n    const inactiveUser = getAuth(\"m.vance@sovereign-logistics.gff.ai\"); // inactive\n\n    console.log(\"Checking Auth & Guards...\");\n    let res = await supportRoute.GET(new Request(\"http://l/api/v1/support\", { headers: { \"Authorization\": inactiveUser } }));\n    if (res.status !== 403) throw new Error(\"Expected inactive to get 403\");\n\n    res = await supportRoute.GET(new Request(\"http://l/api/v1/support\"));\n    if (res.status !== 401) throw new Error(\"Expected unauthenticated to get 401\");\n\n    console.log(\"Checking GET list and filtering...\");\n    res = await supportRoute.GET(new Request(\"http://l/api/v1/support\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.tickets.length < 3) throw new Error(\"Admin GET list failed\");\n\n    res = await supportRoute.GET(new Request(\"http://l/api/v1/support\", { headers: { \"Authorization\": clientMercer } }));\n    d = await res.json();\n    if (d.tickets.some(t => t.client_id !== \"client-001\") || d.tickets.length !== 2) throw new Error(\"Client list isolation failed\");\n\n    res = await supportRoute.GET(new Request(\"http://l/api/v1/support?status=open\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.tickets.some(t => t.status !== \"open\")) throw new Error(\"Status filter failed\");\n\n    res = await supportRoute.GET(new Request(\"http://l/api/v1/support?search=HSM\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.tickets.length !== 1 || !d.tickets[0].title.includes(\"HSM\")) throw new Error(\"Search filter failed\");\n\n    console.log(\"Checking GET by ID...\");\n    res = await idRoute.GET(new Request(\"http://l/api/v1/support/SLA-TKT-9912\", { headers: { \"Authorization\": clientMercer } }), { params: Promise.resolve({ id: \"SLA-TKT-9912\" }) });\n    if (res.status !== 200) throw new Error(\"GET own ticket failed\");\n\n    res = await idRoute.GET(new Request(\"http://l/api/v1/support/SLA-TKT-9801\", { headers: { \"Authorization\": clientMercer } }), { params: Promise.resolve({ id: \"SLA-TKT-9801\" }) });\n    if (res.status !== 403) throw new Error(\"GET other client's ticket must be 403\");\n\n    console.log(\"Checking POST Create...\");\n    const payload = { title: \"Test Overflow Error\", description: \"Node is locking up\", category: \"AI Operations\", priority: \"high\" };\n    res = await supportRoute.POST(new Request(\"http://l/api/v1/support\", { method: \"POST\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify(payload) }));\n    d = await res.json();\n    if (res.status !== 201) throw new Error(\"Create ticket failed\");\n    const createdId = d.ticket.id;\n\n    res = await supportRoute.POST(new Request(\"http://l/api/v1/support\", { method: \"POST\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ ...payload, client_id: \"client-002\" }) }));\n    if (res.status !== 403) throw new Error(\"Cross-client POST must be 403\");\n\n    console.log(\"Checking PATCH Update...\");\n    res = await idRoute.PATCH(new Request(`http://l/api/v1/support/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ description: \"Updated description text\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.ticket.description !== \"Updated description text\") throw new Error(\"Client PATCH own ticket failed\");\n\n    res = await idRoute.PATCH(new Request(`http://l/api/v1/support/${createdId}`, { method: \"PATCH\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ assigned_to: \"s.vance@governance.gff.ai\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client assignment must be 403\");\n\n    console.log(\"Checking PATCH status...\");\n    res = await statusRoute.PATCH(new Request(`http://l/api/v1/support/${createdId}/status`, { method: \"PATCH\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ status: \"resolved\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.ticket.status !== \"resolved\") throw new Error(\"PATCH own ticket status failed\");\n\n    console.log(\"Checking PATCH assign...\");\n    res = await assignRoute.PATCH(new Request(`http://l/api/v1/support/${createdId}/assign`, { method: \"PATCH\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ assigned_to: \"s.vance@governance.gff.ai\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client assign patch must be 403\");\n\n    res = await assignRoute.PATCH(new Request(`http://l/api/v1/support/${createdId}/assign`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ assigned_to: \"s.vance@governance.gff.ai\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.ticket.assigned_to !== \"s.vance@governance.gff.ai\") throw new Error(\"Admin assign patch failed\");\n\n    console.log(\"Checking POST comment...\");\n    res = await commentsRoute.POST(new Request(`http://l/api/v1/support/${createdId}/comments`, { method: \"POST\", headers: { \"Authorization\": clientMercer }, body: JSON.stringify({ text: \"Checking updates\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.comment.text !== \"Checking updates\") throw new Error(\"Client POST comment failed\");\n\n    console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: Support Ticket CRUD APIs Fully Verified!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\n\nrun();\n"}}}
