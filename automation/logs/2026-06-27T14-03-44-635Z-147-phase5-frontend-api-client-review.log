n  owner: string;\\n  nodesCount: number;\\n  enclaveType: string;\\n  desc: string;\\n  lastUpdated: string;\\n}\\n\\nexport interface ApiAiOperation {\\n  id: string;\\n  name: string;\\n  client_id: string;\\n  client_name: string;\\n  project_id: string;\\n  status: string; // \\\"active\\\" | \\\"completed\\\" | \\\"paused\\\" | \\\"archived\\\"\\n  health: string; // \\\"healthy\\\" | \\\"warning\\\" | \\\"critical\\\" | \\\"offline\\\"\\n  agent_type: string; // \\\"autonomous\\\" | \\\"human-in-the-loop\\\" | \\\"validator\\\"\\n  governance_status: string; // \\\"compliant\\\" | \\\"under_review\\\" | \\\"flagged\\\"\\n  owner: string;\\n  desc: string;\\n  lastUpdated: string;\\n}\\n\\nexport interface ApiInvoice {\\n  id: string;\\n  invoice_number: string;\\n  client_id: string;\\n  client_name: string;\\n  project_id?: string;\\n  project_name?: string;\\n  amount: number;\\n  currency: string;\\n  status: \\\"paid\\\" | \\\"unpaid\\\" | \\\"processing\\\" | \\\"void\\\";\\n  issue_date: string;\\n  due_date: string;\\n  category: string;\\n  hash: string;\\n  signature: string;\\n  description: string;\\n  lastUpdated: string;\\n}\\n\\nexport interface ApiGovernanceItem {\\n  id: string;\\n  client_id: string;\\n  client_name?: string;\\n  project_id?: string;\\n  project_name?: string;\\n  title: string;\\n  severity: string; // \\\"Critical\\\" | \\\"High\\\" | \\\"Medium\\\" | \\\"Low\\\"\\n  status: string; // \\\"active\\\" | \\\"completed\\\" | \\\"archived\\\" | \\\"Under Review\\\" | \\\"Flagged\\\" | \\\"Remediated\\\" | \\\"Suppressed\\\"\\n  owner: string;\\n  due_date: string; // \\\"YYYY-MM-DD\\\"\\n  description: string;\\n  nodeId?: string;\\n  standard?: string;\\n  hash?: string;\\n  logs?: string[];\\n  lastUpdated?: string;\\n}\\n\\nexport interface ApiDocumentItem {\\n  id: string;\\n  title: string;\\n  fileSize: string;\\n  type: string; // \\\"PDF\\\" | \\\"JSON\\\" | \\\"YAML\\\" etc.\\n  sha256: string;\\n  client_id: string;\\n  client_name: string;\\n  projectId?: string;\\n  status: \\\"Verified\\\" | \\\"Under Review\\\" | \\\"Action Required\\\" | \\\"Superseded\\\";\\n  owner: string;\\n  version: string;\\n  lastUpdated: string;\\n  description: string;\\n  governanceChecks?: { label: string; checked: boolean; framework: string }[];\\n}\\n\\nexport interface ApiSupportTicket {\\n  id: string;\\n  subject: string;\\n  client_id: string;\\n  client_name: string;\\n  priority: \\\"P1\\\" | \\\"P2\\\" | \\\"P3\\\";\\n  category: string;\\n  status: \\\"INVESTIGATING\\\" | \\\"OPEN\\\" | \\\"RESOLVED\\\" | \\\"IN_PROGRESS\\\";\\n  assignedAgent: string;\\n  linkedProjectId?: string;\\n  linkedDocId?: string;\\n  slaSeconds: number;\\n  description: string;\\n  createdDate: string;\\n  wireFeed?: { id: string; sender: string; senderName: string; text: string; timestamp: string }[];\\n}\\n\\nexport interface ClientAccount {\\n  id: string;\\n  name: string;\\n  status: \\\"active\\\" | \\\"suspended\\\" | \\\"pending\\\" | string;\\n  tier: \\\"Sovereign\\\" | \\\"Enterprise\\\" | \\\"Standard\\\" | string;\\n  region: string;\\n  createdAt: string;\\n  complianceLevel?: string;\\n  contactName?: string;\\n  contactEmail?: string;\\n}\\n\\nexport interface LoginCredentials {\\n  email: string;\\n  password?: string;\\n}\\n\\nexport interface LoginResponse {\\n  success: boolean;\\n  accessToken: string;\\n  tokenType: string;\\n  expiresIn: number;\\n  user: ApiUser;\\n}\\n\\nexport interface UserResponse {\\n  success: boolean;\\n  user: ApiUser;\\n}\\n\\nexport interface DashboardSummary {\\n  clients?: {\\n    totalCount: number;\\n    recent: ClientAccount[];\\n  };\\n  projects: {\\n    activeCount: number;\\n    totalCount: number;\\n    recent: ApiProject[];\\n  };\\n  aiOperations: {\\n    activeCount: number;\\n    totalCount: number;\\n    recent: ApiAiOperation[];\\n  };\\n  documents: {\\n    verifiedCount: number;\\n    totalCount: number;\\n    recent: ApiDocumentItem[];\\n  };\\n  invoices: {\\n    unpaidCount: number;\\n    totalCount: number;\\n    recent: ApiInvoice[];\\n  };\\n  support?: {\\n    openCount: number;\\n    totalCount: number;\\n    recent: ApiSupportTicket[];\\n  };\\n  supportTickets?: {\\n    openCount: number;\\n    totalCount: number;\\n    recent: ApiSupportTicket[];\\n  };\\n  governance: {\\n    flaggedCount: number;\\n    totalCount: number;\\n    recent: ApiGovernanceItem[];\\n  };\\n}\\n\\nexport interface DashboardResponse {\\n  success: boolean;\\n  summary: DashboardSummary;\\n  client_id?: string;\\n}\\n\\nexport interface AnalyticsMetricSummary {\\n  totalCount: number;\\n  byStatus: Record<string, number>;\\n  byPhase?: Record<string, number>;\\n  byHealth?: Record<string, number>;\\n  bySeverity?: Record<string, number>;\\n  byPriority?: Record<string, number>;\\n}\\n\\nexport interface AnalyticsSummary {\\n  projects: AnalyticsMetricSummary;\\n  aiOperations: AnalyticsMetricSummary;\\n  documents: AnalyticsMetricSummary;\\n  invoices: AnalyticsMetricSummary;\\n  support: AnalyticsMetricSummary;\\n  governance: AnalyticsMetricSummary;\\n}\\n\\nexport interface AnalyticsResponse {\\n  success: boolean;\\n  summary: AnalyticsSummary;\\n  client_id?: string;\\n}\\n\\n// ============================================================================\\n// 2. CORE UTILITIES (TOKEN PERSISTENCE, API RESOLUTION & BASE REQUESTS)\\n// ============================================================================\\n\\nconst TOKEN_KEY = \\\"gff_api_token\\\";\\n\\nexport function getApiBaseUrl(): string {\\n  if (process.env.NEXT_PUBLIC_API_BASE_URL) {\\n    return process.env.NEXT_PUBLIC_API_BASE_URL;\\n  }\\n  // Client-side auto-resolution\\n  if (typeof window !== \\\"undefined\\\") {\\n    return `${window.location.origin}/api/v1`;\\n  }\\n  return \\\"http://localhost:3000/api/v1\\\";\\n}\\n\\nexport function getStoredToken(): string | null {\\n  if (typeof window === \\\"undefined\\\") return null;\\n  return localStorage.getItem(TOKEN_KEY);\\n}\\n\\nexport function setStoredToken(token: string): void {\\n  if (typeof window === \\\"undefined\\\") return;\\n  localStorage.setItem(TOKEN_KEY, token);\\n}\\n\\nexport function clearStoredToken(): void {\\n  if (typeof window === \\\"undefined\\\") return;\\n  localStorage.removeItem(TOKEN_KEY);\\n}\\n\\n/**\\n * Robust JSON request helper handling authentication injection and centralized errors.\\n */\\nexport async function request<T>(path: string, options: RequestInit = {}): Promise<T> {\\n  const token = getStoredToken();\\n  const headers = new Headers(options.headers || {});\\n\\n  if (token && !headers.has(\\\"Authorization\\\")) {\\n    headers.set(\\\"Authorization\\\", `Bearer ${token}`);\\n  }\\n\\n  if (!headers.has(\\\"Content-Type\\\") && !(options.body instanceof FormData)) {\\n    headers.set(\\\"Content-Type\\\", \\\"application/json\\\");\\n  }\\n\\n  const baseUrl = getApiBaseUrl();\\n  const cleanBase = baseUrl.endsWith(\\\"/\\\") ? baseUrl.slice(0, -1) : baseUrl;\\n  const cleanPath = path.startsWith(\\\"/\\\") ? path : `/${path}`;\\n  const url = `${cleanBase}${cleanPath}`;\\n\\n  try {\\n    const response = await fetch(url, {\\n      ...options,\\n      headers,\\n    });\\n\\n    // Centralized 401 Unauthorized handling (automatic logout & redirect if client-safe)\\n    if (response.status === 401) {\\n      if (typeof window !== \\\"undefined\\\") {\\n        clearStoredToken();\\n        if (!window.location.pathname.includes(\\\"/login\\\")) {\\n          // Clear any local preview session as well to maintain UX parity\\n          localStorage.removeItem(\\\"gff_ai_preview_session_v1\\\");\\n          window.location.href = window.location.pathname.includes(\\\"/admin\\\")\\n            ? \\\"/admin/login\\\"\\n            : \\\"/portal/login\\\";\\n        }\\n      }\\n      throw new Error(\\\"Unauthorized access. Session token cleared.\\\");\\n    }\\n\\n    if (!response.ok) {\\n      const errorBody = await response.json().catch(() => null);\\n      const msg = errorBody?.message || errorBody?.error || `API request failed with status ${response.status}`;\\n      throw new Error(msg);\\n    }\\n\\n    return (await response.json()) as T;\\n  } catch (error: any) {\\n    console.error(`API Client error on [${options.method || \\\"GET\\\"} ${path}]:`, error.message || error);\\n    throw error;\\n  }\\n}\\n\\n// ============================================================================\\n// 3. DOMAIN MODULES\\n// ============================================================================\\n\\n/**\\n * Auth Module\\n */\\nexport const auth = {\\n  login: async (credentials: LoginCredentials): Promise<LoginResponse> => {\\n    const res = await request<LoginResponse>(\\\"/auth/login\\\", {\\n      method: \\\"POST\\\",\\n      body: JSON.stringify(credentials),\\n    });\\n    if (res.success && res.accessToken) {\\n      setStoredToken(res.accessToken);\\n    }\\n    return res;\\n  },\\n\\n  logout: async (): Promise<{ success: boolean }> => {\\n    try {\\n      const res = await request<{ success: boolean }>(\\\"/auth/logout\\\", {\\n        method: \\\"POST\\\",\\n      });\\n      clearStoredToken();\\n      return res;\\n    } catch {\\n      clearStoredToken();\\n      return { success: true };\\n    }\\n  },\\n\\n  me: async (): Promise<UserResponse> => {\\n    return request<UserResponse>(\\\"/auth/me\\\");\\n  },\\n};\\n\\n/**\\n * Dashboard Module\\n */\\nexport const dashboard = {\\n  getAdminSummary: async (): Promise<DashboardResponse> => {\\n    return request<DashboardResponse>(\\\"/dashboard/admin\\\");\\n  },\\n\\n  getClientSummary: async (clientId?: string): Promise<DashboardResponse> => {\\n    const path = clientId ? `/dashboard/client?client_id=${encodeURIComponent(clientId)}` : \\\"/dashboard/client\\\";\\n    return request<DashboardResponse>(path);\\n  },\\n};\\n\\n/**\\n * Clients Module (including high-fidelity preview fallbacks for client-centric APIs)\\n */\\nexport const clients = {\\n  list: async (): Promise<{ success: boolean; clients: ClientAccount[] }> => {\\n    try {\\n      return await request<{ success: boolean; clients: ClientAccount[] }>(\\\"/clients\\\");\\n    } catch {\\n      // High-fidelity fallback for client database\\n      return {\\n        success: true,\\n        clients: [\\n          { id: \\\"client-001\\\", name: \\\"Apex Sovereign Group [Preview Client]\\\", status: \\\"active\\\", tier: \\\"Sovereign\\\", region: \\\"London\\\", createdAt: \\\"2026-01-15T08:00:00Z\\\" },\\n          { id: \\\"client-002\\\", name: \\\"Global Retail Enclave [Preview Client]\\\", status: \\\"active\\\", tier: \\\"Enterprise\\\", region: \\\"New York\\\", createdAt: \\\"2026-02-10T10:30:00Z\\\" },\\n          { id: \\\"client-003\\\", name: \\\"Sovereign Logistics Unit [Preview Client]\\\", status: \\\"active\\\", tier: \\\"Standard\\\", region: \\\"Frankfurt\\\", createdAt: \\\"2026-03-01T09:00:00Z\\\" },\\n          { id: \\\"client-004\\\", name: \\\"Federal Treasury Division [Preview Client]\\\", status: \\\"active\\\", tier: \\\"Sovereign\\\", region: \\\"Washington D.C.\\\", createdAt: \\\"2026-04-18T14:15:00Z\\\" }\\n        ],\\n      };\\n    }\\n  },\\n\\n  get: async (id: string): Promise<{ success: boolean; client: ClientAccount }> => {\\n    try {\\n      return await request<{ success: boolean; client: ClientAccount }>(`/clients/${encodeURIComponent(id)}`);\\n    } catch {\\n      const res = await clients.list();\\n      const found = res.clients.find((c) => c.id === id);\\n      if (!found) throw new Error(`Client with ID ${id} not found.`);\\n      return { success: true, client: found };\\n    }\\n  },\\n};\\n\\n/**\\n * Users Module (GET, POST, PATCH, DELETE + role/status changes)\\n */\\nexport const users = {\\n  list: async (filters?: { role?: string; status?: string; client_id?: string; search?: string }): Promise<{ success: boolean; users: ApiUser[] }> => {\\n    const params = new URLSearchParams();\\n    if (filters?.role) params.set(\\\"role\\\", filters.role);\\n    if (filters?.status) params.set(\\\"status\\\", filters.status);\\n    if (filters?.client_id) params.set(\\\"client_id\\\", filters.client_id);\\n    if (filters?.search) params.set(\\\"search\\\", filters.search);\\n\\n    const query = params.toString() ? `?${params.toString()}` : \\\"\\\";\\n    return request<{ success: boolean; users: ApiUser[] }>(`/users${query}`);\\n  },\\n\\n  get: async (id: string): Promise<{ success: boolean; user: ApiUser }> => {\\n    return request<{ success: boolean; user: ApiUser }>(`/users/${encodeURIComponent(id)}`);\\n  },\\n\\n  create: async (userData: Partial<ApiUser> & { password?: string }): Promise<{ success: boolean; user: ApiUser }> => {\\n    return request<{ success: boolean; user: ApiUser }>(\\\"/users\\\", {\\n      method: \\\"POST\\\",\\n      body: JSON.stringify(userData),\\n    });\\n  },\\n\\n  update: async (id: string, userData: Partial<ApiUser> & { password?: string }): Promise<{ success: boolean; user: ApiUser }> => {\\n    return request<{ success: boolean; user: ApiUser }>(`/users/${encodeURIComponent(id)}`, {\\n      method: \\\"PATCH\\\",\\n      body: JSON.stringify(userData),\\n    });\\n  },\\n\\n  delete: async (id: string): Promise<{ success: boolean; message: string }> => {\\n    return request<{ success: boolean; message: string }>(`/users/${encodeURIComponent(id)}`, {\\n      method: \\\"DELETE\\\",\\n    });\\n  },\\n\\n  updateRole: async (id: string, role: string): Promise<{ success: boolean; user: ApiUser }> => {\\n    return request<{ success: boolean; user: ApiUser }>(`/users/${encodeURIComponent(id)}/role`, {\\n      method: \\\"PATCH\\\",\\n      body: JSON.stringify({ role }),\\n    });\\n  },\\n\\n  updateStatus: async (id: string, status: \\\"active\\\" | \\\"inactive\\\"): Promise<{ success: boolean; user: ApiUser }> => {\\n    return request<{ success: boolean; user: ApiUser }>(`/users/${encodeURIComponent(id)}/status`, {\\n      method: \\\"PATCH\\\",\\n      body: JSON.stringify({ status }),\\n    });\\n  },\\n};\\n\\n/**\\n * Projects Module\\n */\\nexport const projects = {\\n  list: async (filters?: { client_id?: string; phase?: string; status?: string; health?: string; owner?: string; search?: string }): Promise<{ success: boolean; projects: ApiProject[] }> => {\\n    const params = new URLSearchParams();\\n    if (filters?.client_id) params.set(\\\"client_id\\\", filters.client_id);\\n    if (filters?.phase) params.set(\\\"phase\\\", filters.phase);\\n    if (filters?.status) params.set(\\\"status\\\", filters.status);\\n    if (filters?.health) params.set(\\\"health\\\", filters.health);\\n    if (filters?.owner) params.set(\\\"owner\\\", filters.owner);\\n    if (filters?.search) params.set(\\\"search\\\", filters.search);\\n\\n    const query = params.toString() ? `?${params.toString()}` : \\\"\\\";\\n    return request<{ success: boolean; projects: ApiProject[] }>(`/projects${query}`);\\n  },\\n\\n  get: async (id: string): Promise<{ success: boolean; project: ApiProject }> => {\\n    return request<{ success: boolean; project: ApiProject }>(`/projects/${encodeURIComponent(id)}`);\\n  },\\n\\n  create: async (projectData: Partial<ApiProject>): Promise<{ success: boolean; project: ApiProject }> => {\\n    return request<{ success: boolean; project: ApiProject }>(\\\"/projects\\\", {\\n      method: \\\"POST\\\",\\n      body: JSON.stringify(projectData),\\n    });\\n  },\\n\\n  update: async (id: string, projectData: Partial<ApiProject>): Promise<{ success: boolean; project: ApiProject }> => {\\n    return request<{ success: boolean; project: ApiProject }>(`/projects/${encodeURIComponent(id)}`, {\\n      method: \\\"PATCH\\\",\\n      body: JSON.stringify(projectData),\\n    });\\n  },\\n\\n  delete: async (id: string): Promise<{ success: boolean; message: string }> => {\\n    return request<{ success: boolean; message: string }>(`/projects/${encodeURIComponent(id)}`, {\\n      method: \\\"DELETE\\\",\\n    });\\n  },\\n};\\n\\n/**\\n * AI Operations Module\\n */\\nexport const aiOperations = {\\n  list: async (filters?: {\\n    client_id?: string;\\n    project_id?: string;\\n    status?: string;\\n    health?: string;\\n    agent_type?: string;\\n    governance_status?: string;\\n    owner?: string;\\n    search?: string;\\n  }): Promise<{ success: boolean; operations: ApiAiOperation[] }> => {\\n    const params = new URLSearchParams();\\n    if (filters?.client_id) params.set(\\\"client_id\\\", filters.client_id);\\n    if (filters?.project_id) params.set(\\\"project_id\\\", filters.project_id);\\n    if (filters?.status) params.set(\\\"status\\\", filters.status);\\n    if (filters?.health) params.set(\\\"health\\\", filters.health);\\n    if (filters?.agent_type) params.set(\\\"agent_type\\\", filters.agent_type);\\n    if (filters?.governance_status) params.set(\\\"governance_status\\\", filters.governance_status);\\n    if (filters?.owner) params.set(\\\"owner\\\", filters.owner);\\n    if (filters?.search) params.set(\\\"search\\\", filters.search);\\n\\n    const query = params.toString() ? `?${params.toString()}` : \\\"\\\";\\n    return request<{ success: boolean; operations: ApiAiOperation[] }>(`/ai-operations${query}`);\\n  },\\n\\n  get: async (id: string): Promise<{ success: boolean; operation: ApiAiOperation }> => {\\n    return request<{ success: boolean; operation: ApiAiOperation }>(`/ai-operations/${encodeURIComponent(id)}`);\\n  },\\n\\n  create: async (opData: Partial<ApiAiOperation>): Promise<{ success: boolean; operation: ApiAiOperation }> => {\\n    return request<{ success: boolean; operation: ApiAiOperation }>(\\\"/ai-operations\\\", {\\n      method: \\\"POST\\\",\\n      body: JSON.stringify(opData),\\n    });\\n  },\\n\\n  update: async (id: string, opData: Partial<ApiAiOperation>): Promise<{ success: boolean; operation: ApiAiOperation }> => {\\n