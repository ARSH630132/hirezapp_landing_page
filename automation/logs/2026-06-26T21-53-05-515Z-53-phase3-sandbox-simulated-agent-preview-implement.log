  \"Collaborative / HITL\",\n479 |   \"Analytical / Extraction\",\n480 |   \"Multi-Agent Synthesis\",\n481 |   \"Guardrail / Audit\",\n482 |   \"Real-time / Interactive\",\n483 |   \"Reactive / Hardware\"\n484 | ];\n485 | \n486 | export default function SandboxPage() {\n487 |   // Filter States\n488 |   const [selectedIndustry, setSelectedIndustry] = useState(\"All Industries\");\n489 |   const [selectedFunction, setSelectedFunction] = useState(\"All Functions\");\n490 |   const [selectedAgentType, setSelectedAgentType] = useState(\"All Agent Types\");\n491 |   const [searchQuery, setSearchQuery] = useState(\"\");\n492 | \n493 |   // Catalog Active Agent Selection\n494 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n495 | \n496 |   // Simulation Telemetry States\n497 |   const [isSimulating, setIsSimulating] = useState(false);\n498 |   const [simulationProgress, setSimulationProgress] = useState(0);\n499 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n500 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n501 | \n502 |   // Filter lists based on rules\n503 |   const filteredAgents = AGENTS.filter((agent) => {\n504 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n505 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n506 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n507 |     const matchSearch =\n508 |       searchQuery === \"\" ||\n509 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n510 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n511 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n512 | \n513 |     return matchIndustry && matchFunction && matchType && matchSearch;\n514 |   });\n515 | \n516 |   // Dynamically pull active agent object\n517 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n518 | \n519 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n520 |   useEffect(() => {\n521 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n522 |       setActiveAgentId(filteredAgents[0].id);\n523 |     }\n524 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n525 | \n526 |   // Reset simulation whenever active agent changes\n527 |   useEffect(() => {\n528 |     setIsSimulating(false);\n529 |     setSimulationProgress(0);\n530 |     setSimulatedLogs([]);\n531 |   }, [activeAgentId]);\n532 | \n533 |   // Handle dry-run simulation progress\n534 |   useEffect(() => {\n535 |     if (!isSimulating) return;\n536 | \n537 |     setSimulationProgress(0);\n538 |     setSimulatedLogs([]);\n539 | \n540 |     const totalDuration = 4800; // 4.8s simulation\n541 |     const intervalTime = 50; // update every 50ms\n542 |     let elapsed = 0;\n543 | \n544 |     const interval = setInterval(() => {\n545 |       elapsed += intervalTime;\n546 |       const progress = Math.min((elapsed / totalDuration) * 100, 100);\n547 |       setSimulationProgress(Math.round(progress));\n548 | \n549 |       // Stream logs matching current timeline progress\n550 |       const secondsElapsed = elapsed / 1000;\n551 |       const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n552 |       setSimulatedLogs(activeLogs);\n553 | \n554 |       if (elapsed >= totalDuration) {\n555 |         clearInterval(interval);\n556 |         setIsSimulating(false);\n557 |       }\n558 |     }, intervalTime);\n559 | \n560 |     return () => clearInterval(interval);\n561 |   }, [isSimulating, activeAgent]);\n562 | \n563 |   // Dynamic count generators for UI indicators\n564 |   const getIndustryCount = (ind: string) => {\n565 |     if (ind === \"All Industries\") return AGENTS.length;\n566 |     return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n567 |   };\n568 | \n569 |   const getFunctionCount = (func: string) => {\n570 |     if (func === \"All Functions\") return AGENTS.length;\n571 |     return AGENTS.filter((a) => a.category === func).length;\n572 |   };\n573 | \n574 |   const getAgentTypeCount = (type: string) => {\n575 |     if (type === \"All Agent Types\") return AGENTS.length;\n576 |     return AGENTS.filter((a) => a.agentType === type).length;\n577 |   };\n578 | \n579 |   // Render modern animated connection DAG inside Sovereign Architecture Tab\n580 |   const renderSVGArchitecture = (agent: AgentDemo) => {\n581 |     return (\n582 |       <svg className=\"w-full h-full min-h-[220px]\" viewBox=\"0 0 500 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n583 |         <defs>\n584 |           <linearGradient id=\"lineGlow\" x1=\"0\" y1=\"0\" x2=\"500\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n585 |             <stop stopColor=\"#E4000F\" />\n586 |             <stop offset=\"0.5\" stopColor=\"#009DFF\" />\n587 |             <stop offset=\"1\" stopColor=\"#00FF9D\" />\n588 |           </linearGradient>\n589 |           <filter id=\"glowEffect\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n590 |             <feGaussianBlur stdDeviation=\"5\" result=\"blur\" />\n591 |             <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n592 |           </filter>\n593 |         </defs>\n594 | \n595 |         {/* Outer Boundary Box: Cryptographic Enclave */}\n596 |         <rect x=\"130\" y=\"20\" width=\"240\" height=\"180\" rx=\"16\" fill=\"rgba(4,6,11,0.7)\" stroke=\"rgba(0,157,255,0.25)\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n597 |         <text x=\"250\" y=\"212\" fill=\"rgba(255,255,255,0.35)\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" letterSpacing=\"0.1em\">\n598