{"ts":"2026-06-26T21:47:54.814Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"0b7utzx2","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/sandbox/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { AnimatePresence, motion } from \"motion/react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\n\n// Define TypeScript interfaces for static agent data\ninterface AgentStep {\n  title: string;\n  description: string;\n  role: string;\n}\n\ninterface AgentLog {\n  timeOffset: number; // seconds from launch\n  type: \"system\" | \"info\" | \"agent\" | \"success\" | \"warning\";\n  text: string;\n}\n\ninterface AgentDemo {\n  id: string;\n  name: string;\n  category: string;\n  purpose: string;\n  recommendedIndustry: string;\n  relatedPlatform: string;\n  agentType: string;\n  status: string;\n  securityRating: string;\n  metrics: {\n    cpu: string;\n    memory: string;\n    isolation: string;\n    compliance: string;\n  };\n  ingressLabel: string;\n  egressLabel: string;\n  steps: AgentStep[];\n  logs: AgentLog[];\n  // Static deterministic workflow properties as requested by the UI Constitution\n  challenge: string;\n  interpretation: string;\n  knowledgeNeeded: string[];\n  humanApproval: string;\n  governanceCheck: string;\n  outputPreview: string;\n}\n\n// Full 8 representative agent demos using local static data only\nconst AGENTS: AgentDemo[] = [\n  {\n    id: \"knowledge-search\",\n    name: \"Cognitive Knowledge Engine\",\n    category: \"Knowledge Search\",\n    purpose: \"Autonomous deep-reasoning search across distributed unstructured enterprise archives and live telemetry pipelines.\",\n    recommendedIndustry: \"Energy & Utilities\",\n    relatedPlatform: \"Foundry / Knowledge Graph\",\n    agentType: \"Deep Reasoning / DAG\",\n    status: \"Ready for Simulation\",\n    securityRating: \"High (SOC2 Enclave)\",\n    metrics: {\n      cpu: \"16-Core vCPU\",\n      memory: \"64GB Isolated\",\n      isolation: \"AMD SEV-SNP\",\n      compliance: \"Sovereign GDPR\"\n    },\n    ingressLabel: \"Thermal Telemetry & PDFs\",\n    egressLabel: \"Engineering Mitigation Report\",\n    challenge: \"An offshore gas platform operator reports a sudden 4.2% pressure anomaly in Pipeline Sector-4. Engineers must instantly cross-reference 25,000 pages of scanned 1998 legacy manuals, physical sensor schematics, and live thermal SCADA telemetry to identify the correct isolation valve.\",\n    interpretation: \"Translates high-volume unstructured search parameters into ISO-14224 compliant failure modes, maps connectivity graphs, and filters telemetry noise before memory-unlocked aggregation.\",\n    knowledgeNeeded: [\n      \"Sovereign Knowledge Graph (Sector-4 Topology Map)\",\n      \"ISO-14224 Equipment taxonomy database\",\n      \"Historical sensor SCADA telemetry log archives (1998-Present)\",\n      \"Sector-4 legacy engineering manuals and schematics\"\n    ],\n    steps: [\n      {\n        title: \"Parse Semantic Context\",\n        description: \"Ingests high-volume unstructured search parameters to construct hyper-dimensional vector embeddings within memory.\",\n        role: \"Semantic Embedding Model\"\n      },\n      {\n        title: \"Federated Graph Query\",\n        description: \"Dispatches secure sub-agents to query and resolve relationship clusters in the GFF Sovereign Knowledge Graph.\",\n        role: \"Graph Resolver Agent\"\n      },\n      {\n        title: \"Cross-Attention Re-ranking\",\n        description: \"Evaluates context fragments using semantic relevancy layers and filters noise before memory-unlocked aggregation.\",\n        role: \"Context Scorer Pipeline\"\n      },\n      {\n        title: \"Sovereign Synthesis\",\n        description: \"Compiles a certified Failure Mode and Effects Analysis (FMEA) document complete with absolute provenance citations.\",\n        role: \"Executive Synthesis Model\"\n      }\n    ],\n    humanApproval: \"Control Room Engineer must manually verify and sign off on the proposed Isolation Valve #12-B closure recommendation before executing the physical safety dispatch.\",\n    governanceCheck: \"Sovereign GDPR compliance mask filters all proprietary names and locations. Zero-egress sandbox blockages deny raw data transit to unapproved external servers.\",\n    outputPreview: `{\n  \"incident_id\": \"INC-2026-098F\",\n  \"recommended_action\": \"Isolate Sector-4 Valve #12-B within 14 minutes.\",\n  \"confidence_score\": \"0.982\",\n  \"matched_documentation\": [\n    \"Sec-4-Pipeline-Specs-1998.pdf (Page 412)\",\n    \"SCADA-Thermal-Log-S4-Active.csv\"\n  ],\n  \"isolation_instructions\": \"Close pneumatic actuator S4-PA-12B, verify downstream pressure drops below 12.4 bar.\"\n}`,\n    logs: [\n      { timeOffset: 0.2, type: \"system\", text: \"Initializing cryptographic secure enclave on node SECURE_ENCLAVE_NODE-09...\" },\n      { timeOffset: 0.8, type: \"info\", text: \"Mounting unstructured raw file system (containing engineering PDFs, sensor history)...\" },\n      { timeOffset: 1.5, type: \"agent\", text: \"[EmbeddingAgent] Transforming query 'Sector-4 thermal anomaly' into 1536-dimensional vector space.\" },\n      { timeOffset: 2.2, type: \"agent\", text: \"[GraphAgent] Querying Knowledge Graph cluster: resolved 42 nodes and 115 sovereign relations.\" },\n      { timeOffset: 2.9, type: \"warning\", text: \"[Retriever] Re-ranking flagged 2 candidate documents with unverified signatures. Suppressing.\" },\n      { timeOffset: 3.5, type: \"agent\", text: \"[SynthesisAgent] Consolidating 8 high-confidence matching sections (FMEA Standard ISO-14224)...\" },\n      { timeOffset: 4.2, type: \"success\", text: \"Dry-run report generated. SHA-256: 0x9e43b17... Simulation successfully completed.\" }\n    ]\n  },\n  {\n    id: \"procurement-copilot\",\n    name: \"Autonomous Procurement Copilot\",\n    category: \"Procurement Copilot\",\n    purpose: \"Automates raw material requisition validation, supplier contractual compliance checking, and SAP ERP orchestration.\",\n    recommendedIndustry: \"Retail & Supply Chain\",\n    relatedPlatform: \"RetailMesh / ERP Connector\",\n    agentType: \"Transactional / Actions\",\n    status: \"Enclave Verified\",\n    securityRating: \"ISO-27001 Certified\",\n    metrics: {\n      cpu: \"8-Core vCPU\",\n      memory: \"32GB Isolated\",\n      isolation: \"Intel SGX Enclave\",\n      compliance: \"HIPAA/SOC2 Compliant\"\n    },\n    ingressLabel: \"Supplier Invoice PDFs\",\n    egressLabel: \"SAP ERP Ledger Adjustment\",\n    challenge: \"A global retail operator receives 1,200 raw material invoices daily from 85 international vendors. Contract pricing terms fluctuate daily, leading to invoice-to-contract mismatches, manual ledger errors, and delayed SAP settlement cycles.\",\n    interpretation: \"Validates received PDF invoices against registered master purchase agreements. Identifies deviation percentages in unit pricing, and queries SAP ERP ledger state.\",\n    knowledgeNeeded: [\n      \"Vendor Master Service Agreements (MSAs)\",\n      \"SAP ERP active ledger balances\",\n      \"Real-time FX currency conversion rates\",\n      \"Authorized corporate procurement limits directory\"\n    ],\n    steps: [\n      {\n        title: \"Multimodal Invoice Parsing\",\n        description: \"Parses structured invoice tables and unstructured clauses using high-fidelity vision agents within secure boundaries.\",\n        role: \"Multimodal Vision Agent\"\n      },\n      {\n        title: \"Master Agreement Matching\",\n        description: \"Performs absolute, line-item semantic validation matching unit prices against legal Master Service Agreements.\",\n        role: \"Contract Legal Validator\"\n      },\n      {\n        title: \"Discrepancy Reconciliation\",\n        description: \"Flags over-charges, auto-generates delta correction claims, and notifies vendor relationship handlers.\",\n        role: \"Reconciliation Agent\"\n      },\n      {\n        title: \"SAP Ledger Update\",\n        description: \"Formulates secure OData ledger requests and commits validated transaction schemas straight to ERP nodes.\",\n        role: \"SAP ERP Connector\"\n      }\n    ],\n    humanApproval: \"Finance Analyst must review and electronically authorize any invoice matching deviation exceeding +/- 2.5% variance before SAP ledger posting.\",\n    governanceCheck: \"SOC2 boundary checks evaluate vendor banking routing numbers against the authorized OFAC sanctions database before initiating any pending ledger adjusting entry.\",\n    outputPreview: `{\n  \"invoice_id\": \"INV-DE-88291\",\n  \"supplier\": \"Krupp Logistics GmbH\",\n  \"validation_status\": \"DISCREPANCY_DETECTED\",\n  \"discrepancy_details\": \"Unit price on Line Item 3 ($142.50) exceeds Master Agreement Contract Rate ($139.00) by 2.51%.\",\n  \"escalation_route\": \"Routed to Procurement Officer (Approver #4)\"\n}`,\n    logs: [\n      { timeOffset: 0.1, type: \"system\", text: \"Spinning up transactional agent enclave inside Intel SGX secure container...\" },\n      { timeOffset: 0.9, type: \"info\", text: \"Successfully connected to RetailMesh SAP ERP transaction router.\" },\n      { timeOffset: 1.6, type: \"agent\", text: \"[VisionAgent] Extracting text and tabular ledger grids from INV-DE-88291.pdf...\" },\n      { timeOffset: 2.3, type: \"agent\", text: \"[LegalValidator] Cross-referencing pricing with MSA-2025-KRUPP: baseline rate is $139.00.\" },\n      { timeOffset: 3.1, type: \"warning\", text: \"[Reconciler] Unit price mismatch detected on Line Item 3 (Deviation: 2.51%). Restricting SAP auto-write.\" },\n      { timeOffset: 4.0, type: \"success\", text: \"Discrepancy logged. Ticket sent to Human Approval interface. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"hr-assistant\",\n    name: \"Secure Talent Orchestrator\",\n    category: \"Operations Copilot\",\n    purpose: \"Autonomous recruitment flow manager that handles resume parsing, candidate screening, and onboarding orchestration.\",\n    recommendedIndustry: \"Education & Public Services\",\n    relatedPlatform: \"University OneVerse / Teams\",\n    agentType: \"Workflow Router\",\n    status: \"Ready for Simulation\",\n    securityRating: \"GDPR Sovereign Protected\",\n    metrics: {\n      cpu: \"4-Core vCPU\",\n      memory: \"16GB Isolated\",\n      isolation: \"AWS Nitro Enclave\",\n      compliance: \"CCPA & EU Sovereign GDPR\"\n    },\n    ingressLabel: \"Candidate Resumes (PDF)\",\n    egressLabel: \"Interview Board Invitation\",\n    challenge: \"Enterprise HR departments struggle to parse, screen, and schedule interviews for thousands of high-security cleared candidate profiles across disparate sovereign regions without exposing personally identifiable information (PII) to global networks.\",\n    interpretation: \"Masks PII elements in PDF resumes. Compiles verified skills matrices against custom job requirement blueprints, and generates secure self-scheduling portals.\",\n    knowledgeNeeded: [\n      \"Enterprise Role Specifications Blueprint\",\n      \"Candidate Resume Repositories\",\n      \"Sovereign PII Redaction Ruleset\",\n      \"Outlook/GSuite Calendar APIs\"\n    ],\n    steps: [\n      {\n        title: \"PII Redaction Pipeline\",\n        description: \"Scans uploaded CV files to strip out personal details (names, phone numbers, addresses) to prevent bias and comply with PII regulations.\",\n        role: \"Anonymization Agent\"\n      },\n      {\n        title: \"Skills Graph Matching\",\n        description: \"Cross-references candidate skills and certifications against the GFF University OneVerse engineering ontology database.\",\n        role: \"Skills Matcher\"\n      },\n      {\n        title: \"Interactive Scheduling\",\n        description: \"Negotiates open interview slots with candidate and hiring panel calendars, ensuring absolute scheduling coordination.\",\n        role: \"Calendar Coordinator\"\n      },\n      {\n        title: \"Encrypted Candidate Dossier\",\n        description: \"Compiles scores, skills matrix, and sanitized profile into a secure dossier readable only by authorized panel keys.\",\n        role: \"Dossier Synthesizer\"\n      }\n    ],\n    humanApproval: \"Talent Acquisition Lead must manually verify the candidate's cleared credentials and confirm the interview panel schedule.\",\n    governanceCheck: \"Sovereign localization check ensures candidate CV data never exits physical cloud servers located in Germany (Sovereign Cloud Zone EU-Central-1).\",\n    outputPreview: `{\n  \"candidate_ref\": \"ANON-88392-EU\",\n  \"clearance_verified\": \"Level 4 (Sovereign Secure)\",\n  \"skills_alignment\": \"94% Match (Rust, Cryptographic Enclaves, Next.js)\",\n  \"pii_redacted\": \"True\",\n  \"interview_status\": \"Scheduled for Tuesday, 14:00 CET via Secure Room\"\n}`,\n    logs: [\n      { timeOffset: 0.2, type: \"system\", text: \"Starting anonymization tunnel under CCPA / GDPR strict guidelines...\" },\n      { timeOffset: 1.0, type: \"info\", text: \"Decrypting candidate dossier payload with key K-88392-A...\" },\n      { timeOffset: 1.8, type: \"agent\", text: \"[Anonymizer] Successfully redacted candidate name, address, and email from CV.pdf.\" },\n      { timeOffset: 2.7, type: \"agent\", text: \"[SkillsMatcher] Found 14 matching engineering competencies. Alignment index is 94%.\" },\n      { timeOffset: 3.5, type: \"agent\", text: \"[CalendarCoordinator] Checking panel availability. Pre-allocated slot booked on Tuesday at 14:00 CET.\" },\n      { timeOffset: 4.3, type: \"success\", text: \"Secure Candidate Dossier encrypted. Verification key dispatched. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"contract-intelligence\",\n    name: \"Contract Intelligence Engine\",\n    category: \"Knowledge Search\",\n    purpose: \"Analyzes liability boundaries, indemnification loopholes, and governing law compliance in legal catalogs.\",\n    recommendedIndustry: \"Banking & Legal Services\",\n    relatedPlatform: \"Foundry / Enterprise KMS\",\n    agentType: \"Deep Reasoning / DAG\",\n    status: \"Enclave Verified\",\n    securityRating: \"SOC2 Type II Enclave\",\n    metrics: {\n      cpu: \"16-Core vCPU\",\n      memory: \"128GB Isolated\",\n      isolation: \"AMD SEV-SNP Enclave\",\n      compliance: \"FINRA / SOC2 Certified\"\n    },\n    ingressLabel: \"Master Service Agreements\",\n    egressLabel: \"Clause Risk Assessment Matrix\",\n    challenge: \"In-house legal teams at multinational enterprises spend hundreds of hours manually comparing legacy supplier master service agreements (MSAs) against updated regional liability laws, missing critical indemnity exposure clauses.\",\n    interpretation: \"Conducts deep semantic clause analysis. Identifies missing or weak liability caps, cross-references with local court databases, and drafts remedial amendment clauses.\",\n    knowledgeNeeded: [\n      \"Corporate Legal MSA Templates\",\n      \"Regional Civil Code liability tables\",\n      \"Local judicial precedents database\",\n      \"Active enterprise compliance manuals\"\n    ],\n    steps: [\n      {\n        title: \"Semantic Clause Segmentation\",\n        description: \"Deconstructs 200+ page contracts into distinct legal clauses (indemnification, limitation of liability, governing law).\",\n        role: \"Legal Tokenizer\"\n      },\n      {\n        title: \"Risk Coefficient Evaluation\",\n        description: \"Compares extracted clauses with corporate legal guidelines, assigning a risk value based on historical liabilities.\",\n        role: \"Risk Evaluator\"\n      },\n      {\n        title: \"Alternative Clause Synthesis\",\n        description: \"Drafts context-aware, legally sound amendments to mitigate flagged risks based on company-approved templates.\",\n        role: \"Legal Wording Generator\"\n      },\n      {\n        title: \"Legal Review Routing\",\n        description: \"Builds a unified comparison matrix highlighting changes and routes the draft directly to corporate legal officers.\",\n        role: \"Workflow Router\"\n      }\n    ],\n    humanApproval: \"General Counsel must approve the suggested replacement indemnity clause wording before sending the formal contract addendum to the counterparty.\",\n    governanceCheck: \"Zero-retention LLM privacy guard ensures third-party contractual terms are never ingested into global training weights, keeping all legal intellectual property strictly isolated.\",\n    outputPreview: `{\n  \"contract_id\": \"MSA-2026-RETAIL\",\n  \"risk_level\": \"ELEVATED\",\n  \"vulnerabilities\": [\n    {\n      \"clause\": \"Section 14.2 (Limitation of Liability)\",\n      \"issue\": \"Liability cap is uncapped for indirect damages under German Civil Code Section 307.\",\n      \"remedy\": \"Insert: 'Liability for indirect damages shall be capped at 150% of annual fees paid under this Agreement.'\"\n    }\n  ]\n}`,\n    logs: [\n      { timeOffset: 0.1, type: \"system\", text: \"Spawning Deep Reasoning Enclave (AMD SEV-SNP Isolation, Zero External Egress)...\" },\n      { timeOffset: 0.7, type: \"info\", text: \"Loading legal policy weights version LEGAL-2026-v4.3...\" },\n      { timeOffset: 1.5, type: \"agent\", text: \"[LegalTokenizer] Segmented document into 82 structural nodes. Locating limitation of liability clauses.\" },\n      { timeOffset: 2.3, type: \"agent\", text: \"[RiskEvaluator] CRITICAL: Section 14.2 does not explicitly exclude indirect damages under GCC §307.\" },\n      { timeOffset: 3.1, type: \"agent\", text: \"[WordingGenerator] Synthesizing compliant liability cap language...\" },\n      { timeOffset: 4.1, type: \"success\", text: \"Risk Matrix formulated. Comparison diff generated. Saved to localized KMS sandbox. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"executive-dashboard\",\n    name: \"Cross-Chain Portfolio Risk Engine\",\n    category: \"Procurement Copilot\",\n    purpose: \"Aggregates corporate treasury balances, liquid assets, and smart-contract exposures to model value-at-risk.\",\n    recommendedIndustry: \"Banking & Financial Services\",\n    relatedPlatform: \"Control Center / DeFi Node\",\n    agentType: \"Transactional / Actions\",\n    status: \"Ready for Simulation\",\n    securityRating: \"FIPS 140-2 Level 4\",\n    metrics: {\n      cpu: \"16-Core vCPU\",\n      memory: \"64GB Isolated\",\n      isolation: \"Intel SGX HSM\",\n      compliance: \"SEC / Basel III Sovereign\"\n    },\n    ingressLabel: \"Cryptographic Wallet States\",\n    egressLabel: \"Treasury Hedging Protocol\",\n    challenge: \"Chief Financial Officers struggle to reconcile liquidity risk across multiple disparate digital asset vaults, sovereign bank accounts, and active DeFi smart contracts in real-time, leaving them exposed to overnight market volatility.\",\n    interpretation: \"Fetches real-time multi-vault balances, calculates portfolio value-at-risk (VaR) using Monte Carlo distributions, and models hedging strategies.\",\n    knowledgeNeeded: [\n      \"Multi-signature vault telemetry status\",\n      \"Real-time Bloomberg & Chainlink oracle price feeds\",\n      \"Corporate treasury allocation policy parameters\",\n      \"Active interest-bearing token yielding curves\"\n    ],\n    steps: [\n      {\n        title: \"Real-time Treasury Ingestion\",\n        description: \"Polls active balances and liquidity parameters across designated enterprise vaults and clearing networks securely.\",\n        role: \"Vault Integrator\"\n      },\n      {\n        title: \"Value-at-Risk Computation\",\n        description: \"Simulates 10,000 market shocks using a local Monte Carlo distribution to quantify potential capital exposure.\",\n        role: \"Monte Carlo Engine\"\n      },\n      {\n        title: \"Auto-Hedging Simulations\",\n        description: \"Models portfolio rebalancing strategies to hedge against volatility indices without incurring massive fee slippage.\",\n        role: \"Hedging Synthesizer\"\n      },\n      {\n        title: \"Executive Alerting\",\n        description: \"Generates high-priority risk bulletins formatted directly for executive messaging protocols (Signal/Teams).\",\n        role: \"Sec-Comms Dispatcher\"\n      }\n    ],\n    humanApproval: \"CFO or Treasury Director must sign a multi-signature transaction on their physical HSM hardware device to execute any suggested portfolio rebalancing transfers.\",\n    governanceCheck: \"Anti-Money Laundering (AML) checks evaluate recipient address risks; the smart contract execution path runs inside a FIPS 140-2 Level 4 HSM container.\",\n    outputPreview: `{\n  \"portfolio_value_usd\": \"242,501,902.00\",\n  \"24h_value_at_risk_99_confidence\": \"1,420,900.00\",\n  \"alert_status\": \"NOMINAL\",\n  \"hedging_recommendation\": \"Allocate 5% of passive stablecoin treasury to short-duration sovereign bonds to neutralize overnight volatility.\",\n  \"required_signatures\": \"2 of 3 (CFO + Controller)\"\n}`,\n    logs: [\n      { timeOffset: 0.1, type: \"system\", text: \"Initializing FIPS 140-2 Level 4 secure session...\" },\n      { timeOffset: 0.9, type: \"info\", text: \"Querying balances across Ethereum, Arbitrum, and local clearing networks...\" },\n      { timeOffset: 1.6, type: \"agent\", text: \"[VaultIntegrator] Total treasury value detected: $242,501,902.00 across 12 vaults.\" },\n      { timeOffset: 2.5, type: \"agent\", text: \"[MonteCarloEngine] Computing Value-at-Risk... 99% VaR stands at $1,420,900.00.\" },\n      { timeOffset: 3.4, type: \"warning\", text: \"[HedgingSynthesizer] Asset skew detected in Vault-04. Proposing a 5% allocation shift to short-duration bonds.\" },\n      { timeOffset: 4.2, type: \"success\", text: \"Alert compiled. Multi-sig transaction payload generated. Saved to Control Center. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"compliance-assistant\",\n    name: \"Real-time Sovereign Guardrail Monitor\",\n    category: \"Knowledge Search\",\n    purpose: \"Inspects incoming and outgoing streaming API data payloads to dynamically mask and redact sensitive records.\",\n    recommendedIndustry: \"Government & Sovereign Cloud\",\n    relatedPlatform: \"Runtime Governance / Enclave\",\n    agentType: \"Deep Reasoning / DAG\",\n    status: \"Enclave Verified\",\n    securityRating: \"Sovereign Node Certified\",\n    metrics: {\n      cpu: \"32-Core vCPU\",\n      memory: \"128GB Isolated\",\n      isolation: \"AMD SEV-SNP\",\n      compliance: \"Sovereign GovCloud Standard\"\n    },\n    ingressLabel: \"API Request Streams (JSON)\",\n    egressLabel: \"Sanitized API Egress JSON\",\n    challenge: \"Enterprise data pipelines crossing international borders face immediate fines if they transmit sensitive customer records outside sovereign borders. Compliance officers cannot inspect millions of high-velocity payload streams manually.\",\n    interpretation: \"Inspects incoming and outgoing streaming data payloads at the API Gateway level. Detects and blocks PII, health information (PHI), or localized data transgressions in real time.\",\n    knowledgeNeeded: [\n      \"EU GDPR directives handbook\",\n      \"CCPA regulatory frameworks\",\n      \"HIPAA Protected Health Information (PHI) identifiers catalog\",\n      \"Enterprise custom localized data categorization schema\"\n    ],\n    steps: [\n      {\n        title: \"Payload Inspection & Decoding\",\n        description: \"Intercepts and decodes high-throughput API gateway JSON parameters within physical memory cache boundaries.\",\n        role: \"API Gateway Interceptor\"\n      },\n      {\n        title: \"RegEx & Semantic Scanning\",\n        description: \"Utilizes ultra-low-latency models to check incoming variables for PII (names, SSNs, credit card numbers, geo-coordinates).\",\n        role: \"PII Semantic Scanner\"\n      },\n      {\n        title: \"Inline Redaction & Tokenization\",\n        description: \"Replaces sensitive data values with encrypted tokens (tokenization) or complete black-out masks before leaving the server.\",\n        role: \"Encryption Masking Engine\"\n      },\n      {\n        title: \"Violation Alert & Logging\",\n        description: \"Generates tamper-proof compliance ledger records logging the incident type, time, and active gateway route.\",\n        role: \"Ledger Audit Dispatcher\"\n      }\n    ],\n    humanApproval: \"Data Protection Officer (DPO) is alerted to review blocked payloads and decide whether to whitelist specific encrypted tokens.\",\n    governanceCheck: \"Zero-Trust gateway prevents egress of non-anonymized data; automated audit-trail hash is written to the immutable compliance ledger.\",\n    outputPreview: `{\n  \"gateway_session\": \"GW-9921-X\",\n  \"packets_inspected\": \"41,209\",\n  \"violations_detected\": \"1 (PII/Social Security Number detected in Outbound Payload #882)\",\n  \"action_taken\": \"PAYLOAD_MUTED_AND_REDACTED\",\n  \"compliance_status\": \"SECURED\"\n}`,\n    logs: [\n      { timeOffset: 0.2, type: \"system\", text: \"Starting API interceptor stream on node COV_GATEWAY-04...\" },\n      { timeOffset: 0.8, type: \"info\", text: \"Syncing compliance policy rules with GFF Sovereign Repository-Central...\" },\n      { timeOffset: 1.5, type: \"agent\", text: \"[Interceptor] Ingestion buffer bound: active pipeline streaming 8.4K requests/sec.\" },\n      { timeOffset: 2.2, type: \"agent\", text: \"[PIIScanner] Outbound Packet #882 flagged. High-confidence SSN pattern detected inside user_profile payload.\" },\n      { timeOffset: 3.1, type: \"warning\", text: \"[MaskingEngine] Masking index [102-111] with standard SHA-256 tokens. Suppressing original.\" },\n      { timeOffset: 4.1, type: \"success\", text: \"Compliance violation intercepted. Payload redacted cleanly. Audit log committed to sandbox ledger. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"customer-experience\",\n    name: \"Hyper-Personalized Support Agent\",\n    category: \"Customer Experience\",\n    purpose: \"Empathetic, brand-aligned customer advisor that resolves premium service issues using historical CRM data.\",\n    recommendedIndustry: \"Retail & Supply Chain\",\n    relatedPlatform: \"RetailMesh / CRM Connector\",\n    agentType: \"Workflow Router\",\n    status: \"Ready for Simulation\",\n    securityRating: \"ISO-27001 Certified\",\n    metrics: {\n      cpu: \"8-Core vCPU\",\n      memory: \"32GB Isolated\",\n      isolation: \"Intel SGX Enclave\",\n      compliance: \"Sovereign Privacy Shield\"\n    },\n    ingressLabel: \"Customer Ticket & Chat History\",\n    egressLabel: \"Empathetic Resolution Email\",\n    challenge: \"Large-scale customer support centers suffer from slow resolution times and high operational costs, yet generic AI chatbots frustrate high-net-worth customers by giving repetitive, unhelpful, and generic answers.\",\n    interpretation: \"Analyzes user history and emotional sentiment. Cross-references internal knowledge bases, and formulates precise, highly contextual, empathetic resolutions.\",\n    knowledgeNeeded: [\n      \"Customer CRM transaction records\",\n      \"Internal product resolution logs\",\n      \"Live courier and shipping status APIs\",\n      \"Tone of Voice & Sentiment Guardrails\"\n    ],\n    steps: [\n      {\n        title: \"Emotional Sentiment Detection\",\n        description: \"Scans active user tickets and historical chats to identify emotional triggers (frustrated, disappointed, urgent).\",\n        role: \"Sentiment Classifier\"\n      },\n      {\n        title: \"Contextual CRM Search\",\n        description: \"Queries customer profile histories, transaction statuses, and past resolutions to build a comprehensive service profile.\",\n        role: \"CRM Integrator\"\n      },\n      {\n        title: \"Resolution Strategy Synthesis\",\n        description: \"Formulates a custom-tailored resolution (refund, replacement, credit) adhering strictly to localized compensation caps.\",\n        role: \"Resolution Synthesizer\"\n      },\n      {\n        title: \"Response Quality Control Check\",\n        description: \"Polishes the draft response to ensure compliance with the enterprise’s premier tone and language standards.\",\n        role: \"Brand Guardrail Agent\"\n      }\n    ],\n    humanApproval: \"Support Supervisor reviews and edits responses for ultra-high-priority VIP clients before sending the final email or message.\",\n    governanceCheck: \"Safety filter blocks toxic language, and prevents the agent from promising refunds or credits beyond pre-approved thresholds.\",\n    outputPreview: `{\n  \"client_tier\": \"VIP_PLATINUM\",\n  \"sentiment\": \"FRUSTRATED\",\n  \"detected_issue\": \"Delayed delivery of custom industrial server rack\",\n  \"proposed_solution\": \"Express courier redirection + $200 service credit\",\n  \"response_draft\": \"Dear Mr. Vance, we sincerely apologize for the delay. We have upgraded your shipping to overnight express...\"\n}`,\n    logs: [\n      { timeOffset: 0.1, type: \"system\", text: \"Initializing Customer Support Enclave inside isolated sandbox host...\" },\n      { timeOffset: 0.8, type: \"info\", text: \"Successfully linked with Salesforce CRM & DHL Logistics API connectors.\" },\n      { timeOffset: 1.5, type: \"agent\", text: \"[SentimentClassifier] Ticket ID #9921 analyzed. Customer emotional index: FRUSTRATED.\" },\n      { timeOffset: 2.3, type: \"agent\", text: \"[CRMIntegrator] Client is marked Platinum. Historical billing total exceeds $420,000.\" },\n      { timeOffset: 3.2, type: \"warning\", text: \"[ResolutionSynthesizer] Delivery delayed at regional customs. Auto-generating overnight priority courier bypass.\" },\n      { timeOffset: 4.1, type: \"success\", text: \"Resolution email drafted. Sent to Support Supervisor interface for review. Dry-run complete.\" }\n    ]\n  },\n  {\n    id: \"operations-copilot\",\n    name: \"Asset Performance Copilot\",\n    category: \"Operations Copilot\",\n    purpose: \"Polls vibrational and thermal sensors to predict equipment failure and dispatch preventive maintenance schedules.\",\n    recommendedIndustry: \"Energy & Utilities\",\n    relatedPlatform: \"Foundry / IoT Gateway\",\n    agentType: \"Transactional / Actions\",\n    status: \"Enclave Verified\",\n    securityRating: \"ISO-27001 Certified\",\n    metrics: {\n      cpu: \"16-Core vCPU\",\n      memory: \"64GB Isolated\",\n      isolation: \"AMD SEV-SNP Enclave\",\n      compliance: \"Sovereign Industrial Standard\"\n    },\n    ingressLabel: \"Vibration Frequency Feeds\",\n    egressLabel: \"ERP Maintenance Work Order\",\n    challenge: \"Manufacturing plant operators struggle to predict equipment failure in industrial turbines, leading to catastrophic unscheduled downtime costing up to $500k per hour.\",\n    interpretation: \"Polls vibrational and thermal sensors. Compiles deviation profiles against physics-based baseline models, and identifies structural wear metrics.\",\n    knowledgeNeeded: [\n      \"Vibration frequency baselines specifications\",\n      \"Equipment manufacturing design sheets\",\n      \"Turbine past maintenance log history\",\n      \"Weather, ambient humidity, and load telemetry data\"\n    ],\n    steps: [\n      {\n        title: \"Live Sensor Telemetry Ingestion\",\n        description: \"Aggregates real-time sensor streams (bearing vibrations, internal temperatures, pressure parameters) into an isolated buffer.\",\n        role: \"Telemetry Ingestion Agent\"\n      },\n      {\n        title: \"Anomaly Signature Synthesis\",\n        description: \"Applies physics-based deviation models to check if frequency parameters surpass baseline safety thresholds.\",\n        role: \"Anomaly Detector\"\n      },\n      {\n        title: \"Maintenance Manual Retrieval\",\n        description: \"Locates exact model-matching instruction booklets in GFF Sovereign KMS to extract step-by-step repair guides.\",\n        role: \"Manual Retriever\"\n      },\n      {\n        title: \"Dispatch Order Pre-authoring\",\n        description: \"Drafts a localized SAP Work Order detailing required parts, structural repair guides, and certified technician skillsets.\",\n        role: \"Work Order Preparer\"\n      }\n    ],\n    humanApproval: \"Plant Director must manually sign off on the preventive maintenance dispatch order to shut down Turbine-3 for 2 hours.\",\n    governanceCheck: \"Compliance check validates that all scheduled technicians have active safety certifications for High-Voltage Phase-3 equipment.\",\n    outputPreview: `{\n  \"asset_id\": \"TURBINE-03\",\n  \"anomaly_rating\": \"CRITICAL_92%\",\n  \"wear_indicator\": \"Bearing-B radial oscillation is 1.8mm/s above design limits\",\n  \"scheduled_maintenance\": \"Preventive maintenance recommended within 48 hours\",\n  \"required_parts\": \"ISO-Bearing-883-X\"\n}`,\n    logs: [\n      { timeOffset: 0.2, type: \"system\", text: \"Establishing physical communication with turbine IoT gateway buffer...\" },\n      { timeOffset: 0.9, type: \"info\", text: \"Successfully connected. Collecting SCADA turbine telemetry stream...\" },\n      { timeOffset: 1.6, type: \"agent\", text: \"[TelemetryIngestion] Pulled bearing vibration logs: 42Hz oscillations observed.\" },\n      { timeOffset: 2.4, type: \"agent\", text: \"[AnomalyDetector] CRITICAL DEVIATION: Bearing radial displacement is 1.8mm over threshold limit.\" },\n      { timeOffset: 3.2, type: \"warning\", text: \"[ManualRetriever] Retrieved maintenance file ISO-B-883-REPLACEMENT.pdf. Compiling instructions.\" },\n      { timeOffset: 4.1, type: \"success\", text: \"SAP Work Order drafted. Routed to Plant Director dashboard. Dry-run complete.\" }\n    ]\n  }\n];\n\n// List of all filters available\nconst INDUSTRIES = [\n  \"All Industries\",\n  \"Energy & Utilities\",\n  \"Retail & Supply Chain\",\n  \"Education & Public Services\",\n  \"Banking & Legal Services\",\n  \"Banking & Financial Services\",\n  \"Government & Sovereign Cloud\"\n];\n\nconst FUNCTIONS = [\n  \"All Functions\",\n  \"Knowledge Search\",\n  \"Procurement Copilot\",\n  \"Operations Copilot\",\n  \"Customer Experience\"\n];\n\nconst AGENT_TYPES = [\n  \"All Agent Types\",\n  \"Deep Reasoning / DAG\",\n  \"Transactional / Actions\",\n  \"Workflow Router\"\n];\n\nexport default function SandboxPage() {\n  const [activeAgentId, setActiveAgentId] = useState<string>(\"knowledge-search\");\n  const [selectedIndustry, setSelectedIndustry] = useState<string>(\"All Industries\");\n  const [selectedFunction, setSelectedFunction] = useState<string>(\"All Functions\");\n  const [selectedAgentType, setSelectedAgentType] = useState<string>(\"All Agent Types\");\n  const [searchQuery, setSearchQuery] = useState<string>(\"\");\n\n  const [isSimulating, setIsSimulating] = useState(false);\n  const [simulationProgress, setSimulationProgress] = useState(0);\n  const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n  const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n  const [copiedStatus, setCopiedStatus] = useState(false);\n\n  // Filter lists based on rules\n  const filteredAgents = AGENTS.filter((agent) => {\n    const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n    const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n    const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n    const matchSearch =\n      searchQuery === \"\" ||\n      agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n\n    return matchIndustry && matchFunction && matchType && matchSearch;\n  });\n\n  // Dynamically pull active agent object\n  const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n\n  // If filtered agents changed and current active isn't in filtered, select the first filtered one\n  useEffect(() => {\n    if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n      setActiveAgentId(filteredAgents[0].id);\n    }\n  }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n\n  // Reset simulation whenever active agent changes\n  useEffect(() => {\n    setIsSimulating(false);\n    setSimulationProgress(0);\n    setSimulatedLogs([]);\n  }, [activeAgentId]);\n\n  // Handle dry-run simulation progress\n  useEffect(() => {\n    if (!isSimulating) return;\n\n    setSimulationProgress(0);\n    setSimulatedLogs([]);\n\n    const totalDuration = 4800; // 4.8s simulation\n    const intervalTime = 50; // update every 50ms\n    let elapsed = 0;\n\n    const interval = setInterval(() => {\n      elapsed += intervalTime;\n      const progress = Math.min((elapsed / totalDuration) * 100, 100);\n      setSimulationProgress(Math.round(progress));\n\n      // Stream logs matching current timeline progress\n      const secondsElapsed = elapsed / 1000;\n      const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n      setSimulatedLogs(activeLogs);\n\n      if (elapsed >= totalDuration) {\n        clearInterval(interval);\n        setIsSimulating(false);\n      }\n    }, intervalTime);\n\n    return () => clearInterval(interval);\n  }, [isSimulating, activeAgent]);\n\n  // Dynamic count generators for UI indicators\n  const getIndustryCount = (ind: string) => {\n    if (ind === \"All Industries\") return AGENTS.length;\n    return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n  };\n\n  const getFunctionCount = (fnc: string) => {\n    if (fnc === \"All Functions\") return AGENTS.length;\n    return AGENTS.filter((a) => a.category === fnc).length;\n  };\n\n  const getAgentTypeCount = (tp: string) => {\n    if (tp === \"All Agent Types\") return AGENTS.length;\n    return AGENTS.filter((a) => a.agentType === tp).length;\n  };\n\n  const handleCopySchema = () => {\n    navigator.clipboard.writeText(activeAgent.outputPreview);\n    setCopiedStatus(true);\n    setTimeout(() => setCopiedStatus(false), 2000);\n  };\n\n  const renderSVGArchitecture = (agent: AgentDemo) => {\n    return (\n      <div className=\"w-full h-[280px] rounded-xl border border-white/5 bg-[#030304] relative overflow-hidden flex flex-col items-center justify-center p-4\">\n        {/* Subtle background grids */}\n        <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#1f1f2e_1px,transparent_1px),linear-gradient(to_bottom,#1f1f2e_1px,transparent_1px)] bg-[size:16px_16px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] opacity-30\" />\n\n        {/* Dynamic DAG Flow Graphic */}\n        <div className=\"relative z-10 flex flex-col items-center justify-between h-full w-full max-w-md\">\n          {/* Top Row: Ingress Point */}\n          <div className=\"flex items-center gap-2 px-3 py-1.5 rounded-md border border-[#009DFF]/20 bg-[#009DFF]/5 text-[9px] font-mono text-[#009DFF] uppercase tracking-wider\">\n            <svg className=\"w-3 h-3 animate-pulse\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12\" />\n            </svg>\n            <span>INGRESS: {agent.ingressLabel}</span>\n          </div>\n\n          {/* Connected SVG lines */}\n          <svg className=\"absolute inset-0 w-full h-full pointer-events-none\" style={{ minHeight: \"100%\" }}>\n            <defs>\n              <linearGradient id=\"gff-line-grad\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n                <stop offset=\"0%\" stopColor=\"#009DFF\" stopOpacity=\"0.8\" />\n                <stop offset=\"50%\" stopColor=\"#9D00FF\" stopOpacity=\"0.6\" />\n                <stop offset=\"100%\" stopColor=\"#E4000F\" stopOpacity=\"0.8\" />\n              </linearGradient>\n            </defs>\n            {/* Center column flow lines */}\n            <line x1=\"50%\" y1=\"35\" x2=\"50%\" y2=\"245\" stroke=\"url(#gff-line-grad)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n            \n            {/* Split connections */}\n            <path d=\"M 50% 100 L 30% 145 M 50% 100 L 70% 145\" stroke=\"#33334d\" strokeWidth=\"1\" />\n            <path d=\"M 30% 175 L 50% 215 M 70% 175 L 50% 215\" stroke=\"#33334d\" strokeWidth=\"1\" />\n          </svg>\n\n          {/* Middle Row: Isolated Processing Clusters */}\n          <div className=\"flex justify-between w-full px-4 z-10\">\n            {/* Left Node */}\n            <div className=\"flex flex-col items-center p-2 rounded-lg border border-white/5 bg-black/80 max-w-[120px] text-center\">\n              <span className=\"text-[7px] font-mono text-white/40 uppercase tracking-widest block\">DECRYPTION</span>\n              <span className=\"text-[9px] text-white/80 font-bold mt-1 truncate w-full\">SECURE ENCLAVE</span>\n            </div>\n\n            {/* Middle Node (Main Core) */}\n            <div className=\"flex flex-col items-center p-2.5 rounded-lg border border-[#9D00FF]/30 bg-[#9D00FF]/5 max-w-[130px] text-center shadow-[0_0_15px_rgba(157,0,255,0.05)]\">\n              <span className=\"text-[7px] font-mono text-[#9D00FF] uppercase tracking-widest block font-bold\">SOVEREIGN CORE</span>\n              <span className=\"text-[9px] text-white font-bold mt-1 uppercase tracking-wider font-mono\">{agent.id.replace(\"-\", \" \")}</span>\n            </div>\n\n            {/* Right Node */}\n            <div className=\"flex flex-col items-center p-2 rounded-lg border border-white/5 bg-black/80 max-w-[120px] text-center\">\n              <span className=\"text-[7px] font-mono text-white/40 uppercase tracking-widest block\">POLICY FILTER</span>\n              <span className=\"text-[9px] text-white/80 font-bold mt-1 truncate w-full\">LOCAL GUARDRAIL</span>\n            </div>\n          </div>\n\n          {/* Bottom Row: Egress Point */}\n          <div className=\"flex items-center gap-2 px-3 py-1.5 rounded-md border border-[#E4000F]/20 bg-[#E4000F]/5 text-[9px] font-mono text-[#E4000F] uppercase tracking-wider\">\n            <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4\" />\n            </svg>\n            <span>EGRESS: {agent.egressLabel}</span>\n          </div>\n        </div>\n\n        {/* Footnote */}\n        <span className=\"absolute bottom-2 right-3 text-[7px] font-mono text-white/20 uppercase tracking-wider\">\n          GFF SECURE CRYPTO-BOUND-V1\n        </span>\n      </div>\n    );\n  };\n\n  return (\n    <InnerPageShell>\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-12\">\n        <InnerPageHero\n          title=\"Sovereign Agent Sandbox\"\n          subtitle=\"Simulate and stress-test high-throughput agent workflows in zero-trust cryptographic enclaves before factory deployment.\"\n          category=\"DEVELOPER PORTAL\"\n        />\n\n        {/* GLOBAL SEARCH & FILTER GRID */}\n        <MotionReveal>\n          <div className=\"rounded-3xl border border-white/10 bg-[#030304]/40 p-6 md:p-8 space-y-6 backdrop-blur-md\">\n            <div className=\"grid grid-cols-1 md:grid-cols-4 gap-4\">\n              \n              {/* Query Input */}\n              <div className=\"relative md:col-span-1\">\n                <input\n                  type=\"text\"\n                  placeholder=\"Filter by agent query...\"\n                  value={searchQuery}\n                  onChange={(e) => setSearchQuery(e.target.value)}\n                  className=\"w-full h-11 pl-10 pr-4 rounded-xl bg-[#08080c] border border-white/10 text-xs font-mono text-white placeholder-white/30 focus:border-[#009DFF] focus:outline-none transition-colors\"\n                />\n                <svg className=\"w-4 h-4 text-white/30 absolute left-3 top-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" />\n                </svg>\n              </div>\n\n              {/* Industry Select */}\n              <div className=\"relative\">\n                <select\n                  value={selectedIndustry}\n                  onChange={(e) => setSelectedIndustry(e.target.value)}\n                  className=\"w-full h-11 pl-4 pr-10 rounded-xl bg-[#08080c] border border-white/10 text-xs font-mono text-white appearance-none focus:border-[#009DFF] focus:outline-none transition-colors\"\n                >\n                  {INDUSTRIES.map((ind) => (\n                    <option key={ind} value={ind} className=\"bg-black text-white\">\n                      {ind.toUpperCase()} ({getIndustryCount(ind)})\n                    </option>\n                  ))}\n                </select>\n                <div className=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-white/40\">\n                  <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 9l-7 7-7-7\" />\n                  </svg>\n                </div>\n              </div>\n\n              {/* Function Scope Select */}\n              <div className=\"relative\">\n                <select\n                  value={selectedFunction}\n                  onChange={(e) => setSelectedFunction(e.target.value)}\n                  className=\"w-full h-11 pl-4 pr-10 rounded-xl bg-[#08080c] border border-white/10 text-xs font-mono text-white appearance-none focus:border-[#009DFF] focus:outline-none transition-colors\"\n                >\n                  {FUNCTIONS.map((fnc) => (\n                    <option key={fnc} value={fnc} className=\"bg-black text-white\">\n                      {fnc.toUpperCase()} ({getFunctionCount(fnc)})\n                    </option>\n                  ))}\n                </select>\n                <div className=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-white/40\">\n                  <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 9l-7 7-7-7\" />\n                  </svg>\n                </div>\n              </div>\n\n              {/* Agent Type Select */}\n              <div className=\"relative\">\n                <select\n                  value={selectedAgentType}\n                  onChange={(e) => setSelectedAgentType(e.target.value)}\n                  className=\"w-full h-11 pl-4 pr-10 rounded-xl bg-[#08080c] border border-white/10 text-xs font-mono text-white appearance-none focus:border-[#009DFF] focus:outline-none transition-colors\"\n                >\n                  {AGENT_TYPES.map((tp) => (\n                    <option key={tp} value={tp} className=\"bg-black text-white\">\n                      {tp.toUpperCase()} ({getAgentTypeCount(tp)})\n                    </option>\n                  ))}\n                </select>\n                <div className=\"pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-white/40\">\n                  <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 9l-7 7-7-7\" />\n                  </svg>\n                </div>\n              </div>\n\n            </div>\n\n            {/* Active Pill Displayer */}\n            {(selectedIndustry !== \"All Industries\" || selectedFunction !== \"All Functions\" || selectedAgentType !== \"All Agent Types\" || searchQuery !== \"\") && (\n              <div className=\"flex flex-wrap items-center gap-2 pt-4 border-t border-white/5 text-[10px] font-mono\">\n                <span className=\"text-white/40 uppercase mr-2 font-bold\">Applied:</span>\n                {selectedIndustry !== \"All Industries\" && (\n                  <span className=\"px-2.5 py-1 rounded-md bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\">\n                    Industry: {selectedIndustry}\n                  </span>\n                )}\n                {selectedFunction !== \"All Functions\" && (\n                  <span className=\"px-2.5 py-1 rounded-md bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20\">\n                    Category: {selectedFunction}\n                  </span>\n                )}\n                {selectedAgentType !== \"All Agent Types\" && (\n                  <span className=\"px-2.5 py-1 rounded-md bg-[#9D00FF]/10 text-[#a855f7] border border-[#9D00FF]/20\">\n                    Type: {selectedAgentType}\n                  </span>\n                )}\n                {searchQuery !== \"\" && (\n                  <span className=\"px-2.5 py-1 rounded-md bg-white/5 text-white border border-white/10\">\n                    Search: &quot;{searchQuery}&quot;\n                  </span>\n                )}\n                <button\n                  onClick={() => {\n                    setSelectedIndustry(\"All Industries\");\n                    setSelectedFunction(\"All Functions\");\n                    setSelectedAgentType(\"All Agent Types\");\n                    setSearchQuery(\"\");\n                  }}\n                  className=\"ml-auto text-xs font-mono text-[#E4000F] hover:underline\"\n                >\n                  CLEAR ALL FILTERS\n                </button>\n              </div>\n            )}\n          </div>\n        </MotionReveal>\n\n        {/* CORE WORKSPACE GRID */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          \n          {/* LEFT COLUMN: FILTERED BENTO GRID CATALOG OF AGENT CARDS */}\n          <div className=\"lg:col-span-5 space-y-4\">\n            <div className=\"flex items-center justify-between text-xs text-white/50 px-2 font-mono\">\n              <span>EXPLORE ENCLAVE TEMPLATES ({filteredAgents.length} MATCHING)</span>\n              <span>PAGE 1 OF 1</span>\n            </div>\n\n            {filteredAgents.length === 0 ? (\n              <div className=\"rounded-3xl border border-white/5 bg-[#030304]/60 p-12 text-center space-y-4\">\n                <svg className=\"w-12 h-12 text-white/10 mx-auto\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636\" />\n                </svg>\n                <div className=\"space-y-1\">\n                  <h4 className=\"font-bold text-white text-sm\">No Sandbox Blueprints Match Filters</h4>\n                  <p className=\"text-xs text-white/40 max-w-sm mx-auto\">\n                    Try loosening your industry, functional scope, or search queries to explore the standard GFF AI catalogue.\n                  </p>\n                </div>\n                <button\n                  onClick={() => {\n                    setSelectedIndustry(\"All Industries\");\n                    setSelectedFunction(\"All Functions\");\n                    setSelectedAgentType(\"All Agent Types\");\n                    setSearchQuery(\"\");\n                  }}\n                  className=\"px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-xs font-semibold hover:bg-white/10 hover:border-white/15 transition-all\"\n                >\n                  Reset Active Filters\n                </button>\n              </div>\n            ) : (\n              <div className=\"grid grid-cols-1 gap-4\">\n                {filteredAgents.map((agent) => {\n                  const isActive = agent.id === activeAgentId;\n                  return (\n                    <button\n                      key={agent.id}\n                      onClick={() => setActiveAgentId(agent.id)}\n                      className={`w-full text-left p-6 rounded-2xl border transition-all duration-300 group flex flex-col relative overflow-hidden ${\n                        isActive\n                          ? \"bg-gradient-to-br from-[#05080f] to-[#010102] border-[#009DFF]/30 shadow-[0_4px_24px_rgba(0,157,255,0.06)]\"\n                          : \"bg-[#030304]/60 border-white/5 hover:border-white/15 hover:bg-[#060608]/80\"\n                      }`}\n                    >\n                      {/* Active indicator bar */}\n                      {isActive && (\n                        <div className=\"absolute top-0 left-0 w-1.5 h-full bg-gradient-to-b from-[#009DFF] to-[#9D00FF]\" />\n                      )}\n\n                      <div className=\"flex items-center justify-between gap-4 w-full\">\n                        <span className=\"text-[9px] font-mono tracking-wider font-bold text-white/40 uppercase\">\n                          {agent.category}\n                        </span>\n                        <span className={`text-[8px] font-mono px-2 py-0.5 rounded-full border ${\n                          agent.status === \"Enclave Verified\"\n                            ? \"bg-emerald-500/5 text-emerald-400 border-emerald-500/10\"\n                            : \"bg-[#009DFF]/5 text-[#009DFF] border-[#009DFF]/10\"\n                        }`}>\n                          ● {agent.status}\n                        </span>\n                      </div>\n\n                      {/* Title */}\n                      <h3 className=\"text-sm font-bold text-white mt-2 group-hover:text-[#009DFF] transition-colors flex items-center gap-2\">\n                        {agent.name}\n                        <svg className={`w-3.5 h-3.5 text-white/20 group-hover:text-[#009DFF] group-hover:translate-x-0.5 transition-all ${isActive ? \"text-[#009DFF]\" : \"\"}`} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M9 5l7 7-7 7\" />\n                        </svg>\n                      </h3>\n\n                      {/* Purpose */}\n                      <p className=\"text-xs text-white/50 mt-2 font-light leading-relaxed\">\n                        {agent.purpose}\n                      </p>\n\n                      {/* Badges and metadata */}\n                      <div className=\"mt-4 pt-4 border-t border-white/5 grid grid-cols-2 gap-y-2 text-[9px] font-mono\">\n                        <div className=\"flex flex-col\">\n                          <span className=\"text-white/30 uppercase tracking-widest text-[7px]\">RECOMMENDED SECTOR</span>\n                          <span className=\"text-white/80 mt-0.5 truncate\">{agent.recommendedIndustry}</span>\n                        </div>\n                        <div className=\"flex flex-col\">\n                          <span className=\"text-white/30 uppercase tracking-widest text-[7px]\">PLATFORM SPEC</span>\n                          <span className=\"text-[#009DFF] mt-0.5 truncate\">{agent.relatedPlatform}</span>\n                        </div>\n                        <div className=\"flex flex-col mt-1\">\n                          <span className=\"text-white/30 uppercase tracking-widest text-[7px]\">DEPLOYMENT TYPE</span>\n                          <span className=\"text-white/80 mt-0.5 truncate\">{agent.agentType}</span>\n                        </div>\n                        <div className=\"flex flex-col mt-1\">\n                          <span className=\"text-white/30 uppercase tracking-widest text-[7px]\">SECURITY BOUNDARY</span>\n                          <span className=\"text-purple-400 mt-0.5 truncate\">{agent.securityRating}</span>\n                        </div>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n            )}\n          </div>\n\n          {/* RIGHT COLUMN: ACTIVE AGENT SIMULATION WORKSPACE (STICKY) */}\n          <div className=\"lg:col-span-7 lg:sticky lg:top-[116px] space-y-6\">\n            <div className=\"rounded-3xl border border-white/10 bg-black overflow-hidden shadow-2xl flex flex-col min-h-[680px]\">\n              \n              {/* TERMINAL MONITOR CONTROLLER HEADER */}\n              <div className=\"px-6 py-4 border-b border-white/10 bg-[#04060b] flex flex-wrap items-center justify-between gap-3\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"flex gap-1.5\">\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-[#E4000F]/40\" />\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-[#009DFF]/40\" />\n                    <span className=\"w-2.5 h-2.5 rounded-full bg-emerald-500/40\" />\n                  </div>\n                  <span className=\"text-xs font-mono font-bold text-white/90 uppercase tracking-wider ml-2\">\n                    WORKSPACE DETECTOR // {activeAgent.id}\n                  </span>\n                </div>\n                <div className=\"flex items-center gap-2 text-[10px] font-mono\">\n                  <span className={`w-2 h-2 rounded-full ${isSimulating ? \"bg-emerald-500 animate-pulse\" : \"bg-white/30\"}`} />\n                  <span className=\"text-white/40\">{isSimulating ? \"SIMULATION ACTIVE\" : \"STANDBY\"}</span>\n                </div>\n              </div>\n\n              {/* QUICK INSTANCE HARDWARE METRICS PANEL */}\n              <div className=\"p-4 border-b border-white/5 bg-[#030304]/80 grid grid-cols-4 gap-2 text-[9px] font-mono\">\n                <div className=\"flex flex-col p-2 rounded bg-white/[0.01] border border-white/5\">\n                  <span className=\"text-white/30 text-[7px]\">ALLOCATED HOST</span>\n                  <span className=\"text-[#00FF9D] mt-1 font-semibold\">{activeAgent.metrics.cpu}</span>\n                </div>\n                <div className=\"flex flex-col p-2 rounded bg-white/[0.01] border border-white/5\">\n                  <span className=\"text-white/30 text-[7px]\">MEMORY LOCK</span>\n                  <span className=\"text-[#009DFF] mt-1 font-semibold\">{activeAgent.metrics.memory}</span>\n                </div>\n                <div className=\"flex flex-col p-2 rounded bg-white/[0.01] border border-white/5\">\n                  <span className=\"text-white/30 text-[7px]\">ISOLATION SHIELD</span>\n                  <span className=\"text-purple-400 mt-1 font-semibold\">{activeAgent.metrics.isolation}</span>\n                </div>\n                <div className=\"flex flex-col p-2 rounded bg-white/[0.01] border border-white/5\">\n                  <span className=\"text-white/30 text-[7px]\">COMPLIANCE TARGET</span>\n                  <span className=\"text-amber-400 mt-1 font-semibold truncate\">{activeAgent.metrics.compliance}</span>\n                </div>\n              </div>\n\n              {/* HIGH-FIDELITY DETAILED VIEW TABS */}\n              <div className=\"border-b border-white/5 bg-black flex text-[9px] font-mono uppercase tracking-widest text-center\">\n                <button\n                  onClick={() => setActiveTab(\"blueprint\")}\n                  className={`flex-1 py-3 border-r border-white/5 hover:text-white transition-colors relative ${\n                    activeTab === \"blueprint\" ? \"text-[#009DFF] font-semibold bg-white/[0.02]\" : \"text-white/40\"\n                  }`}\n                >\n                  1. Simulation Workflow\n                  {activeTab === \"blueprint\" && (\n                    <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n                  )}\n                </button>\n                <button\n                  onClick={() => setActiveTab(\"architecture\")}\n                  className={`flex-1 py-3 border-r border-white/5 hover:text-white transition-colors relative ${\n                    activeTab === \"architecture\" ? \"text-[#009DFF] font-semibold bg-white/[0.02]\" : \"text-white/40\"\n                  }`}\n                >\n                  2. Sovereign DAG Map\n                  {activeTab === \"architecture\" && (\n                    <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n                  )}\n                </button>\n                <button\n                  onClick={() => setActiveTab(\"security\")}\n                  className={`flex-1 py-3 hover:text-white transition-colors relative ${\n                    activeTab === \"security\" ? \"text-[#009DFF] font-semibold bg-white/[0.02]\" : \"text-white/40\"\n                  }`}\n                >\n                  3. Security & Governance\n                  {activeTab === \"security\" && (\n                    <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n                  )}\n                </button>\n              </div>\n\n              {/* ACTIVE TAB CONTENT DISPLAY PANEL */}\n              <div className=\"flex-grow p-5 md:p-6 bg-[#010101] overflow-y-auto max-h-[500px]\">\n                <AnimatePresence mode=\"wait\">\n                  {activeTab === \"blueprint\" && (\n                    <motion.div\n                      initial={{ opacity: 0, y: 5 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      exit={{ opacity: 0, y: -5 }}\n                      className=\"space-y-6\"\n                    >\n                      {/* STATIC SIMULATION DISCLAIMER - CRITICAL FOR GUARDRAIL */}\n                      <div className=\"p-3.5 rounded-xl border border-amber-500/15 bg-amber-500/[0.02] flex items-start gap-3\">\n                        <svg className=\"w-4 h-4 text-amber-500 shrink-0 mt-0.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n                        </svg>\n                        <div className=\"text-[10px] font-mono text-amber-400 leading-normal font-light\">\n                          <strong className=\"font-bold\">DETERMINISTIC OFFLINE PREVIEW:</strong> This is a client-side static simulation designed to demonstrate isolated cognitive pipelines. No active external APIs, remote LLM endpoints, or live database writes are executed.\n                        </div>\n                      </div>\n\n                      {/* NARRATIVE HEADER */}\n                      <div className=\"space-y-1\">\n                        <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-wider block font-bold\">SOVEREIGN WORKFLOW PLAN</span>\n                        <h4 className=\"text-md font-bold text-white\">Full Deterministic Execution Track</h4>\n                        <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n                          Review the pre-mapped user constraints, required information schemas, action matrices, and checkpoints utilized by this autonomous template.\n                        </p>\n                      </div>\n\n                      {/* 1. USER CHALLENGE */}\n                      <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 space-y-2\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-[#E4000F] font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                          </svg>\n                          <span>User Challenge</span>\n                        </div>\n                        <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                          {activeAgent.challenge}\n                        </p>\n                      </div>\n\n                      {/* 2. AGENT INTERPRETATION */}\n                      <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 space-y-2\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5 animate-pulse\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\" />\n                          </svg>\n                          <span>Agent Interpretation & Plan</span>\n                        </div>\n                        <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                          {activeAgent.interpretation}\n                        </p>\n                      </div>\n\n                      {/* 3. KNOWLEDGE NEEDED */}\n                      <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 space-y-2.5\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-purple-400 font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4\" />\n                          </svg>\n                          <span>Sovereign Knowledge Assets Ingested</span>\n                        </div>\n                        <ul className=\"grid grid-cols-1 md:grid-cols-2 gap-2 text-[11px] font-mono text-white/70\">\n                          {activeAgent.knowledgeNeeded.map((item, idx) => (\n                            <li key={idx} className=\"flex items-center gap-2 bg-black border border-white/5 p-2 rounded-lg truncate\" title={item}>\n                              <span className=\"w-1.5 h-1.5 rounded-full bg-purple-500\" />\n                              <span className=\"truncate\">{item}</span>\n                            </li>\n                          ))}\n                        </ul>\n                      </div>\n\n                      {/* 4. ACTIONS IT WOULD TAKE (THE TIMELINE) */}\n                      <div className=\"space-y-4\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-emerald-400 font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                          </svg>\n                          <span>Sovereign DAG Execution Path</span>\n                        </div>\n\n                        {/* STEP CHRONOLOGY NARRATIVE TIMELINE */}\n                        <div className=\"relative pl-6 space-y-5 before:absolute before:top-2 before:bottom-2 before:left-[11px] before:w-[1px] before:bg-white/10\">\n                          {activeAgent.steps.map((step, idx) => (\n                            <div key={idx} className=\"relative group\">\n                              \n                              {/* Step node indicator */}\n                              <div className=\"absolute -left-[21px] top-1.5 w-[11px] h-[11px] rounded-full bg-black border-2 border-[#009DFF] flex items-center justify-center z-10\">\n                                <div className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF]/60\" />\n                              </div>\n\n                              <div className=\"space-y-1 pl-4\">\n                                <div className=\"flex flex-wrap items-center gap-2\">\n                                  <span className=\"text-xs font-bold text-white\">\n                                    Step {idx + 1}: {step.title}\n                                  </span>\n                                  <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 text-white/40 uppercase\">\n                                    {step.role}\n                                  </span>\n                                </div>\n                                <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n                                  {step.description}\n                                </p>\n                              </div>\n                            </div>\n                          ))}\n                        </div>\n                      </div>\n\n                      {/* 5. HUMAN-IN-THE-LOOP APPROVAL */}\n                      <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 space-y-2\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-blue-400 font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z\" />\n                          </svg>\n                          <span>Human-In-The-Loop (HITL) Gate</span>\n                        </div>\n                        <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                          {activeAgent.humanApproval}\n                        </p>\n                      </div>\n\n                      {/* 6. GOVERNANCE CHECK */}\n                      <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 space-y-2\">\n                        <div className=\"flex items-center gap-2 text-[10px] font-mono text-amber-400 font-bold uppercase tracking-wider\">\n                          <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n                          </svg>\n                          <span>Sovereign Governance Control Policy</span>\n                        </div>\n                        <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                          {activeAgent.governanceCheck}\n                        </p>\n                      </div>\n\n                      {/* 7. EXPECTED OUTPUT PREVIEW */}\n                      <div className=\"space-y-2\">\n                        <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-wider\">\n                          <div className=\"flex items-center gap-2 text-[#00FF9D] font-bold\">\n                            <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                              <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\" />\n                            </svg>\n                            <span>Expected Output Preview (JSON Schema)</span>\n                          </div>\n                          <button\n                            onClick={handleCopySchema}\n                            className=\"text-[#009DFF] hover:underline\"\n                          >\n                            {copiedStatus ? \"COPIED TO CLIPBOARD\" : \"COPY OUTPUT SCHEMA\"}\n                          </button>\n                        </div>\n                        <div className=\"p-4 rounded-xl border border-white/10 bg-[#020203] font-mono text-[11px] text-emerald-400 overflow-x-auto whitespace-pre leading-relaxed\">\n                          {activeAgent.outputPreview}\n                        </div>\n                      </div>\n\n                      {/* RELATED CTAs ROW - MANDATORY AS PER SPEC */}\n                      <div className=\"pt-6 border-t border-white/5 space-y-3\">\n                        <span className=\"text-[9px] font-mono text-white/30 uppercase tracking-wider block font-bold\">SOVEREIGN WORKSPACE RELATED MODULES</span>\n                        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n                          <a\n                            href=\"/build/talk\"\n                            className=\"p-3 rounded-xl border border-white/5 bg-[#030304] hover:border-[#009DFF]/30 transition-all text-left flex flex-col justify-between h-24 group\"\n                          >\n                            <span className=\"text-[10px] font-bold text-white group-hover:text-[#009DFF] transition-colors\">Talk to Agent Architect</span>\n                            <span className=\"text-[8px] text-white/40 font-mono block leading-relaxed\">Book a zero-trust enclave configuration session with our compliance engineering team.</span>\n                          </a>\n                          <a\n                            href=\"/build/blueprint\"\n                            className=\"p-3 rounded-xl border border-white/5 bg-[#030304] hover:border-[#9D00FF]/30 transition-all text-left flex flex-col justify-between h-24 group\"\n                          >\n                            <span className=\"text-[10px] font-bold text-white group-hover:text-[#9D00FF] transition-colors\">Configure Blueprint</span>\n                            <span className=\"text-[8px] text-white/40 font-mono block leading-relaxed\">Define bespoke data schemas, custom security boundaries, and localized execution graphs.</span>\n                          </a>\n                          <a\n                            href=\"/platforms/foundry\"\n                            className=\"p-3 rounded-xl border border-white/5 bg-[#030304] hover:border-[#E4000F]/30 transition-all text-left flex flex-col justify-between h-24 group\"\n                          >\n                            <span className=\"text-[10px] font-bold text-white group-hover:text-[#E4000F] transition-colors\">Open Foundry Studio</span>\n                            <span className=\"text-[8px] text-white/40 font-mono block leading-relaxed\">Instantly orchestrate data pipelines and monitor live sovereign micro-agent containers.</span>\n                          </a>\n                        </div>\n                      </div>\n\n                    </motion.div>\n                  )}\n\n                  {activeTab === \"architecture\" && (\n                    <motion.div\n                      initial={{ opacity: 0, y: 5 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      exit={{ opacity: 0, y: -5 }}\n                      className=\"space-y-6\"\n                    >\n                      <div className=\"space-y-1\">\n                        <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-wider block font-bold\">FLOW TOPOLOGY ARCHITECTURE</span>\n                        <h4 className=\"text-md font-bold text-white\">Isolated Data Routing & Cryptographic DAG</h4>\n                        <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n                          Cryptographic verification and decryption happen natively at physical memory boundary nodes. No data touches raw external servers.\n                        </p>\n                      </div>\n\n                      {renderSVGArchitecture(activeAgent)}\n\n                      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-light leading-relaxed\">\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304] space-y-1.5\">\n                          <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider block font-bold\">ZERO INTERNET EGRESS BOUNDS</span>\n                          <p className=\"text-white/60\">\n                            The secure sandbox blocks all TCP/UDP outbound routing during processing to ensure that sensitive customer database variables or credentials cannot leak to public AI clusters.\n                          </p>\n                        </div>\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304] space-y-1.5\">\n                          <span className=\"text-[9px] font-mono text-purple-400 uppercase tracking-wider block font-bold\">IMMUTABLE LOG VERIFICATION</span>\n                          <p className=\"text-white/60\">\n                            Each active execution produces an audit trail containing cryptographic verification blocks. These can be committed directly to a sovereign auditing ledger.\n                          </p>\n                        </div>\n                      </div>\n                    </motion.div>\n                  )}\n\n                  {activeTab === \"security\" && (\n                    <motion.div\n                      initial={{ opacity: 0, y: 5 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      exit={{ opacity: 0, y: -5 }}\n                      className=\"space-y-6\"\n                    >\n                      <div className=\"space-y-1\">\n                        <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-wider block font-bold\">COMPLIANCE & ATTESTATION</span>\n                        <h4 className=\"text-md font-bold text-white\">Sovereign Guardrails & Attestation Reports</h4>\n                        <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n                          GFF AI operates on a hardware-attested, zero-trust infrastructure. Every single transaction step must pass localized boundary filters.\n                        </p>\n                      </div>\n\n                      <div className=\"space-y-4\">\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304] space-y-2\">\n                          <span className=\"text-[9px] font-mono text-[#00FF9D] uppercase tracking-wider block font-bold\">AMD SEV-SNP HARDWARE ATTESTATION</span>\n                          <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                            Secures execution weights inside AMD secure memory enclaves. Third-party hosts, hypervisors, and cloud operator kernels are completely barred from viewing active memory segments.\n                          </p>\n                        </div>\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304] space-y-2\">\n                          <span className=\"text-[9px] font-mono text-amber-400 uppercase tracking-wider block font-bold\">MODEL DRIFT GUARD</span>\n                          <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                            Continuous compliance score filters and mitigates potential hallucination patterns down to less than 0.01% standard deviation.\n                          </p>\n                        </div>\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304] space-y-2\">\n                          <span className=\"text-[9px] font-mono text-purple-400 uppercase tracking-wider block font-bold\">VIRTUAL PRIVATE CANOPY</span>\n                          <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n                            Isolated VPC boundary blockages deny any unencrypted internet egress during agent transaction routing tasks.\n                          </p>\n                        </div>\n                      </div>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n              </div>\n\n              {/* SIMULATION ACTIVE OUTPUT STREAM MONITOR (TELEMETRY LOGS) */}\n              <div className=\"border-t border-white/10 bg-black flex flex-col h-[280px]\">\n                \n                {/* Console controller row */}\n                <div className=\"px-5 py-3 border-b border-white/5 bg-[#030304]/90 flex items-center justify-between\">\n                  <span className=\"text-[9px] font-mono text-white/40 tracking-wider\">SECURE TELEMETRY SIMULATOR PANEL</span>\n                  {simulationProgress > 0 && (\n                    <span className=\"text-[9px] font-mono font-bold text-[#00FF9D]\">\n                      PROGRESS: {simulationProgress}%\n                    </span>\n                  )}\n                </div>\n\n                {/* Progress bar stream */}\n                <div className=\"w-full h-1 bg-[#0c0c0e]\">\n                  <div\n                    className=\"h-full bg-gradient-to-r from-[#E4000F] via-[#009DFF] to-[#00FF9D] transition-all duration-100\"\n                    style={{ width: `${simulationProgress}%` }}\n                  />\n                </div>\n\n                {/* Live Output Log Stream */}\n                <div className=\"flex-1 p-5 overflow-y-auto font-mono text-[11px] space-y-2 bg-[#020202]\">\n                  {simulatedLogs.length === 0 ? (\n                    <div className=\"h-full flex flex-col items-center justify-center text-white/30 space-y-3\">\n                      <svg className=\"w-8 h-8 text-white/10\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n                      </svg>\n                      <p className=\"text-center max-w-xs font-light text-[9px] uppercase tracking-wider leading-relaxed\">\n                        Secure Enclave Ready. Click Launch to simulate dry-run telemetry outputs locally.\n                      </p>\n                    </div>\n                  ) : (\n                    <div className=\"space-y-1.5\">\n                      {simulatedLogs.map((log, idx) => {\n                        const getLogColor = () => {\n                          switch (log.type) {\n                            case \"success\": return \"text-[#00FF9D]\";\n                            case \"warning\": return \"text-amber-400\";\n                            case \"agent\": return \"text-[#009DFF]\";\n                            case \"system\": return \"text-purple-400 font-bold\";\n                            default: return \"text-white/70\";\n                          }\n                        };\n                        return (\n                          <div key={idx} className=\"flex gap-2 border-l border-white/10 pl-2 text-[10px] leading-normal\">\n                            <span className=\"text-white/20 font-light\">+{log.timeOffset.toFixed(1)}s</span>\n                            <span className=\"text-white/40 font-bold\">[{log.type.toUpperCase()}]</span>\n                            <span className={getLogColor()}>{log.text}</span>\n                          </div>\n                        );\n                      })}\n\n                      {isSimulating && (\n                        <div className=\"flex gap-2 items-center text-white/25 text-[9px] mt-1 pl-2\">\n                          <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping\" />\n                          <span>Processing dynamic secure telemetry pipeline...</span>\n                        </div>\n                      )}\n                    </div>\n                  )}\n                </div>\n\n                {/* LAUNCH CONTROL ROW */}\n                <div className=\"p-4 border-t border-white/5 bg-[#030304] flex items-center justify-end gap-3\">\n                  {simulatedLogs.length > 0 && !isSimulating && (\n                    <button\n                      onClick={() => {\n                        setSimulationProgress(0);\n                        setSimulatedLogs([]);\n                      }}\n                      className=\"px-4 py-2 rounded-lg text-[10px] font-mono font-bold uppercase tracking-wider border border-white/10 hover:bg-white/5 text-white/80 transition-all\"\n                    >\n                      Clear Logs\n                    </button>\n                  )}\n                  \n                  <button\n                    onClick={() => setIsSimulating(true)}\n                    disabled={isSimulating}\n                    className=\"h-10 px-6 rounded-lg text-[10px] font-mono font-bold uppercase tracking-wider bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-95 text-white disabled:opacity-50 transition-opacity\"\n                  >\n                    {isSimulating\n                      ? `Enclave Active (${simulationProgress}%)`\n                      : simulatedLogs.length > 0\n                        ? \"Re-Run Dry-Run Simulation\"\n                        : \"Launch Simulated Sandbox\"}\n                  </button>\n                </div>\n\n              </div>\n\n            </div>\n          </div>\n\n        </div>\n\n        {/* PREMIUM SECURE ENCLAVE CTA */}\n        <PremiumCTA\n          title=\"Ready to Build in the Sovereign Sandbox?\"\n          description=\"Engage our dedicated security architecture team to create isolated, zero-trust deployment sandboxes. Run real-time high-throughput agents optimized for your compliance blueprints.\"\n          primaryLabel=\"Connect with Engineers\"\n          primaryHref=\"/#contact\"\n          secondaryLabel=\"Explore Architecture Specs\"\n          secondaryHref=\"/resources/architecture-library\"\n        />\n\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
