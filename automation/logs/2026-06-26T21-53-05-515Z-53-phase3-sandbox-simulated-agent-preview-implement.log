Agent\",\n351 |     purpose: \"Resolves billing inquiries, diagnostic anomalies, and service adjustments within zero-trust sandboxed limits.\",\n352 |     recommendedIndustry: \"Telecom\",\n353 |     relatedPlatform: \"TelecomVerse\",\n354 |     agentType: \"Real-time / Interactive\",\n355 |     status: \"Ready for Simulation\",\n356 |     securityRating: \"Hardened Gateway\",\n357 |     metrics: {\n358 |       cpu: \"4-Core vCPU\",\n359 |       memory: \"16GB Secure\",\n360 |       isolation: \"Intel SGX Enclave\",\n361 |       compliance: \"TCPA / HIPAA Compliant\"\n362 |     },\n363 |     ingressLabel: \"User Support Chat Thread\",\n364 |     egressLabel: \"Billing Credit & SMS Alert\",\n365 |     steps: [\n366 |       {\n367 |         title: \"Intent Parsing & Verification\",\n368 |         description: \"Resolves primary customer request topic while validating user secure-token claims.\",\n369 |         role: \"Customer Intent Classifier\"\n370 |       },\n371 |       {\n372 |         title: \"Database Telemetry Query\",\n373 |         description: \"Retrieves network registers, historical invoices, and billing traces inside secured read-only memory.\",\n374 |         role: \"Billing Database Connector\"\n375 |       },\n376 |       {\n377 |         title: \"Resolution Strategy Engine\",\n378 |         description: \"Computes loyalty credits or service tier modifications based on enterprise policy guidelines.\",\n379 |         role: \"Policy Execution Agent\"\n380 |       },\n381 |       {\n382 |         title: \"Secured Transaction Run\",\n383 |         description: \"Fires secure webhooks to credit billing profiles and sends cryptographically verified notifications.\",\n384 |         role: \"Transaction Runner Agent\"\n385 |       }\n386 |     ],\n387 |     logs: [\n388 |       { timeOffset: 0.3, type: \"system\", text: \"Customer chat session established (Session: #CC-8402).\" },\n389 |       { timeOffset: 0.9, type: \"info\", text: \"User Token Verified: Tier-1 Platinum Account (ID: 49204).\" },\n390 |       { timeOffset: 1.6, type: \"agent\", text: \"[Classifier] Customer complaint: 'Unexplained $450 data roaming surcharge during Swiss travel.'\" },\n391 |       { timeOffset: 2.3, type: \"agent\", text: \"[Connector] Querying usage registry: verified 9.2GB Swisscom roaming on Jun-18. Tariff mismatch detected.\" },\n392 |       { timeOffset: 3.0, type: \"agent\", text: \"[PolicyAgent] Core logic approved: Customer is eligible for retro-credit of $350 under Platinum SLA.\" },\n393 |       { timeOffset: 3.7, type: \"success\", text: \"[TransactionAgent] Direct credit issued in billing DB. Transaction Ref: TX-903112.\" },\n394 |       { timeOffset: 4.4, type: \"success\", text: \"Confirmation SMS sent to client mobile. Interactive session resolved.\" }\n395 |     ]\n396 |   },\n397 |   {\n398 |     id: \"operations-copilot\",\n399 |     name: \"Predictive Maintenance Operations Agent\",\n400 |     category: \"Operations Copilot\",\n401 |     purpose: \"Analyzes high-frequency vibration and heat telemetry, predicts failure timelines, and dispatches warehouse resources.\",\n402 |     recommendedIndustry: \"Heavy Industry & Mining\",\n403 |     relatedPlatform: \"OreMesh / Telemetry\",\n404 |     agentType: \"Reactive / Hardware Integration\",\n405 |     status: \"Enclave Verified\",\n406 |     securityRating: \"Safety-Critical Enclave\",\n407 |     metrics: {\n408 |       cpu: \"16-Core vCPU\",\n409 |       memory: \"64GB Isolated\",\n410 |       isolation: \"AWS Nitro Enclave\",\n411 |       compliance: \"ISO-55001 Asset Management\"\n412 |     },\n413 |     ingressLabel: \"Vibration Sensor Stream\",\n414 |     egressLabel: \"Field Dispatch Work Order\",\n415 |     steps: [\n416 |       {\n417 |         title: \"Telemetry Signal Parsing\",\n418 |         description: \"Ingests and parses real-time sensor streams and applies Fast Fourier Transforms (FFT).\",\n419 |         role: \"Signal Processing Agent\"\n420 |       },\n421 |       {\n422 |         title: \"Mechanical Failure Predictor\",\n423 |         description: \"Evaluates wear patterns against digital-twin anomalies to estimate remaining useful machine life.\",\n424 |         role: \"Digital Twin Engine\"\n425 |       },\n426 |       {\n427 |         title: \"Material Stock Audit\",\n428 |         description: \"Queries localized warehouse systems to confirm critical replacement part counts.\",\n429 |         role: \"Inventory Audit Agent\"\n430 |       },\n431 |       {\n432 |         title: \"Work-Order Dispatch\",\n433 |         description: \"Generates preventative maintenance tickets and routes them to regional field crews.\",\n434 |         role: \"Maintenance Coordinator\"\n435 |       }\n436 |     ],\n437 |     logs: [\n438 |       { timeOffset: 0.2, type: \"system\", text: \"Listening on OreMesh IoT telemetry gateway (Sector 9 Conveyor Systems)...\" },\n439 |       { timeOffset: 1.0, type: \"info\", text: \"Processing 10-second FFT window on Sensor_VIB_902...\" },\n440 |       { timeOffset: 1.8, type: \"agent\", text: \"[TwinEngine] Harmonic spike identified at 4.2 kHz. Matches bearing degradation pattern.\" },\n441 |       { timeOffset: 2.5, type: \"warning\", text: \"[TwinEngine] Remaining Useful Life (RUL) estimated: 72 hours. Critical Alert Level 2.\" },\n442 |       { timeOffset: 3.2, type: \"agent\", text: \"[InventoryAgent] Checked warehouse stock. Part 'SKF-Ball-Bearing-v9' in stock (Qty: 4).\" },\n443 |       { timeOffset: 3.9, type: \"agent\", text: \"[Coordinator] Creating SAP Maintenance Ticket OP-9942 and reserving replacement part.\" },\n444 |       { timeOffset: 4.6, type: \"success\", text: \"Maintenance dispatch instructions transmitted. Field tablet alerts active.\" }\n445 |     ]\n446 |   }\n447 | ];\n448 | \n449 | // List of all filters available\n450 | const INDUSTRIES = [\n451 |   \"All Industries\",\n452 |   \"Energy & Utilities\",\n453 |   \"Retail & Supply Chain\",\n454 |   \"Professional Services\",\n455 |   \"Regulated / Legal\",\n456 |   \"Financial Services\",\n457 |   \"Government & Sovereign\",\n458 |   \"Telecom\",\n459 |   \"Heavy Industry & Mining\"\n460 | ];\n461 | \n462 | const FUNCTIONS = [\n463 |   \"All Functions\",\n464 |   \"Knowledge Search\",\n465 |   \"Procurement Copilot\",\n466 |   \"HR Assistant\",\n467 |   \"Contract Intelligence\",\n468 |   \"Executive Dashboard\",\n469 |   \"Compliance Assistant\",\n470 |   \"Customer Experience Agent\",\n471 |   \"Operations Copilot\"\n472 | ];\n473 | \n474 | const AGENT_TYPES = [\n475 |   \"All Agent Types\",\n476 |   \"Deep Reasoning / DAG\",\n477 |   \"Transactional / Actions\",\n478 |   \"Collaborative / HITL\",\n479 |   \"Analytical / Extraction\",\n480 |   \"Multi-Agent Synthesis\",\n481 |   \"Guardrail / Audit\",\n482 |   \"Real-time / Interactive\",\n483 |   \"Reactive / Hardware\"\n484 | ];\n485 | \n486 | export default function SandboxPage() {\n487 |   // Filter States\n488 |   const [selectedIndustry, setSelectedIndustry] = useState(\"All Industries\");\n489 |   const [selectedFunction, setSelectedFunction] = useState(\"All Functions\");\n490 |   const [selectedAgentType, setSelectedAgentType] = useState(\"All Agent Types\");\n491 |   const [searchQuery, setSearchQuery] = useState(\"\");\n492 | \n493 |   // Catalog Active Agent Selection\n494 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n495 | \n496 |   // Simulation Telemetry States\n497 |   const [isSimulating, setIsSimulating] = useState(false);\n498 |   const [simulationProgress, setSimulationProgress] = useState(0);\n499 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n500 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n501 | \n502 |   // Filter lists based on rules\n503 |   const filteredAgents = AGENTS.filter((agent) => {\n504 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n505 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n506 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n507 |     const matchSearch =\n508 |       searchQuery === \"\" ||\n509 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n510 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n511 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n512 | \n513 |     return matchIndustry && matchFunction && matchType && matchSearch;\n514 |   });\n515 | \n516 |   // Dynamically pull active agent object\n517 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n518 | \n519 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n520 |   useEffect(() => {\n521 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n522 |       setActiveAgentId(filteredAgents[0].id);\n523 |     }\n524 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n525 | \n526 |   // Reset simulation whenever active agent changes\n527 |   useEffect(() => {\n528 |     setIsSimulating(false);\n529 |     setSimulationProgress(0);\n530 |     setSimulatedLogs([]);\n531 |   }, [activeAgentId]);\n532 | \n533 |   // Handle dry-run simulation progress\n534 |   useEffect(() => {\n535 |     if (!isSimulating) return;\n536 | \n537 |     setSimulationProgress(0);\n538 |     setSimulatedLogs([]);\n539 | \n540 |     const totalDuration = 4800; // 4.8s simulation\n541 |     const intervalTime = 50; // update every 50ms\n542 |     let elapsed = 0;\n543 | \n544 |     const interval = setInterval(() => {\n545 |       elapsed += intervalTime;\n546 |       const progress = Math.min((elapsed / totalDuration) * 100, 100);\n547 |       setSimulationProgress(Math.round(progress));\n548 | \n549 |       // Stream logs matching current timeline progress\n550 |       const secondsElapsed = elapsed / 1000;\n551 |       const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n552 |       setSimulatedLogs(activeLogs);\n553 | \n554 |       if (elapsed >= totalDuration) {\n555 |         clearInterval(interval);\n556 |         setIsSimulating(false);\n557 |       }\n558 |     }, intervalTime);\n559 | \n560 |     return () => clearInterval(interval);\n561 |   }, [isSimulating, activeAgent]);\n562 | \n563 |   // Dynamic count generators for UI indicators\n564 |   const getIndustryCount = (ind: string) => {\n565 |     if (ind === \"All Industries\") return AGENTS.length;\n566 |     return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n567 |   };\n568 | \n569 |   const getFunctionCount = (func: string) => {\n570 |     if (func === \"All Functions\") return AGENTS.length;\n571 |     return AGENTS.filter((a) => a.category === func).length;\n572 |   };\n573 | \n574 |   const getAgentTypeCount = (type: string) => {\n575 |     if (type === \"All Agent Types\") return AGENTS.length;\n576 |     return AGENTS.filter((a) => a.agentType === type).length;\n577 |   };\n578 | \n579 |   // Render modern animated connection DAG inside Sovereign Architecture Tab\n580 |   const renderSVGArchitecture = (agent: AgentDemo) => {\n581 |     return (\n582 |       <svg className=\"w-full h-full min-h-[220px]\" viewBox=\"0 0 500 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n583 |         <defs>\n584 |           <linearGradient id=\"lineGlow\" x1=\"0\" y1=\"0\" x2=\"500\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n585 |             <stop stopColor=\"#E4000F\" />\n586 |             <stop offset=\"0.5\" stopColor=\"#009DFF\" />\n587 |             <stop offset=\"1\" stopColor=\"#00FF9D\" />\n588 |           </linearGradient>\n589 |           <filter id=\"glowEffect\" x=\"-10%\" y=\"-10%\" width=\"120%\" height=\"120%\">\n590 |             <feGaussianBlur stdDeviation=\"5\" result=\"blur\" />\n591 |             <feComposite in=\"SourceGraphic\" in2=\"blur\" operator=\"over\" />\n592 |           </filter>\n593 |         </defs>\n594 | \n595 |         {/* Outer Boundary Box: Cryptographic Enclave */}\n596 |         <rect x=\"130\" y=\"20\" width=\"240\" height=\"180\" rx=\"16\" fill=\"rgba(4,6,11,0.7)\" stroke=\"rgba(0,157,255,0.25)\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n597 |         <text x=\"250\" y=\"212\" fill=\"rgba(255,255,255,0.35)\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\" letterSpacing=\"0.1em\">\n598 |           SOVEREIGN ENCLAVE HARDWARE BOUNDARY\n599 |         </text>\n600 | \n601 |         {/* Dynamic connection lines */}\n602 |         {/* Inbound path */}\n603 |         <path d=\"M 60 110 L 130 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n604 |         <circle cx=\"100\" cy=\"110\" r=\"3\" fill=\"#E4000F\">\n605 |           <animate attributeName=\"cx\" values=\"60;130\" dur=\"2s\" repeatCount=\"indefinite\" />\n606 |         </circle>\n607 | \n608 |         {/* Enclave internal routing path */}\n609 |         <path d=\"M 180 110 L 250 65 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n610 |         <path d=\"M 180 110 L 250 155 L 320 110\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n611 |         <circle cx=\"215\" cy=\"87\" r=\"2.5\" fill=\"#009DFF\">\n612 |           <animate attributeName=\"cx\" values=\"180;250;320\" dur=\"3s\" repeatCount=\"indefinite\" />\n613 |         </circle>\n614 | \n615 |         {/* Outbound path */}\n616 |         <path d=\"M 370 110 L 440 110\" stroke=\"url(#lineGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"5 3\" />\n617 |         <circle cx=\"400\" cy=\"110\" r=\"3\" fill=\"#00FF9D\">\n618 |           <animate attributeName=\"cx\" values=\"370;440\" dur=\"2.5s\" repeatCount=\"indefinite\" />\n619 |         </circle>\n620 | \n621 