rokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z\" />\n1138 |                       </svg>\n1139 |                       <p className=\"text-center max-w-xs font-light text-[10px] uppercase tracking-wider\">\n1140 |                         Secure Enclave Ready. Click Launch to simulate dry-run telemetry outputs locally.\n1141 |                       </p>\n1142 |                     </div>\n1143 |                   ) : (\n1144 |                     <div className=\"space-y-2\">\n1145 |                       {simulatedLogs.map((log, idx) => {\n1146 |                         const getLogColor = () => {\n1147 |                           switch (log.type) {\n1148 |                             case \"success\": return \"text-[#00FF9D]\";\n1149 |                             case \"warning\": return \"text-amber-400\";\n1150 |                             case \"agent\": return \"text-[#009DFF]\";\n1151 |                             case \"system\": return \"text-purple-400 font-bold\";\n1152 |                             default: return \"text-white/70\";\n1153 |                           }\n1154 |                         };\n1155 |                         return (\n1156 |                           <div key={idx} className=\"flex gap-2 border-l border-white/10 pl-2 text-[10px]\">\n1157 |                             <span className=\"text-white/20\">+{log.timeOffset.toFixed(1)}s</span>\n1158 |                             <span className=\"text-white/40\">[{log.type.toUpperCase()}]</span>\n1159 |                             <span className={getLogColor()}>{log.text}</span>\n1160 |                           </div>\n1161 |                         );\n1162 |                       })}\n1163 | \n1164 |                       {isSimulating && (\n1165 |                         <div className=\"flex gap-2 items-center text-white/20 text-[9px]\">\n1166 |                           <span>•</span>\n1167 |                           <span>•</span>\n1168 |                           <span>•</span>\n1169 |                           <span>Enclave processing stream active...</span>\n1170 |                         </div>\n1171 |                       )}\n1172 |                     </div>\n1173 |                   )}\n1174 |                 </div>\n1175 | \n1176 |                 {/* LAUNCH CONTROL ROW */}\n1177 |                 <div className=\"p-4 border-t border-white/5 bg-[#030304] flex items-center justify-end gap-3\">\n1178 |                   {simulatedLogs.length > 0 && !isSimulating && (\n1179 |                     <button\n1180 |                       onClick={() => {\n1181 |                         setSimulationProgress(0);\n1182 |                         setSimulatedLogs([]);\n1183 |                       }}\n1184 |                       className=\"px-4 py-2.5 rounded-lg text-[10px] font-mono font-bold uppercase tracking-wider border border-white/10 hover:bg-white/5 text-white/80 transition-all\"\n1185 |                     >\n1186 |                       Clear Logs\n1187 |                     </button>\n1188 |                   )}\n1189 |                   \n1190 |                   <button\n1191 |                     onClick={() => setIsSimulating(true)}\n1192 |                     disabled={isSimulating}\n1193 |                     className=\"h-10 px-6 rounded-lg text-[10px] font-mono font-bold uppercase tracking-wider bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-95 text-white disabled:opacity-50 transition-opacity\"\n1194 |                   >\n1195 |                     {isSimulating\n1196 |                       ? `Enclave Active (${simulationProgress}%)`\n1197 |                       : simulatedLogs.length > 0\n1198 |                         ? \"Re-Run Dry-Run Simulation\"\n1199 |                         : \"Launch Simulated Sandbox\"}\n1200 |                   </button>\n1201 |                 </div>\n1202 | \n1203 |               </div>\n1204 | \n1205 |             </div>\n1206 |           </div>\n1207 | \n1208 |         </div>\n1209 | \n1210 |         {/* PREMIUM SECURE ENCLAVE CTA */}\n1211 |         <PremiumCTA\n1212 |           title=\"Ready to Build in the Sovereign Sandbox?\"\n1213 |           description=\"Engage our dedicated security architecture team to create isolated, zero-trust deployment sandboxes. Run real-time high-throughput agents optimized for your compliance blueprints.\"\n1214 |           primaryLabel=\"Connect with Engineers\"\n1215 |           primaryHref=\"/#contact\"\n1216 |           secondaryLabel=\"Explore Architecture Specs\"\n1217 |           secondaryHref=\"/resources/architecture-library\"\n1218 |         />\n1219 | \n1220 |       </div>\n1221 |     </InnerPageShell>\n1222 |   );\n1223 | }","success":true}],"durationMs":3}}
