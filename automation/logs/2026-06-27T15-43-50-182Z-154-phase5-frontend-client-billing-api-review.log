 |     setError(null);\n 89 |     try {\n 90 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n 91 |       if (!token) {\n 92 |         setError(\"AUTHENTICATION TOKENS MISSING. SECURE SESSION EXPIRED.\");\n 93 |         return;\n 94 |       }\n 95 |       \n 96 |       const res = await fetch(\"/api/v1/invoices\", {\n 97 |         headers: {\n 98 |           \"Authorization\": `Bearer ${token}`,\n 99 |           \"Content-Type\": \"application/json\"\n100 |         }\n101 |       });\n102 | \n103 |       if (!res.ok) {\n104 |         throw new Error(`Enclave sync failed with status ${res.status}`);\n105 |       }\n106 | \n107 |       const data = await res.json();\n108 |       if (data.success && Array.isArray(data.invoices)) {\n109 |         setInvoices(data.invoices);\n110 |         if (data.invoices.length > 0) {\n111 |           // Select first invoice's invoice number with matching PROJECTS_DATA if possible\n112 |           const matched = data.invoices.find((inv: any) => PROJECTS_DATA[inv.invoice_number]);\n113 |           if (matched) {\n114 |             setSelProjectKey(matched.invoice_number);\n115 |           } else {\n116 |             setSelProjectKey(data.invoices[0].invoice_number);\n117 |           }\n118 |         }\n119 |       } else {\n120 |         throw new Error(\"Handshake returned malformed enclave register.\");\n121 |       }\n122 |     } catch (err: any) {\n123 |       console.error(\"Error fetching billing invoices:\", err);\n124 |       setError(err.message || \"Decentralized ledger handshake timed out.\");\n125 |     } finally {\n126 |       setLoading(false);\n127 |     }\n128 |   }, []);\n129 | \n130 |   useEffect(() => {\n131 |     fetchInvoices();\n132 |   }, [fetchInvoices]);\n133 | \n134 |   const handleCopy = (text: string, id: string) => {\n135 |     navigator.clipboard.writeText(text);\n136 |     setCopiedId(id);\n137 |     setTimeout(() => setCopiedId(null), 1500);\