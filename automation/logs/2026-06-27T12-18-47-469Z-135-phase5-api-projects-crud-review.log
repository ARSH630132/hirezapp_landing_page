ry);\n247 | \n248 |       const matchesClient = selectedClient === \"\" || p.client === selectedClient;\n249 |       const matchesPhase = selectedPhase === \"\" || p.phase === selectedPhase;\n250 |       const matchesStatus = selectedStatus === \"\" || p.status === selectedStatus;\n251 |       const matchesOwner = selectedOwner === \"\" || p.owner === selectedOwner;\n252 | \n253 |       return matchesSearch && matchesClient && matchesPhase && matchesStatus && matchesOwner;\n254 |     });\n255 |   }, [projects, searchQuery, selectedClient, selectedPhase, selectedStatus, selectedOwner]);\n256 | \n257 |   const getStatusStyle = (status: string) => {\n258 |     switch (status) {\n259 |       case \"On Track\":\n260 |         return \"bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/15\";\n261 |       case \"At Risk\":\n262 |         return \"bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500/15\";\n263 |       case \"Delayed\":\n264 |         return \"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/15\";\n265 |       case \"Paused\":\n266 |         return \"bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/15\";\n267 |       default:\n268 |         return \"bg-white/5 border border-white/10 text-white/60 hover:bg-white/10\";\n269 |     }\n270 |   };\n271 | \n272 |   const getPhaseColor = (phase: string) => {\n273 |     switch (phase) {\n274 |       case \"Phase I: Planning\":\n275 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.6)\" };\n276 |       case \"Phase II: Sandbox Provisioning\":\n277 |         return { border: \"rgba(59, 130, 246, 0.2)\", dot: \"rgb(59, 130, 246)\" };\n278 |       case \"Phase III: Agent Alignment\":\n279 |         return { border: \"rgba(0, 157, 255, 0.3)\", dot: \"rgb(0, 157, 255)\" };\n280 |       case \"Phase IV: User Acceptance Testing\":\n281 |         return { border: \"rgba(99, 102,