ge: string, type: \"info\" | \"warning\" | \"success\" = \"info\") => {\n427 |     setToastMessage(message);\n428 |     setToastType(type);\n429 |   };\n430 | \n431 |   // Close Toast automatically after 3.5 seconds\n432 |   useEffect(() => {\n433 |     if (toastMessage) {\n434 |       const timer = setTimeout(() => {\n435 |         setToastMessage(null);\n436 |         setToastType(null);\n437 |       }, 3500);\n438 |       return () => clearTimeout(timer);\n439 |     }\n440 |   }, [toastMessage]);\n441 | \n442 |   // Terminal Handshake Log Simulator inside Drawer\n443 |   useEffect(() => {\n444 |     if (!selectedDoc) {\n445 |       setTerminalLogs([]);\n446 |       return;\n447 |     }\n448 | \n449 |     setIsLogsSyncing(true);\n450 |     setTerminalLogs([\n451 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n452 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n453 |     ]);\n454 | \n455 |     const logsArray = [\n456 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n457 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n458 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n459 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n460 |     ];\n461 | \n462 |     let timerIndex = 0;\n463 |     const interval = setInterval(() => {\n464 |       if (timerIndex < logsArray.length) {\n465 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n466 |         timerIndex++;\n467 |       } else {\n468 |         setIsLogsSyncing(false);\n469 |         clearInterval(interval);\n470 |       }\n471 |     }, 450);\n472 | \n473 |     return () => clearInterval(interval);\n474 |   }, [selectedDoc]);\n475 | \n476 |   // Copy Clipboard Helper\n477 |   const handleCopyHash = (text: string) => {\n478 |     navigator.clipboard.writeText(text);\n479 |     setCopiedHash(true);\n480 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n481 |     setTimeout(() => setCopiedHash(false), 1500);\n482 |   };\n483 | \n484 |   // Reset Filters Helper\n485 |   const handleResetFilters = () => {\n486 |     setSearchQuery(\"\");\n487 |     setSelectedCategory(\"\");\n488 |     setSelectedProject(\"\");\n489 |     setSelectedFormat(\"\");\n490 |     setSelectedStatus(\"\");\n491 |     showToast(\"All filters reset successfully.\", \"info\");\n492 |   };\n493 | \n494 |   // Fetch Current User & Projects for uploading\n495 |   useEffect(() => {\n496 |     const fetchUserDataAndProjects = async () => {\n497 |       try {\n498 |         const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n499 |         if (!token) return;\n500 |         \n501 |         // Fetch user\n502 |         const meRes = await fetch(\"/api/v1/auth/me\", {\n503 |           headers: { \"Authorization\": `Bearer ${token}` }\n504 |         });\n505 |         if (meRes.ok) {\n506 |           const data = await meRes.json();\n507 |           if (data) {\n508 |             setCurrentClientId(data.client_id || null);\n509 |             setCurrentUserRole(data.role || null);\n510 |           }\n511 |         }\n512 | \n513 |         // Fetch projects\n514 |         const projRes = await fetch(\"/api/v1/projects\", {\n515 |           headers: { \"Authorization\": `Bearer ${token}` }\n516 |         });\n517 |         if (projRes.ok) {\n518 |           const data = await projRes.json();\n519 |           const projectsList = Array.isArray(data) ? data : (data.success && Array.isArray(data.projects) ? data.projects : []);\n520 |           setAvailableProjects(projectsList);\n521 |         }\n522 |       } catch (err) {\n523 |         console.error(\"Error fetching user data/projects:\", err);\n524 |       }\n525 |     };\n526 |     fetchUserDataAndProjects();\n527 |   }, []);\n528 | \n529 |   // Real secure download via API\n530 |   const handleRealDownload = async (doc: PortalDocument) => {\n531 |     try {\n532 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n533 |       if (!token) {\n534 |         showToast(\"Authentication token not found.\", \"warning\");\n535 |         return;\n536 |       }\n537 |       showToast(`Transferring certified copy: ${doc.name}...`, \"info\");\n538 |       \n539 |       const res = await fetch(`/api/v1/documents/download/${doc.id}`, {\n540 |         headers: {\n541 |           \"Authorization\": `Bearer ${token}`\n542 |         }\n543 |       });\n544 |       \n545 |       if (!res.ok) {\n546 |         throw new Error(`Download failed with status ${res.status}`);\n547 |       }\n548 |       \n549 |       const blob = await res.blob();\n550 |       const url = window.URL.createObjectURL(blob);\n551 |       const a = document.createElement(\"a\");\n552 |       a.href = url;\n553 |       a.download = doc.name;\n554 |       document.body.appendChild(a);\n555 |       a.click();\n556 |       a.remove();\n557 |       window.URL.revokeObjectURL(url);\n558 |       \n559 |       showToast(`Securely downloaded: ${doc.name}`, \"success\");\n560 |     } catch (err: any) {\n561 |       console.error(\"Error downloading document:\", err);\n562 |       showToast(`Download blocked: ${err.message}`, \"warning\");\n563 |     }\n564 |   };\n565 | \n566 |   // Real multipart upload\n567 |   const handleRealUpload = async (e: React.FormEvent) => {\n568 |     e.preventDefault();\n569 |     if (!uploadFile) {\n570 |       setUploadError(\"Please select a file to upload.\");\n571 |       return;\n572 |     }\n573 |     \n574 |     setUploading(true);\n575 |     setUploadError(null);\n576 |     \n577 |     try {\n578 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n579 |       if (!token) {\n580 |         throw new Error(\"Authentication token not found.\");\n581 |       }\n582 |       \n583 |       let targetClientId = currentClientId;\n584 |       if (!targetClientId) {\n585 |         const meRes = await fetch(\"/api/v1/auth/me\", {\n586 |           headers: { \"Authorization\": `Bearer ${token}` }\n587 |         });\n588 |         if (meRes.ok) {\n589 |           const meData = await meRes.json();\n590 |           targetClientId = meData.client_id;\n591 |         }\n592 |       }\n593 |       \n594 |       if (!targetClientId) {\n595 |         throw new Error(\"Could not resolve your client account assignment. Please contact support.\");\n596 |       }\n597 |       \n598 |       const formData = new FormData();\n599 |       formData.append(\"file\", uploadFile);\n600 |       formData.append(\"client_id\", String(targetClientId));\n601 |       if (uploadProjectId) {\n602 |         formData.append(\"project_id\", uploadProjectId);\n603 |       }\n604 |       formData.append(\"title\", uploadTitle || uploadFile.name);\n605 |       formData.append(\"document_type\", uploadCategory);\n606 |       formData.append(\"version\", uploadVersion);\n607 |       formData.append(\"visibility\", uploadVisibility);\n608 |       formData.append(\"description\", uploadDescription || \"Cryptographically secured enclave system documentation.\");\n609 |       \n610 |       const res = await fetch(\"/api/v1/documents/upload\", {\n611 |         method: \"POST\",\n612 |         headers: {\n613 |           \"Authorization\": `Bearer ${token}`\n614 |         },\n615 |         body: formData\n616 |       });\n617 |       \n618 |       if (!res.ok) {\n619 |         const errData = await res.json().catch(() => ({}));\n620 |         throw new Error(errData.detail || `Upload failed with status ${res.status}`);\n621 |       }\n622 |       \n623 |       const data = await res.json();\n624 |       if (data.success) {\n625 |         showToast(`Document uploaded and sealed: ${uploadFile.name}`, \"success\");\n626 |         setUploadFile(null);\n627 |         setUploadTitle(\"\");\n628 |         setUploadDescription(\"\");\n629 |         setUploadVersion(\"1.0.0\");\n630 |         setIsUploadModalOpen(false);\n631 |         fetchDocuments();\n632 |       } else {\n633 |         throw new Error(data.message || \"Failed to process document upload.\");\n634 |       }\n635 |     } catch (err: any) {\n636 |       console.error(\"Upload error:\", err);\n637 |       setUploadError(err.message || \"An unexpected error occurred during secure file transfer.\");\n638 |     } finally {\n639 |       setUploading(false);\n640 |     }\n641 |   };\n642 | \n643 |   // Simulated Actions\n644 |   const handleSimulatedDownload = (doc: PortalDocument) => {\n645 |     handleRealDownload(doc);\n646 |   };\n647 | \n648 |   const handleSimulatedUploadClick = () => {\n649 |     setIsUploadModalOpen(true);\n650 |   };\n651 | \n652 |   // Filtering Logic\n653 |   const filteredDocuments = documents.filter((doc) => {\n654 |     // 1. Text Search query (checks title, hash, id, owner)\n655 |     if (searchQuery.trim() !== \"\") {\n656 |       const query = searchQuery.toLowerCase();\n657 |       const matchText = \n658 |         doc.name.toLowerCase().includes(query) ||\n659 |         doc.id.toLowerCase().includes(query) ||\n660 |         doc.hash.toLowerCase().includes(query) ||\n661 |         doc.owner.toLowerCase().includes(query) ||\n662 |         doc.desc.toLowerCase().includes(query);\n663 |       if (!matchText) return false;\n664 |     }\n665 |     // 2. Category\n666 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n667 |     // 3. Related Project\n668 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n669 |     // 4. File Format (Type)\n670 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) return false;\n671 |     // 5. Status\n672 |     if (selectedStatus !== \"\" && doc.status !== selectedStatus) return false;\n673 | \n674 |     return true;\n675 |   });\n676 | \n677 |   // Calculate quick document statistics\n678 |   const totalSeals = documents.length;\n679 |   const activeSows = documents.filter(d => d.category === \"SOW\").length;\n680 |   const auditReports = documents.filter(d => d.category === \"Reports\" || d.category === \"Architecture\").length;\n681 |   const pendingReviews = documents.filter(d => d.status === \"Pending Review\" || d.status === \"In Review\").length;\n682 | \n683 |   const getStatusColor = (status: string) => {\n684 |     const s = status.toLowerCase();\n685 |     if (s === \"approved\" || s === \"signed\" || s === \"active\") return \"text-[#00FFC2] border-[#00FFC2]/20 bg-[#00FFC2]/5\";\n686 |     if (s === \"in review\" || s === \"pending review\") return \"text-amber-400 border-amber-400/20 bg-amber-400/5\";\n687 |     return \"text-white/40 border-white/10 bg-white/5\";\n688 |   };\n689 | \n690 |   const getFormatBadgeColor = (fmt: string) => {\n691 |     const f = fmt.toLowerCase();\n692 |     if (f === \"pdf\") return \"text-red-400 border-red-500/20 bg-red-500/5\";\n693 |     if (f === \"yaml\" || f === \"json\") return \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\";\n694 |     if (f === \"zip\") return \"text-indigo-400 border-indigo-500/20 bg-indigo-500/5\";\n695 |     return \"text-white/60 border-white/10 bg-white/5\";\n696 |   };\n697 | \n698 |   const hasActiveFilters = searchQuery !== \"\" || selectedCategory !== \"\" || selectedProject !== \"\" || selectedFormat !== \"\" || selectedStatus !== \"\";\n699 | \n700 |   return (\n701 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none relative\">\n702 |       \n703 |       {/* 1. TOAST NOTIFICATION WINDOW 