based on name keywords\n222 |   let category: any = \"Reports\";\n223 |   const titleLower = (apiDoc.title || apiDoc.name || \"\").toLowerCase();\n224 |   if (titleLower.includes(\"proposal\")) {\n225 |     category = \"Proposals\";\n226 |   } else if (titleLower.includes(\"sow\") || titleLower.includes(\"statement of work\") || titleLower.includes(\"contract\")) {\n227 |     category = \"SOW\";\n228 |   } else if (titleLower.includes(\"blueprint\") || titleLower.includes(\"architecture\") || titleLower.includes(\"topology\")) {\n229 |     category = \"Architecture\";\n230 |   } else if (titleLower.includes(\"ruleset\") || titleLower.includes(\"governance\") || titleLower.includes(\"directive\") || titleLower.includes(\"compliance\")) {\n231 |     category = \"Governance\";\n232 |   } else if (titleLower.includes(\"audit\") || titleLower.includes(\"report\")) {\n233 |     category = \"Reports\";\n234 |   } else if (titleLower.includes(\"invoice\") || titleLower.includes(\"billing\")) {\n235 |     category = \"Invoices\";\n236 |   } else if (titleLower.includes(\"meeting\") || titleLower.includes(\"notes\")) {\n237 |     category = \"Meeting Notes\";\n238 |   } else if (apiDoc.type === \"ZIP\" || titleLower.includes(\"asset\") || titleLower.includes(\"config\")) {\n239 |     category = \"Delivery Assets\";\n240 |   }\n241 | \n242 |   // Map status\n243 |   let status: any = \"Approved\";\n244 |   if (apiDoc.status === \"Verified\") {\n245 |     status = \"Approved\";\n246 |   } else if (apiDoc.status === \"Under Review\") {\n247 |     status = \"In Review\";\n248 |   } else if (apiDoc.status === \"Action Required\") {\n249 |     status = \"Pending Review\";\n250 |   } else if (apiDoc.status === \"Superseded\") {\n251 |     status = \"Archived\";\n252 |   } else {\n253 |     status = apiDoc.status || \"Approved\";\n254 |   }\n255 | \n256 |   return {\n257 |     id: apiDoc.id,\n258 |     name: apiDoc.title || apiDoc.name,\n259 |     category: category,\n260 |     format: format,\n261 |     size: apiDoc.fileSize || \"1.0 MB\",\n262 |     hash: apiDoc.sha256 || \"0xHASH\",\n263 |     uploadedAt: apiDoc.lastUpdated || new Date().toISOString(),\n264 |     project: apiDoc.client_name || \"Global Platform (No Project)\",\n265 |     status: status,\n266 |     version: apiDoc.version || \"v1.0\",\n267 |     owner: apiDoc.owner || \"Dr. Sarah Vance\",\n268 |     visibility: apiDoc.client_id === \"client-001\" ? \"LEVEL_IV (Restricted)\" : \"LEVEL_I (Client View)\",\n269 |     desc: apiDoc.description || apiDoc.desc || \"Cryptographically secured enclave system documentation.\"\n270 |   };\n271 | }\n272 | \n273 | \n274 | function DocumentsSkeleton() {\n275 |   return (\n276 |     <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n277 |       {[1, 2, 3, 4, 5, 6].map((n) => (\n278 |         <WorkspaceCard key={n} className=\"flex flex-col h-[280px] justify-between border-white/[0.03] bg-[#050505]/20 p-5 rounded-2xl relative animate-pulse\">\n279 |           <div className=\"space-y-3\">\n280 |             <div className=\"flex justify-between items-start\">\n281 |               <div className=\"flex items-center gap-2\">\n282 |                 <div className=\"h-4 bg-white/5 rounded w-16 animate-pulse\" />\n283 |                 <div className=\"h-4 bg-white/5 rounded w-12 animate-pulse\" />\n284 |               </div>\n285 |               <div className=\"h-4 bg-white/5 rounded w-10 animate-pulse\" />\n286 |             </div>\n287 |             <div className=\"space-y-2 pt-2\">\n288 |               <div className=\"h-5 bg-white/5 rounded w-5/6 animate-pulse\" />\n289 |               <div className=\"h-3 bg-white/5 rounded w-full animate-pulse\" />\n290 |               <div className=\"h-3 bg-white/5 rounded w-4/5 animate-pulse\" />\n291 |             </div>\n292 |           </div>\n293 |           <div className=\"border-t border-white/5 pt-3 mt-4 space-y-3\">\n294 |             <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/35\">\n295 |               <div className=\"h-3 bg-white/5 rounded w-12 animate-pulse\" />\n296 |               <div className=\"h-3 bg-white/5 rounded w-12 ml-auto animate-pulse\" />\n297 |             </div>\n298 |             <div className=\"grid grid-cols-2 gap-2 pt-1\">\n299 |               <div className=\"h-8 bg-white/5 rounded animate-pulse\" />\n300 |               <div className=\"h-8 bg-white/5 rounded animate-pulse\" />\n301 |             </div>\n302 |           </div>\n303 |         </WorkspaceCard>\n304 |       ))}\n305 |     </div>\n306 |   );\n307 | }\n308 | \n309 | function DocumentsErrorState({ message, onRetry }: { message: string; onRetry: () => void }) {\n310 |   return (\n311 |     <div className=\"p-12 text-center rounded-2xl border border-red-500/10 bg-red-950/5 backdrop-blur-sm max-w-xl mx-auto space-y-4\">\n312 |       <div className=\"p-4 rounded-full bg-red-500/10 border border-red-500/20 inline-flex text-red-400\">\n313 |         <Shield className=\"w-8 h-8\" />\n314 |       </div>\n315 |       <div className=\"space-y-1\">\n316 |         <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">HSM Verification Failed</h3>\n317 |         <p className=\"text-[12.5px] text-white/50 max-w-sm mx-auto font-sans leading-relaxed\">\n318 |           {message}\n319 |         </p>\n320 |       </div>\n321 |       <button \n322 |         onClick={onRetry}\n323 |         className=\"h-9 px-4 rounded-lg bg-red-600 hover:bg-red-500 text-[11px] font-mono font-bold uppercase text-white transition-all cursor-pointer shadow-[0_0_15px_rgba(239,68,68,0.2)] inline-flex items-center gap-1.5\"\n324 |       >\n325 |         <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n326 |         <span>RETRY VERIFICATION</span>\n327 |       </button>\n328 |     </div>\n329 |   );\n330 | }\n331 | \n332 | export default function ClientDocumentsPage() {\n333 |   const router = useRouter();\n334 | \n335 |   // Dynamic API Fetching States\n336 |   const [documents, setDocuments] = useState<PortalDocument[]>([]);\n337 |   const [loading, setLoading] = useState(true);\n338 |   const [error, setError] = useState<string | null>(null);\n339 | \n340 |   // User Profile & Scoped client ID\n341 |   const [currentClientId, setCurrentClientId] = useState<number | null>(null);\n342 |   const [currentUserRole, setCurrentUserRole] = useState<string | null>(null);\n343 |   const [availableProjects, setAvailableProjects] = useState<any[]>([]);\n344 | \n345 |   // Real upload modal state variables\n346 |   const [isUploadModalOpen, setIsUploadModalOpen] = useState(false);\n347 |   const [uploadFile, setUploadFile] = useState<File | null>(null);\n348 |   const [uploadTitle, setUploadTitle] = useState(\"\");\n349 |   const [uploadCategory, setUploadCategory] = useState(\"Reports\");\n350 |   const [uploadProjectId, setUploadProjectId] = useState<string>(\"\");\n351 |   const [uploadVersion, setUploadVersion] = useState(\"1.0.0\");\n352 |   const [uploadVisibility, setUploadVisibility] = useState(\"private\");\n353 |   const [uploadDescription, setUploadDescription] = useState(\"\");\n354 |   const [uploading, setUploading] = useState(false);\n355 |   const [uploadError, setUploadError] = useState<string | null>(null);\n356 | \n357 |   // Filter States\n358 |   const [searchQuery, setSearchQuery] = useState(\"\");\n359 |   const [selectedCategory, setSelectedCategory] = useState(\"\");\n360 |   const [selectedProject, setSelectedProject] = useState(\"\");\n361 |   const [selectedFormat, setSelectedFormat] = useState(\"\");\n362 |   const [selectedStatus, setSelectedStatus] = useState(\"\");\n363 |   \n364 |   const fetchDocuments = useCallback(async () => {\n365 |     setLoading(true);\n366 |     setError(null);\n367 |     try {\n368 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n369 |       if (!token) {\n370 |         setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n371 |         router.push(\"/portal/login\");\n372 |         return;\n373 |       }\n374 | \n375 |       const res = await fetch(\"/api/v1/documents\", {\n376 |         headers: {\n377 |           \"Authorization\": `Bearer ${token}`,\n378 |           \"Content-Type\": \"application/json\"\n379 |         }\n380 |       });\n381 | \n382 |       if (!res.ok) {\n383 |         throw new Error(`Enclave sync failed with status ${res.status}`);\n384 |       }\n385 | \n386 |       const data = await res.json();\n387 |       let docArray = null;\n388 |       if (Array.isArray(data)) {\n389 |         docArray = data;\n390 |       } else if (data && data.success && Array.isArray(data.documents)) {\n391 |         docArray = data.documents;\n392 |       }\n393 | \n394 |       if (docArray) {\n395 |         const mapped = docArray.map((d: any) => mapApiDocToPortalDoc(d));\n396 |         setDocuments(mapped);\n397 |       } else {\n398 |         throw new Error(\"Handshake returned malformed enclave register.\");\n399 |       }\n400 |     } catch (err: any) {\n401 |       console.error(\"Error fetching documents:\", err);\n402 |       setError(err.message || \"Decentralized ledger handshake timed out.\");\n403 |     } finally {\n404 |       setLoading(false);\n405 |     }\n406 |   }, [router]);\n407 | \n408 |   useEffect(() => {\n409 |     fetchDocuments();\n410 |   }, [fetchDocuments]);\n411 | \n412 |   // Layout States\n413 |   const [layoutMode, setLayoutMode] = useState<\"grid\" | \"list\">(\"grid\");\n414 | \n415 |   // Drawer & Attestation Log States\n416 |   const [selectedDoc, setSelectedDoc] = useState<PortalDocument | null>(null);\n417 |   const [terminalLogs, setTerminalLogs] = useState<string[]>([]);\n418 |   const [isLogsSyncing, setIsLogsSyncing] = useState(false);\n419 |   const [copiedHash, setCopiedHash] = useState(false);\n420 | \n421 |   // Custom Toast Notification States\n422 |   const [toastMessage, setToastMessage] = useState<string | null>(null);\n423 |   const [toastType, setToastType] = useState<\"info\" | \"warning\" | \"success\" | null>(null);\n424 | \n425 |   // Trigger Toast Helper\n426 |   const showToast = (message: string, type: \"info\" | \"warning\" | \"success\" = \"info\") => {\n427 |     setToastMessage(message);\n428 |     setToastType(type);\n429 |   };\n430 | \n431 |   // Close Toast automatically after 3.5 seconds\n432 |   useEffect(() => {\n433 |     if (toastMessage) {\n434 |       const timer = setTimeout(() => {\n435 |         setToastMessage(null);\n436 |         setToastType(null);\n437 |       }, 3500);\n438 |       return () => clearTimeout(timer);\n439 |     }\n440 |   }, [toastMessage]);\n441 | \n442 |   // Terminal Handshake Log Simulator inside Drawer\n443 |   useEffect(() => {\n444 |     if (!selectedDoc) {\n445 |       setTerminalLogs([]);\n446 |       return;\n447 |     }\n448 | \n449 |     setIsLogsSyncing(true);\n450 |     setTerminalLogs([\n451 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n452 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n453 |     ]);\n454 | \n455 |     const logsArray = [\n456 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n457 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n458 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n459 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n460 |     ];\n461 | \n462 |     let timerIndex = 0;\n463 |     const interval = setInterval(() => {\n464 |       if (timerIndex < logsArray.length) {\n465 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n466 |         timerIndex++;\n467 |       } else {\n468 |         setIsLogsSyncing(false);\n469 |         clearInterval(interval);\n470 |       }\n471 |     }, 450);\n472 | \n473 |     return () => clearInterval(interval);\n474 |   }, [selectedDoc]);\n475 | \n476 |   // Copy Clipboard Helper\n477 |   const handleCopyHash = (text: string) => {\n478 |     navigator.clipboard.writeText(text);\n479 |     setCopiedHash(true);\n480 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n481 |     setTimeout(() => setCopiedHash(false), 1500);\n482 |   };\n483 | \n484 |   // Reset Filters Helper\n485 |   const handleResetFilters = () => {\n486 |     setSearchQuery(\"\");\n487 |     setSelectedCategory(\"\");\n488 |     setSelectedProject(\"\");\n489 |     setSelectedFormat(\"\");\n490 |     setSelectedStatus(\"\");\n491 |     showToast(\"All filters reset successfully.\", \"info\");\n492 |   };\n493 | \n494 |   // Fetch Current User & Projects for uploading\n495 |   useEffect(() => {\n496 |     const fetchUserDataAndProjects = async () => {\n497 |       try {\n498 |         const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n499 |         if (!token) return;\n500 |         ","success":true}],"durationMs":3}}
