         <div className=\"grid grid-cols-2 gap-3\">\n591 |                 <div className=\"space-y-0.5\">\n592 |                   <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">Category</span>\n593 |                   <select value={newCategory} onChange={(e) => setNewCategory(e.target.value as Ticket[\"category\"])} className=\"h-8 w-full rounded border border-white/5 bg-[#0c0c0e] px-2 text-[10px] text-white outline-none cursor-pointer\">\n594 |                     {AVAILABLE_CATEGORIES.map((cat) => <option key={cat} value={cat}>{cat.toUpperCase()}</option>)}\n595 |                   </select>\n596 |                 </div>\n597 |                 <div className=\"space-y-0.5\">\n598 |                   <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">Lead engineer</span>\n599 |                   <select value={newAgent} onChange={(e) => setNewAgent(e.target.value)} className=\"h-8 w-full rounded border border-white/5 bg-[#0c0c0e] px-2 text-[10px] text-white outline-none cursor-pointer\">\n600 |                     {AVAILABLE_AGENTS.map((a) => <option key={a} value={a}>{a.toUpperCase()}</option>)}\n601 |                   </select>\n602 |                 </div>\n603 |               </div>\n604 |               <div className=\"grid grid-cols-2 gap-3\">\n605 |                 <div className=\"space-y-0.5\">\n606 |                   <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">SLA limit (Hours)</span>\n607 |                   <input type=\"number\" min=\"1\" max=\"168\" value={newSlaHours} onChange={(e) => setNewSlaHours(e.target.value)} className=\"w-full h-8 rounded border border-white/5 bg-white/[0.01] px-2.5 text-[11px] text-white outline-none focus:border-[#009DFF]/40\" />\n608 |                 </div>\n609 |                 <div className=\"space-y-0.5\">\n610 |                   <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">Link project</span>\n611 |                   <select value={newProject} onChange={(e) => setNewProject(e.target.value)} className=\"h-8 w-full rounded border border-white/5 bg-[#0c0c0e] px-2 text-[10px] text-white outline-none cursor-pointer\">\n612 |                     <option value=\"None\">NONE / UNASSIGNED</option>\n613 |                     {MOCK_PROJECTS.map((p) => <option key={p.id} value={p.id}>{p.id} - {p.name.substring(0, 20)}...</option>)}\n614 |                   </select>\n615 |                 </div>\n616 |               </div>\n617 |               <div className=\"space-y-0.5\">\n618 |                 <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">Link document</span>\n619 |                 <select value={newDoc} onChange={(e) => setNewDoc(e.target.value)} className=\"h-8 w-full rounded border border-white/5 bg-[#0c0c0e] px-2 text-[10px] text-white outline-none cursor-pointer\">\n620 |                   <option value=\"None\">NONE / UNASSIGNED</option>\n621 |                   {MOCK_DOCUMENTS.map((d) => <option key={d.id} value={d.id}>{d.id} - {d.title.substring(0, 25)}...</option>)}\n622 |                 </select>\n623 |               </div>\n624 |               <div className=\"space-y-0.5\">\n625 |                 <span className=\"text-[8.5px] text-white/30 uppercase block font-semibold\">Problem description</span>\n626 |                 <textarea required rows={3} placeholder=\"Describe the system problem context...\" value={newDescription} onChange={(e) => setNewDescription(e.target.value)} className=\"w-full rounded border border-white/5 bg-white/[0.01] p-2 text-[11px] text-white placeholder-white/30 outline-none focus:border-[#009DFF]/40 resize-none\" />\n627 |               </div>\n628 |               <div className=\"flex gap-2 pt-2\">\n629 |                 <button type=\"submit\" className=\"flex-grow h-8 rounded bg-[#009DFF] hover:bg-[#0082d4] text-white font-bold uppercase transition-all flex items-center justify-center gap-1 cursor-pointer font-mono text-[10px]\">\n630 |                   <CheckCircle className=\"w-3.5 h-3.5\" /><span>Provision Wire</span>\n631 |                 </button>\n632 |                 <button type=\"button\" onClick={() => setIsNewModalOpen(false)} className=\"px-3 h-8 rounded border border-white/10 text-white font-bold uppercase transition-all cursor-pointer font-mono\">Cancel</button>\n633 |               </div>\n634 |             </form>\n635 |           </div>\n636 |         </div>\n637 |       )}\n638 |     </div>\n639 |   );\n640 | }","success":true}],"durationMs":8}}
