e outline-none cursor-pointer\">\n545 |                     <option value=\"OPEN\">OPEN</option>\n546 |                     <option value=\"INVESTIGATING\">INVESTIGATING</option>\n547 |                     <option value=\"HOLD\">ON HOLD</option>\n548 |                     <option value=\"RESOLVED\">RESOLVED</option>\n549 |                   </select>\n550 |                 </div>\n551 |               </div>\n552 |               <div className=\"flex gap-2 pt-1.5\">\n553 |                 <button onClick={() => handleUpdateStatus(selectedTicket.id, \"RESOLVED\")} disabled={selectedTicket.status === \"RESOLVED\"} className=\"flex-grow h-8 rounded bg-emerald-600 hover:bg-emerald-500 text-white font-bold uppercase transition-all disabled:opacity-45 cursor-pointer\">Resolve wire</button>\n554 |                 <button onClick={() => setSelectedTicketId(null)} className=\"px-3 h-8 rounded border border-white/10 text-white hover:bg-white/[0.02] transition-all cursor-pointer font-bold uppercase\">Close</button>\n555 |               </div>\n556 |             </div>\n557 |           </div>\n558 |         </>\n559 |       )}\n560 | \n561 |       {isNewModalOpen && (\n562 |         <div className=\"fixed inset-0 bg-black/80 backdrop-blur-sm z-50 flex items-center justify-center p-4\">\n563 |           <div className=\"relative max-w-md w-full bg-[#070708] border border-white/10 rounded-xl p-5 shadow-2xl space-y-4\">\n564 |             <button onClick={() => setIsNewModalOpen(false)} className=\"absolute right-4 top-4 text-white/40 hover:text-white cursor-pointer\"><X className=\"w-5 h-5\" /></button>\n565 |             <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n566 |               <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n567 |               <h3 className=\"text-xs font-bold text-white uppercase font-mono\">Provision SLA Support wire</h3>\n568 |             </div>\n569 |             <form onSubmit={handleCreateTicket} className=\"space-