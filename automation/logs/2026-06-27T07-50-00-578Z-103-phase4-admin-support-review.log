${t.status === \"RESOLVED\" ? \"bg-emerald-500\" : \"bg-amber-400 animate-pulse\"}`} />\n402 |                     <span className=\"text-[10px] font-bold uppercase\">{t.status}</span>\n403 |                   </span>\n404 |                 </td>\n405 |                 <td className=\"py-3 px-4 text-white/80\">{t.assignedAgent}</td>\n406 |                 <td className=\"py-3 px-4\">\n407 |                   <div className=\"flex gap-1.5 text-white/40\">\n408 |                     {t.linkedProjectId !== \"None\" && <Folder className=\"w-3.5 h-3.5 text-[#00FFC2]\" />}\n409 |                     {t.linkedDocId !== \"None\" && <FileText className=\"w-3.5 h-3.5 text-amber-400\" />}\n410 |                   </div>\n411 |                 </td>\n412 |                 <td className=\"py-3 px-4 text-right font-bold\">\n413 |                   <span className={t.status === \"RESOLVED\" ? \"text-emerald-400\" : t.slaSeconds <= 0 ? \"text-red-500 font-extrabold animate-pulse\" : \"text-amber-400\"}>\n414 |                     {formatSla(t.slaSeconds, t.status)}\n415 |                   </span>\n416 |                 </td>\n417 |               </tr>\n418 |             ))}\n419 |           </tbody>\n420 |         </table>\n421 |       </div>\n422 | \n423 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 md:hidden\">\n424 |         {filteredTickets.map((t) => (\n425 |           <div key={t.id} onClick={() => setSelectedTicketId(t.id)} className={`border rounded-xl p-4 space-y-3 bg-[#050505]/40 backdrop-blur-sm cursor-pointer ${selectedTicketId === t.id ? \"border-[#009DFF]\" : \"border-white/5\"}`}>\n426 |             <div className=\"flex justify-between\">\n427 |               <span className=\"text-[#009DFF] font-bold font-mono text-[11px]\">{t.id}</span>\n428 |               <span className=\"text-white/40 font-mono text-[9px] uppercase\">{t.category}</span>\n429 |             </div>\n430 |             <h4 className=\"text-white font-semibold text-xs leading-snug\">{t.subject}</h4>\n431 |             <div className=\"flex justify-between items-center pt-2 border-t border-white/5 font-mono text-[10px] text-white/50\">\n432 |               <span>SLA TIMER:</span>\n433 |               <span className={t.status === \"RESOLVED\" ? \"text-emerald-400 font-bold\" : \"text-amber-400 font-bold\"}>{formatSla(t.slaSeconds, t.status)}</span>\n434 |             </div>\n435 |           </div>\n436 |         ))}\n437 |       </div>\n438 | \n439 |       {selectedTicket && (\n440 |         <>\n441 |           <div onClick={() => setSelectedTicketId(null)} className=\"fixed inset-0 bg-black/60 backdrop-blur-sm z-40 transition-all\" />\n442 |           <div className=\"fixed inset-y-0 right-0 z-50 w-full sm:w-[500px] md:w-[600px] bg-[#070708] border-l border-white/10 shadow-2xl p-6 overflow-y-auto flex flex-col justify-between\">\n443 |             <div className=\"space-y-5\">\n444 |               <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n445 |                 <div>\n446 |                   <span className=\"text-[10px] font-mono text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded font-bold\">{selectedTicket.id}</span>\n447 |                   <h3 className=\"text-sm font-bold text-white mt-2 leading-snug\">{selectedTicket.subject}</h3>\n448 |                   <p className=\"text-[9.5px] font-mono text-white/40 uppercase mt-1\">CLIENT: {selectedTicket.client}</p>\n449 |                 </div>\n450 |                 <button onClick={() => setSelectedTicketId(null)} className=\"p-1 hover:bg-white/5 rounded text-white/40 cursor-pointer\"><X className=\"w-5 h-5\" /></button>\n451 |               </div>\n452 | \n453 |               <div className=\"flex border-b border-white/5 font-mono text-[9.5px] select-none\">\n454 |                 <button onClick={() => setDrawerTab(\"wire\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"wire\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n455 |                   <MessageSquare className=\"w-3.5 h-3.5\" /><span>Secure wire</span>\n456 |                 </button>\n457 |                 <button onClick={() => setDrawerTab(\"assets\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"assets\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n458 |                   <Folder className=\"w-3.5 h-3.5\" /><span>Sovereign assets</span>\n459 |                 </button>\n460 |                 <button onClick={() => setDrawerTab(\"diagnostic\")} className={`px-3 py-2 border-b-2 font-bold uppercase flex items-center gap-1 ${drawerTab === \"diagnostic\" ? \"border-[#009DFF] text-[#009DFF]\" : \"border-transparent text-white/40\"}`}>\n461 |                   <Terminal className=\"w-3.5 h-3.5\" /><span>Diagnostics</span>\n462 |                 </button>\n463 |               </div>\n464 | \n465 |               {drawerTab === \"wire\" && (\n466 |                 <div className=\"space-y-4 font-mono\">\n467 |                   <div className=\"border border-emerald-500/10 rounded-lg bg-emerald-500/[0.01] p-2.5 text-[10.5px] text-emerald-400 flex gap-1.5\">\n468 |                     <Shield className=\"w-4 h-4 shrink-0 mt-0.5\" />\n469 |                     <span>Cryptographic Dual-Layer handshake verified. Communications airgapped.</span>\n470 |                   </div>\n471 |                   <div className=\"border border-white/5 rounded-lg bg-black/40 p-3 h-[240px] overflow-y-auto space-y-2 text-[10.5px] flex flex-col\">\n472 |                     {selectedTicket.wireFeed.map((f) => (\n473 |                       <div key={f.id} className={`max-w-[85%] rounded p-2 space-y-0.5 ${f.sender === \"system\" ? \"self-stretch bg-white/[0.01] text-white/35 border-b border-white/[0.02]\" : f.sender === \"agent\" ? \"self-end bg-[#009DFF]/10 text-white border border-[#009DFF]/20\" : \"self-start bg-white/[0.02] text-white/90\"}`}>\n474 |                         <div className=\"flex justify-between text-[8px] opacity-40\">\n475 |                           <span>{f.senderName.toUpperCase()}</span>\n476 |                           <span>{f.timestamp}</span>\n477 |                         </div>\n478 |                         <p className=\"whitespace-pre-wrap\">{f.text}</p>\n479 |                       </div>\n480 |                     ))}\n481 |                     <div ref={chatEndRef} />\n482 |                   </div>\n483 |                   <form onSubmit={handleSendMessage} className=\"flex gap-2\">\n484 |                     <input type=\"text\" value={chatInput} onChange={(e) => setChatInput(e.target.value)} placeholder=\"Type secure message...\" className=\"flex-grow h-9 rounded border border-white/5 bg-white/[0.01] px-3 text-[11px] font-mono text-white placeholder-white/30 outline-none\" />\n485 |                     <button type=\"submit\" disabled={!chatInput.trim()} className=\"h-9 px-3 rounded bg-[#009DFF] text-white cursor-pointer hover:bg-[#0082d4] disabled:opacity-40\"><Send className=\"w-3.5 h-3.5\" /></button>\n486 |                   </form>\n487 |                 </div>\n488 |               )}\n489 | \n490 |               {drawerTab === \"assets\" && (\n491 |                 <div className=\"space-y-4 font-mono text-[11px]\">\n492 |                   <div>\n493 |                     <h4 className=\"text-[9.5px] text-white/30 uppercase font-semibold mb-1\">Project Sandbox Details</h4>\n494 |                     {connectedProject ? (\n495 |                       <div className=\"border border-white/5 bg-[#020202]/50 p-3 rounded-lg space-y-2\">\n496 |                         <div className=\"flex justify-between\"><span className=\"font-bold text-[#00FFC2]\">{connectedProject.id}</span><span>{connectedProject.enclaveType}</span></div>\n497 |                         <h5 className=\"text-white font-semibold\">{connectedProject.name}</h5>\n498 |                         <div className=\"text-[10px] text-white/40\">Status: {connectedProject.status} | Phase: {connectedProject.phase}</div>\n499 |                       </div>\n500 |                     ) : <p className=\"text-white/30 text-[10px]\">No integration project linked.</p>}\n501 |                   </div>\n502 |                   <div>\n503 |                     <h4 className=\"text-[9.5px] text-white/30 uppercase font-semibold mb-1\">Compliance Reference Docs</h4>\n504 |                     {connectedDoc ? (\n505 |                       <div className=\"border border-white/5 bg-[#020202]/50 p-3 rounded-lg space-y-2\">\n506 |                         <div className=\"flex justify-between\"><span className=\"font-bold text-amber-400\">{connectedDoc.id}</span><span>{connectedDoc.type}</span></div>\n507 |                         <h5 className=\"text-white font-semibold\">{connectedDoc.title}</h5>\n508 |                         <div className=\"text-[9px] text-[#00FFC2] truncate\">{connectedDoc.sha256}</div>\n509 |                       </div>\n510 |                     ) : <p className=\"text-white/30 text-[10px]\">No compliance document linked.</p>}\n511 |                   </div>\n512 |                 </div>\n513 |               )}\n514 | \n515 |               {drawerTab === \"diagnostic\" && (\n516 |                 <div className=\"space-y-4 font-mono text-[10.5px]\">\n517 |                   <div className=\"border border-white/5 rounded-lg p-3 bg-black/20\">\n518 |                     <span className=\"text-[9px] text-white/30 uppercase block font-semibold mb-1\">Specification description</span>\n519 |                     <p className=\"text-white/80 leading-relaxed\">{selectedTicket.description}</p>\n520 |                   </div>\n521 |                   <div className=\"space-y-1.5\">\n522 |                     <span className=\"text-[9px] text-white/30 uppercase font-semibold block\">Enclave Audit Metadata</span