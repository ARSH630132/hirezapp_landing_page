.value)}\n                      className=\"bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-[12px] text-white focus:outline-none focus:border-[#009DFF] flex-grow transition-colors\"\n                    />\n                    <button type=\"submit\" className=\"bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-90 active:scale-[0.98] transition-all text-white text-[12px] font-bold px-3 py-1.5 rounded-lg shrink-0\">\n                      Subscribe\n                    </button>\n                  </form>\n                )}\n              </div>\n            </div>\n\n            <div className=\"flex items-center gap-2 mt-6\">\n              {socialIcons.map((icon) => (\n                <button key={icon.alt} type=\"button\" aria-label={icon.alt} className=\"group inline-flex h-8 w-8 items-center justify-center transition-all duration-300 hover:-translate-y-0.5 active:scale-95\">\n                  <img src={icon.src} alt={icon.alt} className=\"h-4.5 w-4.5 object-contain brightness-0 invert transition-transform duration-300 group-hover:scale-110\" />\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {footerColumns.map((col) => (\n            <div key={col.title} className=\"flex flex-col\">\n              <h3 className=\"text-white text-[16px] font-semibold tracking-tight\">{col.title}</h3>\n              <div className=\"mt-[6px] h-[1px] w-[60px]\" style={{ background: \"linear-gradient(270deg, #000000 49.66%, #FF0004 100%)\" }} />\n              <div className=\"mt-4 space-y-[10px] text-[13px]\">\n                {col.items.map((item) => (\n                  <Link key={item.name} href={item.href} className=\"block text-white/60 hover:text-[#009DFF] transition-colors font-light\">\n                    {item.name}\n                  </Link>\n                ))}\n              </div>\n            </div>\n          ))}\n\n          <div className=\"flex flex-col\">\n            <h3 className=\"text-white text-[16px] font-semibold tracking-tight\">Contact</h3>\n            <div className=\"mt-[6px] h-[1px] w-[60px]\" style={{ background: \"linear-gradient(270deg, #000000 49.66%, #FF0004 100%)\" }} />\n            <div className=\"mt-4 space-y-4 text-white/60 text-[13px] font-light\">\n              <p className=\"flex items-center gap-2\">\n                <MdEmail className=\"text-[#009DFF] text-[15px] shrink-0\" />\n                <a href=\"mailto:contact@gff.ai\" className=\"hover:text-white transition-colors\">contact@gff.ai</a>\n              </p>\n              <p className=\"flex items-center gap-2\">\n                <FaPhone className=\"text-[#009DFF] text-[13px] shrink-0\" />\n                <span>+1 (800) 555-GFF-AI</span>\n              </p>\n              <div className=\"pt-2\">\n                <span className=\"text-[9px] font-bold tracking-widest text-white/30 uppercase block\">Global Hub</span>\n                <span className=\"text-[12px] text-white/50 block mt-0.5\">Remote-first Enterprise Core</span>\n              </div>\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      <div className=\"border-t border-white/5 py-4 text-center text-white/40 text-[11.5px] font-light\">\n        © 2026 GFF AI. All Rights Reserved. Enterprise Grade Artificial Intelligence.\n      </div>\n    </footer>\n  );\n}"}}}
