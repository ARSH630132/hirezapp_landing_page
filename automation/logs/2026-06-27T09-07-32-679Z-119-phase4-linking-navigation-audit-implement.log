ame=\"truncate text-left\">\n636 |                                 <span className={`font-bold block tracking-wider ${isSel ? \"text-white\" : \"text-zinc-300 group-hover:text-zinc-200\"}`}>{r.label}</span>\n637 |                                 <span className=\"text-[9px] text-zinc-500 font-sans block truncate group-hover:text-zinc-400\">{r.desc}</span>\n638 |                               </div>\n639 |                             </div>\n640 |                             <span className={`text-[8px] font-bold border rounded px-1.5 py-0.5 shrink-0 font-mono tracking-widest ${\n641 |                               isSel \n642 |                                 ? \"border-[#009DFF]/30 text-[#009DFF] bg-[#009DFF]/5\" \n643 |                                 : \"border-zinc-800 text-zinc-500\"\n644 |                             }`}>\n645 |                               {r.clearance}\n646 |                             </span>\n647 |                           </button>\n648 |                         );\n649 |                       })}\n650 |                     </div>\n651 |                   </div>\n652 | \n653 |                   <div className=\"pt-4 border-t border-zinc-900 space-y-2.5\">\n654 |                     <div className=\"flex items-center justify-between text-[8.5px] font-bold text-zinc-400 uppercase tracking-widest font-mono\">\n655 |                       <span className=\"flex items-center gap-1.5\"><Network className=\"w-3 h-3 text-[#009DFF]\" /> Sovereign Access Matrix</span>\n656 |                       <span className=\"text-[8px] text-zinc-500 font-bold\">DYNAMIC ROLE BOUNDARIES</span>\n657 |                     </div>\n658 |                     \n659 |                     <div className=\"grid grid-cols-2 md:grid-cols-4 gap-1.5\">\n660 |                       {matrixModules.slice(0, 4).map((mod) => {\n661 |                         const perm = getPermissionStatus(selectedRole, mod);\n662 |                         return (\n663 |                     