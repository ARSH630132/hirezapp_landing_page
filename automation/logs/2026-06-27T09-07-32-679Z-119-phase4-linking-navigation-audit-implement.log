        </div>\n392 | \n393 |                   <form onSubmit={handleSubmit} className=\"space-y-4\">\n394 |                     <div className=\"space-y-1.5\">\n395 |                       <label htmlFor=\"auth-email\" className=\"text-[9.5px] font-mono text-zinc-400 uppercase tracking-widest block font-bold\">\n396 |                         Enterprise Email Address\n397 |                       </label>\n398 |                       <input\n399 |                         id=\"auth-email\"\n400 |                         type=\"email\"\n401 |                         value={email}\n402 |                         onChange={(e) => handleInputChange(\"email\", e.target.value)}\n403 |                         placeholder=\"employee@gff.ai\"\n404 |                         className=\"w-full h-10 px-3 rounded-lg bg-zinc-950/80 border border-zinc-800 focus:border-[#009DFF] focus:ring-1 focus:ring-[#009DFF] text-zinc-200 text-xs placeholder-zinc-700 transition-all outline-none font-mono focus:bg-zinc-950\"\n405 |                         required\n406 |                       />\n407 |                     </div>\n408 | \n409 |                     {authMethod === \"credentials\" ? (\n410 |                       <div className=\"space-y-1.5\">\n411 |                         <div className=\"flex justify-between items-center\">\n412 |                           <label htmlFor=\"auth-pass\" className=\"text-[9.5px] font-mono text-zinc-400 uppercase tracking-widest block font-bold\">\n413 |                             Passphrase Key\n414 |                           </label>\n415 |                           <button\n416 |                             type=\"button\"\n417 |                             onClick={() => {\n418 |                               setForgotEmail(email);\n419 |                               setForgotSubmitted(false);\n420 |                               setForgotError(\"\");\n421 |                               setShowForgot(true);\n422 |                             