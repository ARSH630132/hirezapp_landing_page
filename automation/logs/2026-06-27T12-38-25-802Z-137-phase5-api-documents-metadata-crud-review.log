{"ts":"2026-06-27T12:37:06.298Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"run_commands","toolCallId":"56mwliat","output":[{"query":"find app/api/v1/documents","result":"app/api/v1/documents\napp/api/v1/documents/route.ts\napp/api/v1/documents/[id]\napp/api/v1/documents/[id]/route.ts\n","success":true},{"query":"cat scripts/test-document-apis.js","result":"const { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-document-build');\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\ntry {\n  execSync('npx tsc lib/api-auth.ts app/api/v1/documents/route.ts app/api/v1/documents/[id]/route.ts --outDir temp-document-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n} catch (e) {\n  console.error(\"Compilation error:\", e.message);\n  process.exit(1);\n}\nconst apiAuth = require('../temp-document-build/lib/api-auth.js');\nconst docRoute = require('../temp-document-build/app/api/v1/documents/route.js');\nconst didRoute = require('../temp-document-build/app/api/v1/documents/[id]/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    if ((await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": inactive } }))).status !== 403) throw 1;\n    if ((await docRoute.GET(new Request(\"http://l/api/v1/documents\"))).status !== 401) throw 2;\n\n    let res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.documents.length < 5) throw 3;\n\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": client } }));\n    d = await res.json();\n    if (d.documents.some(doc => doc.client_id !== \"client-001\" || doc.visibility === \"admin_only\")) throw 4;\n\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": member } }));\n    d = await res.json();\n    if (d.documents.length !== 0) throw 5;\n\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents?search=Ruleset\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.documents.length !== 1 || !d.documents[0].title.includes(\"Ruleset\")) throw 6;\n\n    res = await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"doc-001\" }) });\n    d = await res.json();\n    if (res.status !== 200 || d.document.id !== \"doc-001\") throw 7;\n\n    if ((await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-004\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"doc-004\" }) })).status !== 403) throw 8;\n    if ((await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-004\", { headers: { \"Authorization\": member } }), { params: Promise.resolve({ id: \"doc-004\" }) })).status !== 403) throw 9;\n\n    const docData = { title: \"Test Doc\", document_type: \"specification\", client_id: \"client-002\", desc: \"Test\" };\n    if ((await docRoute.POST(new Request(\"http://l/api/v1/documents\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(docData) }))).status !== 403) throw 10;\n\n    res = await docRoute.POST(new Request(\"http://l/api/v1/documents\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(docData) }));\n    if (res.status !== 201) throw 11;\n    d = await res.json();\n    const createdId = d.document.id;\n    if (d.document.client_name !== \"Global Retail Enclave [Preview Client]\") throw 12;\n\n    if ((await didRoute.PATCH(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ title: \"Hacked\" }) }), { params: Promise.resolve({ id: createdId }) })).status !== 403) throw 13;\n\n    res = await didRoute.PATCH(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ title: \"Updated Title\", version: \"v2.0.0\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.document.title !== \"Updated Title\" || d.document.version !== \"v2.0.0\") throw 14;\n\n    if ((await didRoute.DELETE(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: createdId }) })).status !== 403) throw 15;\n    if ((await didRoute.DELETE(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) })).status !== 200) throw 16;\n\n    if ((await didRoute.GET(new Request(\"http://l/api/v1/documents/\" + createdId, { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) })).status !== 404) throw 17;\n\n    console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: Documents CRUD APIs Verified!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Test failed at step:\\x1b[0m\", err);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\nrun();\n","success":true}],"durationMs":13}}
