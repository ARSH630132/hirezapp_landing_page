{"ts":"2026-06-27T11:18:27.570Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"4rhdhfxv","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/verify-auth-endpoints.js","new_text":"/* eslint-disable */\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\n\nconsole.log(\"\\x1b[35m%s\\x1b[0m\", \"========================================================\");\nconsole.log(\"\\x1b[35m%s\\x1b[0m\", \"       GFF AI - AUTH GATEWAY LOGIC VERIFICATION SUITE   \");\nconsole.log(\"\\x1b[35m%s\\x1b[0m\", \"========================================================\");\n\nconst TEMP_DIR = path.join(__dirname, '..', 'temp-auth-build');\n\nfunction cleanup() {\n  if (fs.existsSync(TEMP_DIR)) {\n    fs.rmSync(TEMP_DIR, { recursive: true, force: true });\n  }\n}\n\nconsole.log(\"Compiling Authentication Modules to temporary CommonJS directory...\");\ntry {\n  cleanup();\n  execSync(\n    'npx tsc lib/api-auth.ts --outDir temp-auth-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop',\n    { stdio: 'inherit' }\n  );\n  console.log(\"\\x1b[32m%s\\x1b[0m\", \"✔ Auth module compiled successfully.\");\n} catch (error) {\n  console.error(\"\\x1b[31m%s\\x1b[0m\", \"✖ Compilation failed:\");\n  console.error(error.message);\n  process.exit(1);\n}\n\nlet apiAuth;\ntry {\n  apiAuth = require('../temp-auth-build/api-auth.js');\n} catch (error) {\n  console.error(\"\\x1b[31m%s\\x1b[0m\", \"✖ Failed to import compiled auth module:\");\n  console.error(error.stack);\n  cleanup();\n  process.exit(1);\n}\n\nlet passed = 0;\nlet failed = 0;\n\nfunction test(name, fn) {\n  try {\n    fn();\n    console.log(`  \\x1b[32m✔\\x1b[0m ${name}`);\n    passed++;\n  } catch (error) {\n    console.log(`  \\x1b[31m✖\\x1b[0m ${name}`);\n    console.error(`    \\x1b[31mError:\\x1b[0m ${error.message}`);\n    failed++;\n  }\n}\n\nfunction assert(condition, message) {\n  if (!condition) {\n    throw new Error(message || \"Assertion failed\");\n  }\n}\n\ntry {\n  // --- Test Group 1: Cryptographic JWT Operations ---\n  console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 1: Cryptographic JWT Operations ---\");\n\n  test(\"signJwt & verifyJwt - success path with valid payload\", () => {\n    const payload = { sub: \"usr-001\", email: \"s.vance@governance.gff.ai\", role: \"gff_admin\" };\n    const token = apiAuth.signJwt(payload);\n    \n    assert(token && token.split('.').length === 3, \"Token must have exactly 3 parts separated by dots\");\n    \n    const decoded = apiAuth.verifyJwt(token);\n    assert(decoded !== null, \"Decoded token must not be null\");\n    assert(decoded.sub === \"usr-001\", \"Sub claim must match usr-001\");\n    assert(decoded.email === \"s.vance@governance.gff.ai\", \"Email claim must match s.vance@governance.gff.ai\");\n    assert(decoded.role === \"gff_admin\", \"Role claim must match gff_admin\");\n  });\n\n  test(\"verifyJwt - reject modified signature\", () => {\n    const payload = { sub: \"usr-001\", email: \"s.vance@governance.gff.ai\" };\n    const token = apiAuth.signJwt(payload);\n    \n    // Tamper with the signature portion (last part of the JWT)\n    const parts = token.split('.');\n    parts[2] = parts[2].substring(0, parts[2].length - 3) + \"XYZ\";\n    const tamperedToken = parts.join('.');\n    \n    const decoded = apiAuth.verifyJwt(tamperedToken);\n    assert(decoded === null, \"Decoded token must be null for tampered signature\");\n  });\n\n  test(\"verifyJwt - reject modified payload\", () => {\n    const payload = { sub: \"usr-001\", email: \"s.vance@governance.gff.ai\" };\n    const token = apiAuth.signJwt(payload);\n    \n    // Tamper with payload portion (middle part of the JWT)\n    const parts = token.split('.');\n    const decodedPayload = JSON.parse(apiAuth.base64UrlDecode(parts[1]));\n    decodedPayload.role = \"gff_admin\"; // Attempt privilege escalation\n    parts[1] = apiAuth.base64UrlEncode(JSON.stringify(decodedPayload));\n    const tamperedToken = parts.join('.');\n    \n    const decoded = apiAuth.verifyJwt(tamperedToken);\n    assert(decoded === null, \"Decoded token must be null for tampered payload\");\n  });\n\n  test(\"verifyJwt - reject expired token\", () => {\n    const payload = { sub: \"usr-001\" };\n    // Sign token with -10 seconds remaining (already expired)\n    const token = apiAuth.signJwt(payload, undefined, -10);\n    \n    const decoded = apiAuth.verifyJwt(token);\n    assert(decoded === null, \"Decoded token must be null for expired token\");\n  });\n\n  // --- Test Group 2: User Lookup and Password Verifications ---\n  console.log(\"\\n\\x1b[36m%s\\x1b[0m\", \"--- Test Group 2: User Lookup and Password Verifications ---\");\n\n  test(\"verifyUserPassword - correct specific passwords\", () => {\n    assert(apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"VanceSecure2026!\"), \"Dr. Sarah Vance's custom password should succeed\");\n    assert(apiAuth.verifyUserPassword(\"a.mercer@apex-sovereign.gff.ai\", \"MercerSecure2026!\"), \"Alexander Mercer's custom password should succeed\");\n  });\n\n  test(\"verifyUserPassword - correct default password & dev fallback keys\", () => {\n    assert(apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"gff-secure-2026!\"), \"Secure master developer password should succeed\");\n    assert(apiAuth.verifyUserPassword(\"s.jenkins@fed-treasury.gff.ai\", \"password123\"), \"Simple testing password should succeed\");\n  });\n\n  test(\"verifyUserPassword - fail incorrect password\", () => {\n    assert(!apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"wrongpassword\"), \"Incorrect password must fail\");\n    assert(!apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"vanceSecure2026!\"), \"Password check must be case sensitive\");\n  });\n\n  test(\"verifyUserPassword - fail unknown user email\", () => {\n    assert(!apiAuth.verifyUserPassword(\"unknown@gff.ai\", \"VanceSecure2026!\"), \"Checking password for unknown email must fail\");\n  });\n\n  test(\"verifyUserStatus - inactive flag validation\", () => {\n    const user = apiAuth.API_MOCK_USERS[\"m.vance@sovereign-logistics.gff.ai\"];\n    assert(user !== undefined, \"Marcus Vance must exist in mock DB\");\n    assert(user.status === \"inactive\", \"Marcus Vance must be inactive\");\n  });\n\n  console.log(\"\\n\\x1b[35m%s\\x1b[0m\", \"========================================================\");\n  console.log(\"\\x1b[35m%s\\x1b[0m\", \"                  VERIFICATION SUMMARY                  \");\n  console.log(\"\\x1b[35m%s\\x1b[0m\", \"========================================================\");\n  console.log(`  Total Passed:  \\x1b[32m${passed}\\x1b[0m`);\n  console.log(`  Total Failed:  \\x1b[31m${failed}\\x1b[0m`);\n  \n  if (failed > 0) {\n    console.log(\"\\n\\x1b[41m\\x1b[37m %s \\x1b[0m\", \" VERIFICATION FAILED: Fix auth logic errors. \");\n    cleanup();\n    process.exit(1);\n  } else {\n    console.log(\"\\n\\x1b[42m\\x1b[30m VERIFICATION SUCCESSFUL: Auth logic verified! \\x1b[0m\");\n  }\n} catch (e) {\n  console.error(\"Test execution block crash:\", e);\n  cleanup();\n  process.exit(1);\n}\n\ncleanup();\n"}}}
