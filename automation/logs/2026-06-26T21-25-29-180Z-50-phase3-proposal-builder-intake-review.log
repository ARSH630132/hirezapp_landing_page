</h2>\n448 |                       <p className=\"text-white/40 text-[10px] font-light\">Specify your organization, vertical sector, operational scale, and target regional boundary constraints.</p>\n449 |                     </div>\n450 | \n451 |                     <div className=\"space-y-1.5\">\n452 |                       <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Organization Name (Optional)</label>\n453 |                       <input\n454 |                         type=\"text\"\n455 |                         value={inputs.companyName}\n456 |                         onChange={(e) => setInputs({ ...inputs, companyName: e.target.value })}\n457 |                         placeholder=\"e.g. Sovereign Global Mainframes\"\n458 |                         className=\"w-full bg-black/40 border border-white/10 rounded-lg px-4 h-11 text-xs text-white placeholder-white/20 focus:outline-none focus:border-[#009DFF]/60 transition\"\n459 |                       />\n460 |                     </div>\n461 | \n462 |                     <div className=\"space-y-1.5\">\n463 |                       <div className=\"flex justify-between\">\n464 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Industry Vertical</label>\n465 |                         {validationErrors.industry && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.industry}</span>}\n466 |                       </div>\n467 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2.5\">\n468 |                         {INDUSTRIES.map((ind) => (\n469 |                           <button\n470 |                             key={ind.id}\n471 |                             type=\"button\"\n472 |                             onClick={() => { setInputs({ ...inputs, industry: ind.id }); setValidationErrors((prev) => ({ ...prev, industry: \"\" })); }}\n473 |                             className={`p-3 rounded-xl border text-left transition flex gap-3 items-start min-h-[60px] ${inputs.industry === ind.id ? \"border-[#009DFF] bg-[#009DFF]/5 shadow-[0_0_12px_rgba(0,157,255,0.1)]\" : \"border-white/5 bg-black/40 hover:border-white/10 hover:bg-black/60\"}`}\n474 |                           >\n475 |                             <span className=\"text-base mt-0.5\">{ind.icon}</span>\n476 |                             <div>\n477 |                               <h4 className=\"text-xs font-bold text-white leading-none\">{ind.label}</h4>\n478 |                               <p className=\"text-[9px] text-white/40 leading-snug font-light mt-1\">{ind.desc}</p>\n479 |                             </div>\n480 |                           </button>\n481 |                         ))}\n482 |                       </div>\n483 |                     </div>\n484 | \n485 |                     <div className=\"space-y-1.5\">\n486 |                       <div className=\"flex justify-between\">\n487 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Enterprise Operational Scale</label>\n488 |                         {validationErrors.companySize && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.companySize}</span>}\n489 |                       </div>\n490 |                       <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2.5\">\n491 |                         {COMPANY_SIZES.map((size) => (\n492 |                           <button\n493 |                             key={size.id}\n494 |                             type=\"button\"\n495 |                             onClick={() => { setInputs({ ...inputs, companySize: size.id }); setValidationErrors((prev) => ({ ...prev, companySize: \"\" })); }}\n496 |                             className={`p-3 rounded-xl border text-left transition flex flex-col justify-between min-h-[105px] ${inputs.companySize === size.id ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40 hover:border-white/10\"}`}\n497 |                           >\n498 |                             <div>\n499 |                               <h4 className=\"text-xs font-bold text-white leading-tight\">{size.label}</h4>\n500 |                               <span className=\"text-[8px] font-mono text-white/40 mt-0.5 block\">{size.range}</span>\n501 |                             </div>\n502 |                             <p className=\"text-[9px] text-white/30 leading-tight mt-1.5\">{size.desc}</p>\n503 |                           </button>\n504 |                         ))}\n505 |                       </div>\n506 |                     </div>\n507 | \n508 |                     <div className=\"space-y-1.5\">\n509 |                       <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Deployment Geography (Optional)</label>\n510 |                       <input\n511 |                         type=\"text\"\n512 |                         value={inputs.geography}\n513 |                         onChange={(e) => setInputs({ ...inputs, geography: e.target.value })}\n514 |                         placeholder=\"e.g. EU Sovereign Boundary (VPC Frankfurt), AWS us-east-1 VPC\"\n515 |                         className=\"w-full bg-black/40 border border-white/10 rounded-lg px-4 h-11 text-xs text-white placeholder-white/20 focus:outline-none focus:border-[#009DFF]/60 transition\"\n516 |                       />\n517 |                     </div>\n518 |                   </div>\n519 |                 )}\n520 | \n521 |                 {/* GATE 2: STRATEGY & OUTCOMES */}\n522 |                 {activeStepGate === 2 && (\n523 |                   <div className=\"space-y-5 animate-fadeIn\">\n524 |                     <div className=\"border-b border-white/5 pb-3\">\n525 |                       <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider font-bold\">GATE 02 OF 03</span>\n526 |                       <h2 className=\"text-lg font-bold text-white mt-1\">Strategic Friction & Outcomes</h2>\n527 |                     </div>\n528 | \n529 |                     <div className=\"space-y-1.5\">\n530 |                       <div className=\"flex justify-between\">\n531 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Primary Obstacle</label>\n532 |                         {validationErrors.primaryChallenge && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.primaryChallenge}</span>}\n533 |                       </div>\n534 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n535 |                         {CHALLENGES.map((chal) => (\n536 |                           <button\n537 |                             key={chal.id}\n538 |                             type=\"button\"\n539 |                             onClick={() => { setInputs({ ...inputs, primaryChallenge: chal.id }); setValidationErrors((prev) => ({ ...prev, primaryChallenge: \"\" })); }}\n540 |                             className={`p-2 rounded-xl border text-left transition flex gap-2 items-start min-h-[60px] ${inputs.primaryChallenge === chal.id ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40\"}`}\n541 |                           >\n542 |                             <span className=\"text-sm mt-0.5\">{chal.icon}</span>\n543 |                             <div>\n544 |                               <h4 className=\"text-xs font-bold text-white leading-none\">{chal.label}</h4>\n545 |                               <p className=\"text-[8.5px] text-white/35 leading-tight mt-1 font-light\">{chal.desc}</p>\n546 |                             </div>\n547 |                           </button>\n548 |                         ))}\n549 |                       </div>\n550 |                     </div>\n551 | \n552 |                     {inputs.primaryChallenge === \"other\" && (\n553 |                       <div className=\"space-y-1.5\">\n554 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Specify Custom Obstacle</label>\n555 |                         <textarea\n556 |                           rows={2}\n557 |                           value={inputs.customChallenge}\n558 |                           onChange={(e) => { setInputs({ ...inputs, customChallenge: e.target.value }); setValidationErrors((prev) => ({ ...prev, customChallenge: \"\" })); }}\n559 |                           placeholder=\"Describe the custom strategic obstacle...\"\n560 |                           className=\"w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-xs text-white focus:border-[#009DFF]\"\n561 |                         />\n562 |                       </div>\n563 |                     )}\n564 | \n565 |                     <div className=\"space-y-1.5\">\n566 |                       <div className=\"flex justify-between\">\n567 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Priority Outcomes</label>\n568 |                         {validationErrors.priorityOutcomes && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.priorityOutcomes}</span>}\n569 |                       </div>\n570 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n571 |                         {OUTCOMES.map((out) => {\n572 |                           const isSelected = inputs.priorityOutcomes.includes(out.id);\n573 |                           return (\n574 |                             <button\n575 |                               key={out.id}\n576 |                               type=\"button\"\n577 |                               onClick={() => {\n578 |                                 let list = [...inputs.priorityOutcomes];\n579 |                                 if (isSelected) list = list.filter((id) => id !== out.id);\n580 |                                 else list.push(out.id);\n581 |                                 setInputs({ ...inputs, priorityOutcomes: list });\n582 |                               }}\n583 |                               className={`p-2.5 rounded-xl border text-left transition flex items-center justify-between gap-4 ${isSelected ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40\"}`}\n584 |                             >\n585 |                               <div>\n586 |                                 <h4 className=\"text-xs font-bold text-white leading-tight\">{out.label}</h4>\n587 |                                 <p className=\"text-[8.5px] text-white/35 font-light leading-tight mt-0.5\">{out.desc}</p>\n588 |                               </div>\n589 |                               <div className={`w-3.5 h-3.5 rounded border flex items-center justify-center transition-all ${isSelected ? \"bg-[#009DFF] border-[#009DFF]\" : \"border-white/20\"}`}>\n590 |                                 {isSelected && <span className=\"w-1.5 h-1.5 rounded-full bg-black\" />}\n591 |                               </div>\n592 |                             </button>\n593 |                           );\n594 |                         })}\n595 |                       </div>\n596 |                     </div>\n597 | \n598 |                     <div className=\"space-y-1.5\">\n599 |                       <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Target Project Timeline</label>\n600 |                       <div className=\"grid grid-cols-1 sm:grid-cols-4 gap-2\">","success":true}],"durationMs":3}}
