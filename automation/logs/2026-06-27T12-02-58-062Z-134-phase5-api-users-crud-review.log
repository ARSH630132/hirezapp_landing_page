*/}\n508 |             <div className=\"flex items-center gap-1 overflow-x-auto w-full md:w-auto pb-1 md:pb-0 scrollbar-none\">\n509 |               {([\"all\", \"gff_admin\", \"client_admin\", \"client_member\"] as const).map((role) => (\n510 |                 <button\n511 |                   key={role}\n512 |                   onClick={() => setSelectedRoleFilter(role)}\n513 |                   className={`px-2.5 py-1.5 rounded text-[10px] font-mono font-semibold uppercase tracking-wider border transition-all cursor-pointer whitespace-nowrap ${\n514 |                     selectedRoleFilter === role\n515 |                       ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/30 shadow-[0_0_10px_rgba(0,157,255,0.15)]\"\n516 |                       : \"bg-white/[0.01] text-white/50 border-white/5 hover:text-white/80 hover:border-white/10\"\n517 |                   }`}\n518 |                 >\n519 |                   {role === \"all\" ? \"All Roles\" : role.replace(\"_\", \" \")}\n520 |                 </button>\n521 |               ))}\n522 |             </div>\n523 |           </div>\n524 | \n525 | \n526 |           {/* Table container */}\n527 |           <div className=\"overflow-x-auto rounded border border-white/5 bg-[#050507]\">\n528 |             <table className=\"w-full min-w-[620px] border-collapse text-left\">\n529 |               <thead>\n530 |                 <tr className=\"border-b border-white/5 bg-white/[0.02] text-[10px] font-mono text-white/40 uppercase tracking-wider\">\n531 |                   <th className=\"py-3 px-4 font-semibold\">Operator & Secure ID</th>\n532 |                   <th className=\"py-3 px-4 font-semibold\">Role Allocation</th>\n533 |                   <th className=\"py-3 px-4 font-semibold\">Client Association</th>\n534 |                   <th className=\"py-3 px-4 font-semibold\">Status</th>\n535 |                   <th className=\"py-3 px-4 font-semibold text-right\">Clearance</th>\n536 |                 </tr>\n537 |               </thead>\n538 |               <tbody className=\"divide-y divide-white/5\">\n539 |                 {filteredUsers.length === 0 ? (\n540 |                   <tr>\n541 |                     <td colSpan={5} className=\"py-12 text-center\">\n542 |                       <div className=\"flex flex-col items-center justify-center gap-2\">\n543 |                         <Users className=\"w-8 h-8 text-white/10\" />\n544 |                         <p className=\"text-xs font-mono text-white/40 uppercase\">No operators found matching criteria</p>\n545 |                         <button\n546 |                           onClick={() => {\n547 |                             setSearchQuery(\"\");\n548 |                             setSelectedRoleFilter(\"all\");\n549 |                             setSelectedClientFilter(\"all\");\n550 |                           }}\n551 |                           className=\"mt-2 text-[10px] font-mono text-[#009DFF] hover:underline\"\n552 |                         >\n553 |                           Reset Console Filters\n554 |                         </button>\n555 |                       </div>\n556 |                     </td>\n557 |                   </tr>\n558 |                 ) : (\n559 | \n560 |                   filteredUsers.map((user) => {\n561 |                     const isSelected = selectedUser?.id === user.id;\n562 |                     return (\n563 |                       <tr\n564 |                         key={user.id}\n565 |                         onClick={() => setSelectedUser(user)}\n566 |                         className={`group cursor-pointer transition-all ${\n567 |                           isSelected\n568 |                             ? \"bg-[#009DFF]/5 hover:bg-[#009DFF]/5 border-l-2 border-l-[#009DFF]\"\n569 |                             : \"hover:bg-white/[0.015]\"\n570 |                         }`}\n571 |                       >\n572 |                         <td className=\"py-3.5 px-4\">\n573 |           