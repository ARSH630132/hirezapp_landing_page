oken} queued. Access bounds mapped to ${inviteRole.toUpperCase()}.`,\n288 |         ...prev\n289 |       ]);\n290 | \n291 |       setInviteStep(\"success\");\n292 |     }, 1000);\n293 |   };\n294 | \n295 |   // Emulate Accepting the Invite (instantly makes the newly added user active)\n296 |   const handleAcceptInviteSimulated = () => {\n297 |     const lastUser = users[users.length - 1];\n298 |     if (lastUser) {\n299 |       const updatedUsers = users.map((u) => \n300 |         u.id === lastUser.id ? { ...u, status: \"active\" as const, lastActive: \"Just now\" } : u\n301 |       );\n302 |       setUsers(updatedUsers);\n303 |       setSelectedUser({ ...lastUser, status: \"active\" as const, lastActive: \"Just now\" });\n304 | \n305 |       const timestamp = new Date().toLocaleTimeString();\n306 |       setAuditLogs((prev) => [\n307 |         `[${timestamp}] ACCEPTANCE: Operator ${lastUser.name} accepted invite token.`,\n308 |         `[${timestamp}] ACCESS: Cryptographic session established. FIDO2 security token bound.`,\n309 |         ...prev\n310 |       ]);\n311 |     }\n312 |     setIsInviteOpen(false);\n313 |     setInviteStep(\"form\");\n314 |     setInviteName(\"\");\n315 |     setInviteEmail(\"\");\n316 |   };\n317 | \n318 |   // Copy simulated invite link/token\n319 |   const copyTokenToClipboard = () => {\n320 |     navigator.clipboard.writeText(generatedToken);\n321 |     setCopiedToken(true);\n322 |     setTimeout(() => setCopiedToken(false), 2000);\n323 |   };\n324 | \n325 |   // Derive unique clients list for filtering\n326 |   const uniqueClients = Array.from(\n327 |     new Set(users.map((u) => u.clientAssociation).filter((c) => c !== \"GFF AI Platform Core (Global Root)\"))\n328 |   );\n329 | \n330 |   // Filter Users\n331 |   const filteredUsers = users.filter((user) => {\n332 |     // Search filter\n333 |     if (\n334 |       searchQuery.trim() !== \"\" &&\n335 |       !user.name.toLowerCase().includes(searchQuery.toLowerCase()) &&\n336 |     