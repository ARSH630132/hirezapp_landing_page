n175 |           \"Content-Type\": \"application/json\"\n176 |         }\n177 |       });\n178 |       if (!res.ok) {\n179 |         const errData = await res.json().catch(() => ({}));\n180 |         throw new Error(errData.message || `HTTP error! status: ${res.status}`);\n181 |       }\n182 |       const data = await res.json();\n183 |       if (data.success && Array.isArray(data.operations)) {\n184 |         const mapped = data.operations.map(mapApiOpToEnrichedAgent);\n185 |         setAgents(mapped);\n186 |       } else {\n187 |         throw new Error(data.message || \"Failed to retrieve sandbox telemetry ledger.\");\n188 |       }\n189 |     } catch (err: any) {\n190 |       console.error(\"Error fetching AI operations:\", err);\n191 |       setError(err.message || \"An unexpected network error occurred.\");\n192 |     } finally {\n193 |       setLoading(false);\n194 |     }\n195 |   }, []);\n196 | \n197 |   useEffect(() => {\n198 |     fetchOperations();\n199 |   }, [fetchOperations]);\n200 | \n201 |   // Dynamic Reboot Handler (Simulated Enclave Cycling)\n202 |   const handleRecycleEnclave = (agentId: string) => {\n203 |     if (rebootingMap[agentId]) return;\n204 | \n205 |     setRebootingMap(prev => ({ ...prev, [agentId]: true }));\n206 |     \n207 |     // Log reboot sequence initiation\n208 |     setAgents(prev => prev.map(agent => {\n209 |       if (agent.id === agentId) {\n210 |         return {\n211 |           ...agent,\n212 |           logs: [\n213 |             ...agent.logs,\n214 |             `[${new Date().toLocaleTimeString()}] CRITICAL: INITIATING COLD REBOOT SEQUENCE...`,\n215 |             `[${new Date().toLocaleTimeString()}] INTERRUPT VECTOR SEALS TRIGGERED`,\n216 |             `[${new Date().toLocaleTimeString()}] RE-INITIALIZING CRYPTOGRAPHIC HARDWARE...`\n217 |           ]\n218 |         };\n219 |       }\n220 |       return agent;\n221 |     }));\n222 | \n223 |     setTimeout(() => {\n224 |       setRebootingMap(prev => ({ ...prev, [agentId]: false }));\n225 |       setAgents(prev => prev.map(agent => {\n226 |         if (agent.id === agentId) {\n227 |           // If decoupled, return with active status on recycling\n228 |           const finalStatus = agent.status === \"decoupled\" ? \"active\" : agent.status;\n229 |           return {\n230 |             ...agent,\n231 |             status: finalStatus,\n232 |             logs: [\n233 |               ...agent.logs,\n234 |               `[${new Date().toLocaleTimeString()}] HARDWARE CORE RE-ALIGNED OK`,\n235 |               `[${new Date().toLocaleTimeString()}] ZERO-TRUST ATTESTATION INSTRUCTIONS INJECTED`,\n236 |               `[${new Date().toLocaleTimeString()}] TELEMETRY PORT STABLE (SHA256: 0x9AF8)`\n237 |             ]\n238 |           };\n239 |         }\n240 |         return agent;\n241 |       }));\n242 |     }, 1800);\n243 |   };\n244 | \n245 |   // Filter Agents Logic\n246 |   const filteredAgents = agents.filter(agent => {\n247 |     const matchesSearch = agent.name.toLowerCase().includes(search.toLowerCase()) || \n248 |                           agent.id.toLowerCase().includes(search.toLowerCase()) ||\n249 |                           agent.type.toLowerCase().includes(search.toLowerCase());\n250 |     const matchesProject = selectedProject === \"all\" || agent.projectId === selectedProject;\n251 |     const matchesType = selectedType === \"all\" || agent.type === selectedType;\n252 |     const matchesStatus = selectedStatus === \"all\" || agent.status === selectedStatus;\n253 |     const matchesStage = selectedStage === \"all\" || agent.stage === selectedStage;\n254 | \n255 |     return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n256 |   });\n257 | \n258 |   const resetFilters = () => {\n259 |     setSearch(\"\");\n260 |     setSelectedProject(\"all\");\n261 |     setSelectedType(\"all\");\n262 |     setSelectedStatus(\"all\");\n263 |     setSelectedStage(\"all\");\n264 |   };\n265 | \n266 |   // Mock Timeline Steps for Governance\n267 |   const timelineSteps = [\n268 |     {\n269 |       title: \"HARDWARE INTENT COMPLIANCE SECURED\",\n270 |       desc: \"Hardware attestation successfully verified signatures across 5 isolated AMD SEV-SNP and Intel SGX runtimes.\",\n271 |       status: \"complete\" as const,\n272 |       timestamp: \"2 hours ago\"\n273 |     },\n274 |     {\n275 |       title: \"PROMPT INJECTION BARRIER RE-SEALED\",\n276 |       desc: \"Local Model Guardrails completed continuous validation scan. Compliance score locked at 1.0/1.0.\",\n277 |       status: \"complete\" as const,\n278 |       timestamp: \"5 hours ago\"\n279 |     },\n280 |     {\n281 |       title: \"HSM COMPLIANCE ROOT CHECK\",\n282 |       desc: \"Ongoing zero-trust validation of isolated memory partitions and decoupled system interfaces.\",\n283 |       status: \"current\" as const,\n284 |       timestamp: \"Ongoing\"\n285 |     },\n286 |     {\n287 |       title: \"WEEKLY HARDWARE ENCLAVE ROTATION\",\n288 |       desc: \"Automated cryptographic key rollover and fresh partition reallocation for continuous sandbox integrity.\",\n289 |       status: \"pending\" as const,\n290 |       timestamp: \"Scheduled\"\n291 |     }\n292 |   ];\n293 | \n294 | \n295 |   return (\n296 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n297 |       \n298 |       {/* 1. SECURE DISCLOSURE BANNER */}\n299 |       <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n300 |         <div className=\"flex items-center gap-2.5 text-white/70\">\n301 |           <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n302 |           <span>\n303 |             <strong className=\"text-white\">COCKPIT REPRESENTATIVE TELEMETRY:</strong> This control center displays emulated telemetry data and sandboxed system parameters. Real-time live production adjustments are emulated for security.\n304 |           </span>\n305 |         </div>\n306 |         <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n307 |           EMULATED RUNTIME\n308 |         </span>\n309 |       </div>\n310 | \n311 |       {/* 2. PAGE HEADER */}\n312 |       <PrivatePageHeader\n313 |         title=\"AI Operations Command Center\"\n314 |         desc=\"Central portal for continuous monitoring of managed sandbox runtimes, sovereign hardware partition metrics, and zero-trust policy validations.\"\n315 |         badgeLabel=\"Sovereign AI Ops\"\n316 |         actions={\n317 |           <div className=\"flex gap-2 w-full md:w-auto\">\n318 |             <Link\n319 |               href=\"/portal/control-center\"\n320 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[11px] px-4 uppercase tracking-wider transition-all hover:shadow-[0_0_12px_rgba(0,157,255,0.25)]\"\n321 |             >\n322 |               Hardware Control Center\n323 |               <ArrowUpRight className=\"w-3.5 h-3.5\" />\n324 |             </Link>\n325 |           </div>\n326 |         }\n327 |       />\n328 | \n329 | \n330 |       {/* 3. MANAGED OPERATION STATUS RAIL */}\n331 |       <div className=\"grid grid-cols-1 md:grid-cols-4 gap-3 border border-white/5 rounded-xl bg-white/[0.01] p-3.5 font-mono text-[11px]\">\n332 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n333 |           <span className=\"relative flex h-2 w-2 shrink-0\">\n334 |             <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n335 |             <span className=\"relative inline-flex rounded-full h-2 w-2 bg-emerald-500\"></span>\n336 |           </span>\n337 |           <span className=\"text-white/40\">OPS STATUS:</span>\n338 |           <span className=\"text-[#00FFC2] font-bold\">STEADY & COMPLIANT</span>\n339 |         </div>\n340 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n341 |           <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n342 |           <span className=\"text-white/40\">SYSTEM RUNTIMES:</span>\n343 |           <span className=\"text-white font-bold\">5 REPL SANDBOXES</span>\n344 |         </div>\n345 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n346 |           <ShieldCheck className=\"w-3.5 h-3.5 text-emerald-400\" />\n347 |           <span className=\"text-white/40\">INTEGRITY LOCKS:</span>\n348 |           <span className=\"text-emerald-400 font-bold\">ISO-27001 ACTIVE</span>\n349 |         </div>\n350 |         <div className=\"flex items-center gap-2.5 px-3 py-1\">\n351 |           <Clock className=\"w-3.5 h-3.5 text-amber-400\" />\n352 |           <span className=\"text-white/40\">MAINTENANCE CYCLE:</span>\n353 |           <span className=\"text-white font-bold\">AUTOMATED (2H 45M)</span>\n354 |         </div>\n355 |       </div>\n356 | \n357 |       {/* 4. HEALTH OVERVIEW & RUNTIME STATUS (HEALTH RINGS) */}\n358 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n359 |         <HealthRing \n360 |           percentage={68} \n361 |           title=\"Avg Core CPU Load\" \n362 |           value=\"59.84 Gigaflops\" \n363 |           color=\"#10b981\" \n364 |         />\n365 |         <HealthRing \n366 |           percentage={78} \n367 |           title=\"Sandbox Memory Lock\" \n368 |           value=\"27.2 GB / 34.0 GB\" \n369 |           color=\"#009DFF\" \n370 |         />\n371 |         <HealthRing \n372 |           percentage={100} \n373 |           title=\"Guardrail Compliance\" \n374 |           value=\"4 / 4 Rules Enforced\" \n375 |           color=\"#00FFC2\" \n376 |         />\n377 |         \n378 |         {/* Rapid Overview Metric Tile */}\n379 |         <WorkspaceCard className=\"flex flex-col justify-between p-4 bg-[#050505]/20\">\n380 |           <div className=\"flex justify-between items-start font-mono\">\n381 |             <div>\n382 |               <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">Aggregate Pulse Latency</span>\n383 |               <span className=\"text-[18px] font-bold text-white mt-1.5 block\">16.42 ms</span>\n384 |             </div>\n385 |             <span className=\"text-[10px] px-2 py-0.5 rounded bg-[#00FFC2]/5 border border-[#00FFC2]/20 text-[#00FFC2] font-bold\">\n386 |               OPTIMAL\n387 |             </span>\n388 |           </div>\n389 |           <div className=\"border-t border-white/5 pt-2 mt-2 flex justify-between items-center text-[10px] font-mono text-white/45\">\n390 |             <span>UPTIME SCORE:</span>\n391 |             <span className=\"text-white font-bold\">99.998% CERTIFIED</span>\n392 |           </div>\n393 |         </WorkspaceCard>\n394 |       </div>\n395 | \n396 |       {/* 5. TABS SYSTEM */}\n397 |       <div className=\"flex border-b border-white/5 font-mono text-[12px]\">\n398 |         <button\n399 |           onClick={() => setActiveTab(\"telemetry\")}\n400 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n401 |             activeTab === \"telemetry\" \n402 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n403 |               : \"border-transparent text-white/40 hover:text-white/70\"\n404 |           }`}\n405 |         >\n406 |           ACTIVE TELEMETRY LEDGER\n407 |         </button>\n408 |         <button\n409 |           onClick={() => setActiveTab(\"hardware\")}\n410 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n411 |             activeTab === \"hardware\" \n412 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n413 |               : \"border-transparent text-white/40 hover:text-white/70\"\n414 |           }`}\n415 |         >\n416 |           HARDWARE & ENCLAVE ARCHITECTURE\n417 |         </button>\n418 |         <button\n419 |           onClick={() => setActiveTab(\"governance\")}\n420 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n421 |             activeTab === \"governance\" \n422 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n423 |               : \"border-transparent text-white/40 hover:text-white/70\"\n424 |           }`}\n425 |         >\n426 |           GOVERNANCE & ACTIVITY LOG\n427 |         </button>\n428 |       </div>\n429 | \n430 |       {/* ==========================================\n431 |           TAB 1: TELEMETRY & ACTIVE AGENTS GRID\n432 |           ========================================== */}\n433 |       {activeTab === \"telemetry\" && (\n434 |         <div className=\"space-y-6\">\n435 |           <WorkspaceCard className=\"p-4 space-y-4\">\n436 |             <div className=\"flex items-center gap-2 pb-2 border-b border-white/5\">\n437 |               <SlidersHorizontal className=\"w-4 h-4 text-[#009DFF]\" />\n438 |               <h3 className=\"text-xs font-mono font-bold uppercase text-white tracking-widest\">Interactive Telemetry Filters</h3>\n439 |             </div>\n440 |             <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n441 |               <div className=\"relative\">\n442 |                 <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n443 |                 <input \n444 |                   type=\"text\"\n445 |                   value={search}\n446 |                   onChange={(e) => setSearch(e.target.value)}\n447 |                   placeholder=\"Search agent ID, name...\"\n448 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[11px] font-mono text-white placeholder-white/30 outline-none focus:border-[#009DFF]/50 focus:bg-white/[0.04] transition-all\"\n449 |                 />\n450 |               </div>\n451 |               <div className=\"relative\">\n452 |                 <select \n453 |                   value={selectedProject}\n454 |                   onChange={(e) => setSelectedProject(e.target.value)}\n455 |                   aria-label=\"Filter by Project\"\n456 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n457 |                 >\n458 |                   <option value=\"all\">ALL PROJECTS</option>\n459 |                   <option value=\"proj-001\">Sovereign Core Sandbox 02</option>\n460 |                   <option value=\"proj-002\">Model Guardrail Sandbox 04</option>\n461 |                   <option value=\"proj-003\">Sovereign Mining Intel Loop</option>\n462 |                 </select>\n463 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n464 |               </div>\n465 |               <div className=\"relative\">\n466 |                 <select \n467 |                   value={selectedType}\n468 |                   onChange={(e) => setSelectedType(e.target.value)}\n469 |                   aria-label=\"Filter by Agent Type\"\n470 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n471 |                 >\n472 |                   <option value=\"all\">ALL AGENT TYPES</option>\n473 |                   <option value=\"Core Telemetry\">Core Telemetry</option>\n474 |                   <option value=\"Alignment Guard\">Alignment Guard</option>\n475 |                   <option value=\"Seismic Processing\">Seismic Processing</option>\n476 |                   <option value=\"Medical Enclave\">Medical Enclave</option>\n477 |                   <option value=\"Transport Node\">Transport Node</option>\n478 |                 </select>\n479 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n480 |               </div>\n481 |               <div className=\"relative\">\n482 |                 <select \n483 |                   value={selectedStatus}\n484 |                   onChange={(e) => setSelectedStatus(e.target.value)}\n485 |                   aria-label=\"Filter by Status\"\n486 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n487 |                 >\n488 |                   <option value=\"all\">ALL PULSE STATES</option>\n489 |                   <option value=\"active\">Active</option>\n490 |                   <option value=\"evaluating\">Evaluating</option>\n491 |                   <option value=\"warning\">Warning</option>\n492 |                   <option value=\"decoupled\">Decoupled</option>\n493 |                 </select>\n494 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n495 |               </div>\n496 |               <div className=\"relative\">\n497 |                 <select \n498 |                   value={selectedStage}\n499 |                   onChange={(e) => setSelectedStage(e.target.value)}\n500 |                   aria-label=\"Filter by Operating Stage\"\n501 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n502 |                 >\n503 |                   <option value=\"all\">ALL SECURE STAGES</option>\n504 |                   <option value=\"Sandbox Emulation\">Sandbox Emulation</option>\n505 |                   <option value=\"Staging Enclave\">Staging Enclave</option>\n506 |                   <option value=\"Production Guardrail\">Production Guardrail</option>\n507 |                 </select>\n508 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n509 |               </div>\n510 |             </div>\n511 |             {(search || selectedProject !== \"all\" || selectedType !== \"all\" || selectedStatus !== \"all\" || selectedStage !== \"all\") && (\n512 |               <div className=\"flex justify-between items-center text-[10px] font-mono text-white/45 bg-white/[0.01] border border-white/5 px-3 py-1.5 rounded\">\n513 |                 <span>\n514 |                   Filtering active sandbox ledger: found <strong className=\"text-white\">{filteredAgents.length}</strong> matching agent nodes.\n515 |                 </span>\n516 |                 <button onClick={resetFilters} className=\"text-[#009DFF] hover:underline uppercase font-bold cursor-pointer\">\n517 |                   Reset Active Filters\n518 |                 </button>\n519 |               </div>\n520 |             )}\n521 |           </WorkspaceCard>\n522 | \n523 | \n524 |           {loading ? (\n525 |             <OperationsSkeleton />\n526 |           ) : error ? (\n527 |             <OperationsErrorState message={error} onRetry={fetchOperations} />\n528 |           ) : agents.length === 0 ? (\n529 |             <OperationsEmptyState />\n530 |           ) : filteredAgents.length > 0 ? (\n531 |             <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n532 |               {filteredAgents.map((agent) => {\n533 |                 const isRebooting = rebootingMap[agent.id];\n534 |                 const badgeState = isRebooting ? \"warning\" : agent.status === \"active\" ? \"active\" : agent.status === \"evaluating\" ? \"warning\" : agent.status === \"warning\" ? \"error\" : \"decoupled\";\n535 |                 const badgeLabel = isRebooting ? \"RECYCLING\" : agent.status;\n536 | \n537 |                 return (\n538 |                   <WorkspaceCard key={agent.id} className=\"space-y-4\">\n539 |                     <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n540 |                       <div>\n541 |                         <span className=\"text-[8.5px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1.5 py-0.5 rounded\">\n542 |                           {agent.id.toUpperCase()} • {agent.type.toUpperCase()}\n543 |                         </span>\n544 |                         <h4 className=\"text-[13.5px] font-bold text-white font-mono mt-1.5 tracking-tight\">\n545 |                           {agent.name}\n546 |                         </h4>\n547 |                       </div>\n548 |                       <StatusBadge state={badgeState} label={badgeLabel} />\n549 |                     </div>\n550 | \n551 |                     <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono\">\n552 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n553 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Project Bounds</span>\n554 |                         <span className=\"text-white font-medium truncate block mt-1\">{agent.projectName}</span>\n555 |                       </div>\n556 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n557 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Enclave Stage</span>\n558 |                         <span className=\"text-white font-medium block mt-1\">{agent.stage}</span>\n559 |                       </div>\n560 |                     </div>\n561 | \n562 |                     <div className=\"grid grid-cols-3 gap-2 text-[10px] font-mono text-center select-none\">\n563 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n564 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Alloc CPU</span>\n565 |                         <span className=\"text-white font-bold block mt-0.5\">\n566 |                           {isRebooting ? \"--\" : `${agent.cpu}%`}\n567 |                         </span>\n568 |                       </div>\n569 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n570 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Memory State</span>\n571 |                         <span className=\"text-white font-bold block mt-0.5\">\n572 |                           {isRebooting ? \"--\" : agent.memory.split(\" / \")[0]}\n573 |                         </span>\n574 |                       </div>\n575 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n576 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Core Threads</span>\n577 |                         <span className=\"text-[#009DFF] font-bold block mt-0.5\">\n578 |                           {isRebooting ? \"0\" : `${agent.threads}`}\n579 |                         </span>\n580 |                       </div>\n581 |                     </div>\n582 | \n583 |                     <div className=\"border border-white/5 rounded-lg overflow-hidden bg-black/70 p-3 h-28 overflow-y-auto font-mono text-[9px] text-white/50 space-y-1\">\n584 |                       {agent.logs.map((log, index) => (\n585 |                         <div key={index} className=\"leading-normal flex\">\n586 |                           <span className=\"text-white/20 mr-1 shrink-0\">&gt;</span>\n587 |                           <span className={\n588 |                             log.includes(\"REBOOT\") || log.includes(\"CRITICAL