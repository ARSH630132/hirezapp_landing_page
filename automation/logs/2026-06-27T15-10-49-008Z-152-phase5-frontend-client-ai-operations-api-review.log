 |                       >\n621 |                         <Eye className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n622 |                       </Link>\n623 |                     </div>\n624 |                   </WorkspaceCard>\n625 |                 );\n626 |               })}\n627 |             </div>\n628 | \n629 | \n630 |           ) : (\n631 |             <div className=\"border border-white/5 rounded-2xl bg-white/[0.01] p-12 text-center max-w-xl mx-auto space-y-4\">\n632 |               <div className=\"h-10 w-10 rounded-full border border-white/10 flex items-center justify-center mx-auto bg-black\">\n633 |                 <SlidersHorizontal className=\"w-4 h-4 text-white/30\" />\n634 |               </div>\n635 |               <div className=\"space-y-1 font-mono\">\n636 |                 <h4 className=\"text-[13px] font-bold text-white\">No Sandboxes Match Active Filters</h4>\n637 |                 <p className=\"text-[11px] text-white/40\">Adjust filter values above to find active enclaves.</p>\n638 |               </div>\n639 |               <button\n640 |                 onClick={resetFilters}\n641 |                 className=\"inline-flex h-8 px-4 items-center justify-center rounded bg-white/5 border border-white/10 hover:bg-white/10 text-white font-mono text-[10.5px] uppercase transition-all\"\n642 |               >\n643 |                 Clear Active Filters\n644 |               </button>\n645 |             </div>\n646 |           )}\n647 |         </div>\n648 |       )}\n649 | \n650 |       {/* ==========================================\n651 |           TAB 2: HARDWARE & ENCLAVE ARCHITECTURE\n652 |           ========================================== */}\n653 |       {activeTab === \"hardware\" && (\n654 |         <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n655 |           <div className=\"lg:col-span-2 space-y-6\">\n656 |             <WorkspaceCard className=\"space-y-4\">\n657 |               <div className=\"flex items-center gap-2 border-b 