ion\"\n387 |                   >\n388 |                     Verify & Build Blueprint\n389 |                   </button>\n390 |                 </div>\n391 |               )}\n392 |             </div>\n393 |           </div>\n394 |         )}\n395 | \n396 | \n397 |         {/* Compile Loading Screen */}\n398 |         {isCompiling && (\n399 |           <div className=\"fixed inset-0 z-[10000] bg-black/95 backdrop-blur-md flex flex-col justify-center items-center text-center p-4 animate-fadeIn\">\n400 |             <div className=\"relative w-20 h-20 mb-6\">\n401 |               <div className=\"absolute inset-0 rounded-full border-4 border-white/10\"></div>\n402 |               <div className=\"absolute inset-0 rounded-full border-4 border-t-[#087DF3] animate-spin\"></div>\n403 |             </div>\n404 |             <h4 className=\"text-lg font-bold text-white mb-2\">Compiling Custom AI Blueprint</h4>\n405 |             <p className=\"text-sm font-semibold text-[#087DF3] h-6 transition-all animate-pulse\">\n406 |               {compilingMessages[compilingStep]}\n407 |             </p>\n408 |           </div>\n409 |         )}\n410 | \n411 |         {/* Bottom Wizard Controls */}\n412 |         {step < 4 && (\n413 |           <div className=\"mt-8 pt-4 border-t border-white/5 flex justify-between items-center\">\n414 |             {error && <p className=\"text-xs md:text-sm text-red-400 font-semibold max-w-[70%]\">{error}</p>}\n415 |             <div className=\"flex gap-4 ml-auto\">\n416 |               {step > 1 && (\n417 |                 <button\n418 |                   type=\"button\"\n419 |                   onClick={() => setStep(step - 1)}\n420 |                   className=\"px-5 h-[42px] rounded-lg border border-white/15 text-xs font-semibold text-white hover:bg-white/5 transition\"\n421 |                 >\n422 |                   Back\n423 |                 </button>\n424 |               )}\n425 |               <button\n426 |                 type=\"button