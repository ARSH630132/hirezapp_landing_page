g-wider block\">Live Variables Buffer</span>\n                      <h4 className=\"text-[9px] text-white/40 mt-0.5 font-mono\">REAL-TIME MEMORY REGISTER</h4>\n                    </div>\n\n                    <div className=\"space-y-3\">\n                      {manifest.map((item, idx) => (\n                        <div key={idx} className=\"flex justify-between items-start gap-4 text-xs font-light py-1 border-b border-white/[0.02] last:border-0\">\n                          <span className=\"text-white/40 font-mono text-[9px] uppercase\">{item.label}</span>\n                          <span className=\"font-bold text-white text-right max-w-[200px] truncate\" style={item.color ? { color: item.color } : undefined}>\n                            {item.value || <span className=\"text-white/10 font-mono font-normal\">WAITING_INPUT</span>}\n                          </span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n\n                  <ToolPreviewNotice />\n                </div>\n              }\n              content={\n                <div className=\"p-6 lg:p-8 rounded-2xl border border-white/5 bg-[#030306]/90 backdrop-blur-md space-y-8 flex flex-col justify-between min-h-[480px]\">\n                  <div className=\"space-y-6\">\n                    <div className=\"border-b border-white/5 pb-4 space-y-1\">\n                      <div className=\"flex items-center gap-2\">\n                        <span className=\"text-[9px] font-mono px-2 py-0.5 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF] uppercase font-bold tracking-wider\">\n                          GATE {currentStepIndex + 1} OF {steps.length}\n                        </span>\n                        {currentStep.duration && (\n                          <span className=\"text-[9px] font-mono text-white/30 uppercase\">\n                            Est: {currentStep.duration}\n                          </span>\n       