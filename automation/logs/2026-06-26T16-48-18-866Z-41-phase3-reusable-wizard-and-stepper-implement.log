0 |                         : \"border-white/10 bg-black/40 text-white/70 hover:border-white/20 hover:bg-black/60\"\n321 |                     }`}\n322 |                   >\n323 |                     <span className=\"text-xs md:text-sm font-medium\">{o.label}</span>\n324 |                     <span className={`w-4 h-4 rounded-full border flex items-center justify-center shrink-0 ml-2 ${\n325 |                       isSelected ? \"border-[#087DF3] bg-[#087DF3]\" : \"border-white/30\"\n326 |                     }`}>\n327 |                       {isSelected && <span className=\"text-[10px] text-white\">✓</span>}\n328 |                     </span>\n329 |                   </button>\n330 |                 );\n331 |               })}\n332 |             </div>\n333 |           </div>\n334 |         )}\n335 | \n336 |         {/* Step 4: Verification Flow */}\n337 |         {step === 4 && (\n338 |           <div className=\"space-y-6 max-w-[500px] mx-auto w-full animate-fadeIn py-4\">\n339 |             <h3 className=\"text-lg font-bold text-white text-center\">Secure Verification Check</h3>\n340 |             <p className=\"text-xs text-white/50 text-center\">\n341 |               Enter your enterprise email to verify instant delivery and view your interactive roadmap.\n342 |             </p>\n343 | \n344 |             <div className=\"space-y-4\">\n345 |               <div className=\"space-y-2\">\n346 |                 <label className=\"text-xs font-semibold text-white/70 block\">Enterprise Email</label>\n347 |                 <input\n348 |                   type=\"email\"\n349 |                   disabled={otpSent}\n350 |                   value={answers.email}\n351 |                   onChange={(e) => setAnswers({ ...answers, email: e.target.value })}\n352 |                   placeholder=\"name@company.com\"\n353 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none tr