crease Revenue\", \"Improve Productivity\", \n 38 |   \"Improve Customer Experience\", \"Automate Processes\", \"Strengthen Compliance\", \"AI Transformation\"\n 39 | ] as const;\n 40 | export type SharedPriority = typeof SHARED_PRIORITIES[number];\n 41 | \n 42 | export const SHARED_PRIORITY_OPTIONS = SHARED_PRIORITIES.map(p => ({ value: p, label: p }));\n 43 | \n 44 | export const SHARED_DATA_READINESS_LEVELS = [\n 45 |   \"Highly fragmented\", \"Partially connected\", \"Mostly integrated\", \"Fully integrated\"\n 46 | ] as const;\n 47 | export type SharedDataReadiness = typeof SHARED_DATA_READINESS_LEVELS[number];\n 48 | \n 49 | export const SHARED_DATA_READINESS_OPTIONS = [\n 50 |   { value: \"Highly fragmented\", label: \"Highly fragmented\" },\n 51 |   { value: \"Partially connected\", label: \"Partially connected\" },\n 52 |   { value: \"Mostly integrated\", label: \"Mostly integrated (Mostly Integrated Data)\" },\n 53 |   { value: \"Fully integrated\", label: \"Fully integrated\" }\n 54 | ] as const;\n 55 | \n 56 | export const SHARED_LEADERSHIP_COMMITMENTS = [\n 57 |   \"Not Discussed\", \"Exploring\", \"Budget Approved\", \"Executive Mandate\"\n 58 | ] as const;\n 59 | export type SharedLeadershipCommitment = typeof SHARED_LEADERSHIP_COMMITMENTS[number];\n 60 | \n 61 | export const SHARED_LEADERSHIP_COMMITMENT_OPTIONS = SHARED_LEADERSHIP_COMMITMENTS.map(c => ({ value: c, label: c }));\n 62 | \n 63 | \n 64 | export const SHARED_AI_OPPORTUNITIES = [\n 65 |   \"Procurement Copilot\", \"HR Assistant\", \"Contract Intelligence\", \"Knowledge Search\", \n 66 |   \"Executive Dashboard\", \"Compliance Assistant\", \"Customer Experience Agent\", \n 67 |   \"Document Intelligence Agent\", \"Operations Copilot\"\n 68 | ] as const;\n 69 | export type SharedAIOpportunity = typeof SHARED_AI_OPPORTUNITIES[number];\n 70 | \n 71 | export interface AIOpportunityMetadata {\n 72 |   name: string;\n 73 |   description: string;\n 74 |   primaryValueMetric: string;\n 75 |   estimatedComplexity: \"Low\" | \"Medium\" | \"High\";\n 76 | }\n 77 | \n 78 | export const SHARED_AI_OPPORTUNITY_METADATA: Record<SharedAIOpportunity, AIOpportunityMetadata> = {\n 79 |   \"Procurement Copilot\": {\n 80 |     name: \"Procurement Copilot\",\n 81 |     description: \"Automates supplier negotiation and matches line-item compliance inside private enclaves.\",\n 82 |     primaryValueMetric: \"Save 15-25% in purchasing overhead\",\n 83 |     estimatedComplexity: \"Medium\"\n 84 |   },\n 85 |   \"HR Assistant\": {\n 86 |     name: \"HR Assistant\",\n 87 |     description: \"Sovereign onboarding assistant running on fine-tuned private knowledge models.\",\n 88 |     primaryValueMetric: \"30% reduction in HR ticket handling times\",\n 89 |     estimatedComplexity: \"Low\"\n 90 |   },\n 91 |   \"Contract Intelligence\": {\n 92 |     name: \"Contract Intelligence\",\n 93 |     description: \"Parses liability, governing laws, and commercial terms in multi-page documents.\",\n 94 |     primaryValueMetric: \"Reduces contract review durations by up to 70%\",\n 95 |     estimatedComplexity: \"High\"\n 96 |   },\n 97 |   \"Knowledge Search\": {\n 98 |     name: \"Knowledge Search\",\n 99 |     description: \"Bridges wikis and document servers to answer deep technical queries securely.\",\n100 |     primaryValueMetric: \"Saves operational personnel up to 6 hours weekly\",\n101 |     estimatedComplexity: \"Medium\"\n102 |   },\n103 |   \"Executive Dashboard\": {\n104 |     name: \"Executive Dashboard\",\n105 |     description: \"Continuous dashboard displaying process latency, token usage, and security compliance keys.\",\n106 |     primaryValueMetric: \"Provides 100% cryptographic visibility of operations\",\n107 |     estimatedComplexity: \"Medium\"\n108 |   },\n109 |   \"Compliance Assistant\": {\n110 |     name: \"Compliance Assistant\",\n111 |     description: \"Intercepts multi-agent conversational trails to prevent security leakage (GDPR, SOC2).\",\n112 |     primaryValueMetric: \"Enforces 0% critical leak rates in production\",\n113 |     estimatedComplexity: \"High\"\n114 |   },\n115 |   \"Customer Experience Agent\": {\n116 |     name: \"Customer Experience Agent\",\n117 |     description: \"Contextual customer service assistant resolving requests without remote log retention.\",\n118 |     primaryValueMetric: \"Enables 4.5x faster customer support resolution cycles\",\n119 |     estimatedComplexity: \"Low\"\n120 |   },\n121 |   \"Document Intelligence Agent\": {\n122 |     name: \"Document Intelligence Agent\",\n123 |     description: \"Processes structured and unstructured forms, bills, and diagnostics automatically.\",\n124 |     primaryValueMetric: \"Increases document ingest processing speed by 10x\",\n125 |     estimatedComplexity: \"Medium\"\n126 |   },\n127 |   \"Operations Copilot\": {\n128 |     name: \"Operations Copilot\",\n129 |     description: \"Enterprise operations manager coordinating queue logs and automated system alerts.\",\n130 |     primaryValueMetric: \"Modelled 35% reduction in manual execution overhead\",\n131 |     estimatedComplexity: \"High\"\n132 |   }\n133 | };\n134 | \n135 | export const SHARED_GFF_SOLUTIONS = [\n136 |   \"Agent Factory\", \"Knowledge Graph\", \"AI Governance\", \"Managed AI Operations\", \n137 |   \"Garage\", \"Foundry\", \"Factory\", \"Control Center\"\n138 | ] as const;\n139 | export type SharedGFFSolution = typeof SHARED_GFF_SOLUTIONS[number];\n140 | \n141 | export interface GFFSolutionMetadata {\n142 |   name: string;\n143 |   category: \"Methodology\" | \"Platform\" | \"Module\" | \"Ops\";\n144 |   tagline: string;\n145 |   description: string;\n146 | }\n147 | \n148 | export const SHARED_GFF_SOLUTION_METADATA: Record<SharedGFFSolution, GFFSolutionMetadata> = {\n149 |   \"Agent Factory\": {\n150 |     name: \"GFF Agent Factory™\",\n151 |     category: \"Platform\",\n152 |     tagline: \"High-Throughput Sovereign Agent Generation\",\n153 |     description: \"Rapidly builds