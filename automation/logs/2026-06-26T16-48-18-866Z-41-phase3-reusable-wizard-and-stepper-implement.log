-fidelity audit reports.\"\n  }\n};\n\n\nexport default function ROICalculatorPage() {\n  const [size, setSize] = useState(250);\n  const [hours, setHours] = useState(8);\n  const [rate, setRate] = useState(65);\n  const [invest, setInvest] = useState(35000);\n  const [activeDept, setActiveDept] = useState<DeptKey>(\"finance\");\n\n  const annualHours = Math.round(size * hours * 52 * 0.85);\n  const grossSavings = annualHours * rate;\n  const netSavings = Math.max(0, grossSavings - invest);\n  const roi = invest > 0 ? Math.round((netSavings / invest) * 100) : 0;\n\n  const currentDept = DEPT_DETAILS[activeDept];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Executive Calculator\"\n        title=\"Operational ROI Calculator\"\n        highlightedWord=\"ROI Calculator\"\n        description=\"Quantify structural cost reductions, productivity reclaimed, and net financial ROI of deploying autonomous agent fleets.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          {/* Sliders Control Board */}\n          <div className=\"lg:col-span-6 space-y-6 p-6 rounded-2xl border border-white/5 bg-[#04060b]\">\n            <div className=\"border-b border-white/5 pb-2\">\n              <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">Financial Model Variables</h3>\n            </div>\n\n            <div className=\"space-y-4\">\n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-xs text-white/80\"><span>Enterprise Team Size</span><span className=\"text-[#E4000F] font-bold\">{size} Employees</span></div>\n                <input type=\"range\" min=\"10\" max=\"1000\" step=\"10\" value={size} onChange={(e) => setSize(Number(e.target.value))} className=\"w-full accent-[#E4000F]\" />\n              </div>\n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-xs text-white/80\"><span>Inefficient Hours Per Week</span><span className=\"text-[#009DFF] font-bold\">{hours} Hours/Employee</span></div>\n                <input type=\"range\" min=\"1\" max=\"40\" value={hours} onChange={(e) => setHours(Number(e.target.value))} className=\"w-full accent-[#009DFF]\" />\n              </div>\n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-xs text-white/80\"><span>Average Hourly Rate</span><span className=\"text-[#00FF9D] font-bold\">${rate}/Hour</span></div>\n                <input type=\"range\" min=\"20\" max=\"200\" step=\"5\" value={rate} onChange={(e) => setRate(Number(e.target.value))} className=\"w-full accent-[#00FF9D]\" />\n              </div>\n              <div className=\"space-y-1\">\n                <div className=\"flex justify-between text-xs text-white/80\"><span>Initial Enclave Investment</span><span className=\"text-[#9D00FF] font-bold\">${invest.toLocaleString()}</span></div>\n                <input type=\"range\" min=\"5000\" max=\"250000\" step=\"5000\" value={invest} onChange={(e) => setInvest(Number(e.target.value))} className=\"w-full accent-[#9D00FF]\" />\n              </div>\n            </div>\n          </div>\n\n          {/* Results Board */}\n          <div className=\"lg:col-span-6 p-6 rounded-2xl border border-white/5 bg-[#04060b] min-h-[385px] flex flex-col justify-between\">\n            <div className=\"space-y-6\">\n              <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono border-b border-white/5 pb-2\">Investment Projection</h3>\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                  <span className=\"text-[10px] text-white/40 font-mono block\">ANNUAL RESOURCE RECLAIMED</span>\n                  <span className=\"text-xl font-bold text-[#00FF9D] mt-1 font-mono tracking-tight\">{annualHours.toLocaleString()} Hours</span>\n                </div>\n                <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01]\">\n                  <span className=\"text-[10px] text-white/40 font-mono block\">NET SAVINGS (YEAR 1)</span>\n                  <span className=\"text-xl font-bold text-[#009DFF] mt-1 font-mono tracking-tight\">${netSavings.toLocaleString()}</span>\n                </div>\n              </div>\n              <div className=\"text-center p-4 bg-white/[0.01] border border-white/5 rounded-xl\">\n                <span className=\"text-[10px] text-white/40 block font-mono\">ESTIMATED RETURN ON INVESTMENT</span>\n                <span className=\"text-3xl font-extrabold text-[#E4000F] mt-1 block font-mono tracking-tight\">{roi}% ROI</span>\n              </div>\n            </div>\n            <div className=\"pt-4 border-t border-white/5 text-[10px] font-mono text-white/30 flex justify-between\">\n              <span>ZERO DATA RETENTION</span>\n              <span>CALCULATED ON SOVEREIGN CODES</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic Detail Segment */}\n        <div className=\"p-6 lg:p-8 rounded-2xl border border-white/5 bg-[#04060b] space-y-6\">\n          <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n            <div>\n              <h3 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">Sovereign Target Architectures</h3>\n              <p className=\"text-xs text-white/40 font-light mt-0.5\">Explore the specialized agents running on our platform enclaves.</p>\n            </div>\n            <div className=\"flex gap-2 shrink-0\">\n              {([\"finance\", \"operations\"] as const).map((key) => (\n                <button\n                  key={key}\n                  onClick={() => setActiveDept(key)}\n                  className={`px-3 py-1.5 rounded-lg border text-xs font-semibold font-mono tracking-wider transition ${\n                    activeDept === key ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/30\" : \"bg-white/[0.01] text-white/50 border-white/5 hover:text-white\"\n                  }`}\n                >\n                  {DEPT_DETAILS[key].title}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center pt-2\">\n            <div className=\"lg:col-span-7 space-y-4\">\n              <div>\n                <span className=\"text-[9px] font-mono text-white/30 uppercase tracking-widest block\">THE CHALLENGE</span>\n                <p className=\"text-xs text-white/80 leading-relaxed font-light\">{currentDept.bottleneck}</p>\n              </div>\n\n              <div className=\"p-4 rounded-xl bg-white/[0.01] border border-white/5 space-y-2\">\n                <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-widest block\">GFF AUTONOMOUS NODE</span>\n                <h4 className=\"text-sm font-bold text-white\">{currentDept.agent}</h4>\n                <p className=\"text-xs text-white/60 leading-relaxed font-light\">{currentDept.description}</p>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-3\">\n                {currentDept.metrics.map((m, idx) => (\n                  <div key={idx} className=\"p-3 rounded-xl border border-white/5 bg-black/40 text-center\">\n                    <span className=\"text-[9px] font-mono text-white/40 uppercase block mb-1\">{m.label}</span>\n                    <span className=\"text-sm font-bold font-mono\" style={{ color: m.color }}>{m.value}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"lg:col-span-5 flex justify-center items-center bg-black/40 border border-white/5 rounded-2xl p-6 min-h-[180px]\">\n              {activeDept === \"finance\" ? (\n                <svg className=\"w-full max-w-[200px]\" viewBox=\"0 0 200 120\" fill=\"none\">\n                  <rect x=\"10\" y=\"40\" width=\"40\" height=\"40\" rx=\"6\" fill=\"#04060b\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n                  <text x=\"30\" y=\"65\" fill=\"#009DFF\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\">DB IN</text>\n                  <rect x=\"150\" y=\"40\" width=\"40\" height=\"40\" rx=\"6\" fill=\"#04060b\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" />\n                  <text x=\"170\" y=\"65\" fill=\"#00FF9D\" fontSize=\"8\" fontFamily=\"monospace\" textAnchor=\"middle\">AS-09</text>\n                  <path d=\"M50 60 H150\" stroke=\"white\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" strokeOpacity=\"0.4\" />\n                  <path d=\"M50 60 H150\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeDasharray=\"12 40\" strokeDashoffset=\"10\">\n                    <animate attributeName=\"stroke-dashoffset\" values=\"40;0\" dur=\"2s\" repeatCount=\"indefinite\" />\n                  </path>\n                </svg>\n              ) : (\n                <svg className=\"w-full max-w-[200px]\" viewBox=\"0 0 200 120\" fill=\"none\">\n                  <circle cx=\"100\" cy=\"60\" r=\"45\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 3\" strokeOpacity=\"0.3\" />\n                  <circle cx=\"100\" cy=\"60\" r=\"15\" fill=\"#04060b\" stroke=\"#00FF9D\" strokeWidth=\"2\" />\n                  <line x1=\"100\" y1=\"60\" x2=\"135\" y2=\"25\" stroke=\"#00FF9D\" strokeWidth=\"1.5\" strokeOpacity=\"0.7\">\n                    <animateTransform attributeName=\"transform\" type=\"rotate\" from=\"0 100 60\" to=\"360 100 60\" dur=\"4s\" repeatCount=\"indefinite\" />\n                  </line>\n                </svg>\n              )}\n            </div>\n          </div>\n        </div>\n\n        <PremiumCTA />\n      </div>\n    </InnerPageShell>\n  );","new_text":"\"use client\";\n\nimport React from \"react\";\nimport { ToolPageShell, ToolInputGroup, ToolCTA } from \"@/components/build/components\";\nimport { WizardStepperSystem } from \"@/components/build/WizardStepperSystem\";\nimport { calculateSharedROIEstimate } from \"@/lib/shared-validation\";\nimport { SharedROIInputs, SharedROIResult, SharedPriority } from \"@/lib/shared-validation\";\nimport { SHARED_PRIORITY_OPTIONS } from \"@/lib/shared-constants\";\n\nexport default function ROICalculatorPage() {\n  const initialData: SharedROIInputs = {\n    teamSize: 250, avgHourlyRate: 65, inefficientHoursPerWeek: 8, initialInvestment: 35000, priority: \"Reduce Costs\"\n  };\n\n  const steps = [\n    {\n      id: \"team\", label: \"Enterprise Scale\", description: \"Number of full-time employees impacted.\",\n      render: ({ data, onChange }: any) => (\n        <ToolInputGroup label=\"Team Size\" valueDisplay={`${data.teamSize} Employees`}>\n          <input type=\"range\" min=\"10\" max=\"1000\" step=\"10\" value={data.teamSize} onChange={(e) => onChange({ teamSize: Number(e.target.value) })} className=\"w-full accent-[#E4000F]\" />\n        </ToolInputGroup>\n      )\n    },\n    {\n      id: \"hours\", label: \"Operational Friction\", description: \"Inefficient hours spent per employee weekly.\",\n      render: ({ data, onChange }: any) => (\n        <ToolInputGroup label=\"Friction Hours\" valueDisplay={`${data.inefficientHoursPerWeek} Hours/Week`} accentColor=\"#009DFF\">\n          <input type=\"range\" min=\"1\" max=\"40\" value={data.inefficientHoursPerWeek} onChange={(e) => onChange({ inefficientHoursPerWeek: Number(e.target.value) })} className=\"w-full accent-[#009DFF]\" />\n        </ToolInputGroup>\n      )\n    },\n    {\n      id: \"rate\", label: \"Average Rate\", description: \"Blended hourly resource rate.\",\n      render: ({ data, onChange }: any) => (\n        <ToolInputGroup label=\"Average Hourly Rate\" valueDisplay={`$${data.avgHourlyRate}/Hour`} accentColor=\"#00FF9D\">\n          <input type=\"range\" min=\"25\" max=\"250\" step=\"5\" value={data.avgHourlyRate} onChange={(e) => onChange({ avgHourlyRate: Number(e.target.value) })} className=\"w-full accent-[#00FF9D]\" />\n        </ToolInputGroup>\n      )\n    },\n    {\n      id: \"invest\", label: \"Investment\", description: \"Initial setup allocation.\",\n      render: ({ data, onChange }: any) => (\n        <ToolInputGroup label=\"Initial Investment\" valueDisplay={`$${data.initialInvestment.toLocaleString()}`} accentColor=\"#9D00FF\">\n          <input type=\"range\" min=\"5000\" max=\"250000\" step=\"5000\" value={data.initialInvestment} onChange={(e) => onChange({ initialInvestment: Number(e.target.value) })} className=\"w-full accent-[#9D00FF]\" />\n        </ToolInputGroup>\n      )\n    },\n    {\n      id: \"priority\", label: \"Strategy Priority\", description: \"Choose target commercial focus.\",\n      render: ({ data, onChange }: any) => (\n        <select value={data.priority} onChange={(e) => onChange({ priority: e.target.value as SharedPriority })} className=\"w-full h-10 rounded-lg border border-white/10 bg-black text-white px-3 text-xs font-mono\">\n          {SHARED_PRIORITY_OPTIONS.map((opt) => (\n            <option key={opt.value} value={opt.value}>{opt.label}</option>\n          ))}\n        </select>\n      )\n    }\n  ];\n\n  return (\n    <ToolPageShell>\n      <WizardStepperSystem\n        toolName=\"Operational ROI Calculator\"\n        category=\"Executive Calculator\"\n        toolDescription=\"Quantify cost reductions, productivity reclaimed, and payback milestones of deploying autonomous enclaves.\"\n        steps={steps}\n        initialData={initialData}\n        summaryItems={(d: SharedROIInputs) => [\n          { label: \"Scale\", value: `${d.teamSize} FTEs` },\n          { label: \"Friction\", value: `${d.inefficientHoursPerWeek} hrs` },\n          { label: \"Rate\", value: `$${d.avgHourlyRate}/hr` },\n          { label: \"Allocated\", value: `$${d.initialInvestment.toLocaleString()}` },\n          { label: \"Target Focus\", value: d.priority, color: \"#009DFF\" }\n        ]}\n        onCompile={(d: SharedROIInputs) => calculateSharedROIEstimate(d)}\n        renderResult={(data: SharedROIInputs, res: SharedROIResult, onReset: () => void) => (\n          <div className=\"space-y-6 text-white animate-fadeIn\">\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n              <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030304]/80 text-center\">\n                <span className=\"text-[10px] font-mono text-white/40 block\">ANNUAL RESOURCE RECLAIMED</span>\n                <span className=\"text-3xl font-extrabold font-mono text-[#00FF9D] mt-2 block\">{res.annualHoursSaved.toLocaleString()} Hrs</span>\n              </div>\n              <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030304]/80 text-center\">\n                <span className=\"text-[10px] font-mono text-white/40 block\">NET COMMERCIAL SAVINGS</span>\n                <span className=\"text-3xl font-extrabold font-mono text-[#009DFF] mt-2 block\">${res.netSavings.toLocaleString()}</span>\n              </div>\n              <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030304]/80 text-center\">\n                <span className=\"text-[10px] font-mono text-white/40 block\">PAYBACK HORIZON</span>\n                <span className=\"text-3xl font-extrabold font-mono text-white mt-2 block\">{res.paybackMonths} Months</span>\n              </div>\n            </div>\n\n            <div className=\"p-6 rounded-2xl border border-[#009DFF]/20 bg-[#009DFF]/5 text-center space-y-2\">\n              <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-widest block font-bold\">MODELING METRIC PROJECTION</span>\n              <h3 className=\"text-2xl font-bold font-mono\">ESTIMATED FIRST-YEAR RETURN: {res.roiPercentage}% ROI</h3>\n              <p className=\"text-xs text-white/60 font-light max-w-lg mx-auto\">Calculated dynamically against zero-landing sovereign buffers. Deployment of autonomous nodes are modelled for near-zero compliance leakage.</p>\n            </div>\n\n            <div className=\"flex justify-between items-center pt-4 border-t border-white/5\">\n              <span className=\"text-[10px] text-white/30 font-mono\">0% retention modeling</span>\n              <button type=\"button\" onClick={onReset} className=\"px-4 h-8 rounded border border-white/10 text-xs text-white hover:bg-white/5 font-mono uppercase\">Reconfigure</button>\n            </div>\n            <ToolCTA />\n          </div>\n        )}\n        metricLabel=\"RECOVER HORIZON\"\n        metricValue=\"100% LOCAL\"\n      />\n    </ToolPageShell>\n  );\n}\n"}}}
