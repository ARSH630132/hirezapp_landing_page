{"ts":"2026-06-26T16:36:41.124Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"v773qlnw","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/build/WizardStepperSystem.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { ToolStepLayout, ToolSidebarProgress, ToolPreviewNotice } from \"./components\";\n\nexport interface WizardStep<T = any> {\n  id: string;\n  label: string;\n  description: string;\n  duration?: string;\n  validate?: (data: T) => string | null;\n  render: (params: {\n    data: T;\n    onChange: (newData: Partial<T>) => void;\n    error: string | null;\n  }) => React.ReactNode;\n}\n\ninterface WizardStepperSystemProps<T = any> {\n  toolName: string;\n  category: string;\n  toolDescription: string;\n  steps: WizardStep<T>[];\n  initialData: T;\n  summaryItems: (data: T) => { label: string; value: string; color?: string }[];\n  onCompile: (data: T) => Promise<any> | any;\n  renderResult: (data: T, result: any, onReset: () => void) => React.ReactNode;\n  compilingMessages?: string[];\n  metricLabel?: string;\n  metricValue?: string;\n}\n\nexport function WizardStepperSystem<T = any>({\n  toolName,\n  category,\n  toolDescription,\n  steps,\n  initialData,\n  summaryItems,\n  onCompile,\n  renderResult,\n  compilingMessages = [\n    \"Establishing secure network baseline...\",\n    \"Scanning database schemas...\",\n    \"Compiling sovereign execution graphs...\",\n    \"Synthesizing dynamic specifications...\"\n  ],\n  metricLabel,\n  metricValue\n}: WizardStepperSystemProps<T>) {\n  const [data, setData] = useState<T>(initialData);\n  const [currentStepIndex, setCurrentStepIndex] = useState(0);\n  const [error, setError] = useState<string | null>(null);\n  const [isCompiling, setIsCompiling] = useState(false);\n  const [compilingStep, setCompilingStep] = useState(0);\n  const [result, setResult] = useState<any>(null);\n  const [showResult, setShowResult] = useState(false);\n\n  const currentStep = steps[currentStepIndex];\n\n  useEffect(() => {\n    if (!isCompiling) return;\n    const interval = setInterval(() => {\n      setCompilingStep((prev) => {\n        if (prev < compilingMessages.length - 1) {\n          return prev + 1;\n        } else {\n          clearInterval(interval);\n          setResult(onCompile(data));\n          setIsCompiling(false);\n          setShowResult(true);\n          return prev;\n        }\n      });\n    }, 800);\n    return () => clearInterval(interval);\n  }, [isCompiling, data, compilingMessages, onCompile]);\n\n  const handleNext = () => {\n    setError(null);\n    if (currentStep.validate) {\n      const valErr = currentStep.validate(data);\n      if (valErr) {\n        setError(valErr);\n        return;\n      }\n    }\n    if (currentStepIndex < steps.length - 1) {\n      setCurrentStepIndex((prev) => prev + 1);\n    } else {\n      setIsCompiling(true);\n      setCompilingStep(0);\n    }\n  };\n\n  const handleBack = () => {\n    setError(null);\n    if (currentStepIndex > 0) {\n      setCurrentStepIndex((prev) => prev - 1);\n    }\n  };\n\n  const handleReset = () => {\n    setData(initialData);\n    setCurrentStepIndex(0);\n    setError(null);\n    setResult(null);\n    setShowResult(false);\n    setIsCompiling(false);\n  };\n\n  const handleDataChange = (newData: Partial<T>) => {\n    setError(null);\n    setData((prev) => ({ ...prev, ...newData }));\n  };\n\n  const handleStepClick = (index: number) => {\n    if (index === currentStepIndex) return;\n    if (index > currentStepIndex) {\n      for (let i = currentStepIndex; i < index; i++) {\n        if (steps[i].validate) {\n          const err = steps[i].validate!(data);\n          if (err) {\n            setError(`Step \"${steps[i].label}\" error: ${err}`);\n            setCurrentStepIndex(i);\n            return;\n          }\n        }\n      }\n    }\n    setError(null);\n    setCurrentStepIndex(index);\n  };\n\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      const tag = document.activeElement?.tagName;\n      if (tag === \"INPUT\" || tag === \"TEXTAREA\" || tag === \"SELECT\") {\n        if (e.key === \"Enter\" && tag === \"INPUT\") {\n          e.preventDefault();\n          handleNext();\n        }\n        return;\n      }\n      if (e.key === \"ArrowRight\" || e.key === \"Enter\") {\n        e.preventDefault();\n        handleNext();\n      } else if (e.key === \"ArrowLeft\" || e.key === \"Backspace\") {\n        e.preventDefault();\n        handleBack();\n      } else if (e.key === \"Escape\") {\n        e.preventDefault();\n        handleReset();\n      }\n    };\n    window.addEventListener(\"keydown\", handleKeyDown);\n    return () => window.removeEventListener(\"keydown\", handleKeyDown);\n  }, [currentStepIndex, data]);\n\n  const manifest = summaryItems(data);\n  const percentage = Math.round((currentStepIndex / (steps.length - 1)) * 100);\n\n  return (\n    <div className=\"w-full space-y-8\">\n      <div className=\"border-b border-white/5 pb-8 mb-4 flex flex-col md:flex-row md:items-end justify-between gap-6\">\n        <div className=\"space-y-3 max-w-4xl\">\n          <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">\n            {category}\n          </span>\n          <h1 className=\"text-3xl lg:text-5xl font-extrabold text-white tracking-tight leading-none\">\n            {toolName}\n          </h1>\n          <p className=\"text-white/60 text-xs lg:text-sm font-light max-w-2xl leading-relaxed\">\n            {toolDescription}\n          </p>\n        </div>\n        {metricLabel && metricValue && (\n          <div className=\"p-4 px-6 rounded-xl bg-white/[0.01] border border-white/5 flex flex-col items-start min-w-[200px] shrink-0\">\n            <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest\">{metricLabel}</span>\n            <span className=\"text-xl font-bold text-[#00FF9D] mt-1 font-mono tracking-tight\">{metricValue}</span>\n          </div>\n        )}\n      </div>\n\n      <AnimatePresence mode=\"wait\">\n        {isCompiling && (\n          <motion.div\n            key=\"compiling\"\n            initial={{ opacity: 0, scale: 0.98 }}\n            animate={{ opacity: 1, scale: 1 }}\n            exit={{ opacity: 0, scale: 1.02 }}\n            className=\"w-full max-w-4xl mx-auto min-h-[400px] rounded-2xl border border-white/5 bg-[#030306]/95 backdrop-blur-md p-8 lg:p-12 flex flex-col justify-between\"\n          >\n            <div className=\"space-y-8\">\n              <div className=\"flex items-center gap-4\">\n                <div className=\"relative w-10 h-10 shrink-0\">\n                  <div className=\"absolute inset-0 rounded-full border border-white/10\" />\n                  <div className=\"absolute inset-0 rounded-full border-t border-[#009DFF] animate-spin\" />\n                </div>\n                <div>\n                  <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">Sovereign Synthesizer Core</h3>\n                  <p className=\"text-[10px] text-[#00FF9D] font-mono\">STATUS: DYNAMIC_COMPILING_ACTIVE</p>\n                </div>\n              </div>\n\n              <div className=\"p-6 rounded-xl bg-black/60 border border-white/5 font-mono text-xs text-white/70 space-y-3 min-h-[200px] flex flex-col justify-end overflow-hidden relative\">\n                <div className=\"absolute inset-x-0 top-0 h-px bg-white/5 pointer-events-none\" />\n                <div className=\"space-y-2\">\n                  <p className=\"text-white/35 text-[10px]\">&gt; GFF SYSTEM AGENT INIT V16.2.9</p>\n                  <p className=\"text-white/35 text-[10px]\">&gt; ZERO-STORAGE MEMORY CONSOLE ONLINE...</p>\n                  {compilingMessages.slice(0, compilingStep + 1).map((msg, idx) => (\n                    <motion.div key={idx} initial={{ opacity: 0, x: -5 }} animate={{ opacity: 1, x: 0 }} className=\"flex items-start gap-2.5\">\n                      <span className=\"text-[#00FF9D] font-bold\">✔</span>\n                      <span className=\"text-white/95\">{msg}</span>\n                    </motion.div>\n                  ))}\n                  {compilingStep < compilingMessages.length - 1 && (\n                    <div className=\"flex items-center gap-2 text-white/50 animate-pulse\">\n                      <span className=\"inline-block w-1.5 h-3 bg-[#009DFF]\" />\n                      <span>Processing index {compilingStep + 1}...</span>\n                    </div>\n                  )}\n                </div>\n              </div>\n            </div>\n            <div className=\"border-t border-white/5 pt-6 text-[9px] font-mono text-white/30 flex justify-between items-center mt-4\">\n              <span>SECURITY PROTOCOL: AIR-GAPPED HARDWARE SHIELD</span>\n              <span>TOKEN BUFFER: 0% RETENTION ENFORCED</span>\n            </div>\n          </motion.div>\n        )}\n\n        {showResult && result && (\n          <motion.div key=\"result\" initial={{ opacity: 0, y: 15 }} animate={{ opacity: 1, y: 0 }} className=\"w-full\">\n            {renderResult(data, result, handleReset)}\n          </motion.div>\n        )}\n\n        {!isCompiling && !showResult && (\n          <motion.div key=\"wizard\" initial={{ opacity: 0 }} animate={{ opacity: 1 }} className=\"w-full\">\n            <ToolStepLayout\n              sidebar={\n                <div className=\"space-y-6\">\n                  <ToolSidebarProgress\n                    steps={steps.map((s) => ({ id: s.id, label: s.label, description: s.description, duration: s.duration }))}\n                    currentStepIndex={currentStepIndex}\n                    onStepClick={handleStepClick}\n                  />\n\n                  <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030305]/95 backdrop-blur-sm space-y-4 relative overflow-hidden group\">\n                    <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/20 to-transparent pointer-events-none\" />\n                    <div className=\"border-b border-white/5 pb-3\">\n                      <span className=\"text-[10px] font-mono text-[#00FF9D] font-bold uppercase tracking-wider block\">Live Variables Buffer</span>\n                      <h4 className=\"text-[9px] text-white/40 mt-0.5 font-mono\">REAL-TIME MEMORY REGISTER</h4>\n                    </div>\n\n                    <div className=\"space-y-3\">\n                      {manifest.map((item, idx) => (\n                        <div key={idx} className=\"flex justify-between items-start gap-4 text-xs font-light py-1 border-b border-white/[0.02] last:border-0\">\n                          <span className=\"text-white/40 font-mono text-[9px] uppercase\">{item.label}</span>\n                          <span className=\"font-bold text-white text-right max-w-[200px] truncate\" style={item.color ? { color: item.color } : undefined}>\n                            {item.value || <span className=\"text-white/10 font-mono font-normal\">WAITING_INPUT</span>}\n                          </span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n\n                  <ToolPreviewNotice />\n                </div>\n              }\n              content={\n                <div className=\"p-6 lg:p-8 rounded-2xl border border-white/5 bg-[#030306]/90 backdrop-blur-md space-y-8 flex flex-col justify-between min-h-[480px]\">\n                  <div className=\"space-y-6\">\n                    <div className=\"border-b border-white/5 pb-4 space-y-1\">\n                      <div className=\"flex items-center gap-2\">\n                        <span className=\"text-[9px] font-mono px-2 py-0.5 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF] uppercase font-bold tracking-wider\">\n                          GATE {currentStepIndex + 1} OF {steps.length}\n                        </span>\n                        {currentStep.duration && (\n                          <span className=\"text-[9px] font-mono text-white/30 uppercase\">\n                            Est: {currentStep.duration}\n                          </span>\n                        )}\n                      </div>\n                      <h2 className=\"text-xl font-bold text-white tracking-tight\">{currentStep.label}</h2>\n                      <p className=\"text-white/50 text-xs font-light max-w-2xl\">{currentStep.description}</p>\n                    </div>\n\n                    <div className=\"py-2 min-h-[160px]\">\n                      {currentStep.render({ data, onChange: handleDataChange, error })}\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-4 border-t border-white/5 pt-6 mt-4\">\n                    <AnimatePresence>\n                      {error && (\n                        <motion.div initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: 10 }} role=\"alert\" aria-live=\"polite\" className=\"p-4 rounded-xl bg-[#E4000F]/5 border border-[#E4000F]/15 flex items-start gap-3\">\n                          <div className=\"p-1.5 rounded-md bg-[#E4000F]/10 border border-[#E4000F]/20 text-[#E4000F] shrink-0 font-bold text-xs\">!</div>\n                          <div>\n                            <h4 className=\"text-[10px] font-mono font-bold text-[#E4000F] uppercase tracking-wider\">Validation Interrupted</h4>\n                            <p className=\"text-xs text-white/80 mt-0.5 font-light leading-relaxed\">{error}</p>\n                          </div>\n                        </motion.div>\n                      )}\n                    </AnimatePresence>\n\n                    <div className=\"flex items-center justify-between gap-4\">\n                      <button\n                        type=\"button\"\n                        onClick={handleBack}\n                        disabled={currentStepIndex === 0}\n                        className={`px-5 h-[42px] rounded-lg border text-xs font-semibold tracking-wider uppercase transition flex items-center gap-2 ${\n                          currentStepIndex === 0 ? \"border-white/5 text-white/10 cursor-not-allowed\" : \"border-white/10 text-white/70 hover:border-white/20 hover:text-white\"\n                        }`}\n                      >\n                        <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M15 19l-7-7 7-7\" />\n                        </svg>\n                        <span>Back</span>\n                      </button>\n\n                      {currentStepIndex > 0 && (\n                        <button type=\"button\" onClick={handleReset} className=\"text-[10px] font-mono text-white/30 hover:text-[#E4000F] uppercase transition\">\n                          [Reset]\n                        </button>\n                      )}\n\n                      <button\n                        type=\"button\"\n                        onClick={handleNext}\n                        className=\"px-6 h-[42px] rounded-lg text-xs font-bold uppercase tracking-wider flex items-center gap-2 bg-[#009DFF] hover:bg-[#009DFF]/90 text-black transition font-mono shadow-[0_0_15px_rgba(0,157,255,0.25)] hover:shadow-[0_0_20px_rgba(0,157,255,0.4)]\"\n                      >\n                        <span>{currentStepIndex === steps.length - 1 ? \"Sovereign Compile\" : \"Next Gate\"}</span>\n                        <svg className=\"w-3 h-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n                        </svg>\n                      </button>\n                    </div>\n\n                    <div className=\"text-[9px] font-mono text-white/25 flex justify-between items-center pt-2\">\n                      <span>Shortcuts: [←: Back] • [→/Enter: Next]</span>\n                      <span>[Esc: Reset]</span>\n                    </div>\n                  </div>\n                </div>\n              }\n            />\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"}}}
