{"ts":"2026-06-26T19:50:23.888Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"fhfn8isd","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { ToolPageShell, ToolCTA } from \"@/components/build/components\";\n\nexport default function ProposalStudioPage() {\n  const [data, setData] = useState({\n    orgName: \"\", industry: \"\", size: \"\", challenge: \"\",\n    outcomes: [] as string[], path: \"\", timeline: \"\",\n    budget: \"\", geography: \"\", stakeholders: [] as string[]\n  });\n\n  const [step, setStep] = useState(0);\n  const [err, setErr] = useState<string | null>(null);\n  const [state, setState] = useState<\"edit\" | \"compiling\" | \"done\">(\"edit\");\n  const [compIdx, setCompIdx] = useState(0);\n  const [tab, setTab] = useState(\"summary\");\n  const [dls, setDls] = useState<Record<string, string>>({});\n\n  const compLogs = [\n    \"Initializing Sovereign Compiler...\",\n    \"Verifying single-tenant VPC boundaries...\",\n    \"Synthesizing dynamic Statement of Work...\"\n  ];\n\n  useEffect(() => {\n    if (state !== \"compiling\") return;\n    if (compIdx < compLogs.length) {\n      const t = setTimeout(() => setCompIdx(p => p + 1), 400);\n      return () => clearTimeout(t);\n    }\n    setState(\"done\");\n  }, [state, compIdx]);\n\n  const handleNext = () => {\n    setErr(null);\n    if (step === 0 && (!data.industry || !data.size)) return setErr(\"Strategic Domain and Scale are required.\");\n    if (step === 1 && (!data.challenge || data.outcomes.length === 0)) return setErr(\"Challenge and Outcome are required.\");\n    if (step === 2 && (!data.path || !data.timeline)) return setErr(\"Engagement Path and Timeline are required.\");\n    \n    if (step < 3) setStep(p => p + 1);\n    else { setState(\"compiling\"); setCompIdx(0); }\n  };\n\n  const handleBack = () => { setErr(null); if (step > 0) setStep(p => p - 1); };\n\n  const toggleVal = (field: \"outcomes\" | \"stakeholders\", val: string) => {\n    setData(p => ({\n      ...p,\n      [field]: p[field].includes(val) ? p[field].filter((x: string) => x !== val) : [...p[field], val]\n    }));\n  };\n\n  const triggerDl = (f: string) => {\n    if (dls[f]) return;\n    setDls(p => ({ ...p, [f]: \"Exporting...\" }));\n    setTimeout(() => setDls(p => ({ ...p, [f]: \"✓ Ready\" })), 1000);\n  };\n\n  const activePath = data.path ? {\n    Garage: \"GFF Garage — 4 Weeks Strategy & Sandbox Sprint\",\n    Foundry: \"GFF Foundry — 8-12 Weeks VPC Platform Ingest\",\n    Factory: \"GFF Factory — 12-16 Weeks Massive Agent Scaling\",\n    Operate: \"GFF Operate — Ongoing Day-2 Managed Sovereignty & SLAs\"\n  }[data.path as \"Garage\"|\"Foundry\"|\"Factory\"|\"Operate\"] : \"\";\n\n  return (\n    <ToolPageShell showContact={state !== \"done\"}>\n      <div className=\"mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-4 font-sans\">\n        <div>\n          <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">Phase 3 Strategic Studio</span>\n          <h1 className=\"text-xl md:text-2xl font-black text-white\">Sovereign SOW <span className=\"text-white/50\">Proposal Studio</span></h1>\n        </div>\n        {state === \"edit\" && (\n          <div className=\"flex gap-2 font-mono text-[9px] bg-white/[0.01] border border-white/5 p-2 rounded-lg\">\n            <span>GATES:</span>\n            {[0, 1, 2, 3].map(s => (\n              <span key={s} className={`px-1.5 rounded font-bold ${step === s ? \"bg-[#009DFF] text-black\" : step > s ? \"text-[#00FF9D]\" : \"text-white/35\"}`}>{s + 1}</span>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {state === \"edit\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 text-xs text-white/80\">\n          <div className=\"lg:col-span-7 bg-[#030306]/95 border border-white/5 rounded-xl p-5 min-h-[380px] flex flex-col justify-between relative\">\n            <div className=\"space-y-4\">\n              <span className=\"text-[9px] font-mono uppercase text-[#009DFF] font-bold\">Gate {step + 1} of 4 • {[\"Corporate Scale\", \"Strategic Intent\", \"Deployment Pathway\", \"Boundaries\"][step]}</span>\n              \n              {step === 0 && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <input type=\"text\" placeholder=\"Organization Name (Optional)\" value={data.orgName} onChange={e => setData({...data, orgName: e.target.value})} className=\"w-full h-10 bg-white/[0.02] border border-white/10 rounded px-3 text-white focus:outline-none focus:border-[#009DFF]\" />\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Domain Industry *</label>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      {[\"banking\", \"healthcare\", \"energy\", \"public-sector\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, industry: id})} className={`p-2.5 rounded border text-left font-bold ${data.industry === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Deployment Scale *</label>\n                    <div className=\"grid grid-cols-3 gap-2\">\n                      {[\"mid-market\", \"enterprise\", \"conglomerate\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, size: id})} className={`p-2.5 rounded border font-bold text-center ${data.size === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 1 && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Primary Strategic Challenge *</label>\n                    {[\"orch_lag\", \"compliance_barrier\", \"drift_deficits\"].map(id => (\n                      <button key={id} onClick={() => setData({...data, challenge: id})} className={`w-full p-2.5 rounded border text-left transition-all text-xs flex items-center gap-2 ${data.challenge === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>\n                        <div className={`w-3 h-3 rounded-full border flex items-center justify-center ${data.challenge === id ? \"border-[#009DFF]\" : \"border-white/20\"}`}>{data.challenge === id && <div className=\"w-1.5 h-1.5 bg-[#009DFF] rounded-full\" />}</div>\n                        <span className=\"font-bold\">{id === \"orch_lag\" ? \"Multi-System Orchestration Lag\" : id === \"compliance_barrier\" ? \"Sovereign Compliance Boundaries\" : \"Behavioral Model Drift & Safety\"}</span>\n                      </button>\n                    ))}\n                  </div>\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Priority Strategic Outcomes *</label>\n                    <div className=\"grid grid-cols-3 gap-2 text-center font-bold\">\n                      {[\"latency\", \"isolation\", \"drift_guard\"].map(id => (\n                        <button key={id} onClick={() => toggleVal(\"outcomes\", id)} className={`p-2.5 rounded border ${data.outcomes.includes(id) ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 2 && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Preferred GFF Engagement Path *</label>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      {[\"Garage\", \"Foundry\", \"Factory\", \"Operate\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, path: id})} className={`p-3 rounded border text-left ${data.path === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] hover:border-white/10\"}`}>\n                          <div className=\"font-black text-[11px]\">{id === \"Garage\" ? \"GFF Garage\" : id === \"Foundry\" ? \"GFF Foundry\" : id === \"Factory\" ? \"GFF Factory\" : \"GFF Operate\"}</div>\n                          <span className=\"text-[7.5px] text-white/40 uppercase block font-mono\">{id === \"Garage\" ? \"Co-Design Sprint\" : id === \"Foundry\" ? \"VPC Platform\" : id === \"Factory\" ? \"Fleet Scale\" : \"SecOps SLA\"}</span>\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Target Implementation Timeline *</label>\n                    <div className=\"grid grid-cols-3 gap-2\">\n                      {[\"immediate\", \"strategic\", \"transformational\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, timeline: id})} className={`p-2.5 rounded border font-bold text-center uppercase ${data.timeline === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>{id}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 3 && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <div className=\"space-y-1.5\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Corporate Budget Range (Optional)</label>\n                    <div className=\"grid grid-cols-2 gap-2 font-bold text-center\">\n                      {[\"< $250k\", \"$250k - $1M\", \"$1M - $5M\", \"$5M+\"].map(b => (\n                        <button key={b} onClick={() => setData({...data, budget: b})} className={`p-2 rounded border ${data.budget === b ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-black hover:border-white/10\"}`}>{b}</button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"grid grid-cols-2 gap-3\">\n                    <div>\n                      <label className=\"block text-[9px] font-mono text-white/40 uppercase mb-1\">Geography (Optional)</label>\n                      <select value={data.geography} onChange={e => setData({...data, geography: e.target.value})} className=\"w-full h-9 bg-black border border-white/10 rounded px-2 text-white\">\n                        <option value=\"\">-- Auto Route --</option>\n                        <option value=\"na\">North America</option>\n                        <option value=\"eu\">European Union</option>\n                        <option value=\"apac\">Asia-Pacific</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-[9px] font-mono text-white/40 uppercase mb-1\">Stakeholders (Optional)</label>\n                      <div className=\"flex gap-1\">\n                        {[\"board\", \"cto\", \"security\"].map(s => (\n                          <button key={s} onClick={() => toggleVal(\"stakeholders\", s)} className={`px-2 py-1 rounded text-[8px] font-mono uppercase border ${data.stakeholders.includes(s) ? \"bg-[#009DFF]/10 border-[#009DFF] text-[#009DFF]\" : \"border-white/5 bg-black text-white/40\"}`}>{s}</button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            <div className=\"mt-4 border-t border-white/5 pt-3 flex justify-between items-center text-xs\">\n              <button type=\"button\" onClick={handleBack} disabled={step === 0} className={`px-3 h-8 rounded border uppercase font-bold ${step === 0 ? \"border-white/5 text-white/20\" : \"border-white/10 text-white hover:bg-white/5\"}`}>Back</button>\n              {err && <span className=\"text-[#E4000F] font-mono text-[9px]\">{err}</span>}\n              <button type=\"button\" onClick={handleNext} className=\"px-4 h-8 rounded bg-[#009DFF] text-black font-bold uppercase hover:bg-[#009DFF]/80\">Next Gate</button>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-5 bg-[#030305]/95 border border-white/5 rounded-xl p-4 font-mono text-[10px] space-y-3\">\n            <span className=\"font-bold text-[#00FF9D] tracking-wider block border-b border-white/5 pb-1\">SOW OUTLINE LIVE PREVIEW</span>\n            <div className=\"space-y-1.5\">\n              <div>ORGANIZATION: <span className=\"text-white font-bold\">{data.orgName || \"Sovereign Enterprise\"}</span></div>\n              <div>INDUSTRY: <span className=\"text-[#009DFF] font-bold\">{data.industry.toUpperCase() || \"AWAITING...\"}</span></div>\n              <div>SCALE: <span className=\"text-white font-bold\">{data.size.toUpperCase() || \"AWAITING...\"}</span></div>\n            </div>\n            <div className=\"pt-2 border-t border-white/5 space-y-1\">\n              <div className=\"font-bold\">I. Core Directive:</div>\n              <p className=\"text-white/40 pl-2\">\n                {data.industry === \"healthcare\" ? \"→ Air-gapped PHI ingestion container validation\" : \"→ Targeted sovereign agent execution mesh\"}\n              </p>\n              <div className=\"font-bold\">II. Engagement Path:</div>\n              <span className=\"text-[#9D00FF] pl-2 font-bold\">{data.path || \"AWAITING...\"}</span>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {state === \"compiling\" && (\n        <div className=\"max-w-md mx-auto text-center font-mono py-12 bg-[#030306] border border-white/5 rounded-xl p-6\">\n          <div className=\"w-12 h-12 border border-t-[#00FF9D] rounded-full animate-spin mx-auto mb-4\" />\n          <h3 className=\"text-xs font-bold text-white uppercase tracking-widest\">Compiling SOW Blueprint...</h3>\n          <div className=\"text-[9px] text-white/50 text-left bg-black p-3 rounded mt-3 space-y-1\">\n            {compLogs.slice(0, compIdx).map((log, i) => (\n              <div key={i}>✓ {log}</div>\n            ))}\n          </div>\n        </div>\n      )}\n\n      {state === \"done\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 text-xs animate-fadeIn font-sans\">\n          <div className=\"lg:col-span-8 bg-[#030306]/95 border border-white/5 rounded-xl overflow-hidden\">\n            <div className=\"p-4 bg-white/[0.01] border-b border-white/5 flex justify-between font-mono text-[10px]\">\n              <div>\n                <span className=\"text-[8px] text-[#00FF9D] border border-[#00FF9D]/20 px-1.5 py-0.5 rounded font-black tracking-wider uppercase\">SOW SECURED</span>\n                <h3 className=\"text-white font-bold mt-1.5\">{data.orgName || \"Sovereign Enterprise\"} • Custom AI Spec</h3>\n              </div>\n              <span className=\"text-white/30 text-right\">HASH: SHA-256</span>\n            </div>\n\n            <div className=\"flex border-b border-white/5 bg-black/15 font-mono text-[9px]\">\n              {[\"summary\", \"topology\", \"sow\", \"commercials\"].map(t => (\n                <button key={t} onClick={() => setTab(t)} className={`flex-1 py-2 text-center uppercase font-bold border-b-2 ${tab === t ? \"border-[#009DFF] text-white\" : \"border-transparent text-white/40\"}`}>{t}</button>\n              ))}\n            </div>\n\n            <div className=\"p-5 space-y-4\">\n              {tab === \"summary\" && (\n                <div className=\"space-y-2 text-white/70\">\n                  <h4 className=\"text-[10px] font-mono text-[#009DFF] uppercase font-bold\">I. Executive Summary</h4>\n                  <p className=\"font-light leading-relaxed\">\n                    This customized Statement of Work details GFF node deployment for <span className=\"text-white font-bold\">{data.industry.toUpperCase()}</span>.\n                    By running zero-retention micro-agent orchestrators inside private VPC enclaves, GFF fully resolves core challenges around <span className=\"text-white font-bold\">{data.challenge === \"orch_lag\" ? \"Orchestration Latency\" : \"Sovereign Compliance Limits\"}</span>.\n                  </p>\n                </div>\n              )}\n\n              {tab === \"topology\" && (\n                <div className=\"space-y-3 text-white/70\">\n                  <h4 className=\"text-[10px] font-mono text-[#9D00FF] uppercase font-bold\">I. Node Topology Map</h4>\n                  <svg className=\"w-full max-w-xs h-24 mx-auto\" viewBox=\"0 0 200 80\">\n                    <rect x=\"2\" y=\"2\" width=\"196\" height=\"76\" rx=\"4\" fill=\"none\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"2 2\" />\n                    <circle cx=\"100\" cy=\"40\" r=\"10\" fill=\"#000\" stroke=\"#9D00FF\" />\n                    <rect x=\"15\" y=\"25\" width=\"45\" height=\"30\" rx=\"3\" fill=\"rgba(0,157,255,0.01)\" stroke=\"#009DFF\" />\n                    <rect x=\"140\" y=\"25\" width=\"45\" height=\"30\" rx=\"3\" fill=\"rgba(0,255,157,0.01)\" stroke=\"#00FF9D\" />\n                    <path d=\"M60 40 H90 M110 40 H140\" stroke=\"rgba(255,255,255,0.1)\" strokeDasharray=\"1\" />\n                    <text x=\"37\" y=\"42\" fill=\"white\" fontSize=\"5\" textAnchor=\"middle\">Ingress</text>\n                    <text x=\"162\" y=\"42\" fill=\"white\" fontSize=\"5\" textAnchor=\"middle\">Sovereign Node</text>\n                  </svg>\n                  {activePath && <p className=\"font-mono text-[9px] bg-white/[0.01] p-2 border border-white/5 rounded text-white\">{activePath}</p>}\n                </div>\n              )}\n\n              {tab === \"sow\" && (\n                <div className=\"space-y-2.5 font-mono text-[9px] text-white/60\">\n                  <h4 className=\"text-[10px] text-[#00FF9D] uppercase font-bold font-sans\">I. Deliverable Phases</h4>\n                  <div className=\"p-3 bg-white/[0.005] border border-white/5 rounded\">\n                    <span className=\"text-white/40 block font-bold\">PHASE 1: VPC Boundary Seal</span>\n                    <p className=\"mt-0.5\">Provision secure single-tenant computing memories with 0% data retention.</p>\n                  </div>\n                  <div className=\"p-3 bg-white/[0.005] border border-white/5 rounded\">\n                    <span className=\"text-white/40 block font-bold\">PHASE 2: Ingestion Optimizations</span>\n                    <p className=\"mt-0.5\">Map API interfaces to GFF orchestrators to eliminate processing lag.</p>\n                  </div>\n                </div>\n              )}\n\n              {tab === \"commercials\" && (\n                <div className=\"space-y-3 text-white/70\">\n                  <h4 className=\"text-[10px] font-mono text-[#E4000F] uppercase font-bold\">I. Pricing & SLAs</h4>\n                  <div className=\"grid grid-cols-2 gap-2 text-[9px] font-mono\">\n                    <div className=\"p-3 rounded bg-black border border-white/5\">\n                      <span className=\"text-white/45 block\">Isolation Standard SLA</span>\n                      <span className=\"text-white font-bold block mt-0.5\">99.99% Node isolation</span>\n                    </div>\n                    <div className=\"p-3 rounded bg-black border border-white/5\">\n                      <span className=\"text-white/45 block\">VPC Annual License</span>\n                      <span className=\"text-[#00FF9D] font-bold block mt-0.5\">{data.budget || \"Strategic Allocation\"}</span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-4 space-y-4\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-xl p-4 font-mono\">\n              <span className=\"text-[9px] text-white/40 font-bold block border-b border-white/5 pb-1 mb-3\">SOW COMPILED ARTIFACTS</span>\n              <div className=\"space-y-2 text-[10px]\">\n                {[\"SOW_Sovereign.pdf\", \"Strategy_Deck.pptx\"].map(f => (\n                  <div key={f} className=\"p-3 rounded border border-white/5 bg-black flex justify-between items-center\">\n                    <span className=\"font-bold text-white/80\">{f.split(\".\")[0].toUpperCase()}</span>\n                    <button onClick={() => triggerDl(f)} className=\"px-2 py-1 rounded bg-white/5 border border-white/10 hover:bg-white/10 text-[8px] text-white font-mono\">{dls[f] || \"EXPORT\"}</button>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/90 text-[10px] leading-relaxed text-white/45 space-y-3 font-mono\">\n              <span className=\"text-[#E4000F] font-bold block uppercase text-[8px]\">Transient Guard Enforced</span>\n              <p>Details remain in localized client-side transient memories and won't be saved on our database hubs.</p>\n              <button onClick={() => {\n                setData({ orgName: \"\", industry: \"\", size: \"\", challenge: \"\", outcomes: [], path: \"\", timeline: \"\", budget: \"\", geography: \"\", stakeholders: [] });\n                setStep(0); setState(\"edit\"); setDls({});\n              }} className=\"w-full h-8 border border-white/10 text-[9px] font-bold text-white hover:bg-white/5 rounded uppercase transition-colors\">Reconfigure Draft</button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      <div className=\"mt-12\">\n        <ToolCTA />\n      </div>\n    </ToolPageShell>\n  );\n}\n"}}}
