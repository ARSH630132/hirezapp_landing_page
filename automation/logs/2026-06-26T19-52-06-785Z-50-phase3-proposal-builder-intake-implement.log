{"ts":"2026-06-26T19:48:58.567Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"5cxo9q33","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { ToolPageShell, ToolCTA } from \"@/components/build/components\";\n\n// Option lists\nconst INDUSTRIES = [\n  { id: \"banking\", title: \"Banking & Finance\", icon: \"🏛️\", desc: \"Sovereign ledgers, multi-agent audits\" },\n  { id: \"healthcare\", title: \"Healthcare & Life Sci\", icon: \"🔬\", desc: \"HIPAA air-gapped clinical trials\" },\n  { id: \"energy\", title: \"Energy & Infrastructure\", icon: \"⚡\", desc: \"Edge grid telemetry and security\" },\n  { id: \"public-sector\", title: \"Public Sector & Defense\", icon: \"🛡️\", desc: \"Sovereign regulatory containment\" },\n  { id: \"telecom\", title: \"Telecom & Networks\", icon: \"📡\", desc: \"Low-latency multi-agent routers\" },\n  { id: \"retail\", title: \"Retail & Supply Chain\", icon: \"📦\", desc: \"Supply chain workflow orchestration\" }\n];\n\nconst COMPANY_SIZES = [\n  { id: \"mid-market\", title: \"Growth Enterprise\", desc: \"500 - 2k headcount\" },\n  { id: \"enterprise\", title: \"Core Enterprise\", desc: \"2k - 10k headcount\" },\n  { id: \"conglomerate\", title: \"Global Sovereign\", desc: \"10k+ headcount\" }\n];\n\nconst CHALLENGES = [\n  { id: \"orch_lag\", title: \"Multi-System Orchestration Lag\", desc: \"Desynchronized legacy systems causing operational blind spots.\" },\n  { id: \"compliance_barrier\", title: \"Sovereign Compliance Barriers\", desc: \"Strict jurisdictional data borders requiring 0% cloud persistence.\" },\n  { id: \"drift_deficits\", title: \"Model Behavior & Safety Drift\", desc: \"Autonomous run deviation from strict corporate guidelines.\" }\n];\n\nconst OUTCOMES = [\n  { id: \"latency\", title: \"Sub-150ms Node Latency\", desc: \"Instantaneous execution pathways across APIs.\" },\n  { id: \"isolation\", title: \"100% Air-Gapped Isolation\", desc: \"Complete data encapsulation inside private tenant memory.\" },\n  { id: \"drift_guard\", title: \"Continuous Guardrails & Auditing\", desc: \"Cryptographically locked behavior rules.\" }\n];\n\nconst ENGAGEMENT_PATHS = [\n  { id: \"Garage\", title: \"GFF Garage\", tagline: \"Co-Design Enclave\", desc: \"Rapid strategy sprint. Deploy isolated sandbox in 4 weeks.\", duration: \"4 Weeks\", color: \"#009DFF\" },\n  { id: \"Foundry\", title: \"GFF Foundry\", tagline: \"Platform Integration\", desc: \"Core engineering. Deploy secure orchestrator in 8-12 weeks.\", duration: \"8-12 Weeks\", color: \"#9D00FF\" },\n  { id: \"Factory\", title: \"GFF Factory\", tagline: \"Fleet Industrialization\", desc: \"Roll out dozens of specialized custom fine-tuned agent nodes.\", duration: \"12-16 Weeks\", color: \"#00FF9D\" },\n  { id: \"Operate\", title: \"GFF Operate\", tagline: \"Day-2 Managed SecOps\", desc: \"Persistent maintenance, security telemetry, and regular audits.\", duration: \"Ongoing SLA\", color: \"#E4000F\" }\n];\n\nconst TIMELINES = [\n  { id: \"immediate\", title: \"Immediate Acceleration\", desc: \"1 - 3 months horizon\" },\n  { id: \"strategic\", title: \"Strategic Integration\", desc: \"3 - 6 months horizon\" },\n  { id: \"transformational\", title: \"Transformational Shift\", desc: \"6 - 12 months horizon\" }\n];\n\nconst BUDGETS = [\n  { id: \"tier1\", title: \"Strategic Discovery (Under $250k)\" },\n  { id: \"tier2\", title: \"Production Deployment ($250k - $1M)\" },\n  { id: \"tier3\", title: \"Industrial Enterprise ($1M - $5M)\" },\n  { id: \"tier4\", title: \"Sovereign Infrastructure ($5M+)\" }\n];\n\nconst GEOGRAPHIES = [\n  { id: \"na\", title: \"North America\", sub: \"US/CA VPC\" },\n  { id: \"eu\", title: \"European Union\", sub: \"GDPR isolated\" },\n  { id: \"apac\", title: \"Asia-Pacific\", sub: \"APAC hubs\" },\n  { id: \"global\", title: \"Decentralized Sovereign\", sub: \"Multi-jurisdictional mesh\" }\n];\n\nconst STAKEHOLDERS = [\n  { id: \"board\", title: \"Board of Directors\" },\n  { id: \"cto_cio\", title: \"Office of CIO/CTO\" },\n  { id: \"compliance\", title: \"Security Council\" },\n  { id: \"business_lead\", title: \"LOB Executives\" }\n];\n\nexport default function ProposalStudioPage() {\n  const [data, setData] = useState({\n    organizationName: \"\",\n    industry: \"\",\n    companySize: \"\",\n    primaryChallenge: \"\",\n    priorityOutcomes: [] as string[],\n    preferredEngagementPath: \"\",\n    targetTimeline: \"\",\n    budgetRange: \"\",\n    geography: \"\",\n    stakeholders: [] as string[]\n  });\n\n  const [activeStep, setActiveStep] = useState(0);\n  const [error, setError] = useState<string | null>(null);\n  const [appState, setAppState] = useState<\"edit\" | \"compiling\" | \"completed\">(\"edit\");\n  const [compilingIndex, setCompilingIndex] = useState(0);\n  const [activeTab, setActiveTab] = useState(\"summary\");\n  const [downloads, setDownloads] = useState<Record<string, string>>({});\n\n  const compLogs = [\n    \"Initializing GFF Proposal Compiler v4.2...\",\n    \"Verifying single-tenant network boundaries...\",\n    \"Structuring customizable Statement of Work...\",\n    \"Securing blueprint hash with VRAM isolation...\",\n    \"Compiling strategic deployment timeline...\"\n  ];\n\n  useEffect(() => {\n    if (appState !== \"compiling\") return;\n    if (compilingIndex < compLogs.length) {\n      const t = setTimeout(() => setCompilingIndex(p => p + 1), 500);\n      return () => clearTimeout(t);\n    }\n    setAppState(\"completed\");\n  }, [appState, compilingIndex]);\n\n  const validateStep = (step: number) => {\n    setError(null);\n    if (step === 0 && (!data.industry || !data.companySize)) {\n      setError(\"Please select Industry and Company Size to proceed.\");\n      return false;\n    }\n    if (step === 1 && (!data.primaryChallenge || data.priorityOutcomes.length === 0)) {\n      setError(\"Please select Primary Challenge and at least one Priority Outcome.\");\n      return false;\n    }\n    if (step === 2 && (!data.preferredEngagementPath || !data.targetTimeline)) {\n      setError(\"Please select Preferred Engagement Path and Target Timeline.\");\n      return false;\n    }\n    return true;\n  };\n\n  const handleNext = () => {\n    if (validateStep(activeStep)) {\n      if (activeStep < 3) setActiveStep(p => p + 1);\n      else {\n        setCompilingIndex(0);\n        setAppState(\"compiling\");\n      }\n    }\n  };\n\n  const toggleOutcome = (id: string) => {\n    setData(p => ({\n      ...p,\n      priorityOutcomes: p.priorityOutcomes.includes(id)\n        ? p.priorityOutcomes.filter(x => x !== id)\n        : [...p.priorityOutcomes, id]\n    }));\n  };\n\n  const triggerDownload = (name: string) => {\n    if (downloads[name]) return;\n    setDownloads(p => ({ ...p, [name]: \"Downloading...\" }));\n    setTimeout(() => {\n      setDownloads(p => ({ ...p, [name]: \"✓ Exported\" }));\n    }, 1200);\n  };\n\n  const currentPath = ENGAGEMENT_PATHS.find(p => p.id === data.preferredEngagementPath);\n\n  return (\n    <ToolPageShell showContact={appState !== \"completed\"}>\n      <div className=\"mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-6\">\n        <div>\n          <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">Strategic Enterprise Workspace</span>\n          <h1 className=\"text-2xl md:text-3xl font-extrabold text-white tracking-tight\">\n            Sovereign SOW <span className=\"text-white/50\">Proposal Studio</span>\n          </h1>\n          <p className=\"text-white/40 text-xs mt-1 font-light\">\n            Model customized agentic architectures, workloads, and Statement of Work specifications locally in VPC VRAM.\n          </p>\n        </div>\n\n        {appState === \"edit\" && (\n          <div className=\"flex items-center gap-2 bg-[#08080c] border border-white/5 px-4 py-2 rounded-xl font-mono text-[10px]\">\n            <span className=\"text-white/35 mr-1\">DESIGN GATES:</span>\n            {[0, 1, 2, 3].map((s) => (\n              <button\n                key={s}\n                onClick={() => { if (s < activeStep) setActiveStep(s); }}\n                className={`w-5 h-5 rounded flex items-center justify-center font-bold ${\n                  activeStep === s ? \"bg-[#009DFF] text-black\" : activeStep > s ? \"bg-[#00FF9D]/15 text-[#00FF9D]\" : \"border border-white/10 text-white/30\"\n                }`}\n              >\n                {s + 1}\n              </button>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {appState === \"edit\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          {/* Form Side */}\n          <div className=\"lg:col-span-7\">\n            <div className=\"bg-[#030306]/90 border border-white/5 rounded-2xl p-6 min-h-[460px] flex flex-col justify-between relative overflow-hidden\">\n              <div className=\"space-y-6\">\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n                  <span className=\"text-[9px] font-mono uppercase font-bold text-[#009DFF]\">\n                    Gate {activeStep + 1} of 4 • {[\"Corporate Profile\", \"Operational Intent\", \"Strategic Model\", \"Local Parameters\"][activeStep]}\n                  </span>\n                  <span className=\"text-[9px] font-mono text-white/30\">VRAM TRANSIENT MODE</span>\n                </div>\n\n                {activeStep === 0 && (\n                  <div className=\"space-y-5 animate-fadeIn\">\n                    <div>\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase mb-2\">Organization Name (Optional)</label>\n                      <input\n                        type=\"text\"\n                        placeholder=\"e.g. Apex Global Systems\"\n                        value={data.organizationName}\n                        onChange={(e) => setData({ ...data, organizationName: e.target.value })}\n                        className=\"w-full h-10 bg-white/[0.02] border border-white/10 rounded-lg px-4 text-xs text-white focus:outline-none focus:border-[#009DFF]/40\"\n                      />\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Strategic Industry Domain *</label>\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2.5\">\n                        {INDUSTRIES.map(ind => (\n                          <button\n                            key={ind.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, industry: ind.id })}\n                            className={`p-3 rounded-xl border text-left transition-all text-xs flex gap-3 items-center ${\n                              data.industry === ind.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span className=\"text-lg\">{ind.icon}</span>\n                            <div>\n                              <h4 className=\"font-bold\">{ind.title}</h4>\n                              <p className=\"text-[9px] text-white/40 line-clamp-1\">{ind.desc}</p>\n                            </div>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Corporate Scale & Node Size *</label>\n                      <div className=\"grid grid-cols-3 gap-2\">\n                        {COMPANY_SIZES.map(sz => (\n                          <button\n                            key={sz.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, companySize: sz.id })}\n                            className={`p-3 rounded-xl border text-center transition-all flex flex-col justify-center h-16 ${\n                              data.companySize === sz.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <h4 className=\"text-[11px] font-bold\">{sz.title}</h4>\n                            <p className=\"text-[8px] text-white/35 mt-1\">{sz.desc}</p>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {activeStep === 1 && (\n                  <div className=\"space-y-5 animate-fadeIn\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Primary Operational Challenge *</label>\n                      {CHALLENGES.map(ch => (\n                        <button\n                          key={ch.id}\n                          type=\"button\"\n                          onClick={() => setData({ ...data, primaryChallenge: ch.id })}\n                          className={`w-full p-3 rounded-xl border text-left transition-all text-xs flex items-center gap-3 ${\n                            data.primaryChallenge === ch.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                          }`}\n                        >\n                          <div className={`w-3 h-3 rounded-full border flex items-center justify-center ${data.primaryChallenge === ch.id ? \"border-[#009DFF]\" : \"border-white/35\"}`}>\n                            {data.primaryChallenge === ch.id && <div className=\"w-1.5 h-1.5 bg-[#009DFF] rounded-full\" />}\n                          </div>\n                          <div>\n                            <h4 className=\"font-bold\">{ch.title}</h4>\n                            <p className=\"text-[9px] text-white/40 mt-0.5\">{ch.desc}</p>\n                          </div>\n                        </button>\n                      ))}\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Priority Strategic Outcomes *</label>\n                      <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-2\">\n                        {OUTCOMES.map(out => {\n                          const isSelected = data.priorityOutcomes.includes(out.id);\n                          return (\n                            <button\n                              key={out.id}\n                              type=\"button\"\n                              onClick={() => toggleOutcome(out.id)}\n                              className={`p-3 rounded-xl border text-left transition-all h-24 flex flex-col justify-between ${\n                                isSelected ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                              }`}\n                            >\n                              <h4 className=\"text-[11px] font-bold line-clamp-1\">{out.title}</h4>\n                              <p className=\"text-[9px] text-white/40 leading-tight font-light mt-1\">{out.desc}</p>\n                            </button>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {activeStep === 2 && (\n                  <div className=\"space-y-5 animate-fadeIn\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Preferred GFF Engagement Model *</label>\n                      <div className=\"grid grid-cols-2 gap-2.5\">\n                        {ENGAGEMENT_PATHS.map(path => {\n                          const isSelected = data.preferredEngagementPath === path.id;\n                          return (\n                            <button\n                              key={path.id}\n                              type=\"button\"\n                              onClick={() => setData({ ...data, preferredEngagementPath: path.id })}\n                              className={`p-4 rounded-xl border text-left transition-all h-36 flex flex-col justify-between relative overflow-hidden ${\n                                isSelected ? \"bg-white/[0.01]\" : \"border-white/5 bg-[#030304] hover:border-white/10\"\n                              }`}\n                              style={isSelected ? { borderColor: path.color } : undefined}\n                            >\n                              <div>\n                                <div className=\"flex justify-between items-center mb-1\">\n                                  <h4 className=\"text-xs font-bold text-white\">{path.title}</h4>\n                                  <span className=\"text-[8px] font-mono uppercase bg-white/5 px-1.5 py-0.5 rounded text-white/60\">{path.duration}</span>\n                                </div>\n                                <span className=\"text-[8px] font-mono block opacity-40 uppercase mb-1\">{path.tagline}</span>\n                                <p className=\"text-[9px] text-white/45 leading-relaxed font-light line-clamp-2\">{path.desc}</p>\n                              </div>\n                              {isSelected && (\n                                <div className=\"text-[8px] font-mono uppercase flex items-center gap-1 font-black\" style={{ color: path.color }}>\n                                  <span className=\"w-1.5 h-1.5 rounded-full animate-ping\" style={{ backgroundColor: path.color }} />\n                                  Active Path\n                                </div>\n                              )}\n                            </button>\n                          );\n                        })}\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Target Deployment Timeline *</label>\n                      <div className=\"grid grid-cols-3 gap-2\">\n                        {TIMELINES.map(tm => (\n                          <button\n                            key={tm.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, targetTimeline: tm.id })}\n                            className={`p-3 rounded-xl border text-center transition-all flex flex-col justify-center h-16 ${\n                              data.targetTimeline === tm.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <h4 className=\"text-[11px] font-bold\">{tm.title}</h4>\n                            <p className=\"text-[8px] text-white/40 mt-1\">{tm.desc}</p>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {activeStep === 3 && (\n                  <div className=\"space-y-5 animate-fadeIn\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Corporate Budget Range (Optional)</label>\n                      <div className=\"grid grid-cols-2 gap-2\">\n                        {BUDGETS.map(bg => (\n                          <button\n                            key={bg.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, budgetRange: bg.id })}\n                            className={`p-3 rounded-xl border text-left transition-all text-xs h-12 flex items-center ${\n                              data.budgetRange === bg.id ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span className=\"font-bold\">{bg.title}</span>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                      <div className=\"space-y-2\">\n                        <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Deployment Geography (Optional)</label>\n                        <select\n                          value={data.geography}\n                          onChange={(e) => setData({ ...data, geography: e.target.value })}\n                          className=\"w-full h-10 bg-white/[0.02] border border-white/10 rounded-lg px-3 text-xs text-white focus:outline-none appearance-none cursor-pointer\"\n                        >\n                          <option value=\"\" className=\"bg-[#030306]\">-- Auto-Select Best VPC --</option>\n                          {GEOGRAPHIES.map(geo => (\n                            <option key={geo.id} value={geo.id} className=\"bg-[#030306]\">\n                              {geo.title} ({geo.sub})\n                            </option>\n                          ))}\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-2\">\n                        <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Stakeholder Alignment (Optional)</label>\n                        <div className=\"flex flex-wrap gap-1.5\">\n                          {STAKEHOLDERS.map(st => {\n                            const isSelected = data.stakeholders.includes(st.id);\n                            return (\n                              <button\n                                key={st.id}\n                                type=\"button\"\n                                onClick={() => setData(p => ({\n                                  ...p,\n                                  stakeholders: p.stakeholders.includes(st.id) ? p.stakeholders.filter(x => x !== st.id) : [...p.stakeholders, st.id]\n                                }))}\n                                className={`h-7 px-2.5 rounded-full border text-[9px] font-mono uppercase tracking-wider transition-all ${\n                                  isSelected ? \"bg-[#009DFF]/15 border-[#009DFF] text-[#009DFF]\" : \"bg-white/5 border-white/5 text-white/50 hover:border-white/10\"\n                                }`}\n                              >\n                                {st.title}\n                              </button>\n                            );\n                          })}\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                )}\n              </div>\n\n              {/* Step Actions */}\n              <div className=\"mt-8 border-t border-white/5 pt-4 space-y-3\">\n                {error && (\n                  <div className=\"p-3 rounded-lg bg-[#E4000F]/5 border border-[#E4000F]/15 text-[10px] text-white/80 font-mono\">\n                    <span className=\"text-[#E4000F] font-bold\">ERROR:</span> {error}\n                  </div>\n                )}\n                <div className=\"flex justify-between items-center\">\n                  <button\n                    type=\"button\"\n                    onClick={handleBack}\n                    disabled={activeStep === 0}\n                    className={`px-4 h-9 rounded-lg border text-xs font-bold uppercase ${\n                      activeStep === 0 ? \"border-white/5 text-white/10 cursor-not-allowed\" : \"border-white/10 text-white hover:bg-white/5\"\n                    }`}\n                  >\n                    Back\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={handleNext}\n                    className=\"px-5 h-9 rounded-lg text-xs font-bold uppercase bg-[#009DFF] text-black hover:bg-[#009DFF]/90 font-mono shadow-[0_0_12px_rgba(0,157,255,0.2)] flex items-center gap-1.5\"\n                  >\n                    <span>{activeStep === 3 ? \"Compile SOW\" : \"Next Gate\"}</span>\n                    <span>→</span>\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* SOW Draft Outline Live Preview Sidebar */}\n          <div className=\"lg:col-span-5\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-2xl p-5 font-mono relative overflow-hidden\">\n              <div className=\"border-b border-white/5 pb-2 mb-4 flex justify-between items-center\">\n                <span className=\"text-[9px] font-bold text-[#00FF9D] tracking-wider flex items-center gap-1.5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF9D] animate-ping\" />\n                  SOW SPEC OUTLINE PREVIEW\n                </span>\n                <span className=\"text-[8px] text-white/30\">LATEST REV</span>\n              </div>\n\n              <div className=\"space-y-4 text-[10px]\">\n                <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1\">\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/40\">ORGANIZATION:</span>\n                    <span className=\"font-bold text-white truncate max-w-[140px]\">{data.organizationName || \"Sovereign Enterprise\"}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/40\">INDUSTRY DOMAIN:</span>\n                    <span className=\"font-bold text-[#009DFF]\">\n                      {data.industry ? INDUSTRIES.find(i => i.id === data.industry)?.title : \"AWAITING...\"}\n                    </span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/40\">RECOMMENDED TIER:</span>\n                    <span className=\"font-bold text-[#00FF9D]\">\n                      {data.companySize === \"conglomerate\" ? \"Sovereign Consensus\" : data.companySize === \"enterprise\" ? \"Global Scale\" : \"Strategic Incubation\"}\n                    </span>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2.5\">\n                  <span className=\"text-[8px] text-white/35 uppercase tracking-widest block\">Contract Sections:</span>\n                  <div className=\"space-y-2 pl-2 border-l border-white/5\">\n                    <div className=\"font-bold text-white/80\">I. Strategic Core Directive</div>\n                    <p className=\"text-[9px] text-white/40 pl-3\">\n                      {data.industry === \"healthcare\" ? \"→ Air-gapped HIPAA PHI ingestion mesh\" : data.industry === \"banking\" ? \"→ High-throughput atomic transaction auditing ledger\" : \"→ Targeted sovereign agent workflows\"}\n                    </p>\n\n                    <div className=\"font-bold text-white/80\">II. Deployment Path Framework</div>\n                    <div className=\"pl-3\">\n                      {data.preferredEngagementPath ? (\n                        <span className=\"text-[#9D00FF] font-bold\">\n                          {data.preferredEngagementPath} ({ENGAGEMENT_PATHS.find(p => p.id === data.preferredEngagementPath)?.duration})\n                        </span>\n                      ) : (\n                        <span className=\"text-white/25 italic\">Awaiting selection</span>\n                      )}\n                    </div>\n\n                    <div className=\"font-bold text-white/80\">III. Geographical Constraints</div>\n                    <span className=\"pl-3 text-white/50 block\">\n                      {data.geography ? GEOGRAPHIES.find(g => g.id === data.geography)?.title : \"Transient Local VRAM\"}\n                    </span>\n                  </div>\n                </div>\n\n                <div className=\"pt-3 border-t border-white/5 flex items-center justify-between text-[8px] text-white/20\">\n                  <span>SECURE SINGLE-TENANT BLUEPRINT</span>\n                  <span>SHA-256 SECURED</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Compiling Overlay State */}\n      {appState === \"compiling\" && (\n        <div className=\"max-w-2xl mx-auto py-12\">\n          <div className=\"bg-[#030306]/95 border border-white/5 rounded-2xl p-6 font-mono space-y-5 text-center\">\n            <div className=\"relative w-20 h-20 mx-auto border border-[#009DFF]/20 rounded-full flex items-center justify-center animate-pulse\">\n              <div className=\"absolute inset-0 border border-t-[#00FF9D] rounded-full animate-spin\" />\n              <span className=\"text-lg\">🔒</span>\n            </div>\n            <h3 className=\"text-sm font-bold text-white tracking-widest uppercase\">Compiling SOW Blueprint...</h3>\n            <div className=\"bg-black/40 border border-white/5 rounded-xl p-4 text-left text-[10px] space-y-1 leading-relaxed text-white/70 min-h-[110px]\">\n              {compLogs.slice(0, compilingIndex).map((log, idx) => (\n                <div key={idx} className=\"flex gap-2\">\n                  <span className=\"text-[#00FF9D]\">✓</span>\n                  <span>{log}</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Results Workspace State */}\n      {appState === \"completed\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start animate-fadeIn\">\n          {/* Main Proposal Document Folder */}\n          <div className=\"lg:col-span-8 bg-[#030306]/90 border border-white/5 rounded-2xl overflow-hidden\">\n            <div className=\"p-6 bg-white/[0.01] border-b border-white/5 flex flex-col sm:flex-row sm:items-center justify-between gap-3 font-mono\">\n              <div>\n                <span className=\"text-[9px] text-[#00FF9D] font-bold tracking-widest uppercase px-1.5 py-0.5 rounded bg-[#00FF9D]/10 border border-[#00FF9D]/20\">PROPOSAL SECURED</span>\n                <h2 className=\"text-base font-extrabold text-white mt-1.5\">{data.organizationName || \"Sovereign Enterprise\"} • Custom AI Spec</h2>\n              </div>\n              <div className=\"text-left sm:text-right text-[8px] text-white/40\">\n                <p>COMPILED: {new Date().toLocaleDateString()}</p>\n                <p className=\"text-white/20\">REVISION: {Math.floor(100000 + Math.random() * 900000)}</p>\n              </div>\n            </div>\n\n            {/* Document Tabs */}\n            <div className=\"flex border-b border-white/5 bg-black/10 text-[10px] font-mono\">\n              {[\"summary\", \"topology\", \"sow\", \"commercials\"].map(tab => (\n                <button\n                  key={tab}\n                  type=\"button\"\n                  onClick={() => setActiveTab(tab)}\n                  className={`flex-1 py-3 text-center transition-colors font-bold uppercase border-b-2 ${\n                    activeTab === tab ? \"border-[#009DFF] text-white bg-white/[0.01]\" : \"border-transparent text-white/40 hover:text-white\"\n                  }`}\n                >\n                  {tab}\n                </button>\n              ))}\n            </div>\n\n            {/* Tab Contents */}\n            <div className=\"p-6 md:p-8 space-y-6\">\n              {activeTab === \"summary\" && (\n                <div className=\"space-y-5 animate-fadeIn\">\n                  <div className=\"space-y-2\">\n                    <h3 className=\"text-[11px] font-mono text-[#009DFF] uppercase font-bold\">I. Executive Strategy Alignments</h3>\n                    <p className=\"text-xs text-white/70 leading-relaxed font-light\">\n                      This sovereign deployment blueprint establishes customized deployment architecture tailored for{\" \"}\n                      <span className=\"text-white font-bold\">{INDUSTRIES.find(i => i.id === data.industry)?.title}</span> deployment.\n                      By isolating core data models inside private VPC boundaries, GFF AI resolves your primary challenge regarding{\" \"}\n                      <span className=\"text-white font-bold\">{CHALLENGES.find(c => c.id === data.primaryChallenge)?.title}</span>.\n                    </p>\n                  </div>\n\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.005] space-y-3\">\n                    <span className=\"text-[8px] font-mono uppercase tracking-wider text-white/40\">Targeted Outcomes:</span>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs\">\n                      {data.priorityOutcomes.map(outId => (\n                        <div key={outId} className=\"p-3 rounded-lg bg-[#030304] border border-white/5\">\n                          <span className=\"font-bold text-white block\">{OUTCOMES.find(o => o.id === outId)?.title}</span>\n                          <span className=\"text-[9px] text-white/40 font-light block mt-0.5\">{OUTCOMES.find(o => o.id === outId)?.desc}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {activeTab === \"topology\" && (\n                <div className=\"space-y-5 animate-fadeIn\">\n                  <div className=\"space-y-2\">\n                    <h3 className=\"text-[11px] font-mono text-[#9D00FF] uppercase font-bold\">I. Node Ingestion & Security Topology</h3>\n                    <p className=\"text-xs text-white/70 font-light\">\n                      The GFF security orchestrator executes transient, zero-retention computations directly inside single-tenant clusters.\n                    </p>\n                  </div>\n\n                  {/* SVG diagram */}\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-[#010103] flex justify-center\">\n                    <svg className=\"w-full max-w-md h-32\" viewBox=\"0 0 400 120\">\n                      <rect x=\"5\" y=\"5\" width=\"390\" height=\"110\" rx=\"6\" fill=\"rgba(255,255,255,0.003)\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"3 3\" />\n                      <circle cx=\"200\" cy=\"60\" r=\"18\" fill=\"#0c0c10\" stroke=\"#9D00FF\" strokeWidth={1.5} />\n                      <rect x=\"30\" y=\"35\" width=\"90\" height=\"50\" rx=\"4\" fill=\"rgba(0,157,255,0.02)\" stroke=\"#009DFF\" strokeWidth={1} />\n                      <rect x=\"280\" y=\"35\" width=\"90\" height=\"50\" rx=\"4\" fill=\"rgba(0,255,157,0.02)\" stroke=\"#00FF9D\" strokeWidth={1} />\n                      <path d=\"M120 60 H182\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth={1} strokeDasharray=\"2 2\" />\n                      <path d=\"M218 60 H280\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth={1} strokeDasharray=\"2 2\" />\n                      <text x=\"75\" y=\"58\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" fontWeight=\"bold\">Secure Ingress</text>\n                      <text x=\"75\" y=\"72\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">Air-Gapped Data</text>\n                      <text x=\"325\" y=\"58\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" fontWeight=\"bold\">Sovereign LLMs</text>\n                      <text x=\"325\" y=\"72\" fill=\"rgba(255,255,255,0.4)\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">Memory Shield</text>\n                      <text x=\"200\" y=\"63\" fill=\"white\" fontSize=\"7\" fontFamily=\"monospace\" textAnchor=\"middle\" fontWeight=\"bold\">ORCH</text>\n                    </svg>\n                  </div>\n\n                  {currentPath && (\n                    <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.005]\">\n                      <h4 className=\"text-xs font-bold text-white uppercase\">{currentPath.title} — {currentPath.tagline}</h4>\n                      <p className=\"text-[11px] text-white/50 mt-1 font-light leading-relaxed\">{currentPath.desc}</p>\n                    </div>\n                  )}\n                </div>\n              )}\n\n              {activeTab === \"sow\" && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <h3 className=\"text-[11px] font-mono text-[#00FF9D] uppercase font-bold\">I. Phase Scoping Deliverables</h3>\n                  <div className=\"space-y-3 font-mono text-[10px]\">\n                    <div className=\"p-4 rounded-lg bg-white/[0.005] border border-white/5\">\n                      <div className=\"text-white/40 uppercase mb-1\">Phase 1: VPC Boundary Seal</div>\n                      <p className=\"text-white/60 font-light\">Provision isolated single-tenant memory-locked container enclaves with 0% data retention.</p>\n                    </div>\n                    <div className=\"p-4 rounded-lg bg-white/[0.005] border border-white/5\">\n                      <div className=\"text-white/40 uppercase mb-1\">Phase 2: Custom DAG Ingestion</div>\n                      <p className=\"text-white/60 font-light\">Connect core legacy systems and map pipeline interfaces to custom GFF orchestrators.</p>\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {activeTab === \"commercials\" && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  <h3 className=\"text-[11px] font-mono text-[#E4000F] uppercase font-bold\">I. Pricing Structure & SLAs</h3>\n                  <div className=\"grid grid-cols-2 gap-3 font-mono text-[11px]\">\n                    <div className=\"p-4 rounded-lg bg-[#030304] border border-white/5\">\n                      <span className=\"text-white/40 uppercase block text-[9px]\">SLA Standard Guarantee</span>\n                      <span className=\"text-white font-bold block mt-1\">99.99% Isolation Uptime</span>\n                    </div>\n                    <div className=\"p-4 rounded-lg bg-[#030304] border border-white/5\">\n                      <span className=\"text-white/40 uppercase block text-[9px]\">Estimated License Cost</span>\n                      <span className=\"text-[#00FF9D] font-bold block mt-1\">\n                        {data.budgetRange ? BUDGETS.find(b => b.id === data.budgetRange)?.title.split(\"(\")[0] : \"Custom Strategic\"}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n          </div>\n\n          {/* SOW Download / Action Hub Sidebar */}\n          <div className=\"lg:col-span-4 space-y-4\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-2xl p-5\">\n              <div className=\"border-b border-white/5 pb-2 mb-4\">\n                <span className=\"text-[9px] font-mono text-white/40 uppercase font-bold\">Compiled SOW Blueprint Bundles</span>\n              </div>\n\n              <div className=\"space-y-3 text-[11px]\">\n                {[\n                  { id: \"sow\", label: \"Statement of Work (SOW)\", file: \"SOW_Sovereign.pdf\", color: \"#009DFF\" },\n                  { id: \"ppt\", label: \"Executive Alignment Deck\", file: \"Board_Briefing.pptx\", color: \"#9D00FF\" },\n                  { id: \"specs\", label: \"Architecture Topology JSON\", file: \"Topology_Node_Map.json\", color: \"#00FF9D\" }\n                ].map(b => (\n                  <div key={b.id} className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/80 flex flex-col justify-between h-28\">\n                    <div>\n                      <span className=\"text-[8px] font-mono uppercase px-1.5 py-0.5 rounded\" style={{ color: b.color, backgroundColor: `${b.color}10`, border: `1px solid ${b.color}25` }}>READY TO EXPORT</span>\n                      <h4 className=\"text-xs font-bold text-white mt-2 leading-none\">{b.label}</h4>\n                    </div>\n                    <button\n                      type=\"button\"\n                      onClick={() => triggerDownload(b.file)}\n                      className=\"h-7 w-full rounded border border-white/10 hover:bg-white/5 text-[10px] font-mono text-white/80 transition-all uppercase\"\n                    >\n                      {downloads[b.file] || \"Simulate Export\"}\n                    </button>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030305]/90\">\n              <span className=\"text-[8px] font-mono text-[#E4000F] uppercase tracking-widest font-bold block\">SECURITY PROMPT</span>\n              <h4 className=\"text-xs font-bold text-white mt-1 leading-none\">Transient Session Guarantee</h4>\n              <p className=\"text-[10px] text-white/40 mt-1.5 leading-relaxed font-light\">\n                This Proposal Studio operates exclusively on local client-side memory structures with zero external network serialization.\n              </p>\n            </div>\n          </div>\n        </div>\n      )}\n\n      <div className=\"mt-16\">\n        <ToolCTA />\n      </div>\n    </ToolPageShell>\n  );\n}\n"}}}
