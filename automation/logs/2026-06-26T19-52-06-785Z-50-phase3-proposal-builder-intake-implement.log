{"ts":"2026-06-26T19:49:49.279Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"z5ddq19i","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { ToolPageShell, ToolCTA } from \"@/components/build/components\";\n\nconst ENGAGEMENT_PATHS = [\n  { id: \"Garage\", title: \"GFF Garage\", tagline: \"Co-Design Enclave\", desc: \"Collaborative strategy sprint. Deploy isolated sandbox in 4 weeks.\", duration: \"4 Weeks\", color: \"#009DFF\" },\n  { id: \"Foundry\", title: \"GFF Foundry\", tagline: \"Platform Integration\", desc: \"Core engineering. Deploy secure orchestrator in 8-12 weeks.\", duration: \"8-12 Weeks\", color: \"#9D00FF\" },\n  { id: \"Factory\", title: \"GFF Factory\", tagline: \"Fleet Industrialization\", desc: \"Industrial-scale execution. Roll out dozens of fine-tuned agent nodes.\", duration: \"12-16 Weeks\", color: \"#00FF9D\" },\n  { id: \"Operate\", title: \"GFF Operate\", tagline: \"Day-2 Managed SecOps\", desc: \"Persistent Day-2 managed sovereignty, telemetry, and regular audits.\", duration: \"Ongoing SLA\", color: \"#E4000F\" }\n];\n\nexport default function ProposalStudioPage() {\n  const [data, setData] = useState({\n    organizationName: \"\",\n    industry: \"\",\n    companySize: \"\",\n    primaryChallenge: \"\",\n    priorityOutcomes: [] as string[],\n    preferredEngagementPath: \"\",\n    targetTimeline: \"\",\n    budgetRange: \"\",\n    geography: \"\",\n    stakeholders: [] as string[]\n  });\n\n  const [activeStep, setActiveStep] = useState(0);\n  const [error, setError] = useState<string | null>(null);\n  const [appState, setAppState] = useState<\"edit\" | \"compiling\" | \"completed\">(\"edit\");\n  const [compilingIndex, setCompilingIndex] = useState(0);\n  const [activeTab, setActiveTab] = useState(\"summary\");\n  const [downloads, setDownloads] = useState<Record<string, string>>({});\n\n  const compLogs = [\n    \"Initializing GFF Sovereign Compiler...\",\n    \"Verifying secure VPC network boundaries...\",\n    \"Synthesizing customized Statement of Work...\",\n    \"Sealing proposal with cryptographical proof...\"\n  ];\n\n  useEffect(() => {\n    if (appState !== \"compiling\") return;\n    if (compilingIndex < compLogs.length) {\n      const t = setTimeout(() => setCompilingIndex(p => p + 1), 400);\n      return () => clearTimeout(t);\n    }\n    setAppState(\"completed\");\n  }, [appState, compilingIndex]);\n\n  const validateStep = () => {\n    setError(null);\n    if (activeStep === 0 && (!data.industry || !data.companySize)) {\n      setError(\"Strategic Domain and Scale parameters are required.\");\n      return false;\n    }\n    if (activeStep === 1 && (!data.primaryChallenge || data.priorityOutcomes.length === 0)) {\n      setError(\"Primary Challenge and at least one Outcome are required.\");\n      return false;\n    }\n    if (activeStep === 2 && (!data.preferredEngagementPath || !data.targetTimeline)) {\n      setError(\"Preferred Engagement Path and Timeline are required.\");\n      return false;\n    }\n    return true;\n  };\n\n  const handleNext = () => {\n    if (validateStep()) {\n      if (activeStep < 3) setActiveStep(p => p + 1);\n      else {\n        setCompilingIndex(0);\n        setAppState(\"compiling\");\n      }\n    }\n  };\n\n  const handleBack = () => {\n    setError(null);\n    if (activeStep > 0) setActiveStep(p => p - 1);\n  };\n\n  const toggleOutcome = (id: string) => {\n    setData(p => ({\n      ...p,\n      priorityOutcomes: p.priorityOutcomes.includes(id)\n        ? p.priorityOutcomes.filter(x => x !== id) : [...p.priorityOutcomes, id]\n    }));\n  };\n\n  const triggerDownload = (name: string) => {\n    if (downloads[name]) return;\n    setDownloads(p => ({ ...p, [name]: \"Downloading...\" }));\n    setTimeout(() => {\n      setDownloads(p => ({ ...p, [name]: \"✓ Exported\" }));\n    }, 1000);\n  };\n\n  const selectedPath = ENGAGEMENT_PATHS.find(p => p.id === data.preferredEngagementPath);\n\n  return (\n    <ToolPageShell showContact={appState !== \"completed\"}>\n      {/* HEADER SECTION */}\n      <div className=\"mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-6\">\n        <div>\n          <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">Phase 3 Strategic Studio</span>\n          <h1 className=\"text-2xl md:text-3xl font-extrabold text-white tracking-tight\">Sovereign SOW <span className=\"text-white/45 font-medium\">Proposal Studio</span></h1>\n          <p className=\"text-white/40 text-xs mt-1 font-light max-w-xl\">\n            Model customized agentic architectures, timelines, and formal Statement of Work outlines inside your browser session.\n          </p>\n        </div>\n\n        {appState === \"edit\" && (\n          <div className=\"flex items-center gap-2 bg-[#08080c] border border-white/5 px-4 py-2 rounded-xl font-mono text-[10px]\">\n            <span className=\"text-white/35 mr-1\">DESIGN GATES:</span>\n            {[0, 1, 2, 3].map((s) => (\n              <button\n                key={s}\n                onClick={() => { if (s < activeStep) setActiveStep(s); }}\n                className={`w-5 h-5 rounded flex items-center justify-center font-bold transition-all ${\n                  activeStep === s ? \"bg-[#009DFF] text-black\" : activeStep > s ? \"bg-[#00FF9D]/15 text-[#00FF9D]\" : \"border border-white/10 text-white/30\"\n                }`}\n              >\n                {s + 1}\n              </button>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* STRATEGIC INTAKE GATES */}\n      {appState === \"edit\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          \n          {/* Active Intake Form Side */}\n          <div className=\"lg:col-span-7\">\n            <div className=\"bg-[#030306]/90 border border-white/5 rounded-2xl p-6 min-h-[440px] flex flex-col justify-between relative overflow-hidden backdrop-blur-xl\">\n              <div className=\"space-y-6\">\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-3 text-[10px] font-mono\">\n                  <span className=\"font-bold text-[#009DFF] uppercase\">\n                    Gate {activeStep + 1} of 4 • {[\"Corporate Profile\", \"Strategic Intent\", \"Deployment Pathway\", \"Operational Bounds\"][activeStep]}\n                  </span>\n                  <span className=\"text-white/30\">VRAM TRANSIENT SESSION</span>\n                </div>\n\n                {/* STEP 1 */}\n                {activeStep === 0 && (\n                  <div className=\"space-y-4 animate-fadeIn text-xs\">\n                    <div>\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase mb-2\">Organization Name (Optional)</label>\n                      <input\n                        type=\"text\"\n                        placeholder=\"e.g. Apex Global Operations\"\n                        value={data.organizationName}\n                        onChange={(e) => setData({ ...data, organizationName: e.target.value })}\n                        className=\"w-full h-10 bg-white/[0.02] border border-white/10 rounded-lg px-4 text-xs text-white placeholder-white/20 focus:outline-none focus:border-[#009DFF]/40\"\n                      />\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Strategic Industry Domain *</label>\n                      <div className=\"grid grid-cols-2 gap-2\">\n                        {[\n                          { id: \"banking\", label: \"Banking & Finance\", icon: \"🏛️\" },\n                          { id: \"healthcare\", label: \"Healthcare & Life Sciences\", icon: \"🔬\" },\n                          { id: \"energy\", label: \"Energy & Grid Infrastructure\", icon: \"⚡\" },\n                          { id: \"public-sector\", label: \"Public Sector & Defense\", icon: \"🛡️\" }\n                        ].map(ind => (\n                          <button\n                            key={ind.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, industry: ind.id })}\n                            className={`p-3 rounded-xl border text-left flex items-center gap-2.5 transition-all ${\n                              data.industry === ind.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span>{ind.icon}</span>\n                            <span className=\"font-bold text-[11px]\">{ind.label}</span>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Corporate Scale & Node Count *</label>\n                      <div className=\"grid grid-cols-3 gap-2\">\n                        {[\n                          { id: \"mid-market\", label: \"Growth Enterprise\", cap: \"Mid-Market\" },\n                          { id: \"enterprise\", label: \"Core Enterprise\", cap: \"Dedicated VPC\" },\n                          { id: \"conglomerate\", label: \"Sovereign Scale\", cap: \"Global Nodes\" }\n                        ].map(sz => (\n                          <button\n                            key={sz.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, companySize: sz.id })}\n                            className={`p-3 rounded-xl border text-center transition-all flex flex-col justify-center h-16 ${\n                              data.companySize === sz.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span className=\"font-bold text-[11px]\">{sz.label}</span>\n                            <span className=\"text-[8px] text-white/35 font-mono mt-1\">{sz.cap}</span>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {/* STEP 2 */}\n                {activeStep === 1 && (\n                  <div className=\"space-y-4 animate-fadeIn text-xs\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Primary Operational Challenge *</label>\n                      {[\n                        { id: \"orch_lag\", label: \"Multi-System Orchestration Lag\", desc: \"Desynchronized legacy platforms causing latency.\" },\n                        { id: \"compliance_barrier\", label: \"Sovereign Compliance Barriers\", desc: \"Strict data residency prohibiting persistent storage.\" },\n                        { id: \"drift_deficits\", label: \"Autonomous Model Performance Drift\", desc: \"Risk of workflow deviation over persistent runs.\" }\n                      ].map(ch => (\n                        <button\n                          key={ch.id}\n                          type=\"button\"\n                          onClick={() => setData({ ...data, primaryChallenge: ch.id })}\n                          className={`w-full p-3 rounded-xl border text-left transition-all flex items-center gap-3 ${\n                            data.primaryChallenge === ch.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                          }`}\n                        >\n                          <div className={`w-3 h-3 rounded-full border flex items-center justify-center ${data.primaryChallenge === ch.id ? \"border-[#009DFF]\" : \"border-white/35\"}`}>\n                            {data.primaryChallenge === ch.id && <div className=\"w-1.5 h-1.5 bg-[#009DFF] rounded-full\" />}\n                          </div>\n                          <div>\n                            <h4 className=\"font-bold text-[11px]\">{ch.label}</h4>\n                            <p className=\"text-[9px] text-white/45 mt-0.5\">{ch.desc}</p>\n                          </div>\n                        </button>\n                      ))}\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Priority Strategic Outcomes *</label>\n                      <div className=\"grid grid-cols-3 gap-2\">\n                        {[\n                          { id: \"latency\", label: \"Sub-150ms Latency\", desc: \"Accelerate interface routing\" },\n                          { id: \"isolation\", label: \"100% Air-Gap VPC\", desc: \"Total private containment\" },\n                          { id: \"drift_guard\", label: \"Model Behavior Guard\", desc: \"Locked cryptographic weights\" }\n                        ].map(out => {\n                          const isSelected = data.priorityOutcomes.includes(out.id);\n                          return (\n                            <button\n                              key={out.id}\n                              type=\"button\"\n                              onClick={() => toggleOutcome(out.id)}\n                              className={`p-3 rounded-xl border text-left transition-all h-24 flex flex-col justify-between ${\n                                isSelected ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                              }`}\n                            >\n                              <span className=\"font-bold text-[10px] leading-tight\">{out.label}</span>\n                              <span className=\"text-[8px] text-white/40 font-light mt-1\">{out.desc}</span>\n                            </button>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {/* STEP 3 */}\n                {activeStep === 2 && (\n                  <div className=\"space-y-4 animate-fadeIn text-xs\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Preferred GFF Engagement Path *</label>\n                      <div className=\"grid grid-cols-2 gap-2.5\">\n                        {ENGAGEMENT_PATHS.map(path => {\n                          const isSelected = data.preferredEngagementPath === path.id;\n                          return (\n                            <button\n                              key={path.id}\n                              type=\"button\"\n                              onClick={() => setData({ ...data, preferredEngagementPath: path.id })}\n                              className={`p-3 rounded-xl border text-left transition-all h-32 flex flex-col justify-between relative overflow-hidden ${\n                                isSelected ? \"bg-white/[0.01]\" : \"border-white/5 bg-[#030304] hover:border-white/10\"\n                              }`}\n                              style={isSelected ? { borderColor: path.color } : undefined}\n                            >\n                              <div>\n                                <div className=\"flex justify-between items-center mb-1\">\n                                  <h4 className=\"text-xs font-bold text-white\">{path.title}</h4>\n                                  <span className=\"text-[8px] font-mono bg-white/5 px-1 rounded text-white/50\">{path.duration}</span>\n                                </div>\n                                <span className=\"text-[8px] font-mono opacity-40 block uppercase\">{path.tagline}</span>\n                                <p className=\"text-[9px] text-white/45 font-light leading-tight mt-1 line-clamp-2\">{path.desc}</p>\n                              </div>\n                              {isSelected && (\n                                <div className=\"text-[8px] font-mono uppercase flex items-center gap-1 font-bold\" style={{ color: path.color }}>\n                                  <span className=\"w-1.5 h-1.5 rounded-full animate-ping\" style={{ backgroundColor: path.color }} />\n                                  Active Path\n                                </div>\n                              )}\n                            </button>\n                          );\n                        })}\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Target Implementation Timeline *</label>\n                      <div className=\"grid grid-cols-3 gap-2\">\n                        {[\n                          { id: \"immediate\", label: \"Immediate Launch\", scope: \"1 - 3 Months\" },\n                          { id: \"strategic\", label: \"Strategic Enclave\", scope: \"3 - 6 Months\" },\n                          { id: \"transformational\", label: \"Total Transition\", scope: \"6 - 12 Months\" }\n                        ].map(tm => (\n                          <button\n                            key={tm.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, targetTimeline: tm.id })}\n                            className={`p-3 rounded-xl border text-center transition-all flex flex-col justify-center h-16 ${\n                              data.targetTimeline === tm.id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span className=\"font-bold text-[11px] leading-none\">{tm.label}</span>\n                            <span className=\"text-[8px] text-white/40 mt-1 font-mono\">{tm.scope}</span>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {/* STEP 4 */}\n                {activeStep === 3 && (\n                  <div className=\"space-y-4 animate-fadeIn text-xs\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Corporate Budget Range (Optional)</label>\n                      <div className=\"grid grid-cols-2 gap-2\">\n                        {[\n                          { id: \"tier1\", label: \"Strategic Discovery (< $250k)\" },\n                          { id: \"tier2\", label: \"Production VPC ($250k - $1M)\" },\n                          { id: \"tier3\", label: \"Industrial Scale ($1M - $5M)\" },\n                          { id: \"tier4\", label: \"Sovereign Infrastructure ($5M+)\" }\n                        ].map(bg => (\n                          <button\n                            key={bg.id}\n                            type=\"button\"\n                            onClick={() => setData({ ...data, budgetRange: bg.id })}\n                            className={`p-2.5 rounded-xl border text-left transition-all ${\n                              data.budgetRange === bg.id ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-[#030304] text-white/60 hover:border-white/10\"\n                            }`}\n                          >\n                            <span className=\"font-bold text-[11px]\">{bg.label}</span>\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                      <div className=\"space-y-2\">\n                        <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Deployment Geography (Optional)</label>\n                        <select\n                          value={data.geography}\n                          onChange={(e) => setData({ ...data, geography: e.target.value })}\n                          className=\"w-full h-10 bg-[#030304] border border-white/10 rounded-lg px-3 text-xs text-white appearance-none cursor-pointer focus:outline-none\"\n                        >\n                          <option value=\"\">-- Local VPC Host Region --</option>\n                          <option value=\"na\">North America (US/CA VPC)</option>\n                          <option value=\"eu\">European Union (GDPR Restricted)</option>\n                          <option value=\"apac\">Asia-Pacific Hubs</option>\n                          <option value=\"global\">Decentralized Sovereign Grid</option>\n                        </select>\n                      </div>\n\n                      <div className=\"space-y-2\">\n                        <label className=\"block text-[10px] font-mono text-white/40 uppercase\">Stakeholder Alignment (Optional)</label>\n                        <div className=\"flex flex-wrap gap-1.5\">\n                          {[\n                            { id: \"board\", label: \"Board of Directors\" },\n                            { id: \"cto_cio\", label: \"Office of CIO/CTO\" },\n                            { id: \"compliance\", label: \"Security Council\" }\n                          ].map(st => {\n                            const isSelected = data.stakeholders.includes(st.id);\n                            return (\n                              <button\n                                key={st.id}\n                                type=\"button\"\n                                onClick={() => setData(p => ({\n                                  ...p,\n                                  stakeholders: p.stakeholders.includes(st.id) ? p.stakeholders.filter(x => x !== st.id) : [...p.stakeholders, st.id]\n                                }))}\n                                className={`h-7 px-2.5 rounded-full border text-[9px] font-mono uppercase transition-all ${\n                                  isSelected ? \"bg-[#009DFF]/15 border-[#009DFF] text-[#009DFF]\" : \"bg-white/5 border-white/5 text-white/50 hover:border-white/10\"\n                                }`}\n                              >\n                                {st.label}\n                              </button>\n                            );\n                          })}\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                )}\n              </div>\n\n              {/* Step Navigation */}\n              <div className=\"mt-8 border-t border-white/5 pt-4 space-y-3\">\n                {error && (\n                  <div className=\"p-2.5 rounded-lg bg-[#E4000F]/5 border border-[#E4000F]/15 text-[10px] text-white/80 font-mono\">\n                    <span className=\"text-[#E4000F] font-bold\">ERROR:</span> {error}\n                  </div>\n                )}\n                <div className=\"flex justify-between items-center text-xs font-bold uppercase\">\n                  <button\n                    type=\"button\"\n                    onClick={handleBack}\n                    disabled={activeStep === 0}\n                    className={`px-4 h-9 rounded-lg border ${activeStep === 0 ? \"border-white/5 text-white/10 cursor-not-allowed\" : \"border-white/10 text-white hover:bg-white/5\"}`}\n                  >\n                    Back\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={handleNext}\n                    className=\"px-5 h-9 rounded-lg bg-[#009DFF] text-black hover:bg-[#009DFF]/90 font-mono flex items-center gap-1 shadow-[0_0_10px_rgba(0,157,255,0.25)]\"\n                  >\n                    <span>{activeStep === 3 ? \"Compile SOW\" : \"Next Gate\"}</span>\n                    <span>→</span>\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          {/* SOW LIVE OUTLINE PREVIEW SIDEBAR */}\n          <div className=\"lg:col-span-5\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-2xl p-5 font-mono relative overflow-hidden backdrop-blur-xl\">\n              <div className=\"border-b border-white/5 pb-2 mb-4 flex justify-between items-center text-[9px]\">\n                <span className=\"font-bold text-[#00FF9D] tracking-wider flex items-center gap-1.5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF9D] animate-ping\" />\n                  SOW BLUEPRINT LIVE OUTLINE\n                </span>\n                <span className=\"text-white/30\">VRAM SPEC</span>\n              </div>\n\n              <div className=\"space-y-4 text-[10px]\">\n                <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-xl space-y-1.5 text-white/70\">\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/35 uppercase\">Organization:</span>\n                    <span className=\"font-bold text-white truncate max-w-[150px]\">{data.organizationName || \"Sovereign Enterprise\"}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/35 uppercase\">Core Industry:</span>\n                    <span className=\"font-bold text-[#009DFF] uppercase\">{data.industry || \"AWAITING G0\"}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-white/35 uppercase\">Enterprise Scale:</span>\n                    <span className=\"font-bold text-white uppercase\">{data.companySize || \"AWAITING G0\"}</span>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <span className=\"text-[8px] text-white/35 uppercase tracking-widest block\">Contract Sections Output:</span>\n                  <div className=\"space-y-2 pl-2 border-l border-white/5\">\n                    <div>\n                      <div className=\"font-bold text-white/80\">I. Core Ingestion Directives</div>\n                      <p className=\"text-[9px] text-white/40 pl-3 leading-relaxed mt-0.5\">\n                        {data.industry === \"healthcare\" ? \"→ Strict air-gapped HIPAA PHI filters\" : data.industry === \"banking\" ? \"→ Decentralized transaction auditing ledgers\" : \"→ Optimized strategic system nodes\"}\n                      </p>\n                    </div>\n\n                    <div>\n                      <div className=\"font-bold text-white/80\">II. Strategic Engagement Path</div>\n                      <div className=\"pl-3 mt-0.5\">\n                        {data.preferredEngagementPath ? (\n                          <span className=\"text-[#9D00FF] font-bold uppercase\">{data.preferredEngagementPath} ({ENGAGEMENT_PATHS.find(p => p.id === data.preferredEngagementPath)?.duration})</span>\n                        ) : (\n                          <span className=\"text-white/20 italic\">Awaiting Selection...</span>\n                        )}\n                      </div>\n                    </div>\n\n                    <div>\n                      <div className=\"font-bold text-white/80\">III. Regional Boundaries</div>\n                      <span className=\"pl-3 text-white/45 block mt-0.5\">{data.geography ? `Hosted Zone: ${data.geography.toUpperCase()}` : \"Browser Private Memory Only\"}</span>\n                    </div>\n                  </div>\n                </div>\n\n                <div className=\"pt-3 border-t border-white/5 flex items-center justify-between text-[8px] text-white/25\">\n                  <span>SINGLE-TENANT ISOLATION</span>\n                  <span>SHA-256 ENCRYPTED</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* COMPILING BUFFER STATE */}\n      {appState === \"compiling\" && (\n        <div className=\"max-w-xl mx-auto py-12 font-mono\">\n          <div className=\"bg-[#030306]/95 border border-white/5 rounded-2xl p-6 text-center space-y-5\">\n            <div className=\"w-16 h-16 mx-auto border border-[#009DFF]/20 rounded-full flex items-center justify-center relative\">\n              <div className=\"absolute inset-0 border border-t-[#00FF9D] rounded-full animate-spin\" />\n              <span className=\"text-xl\">🔒</span>\n            </div>\n            <h3 className=\"text-xs font-bold text-white uppercase tracking-widest\">Compiling Strategic SOW Blueprint...</h3>\n            <div className=\"bg-black/35 border border-white/5 rounded-xl p-4 text-left text-[10px] space-y-1.5 text-white/70 min-h-[100px] leading-normal\">\n              {compLogs.slice(0, compilingIndex).map((log, idx) => (\n                <div key={idx} className=\"flex gap-2\">\n                  <span className=\"text-[#00FF9D]\">✓</span>\n                  <span>{log}</span>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* COMPILED RESULTS MODE */}\n      {appState === \"completed\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start animate-fadeIn\">\n          \n          {/* Main SOW folder viewer */}\n          <div className=\"lg:col-span-8 bg-[#030306]/95 border border-white/5 rounded-2xl overflow-hidden backdrop-blur-xl\">\n            <div className=\"p-6 bg-white/[0.01] border-b border-white/5 flex flex-col sm:flex-row sm:items-center justify-between gap-3 font-mono text-xs\">\n              <div>\n                <span className=\"text-[9px] text-[#00FF9D] font-bold tracking-widest uppercase px-2 py-0.5 rounded bg-[#00FF9D]/10 border border-[#00FF9D]/20\">PROPOSAL SECURED</span>\n                <h2 className=\"text-sm font-extrabold text-white mt-1.5\">{data.organizationName || \"Sovereign Enterprise\"} • SOW Briefing</h2>\n              </div>\n              <div className=\"text-left sm:text-right text-[8px] text-white/40\">\n                <p>COMPILED: {new Date().toLocaleDateString()}</p>\n                <p className=\"text-white/20\">REVISION ID: {Math.floor(100000 + Math.random() * 900000)}</p>\n              </div>\n            </div>\n\n            {/* Document Tabs */}\n            <div className=\"flex border-b border-white/5 bg-black/10 text-[10px] font-mono\">\n              {[\"summary\", \"topology\", \"sow\", \"commercials\"].map(tab => (\n                <button\n                  key={tab}\n                  type=\"button\"\n                  onClick={() => setActiveTab(tab)}\n                  className={`flex-1 py-3 text-center transition-all font-bold uppercase border-b-2 ${\n                    activeTab === tab ? \"border-[#009DFF] text-white bg-white/[0.01]\" : \"border-transparent text-white/40 hover:text-white\"\n                  }`}\n                >\n                  {tab}\n                </button>\n              ))}\n            </div>\n\n            {/* Tab Body */}\n            <div className=\"p-6 md:p-8 space-y-6\">\n              {activeTab === \"summary\" && (\n                <div className=\"space-y-4 animate-fadeIn text-xs leading-relaxed text-white/70\">\n                  <h3 className=\"text-[11px] font-mono text-[#009DFF] uppercase font-bold\">I. Executive Strategy Alignment</h3>\n                  <p className=\"font-light\">\n                    This sovereign blueprint details the integration specifications modeled for your organization. \n                    By containerizing workflow paths, GFF AI secures your operations against persistent cloud leakage, resolving primary hurdles related to <span className=\"text-white font-bold\">{data.primaryChallenge === \"orch_lag\" ? \"Orchestration Lag\" : \"Sovereign Compliance Borders\"}</span>.\n                  </p>\n\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/60 space-y-2 mt-4 text-[11px]\">\n                    <span className=\"text-[8px] font-mono text-[#00FF9D] uppercase block tracking-wider\">Identified Outcomes Scope:</span>\n                    <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n                      {data.priorityOutcomes.map(outId => (\n                        <div key={outId} className=\"p-3 rounded-lg bg-black border border-white/5\">\n                          <span className=\"font-bold text-white block\">✓ {outId === \"latency\" ? \"Sub-150ms Interface Latency\" : outId === \"isolation\" ? \"100% On-Prem VPC Air-Gap\" : \"Model Behavior Drift Protection\"}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {activeTab === \"topology\" && (\n                <div className=\"space-y-4 animate-fadeIn text-xs text-white/70\">\n                  <h3 className=\"text-[11px] font-mono text-[#9D00FF] uppercase font-bold\">I. System Topology & Data Mesh</h3>\n                  <p className=\"font-light\">Transient, zero-retention computations execute directly within localized single-tenant memories.</p>\n                  \n                  {/* Inline CSS Diagram */}\n                  <div className=\"p-4 rounded-xl border border-white/5 bg-black/40 flex justify-center\">\n                    <svg className=\"w-full max-w-sm h-28\" viewBox=\"0 0 300 100\">\n                      <rect x=\"5\" y=\"5\" width=\"290\" height=\"90\" rx=\"4\" fill=\"none\" stroke=\"rgba(255,255,255,0.03)\" strokeDasharray=\"3 3\" />\n                      <circle cx=\"150\" cy=\"50\" r=\"14\" fill=\"#07070a\" stroke=\"#9D00FF\" strokeWidth={1} />\n                      <rect x=\"20\" y=\"30\" width=\"70\" height=\"40\" rx=\"4\" fill=\"rgba(0,157,255,0.02)\" stroke=\"#009DFF\" strokeWidth={1} />\n                      <rect x=\"210\" y=\"30\" width=\"70\" height=\"40\" rx=\"4\" fill=\"rgba(0,255,157,0.02)\" stroke=\"#00FF9D\" strokeWidth={1} />\n                      <path d=\"M90 50 H136\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth={1} strokeDasharray=\"2 2\" />\n                      <path d=\"M164 50 H210\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth={1} strokeDasharray=\"2 2\" />\n                      <text x=\"55\" y=\"52\" fill=\"white\" fontSize=\"7\" textAnchor=\"middle\" fontWeight=\"bold\">Ingress</text>\n                      <text x=\"245\" y=\"52\" fill=\"white\" fontSize=\"7\" textAnchor=\"middle\" fontWeight=\"bold\">Sovereign LLM</text>\n                      <text x=\"150\" y=\"53\" fill=\"white\" fontSize=\"6\" fontFamily=\"monospace\" textAnchor=\"middle\">CORE</text>\n                    </svg>\n                  </div>\n\n                  {selectedPath && (\n                    <div className=\"p-3.5 rounded-xl border border-white/5 bg-white/[0.01]\">\n                      <span className=\"text-[8px] font-mono text-[#9D00FF] uppercase tracking-wider block\">Engagement Model:</span>\n                      <h4 className=\"font-bold text-white text-[11px] mt-1\">{selectedPath.title} — {selectedPath.tagline}</h4>\n                      <p className=\"text-[10px] text-white/50 mt-1 font-light leading-normal\">{selectedPath.desc}</p>\n                    </div>\n                  )}\n                </div>\n              )}\n\n              {activeTab === \"sow\" && (\n                <div className=\"space-y-4 animate-fadeIn text-xs text-white/70 font-mono\">\n                  <h3 className=\"text-[11px] font-mono text-[#00FF9D] uppercase font-bold\">I. Step-by-Step Milestones</h3>\n                  <div className=\"space-y-2.5 text-[10px]\">\n                    <div className=\"p-3 rounded-lg bg-white/[0.005] border border-white/5\">\n                      <span className=\"text-white/40 block uppercase\">Phase 1: VPC Boundary Audit</span>\n                      <p className=\"text-white/60 mt-0.5\">Deploy isolated single-tenant memory units and verify absolute telemetry containment.</p>\n                    </div>\n                    <div className=\"p-3 rounded-lg bg-white/[0.005] border border-white/5\">\n                      <span className=\"text-white/40 block uppercase\">Phase 2: Custom DAG Optimization</span>\n                      <p className=\"text-white/60 mt-0.5\">Model the targeted GFF orchestrator schemas and connect legacy storage layers safely.</p>\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {activeTab === \"commercials\" && (\n                <div className=\"space-y-4 animate-fadeIn text-xs text-white/70\">\n                  <h3 className=\"text-[11px] font-mono text-[#E4000F] uppercase font-bold\">I. Commercial Structuring</h3>\n                  <div className=\"grid grid-cols-2 gap-3 text-[10px] font-mono\">\n                    <div className=\"p-4 rounded-xl border border-white/5 bg-black\">\n                      <span className=\"text-white/35 block uppercase\">Guaranteed SLA standard</span>\n                      <span className=\"text-white font-bold block mt-1\">99.99% Node Isolation</span>\n                    </div>\n                    <div className=\"p-4 rounded-xl border border-white/5 bg-black\">\n                      <span className=\"text-white/35 block uppercase\">Sovereign License</span>\n                      <span className=\"text-[#00FF9D] font-bold block mt-1\">\n                        {data.budgetRange ? BUDGETS.find(b => b.id === data.budgetRange)?.title : \"Strategic Allocation Tier\"}\n                      </span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n          </div>\n\n          {/* SOW Download / Action Hub Sidebar */}\n          <div className=\"lg:col-span-4 space-y-4\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-2xl p-5\">\n              <span className=\"text-[9px] font-mono text-white/35 uppercase font-bold block border-b border-white/5 pb-2 mb-3\">COMPILED ARTIFACT BUNDLES</span>\n              \n              <div className=\"space-y-3\">\n                {[\n                  { id: \"sow\", label: \"Statement of Work (SOW)\", file: \"SOW_Sovereign.pdf\", color: \"#009DFF\" },\n                  { id: \"ppt\", label: \"Strategy Presentation\", file: \"Briefing_Decks.pptx\", color: \"#9D00FF\" },\n                  { id: \"specs\", label: \"Topology Spec Configuration\", file: \"Topology_Node_Map.json\", color: \"#00FF9D\" }\n                ].map(b => (\n                  <div key={b.id} className=\"p-3.5 rounded-xl border border-white/5 bg-[#030304]/80 flex flex-col justify-between h-24\">\n                    <div className=\"flex justify-between items-start\">\n                      <h4 className=\"text-[10.5px] font-bold text-white leading-tight\">{b.label}</h4>\n                      <span className=\"text-[6.5px] font-mono uppercase bg-white/5 px-1 py-0.5 rounded text-white/50\">VRAM</span>\n                    </div>\n                    <button\n                      type=\"button\"\n                      onClick={() => triggerDownload(b.file)}\n                      className=\"h-6 w-full rounded border border-white/10 hover:bg-white/5 text-[9px] font-mono text-white/70 transition-all uppercase\"\n                    >\n                      {downloads[b.file] || \"Export Spec\"}\n                    </button>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030305]/90\">\n              <span className=\"text-[8px] font-mono text-[#E4000F] uppercase tracking-widest font-bold block\">Transient Session Active</span>\n              <p className=\"text-[10px] text-white/40 mt-1 leading-relaxed font-light\">\n                GFF AI does not persist, store, or forward details outside your current secure browser session memory.\n              </p>\n              <button\n                type=\"button\"\n                onClick={() => {\n                  setData({\n                    organizationName: \"\",\n                    industry: \"\",\n                    companySize: \"\",\n                    primaryChallenge: \"\",\n                    priorityOutcomes: [] as string[],\n                    preferredEngagementPath: \"\",\n                    targetTimeline: \"\",\n                    budgetRange: \"\",\n                    geography: \"\",\n                    stakeholders: [] as string[]\n                  });\n                  setActiveStep(0);\n                  setAppState(\"edit\");\n                  setDownloads({});\n                }}\n                className=\"w-full h-8 border border-white/10 text-[10px] font-mono font-bold mt-3 text-white uppercase hover:bg-white/5 rounded transition-all\"\n              >\n                Reset Parameters\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* FOOTER CTA */}\n      <div className=\"mt-16\">\n        <ToolCTA />\n      </div>\n    </ToolPageShell>\n  );\n}\n"}}}
