{"ts":"2026-06-26T19:50:51.500Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"6um9xnri","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { ToolPageShell, ToolCTA } from \"@/components/build/components\";\n\nexport default function ProposalStudioPage() {\n  const [data, setData] = useState({\n    org: \"\", ind: \"\", size: \"\", chal: \"\", out: [] as string[],\n    path: \"\", time: \"\", budget: \"\", geo: \"\", stake: [] as string[]\n  });\n  const [step, setStep] = useState(0);\n  const [err, setErr] = useState<string | null>(null);\n  const [state, setState] = useState<\"edit\" | \"compiling\" | \"done\">(\"edit\");\n  const [compIdx, setCompIdx] = useState(0);\n  const [tab, setTab] = useState(\"summary\");\n  const [dls, setDls] = useState<Record<string, string>>({});\n\n  useEffect(() => {\n    if (state !== \"compiling\") return;\n    if (compIdx < 3) {\n      const t = setTimeout(() => setCompIdx(p => p + 1), 450);\n      return () => clearTimeout(t);\n    }\n    setState(\"done\");\n  }, [state, compIdx]);\n\n  const handleNext = () => {\n    setErr(null);\n    if (step === 0 && (!data.ind || !data.size)) return setErr(\"Domain Industry and Scale are required.\");\n    if (step === 1 && (!data.chal || data.out.length === 0)) return setErr(\"Challenge and Outcome are required.\");\n    if (step === 2 && (!data.path || !data.time)) return setErr(\"Engagement Path and Timeline are required.\");\n    \n    if (step < 3) setStep(p => p + 1);\n    else { setState(\"compiling\"); setCompIdx(0); }\n  };\n\n  const toggle = (f: \"out\" | \"stake\", v: string) => {\n    setData(p => ({ ...p, [f]: p[f].includes(v) ? p[f].filter(x => x !== v) : [...p[f], v] }));\n  };\n\n  const dl = (f: string) => {\n    setDls(p => ({ ...p, [f]: \"Exporting...\" }));\n    setTimeout(() => setDls(p => ({ ...p, [f]: \"✓ Ready\" })), 1000);\n  };\n\n  return (\n    <ToolPageShell showContact={state !== \"done\"}>\n      <div className=\"mb-6 border-b border-white/5 pb-4 font-sans text-white\">\n        <span className=\"text-[10px] font-mono text-[#009DFF] font-bold block\">Phase 3 Strategic Studio</span>\n        <h1 className=\"text-xl md:text-2xl font-black\">Sovereign SOW <span className=\"text-white/50\">Proposal Studio</span></h1>\n      </div>\n\n      {state === \"edit\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 text-xs text-white/80 font-sans\">\n          <div className=\"lg:col-span-7 bg-[#030306]/95 border border-white/5 rounded-xl p-5 min-h-[350px] flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <span className=\"text-[9px] font-mono uppercase text-[#009DFF] font-bold\">Gate {step + 1} of 4 • {[\"Profile\", \"Intent\", \"Pathway\", \"Bounds\"][step]}</span>\n              \n              {step === 0 && (\n                <div className=\"space-y-3\">\n                  <input type=\"text\" placeholder=\"Organization Name (Optional)\" value={data.org} onChange={e => setData({...data, org: e.target.value})} className=\"w-full h-10 bg-white/[0.02] border border-white/10 rounded px-3 text-white focus:outline-none\" />\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Domain Industry *</label>\n                    <div className=\"grid grid-cols-2 gap-2 font-bold\">\n                      {[\"banking\", \"healthcare\", \"energy\", \"public-sector\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, ind: id})} className={`p-2.5 rounded border text-left ${data.ind === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Scale *</label>\n                    <div className=\"grid grid-cols-3 gap-2 font-bold text-center\">\n                      {[\"mid-market\", \"enterprise\", \"conglomerate\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, size: id})} className={`p-2 rounded border ${data.size === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 1 && (\n                <div className=\"space-y-4\">\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Primary Challenge *</label>\n                    {[\"orch_lag\", \"compliance_barrier\", \"drift_deficits\"].map(id => (\n                      <button key={id} onClick={() => setData({...data, chal: id})} className={`w-full p-2.5 rounded border text-left flex items-center gap-2 ${data.chal === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black\"}`}>\n                        <div className=\"font-bold\">{id === \"orch_lag\" ? \"Multi-System Orchestration Lag\" : id === \"compliance_barrier\" ? \"Sovereign Compliance Boundaries\" : \"Behavioral Model Drift & Safety\"}</div>\n                      </button>\n                    ))}\n                  </div>\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Priority Outcomes *</label>\n                    <div className=\"grid grid-cols-3 gap-2 text-center font-bold\">\n                      {[\"latency\", \"isolation\", \"drift_guard\"].map(id => (\n                        <button key={id} onClick={() => toggle(\"out\", id)} className={`p-2 rounded border ${data.out.includes(id) ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-black\"}`}>{id.toUpperCase()}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 2 && (\n                <div className=\"space-y-4\">\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Engagement Path *</label>\n                    <div className=\"grid grid-cols-2 gap-2\">\n                      {[\"Garage\", \"Foundry\", \"Factory\", \"Operate\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, path: id})} className={`p-3 rounded border text-left ${data.path === id ? \"border-white/40 bg-white/[0.01]\" : \"border-white/5 bg-[#030304]\"}`}>\n                          <div className=\"font-black text-[11px] text-white\">{id === \"Garage\" ? \"GFF Garage (4 Wks)\" : id === \"Foundry\" ? \"GFF Foundry (12 Wks)\" : id === \"Factory\" ? \"GFF Factory (16 Wks)\" : \"GFF Operate (SLA)\"}</div>\n                          <span className=\"text-[7px] text-white/40 uppercase block\">{id === \"Garage\" ? \"Co-Design Sprint\" : id === \"Foundry\" ? \"VPC Platform\" : id === \"Factory\" ? \"Fleet Scale\" : \"SecOps SLA\"}</span>\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Target Timeline *</label>\n                    <div className=\"grid grid-cols-3 gap-2 font-bold text-center\">\n                      {[\"immediate\", \"strategic\", \"transformational\"].map(id => (\n                        <button key={id} onClick={() => setData({...data, time: id})} className={`p-2 rounded border uppercase ${data.time === id ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-black\"}`}>{id}</button>\n                      ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {step === 3 && (\n                <div className=\"space-y-4\">\n                  <div className=\"space-y-1\">\n                    <label className=\"block text-[9px] font-mono text-white/40 uppercase\">Budget Range (Optional)</label>\n                    <div className=\"grid grid-cols-2 gap-2 text-center font-bold\">\n                      {[\"< $250k\", \"$250k - $1M\", \"$1M - $5M\", \"$5M+\"].map(b => (\n                        <button key={b} onClick={() => setData({...data, budget: b})} className={`p-2 rounded border ${data.budget === b ? \"border-[#00FF9D] bg-[#00FF9D]/5 text-white\" : \"border-white/5 bg-black\"}`}>{b}</button>\n                      ))}\n                    </div>\n                  </div>\n                  <div className=\"grid grid-cols-2 gap-3\">\n                    <div>\n                      <label className=\"block text-[9px] font-mono text-white/40 uppercase mb-1\">Geography (Optional)</label>\n                      <select value={data.geo} onChange={e => setData({...data, geo: e.target.value})} className=\"w-full h-9 bg-black border border-white/10 rounded px-2 text-white text-xs\">\n                        <option value=\"\">-- Host VPC --</option>\n                        <option value=\"na\">North America</option>\n                        <option value=\"eu\">European Union</option>\n                        <option value=\"apac\">Asia-Pacific</option>\n                      </select>\n                    </div>\n                    <div>\n                      <label className=\"block text-[9px] font-mono text-white/40 uppercase mb-1\">Stakeholders (Optional)</label>\n                      <div className=\"flex gap-1\">\n                        {[\"board\", \"cto\", \"compliance\"].map(s => (\n                          <button key={s} onClick={() => toggle(\"stake\", s)} className={`px-2 py-1 rounded text-[8px] font-mono uppercase border ${data.stake.includes(s) ? \"bg-[#009DFF]/10 border-[#009DFF] text-[#009DFF]\" : \"border-white/5 bg-black text-white/40\"}`}>{s}</button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            <div className=\"mt-4 border-t border-white/5 pt-3 flex justify-between items-center text-xs font-bold uppercase\">\n              <button type=\"button\" onClick={handleBack} disabled={step === 0} className={`px-3 h-8 rounded border ${step === 0 ? \"border-white/5 text-white/20\" : \"border-white/10 text-white\"}`}>Back</button>\n              {err && <span className=\"text-[#E4000F] font-mono text-[9px] normal-case\">{err}</span>}\n              <button type=\"button\" onClick={handleNext} className=\"px-4 h-8 rounded bg-[#009DFF] text-black font-mono\">Next Gate</button>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-5 bg-[#030305]/95 border border-white/5 rounded-xl p-4 font-mono text-[10px] space-y-3\">\n            <span className=\"font-bold text-[#00FF9D] block border-b border-white/5 pb-1 uppercase\">SOW SPEC OUTLINE PREVIEW</span>\n            <div className=\"space-y-1\">\n              <div>ORGANIZATION: <span className=\"text-white font-bold\">{data.org || \"Sovereign Enterprise\"}</span></div>\n              <div>INDUSTRY: <span className=\"text-[#009DFF] font-bold uppercase\">{data.ind || \"AWAITING...\"}</span></div>\n              <div>SCALE: <span className=\"text-white font-bold uppercase\">{data.size || \"AWAITING...\"}</span></div>\n            </div>\n            <div className=\"pt-2 border-t border-white/5 space-y-1\">\n              <div className=\"font-bold\">I. Ingestion Directive:</div>\n              <p className=\"text-white/40 pl-2\">\n                {data.ind === \"healthcare\" ? \"→ Air-gapped PHI container validation\" : \"→ Targeted sovereign agent workflows\"}\n              </p>\n              <div className=\"font-bold\">II. Deployment Path:</div>\n              <span className=\"text-[#9D00FF] pl-2 font-bold uppercase\">{data.path || \"AWAITING...\"}</span>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {state === \"compiling\" && (\n        <div className=\"max-w-md mx-auto text-center font-mono py-12 bg-[#030306] border border-white/5 rounded-xl p-6 text-white\">\n          <div className=\"w-10 h-10 border border-t-[#00FF9D] rounded-full animate-spin mx-auto mb-4\" />\n          <h3 className=\"text-xs font-bold uppercase tracking-widest\">Compiling SOW Blueprint...</h3>\n          <div className=\"text-[9px] text-white/50 text-left bg-black p-3 rounded mt-3 space-y-1\">\n            <div>✓ Initializing Sovereign Compiler...</div>\n            {compIdx > 0 && <div>✓ Verifying single-tenant VPC boundaries...</div>}\n            {compIdx > 1 && <div>✓ Synthesizing custom Statement of Work chapters...</div>}\n          </div>\n        </div>\n      )}\n\n      {state === \"done\" && (\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 text-xs text-white/80 font-sans\">\n          <div className=\"lg:col-span-8 bg-[#030306]/95 border border-white/5 rounded-xl overflow-hidden\">\n            <div className=\"p-4 bg-white/[0.01] border-b border-white/5 flex justify-between font-mono text-[9px]\">\n              <div>\n                <span className=\"text-[8px] text-[#00FF9D] border border-[#00FF9D]/20 px-1.5 py-0.5 rounded font-black uppercase\">SOW SECURED</span>\n                <h3 className=\"text-white font-bold mt-1.5\">{data.org || \"Sovereign Enterprise\"} • Custom AI Spec</h3>\n              </div>\n              <span className=\"text-white/30 text-right\">HASH: SHA-256</span>\n            </div>\n\n            <div className=\"flex border-b border-white/5 bg-black/15 font-mono text-[9px] text-center font-bold\">\n              {[\"summary\", \"topology\", \"sow\", \"commercials\"].map(t => (\n                <button key={t} onClick={() => setTab(t)} className={`flex-1 py-2 uppercase ${tab === t ? \"border-b-2 border-[#009DFF] text-white\" : \"text-white/40\"}`}>{t}</button>\n              ))}\n            </div>\n\n            <div className=\"p-5 space-y-4\">\n              {tab === \"summary\" && (\n                <div className=\"space-y-2\">\n                  <h4 className=\"text-[10px] font-mono text-[#009DFF] uppercase font-bold\">I. Executive Summary</h4>\n                  <p className=\"font-light leading-relaxed\">\n                    This Statement of Work outlines sovereign integration tailored for <span className=\"text-white font-bold\">{data.ind.toUpperCase()}</span>.\n                    By deploying zero-retention orchestrator agents inside private VPC memories, GFF solves challenges regarding <span className=\"text-white font-bold\">{data.chal === \"orch_lag\" ? \"Orchestration Latency\" : \"Compliance Boundaries\"}</span>.\n                  </p>\n                </div>\n              )}\n\n              {tab === \"topology\" && (\n                <div className=\"space-y-3\">\n                  <h4 className=\"text-[10px] font-mono text-[#9D00FF] uppercase font-bold\">I. Node Topology Map</h4>\n                  <svg className=\"w-full max-w-xs h-20 mx-auto\" viewBox=\"0 0 200 60\">\n                    <circle cx=\"100\" cy=\"30\" r=\"10\" fill=\"#000\" stroke=\"#9D00FF\" />\n                    <rect x=\"15\" y=\"15\" width=\"45\" height=\"30\" rx=\"3\" fill=\"none\" stroke=\"#009DFF\" />\n                    <rect x=\"140\" y=\"15\" width=\"45\" height=\"30\" rx=\"3\" fill=\"none\" stroke=\"#00FF9D\" />\n                    <path d=\"M60 30 H90 M110 30 H140\" stroke=\"rgba(255,255,255,0.1)\" strokeDasharray=\"1\" />\n                    <text x=\"37\" y=\"32\" fill=\"white\" fontSize=\"5\" textAnchor=\"middle\">Ingress</text>\n                    <text x=\"162\" y=\"32\" fill=\"white\" fontSize=\"5\" textAnchor=\"middle\">Sovereign Node</text>\n                  </svg>\n                  {data.path && <p className=\"font-mono text-[9px] bg-white/[0.01] p-2 border border-white/5 rounded text-white text-center\">Selected Path: GFF {data.path.toUpperCase()}</p>}\n                </div>\n              )}\n\n              {tab === \"sow\" && (\n                <div className=\"space-y-2.5 font-mono text-[9px] text-white/60\">\n                  <h4 className=\"text-[10px] text-[#00FF9D] uppercase font-bold font-sans\">I. SOW Phase Deliverables</h4>\n                  <div className=\"p-3 bg-white/[0.005] border border-white/5 rounded\">\n                    <span className=\"text-white/40 block font-bold\">PHASE 1: VPC Boundary Seal</span>\n                    <p className=\"mt-0.5\">Deploy secure memory-locked containers inside your private host cloud.</p>\n                  </div>\n                  <div className=\"p-3 bg-white/[0.005] border border-white/5 rounded\">\n                    <span className=\"text-white/40 block font-bold\">PHASE 2: Orchestration Bridge</span>\n                    <p className=\"mt-0.5\">Route legacy APIs through custom transient agents to secure workflow velocity.</p>\n                  </div>\n                </div>\n              )}\n\n              {tab === \"commercials\" && (\n                <div className=\"space-y-3 font-mono\">\n                  <h4 className=\"text-[10px] text-[#E4000F] uppercase font-bold font-sans\">I. Pricing & SLA Guarantee</h4>\n                  <div className=\"grid grid-cols-2 gap-2 text-[9px]\">\n                    <div className=\"p-3 rounded bg-black border border-white/5\">\n                      <span className=\"text-white/45 block\">Isolation Standard SLA</span>\n                      <span className=\"text-white font-bold block mt-0.5\">99.99% Node isolation</span>\n                    </div>\n                    <div className=\"p-3 rounded bg-black border border-white/5\">\n                      <span className=\"text-white/45 block\">VPC Annual License</span>\n                      <span className=\"text-[#00FF9D] font-bold block mt-0.5\">{data.budget || \"Strategic Tier\"}</span>\n                    </div>\n                  </div>\n                </div>\n              )}\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-4 space-y-4\">\n            <div className=\"bg-[#030305]/95 border border-white/5 rounded-xl p-4 font-mono\">\n              <span className=\"text-[9px] text-white/40 font-bold block border-b border-white/5 pb-1 mb-3\">SOW COMPILED ARTIFACTS</span>\n              <div className=\"space-y-2 text-[10px]\">\n                {[\"SOW_Sovereign.pdf\", \"Strategy_Deck.pptx\"].map(f => (\n                  <div key={f} className=\"p-3 rounded border border-white/5 bg-black flex justify-between items-center\">\n                    <span className=\"font-bold text-white/80\">{f.split(\".\")[0].toUpperCase()}</span>\n                    <button onClick={() => dl(f)} className=\"px-2 py-1 rounded bg-white/5 border border-white/10 hover:bg-white/10 text-[8px] text-white font-mono\">{dls[f] || \"EXPORT\"}</button>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/90 text-[10px] leading-relaxed text-white/45 space-y-3 font-mono\">\n              <span className=\"text-[#E4000F] font-bold block uppercase text-[8px]\">Transient Guard Enforced</span>\n              <p>Details remain in localized client-side memories and won't be saved on database hubs.</p>\n              <button onClick={() => {\n                setData({ org: \"\", ind: \"\", size: \"\", chal: \"\", out: [], path: \"\", time: \"\", budget: \"\", geo: \"\", stake: [] });\n                setStep(0); setState(\"edit\"); setDls({});\n              }} className=\"w-full h-8 border border-white/10 text-[9px] font-bold text-white hover:bg-white/5 rounded uppercase transition-colors\">Reconfigure Draft</button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      <div className=\"mt-12\">\n        <ToolCTA />\n      </div>\n    </ToolPageShell>\n  );\n}\n"}}}
