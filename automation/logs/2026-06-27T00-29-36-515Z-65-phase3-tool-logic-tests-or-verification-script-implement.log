ng;\n146 | }\n147 | \n148 | export const SHARED_GFF_SOLUTION_METADATA: Record<SharedGFFSolution, GFFSolutionMetadata> = {\n149 |   \"Agent Factory\": {\n150 |     name: \"GFF Agent Factory™\",\n151 |     category: \"Platform\",\n152 |     tagline: \"High-Throughput Sovereign Agent Generation\",\n153 |     description: \"Rapidly builds sovereign enterprise agents with consensus execution mechanisms and zero landing-page storage.\"\n154 |   },\n155 |   \"Knowledge Graph\": {\n156 |     name: \"GFF Knowledge Graph™\",\n157 |     category: \"Platform\",\n158 |     tagline: \"Semantic Entity Silo Integration\",\n159 |     description: \"Synthesizes disconnected enterprise databases into a cryptographically secure, unified cognitive vector cache.\"\n160 |   },\n161 |   \"AI Governance\": {\n162 |     name: \"GFF AI Governance & Telemetry™\",\n163 |     category: \"Platform\",\n164 |     tagline: \"Hardened Security Boundaries\",\n165 |     description: \"Enforces air-gapped security, strict compliance audits, and real-time conversational drift supervision.\"\n166 |   },\n167 |   \"Managed AI Operations\": {\n168 |     name: \"GFF Managed AI Operations™\",\n169 |     category: \"Ops\",\n170 |     tagline: \"24/7 Monitored Multi-Agent Execution\",\n171 |     description: \"Offers fully managed orchestration, hosting, and continuous active security updates.\"\n172 |   },\n173 |   \"Garage\": {\n174 |     name: \"GFF Garage™\",\n175 |     category: \"Methodology\",\n176 |     tagline: \"Co-Innovation & Discovery\",\n177 |     description: \"Initial rapid-prototyping sandbox phase, defining compliance rules and localized simulation trials.\"\n178 |   },\n179 |   \"Foundry\": {\n180 |     name: \"GFF Foundry™\",\n181 |     category: \"Methodology\",\n182 |     tagline: \"Active Scale-Up Integration\",\n183 |     description: \"Core production deployment, connecting sandboxed models to enterprise transactional mainframes.\"\n184 |   },\n185 |   \"Factory\": {\n186 |     name: \"GFF Factory™\",\n187 |     category: \"Methodology\",\n188 |     tagline: \"Sovereign Production & Tuning\",\n189 |     description: \"Optimization tier, transferring local administration keys with drift prevention audits.\"\n190 |   },\n191 |   \"Control Center\": {\n192 |     name: \"GFF Sovereign Control Center™\",\n193 |     category: \"Platform\",\n194 |     tagline: \"Autonomous Administration Workspace\",\n195 |     description: \"Secure workspace to configure private subnets and manage single-tenant vector keys.\"\n196 |   }\n197 | };\n198 | ","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/assessment/data.ts","result":"  1 | import React from \"react\";\n  2 | \n  3 | export interface Option {\n  4 |   score: number;\n  5 |   label: string;\n  6 |   description: string;\n  7 | }\n  8 | \n  9 | export interface Question {\n 10 |   id: string;\n 11 |   text: string;\n 12 |   options: Option[];\n 13 | }\n 14 | \n 15 | export interface Dimension {\n 16 |   id: string;\n 17 |   name: string;\n 18 |   shortName: string;\n 19 |   color: string;\n 20 |   borderColor: string;\n 21 |   description: string;\n 22 |   questions: Question[];\n 23 | }\n 24 | \n 25 | export const DIMENSIONS: Dimension[] = [\n 26 |   {\n 27 |     id: \"strategy\",\n 28 |     name: \"Strategy & Alignment\",\n 29 |     shortName: \"Strategy\",\n 30 |     color: \"#009DFF\",\n 31 |     borderColor: \"border-[#009DFF]/20\",\n 32 |     description: \"Alignment of AI initiatives with core business differentiation and multi-year planning.\",\n 33 |     questions: [\n 34 |       {\n 35 |         id: \"strategy_q1\",\n 36 |         text: \"How is AI prioritized within your multi-year corporate strategy?\",\n 37 |         options: [\n 38 |           { score: 1, label: \"Ad-hoc / Opportunistic\", description: \"Explored primarily as isolated pilot projects or experimental IT snippets.\" },\n 39 |           { score: 2, label: \"Departmental Priority\", description: \"Integrated into specific division objectives like customer service or back-office script automation.\" },\n 40 |           { score: 3, label: \"Core Strategic Pillar\", description: \"Expressly defined in corporate strategies with dedicated executive sponsorship and capital allocation.\" },\n 41 |           { score: 4, label: \"Business Model Driver\", description: \"Positioned as a primary competitive differentiator, actively reorganizing processes around agentic flows.\" }\n 42 |         ]\n 43 |       },\n 44 |       {\n 45 |         id: \"strategy_q2\",\n 46 |         text: \"How does your organization identify and prioritize AI opportunities?\",\n 47 |         options: [\n 48 |           { score: 1, label: \"Reactive Response\", description: \"Driven primarily by vendor pitches or technical curiosity with minimal business case review.\" },\n 49 |           { score: 2, label: \"Technical Feasibility\", description: \"Evaluated based on ease of engineering implementation, rather than business impact or scaling risks.\" },\n 50 |           { score: 3, label: \"Value-Driven Framework\", description: \"Assessed via standard ROI spreadsheets, risk-impact matrices, and multi-disciplinary reviews.\" },\n 51 |           { score: 4, label: \"Sovereign Topologies\", description: \"Continuously mapped using formal frameworks matching organizational friction to custom multi-agent DAGs.\" }\n 52 |         ]\n 53 |       },\n 54 |       {\n 55 |         id: \"strategy_q3\",\n 56 |         text: \"What is your capital allocation model for AI initiatives?\",\n 57 |         options: [\n 58 |           { score: 1, label: \"Discretionary / OPEX\", description: \"Funded out of general maintenance budgets or ad-hoc department allocations.\" },\n 59 |           { score: 2, label: \"Annual Project Cycles\", description: \"Budgeted per specific initiative during standard annual corporate planning phases.\" },\n 60 |           { score: 3, label: \"Dedicated Multi-Year Capital\", description: \"Protected long-term transformation funds explicitly earmarked for AI enclaves and pilot scaling.\" },\n 61 |           { score: 4, label: \"Venture-Style Funding\", description: \"Agile, performance-gated capital allocations aligned to incremental telemetry metrics and sovereign outcomes.\" }\n 62 |         ]\n 63 |       }\n 64 |     ]\n 65 |   },\n 66 |   {\n 67 |     id: \"data\",\n 68 |     name: \"Data Readiness & Pipelines\",\n 69 |     shortName: \"Data\",\n 70 |     color: \"#00FF9D\",\n 71 |     borderColor: \"border-[#00FF9D]/20\",\n 72 |     description: \"Accessibility, cleanliness, security, and context structure of unstructured and structured corporate repositories.\",\n 73 |     questions: [\n 74 |       {\n 75 |         id: \"data_q1\",\n 76 |         text: \"How accessible and integrated is corporate data for autonomous workflows?\",\n 77 |         options: [\n 78 |           { score: 1, label: \"Siloed & Fragmented\", description: \"Trapped in legacy databases, on-prem servers, or unmapped folders with zero shared schema access.\" },\n 79 |           { score: 2, label: \"Centralized Lakehouses\", description: \"Aggregated in modern environments (e.g. Snowflake) but lacking semantic organization or indexing.\" },\n 80 |           { score: 3, label: \"Pipeline Orchestrated\", description: \"Equipped with active pipeline syncs, structured REST layers, and pre-indexed corporate taxonomies.\" },\n 81 |           { score: 4, label: \"Sovereign Knowledge Graphs\", description: \"Fully unified context layer mapping real-time semantic schemas into secure local vector databases.\" }\n 82 |         ]\n 83 |       },\n 84 |       {\n 85 |         id: \"data_q2\",\n 86 |         text: \"What is your methodology for processing unstructured data (PDFs, SOPs)?\",\n 87 |         options: [\n 88 |           { score: 1, label: \"Manual Retrieval\", description: \"Hardcopy printouts or scattered digital documents opened and searched manually by operators.\" },\n 89 |           { score: 2, label: \"Keyword Indexing\", description: \"Simple OCR scanning or search bars built into legacy file storage units with no semantics.\" },\n 90 |           { score: 3, label: \"Standard Vector RAG\", description: \"Automated document chunking, embedding generation, and query-response indexing in cloud vector stores.\" },\n 91 |           { score: 4, label: \"Cognitive Ingestion\", description: \"Hierarchical chunking, semantic cross-encoding, metadata enrichment, and active graph linking.\" }\n 92 |         ]\n 93 |       },\n 94 |       {\n 95 |         id: \"data_q3\",\n 96 |         text: \"How do you guarantee data freshness and detect telemetry anomalies?\",\n 97 |         options: [\n 98 |           { score: 1, label: \"Reactive Audits\", description: \"Data drift or broken feeds are only corrected when downstream applications experience failures.\" },\n 99 |           { score: 2, label: \"Scheduled Batch Syncs\", description: \"Nightly cron-jobs rebuild vector indexes or data lakes, leaving data stale during active hours.\" },\n100 |           { score: 3, label: \"Real-Time Streaming\", description: \"Event-driven updates instantly refresh context vectors as changes propagate inside SQL databases.\" },\n101 |           { score: 4, label: \"Self-Healing Context\", description: \"Active supervisor models audit, clean, and validate ingestion drift, raising alerts for anomaly spikes.\" }\n102 |         ]\n103 |       }\n104 |     ]\n105 |   },\n106 |   {\n107 |     id: \"process\",\n108 |     name: \"Process & Workflow Maturity\",\n109 |     shortName: \"Process\",\n110 |     color: \"#9D00FF\",\n111 |     borderColor: \"border-[#9D00FF]/20\",\n112 |     description: \"Standardization of business logic, degree of digital automation, and human integration latency.\",\n113 |     questions: [\n114 |       {\n115 |         id: \"process_q1\",\n116 |         text: \"How documented and structured are your target business proces