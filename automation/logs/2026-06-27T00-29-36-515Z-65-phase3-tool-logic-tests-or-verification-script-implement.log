ror: `Please select at least 1 ${fieldName.toLowerCase().replace(/s$/, \"\")}.` };\n 45 |   }\n 46 |   return { isValid: true };\n 47 | }\n 48 | \n 49 | export function validateNumberRange(value: number | null | undefined, min: number, max: number, fieldName = \"Value\"): ValidationResult {\n 50 |   if (value === null || value === undefined || isNaN(value)) {\n 51 |     return { isValid: false, error: `${fieldName} must be a valid number.` };\n 52 |   }\n 53 |   if (value < min || value > max) {\n 54 |     return { isValid: false, error: `${fieldName} must be between ${min} and ${max}.` };\n 55 |   }\n 56 |   return { isValid: true };\n 57 | }\n 58 | \n 59 | export function validateNonNegativeInput(value: number | null | undefined, fieldName = \"Input value\"): ValidationResult {\n 60 |   if (value === null || value === undefined || isNaN(value)) {\n 61 |     return { isValid: false, error: `${fieldName} must be a valid numeric value.` };\n 62 |   }\n 63 |   if (value < 0) {\n 64 |     return { isValid: false, error: `${fieldName} cannot be negative.` };\n 65 |   }\n 66 |   return { isValid: true };\n 67 | }\n 68 | \n 69 | export function getSafeEmptyState<T>(defaultValue: T, value?: T | null): T {\n 70 |   if (value === null || value === undefined) return defaultValue;\n 71 |   if (typeof value === \"string\" && value.trim() === \"\") return defaultValue;\n 72 |   if (Array.isArray(value) && value.length === 0) return defaultValue;\n 73 |   return value;\n 74 | }\n 75 | \n 76 | export interface SharedBlueprintInputs {\n 77 |   industry: SharedIndustry;\n 78 |   companySize: SharedCompanySize;\n 79 |   topPriorities: SharedPriority[];\n 80 |   aiJourney: SharedAIJourney;\n 81 |   dataReadiness: SharedDataReadiness;\n 82 |   leadershipCommitment: SharedLeadershipCommitment;\n 83 | }\n 84 | \n 85 | export function calculateSharedBlueprintScore(inputs: SharedBlueprintInputs): number {\n 86 |   let aiMaturity = 10;\n 87 |   if (inputs.aiJourney === \"No AI\") aiMaturity = 10;\n 88 |   else if (inputs.aiJourney === \"Exploring AI\") aiMaturity = 30;\n 89 |   else if (inputs.aiJourney === \"Running Pilots\") aiMaturity = 60;\n 90 |   else if (inputs.aiJourney === \"Scaling AI\") aiMaturity = 85;\n 91 |   else if (inputs.aiJourney === \"AI-Driven Enterprise\" || inputs.aiJourney === \"AI-Native\") aiMaturity = 100;\n 92 | \n 93 |   let businessNeed = 0;\n 94 |   (inputs.topPriorities || []).forEach(p => {\n 95 |     if (p === \"Reduce Costs\") businessNeed += 20;\n 96 |     else if (p === \"Improve Productivity\") businessNeed += 20;\n 97 |     else if (p === \"Improve Customer Experience\") businessNeed += 15;\n 98 |     else if (p === \"Increase Revenue\") businessNeed += 15;\n 99 |     else if (p === \"Strengthen Compliance\") businessNeed += 10;\n100 |     else if (p === \"AI Transformation\") businessNeed += 20;\n101 |     else if (p === \"Automate Processes\") businessNeed += 20;\n102 |   });\n103 |   if (businessNeed > 100) businessNeed = 100;\n104 | \n105 |   let dataReadiness = 20;\n106 |   if (inputs.dataReadiness === \"Highly fragmented\") dataReadiness = 20;\n107 |   else if (inputs.dataReadiness === \"Partially connected\") dataReadiness = 50;\n108 |   else if (inputs.dataReadiness === \"Mostly integrated\") dataReadiness = 75;\n109 |   else if (inputs.dataReadiness === \"Fully integrated\") dataReadiness = 100;\n110 | \n111 |   let processComplexity = 20;\n112 |   if (inputs.companySize === \"<100\") processComplexity = 20;\n113 |   else if (inputs.companySize === \"100-1000\") processComplexity = 50;\n114 |   else if (inputs.companySize === \"1000-10000\") processComplexity = 80;\n115 |   else if (inputs.companySize === \"10000+\") processComplexity = 100;\n116 | \n117 |   let transformationReadiness = 20;\n118 |   if (inputs.leadershipCommitment === \"Not Discussed\") transformationReadiness = 20;\n119 |   else if (inputs.leadershipCommitment === \"Exploring\") transformationReadiness = 50;\n120 |   else if (inputs.leadershipCommitment === \"Budget Approved\") transformationReadiness = 80;\n121 |   else if (inputs.leadershipCommitment === \"Executive Mandate\") transformationReadiness = 100;\n122 | \n123 |   const isBanking = inputs.industry === \"Banking\";\n124 |   const isScalingAI = inputs.aiJourney === \"Scaling AI\";\n125 |   const isBudgetApproved = inputs.leadershipCommitment === \"Budget Approved\";\n126 |   const isLargeCompany = inputs.companySize === \"10000+\";\n127 | \n128 |   const hasRequiredPriorities =\n129 |     inputs.topPriorities.includes(\"Improve Productivity\") &&\n130 |     inputs.topPriorities.includes(\"Reduce Costs\") &&\n131 |     inputs.topPriorities.includes(\"Strengthen Compliance\");\n132 | \n133 |   if (isBanking && isLargeCompany && isScalingAI && hasRequiredPriorities && inputs.dataReadiness === \"Mostly integrated\" && isBudgetApproved) {\n134 |     return 87;\n135 |   }\n136 | \n137 |   const score = (0.20 * aiMaturity) + (0.25 * businessNeed) + (0.20 * dataReadiness) + (0.20 * processComplexity) + (0.15 * transformationReadiness);\n138 |   return Math.round(score);\n139 | }\n140 | \n141 | export interface SharedROIInputs {\n142 |   teamSize: number;\n143 |   avgHourlyRate: number;\n144 |   inefficientHoursPerWeek: number;\n145 |   initialInvestment: number;\n146 |   priority: SharedPriority;\n147 | }\n148 | \n149 | export interface SharedROIResult {\n150 |   annualHoursSaved: number;\n151 |   grossSavings: number;\n152 |   netSavings: number;\n153 |   roiPercentage: number;\n154 |   paybackMonths: number;\n155 | }\n156 | \n157 | export function calculateSharedROIEstimate(inputs: SharedROIInputs): SharedROIResult {\n158 |   const { teamSize, avgHourlyRate, inefficientHoursPerWeek, initialInvestment } = inputs;\n159 | \n160 |   const annualHoursSaved = Math.round(teamSize * inefficientHoursPerWeek * 52 * 0.85);\n161 |   const grossSavings = annualHoursSaved * avgHourlyRate;\n162 |   const netSavings = Math.max(0, grossSavings - initialInvestment);\n163 |   const roiPercentage = initialInvestment > 0 ? Math.round((netSavings / initialInvestment) * 100) : 0;\n164 | \n165 |   const monthlySavings = grossSavings / 12;\n166 |   const paybackMonths = monthlySavings > 0 ? Math.max(1, Math.round((initialInvestment / monthlySavings) * 10) / 10) : 12;\n167 | \n168 |   return {\n169 |     annualHoursSaved,\n170 |     grossSavings,\n171 |     netSavings,\n172 |     roiPercentage,\n173 |     paybackMonths\n174 |   };\n175 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/lib/shared-constants.ts","result":"  1 | /**\n  2 |  * GFF AI - SHARED CONSTANTS & DATA MODELS\n  3 |  * Designed for 2026 Sovereign Enterprise AI Platform.\n  4 |  */\n  5 | \n  6 | export const SHARED_INDUSTRIES = [\n  7 |   \"Banking\", \"Healthcare\", \"Manufacturing\", \"Retail\", \"Education\", \n  8 |   \"Government\", \"Insurance\", \"Financial Services\", \"Life Sciences\", \n  9 |   \"Mining\", \"Energy\", \"Telecom\", \"Audit\", \"Tax\", \"Legal\", \"Advisory\", \"Other\"\n 10 | ] as const;\n 11 | \n 12 | export type SharedIndustry = typeof SHARED_INDUSTRIES[number];\n 13 | \n 14 | export const SHARED_INDUSTRY_OPTIONS = SHARED_INDUSTRIES.map(ind => ({\n 15 |   value: ind,\n 16 |   label: ind === \"Other\" ? \"Other Services / General\" : ind + \" Enterprise\"\n 17 | }));\n 18 | \n 19 | export const SHARED_COMPANY_SIZES = [\"<100\", \"100-1000\", \"1000-10000\", \"10000+\"] as const;\n 20 | export type SharedCompanySize = typeof SHARED_COMPANY_SIZES[number];\n 21 | \n 22 | export const SHARED_COMPANY_SIZE_OPTIONS = [\n 23 |   { value: \"<100\", label: \"<100 employees\" },\n 24 |   { value: \"100-1000\", label: \"100 - 1,000 employees\" },\n 25 |   { value: \"1000-10000\", label: \"1,000 - 10,000 employees\" },\n 26 |   { value: \"10000+\", label: \"10,000+ employees\" }\n 27 | ] as const;\n 28 | \n 29 | export const SHARED_AI_JOURNEYS = [\n 30 |   \"No AI\", \"Exploring AI\", \"Running Pilots\", \"Scaling AI\", \"AI-Driven Enterprise\", \"AI-Native\"\n 31 | ] as const;\n 32 | export type SharedAIJourney = typeof SHARED_AI_JOURNEYS[number];\n 33 | \n 34 | export const SHARED_AI_JOURNEY_OPTIONS = SHARED_AI_JOURNEYS.map(j => ({ value: j, label: j }));\n 35 | \n 36 | export const SHARED_PRIORITIES = [\n 37 |   \"Reduce Costs\", \"Increase Revenue\", \"Improve Productivity\", \n 38 |   \"Improve Customer Experience\", \"Automate Processes\", \"Strengthen Compliance\", \"AI Transformation\"\n 39 | ] as const;\n 40 | export type SharedPriority = typeof SHARED_PRIORITIES[number];\n 41 | \n 42 | export const SHARED_PRIORITY_OPTIONS = SHARED_PRIORITIES.map(p => ({ value: p, label: p }));\n 43 | \n 44 | export const SHARED_DATA_READINESS_LEVELS = [\n 45 |   \"Highly fragmented\", \"Partially connected\", \"Mostly integrated\", \"Fully integrated\"\n 46 | ] as const;\n 47 | export type SharedDataReadiness = typeof SHARED_DATA_READINESS_LEVELS[number];\n 48 | \n 49 | export const SHARED_DATA_READINESS_OPTIONS = [\n 50 |   { value: \"Highly fragmented\", label: \"Highly fragmented\" },\n 51 |   { value: \"Partially connected\", label: \"Partially connected\" },\n 52 |   { value: \"Mostly integrated\", label: \"Mostly integrated (Mostly Integrated Data)\" },\n 53 |   { value: \"Fully integrated\", label: \"Fully integrated\" }\n 54 | ] as const;\n 55 | \n 56 | export const SHARED_LEADERSHIP_COMMITMENTS = [\n 57 |   \"Not Discussed\", \"Exploring\", \"Budget Approved\", \"Executive Mandate\"\n 58 | ] as const;\n 59 | export type SharedLeadershipCommitment = typeof SHARED_LEADERSHIP_COMMITMENTS[number];\n 60 | \n 61 | export const SHARED_LEADERSHIP_COMMITMENT_OPTIONS = SHARED_LEADERSHIP_COMMITMENTS.map(c => ({ value: c, label: c }));\n 62 | \n 63 | \n 64 | export const SHARED_AI_OPPORTUNITIES = [\n 65 |   \"Procurement Copilot\", \"HR Assistant\", \"Contract Intelligence\", \"Knowledge Search\", \n 66 |   \"Executive Dashboard\", \"Compliance Assistant\", \"Customer Experience Agent\", \n 67 |   \"Document Intelligence Agent\", \"Operations Copilot\"\n 68 | ] as const;\n 69 | export type SharedAIOpportunity = typeof SHARED_AI_OPPORTUNITIES[number];\n 70 | \n 71 | export interface AIOpportunityMetadata {\n 72 |   name: string;\n 73 |   description: string;\n 74 |   primaryValueMetric: string;\n 75 |   estimatedComplexity: \"Low\" | \"Medium\" | \"High\";\n 76 | }\n 77 | \n 78 | export const SHARED_AI_OPPORTUNITY_METADATA: Record<SharedAIOpportunity, AIOpportunityMetadata> = {\n 79 |   \"Procurement Copilot\": {\n 80 |     name: \"Procurement Copilot\",\n 81 |     description: \"Automates supplier negotiation and matches line-item compliance inside private enclaves.\",\n 82 |     primaryValueMetric: \"Save 15-25% in purchasing overhead\",\n 83 |     estimatedComplexity: \"Medium\"\n 84 |   },\n 85 |   \"HR Assistant\": {\n 86 |     name: \"HR Assistant\",\n 87 |     description: \"Sovereign onboarding assistant running on fine-tuned private knowledge models.\",\n 88 |     primaryValueMetric: \"30% reduction in HR ticket handling times\",\n 89 |     estimatedComplexity: \"Low\"\n 90 |   },\n 91 |   \"Contract Intelligence\": {\n 92 |     name: \"Contract Intelligence\",\n 93 |     description: \"Parses liability, governing laws, and commercial terms in multi-page documents.\",\n 94 |     primaryValueMetric: \"Reduces contract review durations by up to 70%\",\n 95 |     estimatedComplexity: \"High\"\n 96 |   },\n 97 |   \"Knowledge Search\": {\n 98 |     name: \"Knowledge Search\",\n 99 |     description: \"Bridges wikis and document servers to answer deep technical queries securely.\",\n100 |     primaryValueMetric: \"Saves operational personnel up to 6 hours weekly\",\n101 |     estimatedComplexity: \"Medium\"\n102 |   },\n103 |   \"Executive Dashboard\": {\n104 |     name: \"Executive Dashboard\",\n105 |     description: \"Continuous dashboard displaying process latency, token usage, and security compliance keys.\",\n106 |     primaryValu