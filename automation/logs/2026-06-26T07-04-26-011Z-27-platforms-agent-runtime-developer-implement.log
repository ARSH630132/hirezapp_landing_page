{"ts":"2026-06-26T06:51:52.939Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"pr8m41wp","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/MotionReveal.tsx:1-100","result":" 1 | \"use client\";\n 2 | \n 3 | import React, { useEffect, useState } from \"react\";\n 4 | import { motion } from \"motion/react\";\n 5 | \n 6 | interface MotionRevealProps {\n 7 |   children: React.ReactNode;\n 8 |   direction?: \"up\" | \"down\" | \"left\" | \"right\" | \"fade\";\n 9 |   delay?: number;\n10 |   duration?: number;\n11 |   className?: string;\n12 |   threshold?: number;\n13 | }\n14 | \n15 | export default function MotionReveal({\n16 |   children,\n17 |   direction = \"up\",\n18 |   delay = 0,\n19 |   duration = 0.5,\n20 |   className = \"\",\n21 |   threshold = 0.1,\n22 | }: MotionRevealProps) {\n23 |   const [prefersReduced, setPrefersReduced] = useState(false);\n24 | \n25 |   useEffect(() => {\n26 |     const mediaQuery = window.matchMedia(\"(prefers-reduced-motion: reduce)\");\n27 |     setPrefersReduced(mediaQuery.matches);\n28 | \n29 |     const handleChange = (e: MediaQueryListEvent) => {\n30 |       setPrefersReduced(e.matches);\n31 |     };\n32 | \n33 |     mediaQuery.addEventListener(\"change\", handleChange);\n34 |     return () => mediaQuery.removeEventListener(\"change\", handleChange);\n35 |   }, []);\n36 | \n37 |   if (prefersReduced) {\n38 |     return <div className={className}>{children}</div>;\n39 |   }\n40 | \n41 |   const getDirectionOffset = () => {\n42 |     switch (direction) {\n43 |       case \"up\": return { y: 24, x: 0 };\n44 |       case \"down\": return { y: -24, x: 0 };\n45 |       case \"left\": return { y: 0, x: 24 };\n46 |       case \"right\": return { y: 0, x: -24 };\n47 |       case \"fade\":\n48 |       default: return { y: 0, x: 0 };\n49 |     }\n50 |   };\n51 | \n52 |   const offset = getDirectionOffset();\n53 | \n54 |   return (\n55 |     <motion.div\n56 |       initial={{ opacity: 0, ...offset }}\n57 |       whileInView={{ opacity: 1, y: 0, x: 0 }}\n58 |       viewport={{ once: true, amount: threshold }}\n59 |       transition={{\n60 |         duration: duration,\n61 |         delay: delay,\n62 |         ease: [0.16, 1, 0.3, 1], // Custom premium cubic-bezier curve (easeOutExpo)\n63 |       }}\n64 |       className={className}\n65 |     >\n66 |       {children}\n67 |     </motion.div>\n68 |   );\n69 | }","success":true}],"durationMs":3}}
