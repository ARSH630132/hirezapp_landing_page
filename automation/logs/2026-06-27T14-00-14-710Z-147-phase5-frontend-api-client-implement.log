etData.client_id || \"client-001\",\n        client_name: ticketData.client_name || \"Apex Sovereign Group [Preview Client]\",\n        priority: ticketData.priority || \"P3\",\n        category: ticketData.category || \"General Support\",\n        status: ticketData.status || \"OPEN\",\n        assignedAgent: ticketData.assignedAgent || \"Unassigned\",\n        linkedProjectId: ticketData.linkedProjectId,\n        linkedDocId: ticketData.linkedDocId,\n        slaSeconds: ticketData.slaSeconds || 7200,\n        description: ticketData.description || \"Standard customer support telemetry investigation query.\",\n        createdDate: new Date().toISOString(),\n      };\n      return { success: true, ticket: mockTicket };\n    }\n  },\n\n  update: async (id: string, ticketData: Partial<ApiSupportTicket>): Promise<{ success: boolean; ticket: ApiSupportTicket }> => {\n    try {\n      return await request<{ success: boolean; ticket: ApiSupportTicket }>(`/support/${encodeURIComponent(id)}`, {\n        method: \"PATCH\",\n        body: JSON.stringify(ticketData),\n      });\n    } catch {\n      const tRes = await support.get(id);\n      const updated = { ...tRes.ticket, ...ticketData };\n      return { success: true, ticket: updated };\n    }\n  },\n};\n\n/**\n * Governance Module\n */\nexport const governance = {\n  list: async (filters?: {\n    client_id?: string;\n    project_id?: string;\n    severity?: string;\n    status?: string;\n    search?: string;\n  }): Promise<{ success: boolean; governance: ApiGovernanceItem[] }> => {\n    const params = new URLSearchParams();\n    if (filters?.client_id) params.set(\"client_id\", filters.client_id);\n    if (filters?.project_id) params.set(\"project_id\", filters.project_id);\n    if (filters?.severity) params.set(\"severity\", filters.severity);\n    if (filters?.status) params.set(\"status\", filters.status);\n    if (filters?.search) params.set(\"search\", filters.search);\n\n    const query = params.toString() ? `?${params.toString()}` : \"\";\n    return request<{ success: boolean; governance: ApiGovernanceItem[] }>(`/governance${query}`);\n  },\n\n  get: async (id: string): Promise<{ success: boolean; governance: ApiGovernanceItem }> => {\n    return request<{ success: boolean; governance: ApiGovernanceItem }>(`/governance/${encodeURIComponent(id)}`);\n  },\n\n  create: async (govData: Partial<ApiGovernanceItem>): Promise<{ success: boolean; governance: ApiGovernanceItem }> => {\n    return request<{ success: boolean; governance: ApiGovernanceItem }>(\"/governance\", {\n      method: \"POST\",\n      body: JSON.stringify(govData),\n    });\n  },\n\n  update: async (id: string, govData: Partial<ApiGovernanceItem>): Promise<{ success: boolean; governance: ApiGovernanceItem }> => {\n    return request<{ success: boolean; governance: ApiGovernanceItem }>(`/governance/${encodeURIComponent(id)}`, {\n      method: \"PATCH\",\n      body: JSON.stringify(govData),\n    });\n  },\n\n  updateStatus: async (id: string, status: string): Promise<{ success: boolean; governance: ApiGovernanceItem }> => {\n    return request<{ success: boolean; governance: ApiGovernanceItem }>(`/governance/${encodeURIComponent(id)}/status`, {\n      method: \"PATCH\",\n      body: JSON.stringify({ status }),\n    });\n  },\n};\n\n/**\n * Analytics Module\n */\nexport const analytics = {\n  getAdminAnalytics: async (): Promise<AnalyticsResponse> => {\n    return request<AnalyticsResponse>(\"/analytics/admin\");\n  },\n\n  getClientAnalytics: async (clientId?: string): Promise<AnalyticsResponse> => {\n    const path = clientId ? `/analytics/client?client_id=${encodeURIComponent(clientId)}` : \"/analytics/client\";\n    return request<AnalyticsResponse>(path);\n  },\n};\n\n// ============================================================================\n// 4. UNIFIED EXPORT OBJECT\n// ============================================================================\n\nexport const apiClient = {\n  getApiBaseUrl,\n  getSt