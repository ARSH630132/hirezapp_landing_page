{"ts":"2026-06-27T13:56:53.072Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"tchdm5z0","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/api/v1/governance/[id]/route.ts:1-150","result":"  1 | import { NextResponse } from \"next/server\";\n  2 | import { \n  3 |   API_MOCK_USERS, API_MOCK_GOVERNANCE, API_MOCK_PROJECTS,\n  4 |   verifyJwt, MockUserDbEntry, ApiGovernanceItem, \n  5 |   getClientNameFromId, getClientIdFromAssociation \n  6 | } from \"../../../../../lib/api-auth\";\n  7 | \n  8 | export const runtime = \"nodejs\";\n  9 | \n 10 | function getAuthCaller(req: Request) {\n 11 |   const auth = req.headers.get(\"authorization\");\n 12 |   if (!auth?.startsWith(\"Bearer \")) return null;\n 13 |   const decoded = verifyJwt(auth.substring(7));\n 14 |   if (!decoded?.email) return null;\n 15 |   const user = (API_MOCK_USERS as Record<string, MockUserDbEntry>)[decoded.email.toLowerCase().trim()];\n 16 |   return user && user.status !== \"inactive\" ? user : null;\n 17 | }\n 18 | \n 19 | export async function GET(req: Request, { params }: { params: any }) {\n 20 |   try {\n 21 |     const caller = getAuthCaller(req);\n 22 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n 23 |     const { id } = await params;\n 24 |     const item = (API_MOCK_GOVERNANCE as Record<string, ApiGovernanceItem>)[id];\n 25 |     if (!item) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n 26 | \n 27 |     if (caller.role !== \"gff_admin\") {\n 28 |       const cid = getClientIdFromAssociation(caller.clientAssociation);\n 29 |       if (item.client_id !== cid) {\n 30 |         return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n 31 |       }\n 32 |     }\n 33 |     return NextResponse.json({ success: true, governance: item });\n 34 |   } catch (err) {\n 35 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n 36 |   }\n 37 | }\n 38 | \n 39 | export async function PATCH(req: Request, { params }: { params: any }) {\n 40 |   try {\n 41 |     const caller = getAuthCaller(req);\n 42 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n 43 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n 44 | \n 45 |     const { id } = await params;\n 46 |     const item = (API_MOCK_GOVERNANCE as Record<string, ApiGovernanceItem>)[id];\n 47 |     if (!item) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n 48 | \n 49 |     const body = await req.json().catch(() => null);\n 50 |     if (!body) return NextResponse.json({ success: false, error: \"Bad Request\" }, { status: 400 });\n 51 | \n 52 |     const fields = [\n 53 |       \"title\", \"client_id\", \"project_id\", \"severity\", \"status\", \n 54 |       \"owner\", \"due_date\", \"description\", \"standard\", \"nodeId\", \"hash\"\n 55 |     ];\n 56 | \n 57 |     for (const key of fields) {\n 58 |       if (body[key] !== undefined) {\n 59 |         if (key === \"title\" && (typeof body.title !== \"string\" || !body.title.trim())) {\n 60 |           return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid title.\" }, { status: 400 });\n 61 |         }\n 62 |         if (key === \"client_id\") {\n 63 |           const valids = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n 64 |           if (!valids.includes(body.client_id)) {\n 65 |             return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id.\" }, { status: 400 });\n 66 |           }\n 67 |           item.client_id = body.client_id;\n 68 |           item.client_name = getClientNameFromId(body.client_id);\n 69 |         } else if (key === \"project_id\") {\n 70 |           item.project_id = body.project_id || undefined;\n 71 |           if (body.project_id) {\n 72 |             const proj = (API_MOCK_PROJECTS as any)[body.project_id];\n 73 |             item.project_name = proj ? proj.name : undefined;\n 74 |           } else {\n 75 |             item.project_name = undefined;\n 76 |           }\n 77 |         } else {\n 78 |           (item as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n 79 |         }\n 80 |       }\n 81 |     }\n 82 | \n 83 |     if (body.logs && Array.isArray(body.logs)) {\n 84 |       item.logs = body.logs;\n 85 |     }\n 86 | \n 87 |     item.lastUpdated = new Date().toISOString();\n 88 |     (API_MOCK_GOVERNANCE as Record<string, ApiGovernanceItem>)[id] = item;\n 89 |     return NextResponse.json({ success: true, governance: item });\n 90 |   } catch (err) {\n 91 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n 92 |   }\n 93 | }\n 94 | \n 95 | export async function DELETE(req: Request, { params }: { params: any }) {\n 96 |   try {\n 97 |     const caller = getAuthCaller(req);\n 98 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n 99 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n100 | \n101 |     const { id } = await params;\n102 |     if (!(API_MOCK_GOVERNANCE as Record<string, ApiGovernanceItem>)[id]) {\n103 |       return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n104 |     }\n105 | \n106 |     delete (API_MOCK_GOVERNANCE as Record<string, ApiGovernanceItem>)[id];\n107 |     return NextResponse.json({ success: true, message: \"Governance item deleted.\" });\n108 |   } catch (err) {\n109 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n110 |   }\n111 | }","success":true}],"durationMs":1}}
