cess: boolean; operation: ApiAiOperation }> => {\n    return request<{ success: boolean; operation: ApiAiOperation }>(\"/ai-operations\", {\n      method: \"POST\",\n      body: JSON.stringify(opData),\n    });\n  },\n\n  update: async (id: string, opData: Partial<ApiAiOperation>): Promise<{ success: boolean; operation: ApiAiOperation }> => {\n    return request<{ success: boolean; operation: ApiAiOperation }>(`/ai-operations/${encodeURIComponent(id)}`, {\n      method: \"PATCH\",\n      body: JSON.stringify(opData),\n    });\n  },\n\n  delete: async (id: string): Promise<{ success: boolean; message: string }> => {\n    return request<{ success: boolean; message: string }>(`/ai-operations/${encodeURIComponent(id)}`, {\n      method: \"DELETE\",\n    });\n  },\n};\n\n/**\n * Documents Module (Supports real future REST architecture, falling back gracefully to seed data)\n */\nexport const documents = {\n  list: async (filters?: { client_id?: string; project_id?: string; search?: string }): Promise<{ success: boolean; documents: ApiDocumentItem[] }> => {\n    try {\n      const params = new URLSearchParams();\n      if (filters?.client_id) params.set(\"client_id\", filters.client_id);\n      if (filters?.project_id) params.set(\"project_id\", filters.project_id);\n      if (filters?.search) params.set(\"search\", filters.search);\n\n      const query = params.toString() ? `?${params.toString()}` : \"\";\n      return await request<{ success: boolean; documents: ApiDocumentItem[] }>(`/documents${query}`);\n    } catch {\n      // High-fidelity local seed fallbacks\n      const fallbackDocs: ApiDocumentItem[] = [\n        {\n          id: \"DOC-801\",\n          title: \"Sovereign Core Architectural Blueprint\",\n          fileSize: \"12.4 MB\",\n          type: \"PDF\",\n          sha256: \"0xAB9811C82FFD201A99E8F3C721A0C5E89812A\",\n          client_id: \"client-001\",\n          client_name: \"Apex Sovereign Group [Preview Client]\",\n          projectId: \"proj-001\"