4 += \"=\";\n 31 |   return Buffer.from(base64, \"base64\").toString(\"utf8\");\n 32 | }\n 33 | \n 34 | export function signJwt(payload: Record<string, any>, secret: string = JWT_SECRET, expiresInSec: number = 3600): string {\n 35 |   const header = { alg: \"HS256\", typ: \"JWT\" };\n 36 |   const now = Math.floor(Date.now() / 1000);\n 37 |   const fullPayload = { ...payload, iat: now, exp: now + expiresInSec };\n 38 |   \n 39 |   const encodedHeader = base64UrlEncode(JSON.stringify(header));\n 40 |   const encodedPayload = base64UrlEncode(JSON.stringify(fullPayload));\n 41 |   const signatureInput = `${encodedHeader}.${encodedPayload}`;\n 42 |   \n 43 |   const signature = crypto\n 44 |     .createHmac(\"sha256\", secret)\n 45 |     .update(signatureInput)\n 46 |     .digest(\"base64\")\n 47 |     .replace(/=/g, \"\")\n 48 |     .replace(/\\+/g, \"-\")\n 49 |     .replace(/\\//g, \"_\");\n 50 |     \n 51 |   return `${signatureInput}.${signature}`;\n 52 | }\n 53 | \n 54 | export function verifyJwt(token: string, secret: string = JWT_SECRET): Record<string, any> | null {\n 55 |   try {\n 56 |     const parts = token.split(\".\");\n 57 |     if (parts.length !== 3) return null;\n 58 |     \n 59 |     const [encodedHeader, encodedPayload, signature] = parts;\n 60 |     const signatureInput = `${encodedHeader}.${encodedPayload}`;\n 61 |     \n 62 |     const expectedSignature = crypto\n 63 |       .createHmac(\"sha256\", secret)\n 64 |       .update(signatureInput)\n 65 |       .digest(\"base64\")\n 66 |       .replace(/=/g, \"\")\n 67 |       .replace(/\\+/g, \"-\")\n 68 |       .replace(/\\//g, \"_\");\n 69 |       \n 70 |     if (signature !== expectedSignature) return null;\n 71 |     \n 72 |     const payload = JSON.parse(base64UrlDecode(encodedPayload));\n 73 |     if (payload.exp && Math.floor(Date.now() / 1000) > payload.exp) return null;\n 74 |     \n 75 |     return payload;\n 76 |   } catch (e) {\n 77 |     return null;\n 78 |   }\n 79 | }\n 80 | \n 81 | exp