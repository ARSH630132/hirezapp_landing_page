{"ts":"2026-06-27T02:24:35.096Z","type":"agent_event","event":{"type":"content_end","contentType":"reasoning","reasoning":"**Prioritizing New Features**\n\nI'm focusing on the integration. I aim to maintain the current user structure, roles, and scanning details while seamlessly adding GFF AI branding and custom visuals. Also, I plan on implementing interactive email input fields.\n\n\n**Refining Implementation Details**\n\nI'm now fully immersed in the nitty-gritty of implementation, specifically focusing on `SecureLogin.tsx`. My current focus is a complete rewrite. I'm meticulously crafting each step, ensuring a clean and precise editor write. My goal is a high-fidelity, premium login experience that adheres to our UI quality standards, including password placeholders, simulated identity profile autofill, and toggleable credentials vs. OTP modes. I'm prioritizing interactive input handlers, enter-key support, and SSO placeholders.\n\n\n"}}
{"ts":"2026-06-27T02:24:35.098Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ebalz8in","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/portal/SecureLogin.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  Lock, \n  Shield, \n  Key, \n  CheckCircle, \n  RefreshCw, \n  Layers, \n  Eye, \n  EyeOff, \n  Users, \n  Cpu, \n  FileText, \n  HelpCircle, \n  Fingerprint, \n  ArrowRight, \n  AlertCircle, \n  X, \n  Info, \n  Laptop, \n  Server, \n  Terminal \n} from \"lucide-react\";\nimport { setPreviewSession, PreviewRole, MOCK_PREVIEW_USERS } from \"@/lib/preview-auth\";\n\nexport default function SecureLogin({ defaultRole }: { defaultRole?: string }) {\n  const router = useRouter();\n  \n  // Choose initial role based on defaults\n  const initialRole: PreviewRole = defaultRole === \"Administrator\" ? \"gff_admin\" : \"client_admin\";\n  const [selectedRole, setSelectedRole] = useState<PreviewRole>(initialRole);\n  \n  // Auth state\n  const [authMethod, setAuthMethod] = useState<\"credentials\" | \"otp\">(\"credentials\");\n  const [email, setEmail] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n  const [otpCode, setOtpCode] = useState(\"\");\n  const [showPassword, setShowPassword] = useState(false);\n  const [error, setError] = useState(\"\");\n  \n  // UI Overlays\n  const [showForgotModal, setShowForgotModal] = useState(false);\n  const [showSupportModal, setShowSupportModal] = useState(false);\n  \n  // Handshake scan animation states\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n\n  const rolesList = [\n    { id: \"client_admin\" as PreviewRole, label: \"Client Admin\", clearance: \"Level III\", desc: \"Sandbox gateway owner\", icon: Users, color: \"text-cyan-400\" },\n    { id: \"client_member\" as PreviewRole, label: \"Client Member\", clearance: \"Level II\", desc: \"Sandbox layer worker\", icon: Layers, color: \"text-blue-400\" },\n    { id: \"gff_admin\" as PreviewRole, label: \"GFF Admin\", clearance: \"Level V\", desc: \"Root platform controller\", icon: Shield, color: \"text-red-400\" },\n    { id: \"gff_operator\" as PreviewRole, label: \"GFF Operator\", clearance: \"Level IV\", desc: \"Model architecture manager\", icon: Cpu, color: \"text-purple-400\" },\n    { id: \"finance_admin\" as PreviewRole, label: \"Finance Admin\", clearance: \"Level III\", desc: \"Epoch financial controller\", icon: FileText, color: \"text-emerald-400\" },\n    { id: \"support_agent\" as PreviewRole, label: \"Support Agent\", clearance: \"Level III\", desc: \"SLA wire representative\", icon: HelpCircle, color: \"text-orange-400\" },\n    { id: \"viewer\" as PreviewRole, label: \"Auditor (Viewer)\", clearance: \"Level I\", desc: \"Read-only observers\", icon: Eye, color: \"text-slate-400\" },\n  ];\n\n  // Pre-fill form when role changes\n  useEffect(() => {\n    const mockUser = MOCK_PREVIEW_USERS[selectedRole];\n    if (mockUser) {\n      setEmail(mockUser.email);\n      setPassword(\"••••••••••••\");\n      setOtpCode(\"102486\");\n    }\n  }, [selectedRole]);\n\n  const handleRoleSelection = (role: PreviewRole) => {\n    setSelectedRole(role);\n    setError(\"\");\n  };\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => setScanStep(p => p < 3 ? p + 1 : p), 220);\n    await new Promise(r => setTimeout(r, 1000));\n    clearInterval(interval);\n    setScanning(false);\n    \n    // Save state to preview session\n    setPreviewSession(selectedRole);\n    \n    // Route appropriately\n    if (selectedRole === \"client_admin\" || selectedRole === \"client_member\") {\n      router.push(\"/portal/dashboard\");\n    } else {\n      router.push(\"/admin/dashboard\");\n    }\n  };\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!email) {\n      setError(\"Operational identifier (Email) is required.\");\n      return;\n    }\n    if (authMethod === \"credentials\" && !password) {\n      setError(\"Clearance passphrase is required.\");\n      return;\n    }\n    if (authMethod === \"otp\" && !otpCode) {\n      setError(\"Single-Use Token is required.\");\n      return;\n    }\n    setError(\"\");\n    handleAuthenticate();\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n  const activeRoleObj = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n  \n  const scanMessages = [\n    \"Establishing zero-trust handshake protocol...\",\n    \"Isolating browser session within sandbox container...\",\n    \"Exchanging SHA-256 secure tokens...\",\n    \"Provisioning administrative clearance keys...\"\n  ];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-zinc-100 flex flex-col items-center justify-center relative px-4 py-12 select-none overflow-x-hidden\">\n      \n      {/* Premium Ambient Grid Background */}\n      <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#0f0f11_1px,transparent_1px),linear-gradient(to_bottom,#0f0f11_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] pointer-events-none\" />\n      \n      {/* Elegant Radial Soft Glows */}\n      <div className=\"absolute top-1/4 left-1/4 w-[500px] h-[500px] rounded-full bg-[#009DFF]/3 blur-[140px] pointer-events-none animate-pulse duration-[8000ms]\" />\n      <div className=\"absolute bottom-1/4 right-1/4 w-[500px] h-[500px] rounded-full bg-cyan-500/2 blur-[140px] pointer-events-none animate-pulse duration-[6000ms]\" />\n\n      <div className=\"w-full max-w-5xl z-10 space-y-8\">\n        \n        {/* Top Header & Core GFF AI Branding */}\n        <div className=\"text-center space-y-4\">\n          <div className=\"flex items-center justify-center\">\n            {/* Custom SVG Geometric Logo representing concentric core parts of GFF: Garage, Foundry, Factory */}\n            <div className=\"relative group flex items-center justify-center\">\n              <div className=\"absolute inset-0 rounded-2xl bg-gradient-to-tr from-[#009DFF]/20 to-cyan-500/20 blur-md opacity-70 group-hover:opacity-100 transition-opacity\" />\n              <div className=\"relative h-12 w-12 rounded-2xl border border-zinc-800 bg-zinc-950/90 flex items-center justify-center text-[#009DFF] shadow-inner\">\n                <svg className=\"w-7 h-7\" viewBox=\"0 0 100 100\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                  <path d=\"M50 5L90 28V72L50 95L10 72V28L50 5Z\" stroke=\"currentColor\" strokeWidth=\"3\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.03\" />\n                  <path d=\"M50 18L80 35V65L50 82L20 65V35L50 18Z\" stroke=\"currentColor\" strokeWidth=\"2.5\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.05\" />\n                  <path d=\"M50 32L70 43V57L50 68L30 57V43L50 32Z\" stroke=\"#00d2ff\" strokeWidth=\"2\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.1\" />\n                  <circle cx=\"50\" cy=\"50\" r=\"4.5\" fill=\"#009DFF\" className=\"animate-pulse\" />\n                </svg>\n              </div>\n            </div>\n          </div>\n          \n          <div className=\"space-y-1\">\n            <h1 className=\"text-xl md:text-2xl font-bold font-sans tracking-tight text-white uppercase flex items-center justify-center gap-2\">\n              GFF AI <span className=\"text-zinc-500 font-light\">|</span> <span className=\"text-[#009DFF] tracking-widest font-mono text-lg md:text-xl\">Sovereign Gateway</span>\n            </h1>\n            <p className=\"text-xs text-zinc-400 max-w-lg mx-auto leading-relaxed\">\n              Zero-Trust identity verification platform. Access authorized development enclaves and real-time operations dashboards.\n            </p>\n          </div>\n        </div>\n\n        {/* Main Interface Layout Card */}\n        <div className=\"border border-zinc-800/80 bg-zinc-950/60 backdrop-blur-xl rounded-2xl shadow-[0_25px_60px_-15px_rgba(0,0,0,0.9)] overflow-hidden transition-all\">\n          \n          {!scanning ? (\n            <div className=\"grid grid-cols-1 lg:grid-cols-12 divide-y lg:divide-y-0 lg:divide-x divide-zinc-800/60\">\n              \n              {/* Left Side: Premium Enterprise Login Form (7 columns) */}\n              <form onSubmit={handleSubmit} className=\"lg:col-span-7 p-6 md:p-8 lg:p-10 space-y-6\">\n                \n                {/* Secure Gateway Title & Handshake Indicator */}\n                <div className=\"flex justify-between items-center pb-2 border-b border-zinc-800/40\">\n                  <div>\n                    <h2 className=\"text-sm font-semibold text-zinc-100 uppercase tracking-wider font-mono\">Authentication Terminal</h2>\n                    <p className=\"text-[10.5px] text-zinc-500 mt-0.5 font-sans\">Initialize cryptographic keys to authorize the current browser.</p>\n                  </div>\n                  <div className=\"flex items-center gap-1.5 px-2 py-1 rounded bg-emerald-500/5 border border-emerald-500/20 text-emerald-400 text-[9px] font-mono font-medium tracking-wider\">\n                    <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n                    ONLINESECURE\n                  </div>\n                </div>\n\n                {/* Secure Tab Swapper: Secure Keycard (Credentials) vs Single-Use Token (OTP) */}\n                <div className=\"flex border-b border-zinc-800/60\" role=\"tablist\">\n                  <button\n                    type=\"button\"\n                    onClick={() => { setAuthMethod(\"credentials\"); setError(\"\"); }}\n                    className={`flex-1 pb-2.5 text-xs font-semibold uppercase tracking-wider border-b-2 transition-all ${\n                      authMethod === \"credentials\"\n                        ? \"border-[#009DFF] text-white\"\n                        : \"border-transparent text-zinc-500 hover:text-zinc-300\"\n                    }`}\n                    role=\"tab\"\n                    aria-selected={authMethod === \"credentials\"}\n                  >\n                    Secure Keycard\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={() => { setAuthMethod(\"otp\"); setError(\"\"); }}\n                    className={`flex-1 pb-2.5 text-xs font-semibold uppercase tracking-wider border-b-2 transition-all ${\n                      authMethod === \"otp\"\n                        ? \"border-[#009DFF] text-white\"\n                        : \"border-transparent text-zinc-500 hover:text-zinc-300\"\n                    }`}\n                    role=\"tab\"\n                    aria-selected={authMethod === \"otp\"}\n                  >\n                    Single-Use Token (OTP)\n                  </button>\n                </div>\n\n                {/* Form Inputs container */}\n                <div className=\"space-y-4\">\n                  \n                  {/* Email Input */}\n                  <div className=\"space-y-2\">\n                    <label className=\"text-[10.5px] font-mono text-zinc-400 uppercase tracking-widest block font-semibold\">\n                      Enterprise Identifier (Email)\n                    </label>\n                    <div className=\"relative\">\n                      <input\n                        type=\"email\"\n                        value={email}\n                        onChange={(e) => setEmail(e.target.value)}\n                        placeholder=\"e.g. administrator@gff.ai\"\n                        className=\"w-full h-11 pl-3.5 pr-10 rounded-lg bg-zinc-950/80 border border-zinc-800 focus:border-[#009DFF] focus:ring-2 focus:ring-[#009DFF]/15 text-zinc-100 text-xs placeholder-zinc-600 transition-all font-sans outline-none\"\n                        required\n                        aria-label=\"Enterprise Email Address\"\n                      />\n                      <div className=\"absolute right-3.5 top-1/2 -translate-y-1/2 text-zinc-600\">\n                        <Users className=\"w-4 h-4\" />\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Credentials Passphrase Input */}\n                  {authMethod === \"credentials\" ? (\n                    <div className=\"space-y-2\">\n                      <div className=\"flex justify-between items-center\">\n                        <label className=\"text-[10.5px] font-mono text-zinc-400 uppercase tracking-widest block font-semibold\">\n                          Clearance Passphrase\n                        </label>\n                        <button\n                          type=\"button\"\n                          onClick={() => setShowForgotModal(true)}\n                          className=\"text-[10px] text-zinc-500 hover:text-[#009DFF] transition-colors font-sans hover:underline focus:outline-none\"\n                        >\n                          Request Passphrase Reset?\n                        </button>\n                      </div>\n                      <div className=\"relative\">\n                        <input\n                          type={showPassword ? \"text\" : \"password\"}\n                          value={password}\n                          onChange={(e) => setPassword(e.target.value)}\n                          placeholder=\"••••••••••••\"\n                          className=\"w-full h-11 pl-3.5 pr-10 rounded-lg bg-zinc-950/80 border border-zinc-800 focus:border-[#009DFF] focus:ring-2 focus:ring-[#009DFF]/15 text-zinc-100 text-xs placeholder-zinc-600 transition-all font-mono tracking-widest outline-none\"\n                          required\n                          aria-label=\"Security Passphrase\"\n                        />\n                        <button\n                          type=\"button\"\n                          onClick={() => setShowPassword(!showPassword)}\n                          className=\"absolute right-3.5 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300 transition-colors focus:outline-none\"\n                          aria-label={showPassword ? \"Hide password\" : \"Show password\"}\n                        >\n                          {showPassword ? <EyeOff className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}\n                        </button>\n                      </div>\n                    </div>\n                  ) : (\n                    /* OTP Token input */\n                    <div className=\"space-y-2\">\n                      <div className=\"flex justify-between items-center\">\n                        <label className=\"text-[10.5px] font-mono text-zinc-400 uppercase tracking-widest block font-semibold\">\n                          One-Time Verification Token\n                        </label>\n                        <button\n                          type=\"button\"\n                          onClick={() => alert(\"Verification token simulator: In actual production, an active hardware security key or authenticator app will provide this dynamic passcode.\")}\n                          className=\"text-[10px] text-zinc-500 hover:text-[#009DFF] transition-colors font-sans hover:underline focus:outline-none\"\n                        >\n                          Resend Token Code?\n                        </button>\n                      </div>\n                      <div className=\"relative\">\n                        <input\n                          type=\"text\"\n                          value={otpCode}\n                          onChange={(e) => setOtpCode(e.target.value)}\n                          placeholder=\"102486\"\n                          maxLength={6}\n                          className=\"w-full h-11 pl-3.5 pr-10 rounded-lg bg-zinc-950/80 border border-zinc-800 focus:border-[#009DFF] focus:ring-2 focus:ring-[#009DFF]/15 text-zinc-100 text-xs placeholder-zinc-600 transition-all font-mono tracking-[0.4em] text-center outline-none\"\n                          required\n                          aria-label=\"Six Digit One-Time Passcode\"\n                        />\n                        <div className=\"absolute right-3.5 top-1/2 -translate-y-1/2 text-zinc-600\">\n                          <Fingerprint className=\"w-4 h-4\" />\n                        </div>\n                      </div>\n                    </div>\n                  )}\n\n                </div>\n\n                {/* Display validation errors if any */}\n                {error && (\n                  <div className=\"p-3 bg-red-950/35 border border-red-900/40 text-red-400 rounded-lg text-xs flex items-start gap-2.5 font-sans\">\n                    <AlertCircle className=\"w-4 h-4 shrink-0 mt-0.5\" />\n                    <span>{error}</span>\n                  </div>\n                )}\n\n                {/* Primary Actions Button */}\n                <button\n                  type=\"submit\"\n                  className=\"w-full h-11 rounded-lg bg-[#009DFF] hover:bg-[#0086db] text-black font-semibold text-xs uppercase tracking-wider flex items-center justify-center gap-2 cursor-pointer active:scale-[0.99] transition-all hover:shadow-[0_0_25px_rgba(0,157,255,0.2)] focus:ring-2 focus:ring-[#009DFF]\"\n                >\n                  <Lock className=\"w-3.5 h-3.5\" />\n                  Authorize Sovereign Enclave\n                  <ArrowRight className=\"w-3.5 h-3.5\" />\n                </button>\n\n                {/* Federated SSO Login Options Placeholder */}\n                <div className=\"space-y-3 pt-3\">\n                  <div className=\"flex items-center justify-between text-[9px] text-zinc-500 font-semibold uppercase tracking-widest\">\n                    <span className=\"h-[1px] bg-zinc-800/80 flex-1 mr-3\" />\n                    <span>or authenticate via SSO</span>\n                    <span className=\"h-[1px] bg-zinc-800/80 flex-1 ml-3\" />\n                  </div>\n\n                  <div className=\"grid grid-cols-2 gap-3\">\n                    <button\n                      type=\"button\"\n                      onClick={() => alert(\"SSO handshaking: Connecting browser to Azure AD/Entra portal...\")}\n                      className=\"flex items-center justify-center gap-2 py-2.5 px-3 rounded-lg border border-zinc-800 bg-zinc-900/30 hover:bg-zinc-800/50 text-[11px] font-sans font-medium text-zinc-300 transition-all hover:border-zinc-700 active:scale-[0.98] cursor-pointer\"\n                    >\n                      <svg className=\"w-3.5 h-3.5 shrink-0\" viewBox=\"0 0 23 23\" fill=\"currentColor\">\n                        <path d=\"M0 0h11v11H0z\" fill=\"#f25022\"/>\n                        <path d=\"M12 0h11v11H12z\" fill=\"#7fba00\"/>\n                        <path d=\"M0 12h11v11H0z\" fill=\"#00a4ef\"/>\n                        <path d=\"M12 12h11v11H12z\" fill=\"#ffb900\"/>\n                      </svg>\n                      <span>Entra ID</span>\n                    </button>\n                    <button\n                      type=\"button\"\n                      onClick={() => alert(\"SSO handshaking: Initializing secure Okta enclave verification...\")}\n                      className=\"flex items-center justify-center gap-2 py-2.5 px-3 rounded-lg border border-zinc-800 bg-zinc-900/30 hover:bg-zinc-800/50 text-[11px] font-sans font-medium text-zinc-300 transition-all hover:border-zinc-700 active:scale-[0.98] cursor-pointer\"\n                    >\n                      <svg className=\"w-3.5 h-3.5 shrink-0 text-[#007dc1]\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                        <path d=\"M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm0 18c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z\"/>\n                      </svg>\n                      <span>Okta SSO</span>\n                    </button>\n                  </div>\n                </div>\n\n                {/* Forgot Credentials & Support Link relays */}\n                <div className=\"flex justify-between text-[11px] text-zinc-500 pt-2 font-sans\">\n                  <span>Authorized use only.</span>\n                  <button\n                    type=\"button\"\n                    onClick={() => setShowSupportModal(true)}\n                    className=\"hover:text-[#009DFF] hover:underline flex items-center gap-1 transition-all focus:outline-none\"\n                  >\n                    <HelpCircle className=\"w-3.5 h-3.5\" /> Contact Support Relay\n                  </button>\n                </div>\n\n              </form>\n\n              {/* Right Side: Local Identity Deck Selector & Simulation Notice (5 columns) */}\n              <div className=\"lg:col-span-5 p-6 md:p-8 bg-zinc-900/25 flex flex-col justify-between space-y-6\">\n                \n                <div className=\"space-y-4\">\n                  {/* Local Sandbox Title */}\n                  <div className=\"space-y-1\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n                      <h3 className=\"text-xs font-semibold text-white font-mono uppercase tracking-wider\">Local Role Sandbox</h3>\n                    </div>\n                    <p className=\"text-[10.5px] text-zinc-400 leading-relaxed font-sans\">\n                      Select an administrative role profile to pre-configure secure clearance credentials and test granular dashboard boundaries.\n                    </p>\n                  </div>\n\n                  {/* Sandbox Frontend-only warning notice */}\n                  <div className=\"p-3 rounded-xl border border-[#009DFF]/20 bg-[#009DFF]/5 text-zinc-300 text-[10.5px] leading-relaxed space-y-1.5 font-sans\">\n                    <div className=\"flex items-center gap-1.5 font-bold text-[#009DFF] uppercase tracking-wider font-mono text-[9px]\">\n                      <Info className=\"w-3.5 h-3.5 shrink-0\" />\n                      Frontend-Only Notice\n                    </div>\n                    <p className=\"text-zinc-400\">\n                      This environment operates fully in browser sandbox memory. Credentials are isolated, safe, and require no backend server database handshakes.\n                    </p>\n                  </div>\n\n                  {/* Scrollable list of identity configurations */}\n                  <div className=\"space-y-1.5 max-h-[260px] overflow-y-auto pr-1 select-none custom-scrollbar\">\n                    {rolesList.map((r) => {\n                      const isSel = selectedRole === r.id;\n                      const RoleIcon = r.icon;\n                      return (\n                        <button\n                          key={r.id}\n                          type=\"button\"\n                          onClick={() => handleRoleSelection(r.id)}\n                          className={`w-full p-2.5 rounded-xl border text-left cursor-pointer flex justify-between items-center transition-all text-xs group focus:outline-none ${\n                            isSel \n                              ? \"border-[#009DFF]/40 bg-[#009DFF]/10 text-white shadow-[0_0_15px_rgba(0,157,255,0.05)]\" \n                              : \"border-zinc-800/40 bg-zinc-950/20 hover:bg-zinc-900/40 hover:border-zinc-800 text-zinc-400\"\n                          }`}\n                        >\n                          <div className=\"flex items-center gap-3 truncate\">\n                            <div className={`p-1.5 rounded-lg ${isSel ? \"bg-zinc-950\" : \"bg-transparent\"} shrink-0`}>\n                              <RoleIcon className={`w-3.5 h-3.5 ${r.color}`} />\n                            </div>\n                            <div className=\"truncate\">\n                              <span className={`font-bold block ${isSel ? \"text-white font-semibold\" : \"text-zinc-300 group-hover:text-zinc-200\"}`}>{r.label}</span>\n                              <span className=\"text-[9px] text-zinc-500 font-sans block truncate group-hover:text-zinc-400\">{r.desc}</span>\n                            </div>\n                          </div>\n                          <span className={`text-[8px] font-bold border rounded-md px-2 py-0.5 shrink-0 font-mono tracking-wider ${\n                            isSel \n                              ? \"border-[#009DFF]/30 text-[#009DFF] bg-[#009DFF]/5\" \n                              : \"border-zinc-800 text-zinc-500 group-hover:border-zinc-700\"\n                          }`}>\n                            {r.clearance}\n                          </span>\n                        </button>\n                      );\n                    })}\n                  </div>\n                </div>\n\n                {/* Simulated Identity Active Status card */}\n                <div className=\"pt-2.5 border-t border-zinc-800/50 space-y-2 font-mono\">\n                  <div className=\"text-[8px] font-bold text-zinc-500 uppercase tracking-widest flex items-center gap-1.5\">\n                    <Server className=\"w-3 h-3 text-zinc-500\" />\n                    Simulated Access Profile\n                  </div>\n                  <div className=\"p-3 bg-zinc-950/80 border border-zinc-900 rounded-xl space-y-1.5\">\n                    <div className=\"flex items-center justify-between text-[11px] font-bold text-white truncate\">\n                      <span className=\"truncate\">{currentMockUser.name}</span>\n                      <span className=\"text-[8.5px] text-[#009DFF] font-semibold border border-[#009DFF]/25 px-1.5 py-0.5 rounded bg-[#009DFF]/5 uppercase\">{activeRoleObj.clearance}</span>\n                    </div>\n                    <div className=\"text-[10px] text-zinc-500 truncate\">{currentMockUser.email}</div>\n                  </div>\n                </div>\n\n              </div>\n\n            </div>\n          ) : (\n            /* Setup Handshake Cryptographic Scanning Display */\n            <div className=\"space-y-6 py-12 px-6 max-w-md mx-auto text-center font-mono\">\n              <div className=\"relative h-20 w-20 bg-zinc-950 border border-[#009DFF]/20 rounded-full flex items-center justify-center overflow-hidden shadow-[0_0_35px_rgba(0,157,255,0.1)] mx-auto\">\n                <div className=\"absolute left-0 right-0 h-[2px] bg-cyan-400 shadow-[0_0_12px_#009DFF] animate-bounce\" style={{ top: \"45%\" }} />\n                <RefreshCw className=\"w-7 h-7 text-[#009DFF] animate-spin shrink-0\" />\n              </div>\n              \n              <div className=\"space-y-2.5\">\n                <div className=\"flex justify-between items-center text-[10px] text-zinc-500 tracking-wider\">\n                  <span>HANDSHAKE SECURE CHANNELS</span>\n                  <span className=\"text-white font-bold\">{Math.min(100, Math.round((scanStep + 1) * 25))}%</span>\n                </div>\n                <div className=\"h-1.5 w-full bg-zinc-900 rounded-full overflow-hidden border border-zinc-800\">\n                  <div className=\"h-full bg-gradient-to-r from-[#009DFF] to-cyan-400 transition-all duration-300\" style={{ width: `${(scanStep + 1) * 25}%` }} />\n                </div>\n              </div>\n\n              <div className=\"p-4 rounded-xl border border-zinc-800/80 bg-zinc-950 text-xs text-left space-y-2.5 min-h-[125px]\">\n                {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                  <div key={idx} className=\"flex items-center gap-3 text-zinc-300\">\n                    {idx < scanStep ? (\n                      <CheckCircle className=\"w-4 h-4 text-emerald-400 shrink-0\" />\n                    ) : (\n                      <RefreshCw className=\"w-4 h-4 text-[#009DFF] animate-spin shrink-0\" />\n                    )}\n                    <span className={idx < scanStep ? \"text-zinc-600 line-through font-light\" : \"text-white font-semibold\"}>\n                      {msg}\n                    </span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n        {/* Global Footer Notes */}\n        <div className=\"flex flex-col sm:flex-row items-center justify-between gap-4 text-[11px] text-zinc-500/80 px-2 font-sans\">\n          <div className=\"flex items-center gap-2\">\n            <Shield className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n            <span>Sovereign Enclave protocol GFF_0x7FFA enabled.</span>\n          </div>\n          <div className=\"flex items-center gap-4\">\n            <a href=\"/privacy\" className=\"hover:text-zinc-300 hover:underline\">Privacy Policy</a>\n            <span className=\"text-zinc-800\">|</span>\n            <a href=\"/terms\" className=\"hover:text-zinc-300 hover:underline\">Terms of Service</a>\n          </div>\n        </div>\n\n      </div>\n\n      {/* Forgot Password Recovery Modal */}\n      {showForgotModal && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md p-4 animate-fade-in\" role=\"dialog\" aria-modal=\"true\">\n          <div className=\"bg-zinc-950 border border-zinc-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n            <div className=\"flex justify-between items-start\">\n              <div className=\"flex items-center gap-2.5 text-zinc-200\">\n                <div className=\"p-1.5 rounded-lg bg-[#009DFF]/10 text-[#009DFF]\">\n                  <Fingerprint className=\"w-5 h-5\" />\n                </div>\n                <h3 className=\"font-mono font-bold text-sm uppercase tracking-wider\">Credential Recovery</h3>\n              </div>\n              <button \n                onClick={() => setShowForgotModal(false)} \n                className=\"text-zinc-500 hover:text-zinc-300 transition-colors cursor-pointer p-1 rounded-md hover:bg-zinc-900\"\n                aria-label=\"Close recovery dialog\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            <p className=\"text-xs text-zinc-400 leading-relaxed font-sans\">\n              GFF AI Zero-Trust access enclaves enforce extreme security boundaries. Recovery keys and new security profiles must be issued by your enterprise administrator or a delegated GFF security agent.\n            </p>\n            <div className=\"bg-zinc-900/60 p-3.5 rounded-xl border border-zinc-800/80 font-mono text-[10px] text-zinc-500 space-y-1\">\n              <div className=\"flex justify-between\"><span className=\"uppercase\">Recovery Tunnel:</span> <span className=\"text-zinc-400\">ACTIVE</span></div>\n              <div className=\"flex justify-between\"><span className=\"uppercase\">Handshake Reference:</span> <span className=\"text-[#009DFF]\">SECURE_RECOVERY_0x8F9B2C</span></div>\n            </div>\n            <div className=\"flex justify-end pt-2\">\n              <button\n                type=\"button\"\n                onClick={() => setShowForgotModal(false)}\n                className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-sans font-bold text-xs uppercase tracking-wider rounded-lg transition-all cursor-pointer\"\n              >\n                Close Connection\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Contact Support Relay Modal */}\n      {showSupportModal && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md p-4 animate-fade-in\" role=\"dialog\" aria-modal=\"true\">\n          <div className=\"bg-zinc-950 border border-zinc-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n            <div className=\"flex justify-between items-start\">\n              <div className=\"flex items-center gap-2.5 text-zinc-200\">\n                <div className=\"p-1.5 rounded-lg bg-[#009DFF]/10 text-[#009DFF]\">\n                  <HelpCircle className=\"w-5 h-5\" />\n                </div>\n                <h3 className=\"font-mono font-bold text-sm uppercase tracking-wider\">Secure Support Relay</h3>\n              </div>\n              <button \n                onClick={() => setShowSupportModal(false)} \n                className=\"text-zinc-500 hover:text-zinc-300 transition-colors cursor-pointer p-1 rounded-md hover:bg-zinc-900\"\n                aria-label=\"Close support dialog\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            <p className=\"text-xs text-zinc-400 leading-relaxed font-sans\">\n              Connect directly with GFF AI’s Operations Command Center for priority routing and enclave management support.\n            </p>\n            <div className=\"p-4 bg-zinc-900/60 border border-zinc-800/80 rounded-xl space-y-2 text-xs font-mono\">\n              <div className=\"text-zinc-400 flex justify-between\">\n                <span>Support Relay:</span>\n                <span className=\"text-[#009DFF] font-semibold select-all\">support@gff.ai</span>\n              </div>\n              <div className=\"text-zinc-400 flex justify-between\">\n                <span>Security Queue:</span>\n                <span className=\"text-emerald-400 font-semibold uppercase tracking-wider\">Level 1 - Active</span>\n              </div>\n            </div>\n            <div className=\"flex justify-end pt-2\">\n              <button\n                type=\"button\"\n                onClick={() => setShowSupportModal(false)}\n                className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-sans font-bold text-xs uppercase tracking-wider rounded-lg transition-all cursor-pointer\"\n              >\n                Close Relay\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}"}}}
