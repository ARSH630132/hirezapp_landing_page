olor: \"text-red-400\" },\n    { id: \"gff_operator\" as PreviewRole, label: \"GFF Operator\", clearance: \"L-4\", desc: \"Model architecture manager\", icon: Cpu, color: \"text-purple-400\" },\n    { id: \"finance_admin\" as PreviewRole, label: \"Finance Admin\", clearance: \"L-3\", desc: \"Epoch financial controller\", icon: FileText, color: \"text-emerald-400\" },\n    { id: \"support_agent\" as PreviewRole, label: \"Support Agent\", clearance: \"L-3\", desc: \"SLA wire representative\", icon: HelpCircle, color: \"text-orange-400\" },\n    { id: \"viewer\" as PreviewRole, label: \"Auditor (Viewer)\", clearance: \"L-1\", desc: \"Read-only observers\", icon: Eye, color: \"text-slate-400\" },\n  ];\n\n  useEffect(() => {\n    const mockUser = MOCK_PREVIEW_USERS[selectedRole];\n    if (mockUser) {\n      setEmail(mockUser.email);\n      setPassword(\"••••••••••••\");\n      setOtpCode(\"102486\");\n    }\n  }, [selectedRole]);\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => setScanStep(p => p < 3 ? p + 1 : p), 220);\n    await new Promise(r => setTimeout(r, 900));\n    clearInterval(interval);\n    setScanning(false);\n    setPreviewSession(selectedRole);\n    router.push(selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n  };\n\n  const handleSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!email) return setError(\"Operational identifier (Email) is required.\");\n    if (authMethod === \"credentials\" && !password) return setError(\"Clearance passphrase is required.\");\n    if (authMethod === \"otp\" && !otpCode) return setError(\"Single-Use Token is required.\");\n    setError(\"\");\n    handleAuthenticate();\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n  const scanMessages = [\n    \"Establishing zero-trust handshake protocol...\",\n    \"Isolating browser session within sandbox container...\",\n    \"Exchanging SHA-256 secure tokens...\",\n    \"Provisioning administrative clearance keys...\"\n  ];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-zinc-100 flex flex-col items-center justify-center relative px-4 py-10 select-none overflow-hidden\">\n      {/* BACKGROUND GRAPHICS */}\n      <div className=\"absolute inset-0 bg-[linear-gradient(to_right,#0f0f11_1px,transparent_1px),linear-gradient(to_bottom,#0f0f11_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)] pointer-events-none\" />\n      <div className=\"absolute top-1/4 left-1/4 w-[350px] h-[350px] rounded-full bg-[#009DFF]/3 blur-[120px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-1/4 w-[350px] h-[350px] rounded-full bg-cyan-500/2 blur-[120px] pointer-events-none\" />\n\n      <div className=\"w-full max-w-5xl z-10 space-y-6\">\n        {/* BRANDING HEADER */}\n        <div className=\"text-center space-y-3\">\n          <div className=\"flex justify-center\">\n            <div className=\"relative h-12 w-12 rounded-xl border border-zinc-800 bg-zinc-950/90 flex items-center justify-center text-[#009DFF] shadow-lg\">\n              <svg className=\"w-7 h-7\" viewBox=\"0 0 100 100\" fill=\"none\">\n                <path d=\"M50 5L90 28V72L50 95L10 72V28L50 5Z\" stroke=\"currentColor\" strokeWidth=\"3\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.03\" />\n                <path d=\"M50 18L80 35V65L50 82L20 65V35L50 18Z\" stroke=\"currentColor\" strokeWidth=\"2.5\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.05\" />\n                <path d=\"M50 32L70 43V57L50 68L30 57V43L50 32Z\" stroke=\"#00d2ff\" strokeWidth=\"2\" strokeLinejoin=\"round\" fill=\"currentColor\" fillOpacity=\"0.1\" />\n                <circle cx=\"50\" cy=\"50\" r=\"4.5\" fill=\"#009DFF\" />\n              </svg>\n            </div>\n          </div>\n          <div>\n            <h1 className=\"text-lg md:text-xl font-bold font-sans tracking-tight text-white uppercase flex items-center justify-center gap-2\">\n              GFF AI <span className=\"text-zinc-600 font-light\">|</span> <span className=\"text-[#009DFF] tracking-wider font-mono\">Sovereign Gateway</span>\n            </h1>\n            <p className=\"text-[11px] text-zinc-500 max-w-md mx-auto\">Zero-Trust developer credentials gateway. Use the sandbox selector to test operational dashboard roles.</p>\n          </div>\n        </div>\n\n        {/* MAIN CONTAINER */}\n        <div className=\"border border-zinc-800/80 bg-zinc-950/50 backdrop-blur-md rounded-xl shadow-2xl overflow-hidden\">\n          {/* PLACEHOLDER FOR NEXT PORTION */}\n          <div id=\"content-container\">REPLACE_ME</div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
