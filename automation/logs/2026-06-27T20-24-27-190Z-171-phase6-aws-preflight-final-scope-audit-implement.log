s provided.\" },\n46 |         { status: 401 }\n47 |       );\n48 |     }\n49 | \n50 |     const tokenPayload = {\n51 |       sub: user.id,\n52 |       email: user.email,\n53 |       role: user.role,\n54 |       name: user.name,\n55 |       clearance: user.clearance,\n56 |     };\n57 | \n58 |     const accessToken = signJwt(tokenPayload);\n59 | \n60 |     // Exclude passwordHash from user info returned\n61 |     const { passwordHash, ...userResponse } = user;\n62 | \n63 |     return NextResponse.json(\n64 |       {\n65 |         success: true,\n66 |         accessToken,\n67 |         tokenType: \"Bearer\",\n68 |         expiresIn: 3600,\n69 |         user: userResponse,\n70 |       },\n71 |       { status: 200 }\n72 |     );\n73 |   } catch (error: any) {\n74 |     console.error(\"Auth login error:\", error);\n75 |     return NextResponse.json(\n76 |       { success: false, error: \"Internal Server Error\", message: \"An unexpected error occurred during authentication.\" },\n77 |       { status: 500 }\n78 |     );\n79 |   }\n80 | }","success":true}],"durationMs":3}}
