{"ts":"2026-06-27T13:26:46.506Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7oow46cj","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-analytics-apis.js","new_text":"/* eslint-disable */\n\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-analytics-build');\n\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\ntry {\n  console.log(\"Compiling files for test...\");\n  execSync('npx tsc lib/api-auth.ts app/api/v1/analytics/client/route.ts app/api/v1/analytics/admin/route.ts --outDir temp-analytics-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  console.error(\"✖ Compilation failed:\", e.message);\n  process.exit(1);\n}\n\nconst apiAuth = require('../temp-analytics-build/lib/api-auth.js');\nconst clientRoute = require('../temp-analytics-build/app/api/v1/analytics/client/route.js');\nconst adminRoute = require('../temp-analytics-build/app/api/v1/analytics/admin/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\");\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\");\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    // --- TEST CLIENT ANALYTICS ---\n    console.log(\"\\nTesting Client Analytics Summary API...\");\n\n    // Inactive user validation (403)\n    let res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client\", { headers: { \"Authorization\": inactive } }));\n    if (res.status !== 403) throw new Error(\"Inactive user must return 403\");\n\n    // Unauthorized validation (401)\n    res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client\"));\n    if (res.status !== 401) throw new Error(\"Request without auth token must return 401\");\n\n    // Client Mercer GET (client-001)\n    res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client\", { headers: { \"Authorization\": client } }));\n    if (res.status !== 200) throw new Error(\"Client analytics GET failed\");\n    let d = await res.json();\n    if (!d.success) throw new Error(\"Response success must be true\");\n    if (d.client_id !== \"client-001\") throw new Error(\"Client ID mismatch\");\n    \n    // Assert client-001 summary metrics exist and are correctly aggregated\n    const summary = d.summary;\n    if (!summary.projects || typeof summary.projects.totalCount !== \"number\" || !summary.projects.byStatus || !summary.projects.byPhase) {\n      throw new Error(\"Projects aggregation fields missing or malformed\");\n    }\n    if (!summary.aiOperations || typeof summary.aiOperations.totalCount !== \"number\" || !summary.aiOperations.byStatus || !summary.aiOperations.byHealth) {\n      throw new Error(\"AI Operations aggregation fields missing or malformed\");\n    }\n    if (!summary.documents || typeof summary.documents.totalCount !== \"number\" || !summary.documents.byStatus) {\n      throw new Error(\"Documents aggregation fields missing or malformed\");\n    }\n    if (!summary.invoices || typeof summary.invoices.totalCount !== \"number\" || !summary.invoices.byStatus) {\n      throw new Error(\"Invoices aggregation fields missing or malformed\");\n    }\n    if (!summary.support || typeof summary.support.totalCount !== \"number\" || !summary.support.byStatus || !summary.support.byPriority) {\n      throw new Error(\"Support aggregation fields missing or malformed\");\n    }\n    if (!summary.governance || typeof summary.governance.totalCount !== \"number\" || !summary.governance.byStatus || !summary.governance.bySeverity) {\n      throw new Error(\"Governance aggregation fields missing or malformed\");\n    }\n\n    console.log(\"✔ Client (client-001) aggregated projects: \" + JSON.stringify(summary.projects));\n    console.log(\"✔ Client (client-001) aggregated support: \" + JSON.stringify(summary.support));\n\n    // Client Member GET (client-004)\n    res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client\", { headers: { \"Authorization\": member } }));\n    d = await res.json();\n    if (d.client_id !== \"client-004\") throw new Error(\"Client member ID mismatch\");\n\n    // Cross-tenant check (client trying to request client-004 analytics)\n    res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client?client_id=client-004\", { headers: { \"Authorization\": client } }));\n    if (res.status !== 403) throw new Error(\"Cross-tenant client analytics access must return 403\");\n\n    // Admin calling client analytics for client-004\n    res = await clientRoute.GET(new Request(\"http://l/api/v1/analytics/client?client_id=client-004\", { headers: { \"Authorization\": admin } }));\n    if (res.status !== 200) throw new Error(\"Admin fetching client analytics failed\");\n    d = await res.json();\n    if (d.client_id !== \"client-004\") throw new Error(\"Admin fetching client analytics client_id mismatch\");\n\n    // --- TEST ADMIN ANALYTICS ---\n    console.log(\"\\nTesting Admin Analytics Summary API...\");\n\n    // RBAC validation\n    res = await adminRoute.GET(new Request(\"http://l/api/v1/analytics/admin\", { headers: { \"Authorization\": client } }));\n    if (res.status !== 403) throw new Error(\"Non-admin accessing admin analytics must return 403\");\n\n    // Admin GET global summary\n    res = await adminRoute.GET(new Request(\"http://l/api/v1/analytics/admin\", { headers: { \"Authorization\": admin } }));\n    if (res.status !== 200) throw new Error(\"Admin analytics GET failed\");\n    d = await res.json();\n    if (!d.success) throw new Error(\"Response success must be true\");\n    \n    // Verify admin summary aggregates\n    const adminSum = d.summary;\n    if (adminSum.projects.totalCount < 5) throw new Error(\"Global projects count should be at least 5\");\n    if (adminSum.documents.totalCount < 4) throw new Error(\"Global documents count should be at least 4\");\n    if (adminSum.support.totalCount < 3) throw new Error(\"Global support count should be at least 3\");\n\n    // Check specific aggregations\n    if (!adminSum.projects.byStatus.active) throw new Error(\"Projects status 'active' count missing in global summary\");\n    if (!adminSum.support.byPriority.P1) throw new Error(\"Support priority 'P1' count missing in global summary\");\n    if (!adminSum.governance.bySeverity.Critical) throw new Error(\"Governance severity 'Critical' count missing in global summary\");\n\n    console.log(\"✔ Admin summary details - Projects: \" + adminSum.projects.totalCount + \", Invoices Statuses: \" + JSON.stringify(adminSum.invoices.byStatus));\n    console.log(\"✔ Admin governance severities: \" + JSON.stringify(adminSum.governance.bySeverity));\n\n    console.log(\"\\n\\x1b[32m✔ ALL ANALYTICS SUMMARY API TESTS PASSED SUCCESSFULLY!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\nrun();\n"}}}
