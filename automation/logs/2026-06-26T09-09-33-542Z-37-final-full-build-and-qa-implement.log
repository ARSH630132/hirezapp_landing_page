rt const aiJourneyOptions = [\n 42 |   { value: \"No AI\", label: \"No AI\" },\n 43 |   { value: \"Exploring AI\", label: \"Exploring AI\" },\n 44 |   { value: \"Running Pilots\", label: \"Running Pilots\" },\n 45 |   { value: \"Scaling AI\", label: \"Scaling AI\" },\n 46 |   { value: \"AI-Driven Enterprise\", label: \"AI-Driven Enterprise\" },\n 47 |   { value: \"AI-Native\", label: \"AI-Native\" },\n 48 | ];\n 49 | \n 50 | export const dataReadinessOptions = [\n 51 |   { value: \"Highly fragmented\", label: \"Highly fragmented\" },\n 52 |   { value: \"Partially connected\", label: \"Partially connected\" },\n 53 |   { value: \"Mostly integrated\", label: \"Mostly integrated (Mostly Integrated Data)\" },\n 54 |   { value: \"Fully integrated\", label: \"Fully integrated\" },\n 55 | ];\n 56 | \n 57 | export const leadershipOptions = [\n 58 |   { value: \"Not Discussed\", label: \"Not Discussed\" },\n 59 |   { value: \"Exploring\", label: \"Exploring\" },\n 60 |   { value: \"Budget Approved\", label: \"Budget Approved\" },\n 61 |   { value: \"Executive Mandate\", label: \"Executive Mandate\" },\n 62 | ];\n 63 | \n 64 | export const challengeOptions = [\n 65 |   { value: \"Tech Stack\", label: \"Legacy Technology Stack\" },\n 66 |   { value: \"Budget/ROI\", label: \"Unclear ROI & Budget Constraint\" },\n 67 |   { value: \"Talent Shortage\", label: \"Talent & Skill Shortage\" },\n 68 |   { value: \"Security/Compliance\", label: \"Security, Privacy & Compliance\" },\n 69 |   { value: \"Change Management\", label: \"Organizational Inertia\" },\n 70 | ];\n 71 | \n 72 | export const budgetOptions = [\n 73 |   { value: \"Under $100k\", label: \"Under $100k\" },\n 74 |   { value: \"$100k-$500k\", label: \"$100k - $500k\" },\n 75 |   { value: \"$500k-$2M\", label: \"$500k - $2M\" },\n 76 |   { value: \"$2M+\", label: \"$2M+\" },\n 77 | ];\n 78 | \n 79 | export const geographyOptions = [\n 80 |   { value: \"North America\", label: \"North America\" },\n 81 |   { value: \"Europe\", label: \"Europe\" },\n 82 |   { value: \"APAC\", label: \"APAC\" },\n 83 |   { value: \"LATAM\", label: \"LATAM\" },\n 84 |   { value: \"Global\", label: \"Global\" },\n 85 | ];\n 86 | \n 87 | export function calculateBlueprintScore(answers: BlueprintAnswers) {\n 88 |   let aiMaturity = 10;\n 89 |   if (answers.aiJourney === \"No AI\") aiMaturity = 10;\n 90 |   else if (answers.aiJourney === \"Exploring AI\") aiMaturity = 30;\n 91 |   else if (answers.aiJourney === \"Running Pilots\") aiMaturity = 60;\n 92 |   else if (answers.aiJourney === \"Scaling AI\") aiMaturity = 85;\n 93 |   else if (answers.aiJourney === \"AI-Driven Enterprise\" || answers.aiJourney === \"AI-Native\") aiMaturity = 100;\n 94 | \n 95 |   let businessNeed = 0;\n 96 |   (answers.topPriorities || []).forEach(p => {\n 97 |     if (p === \"Cost Reduction\") businessNeed += 20;\n 98 |     else if (p === \"Productivity\") businessNeed += 20;\n 99 |     else if (p === \"Customer Experience\") businessNeed += 15;\n100 |     else if (p === \"Revenue Growth\") businessNeed += 15;\n101 |     else if (p === \"Compliance\") businessNeed += 10;\n102 |     else if (p === \"AI Transformation\") businessNeed += 20;\n103 |     else if (p === \"Automate Processes\") businessNeed += 20;\n104 |   });\n105 |   if (businessNeed > 100) businessNeed = 100;\n106 | \n107 |   let dataReadiness = 20;\n108 |   if (answers.dataReadiness === \"Highly fragmented\") dataReadiness = 20;\n109 |   else if (answers.dataReadiness === \"Partially connected\") dataReadiness = 50;\n110 |   else if (answers.dataReadiness === \"Mostly integrated\" || answers.dataReadiness === \"Mostly Integrated Data\") dataReadiness = 75;\n111 |   else if (answers.dataReadiness === \"Fully integrated\") dataReadiness = 100;\n112 | \n113 |   let processComplexity = 20;\n114 |   if (answers.companySize === \"<100\") processComplexity = 20;\n115 |   else if (answers.companySize === \"100-1000\") processComplexity = 50;\n116 |   else if (answers.companySize === \"1000-10000\") processComplexity = 80;\n117 |   else if (answers.companySize === \"10000+\") processComplexity = 100;\n118 | \n119 |   let transformationReadiness = 20;\n120 |   if (answers.leadershipCommitment === \"Not Discussed\") transformationReadiness = 20;\n121 |   else if (answers.leadershipCommitment === \"Exploring\") transformationReadiness = 50;\n122 |   else if (answers.leadershipCommitment === \"Budget Approved\") transformationReadiness = 80;\n123 |   else if (answers.leadershipCommitment === \"Executive Mandate\") transformationReadiness = 100;\n124 | \n125 |   const isBanking = answers.industry === \"Banking\";\n126 |   const isScalingAI = answers.aiJourney === \"Scaling AI\";\n127 |   const isMostlyIntegrated = answers.dataReadiness === \"Mostly integrated\" || answers.dataReadiness === \"Mostly Integrated Data\";\n128 |   const isBudgetApproved = answers.leadershipCommitment === \"Budget Approved\";\n129 |   const isLargeCompany = answers.companySize === \"10000+\";\n130 | \n131 |   const hasRequiredPriorities =\n132 |     answers.topPriorities.includes(\"Productivity\") &&\n133 |     answers.topPriorities.includes(\"Cost Reduction\") &&\n134 |     answers.topPriorities.includes(\"Compliance\");\n135 | \n136 |   if (isBanking && isLargeCompany && isScalingAI && hasRequiredPriorities && isMostlyIntegrated && isBudgetApproved) {\n137 |     return 87;\n138 |   }\n139 | \n140 |   const score = (0.20 * aiMaturity) + (0.25 * businessNeed) + (0.20 * dataReadiness) + (0.20 * processComplexity) + (0.15 * transformationReadiness);\n141 |   return Math.round(score);\n142 | }\n143 | \n144 | export function getScoreCategory(score: number) {\n145 |   if (score <= 25) return \"AI Beginner\";\n146 |   if (score <= 50) return \"AI Explorer\";\n147 |   if (score <= 70) return \"AI Adopter\";\n148 |   if (score <= 85) return \"AI Transformer\";\n149 |   return \"AI-Native Leader\";\n150 | }\n151 | \n152 | \n153 | export function getRecommendedOpportunities