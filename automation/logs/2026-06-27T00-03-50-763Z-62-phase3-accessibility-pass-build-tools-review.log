                   </span>\n408 |                     </button>\n409 |                   );\n410 |                 })}\n411 |               </div>\n412 |             </div>\n413 | \n414 |             {/* Active Stage Details Panel */}\n415 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 pt-4\">\n416 |               <div className=\"lg:col-span-8 space-y-4\">\n417 |                 <div className=\"flex items-center gap-2 text-[11px] font-mono text-white/50\">\n418 |                   <span className=\"text-[#E4000F] font-bold\">PHASE 0{activeStage.n}</span>\n419 |                   <span>|</span>\n420 |                   <span className=\"text-[#00FF9D] font-semibold\">{activeStage.metric}</span>\n421 |                 </div>\n422 |                 <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">\n423 |                   {activeStage.name} Milestone Target\n424 |                 </h3>\n425 |                 <p className=\"text-white/70 text-xs leading-relaxed max-w-[720px] font-light\">\n426 |                   {activeStage.desc}\n427 |                 </p>\n428 |                 <div className=\"pt-2\">\n429 |                   <Link \n430 |                     href={activeStage.tool} \n431 |                     className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF]/30 transition group\"\n432 |                   >\n433 |                     <span>Launch {activeStage.btn} Helper</span>\n434 |                     <svg className=\"w-3 h-3 group-hover:translate-x-1 transition-transform text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n435 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n436 |                     </svg>\n437 |                   </Link>\n438 |                 </div>\n439 |               </div