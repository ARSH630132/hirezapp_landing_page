 }, [telemetryLogs]);\n210 | \n211 |   const handleAuthenticate = async () => {\n212 |     setScanning(true);\n213 |     setScanStep(0);\n214 |     \n215 |     const stepIntervals = [250, 300, 350, 400];\n216 |     for (let i = 0; i < stepIntervals.length; i++) {\n217 |       await new Promise(r => setTimeout(r, stepIntervals[i]));\n218 |       setScanStep(prev => prev + 1);\n219 |     }\n220 |     \n221 |     await new Promise(r => setTimeout(r, 400));\n222 |     setScanning(false);\n223 |     setPreviewSession(selectedRole);\n224 |     \n225 |     const isGffStaff = !selectedRole.startsWith(\"client_\");\n226 |     router.push(isGffStaff ? \"/admin/dashboard\" : \"/portal/dashboard\");\n227 |   };\n228 | \n229 |   const handleSubmit = (e: React.FormEvent) => {\n230 |     e.preventDefault();\n231 |     handleAuthenticate();\n232 |   };\n233 | \n234 |   const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n235 |   const activeRoleObj = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n236 | \n237 |   const scanMessages = [\n238 |     \"Establishing zero-trust gateway handshake protocol...\",\n239 |     \"Isolating browser session within local memory sandbox container...\",\n240 |     \"Exchanging SHA-256 secure tokens with crypt node gateway...\",\n241 |     \"Provisioning administrative clearance keys in sovereign database...\",\n242 |     \"Clearance successfully decrypted. Granting portal dashboard access...\"\n243 |   ];\n244 | \n245 |   const getPermissionStatus = (role: PreviewRole, module: string) => {\n246 |     if (role === \"gff_admin\") {\n247 |       return { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" };\n248 |     }\n249 |     \n250 |     if (role === \"viewer\") {\n251 |       const isReadOnlyModule = [\"Core Terminal\", \"Sovereign Control\", \"AI Governance\"].includes(module);\n252 |       if (isReadOnlyModule) {\n253 |         return { status: \"READ ONLY\", color: \"text-amber-400 border-amber-500/20 bg-amber-500/5\", dot: \"bg-amber-400\" };\n254 |       }\n255 |       return { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n256 |     }\n257 | \n258 |     switch (module) {\n259 |       case \"Core Terminal\":\n260 |         return [\"client_admin\", \"client_member\", \"gff_operator\", \"finance_admin\", \"support_agent\"].includes(role)\n261 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n262 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n263 |       case \"AI Operations\":\n264 |         return [\"client_admin\", \"client_member\", \"gff_operator\"].includes(role)\n265 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n266 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n267 |       case \"AI Governance\":\n268 |         return [\"client_admin\", \"client_member\", \"gff_operator\"].includes(role)\n269 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n270 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n271 |       case \"Financial Ledger\":\n272 |         return [\"client_admin\", \"finance_admin\"].includes(role)\n273 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n274 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n275 |       case \"Sovereign Control\":\n276 |         return [\"gff_operator\"].includes(role)\n277 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n278 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n279 |       case \"Support Enclave\":\n280 |         return [\"client_admin\", \"client_member\", \"support_agent\"].includes(role)\n281 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n282 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n283 |       case \"Users Directory\":\n284 |         return [\"support_agent\"].includes(role)\n285 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n286 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n287 |       default:\n288 |         return { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n289 |     }\n290 |   };\n291 | \n292 |   const matrixModules = [\n293 |     \"Core Terminal\",\n294 |     \"AI Operations\",\n295 |     \"AI Governance\",\n296 |     \"Financial Ledger\",\n297 |     \"Sovereign Control\",\n298 |     \"Support Enclave\",\n299 |     \"Users Directory\"\n300 |   ];\n301 | \n302 |   return (\n303 |     <div className=\"min-h-screen w-full bg-[#010101] text-zinc-100 flex flex-col items-center justify-center relative px-4 py-8 md:py-16 select-none overflow-hidden font-sans\">\n304 |       <div className=\"absolute inset-0 z-0 pointer-events-none opacity-40\">\n305 |         <div \n306 |           className=\"absolute inset-0\"\n307 |           style={{\n308 |             backgroundImage: `\n309 |               radial-gradient(circle at 10% 20%, rgba(228, 0, 15, 0.04) 0%, transparent 45%),\n310 |             