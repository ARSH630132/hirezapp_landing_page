ndex < 5) {\n135 |       otpRefs[index + 1].current?.focus();\n136 |     }\n137 |   };\n138 | \n139 |   const handleOtpPaste = (e: React.ClipboardEvent) => {\n140 |     e.preventDefault();\n141 |     const pastedData = e.clipboardData.getData(\"text\").replace(/\\D/g, \"\").slice(0, 6);\n142 |     if (pastedData) {\n143 |       setOtpCode(pastedData);\n144 |       logTelemetry(`[OTP] Pasted authentication block: ${pastedData}`);\n145 |       const targetIndex = Math.min(pastedData.length, 5);\n146 |       setTimeout(() => {\n147 |         otpRefs[targetIndex].current?.focus();\n148 |       }, 50);\n149 |     }\n150 |   };\n151 | \n152 |   const rolesList = [\n153 |     { id: \"client_admin\" as PreviewRole, label: \"Client Admin\", clearance: \"L-3\", desc: \"Sovereign gateway owner\", icon: Users, color: \"text-[#009DFF]\" },\n154 |     { id: \"client_member\" as PreviewRole, label: \"Client Member\", clearance: \"L-2\", desc: \"Model operator layer worker\", icon: Layers, color: \"text-blue-400\" },\n155 |     { id: \"gff_admin\" as PreviewRole, label: \"GFF Admin\", clearance: \"L-5\", desc: \"Root platform superintendent\", icon: Shield, color: \"text-[#E4000F]\" },\n156 |     { id: \"gff_operator\" as PreviewRole, label: \"GFF Operator\", clearance: \"L-4\", desc: \"Model architecture controller\", icon: Cpu, color: \"text-purple-400\" },\n157 |     { id: \"finance_admin\" as PreviewRole, label: \"Finance Admin\", clearance: \"L-3\", desc: \"Epoch financial ledger auditor\", icon: FileText, color: \"text-emerald-400\" },\n158 |     { id: \"support_agent\" as PreviewRole, label: \"Support Agent\", clearance: \"L-3\", desc: \"SLA wire operations specialist\", icon: HelpCircle, color: \"text-orange-400\" },\n159 |     { id: \"viewer\" as PreviewRole, label: \"Auditor (Viewer)\", clearance: \"L-1\", desc: \"Read-only observer node\", icon: Eye, color: \"text-zinc-400\" },\n160 |   ];\n161 | \n162 |   useEffect(() => {\n163 |     const mockUser = MOCK_PREVIEW_USERS[