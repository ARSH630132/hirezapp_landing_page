{"ts":"2026-06-27T11:27:09.688Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"dqnzco5r","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/app/seed.py","old_text":"import sys\nimport os\n# Adjust path to enable importing from backend.app\nsys.path.append(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))\n\nfrom sqlalchemy.orm import Session\nfrom backend.app.db import SessionLocal, init_db\nfrom backend.app.services.auth import AuthService\nfrom backend.app.services.logger import SystemLoggerService\nfrom backend.app.schemas.user import UserCreate\nfrom backend.app.schemas.system_log import SystemLogCreate\n\ndef seed_db():\n    print(\"Initializing database tables via init_db...\")\n    init_db()\n    \n    db: Session = SessionLocal()\n    try:\n        # Check if users already exist\n        admin_user = AuthService.get_user_by_email(db, \"admin@gff.ai\")\n        if not admin_user:\n            print(\"Creating default enterprise admin (admin@gff.ai)...\")\n            AuthService.create_user(\n                db,\n                UserCreate(\n                    email=\"admin@gff.ai\",\n                    password=\"gff_enterprise_admin_pass_2026\",\n                    full_name=\"GFF Executive Admin\",\n                    role=\"admin\"\n                )\n            )\n        \n        test_client = AuthService.get_user_by_email(db, \"client@chevron.com\")\n        if not test_client:\n            print(\"Creating default test client (client@chevron.com)...\")\n            AuthService.create_user(\n                db,\n                UserCreate(\n                    email=\"client@chevron.com\",\n                    password=\"chevron_secure_pass_2026\",\n                    full_name=\"Chevron Operations Lead\",\n                    role=\"client\"\n                )\n            )\n            \n        # Seed system initialization log\n        print(\"Creating default system log entries...\")\n        SystemLoggerService.create_log(\n            db,\n            SystemLogCreate(\n                level=\"INFO\",\n                message=\"Enterprise API initialized and seeded successfully with role definitions.\",\n                module=\"system_init\"\n            )\n        )\n        print(\"Database seeding completed successfully.\")\n        \n    except Exception as e:\n        print(f\"Error seeding database: {e}\")\n    finally:\n        db.close()\n\nif __name__ == \"__main__\":\n    seed_db()","new_text":"import sys\nimport os\nimport datetime\nimport argparse\n\n# Adjust path to enable importing from backend.app\nsys.path.append(os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__)))))\n\nfrom sqlalchemy.orm import Session\nfrom backend.app.db import SessionLocal, init_db\nfrom backend.app.services.auth import AuthService\nfrom backend.app.services.logger import SystemLoggerService\nfrom backend.app.schemas.user import UserCreate\nfrom backend.app.schemas.system_log import SystemLogCreate\nfrom backend.app.models import (\n    User,\n    ClientAccount,\n    Project,\n    AgentOperation,\n    DocumentItem,\n    Invoice,\n    SupportTicket,\n    GovernanceItem,\n    SystemLog,\n)\n\ndef seed_db(reset: bool = False):\n    print(\"Initializing database tables via init_db...\")\n    init_db()\n    \n    db: Session = SessionLocal()\n    try:\n        if reset:\n            print(\"Resetting database (wiping all existing tables to guarantee a clean state)...\")\n            db.query(SystemLog).delete()\n            db.query(SupportTicket).delete()\n            db.query(GovernanceItem).delete()\n            db.query(Invoice).delete()\n            db.query(DocumentItem).delete()\n            db.query(AgentOperation).delete()\n            db.query(User).delete()\n            db.query(Project).delete()\n            db.query(ClientAccount).delete()\n            db.commit()\n            print(\"All existing tables wiped successfully.\")\n\n        # 1. Seed Client Accounts\n        clients_data = [\n            {\n                \"name\": \"Apex Global\",\n                \"industry\": \"Financial Services\",\n                \"region\": \"North America\",\n                \"status\": \"active\",\n                \"account_owner\": \"GFF Partner Team\"\n            },\n            {\n                \"name\": \"Nova Energy\",\n                \"industry\": \"Energy\",\n                \"region\": \"Europe\",\n                \"status\": \"active\",\n                \"account_owner\": \"GFF Partner Team\"\n            },\n            {\n                \"name\": \"Orion Tech\",\n                \"industry\": \"Technology\",\n                \"region\": \"Asia-Pacific\",\n                \"status\": \"active\",\n                \"account_owner\": \"GFF Partner Team\"\n            },\n            {\n                \"name\": \"Chevron Corporation\",\n                \"industry\": \"Energy\",\n                \"region\": \"North America\",\n                \"status\": \"active\",\n                \"account_owner\": \"GFF Partner Team\"\n            }\n        ]\n        \n        client_map = {}\n        for c_info in clients_data:\n            client = db.query(ClientAccount).filter(ClientAccount.name == c_info[\"name\"]).first()\n            if not client:\n                print(f\"Creating Client Account: {c_info['name']}\")\n                client = ClientAccount(**c_info)\n                db.add(client)\n                db.commit()\n                db.refresh(client)\n            else:\n                print(f\"Client Account already exists: {c_info['name']}\")\n            client_map[c_info[\"name\"]] = client\n\n        # 2. Seed Developer Users\n        users_data = [\n            {\n                \"email\": \"gff_admin@gff.ai\",\n                \"password\": \"password123\",\n                \"full_name\": \"GFF Admin Lead\",\n                \"name\": \"GFF Admin Lead\",\n                \"role\": \"gff_admin\",\n                \"status\": \"active\",\n                \"is_active\": True,\n                \"client_name\": None\n            },\n            {\n                \"email\": \"client_admin@apex.com\",\n                \"password\": \"password123\",\n                \"full_name\": \"Apex Admin Lead\",\n                \"name\": \"Apex Admin Lead\",\n                \"role\": \"client_admin\",\n                \"status\": \"active\",\n                \"is_active\": True,\n                \"client_name\": \"Apex Global\"\n            },\n            {\n                \"email\": \"client_member@apex.com\",\n                \"password\": \"password123\",\n                \"full_name\": \"Apex Analyst\",\n                \"name\": \"Apex Analyst\",\n                \"role\": \"client_member\",\n                \"status\": \"active\",\n                \"is_active\": True,\n                \"client_name\": \"Apex Global\"\n            },\n            {\n                \"email\": \"admin@gff.ai\",\n                \"password\": \"gff_enterprise_admin_pass_2026\",\n                \"full_name\": \"GFF Executive Admin\",\n                \"name\": \"GFF Executive Admin\",\n                \"role\": \"admin\",\n                \"status\": \"active\",\n                \"is_active\": True,\n                \"client_name\": None\n            },\n            {\n                \"email\": \"client@chevron.com\",\n                \"password\": \"chevron_secure_pass_2026\",\n                \"full_name\": \"Chevron Operations Lead\",\n                \"name\": \"Chevron Operations Lead\",\n                \"role\": \"client\",\n                \"status\": \"active\",\n                \"is_active\": True,\n                \"client_name\": \"Chevron Corporation\"\n            }\n        ]\n\n        for u_info in users_data:\n            user = db.query(User).filter(User.email == u_info[\"email\"]).first()\n            client_id = client_map[u_info[\"client_name\"]].id if u_info[\"client_name\"] else None\n            \n            if not user:\n                print(f\"Creating User: {u_info['email']} (role: {u_info['role']})\")\n                AuthService.create_user(\n                    db,\n                    UserCreate(\n                        email=u_info[\"email\"],\n                        password=u_info[\"password\"],\n                        full_name=u_info[\"full_name\"],\n                        role=u_info[\"role\"],\n                        is_active=u_info[\"is_active\"],\n                        client_id=client_id\n                    )\n                )\n                user = db.query(User).filter(User.email == u_info[\"email\"]).first()\n                user.client_id = client_id\n                user.name = u_info[\"name\"]\n                user.status = u_info[\"status\"]\n                db.add(user)\n                db.commit()\n            else:\n                print(f\"User already exists: {u_info['email']}\")\n                # Ensure fields and password hash are correct/synced\n                from backend.app.core.security import hash_password\n                user.hashed_password = hash_password(u_info[\"password\"])\n                user.client_id = client_id\n                user.name = u_info[\"name\"]\n                user.full_name = u_info[\"full_name\"]\n                user.role = u_info[\"role\"]\n                user.status = u_info[\"status\"]\n                user.is_active = u_info[\"is_active\"]\n                db.add(user)\n                db.commit()\n\n        # 3. Seed Projects\n        projects_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"name\": \"Project Sovereign\",\n                \"phase\": \"Phase 1: Foundation\",\n                \"status\": \"active\",\n                \"health\": \"green\",\n                \"owner\": \"Apex Admin Lead\",\n                \"start_date\": datetime.datetime.utcnow() - datetime.timedelta(days=30),\n                \"target_date\": datetime.datetime.utcnow() + datetime.timedelta(days=150),\n                \"progress\": 35,\n                \"description\": \"Deploying enterprise sovereign AI foundation and security governance models.\"\n            },\n            {\n                \"client_name\": \"Apex Global\",\n                \"name\": \"Automated Tax Intelligence\",\n                \"phase\": \"Phase 3: Integration\",\n                \"status\": \"active\",\n                \"health\": \"amber\",\n                \"owner\": \"Apex Analyst\",\n                \"start_date\": datetime.datetime.utcnow() - datetime.timedelta(days=60),\n                \"target_date\": datetime.datetime.utcnow() + datetime.timedelta(days=60),\n                \"progress\": 75,\n                \"description\": \"Integrating local tax reporting agent nodes with internal financial services ERP.\"\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"name\": \"Omesh Predictive Operations\",\n                \"phase\": \"Phase 2: Core Deployment\",\n                \"status\": \"active\",\n                \"health\": \"green\",\n                \"owner\": \"Nova Ops Team\",\n                \"start_date\": datetime.datetime.utcnow() - datetime.timedelta(days=15),\n                \"target_date\": datetime.datetime.utcnow() + datetime.timedelta(days=120),\n                \"progress\": 55,\n                \"description\": \"Deploying autonomous agent meshes on energy infrastructure for anomaly detection and load management.\"\n            },\n            {\n                \"client_name\": \"Orion Tech\",\n                \"name\": \"Orion Agent Orchestrator\",\n                \"phase\": \"Phase 4: Optimization\",\n                \"status\": \"active\",\n                \"health\": \"green\",\n                \"owner\": \"Orion Dev Lead\",\n                \"start_date\": datetime.datetime.utcnow() - datetime.timedelta(days=90),\n                \"target_date\": datetime.datetime.utcnow() + datetime.timedelta(days=30),\n                \"progress\": 90,\n                \"description\": \"Constructing the next-generation developer platform agent hub and marketplace integration.\"\n            }\n        ]\n\n        project_map = {}\n        for p_info in projects_data:\n            client = client_map[p_info[\"client_name\"]]\n            project = db.query(Project).filter(Project.client_id == client.id, Project.name == p_info[\"name\"]).first()\n            if not project:\n                print(f\"Creating Project: {p_info['name']} for Client: {p_info['client_name']}\")\n                project = Project(\n                    client_id=client.id,\n                    name=p_info[\"name\"],\n                    phase=p_info[\"phase\"],\n                    status=p_info[\"status\"],\n                    health=p_info[\"health\"],\n                    owner=p_info[\"owner\"],\n                    start_date=p_info[\"start_date\"],\n                    target_date=p_info[\"target_date\"],\n                    progress=p_info[\"progress\"],\n                    description=p_info[\"description\"]\n                )\n                db.add(project)\n                db.commit()\n                db.refresh(project)\n            else:\n                print(f\"Project already exists: {p_info['name']} for Client: {p_info['client_name']}\")\n            project_map[(p_info[\"client_name\"], p_info[\"name\"])] = project\n\n        # 4. Seed Agent Operations\n        agents_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"name\": \"TaxComplianceAgent\",\n                \"agent_type\": \"Compliance & Regulatory Audit\",\n                \"status\": \"active\",\n                \"health\": \"healthy\",\n                \"owner\": \"compliance_team\",\n                \"governance_status\": \"compliant\"\n            },\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"name\": \"LedgerIngestionAgent\",\n                \"agent_type\": \"Data Processing & Validation\",\n                \"status\": \"active\",\n                \"health\": \"healthy\",\n                \"owner\": \"finance_ops\",\n                \"governance_status\": \"compliant\"\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"project_name\": \"Omesh Predictive Operations\",\n                \"name\": \"PipelineAnomalyDetector\",\n                \"agent_type\": \"Anomaly Detection & Real-time Vision\",\n                \"status\": \"active\",\n                \"health\": \"healthy\",\n                \"owner\": \"ops_lead\",\n                \"governance_status\": \"warning\"\n            },\n            {\n                \"client_name\": \"Orion Tech\",\n                \"project_name\": \"Orion Agent Orchestrator\",\n                \"name\": \"DeveloperCopilotAgent\",\n                \"agent_type\": \"Code Synthesis & QA Auto-test\",\n                \"status\": \"active\",\n                \"health\": \"healthy\",\n                \"owner\": \"dev_ops\",\n                \"governance_status\": \"compliant\"\n            }\n        ]\n\n        for a_info in agents_data:\n            client = client_map[a_info[\"client_name\"]]\n            project = project_map.get((a_info[\"client_name\"], a_info[\"project_name\"])) if a_info[\"project_name\"] else None\n            project_id = project.id if project else None\n            \n            agent = db.query(AgentOperation).filter(\n                AgentOperation.client_id == client.id,\n                AgentOperation.name == a_info[\"name\"]\n            ).first()\n            if not agent:\n                print(f\"Creating Agent Operation: {a_info['name']} for Client: {a_info['client_name']}\")\n                agent = AgentOperation(\n                    client_id=client.id,\n                    project_id=project_id,\n                    name=a_info[\"name\"],\n                    agent_type=a_info[\"agent_type\"],\n                    status=a_info[\"status\"],\n                    health=a_info[\"health\"],\n                    owner=a_info[\"owner\"],\n                    governance_status=a_info[\"governance_status\"]\n                )\n                db.add(agent)\n                db.commit()\n            else:\n                print(f\"Agent Operation already exists: {a_info['name']} for Client: {a_info['client_name']}\")\n\n        # 5. Seed Documents Metadata\n        documents_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Project Sovereign\",\n                \"title\": \"Sovereign AI Security Architecture\",\n                \"document_type\": \"Architecture Guide\",\n                \"status\": \"active\",\n                \"version\": \"1.2.0\",\n                \"owner\": \"gff_admin\",\n                \"visibility\": \"private\"\n            },\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"title\": \"Tax Automation Node Protocol\",\n                \"document_type\": \"Integration Protocol\",\n                \"status\": \"active\",\n                \"version\": \"1.0.1\",\n                \"owner\": \"client_admin\",\n                \"visibility\": \"private\"\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"project_name\": \"Omesh Predictive Operations\",\n                \"title\": \"Omesh Agent Security Threat Model\",\n                \"document_type\": \"Threat Model\",\n                \"status\": \"active\",\n                \"version\": \"2.0.0\",\n                \"owner\": \"gff_admin\",\n                \"visibility\": \"private\"\n            },\n            {\n                \"client_name\": \"Orion Tech\",\n                \"project_name\": \"Orion Agent Orchestrator\",\n                \"title\": \"API Gateway Specifications\",\n                \"document_type\": \"Technical Spec\",\n                \"status\": \"active\",\n                \"version\": \"0.9.0\",\n                \"owner\": \"client_member\",\n                \"visibility\": \"public\"\n            }\n        ]\n\n        for d_info in documents_data:\n            client = client_map[d_info[\"client_name\"]]\n            project = project_map.get((d_info[\"client_name\"], d_info[\"project_name\"])) if d_info[\"project_name\"] else None\n            project_id = project.id if project else None\n            \n            doc = db.query(DocumentItem).filter(\n                DocumentItem.client_id == client.id,\n                DocumentItem.title == d_info[\"title\"]\n            ).first()\n            if not doc:\n                print(f\"Creating Document: {d_info['title']} for Client: {d_info['client_name']}\")\n                doc = DocumentItem(\n                    client_id=client.id,\n                    project_id=project_id,\n                    title=d_info[\"title\"],\n                    document_type=d_info[\"document_type\"],\n                    status=d_info[\"status\"],\n                    version=d_info[\"version\"],\n                    owner=d_info[\"owner\"],\n                    visibility=d_info[\"visibility\"]\n                )\n                db.add(doc)\n                db.commit()\n            else:\n                print(f\"Document already exists: {d_info['title']} for Client: {d_info['client_name']}\")\n\n        # 6. Seed Invoices\n        invoices_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Project Sovereign\",\n                \"invoice_number\": \"INV-2026-001\",\n                \"status\": \"paid\",\n                \"amount\": 125000.00,\n                \"currency\": \"USD\",\n                \"due_date\": datetime.datetime.utcnow() + datetime.timedelta(days=30),\n                \"issued_date\": datetime.datetime.utcnow() - datetime.timedelta(days=15)\n            },\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"invoice_number\": \"INV-2026-002\",\n                \"status\": \"unpaid\",\n                \"amount\": 95000.00,\n                \"currency\": \"USD\",\n                \"due_date\": datetime.datetime.utcnow() + datetime.timedelta(days=45),\n                \"issued_date\": datetime.datetime.utcnow() - datetime.timedelta(days=2)\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"project_name\": \"Omesh Predictive Operations\",\n                \"invoice_number\": \"INV-2026-003\",\n                \"status\": \"unpaid\",\n                \"amount\": 150000.00,\n                \"currency\": \"USD\",\n                \"due_date\": datetime.datetime.utcnow() + datetime.timedelta(days=15),\n                \"issued_date\": datetime.datetime.utcnow() - datetime.timedelta(days=5)\n            },\n            {\n                \"client_name\": \"Orion Tech\",\n                \"project_name\": \"Orion Agent Orchestrator\",\n                \"invoice_number\": \"INV-2026-004\",\n                \"status\": \"paid\",\n                \"amount\": 80000.00,\n                \"currency\": \"USD\",\n                \"due_date\": datetime.datetime.utcnow() - datetime.timedelta(days=1),\n                \"issued_date\": datetime.datetime.utcnow() - datetime.timedelta(days=31)\n            }\n        ]\n\n        for i_info in invoices_data:\n            client = client_map[i_info[\"client_name\"]]\n            project = project_map.get((i_info[\"client_name\"], i_info[\"project_name\"])) if i_info[\"project_name\"] else None\n            project_id = project.id if project else None\n            \n            invoice = db.query(Invoice).filter(Invoice.invoice_number == i_info[\"invoice_number\"]).first()\n            if not invoice:\n                print(f\"Creating Invoice: {i_info['invoice_number']} for Client: {i_info['client_name']}\")\n                invoice = Invoice(\n                    client_id=client.id,\n                    project_id=project_id,\n                    invoice_number=i_info[\"invoice_number\"],\n                    status=i_info[\"status\"],\n                    amount=i_info[\"amount\"],\n                    currency=i_info[\"currency\"],\n                    due_date=i_info[\"due_date\"],\n                    issued_date=i_info[\"issued_date\"]\n                )\n                db.add(invoice)\n                db.commit()\n            else:\n                print(f\"Invoice already exists: {i_info['invoice_number']}\")\n\n        # 7. Seed Support Tickets\n        tickets_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"title\": \"API Handshake Failure in Production\",\n                \"category\": \"Technical\",\n                \"priority\": \"critical\",\n                \"status\": \"resolved\",\n                \"assigned_to\": \"GFF Support Eng\",\n                \"created_by\": \"Apex Admin Lead\",\n                \"description\": \"The API gateway returned 502 errors during high-volume ledger integration runs.\"\n            },\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Automated Tax Intelligence\",\n                \"title\": \"Request for Custom Model Fine-Tuning\",\n                \"category\": \"Feature Request\",\n                \"priority\": \"medium\",\n                \"status\": \"open\",\n                \"assigned_to\": \"GFF Product Owner\",\n                \"created_by\": \"Apex Analyst\",\n                \"description\": \"Need a pipeline to fine-tune Sovereign Llama models with quarterly tax reports.\"\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"project_name\": \"Omesh Predictive Operations\",\n                \"title\": \"Late Telemetry Sync from Omesh Nodes\",\n                \"category\": \"Hardware Integration\",\n                \"priority\": \"high\",\n                \"status\": \"in_progress\",\n                \"assigned_to\": \"Omesh Mesh Specialist\",\n                \"created_by\": \"Nova Ops Team\",\n                \"description\": \"Some remote nodes show high latency (>10s) when reporting pipeline status.\"\n            }\n        ]\n\n        for t_info in tickets_data:\n            client = client_map[t_info[\"client_name\"]]\n            project = project_map.get((t_info[\"client_name\"], t_info[\"project_name\"])) if t_info[\"project_name\"] else None\n            project_id = project.id if project else None\n            \n            ticket = db.query(SupportTicket).filter(\n                SupportTicket.client_id == client.id,\n                SupportTicket.title == t_info[\"title\"]\n            ).first()\n            if not ticket:\n                print(f\"Creating Support Ticket: {t_info['title']} for Client: {t_info['client_name']}\")\n                ticket = SupportTicket(\n                    client_id=client.id,\n                    project_id=project_id,\n                    title=t_info[\"title\"],\n                    category=t_info[\"category\"],\n                    priority=t_info[\"priority\"],\n                    status=t_info[\"status\"],\n                    assigned_to=t_info[\"assigned_to\"],\n                    created_by=t_info[\"created_by\"],\n                    description=t_info[\"description\"]\n                )\n                db.add(ticket)\n                db.commit()\n            else:\n                print(f\"Support Ticket already exists: {t_info['title']} for Client: {t_info['client_name']}\")\n\n        # 8. Seed Governance Items\n        governance_data = [\n            {\n                \"client_name\": \"Apex Global\",\n                \"project_name\": \"Project Sovereign\",\n                \"title\": \"Third-Party Agent Audit\",\n                \"severity\": \"high\",\n                \"status\": \"active\",\n                \"owner\": \"compliance_lead\",\n                \"due_date\": datetime.datetime.utcnow() + datetime.timedelta(days=20),\n                \"description\": \"Perform independent automated audits of all external integrations for compliance with GFF sovereignty standards.\"\n            },\n            {\n                \"client_name\": \"Nova Energy\",\n                \"project_name\": \"Omesh Predictive Operations\",\n                \"title\": \"Model Drift Check - Pipeline Anomaly Detector\",\n                \"severity\": \"medium\",\n                \"status\": \"active\",\n                \"owner\": \"nova_data_ops\",\n                \"due_date\": datetime.datetime.utcnow() + datetime.timedelta(days=30),\n                \"description\": \"Review performance metrics of pipeline anomaly models to verify consistency and adjust for winter conditions.\"\n            },\n            {\n                \"client_name\": \"Orion Tech\",\n                \"project_name\": \"Orion Agent Orchestrator\",\n                \"title\": \"Access Token Rotation Enforcement\",\n                \"severity\": \"critical\",\n                \"status\": \"resolved\",\n                \"owner\": \"security_team\",\n                \"due_date\": datetime.datetime.utcnow() - datetime.timedelta(days=2),\n                \"description\": \"Force rotate all integration access keys for API Gateway following scheduled quarterly audit.\"\n            }\n        ]\n\n        for g_info in governance_data:\n            client = client_map[g_info[\"client_name\"]]\n            project = project_map.get((g_info[\"client_name\"], g_info[\"project_name\"])) if g_info[\"project_name\"] else None\n            project_id = project.id if project else None\n            \n            gov = db.query(GovernanceItem).filter(\n                GovernanceItem.client_id == client.id,\n                GovernanceItem.title == g_info[\"title\"]\n            ).first()\n            if not gov:\n                print(f\"Creating Governance Item: {g_info['title']} for Client: {g_info['client_name']}\")\n                gov = GovernanceItem(\n                    client_id=client.id,\n                    project_id=project_id,\n                    title=g_info[\"title\"],\n                    severity=g_info[\"severity\"],\n                    status=g_info[\"status\"],\n                    owner=g_info[\"owner\"],\n                    due_date=g_info[\"due_date\"],\n                    description=g_info[\"description\"]\n                )\n                db.add(gov)\n                db.commit()\n            else:\n                print(f\"Governance Item already exists: {g_info['title']} for Client: {g_info['client_name']}\")\n\n        # Seed system initialization log\n        print(\"Creating default system log entries...\")\n        SystemLoggerService.create_log(\n            db,\n            SystemLogCreate(\n                level=\"INFO\",\n                message=\"Enterprise API initialized and seeded successfully with robust role-based identities.\",\n                module=\"system_init\"\n            )\n        )\n        print(\"Database seeding completed successfully.\")\n        \n    except Exception as e:\n        print(f\"Error seeding database: {e}\")\n    finally:\n        db.close()\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser(description=\"Seed GFF AI Local MVP Database.\")\n    parser.add_argument(\"--reset\", action=\"store_true\", help=\"Reset (wipe) the database before seeding.\")\n    args = parser.parse_args()\n    seed_db(reset=args.reset)"}}}
