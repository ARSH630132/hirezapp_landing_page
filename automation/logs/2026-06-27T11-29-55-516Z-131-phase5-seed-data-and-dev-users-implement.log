 print(\"✓ test_jwt_utilities passed.\")\n106 | \n107 | from app.core.rbac import UserRole, PermissionGroup, ROLE_PERMISSIONS, RoleChecker\n108 | from app.api.deps import (\n109 |     require_roles,\n110 |     require_admin,\n111 |     require_client_access,\n112 |     require_same_client_or_admin,\n113 |     require_permission\n114 | )\n115 | from fastapi import HTTPException\n116 | \n117 | # Mock User class for testing dependencies\n118 | class MockUser:\n119 |     def __init__(self, role: str, client_id: int = None, is_active: bool = True):\n120 |         self.role = role\n121 |         self.client_id = client_id\n122 |         self.is_active = is_active\n123 | \n124 | # Mock Request class for testing client parameter extraction\n125 | class MockRequest:\n126 |     def __init__(self, path_params=None, query_params=None):\n127 |         self.path_params = path_params or {}\n128 |         self.query_params = query_params or {}\n129 | \n130 | def test_rbac_roles_and_permissions():\n131 |     print(\"Running test_rbac_roles_and_permissions...\")\n132 |     # Verify new roles exist\n133 |     assert UserRole.CLIENT_ADMIN == \"client_admin\"\n134 |     assert UserRole.CLIENT_MEMBER == \"client_member\"\n135 |     assert UserRole.GFF_ADMIN == \"gff_admin\"\n136 |     \n137 |     # Verify permission groups exist\n138 |     assert PermissionGroup.CLIENT_PORTAL_ACCESS == \"client_portal_access\"\n139 |     assert PermissionGroup.ADMIN_ACCESS == \"admin_access\"\n140 |     assert PermissionGroup.MANAGE_CLIENTS == \"manage_clients\"\n141 |     assert PermissionGroup.MANAGE_USERS == \"manage_users\"\n142 |     \n143 |     # Verify mapping assignments\n144 |     assert PermissionGroup.ADMIN_ACCESS in ROLE_PERMISSIONS[UserRole.GFF_ADMIN]\n145 |     assert PermissionGroup.ADMIN_ACCESS not in ROLE_PERMISSIONS[UserRole.CLIENT_ADMIN]\n146 |     assert PermissionGroup.ADMIN_ACCESS not in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n147 |     \n148 |     assert PermissionGroup.CLIENT_PORTAL_ACCESS in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n149 |     assert PermissionGroup.MANAGE_USERS in ROLE_PERMISSIONS[UserRole.CLIENT_ADMIN]\n150 |     assert PermissionGroup.MANAGE_USERS not in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n151 |     \n152 |     print(\"✓ test_rbac_roles_and_permissions passed.\")\n153 | \n154 | def test_role_checker():\n155 |     print(\"Running test_role_checker...\")\n156 |     checker = RoleChecker([UserRole.GFF_ADMIN, UserRole.CLIENT_ADMIN])\n157 |     \n158 |     # Allowed\n159 |     assert checker(\"gff_admin\") is True\n160 |     assert checker(\"client_admin\") is True\n161 |     \n162 |     # Forbidden\n163 |     try:\n164 |         checker(\"client_member\")\n165 |         assert False, \"Should raise 403\"\n166 |     except HTTPException as e:\n167 |         assert e.status_code == 403\n168 |         assert \"Insufficient role\" in e.detail\n169 |         \n170 |     print(\"✓ test_role_checker passed.\")\n171 | \n172 | def test_require_roles_dependency():\n173 |     print(\"Running test_require_roles_dependency...\")\n174 |     dep = require_roles([UserRole.CLIENT_ADMIN, UserRole.CLIENT_MEMBER])\n175 |     \n176 |     member_user = MockUser(role=\"client_member\")\n177 |     admin_user = MockUser(role=\"client_admin\")\n178 |     gff_user = MockUser(role=\"gff_admin\")\n179 |     \n180 |     # Allowed\n181 |     assert dep(member_user) == member_user\n182 |     assert dep(admin_user) == admin_user\n183 |     \n184 |     # Forbidden\n185 |     try:\n186 |         dep(gff_user)\n187 |         assert False, \"Should raise 403\"\n188 |     except HTTPException as e:\n189 |         assert e.status_code == 403\n190 |         \n191 |     print(\"✓ test_require_roles_dependency passed.\")\n192 | \n193 | def test_require_admin_dependency():\n194 |     print(\"Running test_require_admin_dependency...\")\n195 |     \n196 |     gff_user = MockUser(role=\"gff_admin\")\n197 |     legacy_admin = MockUser(role=\"admin\")\n198 |     member_user = MockUser(role=\"client_member\")\n199 |     \n200 |     # Allowed\n201 |     assert require_admin(gff_user) == gff_user\n202 |     assert require_admin(legacy_admin) == legacy_admin\n203 |     \n204 |     # Forbidden\n205 |     try:\n206 |         require_admin(member_user)\n207 |         assert False, \"Should raise 403\"\n208 |     except HTTPException as e:\n209 |         assert e.status_code == 403\n210 |         \n211 |     print(\"✓ test_require_admin_dependency passed.\")\n212 | \n213 | def test_require_client_access_dependency():\n214 |     print(\"Running test_require_client_access_dependency...\")\n215 |     \n216 |     gff_user = MockUser(role=\"gff_admin\", client_id=None)\n217 |     client_admin_user = MockUser(role=\"client_admin\", client_id=42)\n218 |     client_member_user = MockUser(role=\"client_member\", client_id=42)\n219 |     other_client_user = MockUser(role=\"client_admin\", client_id=99)\n220 |     \n221 |     # Case 1: GFF Admin bypasses with client_id present\n222 |     req1 = MockRequest(path_params={\"client_id\": \"42\"})\n223 |     assert require_client_access(req1, gff_user) == gff_user\n224 |     \n225 |     # Case 2: Matching client_id allowed\n226 |     assert require_client_access(req1, client_admin_user) == client_admin_user\n227 |     assert require_client_access(req1, client_member_user) == client_member_user\n228 |     \n229 |     # Case 3: Mismatched client_id forbidden\n230 |     try:\n231 |         require_client_access(req1, other_client_user)\n232 |         assert False, \"Should raise 403\"\n233 |     except HTTPException as e:\n234 |         assert e.status_code == 403\n235 |         assert \"Access to this client's data is denied\" in e.detail\n236 |         \n237 |     # Case 4: client_id in query parameters\n238 |     req2 = MockRequest(query_params={\"client_id\": \"42\"})\n239 |     assert require_client_access(req2, client_admin_user) == client_admin_user\n240 |     \n241 |     # Case 5: Invalid client_id format\n242 |     req_invalid = MockRequest(path_params={\"client_id\": \"abc\"})\n243 |     try:\n244 |         require_client_access(req_invalid, client_admin_user)\n245 |         assert False, \"Should raise 400\"\n246 |     except HTTPException as e:\n247 |         assert e.status_code == 400\n248 |         assert \"Invalid client_id format\" in e.detail\n249 |         \n250 |     print(\"✓ test_require_client_access_dependency passed.\")\n251 | \n252 | def test_require_same_client_or_admin_dependency():\n253 |     print(\"Running test_require_same_client_or_admin_dependency...\")\n254 |     \n255 |     gff_user = MockUser(role=\"gff_admin\", client_id=None)\n256 |     client_admin_user = MockUser(role=\"client_admin\", client_id=42)\n257 |     other_client_user = MockUser(role=\"client_admin\", client_id=99)\n258 |     \n259 |     req1 = MockRequest(path_params={\"client_id\": \"42\"})\n260 |     \n261 |     # Admin is bypassed\n262 |     assert require_same_client_or_admin(req1, gff_user) == gff_user\n263 |     \n264 |     # Same client is allowed\n265 |     assert require_same_client_or_admin(req1, client_admin_user) == client_admin_user\n266 |     \n267 |     # Other client is rejected\n268 |     try:\n269 |         require_same_client_or_admin(req1, other_client_user)\n270 |         assert False, \"Should raise 403\"\n271 |     except HTTPException as e:\n272 |         assert e.status_code == 403\n273 |         assert \"You can only access data belonging to your own client account\" in e.detail\n274 |         \n275 |     # Missing parameter\n276 |     req_missing = MockRequest()\n277 |     try:\n278 |         require_same_client_or_admin(req_missing, other_client_user)\n279 |         assert False, \"Should raise 400\"\n280 |     except HTTPException as e:\n281 |         assert e.status_code == 400\n282 |         assert \"client_id parameter is required\" in e.detail\n283 |         \n284 |     print(\"✓ test_require_same_client_or_admin_dependency passed.\")\n285 | \n286 | def test_require_permission_dependency():\n287 |     print(\"Running test_require_permission_dependency...\")\n288 |     \n289 |     gff_user = MockUser(role=\"gff_admin\")\n290 |     client_admin_user = MockUser(role=\"client_admin\")\n291 |     client_member_user = MockUser(role=\"client_member\")\n292 |     \n293 |     dep_manage_clients = require_permission(PermissionGroup.MANAGE_CLIENTS)\n294 |     dep_manage_users = require_permission(PermissionGroup.MANAGE_USERS)\n295 |     dep_portal = require_permission(PermissionGroup.CLIENT_PORTAL_ACCESS)\n296 |     \n297 |     # GFF Admin has all permissions\n298 |     assert dep_manage_clients(gff_user) == gff_user\n299 |     assert dep_manage_users(gff_user) == gff_user\n300 |     assert dep_portal(gff_user) == gff_user\n301 |     \n302 |     # Client Admin\n303 |     assert dep_manage_users(client_admin_user) == client_admin_user\n304 |     assert dep_portal(client_admin_user) == client_admin_user\n305 |     try:\n306 |         dep_manage_clients(client_admin_user)\n307 |         assert False, \"Should raise 403\"\n308 |     except HTTPException as e:\n309 |         assert e.status_code == 403\n310 |         assert \"Missing permission\" in e.detail\n311 |         \n312 |     # Client Member\n313 |     assert dep_portal(client_member_user) == client_member_user\n314 |     try:\n315 |         dep_manage_users(client_member_user)\n316 |         assert False, \"Should raise 403\"\n317 |     except HTTPException as e:\n318 |         assert e.status_code == 403\n319 |         \n320 |     print(\"✓ test_require_permission_dependency passed.\")\n321 | \n322 | if __name__ == \"__main__\":\n323 |     try:\n324 |         test_password_hashing()\n325 |         test_jwt_utilities()\n326 |         test_rbac_roles_and_permissions()\n327 |         test_role_checker()\n328 |         test_require_roles_dependency()\n329 |         test_require_admin_dependency()\n330 |         test_require_client_access_dependency()\n331 |         test_require_same_client_or_admin_dependency()\n332 |         test_require_permission_dependency()\n333 |         print(\"\\nAll backend security and RBAC dependency tests passed successfully!\")\n334 |         sys.exit(0)\n335 |     except AssertionError as e:\n336 |         print(\"\\nAssertion error occurred during tests:\")\n337 |         import traceback\n338 |         traceback.print_exc()\n339 |         sys.exit(1)\n340 |     except Exception as e:\n341 |         print(f\"\\nAn error occurred: {e}\")\n342 |         import traceback\n343 |         traceback.print_exc()\n344 |         sys.exit(1)","success":true}],"durationMs":2}}
