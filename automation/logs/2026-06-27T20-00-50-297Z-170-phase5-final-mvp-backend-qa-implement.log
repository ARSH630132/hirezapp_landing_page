response.status}`);\n217 |   }\n218 | \n219 |   return response.json() as Promise<T>;\n220 | }\n221 | \n222 | // ============================================================================\n223 | // SUB-CLIENT MODULES\n224 | // ============================================================================\n225 | \n226 | export const auth = {\n227 |   login: async (creds: { email: string; password?: string }): Promise<{ success: boolean; accessToken: string; user: ApiUser }> => {\n228 |     const res = await request<{ success: boolean; accessToken: string; user: ApiUser }>(\"/auth/login\", {\n229 |       method: \"POST\",\n230 |       body: JSON.stringify(creds),\n231 |     });\n232 |     if (res.success && res.accessToken) setStoredToken(res.accessToken);\n233 |     return res;\n234 |   },\n235 |   logout: async (): Promise<{ success: boolean }> => {\n236 |     try { await request(\"/auth/logout\", { method: \"POST\" }); } catch { /* Ignore */ } finally { clearStoredToken(); }\n237 |     return { success: true };\n238 |   },\n239 |   me: async (): Promise<{ success: boolean; user: ApiUser }> => request<{ success: boolean; user: ApiUser }>(\"/auth/me\"),\n240 | };\n241 | \n242 | export const dashboard = {\n243 |   getAdminSummary: async (): Promise<any> => request<any>(\"/dashboard/admin\"),\n244 |   getClientSummary: async (clientId?: string): Promise<any> => {\n245 |     const path = clientId ? `/dashboard/client?client_id=${encodeURIComponent(clientId)}` : \"/dashboard/client\";\n246 |     return request<any>(path);\n247 |   },\n248 | };\n249 | \n250 | export const clients = {\n251 |   list: async (): Promise<{ success: boolean; clients: ClientAccount[] }> => {\n252 |     try { return await request<{ success: boolean; clients: ClientAccount[] }>(\"/clients\"); } catch {\n253 |       return {\n254 |         success: true,\n255 |         clients: [\n256 |           { id: \"client-001\", name: \"Apex Sovereign Group [Preview Client]\", status: \"active\", tier: \"Sovereign\", region: \"London\", createdAt: \"2026-01-15T08:00:00Z\" },\n257 |           { id: \"client-002\", name: \"Global Retail Enclave [Preview Client]\", status: \"active\", tier: \"Enterprise\", region: \"New York\", createdAt: \"2026-02-10T10:30:00Z\" },\n258 |           { id: \"client-003\", name: \"Sovereign Logistics Unit [Preview Client]\", status: \"active\", tier: \"Standard\", region: \"Frankfurt\", createdAt: \"2026-03-01T09:00:00Z\" },\n259 |           { id: \"client-004\", name: \"Federal Treasury Division [Preview Client]\", status: \"active\", tier: \"Sovereign\", region: \"Washington D.C.\", createdAt: \"2026-04-18T14:15:00Z\" }\n260 |         ],\n261 |       };\n262 |     }\n263 |   },\n264 |   get: async (id: string): Promise<{ success: boolean; client: ClientAccount }> => {\n265 |     try { return await request<{ success: boolean; client: ClientAccount }>(`/clients/${encodeURIComponent(id)}`); } catch {\n266 |       const res = await clients.list();\n267 |       const found = res.clients.find((c) => c.id === id);\n268 |       if (!found) throw new Error(`Client ${id} not found.`);\n269 |       return { success: true, client: found };\n270 |     }\n271 |   },\n272 | };\n273 | \n274 | export const users = {\n275 |   list: async (filters?: any): Promise<{ success: boolean; users: ApiUser[] }> => {\n276 |     const query = filters ? `?${new URLSearchParams(filters).toString()}` : \"\";\n277 |     return request<{ success: boolean; users: ApiUser[] }>(`/users${query}`);\n278 |   },\n279 |   get: async (id: string): Promise<{ success: boolean; user: ApiUser }> => request<{ success: boolean; user: ApiUser }>(`/users/${encodeURIComponent(id)}`),\n280 |   create: async (data: Partial<ApiUser> & { password?: string }): Promise<{ success: boolean; user: ApiUser }> => request<{ success: boolean; user: ApiUser }>(\"/users\", { method: \"POST\", body: JSON.stringify(data) }),\n281 |   update: async (id: string, data: Partial<ApiUser> & { password?: string }):