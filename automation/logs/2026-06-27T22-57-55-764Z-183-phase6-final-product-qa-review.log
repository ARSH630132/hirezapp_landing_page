rray.isArray(data)) {\n390 |         docArray = data;\n391 |       } else if (data && data.success && Array.isArray(data.documents)) {\n392 |         docArray = data.documents;\n393 |       }\n394 | \n395 |       if (docArray) {\n396 |         const mapped = docArray.map((d: any) => mapApiDocToPortalDoc(d));\n397 |         setDocuments(mapped);\n398 |       } else {\n399 |         throw new Error(\"Handshake returned malformed enclave register.\");\n400 |       }","success":true}],"durationMs":3}}
