-500/10 text-rose-400 border-rose-500/25\"\n305 |                 }`}>{active.status}</span>\n306 |               </div>\n307 | \n308 |               <div className=\"space-y-2.5 text-[10.5px]\">\n309 |                 <div className=\"flex justify-between\"><span className=\"text-white/40\">Client Account</span><span className=\"text-white font-bold\">{active.clientName}</span></div>\n310 |                 <div className=\"flex justify-between\"><span className=\"text-white/40\">Enclave Core</span><span className=\"text-white font-bold\">{active.projectName}</span></div>\n311 |                 <div className=\"flex justify-between\"><span className=\"text-white/40\">SLA Category</span><span className=\"text-white/80\">{active.category}</span></div>\n312 |                 <div className=\"flex justify-between\"><span className=\"text-white/40\">Block Date</span><span className=\"text-white/80\">{active.date}</span></div>\n313 |                 <div className=\"flex justify-between\"><span className=\"text-white/40\">Due Date</span><span className=\"text-white/80\">{active.dueDate}</span></div>\n314 |               </div>\n315 | \n316 |               <div className=\"space-y-1.5 pt-2\">\n317 |                 <span className=\"text-[10px] text-white/50 uppercase font-bold flex items-center gap-1.5\"><Lock className=\"w-3.5 h-3.5 text-emerald-400\" />Attestation Ledger Seal</span>\n318 |                 <div className=\"p-3 bg-zinc-950 rounded border border-white/5 font-mono text-[9px] text-zinc-400 whitespace-pre overflow-x-auto\">\n319 | {`{\n320 |   \"ledger_seal\": \"${active.hash}\",\n321 |   \"attestation\": \"AMD_SEV_SNP_HSM_SEALED\",\n322 |   \"root_key\": \"GFF_ROOT_ECC256\",\n323 |   \"integrity_checked\": true\n324 | }`}\n325 |                 </div>\n326 |               </div>\n327 |             </div>\n328 | \n329 |             <div className=\"pt-6 border-t border-white/5 grid grid-cols-2 gap-2.5 bg-black/40 -mx-6 -mb-6 p-6\">\n330 |               <button onClick={() => handleDownload(active.id)} disabled={isDownloading} className=\"h-9 rounded border border-white/10 text-white text-[10px] uppercase font-bold flex items-center justify-center gap-1 cursor-pointer\">\n331 |                 <Download className=\"w-3.5 h-3.5\" />\n332 |                 <span>{isDownloading ? \"Downloading...\" : \"Export PDF\"}</span>\n333 |               </button>\n334 |               {active.status !== \"paid\" ? (\n335 |                 <button onClick={() => handleSettlePayment(active.id)} disabled={isProcessing} className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] text-white uppercase font-bold flex items-center justify-center gap-1 cursor-pointer\">\n336 |                   <Check className=\"w-3.5 h-3.5\" />\n337 |                   <span>{isProcessing ? \"Processing...\" : \"Settle Block\"}</span>\n338 |                 </button>\n339 |               ) : (\n340 |                 <div className=\"h-9 rounded border border-emerald-500/20 bg-emerald-500/5 text-emerald-400 flex items-center justify-center gap-1 text-[9.5px] uppercase font-bold font-mono\">\n341 |                   <Check className=\"w-3.5 h-3.5\" />\n342 |                   <span>Receipt Sealed</span>\n343 |                 </div>\n344 |               )}\n345 |             </div>\n346 |           </div>\n347 |         </div>\n348 |       )}\n349 |       {/* RENDER_MODAL */}\n350 |       {isOpen && (\n351 |         <div className=\"fixed inset-0 z-40 flex justify-end font-mono\">\n352 |           <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm\" onClick={() => !signing && setIsOpen(false)} />\n353 |           <div className=\"w-full max-w-sm bg-[#050505] border-l border-white/5 p-6 relative z-10 flex flex-col justify-between h-full\">\n354 |             <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n355 |               <span className=\"text-[10px] font-bold\">DRAFT SECURE BLOCK</span>\n356 |               <button onClick={() => setIsOpen(false)} className=\"text-white/40 cursor-pointer\"><X className=\"w-4 h-4\" /></button>\n357 |             </div>\n358 |             <div className=\"flex-1 py-4\">\n359 |               {signing ? (\n360 |                 <div className=\"h-full flex flex-col justify-center items-center space-y-4\">\n361 |                   <RefreshCw className=\"w-6 h-6 animate-spin text-[#009DFF]\" />\n362 |                   <span className=\"text-[10px]\">SEALING LEDGER BLOCK ({step + 1}/3)...</span>\n363 |                 </div>\n364 |               ) : (\n365 |                 <form onSubmit={e => { e.preventDefault(); setSigning(true); }} className=\"space-y-3.5\">\n366 |                   <div className=\"space-y-1\">\n367 |                     <span className=\"text-[9px] text-white/40 block\">Client Account *</span>\n368 |                     <select required value={cId} onChange={e => setCId(e.target.value)} className=\"w-full h-8 px-2 rounded bg-black/50 border border-white/5 text-white text-[10px]\">\n369 |                       <option value=\"\">-- Choose Client --</option>\n370 |                       {previewClientAccounts.map(c => <option key={c.id} value={c.id}>{c.name.replace(\" [Preview Client]\", \"\")}</option>)}\n371 |                     </select>\n372 |                   </div>\n373 |                   <div className=\"space-y-1\">\n374 |                     <span className=\"text-[9px] text-white/40 block\">Enclave project *</span>\n375 |                     <select required disabled={!cId} value={pId} onChange={e => setPId(e.target.value)} className=\"w-full h-8 px-2 rounded bg-black/50 border border-white/5 text-white text-[10px] disabled:opacity-30\">\n376 |                       {!cId ? <option value=\"\">-- Choose Client First --</option> : projects.map(p => <option key={p.id} value={p.id}>{p.name}</option>)}\n377 |                     </select>\n378 |                   </div>\n379 |                   <div className=\"space-y-1\">\n380 |                     <span className=\"text-[9px] text-white/40 block\">Credit Invoiced Amount *</span>\n381 |                     <input required type=\"number\" min=\"1\" placeholder=\"12000\" value={amount} onChange={e => setAmount(e.target.value)} className=\"w-full h-8 px-2 rounded bg-black/50 border border-white/5 text-white text-[10px]\" />\n382 |                   </div>\n383 |                   <div className=\"space-y-1\">\n384 |                     <span className=\"text-[9px] text-white/40 block\">Settle Due Date *</span>\n385 |                     <input required type=\"date\" value={due} onChange={e => setDue(e.target.value)} className=\"w-full h-8 px-2 rounded bg-black/50 border border-white/5 text-white text-[10px]\" />\n386 |                   </div>\n387 |                   <div className=\"flex gap-2 pt-2\">\n388 |                     <button type=\"button\" onClick={() => setIsOpen(false)} className=\"flex-1 h-8 rounded border border-white/10 text-white font-bold text-[10px] cursor-pointer\">Cancel</button>\n389 |                     <button type=\"submit\" disabled={!cId || !pId || !amount} className=\"flex-1 h-8 rounded bg-[#009DFF] hover:bg-[#0082d4] text-white font-bold text-[10px] cursor-pointer disabled:opacity-40\">Sign</button>\n390 |                   </div>\n391 |                 </form>\n392 |               )}\n393 |             </div>\n394 |           </div>\n395 |         </div>\n396 |       )}\n397 |     </div>\n398 |   );\n399 | \n400 | }\n401 | ","success":true}],"durationMs":11}}
