172 |               <span className=\"text-[11px] font-bold block\">1. Ingest Telemetry</span>\n173 |               <p className=\"text-[10px] text-white/40 mt-1 leading-relaxed\">Continuous hardware credit utilization captured securely from active client sandboxes using kernel-level eBPF handlers.</p>\n174 |             </div>\n175 |           </div>\n176 |           <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex gap-3 hover:border-white/10 transition-colors\">\n177 |             <Key className=\"w-5 h-5 text-emerald-400 shrink-0\" />\n178 |             <div>\n179 |               <span className=\"text-[11px] font-bold block\">2. Seal HSM Block</span>\n180 |               <p className=\"text-[10px] text-white/40 mt-1 leading-relaxed\">Sovereign Hardware Security Enclaves generate dynamic ECDSA ECC-256 signatures over aggregated metrics.</p>\n181 |             </div>\n182 |           </div>\n183 |           <div className=\"p-4 rounded-xl border border-white/5 bg-black/30 flex gap-3 hover:border-white/10 transition-colors\">\n184 |             <Database className=\"w-5 h-5 text-[#00FFC2] shrink-0\" />\n185 |             <div>\n186 |               <span className=\"text-[11px] font-bold block\">3. Commit Ledger</span>\n187 |               <p className=\"text-[10px] text-white/40 mt-1 leading-relaxed\">Sealed invoice blocks are mapped to the administrative index, creating an immutable history for auditing.</p>\n188 |             </div>\n189 |           </div>\n190 |         </div>\n191 |       </div>\n192 |       {/* RENDER_STATS */}\n193 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n194 |         {[\n195 |           { l: \"Total Invoiced\", v: stats.total, c: \"text-white\" },\n196 |           { l: \"Settled Receipts\", v: stats.settled, c: \"text-emerald-400\" },\n197 |           { l: \"Awaiting Audit\", v: stats.proc, c: \"text-[#009DFF]\" },\n198 |           { l: \"Ledger Exposure\", v: stats.unp, c: \"text-rose-400\" }\n199 |         ].map((s, i) => (\n200 |           <div key={i} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-colors\">\n201 |             <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">{s.l}</span>\n202 |             <div className={`text-[15px] font-extrabold mt-1 ${s.c}`}>{formatUSD(s.v)} USD</div>\n203 |           </div>\n204 |         ))}\n205 |       </div>\n206 |       {/* RENDER_FILTERS */}\n207 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/30 grid grid-cols-1 sm:grid-cols-4 gap-3\">\n208 |         <input \n209 |           type=\"text\" placeholder=\"Query by ID, Client...\" value={query} onChange={e => setQuery(e.target.value)}\n210 |           className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white focus:outline-none focus:border-[#009DFF]/30 placeholder-white/30\"\n211 |         />\n212 |         <select value={selClient} onChange={e => setSelClient(e.target.value)} className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none appearance-none cursor-pointer\">\n213 |           <option value=\"all\">Sovereign Client: All</option>\n214 |           {previewClientAccounts.map(c => <option key={c.id} value={c.id}>{c.name.replace(\" [Preview Client]\", \"\")}</option>)}\n215 |         </select>\n216 |         <select value={selStatus} onChange={e => setSelStatus(e.target.value)} className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none appearance-none cursor-pointer\">\n217 |           <option value=\"all\">Invoice Status: All</option>\n218 |           <option value=\"paid\">Paid</option>\n219 |           <option value=\"unpaid\">Unpaid</option>\n220 |           <option value=\"processing\">Processing</option>\n221 |           <option value=\"overdue\">Overdue</option>\n222 |         </select>\n223 |         <select value={selMonth} onChange={e => setSelMonth(e.target.value)} className=\"h-9 px-3 rounded bg-black/40 border border-white/5 text-[10px] text-white/80 focus:outline-none appearance-none cursor-pointer\">\n224 |           <option value=\"all\">Billing Month: All</option>\n225 |           <option value=\"2026-06\">June 2026</option>\n226 |           <option value=\"2026-05\">May 2026</option>\n227 |         </select>\n228 |       </div>\n229 |       {/* RENDER_TABLE */}\n230 |       <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 overflow-hidden\">\n231 |         <div className=\"overflow-x-auto\">\n232 |           <table className=\"w-full text-left border-collapse\">\n233 |             <thead>\n234 |               <tr className=\"border-b border-white/5 bg-black/30 text-[9px] text-white/50 uppercase\">\n235 |                 <th className=\"py-3 px-5 font-bold\">Invoice ID</th>\n236 |                 <th className=\"py-3 px-5 font-bold\">Client</th>\n237 |                 <th className=\"py-3 px-5 font-bold\">Project</th>\n238 |                 <th className=\"py-3 px-5 font-bold\">Category</th>\n239 |                 <th className=\"py-3 px-5 font-bold text-right\">Amount (USD)</th>\n240 |                 <th className=\"py-3 px-5 font-bold text-center\">Due Date</th>\n241 |                 <th className=\"py-3 px-5 font-bold text-center\">Status</th>\n242 |                 <th className=\"py-3 px-5 font-bold text-center\">Seal Hash</th>\n243 |                 <th className=\"py-3 px-5\"></th>\n244 |               </tr>\n245 |             </thead>\n246 |             <tbody className=\"divide-y divide-white/[0.03]\">\n247 |               {filtered.length === 0 ? (\n248 |                 <tr>\n249 |                   <td colSpan={9} className=\"py-12 text-center text-white/35\">\n250 |                     No matching ledger blocks found.\n251 |                   </td>\n252 |                 </tr>\n253 |               ) : (\n254 |                 filtered.map(i => (\n255 |                   <tr key={i.id} onClick={() => setActive(i)} className=\"hover:bg-white/[0.02] transition-all cursor-pointer group\">\n256 |                     <td className=\"py-3.5 px-5 font-bold text-[#009DFF]\">{i.id}</td>\n257 |                     <td className=\"py-3.5 px-5 text-white/80\">{i.clientName.replace(\" [Preview Client]\", \"\")}</td>\n258 |                     <td className=\"py-3.5 px-5 text-white/60\">{i.projectName}</td>\n259 |                     <td className=\"py-3.5 px-5 text-white/40 text-[9px] uppercase\">{i.category}</td>\n260 |                     <td className=\"py-3.5 px-5 text-right font-bold text-white font-mono\">${i.amount.toLocaleString()}</td>\n261 |                     <td className=\"py-3.5 px-5 text-center text-white/50\">{i.dueDate}</td>\n262 |                     <td className=\"py-3.5 px-5 text-center\">\n263 |                       <span className={`px-2 py-0.5 rounded text-[8.5px] uppercase border font-bold ${\n264 |                         i.status === \"paid\" ? \"bg-emerald-500/10 text-emerald-400 border-emerald-500/25\" :\n265 |                         i.status === \"unpaid\" ? \"bg-amber-400/10 text-amber-400 border-amber-400/25\" :\n266 |                         i.status === \"processing\" ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\" :\n267 |                         \"bg-rose-500/10 text-rose-400 border-rose-500/25\"\n268 |                       }`}>{i.status}</span>\n269 |                     </td>\n270 |                     <td className=\"py-3.5 px-5 text-center text-white/30 text-[9px]\">{i.hash.slice(0, 10)}...</td>\n271 |                     <td className=\"py-3.5 px-5 text-center text-white/20 group-hover:text-white/85\">\n272 |                       <ChevronRight className=\"w-4 h-4 translate-x-0 group-hover:translate-x-0.5 transition-transform\" />\n273 |                     </td>\n274 |                   </tr>\n275 |                 ))\n276 |               )}\n277 |             </t