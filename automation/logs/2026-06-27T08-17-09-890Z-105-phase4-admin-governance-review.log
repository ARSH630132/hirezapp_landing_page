ing-relaxed space-y-1 select-none\">\n                    {selectedAlert.logs.map((log, index) => (\n                      <div key={index} className=\"hover:text-white transition-colors\">{log}</div>\n                    ))}\n                  </div>\n                </div>\n\n                {/* Overrides form */}\n                <form onSubmit={handleApplyOverrides} className=\"space-y-3.5 border-t border-white/5 pt-4\">\n                  <div>\n                    <label className=\"text-[9px] text-white/40 uppercase block mb-1\">Assign Reviewer</label>\n                    <select\n                      value={reviewerVal}\n                      onChange={e => setReviewerVal(e.target.value)}\n                      className=\"w-full h-8 px-2.5 rounded border border-white/10 bg-black text-[10px] text-white cursor-pointer focus:outline-none focus:border-[#009DFF] font-mono\"\n                    >\n                      <option value=\"Unassigned\">Unassigned</option>\n                      <option value=\"Dr. Sarah Vance\">Dr. Sarah Vance</option>\n                      <option value=\"Alexander Mercer\">Alexander Mercer</option>\n                      <option value=\"Sophia Lin\">Sophia Lin</option>\n                    </select>\n                  </div>\n\n                  <div>\n                    <label className=\"text-[9px] text-white/40 uppercase block mb-1\">Update Boundary Status</label>\n                    <select\n                      value={statusVal}\n                      onChange={e => setStatusVal(e.target.value as GovernanceAlert[\"status\"])}\n                      className=\"w-full h-8 px-2.5 rounded border border-white/10 bg-black text-[10px] text-white cursor-pointer focus:outline-none focus:border-[#009DFF] font-mono\"\n                    >\n                      <option value=\"Flagged\">Flagged</option>\n                      <option value=\"Under Review\">Under Review</option>\n                      <option value=\"Remediated\">