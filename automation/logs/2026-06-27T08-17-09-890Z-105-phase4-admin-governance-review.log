{"ts":"2026-06-27T08:06:55.581Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"vrwcmfns","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useMemo, useEffect, useRef } from \"react\";\nimport { \n  ShieldAlert, ShieldCheck, CheckCircle, AlertCircle, FileText, Copy, Search, \n  X, ChevronRight, ChevronDown, Download, Lock, RefreshCw, UserCheck, \n  ThumbsUp, ThumbsDown, Layers, Cpu, SlidersHorizontal, ExternalLink, RotateCcw, Info,\n  Globe, Sparkles, Plus, Terminal, Settings, Activity, Check, Play, Shield\n} from \"lucide-react\";\nimport { \n  WorkspaceCard, \n  MetricTile, \n  StatusBadge, \n  BadgeState, \n  PrivatePageHeader \n} from \"@/components/private-app\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\n// -----------------------------------------------------------------------------\n// DATA MODELS & MOCK DATABASES\n// -----------------------------------------------------------------------------\n\ninterface GovernanceAlert {\n  id: string;\n  title: string;\n  client: string;\n  project: string;\n  nodeId: string;\n  standard: \"ISO-27001\" | \"SOC2 Type II\" | \"HIPAA\" | \"GDPR Enclave\" | \"NIST AI RMF\";\n  sev: \"Critical\" | \"High\" | \"Medium\" | \"Low\";\n  status: \"Flagged\" | \"Under Review\" | \"Remediated\" | \"Suppressed\";\n  owner: string;\n  dueDate: string;\n  desc: string;\n  hash: string;\n  logs: string[];\n}\n\ninterface GuardrailPolicy {\n  id: string;\n  name: string;\n  code: string;\n  standard: string;\n  category: string;\n  desc: string;\n  enforced: boolean;\n}\n\nconst INITIAL_ALERTS: GovernanceAlert[] = [\n  {\n    id: \"GOV-091\",\n    title: \"Sovereign Packet Leakage\",\n    client: \"Apex Group\",\n    project: \"Sovereign Core Sandbox 02\",\n    nodeId: \"APEX-SEC-G4\",\n    standard: \"ISO-27001\",\n    sev: \"Critical\",\n    status: \"Under Review\",\n    owner: \"Alexander Mercer\",\n    dueDate: \"2026-07-01\",\n    desc: \"Anomalous outbound socket attempt detected bypassing the primary encrypted gRPC proxy. Isolation boundary successfully clamped.\",\n    hash: \"0x7F9B1E22D4A3C8F\",\n    logs: [\n      \"[12:15:33] initializing eBPF socket listener on enclave APEX-SEC-G4...\",\n      \"[12:15:35] OUTBOUND PACKET DETECTED: payload 4.8MB towards external_ip (unauthorized IP range).\",\n      \"[12:15:36] WARNING: Outbound socket bypassed primary gRPC enclave proxy.\",\n      \"[12:15:36] ACTION TRIGGERED: Enclave boundary isolated. Port clamped.\",\n      \"[12:15:37] Policy ENFORCE_ISOLATION triggered alert GOV-091.\"\n    ]\n  },\n  {\n    id: \"GOV-092\",\n    title: \"eBPF Telemetry Decoupled\",\n    client: \"National Health Enclave\",\n    project: \"Clinical AI Patient Vault\",\n    nodeId: \"MED-CLINIC-H9\",\n    standard: \"HIPAA\",\n    sev: \"High\",\n    status: \"Flagged\",\n    owner: \"Medical Ops Lead\",\n    dueDate: \"2026-07-03\",\n    desc: \"Kernel-level auditing probe detached unexpectedly during hot model re-allocation. Real-time telemetry feed paused.\",\n    hash: \"0xBC3E491A2E385D9\",\n    logs: [\n      \"[10:04:12] Performing multi-agent re-allocation on node MED-CLINIC-H9...\",\n      \"[10:04:14] System telemetry probe lost connection with kernel ring buffer.\",\n      \"[10:04:15] CRITICAL WARNING: Enclave tracing decoupled. Zero-knowledge logging offline.\",\n      \"[10:04:16] System flag: Telemetry missing. Policy eBPF_HEARTBEAT breached.\"\n    ]\n  },\n  {\n    id: \"GOV-093\",\n    title: \"HIPAA Key Rotation Delay\",\n    client: \"National Health Enclave\",\n    project: \"Surgical Pathfinding Mesh\",\n    nodeId: \"MED-CLINIC-H12\",\n    standard: \"HIPAA\",\n    sev: \"Medium\",\n    status: \"Flagged\",\n    owner: \"Sophia Lin\",\n    dueDate: \"2026-07-05\",\n    desc: \"Automated cryptographic handshake postponed due to cluster lock. Needs manual administrative rollover trigger.\",\n    hash: \"0xDE8911C400AA38B\",\n    logs: [\n      \"[08:00:00] Triggering 30-day key rotation handshake on MED-CLINIC-H12...\",\n      \"[08:00:02] Rotation aborted: Enclave memory locked by surgical run.\",\n      \"[08:00:03] HANDSHAKE DELAYED. System continues with stale key-seal.\",\n      \"[08:00:04] Policy KEY_ROT_AGE breached. Alert logged.\"\n    ]\n  },\n  {\n    id: \"GOV-094\",\n    title: \"Memory Boundary Shift\",\n    client: \"Sovereign Retail Group\",\n    project: \"Sovereign Supply Matrix\",\n    nodeId: \"RETAIL-CORE-A1\",\n    standard: \"SOC2 Type II\",\n    sev: \"Critical\",\n    status: \"Suppressed\",\n    owner: \"Alexander Mercer\",\n    dueDate: \"2026-06-30\",\n    desc: \"Sovereign model thread requested high-clearance cache inspect block. Denied by hardware gate.\",\n    hash: \"0x99AA18CCBFF002E\",\n    logs: [\n      \"[14:22:10] Model agent requested access to host shared L3 cache block...\",\n      \"[14:22:11] SECURE ENCLAVE DENIED: Memory address space outside assigned page registry.\",\n      \"[14:22:12] Sandboxed memory boundary defended successfully.\",\n      \"[14:22:13] Policy SEGREGATION_OF_DUTIES logged warning.\"\n    ]\n  },\n  {\n    id: \"GOV-095\",\n    title: \"Unsigned Model Weights Loading\",\n    client: \"Sovereign Mining Corp\",\n    project: \"Deep Excavation AI Layer\",\n    nodeId: \"ORE-TUNNEL-X4\",\n    standard: \"NIST AI RMF\",\n    sev: \"High\",\n    status: \"Remediated\",\n    owner: \"Sophia Lin\",\n    dueDate: \"2026-06-25\",\n    desc: \"Attempt to hot-load model weights lacking GFF dual-signatory cryptographic signature.\",\n    hash: \"0x6FFA12B10B4D5E1\",\n    logs: [\n      \"[11:10:05] Model agent ORE-MINER-V2 requested weights load handshake...\",\n      \"[11:10:06] Validating weight file signature block...\",\n      \"[11:10:07] FAILURE: Signature missing or corrupt. Hash mismatch detected.\",\n      \"[11:10:08] CRITICAL BLOCK: Weight load rejected. Enclave locked to fallback weights.\",\n      \"[11:10:15] Remediation active: Fallback model signature verified.\"\n    ]\n  }\n];\n\nconst INITIAL_POLICIES: GuardrailPolicy[] = [\n  {\n    id: \"POL-001\",\n    name: \"eBPF Host Syscall Isolation\",\n    code: \"eBPF_HOST_ISOLATE\",\n    standard: \"SOC2 / NIST\",\n    category: \"Hypervisor Security\",\n    desc: \"Kernel-level monitoring ensuring sandbox containers cannot inspect host memory addresses or shared syscall spaces.\",\n    enforced: true\n  },\n  {\n    id: \"POL-002\",\n    name: \"30-Day Hardware HSM Key Hygiene\",\n    code: \"HSM_KEY_ROTATION\",\n    standard: \"ISO-27001\",\n    category: \"Cryptography\",\n    desc: \"Enforces continuous automatic key rotation inside hardware-secured enclave modules to guarantee master secrecy.\",\n    enforced: true\n  },\n  {\n    id: \"POL-003\",\n    name: \"Zero-Knowledge Network Handshake\",\n    code: \"ZK_NET_TUNNEL\",\n    standard: \"ISO-27001 / GDPR\",\n    category: \"Networking\",\n    desc: \"Requires dual-signatory TLS 1.3 tunnels. Telemetry passing through GFF AI is anonymized with zero-knowledge proof verification.\",\n    enforced: true\n  },\n  {\n    id: \"POL-004\",\n    name: \"GDPR Enclave Data Redaction\",\n    code: \"GDPR_ENCLAVE_REDACT\",\n    standard: \"GDPR Enclave\",\n    category: \"Privacy Guard\",\n    desc: \"Inspects multi-agent conversational logging streams and automatically redacts PII before disk writes.\",\n    enforced: true\n  },\n  {\n    id: \"POL-005\",\n    name: \"LLM Context Outbound Gate\",\n    code: \"LLM_OUTBOUND_GATE\",\n    standard: \"NIST AI RMF\",\n    category: \"Model Alignment\",\n    desc: \"Intercepts and scans agent-to-agent outbound requests for proprietary source code, credentials, or API keys.\",\n    enforced: false\n  }\n];\n\nexport default function AdminGovernancePage() {\n  // -----------------------------------------------------------------------------\n  // STATE MANAGEMENT\n  // -----------------------------------------------------------------------------\n  const [alerts, setAlerts] = useState<GovernanceAlert[]>(INITIAL_ALERTS);\n  const [policies, setPolicies] = useState<GuardrailPolicy[]>(INITIAL_POLICIES);\n  const [selectedAlert, setSelectedAlert] = useState<GovernanceAlert | null>(null);\n  const [activeTab, setActiveTab] = useState<\"alert-ledger\" | \"guardrail-matrix\" | \"hardware-hsm\">(\"alert-ledger\");\n  \n  // Search and Filters\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [clientFilter, setClientFilter] = useState(\"All\");\n  const [sevFilter, setSevFilter] = useState(\"All\");\n  const [statusFilter, setStatusFilter] = useState(\"All\");\n\n  // Telemetry drawer edit state\n  const [reviewerVal, setReviewerVal] = useState(\"Unassigned\");\n  const [statusVal, setStatusVal] = useState<GovernanceAlert[\"status\"]>(\"Flagged\");\n  \n  // Handshake and HSM rotation state\n  const [hsmStatus, setHsmStatus] = useState<\"SEALED\" | \"ROTATING\" | \"ROTATED\">(\"SEALED\");\n  const [hsmProgress, setHsmProgress] = useState(0);\n  const [hsmLogs, setHsmLogs] = useState<string[]>([]);\n  const [isRotating, setIsRotating] = useState(false);\n\n  // Compliance Scan simulation state\n  const [isScanning, setIsScanning] = useState(false);\n  const [scanProgress, setScanProgress] = useState(0);\n  const [scanLog, setScanLog] = useState<string>(\"\");\n\n  // Toast State\n  interface Toast { id: string; msg: string; type: \"success\" | \"warning\" | \"info\" }\n  const [toasts, setToasts] = useState<Toast[]>([]);\n\n  // -----------------------------------------------------------------------------\n  // TOAST TRIGGER\n  // -----------------------------------------------------------------------------\n  const triggerToast = (msg: string, type: \"success\" | \"warning\" | \"info\" = \"info\") => {\n    const id = Math.random().toString(36).substring(2, 9);\n    setToasts(prev => [...prev, { id, msg, type }]);\n    setTimeout(() => {\n      setToasts(prev => prev.filter(t => t.id !== id));\n    }, 4000);\n  };\n\n  // -----------------------------------------------------------------------------\n  // HANDLERS\n  // -----------------------------------------------------------------------------\n  const handleSelectAlert = (alert: GovernanceAlert) => {\n    setSelectedAlert(alert);\n    setReviewerVal(alert.owner);\n    setStatusVal(alert.status);\n  };\n\n  const handleApplyOverrides = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!selectedAlert) return;\n\n    setAlerts(prev => prev.map(a => \n      a.id === selectedAlert.id \n        ? { ...a, owner: reviewerVal, status: statusVal } \n        : a\n    ));\n    \n    triggerToast(`Alert ${selectedAlert.id} override applied successfully.`, \"success\");\n    setSelectedAlert(null);\n  };\n\n  const handleTogglePolicy = (policyId: string) => {\n    let policyName = \"\";\n    let state = false;\n\n    setPolicies(prev => prev.map(p => {\n      if (p.id === policyId) {\n        policyName = p.name;\n        state = !p.enforced;\n        return { ...p, enforced: !p.enforced };\n      }\n      return p;\n    }));\n\n    if (state) {\n      triggerToast(`Policy enforced: '${policyName}' is now active.`, \"success\");\n    } else {\n      triggerToast(`Policy bypassed: '${policyName}' is set to PASSIVE/AUDIT-ONLY.`, \"warning\");\n    }\n  };\n\n  // Simulated HSM Master Key rotation\n  const triggerHSMRotation = () => {\n    if (isRotating) return;\n    setIsRotating(true);\n    setHsmStatus(\"ROTATING\");\n    setHsmProgress(0);\n    setHsmLogs([\"[14:40:01] Initializing hardware master key rotation...\"]);\n\n    const logSteps = [\n      { p: 15, text: \"[14:40:02] Handshake request authenticated by administrator (Dr. Sarah Vance).\" },\n      { p: 35, text: \"[14:40:03] Querying AMD SEV-SNP & Intel SGX enclave telemetry ports...\" },\n      { p: 55, text: \"[14:40:04] Injecting zero-knowledge key seed matrix. Destroying previous hardware root certs.\" },\n      { p: 75, text: \"[14:40:05] Multiplexing new cryptographic signatures to 18 active nodes.\" },\n      { p: 90, text: \"[14:40:06] Verifying key seal hashes. Key material locked inside secure HSM ring.\" },\n      { p: 100, text: \"[14:40:07] HSM SEAL RESTORED. Dual-signatory certificates updated across network.\" }\n    ];\n\n    let stepIdx = 0;\n    const interval = setInterval(() => {\n      if (stepIdx < logSteps.length) {\n        const current = logSteps[stepIdx];\n        setHsmProgress(current.p);\n        setHsmLogs(prev => [...prev, current.text]);\n        stepIdx++;\n      } else {\n        clearInterval(interval);\n        setHsmStatus(\"ROTATED\");\n        setIsRotating(false);\n        triggerToast(\"HSM Master Keys rotated successfully.\", \"success\");\n      }\n    }, 1000);\n  };\n\n  // Simulated System Scan\n  const triggerSystemScan = () => {\n    if (isScanning) return;\n    setIsScanning(true);\n    setScanProgress(0);\n    setScanLog(\"Initializing high-integrity guardrail scan across all client enclaves...\\n\");\n\n    const scanMessages = [\n      \"Scanning hypervisors for syscall leakage... CLEAN (POL-001 Enforced)\\n\",\n      \"Scanning HSM master keys status... VERIFIED (30-day age constraint compliant)\\n\",\n      \"Scanning Zero-Knowledge network tunnels... CLEAN (Active tunnels verified via ZK-Proof)\\n\",\n      \"Evaluating GDPR data redaction filters... WARNING (Clinical vault logging had 1 telemetry mismatch)\\n\",\n      \"Analyzing active multi-agent runs on node ORE-TUNNEL-X4... CLEAN\\n\",\n      \"Continuous compliance scan completed. System Score: 98.4%\\n\"\n    ];\n\n    let msgIdx = 0;\n    const interval = setInterval(() => {\n      if (msgIdx < scanMessages.length) {\n        setScanProgress(prev => Math.min(prev + 18, 100));\n        setScanLog(prev => prev + \" > \" + scanMessages[msgIdx]);\n        msgIdx++;\n      } else {\n        clearInterval(interval);\n        setScanProgress(100);\n        setIsScanning(false);\n        triggerToast(\"Sovereign system scan completed. 1 Warning identified.\", \"info\");\n      }\n    }, 700);\n  };\n\n  // -----------------------------------------------------------------------------\n  // DYNAMIC COMPUTATIONS & METRICS\n  // -----------------------------------------------------------------------------\n  const filteredAlerts = useMemo(() => {\n    return alerts.filter(a => {\n      const matchSearch = a.title.toLowerCase().includes(searchQuery.toLowerCase()) || \n                          a.id.toLowerCase().includes(searchQuery.toLowerCase()) || \n                          a.nodeId.toLowerCase().includes(searchQuery.toLowerCase()) || \n                          a.desc.toLowerCase().includes(searchQuery.toLowerCase());\n      const matchClient = clientFilter === \"All\" || a.client === clientFilter;\n      const matchSev = sevFilter === \"All\" || a.sev === sevFilter;\n      const matchStatus = statusFilter === \"All\" || a.status === statusFilter;\n      \n      return matchSearch && matchClient && matchSev && matchStatus;\n    });\n  }, [alerts, searchQuery, clientFilter, sevFilter, statusFilter]);\n\n  const activeAlertsCount = useMemo(() => {\n    return alerts.filter(a => a.status === \"Flagged\" || a.status === \"Under Review\").length;\n  }, [alerts]);\n\n  const overallScore = useMemo(() => {\n    // Basic dynamic simulation\n    const enforcedCount = policies.filter(p => p.enforced).length;\n    const resolvedCount = alerts.filter(a => a.status === \"Remediated\" || a.status === \"Suppressed\").length;\n    const base = 80;\n    const score = base + (enforcedCount * 3) + (resolvedCount * 1.5) - (activeAlertsCount * 2);\n    return Math.min(Math.round(score * 10) / 10, 100);\n  }, [policies, alerts, activeAlertsCount]);\n\n  const clientsList = [\"Apex Group\", \"National Health Enclave\", \"Sovereign Retail Group\", \"Sovereign Mining Corp\"];\n\n  return (\n    <div className=\"space-y-6 text-white font-mono text-[11px] relative max-w-7xl mx-auto\">\n      \n      {/* Toast Notifications Panel */}\n      <div className=\"fixed bottom-6 right-6 z-50 flex flex-col gap-2 pointer-events-none select-none\">\n        <AnimatePresence>\n          {toasts.map(t => (\n            <motion.div \n              key={t.id} \n              initial={{ opacity: 0, y: 20, scale: 0.95 }}\n              animate={{ opacity: 1, y: 0, scale: 1 }}\n              exit={{ opacity: 0, scale: 0.9, transition: { duration: 0.15 } }}\n              className={`p-3.5 rounded-xl shadow-2xl border text-[10px] font-bold flex items-center gap-2.5 pointer-events-auto max-w-sm border-white/10 ${\n                t.type === \"success\" ? \"bg-[#020202] text-[#00FFC2] shadow-[0_4px_20px_rgba(0,255,194,0.15)]\" :\n                t.type === \"warning\" ? \"bg-[#020202] text-amber-500 shadow-[0_4px_20px_rgba(245,158,11,0.15)]\" :\n                \"bg-[#020202] text-[#009DFF] shadow-[0_4px_20px_rgba(0,157,255,0.15)]\"\n              }`}\n            >\n              {t.type === \"success\" && <CheckCircle className=\"w-4 h-4 shrink-0 text-[#00FFC2]\" />}\n              {t.type === \"warning\" && <ShieldAlert className=\"w-4 h-4 shrink-0 text-amber-500\" />}\n              {t.type === \"info\" && <Info className=\"w-4 h-4 shrink-0 text-[#009DFF]\" />}\n              <div className=\"flex-1 leading-normal pr-1\">{t.msg}</div>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>\n\n      {/* Header Section */}\n      <PrivatePageHeader \n        title=\"Oversight & Guardrail Control Desk\" \n        desc=\"System-wide hardware security enclave isolation rules, eBPF telemetry feeds, and real-time sovereign guardrail verification.\"\n        badgeLabel=\"ADMIN SECURITY CONSOLE\"\n      />\n\n      {/* System Disclaimer Box */}\n      <div className=\"p-4 rounded-2xl border border-amber-500/15 bg-amber-500/[0.02] flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between\">\n        <div className=\"flex gap-3 items-start sm:items-center\">\n          <div className=\"p-2 rounded-lg bg-amber-500/10 border border-amber-500/25 shrink-0 text-amber-400\">\n            <ShieldAlert className=\"w-4 h-4\" />\n          </div>\n          <div>\n            <span className=\"font-bold uppercase block text-[10px] text-amber-400\">Continuous Enforcement Standard (CES)</span>\n            <span className=\"text-white/60\">This system monitors cryptographic sandboxes. Altering policies impacts isolation boundaries instantly.</span>\n          </div>\n        </div>\n        <div className=\"flex items-center gap-2 shrink-0\">\n          <button \n            onClick={triggerSystemScan}\n            disabled={isScanning}\n            className=\"h-8 px-4 rounded bg-amber-500/10 hover:bg-amber-500/20 text-amber-300 hover:text-amber-200 border border-amber-500/20 font-bold uppercase text-[9.5px] transition-colors flex items-center gap-1.5 cursor-pointer disabled:opacity-50\"\n          >\n            {isScanning ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <Play className=\"w-3.5 h-3.5\" />}\n            {isScanning ? \"Scanning...\" : \"Scan Compliance Matrix\"}\n          </button>\n        </div>\n      </div>\n\n      {/* Compliance Scan Drawer (Simulated) */}\n      {isScanning && (\n        <motion.div \n          initial={{ opacity: 0, height: 0 }}\n          animate={{ opacity: 1, height: \"auto\" }}\n          exit={{ opacity: 0, height: 0 }}\n          className=\"border border-white/5 bg-black/40 rounded-2xl p-4 space-y-2.5 overflow-hidden font-mono\"\n        >\n          <div className=\"flex items-center justify-between text-[9.5px]\">\n            <span className=\"text-amber-400 flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5\" /> SECURE LIVE SCAN PIPELINE</span>\n            <span className=\"text-white/40\">{scanProgress}% SECURED</span>\n          </div>\n          <div className=\"w-full bg-white/5 h-1 rounded-full overflow-hidden\">\n            <div className=\"bg-amber-500 h-full transition-all duration-300\" style={{ width: `${scanProgress}%` }} />\n          </div>\n          <pre className=\"text-[10px] text-white/50 leading-relaxed max-h-[120px] overflow-y-auto whitespace-pre-wrap p-2.5 bg-black/80 rounded border border-white/5 font-mono select-none\">\n            {scanLog}\n          </pre>\n        </motion.div>\n      )}\n\n      {/* Top Level Metric Cards */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <WorkspaceCard className=\"border-[#009DFF]/15\">\n          <div className=\"space-y-1\">\n            <div className=\"text-[9px] text-white/40 tracking-wider uppercase\">Active Sandbox Escapes</div>\n            <div className=\"text-2xl font-bold text-white flex items-baseline gap-2\">\n              <span>{activeAlertsCount}</span>\n              <span className=\"text-[9.5px] text-rose-400 font-normal px-1 py-0.2 rounded bg-rose-500/10 border border-rose-500/20\">CRITICAL FLAGS</span>\n            </div>\n            <div className=\"text-[9.5px] text-white/50 pt-2 border-t border-white/5 mt-2 flex justify-between\">\n              <span>Awaiting review</span>\n              <span className=\"text-[#009DFF] font-bold\">Priority High</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"border-[#00FFC2]/15\">\n          <div className=\"space-y-1\">\n            <div className=\"text-[9px] text-white/40 tracking-wider uppercase\">System Compliance Score</div>\n            <div className=\"text-2xl font-bold text-[#00FFC2]\">{overallScore}%</div>\n            <div className=\"text-[9.5px] text-white/50 pt-2 border-t border-white/5 mt-2 flex justify-between\">\n              <span>Standards active</span>\n              <span className=\"text-[#00FFC2] font-bold\">5 Policies</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"border-amber-500/15\">\n          <div className=\"space-y-1\">\n            <div className=\"text-[9px] text-white/40 tracking-wider uppercase\">Hardware Key Sealing</div>\n            <div className=\"text-2xl font-bold flex items-baseline gap-2\">\n              <span className={hsmStatus === \"ROTATING\" ? \"text-amber-400 animate-pulse\" : \"text-emerald-400\"}>\n                {hsmStatus === \"ROTATING\" ? `ROTATING...` : hsmStatus === \"ROTATED\" ? \"RE-SEALED\" : \"SEALED (HSM)\"}\n              </span>\n            </div>\n            <div className=\"text-[9.5px] text-white/50 pt-2 border-t border-white/5 mt-2 flex justify-between items-center\">\n              <span>Dual-signatory</span>\n              <span className=\"text-white/70 font-mono text-[9px]\">v4.1.8-X9</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"border-white/10\">\n          <div className=\"space-y-1\">\n            <div className=\"text-[9px] text-white/40 tracking-wider uppercase\">Continuous Tracing</div>\n            <div className=\"text-2xl font-bold text-white\">18 Nodes</div>\n            <div className=\"text-[9.5px] text-white/50 pt-2 border-t border-white/5 mt-2 flex justify-between\">\n              <span>eBPF telemetry pipe</span>\n              <span className=\"text-emerald-400 font-bold\">99.998% Sync</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* Main Workspace Split Layout */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 items-start\">\n        \n        {/* Left 2 Columns: Tabs + Active Content */}\n        <div className=\"lg:col-span-2 space-y-4\">\n          \n          {/* Workspace Tabs Navigation */}\n          <div className=\"flex border-b border-white/5 gap-4\">\n            <button\n              onClick={() => setActiveTab(\"alert-ledger\")}\n              className={`pb-3 font-bold uppercase text-[10px] tracking-wider relative flex items-center gap-1.5 cursor-pointer ${\n                activeTab === \"alert-ledger\" ? \"text-[#009DFF]\" : \"text-white/40 hover:text-white\"\n              }`}\n            >\n              <ShieldAlert className=\"w-3.5 h-3.5\" />\n              <span>Critical Alert Ledger ({filteredAlerts.length})</span>\n              {activeTab === \"alert-ledger\" && (\n                <motion.div layoutId=\"activeTabUnderline\" className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n              )}\n            </button>\n\n            <button\n              onClick={() => setActiveTab(\"guardrail-matrix\")}\n              className={`pb-3 font-bold uppercase text-[10px] tracking-wider relative flex items-center gap-1.5 cursor-pointer ${\n                activeTab === \"guardrail-matrix\" ? \"text-[#009DFF]\" : \"text-white/40 hover:text-white\"\n              }`}\n            >\n              <Settings className=\"w-3.5 h-3.5\" />\n              <span>Global Guardrail Matrix</span>\n              {activeTab === \"guardrail-matrix\" && (\n                <motion.div layoutId=\"activeTabUnderline\" className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n              )}\n            </button>\n\n            <button\n              onClick={() => setActiveTab(\"hardware-hsm\")}\n              className={`pb-3 font-bold uppercase text-[10px] tracking-wider relative flex items-center gap-1.5 cursor-pointer ${\n                activeTab === \"hardware-hsm\" ? \"text-[#009DFF]\" : \"text-white/40 hover:text-white\"\n              }`}\n            >\n              <Lock className=\"w-3.5 h-3.5\" />\n              <span>Hardware HSM Key Controller</span>\n              {activeTab === \"hardware-hsm\" && (\n                <motion.div layoutId=\"activeTabUnderline\" className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-[#009DFF]\" />\n              )}\n            </button>\n          </div>\n\n          {/* TAB 1: CRITICAL ALERT LEDGER */}\n          {activeTab === \"alert-ledger\" && (\n            <div className=\"space-y-4\">\n              \n              {/* Search & Filter bar */}\n              <div className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/35 flex flex-col md:flex-row gap-3 items-center\">\n                <div className=\"relative w-full flex-1\">\n                  <Search className=\"absolute left-2.5 top-2 w-3.5 h-3.5 text-white/30\" />\n                  <input\n                    type=\"text\"\n                    placeholder=\"Search incident ID, nodes, or description...\"\n                    value={searchQuery}\n                    onChange={e => setSearchQuery(e.target.value)}\n                    className=\"w-full h-7.5 pl-8 pr-3 rounded border border-white/5 bg-black/40 text-white placeholder-white/30 focus:outline-none focus:border-white/10 text-[10.5px] transition-colors font-mono\"\n                  />\n                  {searchQuery && (\n                    <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-2.5 top-2 hover:text-white text-white/40\">\n                      <X className=\"w-3.5 h-3.5\" />\n                    </button>\n                  )}\n                </div>\n\n                <div className=\"flex gap-2 w-full md:w-auto items-center\">\n                  <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/30 shrink-0\" />\n                  \n                  {/* Client Filter */}\n                  <select\n                    value={clientFilter}\n                    onChange={e => setClientFilter(e.target.value)}\n                    className=\"h-7.5 px-2 rounded border border-white/5 bg-black/40 text-[10px] text-white/80 cursor-pointer focus:outline-none font-mono\"\n                  >\n                    <option value=\"All\">All Tenants</option>\n                    {clientsList.map(c => <option key={c} value={c}>{c}</option>)}\n                  </select>\n\n                  {/* Severity Filter */}\n                  <select\n                    value={sevFilter}\n                    onChange={e => setSevFilter(e.target.value)}\n                    className=\"h-7.5 px-2 rounded border border-white/5 bg-black/40 text-[10px] text-white/80 cursor-pointer focus:outline-none font-mono\"\n                  >\n                    <option value=\"All\">All Severities</option>\n                    <option value=\"Critical\">Critical</option>\n                    <option value=\"High\">High</option>\n                    <option value=\"Medium\">Medium</option>\n                  </select>\n\n                  {/* Status Filter */}\n                  <select\n                    value={statusFilter}\n                    onChange={e => setStatusFilter(e.target.value)}\n                    className=\"h-7.5 px-2 rounded border border-white/5 bg-black/40 text-[10px] text-white/80 cursor-pointer focus:outline-none font-mono\"\n                  >\n                    <option value=\"All\">All Statuses</option>\n                    <option value=\"Flagged\">Flagged</option>\n                    <option value=\"Under Review\">Under Review</option>\n                    <option value=\"Remediated\">Remediated</option>\n                    <option value=\"Suppressed\">Suppressed</option>\n                  </select>\n                </div>\n              </div>\n\n              {/* Alerts List */}\n              <div className=\"space-y-2.5\">\n                {filteredAlerts.length === 0 ? (\n                  <div className=\"p-12 border border-dashed border-white/5 rounded-2xl text-center max-w-md mx-auto space-y-3\">\n                    <ShieldCheck className=\"w-8 h-8 text-emerald-400/40 mx-auto\" />\n                    <p className=\"text-white font-bold text-xs uppercase\">No Compliance Alerts Detected</p>\n                    <p className=\"text-white/40 text-[10px]\">All multi-tenant isolation sandboxes comply with your enforced rulesets perfectly.</p>\n                  </div>\n                ) : (\n                  filteredAlerts.map(alert => {\n                    const isSelected = selectedAlert?.id === alert.id;\n                    const isUrgent = alert.sev === \"Critical\" || alert.sev === \"High\";\n\n                    return (\n                      <div\n                        key={alert.id}\n                        onClick={() => handleSelectAlert(alert)}\n                        className={`p-4 rounded-xl border transition-all cursor-pointer text-left select-none relative group ${\n                          isSelected \n                            ? \"border-[#009DFF] bg-[#009DFF]/[0.02]\" \n                            : isUrgent\n                              ? \"border-rose-500/10 bg-rose-500/[0.01] hover:border-rose-500/20\"\n                              : \"border-white/5 bg-[#050505]/20 hover:border-white/10\"\n                        }`}\n                      >\n                        {/* Header line */}\n                        <div className=\"flex justify-between items-center gap-3\">\n                          <div className=\"flex items-center gap-2\">\n                            <span className=\"text-[10px] font-bold text-white/30 group-hover:text-white/50 transition-colors\">{alert.id}</span>\n                            <span className=\"text-white/20\">•</span>\n                            <span className=\"text-[10px] text-[#009DFF] font-bold\">{alert.standard}</span>\n                          </div>\n                          \n                          <div className=\"flex items-center gap-1.5\">\n                            {/* Severity Badge */}\n                            <span className={`px-1.5 py-0.2 rounded font-bold uppercase text-[8.5px] border ${\n                              alert.sev === \"Critical\" ? \"bg-rose-500/10 text-rose-400 border-rose-500/20\" :\n                              alert.sev === \"High\" ? \"bg-amber-500/10 text-amber-500 border-amber-500/20\" :\n                              \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\"\n                            }`}>\n                              {alert.sev}\n                            </span>\n                            \n                            {/* Status Indicator */}\n                            <span className={`h-1.5 w-1.5 rounded-full ${\n                              alert.status === \"Flagged\" ? \"bg-red-500 animate-pulse\" :\n                              alert.status === \"Under Review\" ? \"bg-amber-400\" :\n                              alert.status === \"Remediated\" ? \"bg-emerald-500\" : \"bg-white/30\"\n                            }`} />\n                            <span className=\"text-[9px] text-white/40 uppercase font-bold\">{alert.status}</span>\n                          </div>\n                        </div>\n\n                        {/* Title and description */}\n                        <div className=\"mt-2.5\">\n                          <h4 className=\"text-[12px] font-bold text-white group-hover:text-[#009DFF] transition-colors leading-tight\">{alert.title}</h4>\n                          <p className=\"text-white/60 text-[10.5px] mt-1 leading-relaxed line-clamp-2\">{alert.desc}</p>\n                        </div>\n\n                        {/* Footer metadata */}\n                        <div className=\"mt-3.5 pt-3 border-t border-white/5 flex flex-wrap justify-between items-center text-[9.5px] text-white/40 gap-2\">\n                          <div className=\"flex items-center gap-1\">\n                            <Globe className=\"w-3.5 h-3.5 text-white/20 shrink-0\" />\n                            <span>Client: <strong className=\"text-white/70\">{alert.client}</strong></span>\n                            <span className=\"text-white/10\">|</span>\n                            <Cpu className=\"w-3.5 h-3.5 text-white/20 shrink-0\" />\n                            <span>Node: <strong className=\"text-white/70\">{alert.nodeId}</strong></span>\n                          </div>\n                          <div className=\"flex items-center gap-1.5\">\n                            <span>Officer: <strong className=\"text-white/70\">{alert.owner}</strong></span>\n                            <span className=\"text-white/10\">|</span>\n                            <span className=\"text-white/30\">Due {alert.dueDate}</span>\n                          </div>\n                        </div>\n\n                        {/* Active hover visual */}\n                        <div className=\"absolute right-3 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity\">\n                          <ChevronRight className=\"w-4 h-4 text-[#009DFF]\" />\n                        </div>\n                      </div>\n                    );\n                  })\n                )}\n              </div>\n            </div>\n          )}\n\n          {/* TAB 2: GLOBAL GUARDRAIL MATRIX */}\n          {activeTab === \"guardrail-matrix\" && (\n            <div className=\"space-y-4\">\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 space-y-1\">\n                <h3 className=\"font-bold text-white text-[11.5px] uppercase\">Hypervisor-Level Kernel Blockers</h3>\n                <p className=\"text-white/50 text-[10px] leading-relaxed\">\n                  These continuous checks are embedded into the hardware-assisted hypervisor layers of GFF AI's multi-tenant clusters. Deactivating a policy suspends active blockages and places the enclave cluster into passive telemetry scanning mode.\n                </p>\n              </div>\n\n              <div className=\"space-y-2.5\">\n                {policies.map(policy => (\n                  <div key={policy.id} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/10 flex items-start justify-between gap-4\">\n                    <div className=\"space-y-1.5 max-w-xl\">\n                      <div className=\"flex items-center gap-2 flex-wrap\">\n                        <span className=\"text-[10px] font-bold text-white/30\">{policy.id}</span>\n                        <span className=\"text-[10.5px] text-[#009DFF] font-bold uppercase\">{policy.code}</span>\n                        <span className=\"text-white/20\">•</span>\n                        <span className=\"text-[9.5px] px-1.5 py-0.2 rounded bg-white/5 border border-white/10 text-white/40\">{policy.standard}</span>\n                        <span className=\"text-[9px] px-1.5 py-0.2 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF] uppercase font-mono\">{policy.category}</span>\n                      </div>\n                      <h4 className=\"text-[12px] font-bold text-white\">{policy.name}</h4>\n                      <p className=\"text-white/60 text-[10.5px] leading-relaxed\">{policy.desc}</p>\n                    </div>\n\n                    <div className=\"flex flex-col items-end gap-1.5 shrink-0 select-none\">\n                      <label className=\"relative inline-flex items-center cursor-pointer\">\n                        <input \n                          type=\"checkbox\" \n                          checked={policy.enforced} \n                          onChange={() => handleTogglePolicy(policy.id)}\n                          className=\"sr-only peer\" \n                        />\n                        <div className=\"w-9 h-5 bg-white/5 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white/40 after:border-none after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#009DFF] peer-checked:after:bg-black\" />\n                      </label>\n                      <span className={`text-[8.5px] font-bold uppercase tracking-wider ${\n                        policy.enforced ? \"text-[#00FFC2]\" : \"text-white/30\"\n                      }`}>\n                        {policy.enforced ? \"Enforced & Active\" : \"Passive Audit Only\"}\n                      </span>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* TAB 3: HARDWARE HSM KEY CONTROLLER */}\n          {activeTab === \"hardware-hsm\" && (\n            <div className=\"space-y-4\">\n              <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/20 space-y-4\">\n                <div className=\"flex gap-3 items-start\">\n                  <div className=\"p-3 rounded-xl bg-[#00FFC2]/10 border border-[#00FFC2]/20 text-[#00FFC2] shrink-0\">\n                    <Lock className=\"w-5 h-5\" />\n                  </div>\n                  <div className=\"space-y-1\">\n                    <h3 className=\"font-bold text-white text-[12px] uppercase\">Cryptographic Master Key Roll-over</h3>\n                    <p className=\"text-white/50 text-[10.5px] leading-relaxed max-w-lg\">\n                      Physical GFF AI deployments utilize isolated HSM systems (FIPS 140-3 Level 4 equivalent) to anchor tenant privacy. Rotating the master key destroys intermediate ephemeral zero-knowledge seed structures and forces every node to run a multi-party signature handshake.\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"p-4 rounded-xl bg-black/40 border border-white/5 flex flex-col md:flex-row gap-4 items-center justify-between\">\n                  <div>\n                    <span className=\"text-white/45 text-[10px] block\">CURRENT KEY HASH SEAL</span>\n                    <strong className=\"text-white font-mono text-[11px]\">SHA_ZKP_0x7FFA8811BCDE2230018AE992F_SEALED</strong>\n                    <div className=\"text-[9.5px] text-emerald-400 flex items-center gap-1.5 mt-1.5\">\n                      <span className=\"h-2 w-2 rounded-full bg-emerald-500 animate-pulse\" />\n                      <span>Sovereign Enclaves Handshaked: 18/18 active nodes authenticated.</span>\n                    </div>\n                  </div>\n\n                  <button\n                    onClick={triggerHSMRotation}\n                    disabled={isRotating}\n                    className=\"h-8.5 px-4 rounded bg-[#00FFC2] hover:bg-[#00d8a5] text-black font-bold uppercase text-[10px] tracking-wider transition-colors shrink-0 cursor-pointer disabled:opacity-40\"\n                  >\n                    {isRotating ? \"ROTATING MASTER KEYS...\" : \"ROTATE HSM MASTER KEY\"}\n                  </button>\n                </div>\n\n                {/* HSM progress animation */}\n                {hsmStatus !== \"SEALED\" && (\n                  <div className=\"space-y-3 pt-2 font-mono\">\n                    <div className=\"flex justify-between items-center text-[9.5px]\">\n                      <span className=\"text-[#00FFC2] flex items-center gap-1.5 font-bold uppercase tracking-wider\">\n                        <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#00FFC2]\" /> HSM Key Regeneration Engine\n                      </span>\n                      <span>{hsmProgress}% SEEDED</span>\n                    </div>\n                    <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n                      <div className=\"bg-[#00FFC2] h-full transition-all duration-300\" style={{ width: `${hsmProgress}%` }} />\n                    </div>\n\n                    <div className=\"p-3 bg-black/80 rounded-xl border border-white/5 space-y-1.5 max-h-[160px] overflow-y-auto font-mono text-[9.5px] text-white/50 leading-relaxed select-none\">\n                      {hsmLogs.map((log, idx) => (\n                        <div key={idx} className=\"hover:text-white transition-colors\">{log}</div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n              </div>\n            </div>\n          )}\n\n        </div>\n\n        {/* Right 1 Column: Telemetry Topology Map + Inspector Frame */}\n        <div className=\"space-y-4\">\n          \n          {/* SECURE ENCLAVE TOPOLOGY SVG */}\n          <WorkspaceCard className=\"border-white/5 bg-[#030303]/40 p-4\">\n            <div className=\"flex justify-between items-center border-b border-white/5 pb-2 mb-3\">\n              <span className=\"font-bold text-[9.5px] tracking-wider uppercase text-white/40\">Sovereign Cluster Handshakes</span>\n              <span className=\"h-2 w-2 rounded-full bg-emerald-500\" />\n            </div>\n\n            {/* Custom Interactive SVG */}\n            <div className=\"relative w-full aspect-[4/3] rounded-xl border border-white/5 bg-black/30 p-2 overflow-hidden flex items-center justify-center\">\n              \n              {/* Background scanning coordinates lines */}\n              <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.01)_1px,transparent_1px)] bg-[size:16px_16px] pointer-events-none\" />\n\n              <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 300 220\" className=\"overflow-visible select-none z-10\">\n                {/* Connection paths with subtle animation */}\n                {/* Node 1 to Hub */}\n                <path d=\"M 40,50 Q 150,50 150,110\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3,3\" className=\"opacity-40 animate-pulse\" />\n                <circle cx=\"95\" cy=\"50\" r=\"2.5\" fill=\"#009DFF\" className=\"animate-pulse\" />\n                {/* Node 2 to Hub */}\n                <path d=\"M 40,110 Q 150,110 150,110\" fill=\"none\" stroke=\"#00FFC2\" strokeWidth=\"1\" strokeDasharray=\"3,3\" className=\"opacity-40 animate-pulse\" />\n                {/* Node 3 to Hub */}\n                <path d=\"M 40,170 Q 150,170 150,110\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3,3\" className=\"opacity-40 animate-pulse\" />\n                <circle cx=\"95\" cy=\"140\" r=\"2.5\" fill=\"#009DFF\" className=\"animate-pulse\" />\n                {/* Hub to Admin */}\n                <path d=\"M 150,110 Q 250,110 250,110\" fill=\"none\" stroke=\"#FF9D00\" strokeWidth=\"1.2\" className=\"opacity-60\" />\n\n                {/* GFF Zero-Knowledge Guardrail Bridge (Central Hub) */}\n                <g transform=\"translate(150,110)\">\n                  <circle r=\"22\" fill=\"#020202\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-pulse-glow\" />\n                  <circle r=\"16\" fill=\"black\" stroke=\"#00FFC2\" strokeWidth=\"0.5\" />\n                  <polygon points=\"0,-7 -6,3 6,3\" fill=\"#00FFC2\" transform=\"scale(0.8)\" />\n                </g>\n\n                {/* Target Node: Admin (Oversight Deck) */}\n                <g transform=\"translate(250,110)\" className=\"cursor-pointer\" onClick={() => triggerToast(\"Admin Oversight console fully encrypted via dual TLS 1.3 tunnels.\", \"info\")}>\n                  <rect x=\"-18\" y=\"-18\" width=\"36\" height=\"36\" rx=\"4\" fill=\"#020202\" stroke=\"#FF9D00\" strokeWidth=\"1\" />\n                  <Shield className=\"w-4 h-4 text-amber-500 x-icon-offset\" transform=\"translate(-7, -8) scale(0.9)\" />\n                  <text x=\"0\" y=\"27\" fill=\"#FF9D00\" fontSize=\"7\" fontWeight=\"bold\" textAnchor=\"middle\" fontFamily=\"monospace\">ADMIN</text>\n                </g>\n\n                {/* Client Enclave Node 1: Apex (ISO-27001) */}\n                <g transform=\"translate(40,50)\" className=\"cursor-pointer group/node\" onClick={() => { setClientFilter(\"Apex Group\"); triggerToast(\"Filtered alerts to: Apex Group (ISO-27001 Enclaves).\", \"info\"); }}>\n                  <circle r=\"14\" fill=\"#020202\" stroke={clientFilter === \"Apex Group\" ? \"#009DFF\" : \"#333\"} strokeWidth=\"1.5\" className=\"transition-all hover:stroke-[#009DFF]\" />\n                  <rect x=\"-8\" y=\"-8\" width=\"16\" height=\"16\" fill=\"transparent\" />\n                  <Cpu className=\"w-3.5 h-3.5 text-white/40\" transform=\"translate(-7, -7)\" />\n                  <text x=\"0\" y=\"-19\" fill=\"#999\" fontSize=\"6.5\" textAnchor=\"middle\" fontFamily=\"monospace\">APEX-SEC</text>\n                  <circle r=\"3\" cx=\"14\" cy=\"0\" fill={clientFilter === \"Apex Group\" ? \"#009DFF\" : \"transparent\"} />\n                </g>\n\n                {/* Client Enclave Node 2: Clinical Vault (HIPAA) */}\n                <g transform=\"translate(40,110)\" className=\"cursor-pointer group/node\" onClick={() => { setClientFilter(\"National Health Enclave\"); triggerToast(\"Filtered alerts to: National Health Enclave (HIPAA Enclaves).\", \"info\"); }}>\n                  <circle r=\"14\" fill=\"#020202\" stroke={clientFilter === \"National Health Enclave\" ? \"#009DFF\" : \"#333\"} strokeWidth=\"1.5\" className=\"transition-all hover:stroke-[#009DFF]\" />\n                  <Cpu className=\"w-3.5 h-3.5 text-white/40\" transform=\"translate(-7, -7)\" />\n                  <text x=\"0\" y=\"-19\" fill=\"#999\" fontSize=\"6.5\" textAnchor=\"middle\" fontFamily=\"monospace\">MED-CLINIC</text>\n                  <circle r=\"3\" cx=\"14\" cy=\"0\" fill={clientFilter === \"National Health Enclave\" ? \"#009DFF\" : \"transparent\"} />\n                </g>\n\n                {/* Client Enclave Node 3: ORE-TUNNEL (AMD SEV) */}\n                <g transform=\"translate(40,170)\" className=\"cursor-pointer group/node\" onClick={() => { setClientFilter(\"Sovereign Mining Corp\"); triggerToast(\"Filtered alerts to: Sovereign Mining Corp (AMD SEV-SNP Enclaves).\", \"info\"); }}>\n                  <circle r=\"14\" fill=\"#020202\" stroke={clientFilter === \"Sovereign Mining Corp\" ? \"#009DFF\" : \"#333\"} strokeWidth=\"1.5\" className=\"transition-all hover:stroke-[#009DFF]\" />\n                  <Cpu className=\"w-