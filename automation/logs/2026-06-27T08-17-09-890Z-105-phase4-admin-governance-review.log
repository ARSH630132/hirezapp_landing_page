ned\").length;\n+    return list.length > 0 ? Math.round((asgn / list.length) * 100) : 100;\n+  }, [list]);\n+\n+  const onApply = (e: React.FormEvent) => {\n+    e.preventDefault();\n+    if (!sel) return;\n+    setList(list.map(i => i.id === sel.id ? { ...i, rev: rVal, status: sVal } : i));\n+    setSel(null);\n+    setToast(`Saved ${sel.id}`);\n+    setTimeout(() => setToast(null), 2000);\n+  };\n+\n+  return (\n+    <div className=\"space-y-4 text-white font-mono text-[11px] relative\">\n+      {toast && <div className=\"fixed top-5 right-5 z-50 p-2 bg-emerald-500 text-black text-[10px] rounded\">{toast}</div>}\n+      <PrivatePageHeader title=\"Oversight Control\" desc=\"Audit telemetry.\" badgeLabel=\"ADMIN CONTROL\" />\n+      <div className=\"p-3 rounded-xl border border-amber-500/15 bg-amber-500/[0.01] text-amber-300/80 flex gap-2 items-start\">\n+        <ShieldAlert className=\"w-4 h-4 shrink-0 mt-0.5\" />\n+        <div>\n+          <span className=\"font-bold uppercase block text-[10px]\">AUDIT DISCLAIMER</span>\n+          Tracks simulated enclaves. <strong className=\"text-amber-200\">Does not guarantee compliance</strong> under SEC or SOC2.\n+        </div>\n+      </div>\n+      <div className=\"grid grid-cols-2 gap-3\">\n+        <div className=\"p-3 border border-white/5 bg-[#050505]/40 rounded-xl\"><span>Unassigned Alerts</span><div className=\"text-xs font-bold text-amber-400 mt-1\">{list.filter(i => i.rev === \"Unassigned\").length} items</div></div>\n+        <div className=\"p-3 border border-white/5 bg-[#050505]/40 rounded-xl\"><span>Oversight Coverage</span><div className=\"text-xs font-bold text-[#009DFF] mt-1\">{cov}%</div></div>\n+      </div>\n+      <div className=\"p-3 border border-white/5 bg-[#050505]/40 rounded-xl\">\n+        <input placeholder=\"Search...\" value={q} onChange={e => setQ(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/5 bg-black/40 text-white focus:outline-none\" />\n+      </div>\n+      <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n+        {list.filter(i => i.title.toLowerCase().includes(q.toLowerCase()) || i.owner.toLowerCase().includes(q.toLowerCase())).map(item => {\n+          const ScopeIcon = item.type === \"client\" ? Building2 : Cpu;\n+          return (\n+            <div key={item.id} onClick={() => { setSel(item); setRVal(item.rev); setSVal(item.status); }} className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 hover:border-white/15 cursor-pointer flex flex-col justify-between h-[155px] transition-all\">\n+              <div className=\"flex justify-between items-start\"><span className=\"text-[10px] text-white/40\">{item.id}</span><span className=\"text-rose-400 border border-rose-500/20 bg-rose-500/5 px-1.5 py-0.1 rounded font-bold uppercase text-[9px]\">{item.sev}</span></div>\n+              <div className=\"space-y-1\">\n+                <h4 className=\"font-bold truncate text-[11.5px]\">{item.title}</h4>\n+                <div className=\"text-[9.5px] text-white/40\">Owner: {item.owner} • Status: {item.status}</div>\n+              </div>\n+              <div className=\"pt-2 border-t border-white/5 flex justify-between text-[10px] text-white/50\"><div className=\"flex items-center gap-1\"><ScopeIcon className=\"w-3 h-3 text-white/30\" /><span>{item.name}</span></div><span>Due: {item.dueDate}</span></div>\n+            </div>\n+          );\n+        })}\n+      </div>\n+      {sel && (\n+        <div className=\"fixed inset-0 z-40 flex justify-end\">\n+          <div onClick={() => setSel(null)} className=\"absolute inset-0 bg-black/60 backdrop-blur-xs\" />\n+          <div className=\"relative w-full sm:w-[320px] h-full bg-[#030303] border-l border-white/10 p-4 flex flex-col justify-between\">\n+            <div className=\"space-y-4\">\n+              <div className=\"flex justify-between items-center\"><span className=\"text-[#009DFF] font-bold text-[9.5px]\">TELEMETRY FRAME ({sel.id})</span><button onClick={() => setSel(null)} className=\"h-6 w-6 hover:bg-white/5 text-white/40 hover:text-white cursor-pointer rounded flex items-center justify-center\"><X className=\"w-4 h-4\" /></button></div>\n+              <h3 className=\"font-bold text-white text-xs leading-snug\">{sel.title}</h3>\n+              <p className=\"text-[10px] text-white/70 bg-black/40 p-2 rounded border border-white/5 leading-relaxed\">{sel.desc}</p>\n+              <form onSubmit={onApply} className=\"space-y-3 border-t border-b border-white/5 py-3\">\n+                <div>\n+                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Assign Reviewer</label>\n+                  <select value={rVal} onChange={e => setRVal(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n+                    {[\"Dr. Sarah Vance\", \"Alexander Mercer\", \"Sophia Lin\", \"Unassigned\"].map(r => <option key={r} value={r}>{r}</option>)}\n+                  </select>\n+                </div>\n+                <div>\n+                  <label className=\"text-[8.5px] text-white/35 uppercase block\">Update Status</label>\n+                  <select value={sVal} onChange={e => setSVal(e.target.value)} className=\"w-full h-8 px-2 rounded border border-white/10 bg-black text-[10.5px] text-white cursor-pointer\">\n+                    {[\"Flagged\", \"Under Review\", \"Remediated\", \"Suppressed\"].map(s => <option key={s} value={s}>{s}</option>)}\n+                  </select>\n+                </div>\n+                <button type=\"submit\" className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-black uppercase font-bold text-[9.5px] rounded flex items-center justify-center gap-1 cursor-pointer\">Apply Overrides <Check className=\"w-3.5 h-3.5\" /></button>\n+              </form>\n+            </div>\n+          </div>\n+        </div>\n+      )}\n+    </div>\n+  );\n }\n","success":true}],"durationMs":28}}
