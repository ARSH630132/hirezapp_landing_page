{"ts":"2026-06-27T08:13:56.645Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"3ddo85f7","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/governance/page.tsx","old_text":"          {/* TELEMETRY_INSPECTOR_PLACEHOLDER */}","new_text":"          {/* Telemetry Inspector */}\n          <AnimatePresence>\n            {selectedAlert ? (\n              <motion.div\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: 10 }}\n                className=\"p-4.5 rounded-2xl border border-[#009DFF]/30 bg-[#020202] space-y-4 shadow-xl relative\"\n              >\n                <button \n                  onClick={() => setSelectedAlert(null)}\n                  className=\"absolute top-4 right-4 text-white/40 hover:text-white cursor-pointer\"\n                >\n                  <X className=\"w-3.5 h-3.5\" />\n                </button>\n\n                <div className=\"space-y-1\">\n                  <span className=\"text-[#009DFF] font-bold text-[9px] uppercase block\">Enclave Telemetry Frame ({selectedAlert.id})</span>\n                  <h3 className=\"font-bold text-white text-[11px] leading-tight uppercase\">{selectedAlert.title}</h3>\n                </div>\n\n                <div className=\"flex items-center justify-between p-2 rounded bg-black border border-white/5 text-[9px] text-white/50\">\n                  <span className=\"truncate\">Seal: {selectedAlert.hash}</span>\n                  <button \n                    onClick={() => { navigator.clipboard.writeText(selectedAlert.hash); triggerToast(\"Hash seal copied.\", \"success\"); }}\n                    className=\"hover:text-white cursor-pointer text-white/30 shrink-0 p-1 rounded hover:bg-white/5\"\n                    title=\"Copy hash\"\n                  >\n                    <Copy className=\"w-3 h-3\" />\n                  </button>\n                </div>\n\n                <div className=\"space-y-1\">\n                  <span className=\"text-[9px] text-white/40 uppercase block font-bold\">Enclave Log Tail</span>\n                  <div className=\"p-2 bg-black rounded border border-white/5 max-h-[100px] overflow-y-auto font-mono text-[8.5px] text-emerald-400 leading-normal space-y-1 select-none\">\n                    {selectedAlert.logs.map((log, idx) => <div key={idx}>{log}</div>)}\n                  </div>\n                </div>\n\n                <form onSubmit={handleApplyOverrides} className=\"space-y-3 border-t border-white/5 pt-3\">\n                  <div>\n                    <label className=\"text-[8.5px] text-white/40 uppercase block mb-1\">Assign Reviewer</label>\n                    <select\n                      value={reviewerVal}\n                      onChange={e => setReviewerVal(e.target.value)}\n                      className=\"w-full h-7 px-2 rounded border border-white/10 bg-black text-[9.5px] text-white cursor-pointer focus:outline-none\"\n                    >\n                      <option value=\"Unassigned\">Unassigned</option>\n                      <option value=\"Dr. Sarah Vance\">Dr. Sarah Vance</option>\n                      <option value=\"Alexander Mercer\">Alexander Mercer</option>\n                      <option value=\"Sophia Lin\">Sophia Lin</option>\n                    </select>\n                  </div>\n\n                  <div>\n                    <label className=\"text-[8.5px] text-white/40 uppercase block mb-1\">Boundary Status</label>\n                    <select\n                      value={statusVal}\n                      onChange={e => setStatusVal(e.target.value as GovernanceAlert[\"status\"])}\n                      className=\"w-full h-7 px-2 rounded border border-white/10 bg-black text-[9.5px] text-white cursor-pointer focus:outline-none\"\n                    >\n                      <option value=\"Flagged\">Flagged</option>\n                      <option value=\"Under Review\">Under Review</option>\n                      <option value=\"Remediated\">Remediated</option>\n                      <option value=\"Suppressed\">Suppressed</option>\n                    </select>\n                  </div>\n\n                  <button\n                    type=\"submit\"\n                    className=\"w-full h-8 bg-[#009DFF] hover:bg-[#0082d4] text-black uppercase font-bold text-[9.5px] rounded flex items-center justify-center gap-1 cursor-pointer transition-colors\"\n                  >\n                    <span>Apply Enclave Overrides</span>\n                    <Check className=\"w-3 h-3\" />\n                  </button>\n                </form>\n              </motion.div>\n            ) : (\n              <div className=\"p-8 border border-dashed border-white/5 rounded-2xl text-center text-white/30 space-y-2 select-none\">\n                <FileText className=\"w-6 h-6 text-white/15 mx-auto\" />\n                <p className=\"text-[9px] uppercase font-bold text-white/45\">No Telemetry Selected</p>\n                <p className=\"text-[8.5px] max-w-xs mx-auto text-white/20\">\n                  Select a critical compliance event from the ledger to inspect live logs, hash certificates, and override boundary states.\n                </p>\n              </div>\n            )}\n          </AnimatePresence>\n\n          {/* Consult CTA */}\n          <WorkspaceCard className=\"mt-6 border-[#009DFF]/15 text-center\">\n            <div className=\"max-w-md mx-auto space-y-2 p-1\">\n              <ShieldCheck className=\"w-6 h-6 text-[#00FFC2] mx-auto animate-pulse-glow\" />\n              <h3 className=\"text-[11px] font-bold text-white uppercase tracking-wider\">Continuous Trust Boundary Enforcement</h3>\n              <p className=\"text-[10px] text-white/50 leading-relaxed\">\n                Need split-key multi-party signatures (M-of-N handshakes) or continuous HIPAA compliance enforcement on physical secure hardware?\n              </p>\n              <div className=\"pt-1.5\">\n                <a \n                  href=\"/admin/support\" \n                  className=\"inline-flex h-7.5 items-center gap-1 px-3 rounded bg-white/5 hover:bg-white/10 text-[9px] font-bold uppercase text-white border border-white/10 transition-colors\"\n                >\n                  <span>Consult Architects</span>\n                  <ExternalLink className=\"w-3 h-3 text-white/40\" />\n                </a>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          <style dangerouslySetInnerHTML={{ __html: `\n            @keyframes glow { \n              0%, 100% { filter: drop-shadow(0 0 3px rgba(0,255,194,0.15)); } \n              50% { filter: drop-shadow(0 0 8px rgba(0,255,194,0.35)); } \n            }\n            .animate-pulse-glow { animation: glow 2.5s infinite ease-in-out; }\n          `}} />"}}}
