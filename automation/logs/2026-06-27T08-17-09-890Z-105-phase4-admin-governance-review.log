n168 | \n169 |   const handleOpenAssignOwner = (client: AdminClient, e: React.MouseEvent) => {\n170 |     e.stopPropagation();\n171 |     setAssigningClient(client);\n172 |     setAssignedOwner(client.accountOwner);\n173 |     setIsAssignModalOpen(true);\n174 |   };\n175 | \n176 |   const handleSaveOwner = (e: React.FormEvent) => {\n177 |     e.preventDefault();\n178 |     if (!assigningClient) return;\n179 | \n180 |     const updated = clients.map(c => {\n181 |       if (c.id === assigningClient.id) {\n182 |         return { ...c, accountOwner: assignedOwner };\n183 |       }\n184 |       return c;\n185 |     });\n186 | \n187 |     setClients(updated);\n188 |     \n189 |     // Also update current drawer client if selected\n190 |     if (selectedClient && selectedClient.id === assigningClient.id) {\n191 |       setSelectedClient({ ...selectedClient, accountOwner: assignedOwner });\n192 |     }\n193 | \n194 |     setIsAssignModalOpen(false);\n195 |     setAssigningClient(null);\n196 |   };\n197 | \n198 |   const handleInitiateHandshake = (client: AdminClient, e: React.MouseEvent) => {\n199 |     e.stopPropagation();\n200 |     setHandshakeClient(client);\n201 |     setHandshakeStep(1);\n202 | \n203 |     // Step 1: Initial PKI binding\n204 |     setTimeout(() => {\n205 |       setHandshakeStep(2);\n206 |       // Step 2: Establish eBPF boundaries\n207 |       setTimeout(() => {\n208 |         setHandshakeStep(3);\n209 |         // Step 3: Mirror active session & redirect\n210 |         setTimeout(() => {\n211 |           const customSession = {\n212 |             name: client.contactName,\n213 |             email: client.contactEmail,\n214 |             role: \"client_admin\",\n215 |             clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\",\n216 |             isMock: true,\n217 |             label: `PORTAL PREVIEW - ${client.name.toUpperCase()}`\n218 |           };\n219 |           localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify(customSession));\n220 |           window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n221 |           router.push(\"/portal/dashboard\");\n222 |         }, 1200);\n223 |       }, 1000);\n224 |     }, 800);\n225 |   };\n226 | \n227 |   // ---------------------------------------------------------------------------\n228 |   // 4. FILTERED DATASETS\n229 |   // ---------------------------------------------------------------------------\n230 |   const filteredClients = clients.filter(c => {\n231 |     const matchesSearch = \n232 |       c.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n233 |       c.domain.toLowerCase().includes(searchQuery.toLowerCase()) ||\n234 |       c.industry.toLowerCase().includes(searchQuery.toLowerCase()) ||\n235 |       c.accountOwner.toLowerCase().includes(searchQuery.toLowerCase()) ||\n236 |       c.region.toLowerCase().includes(searchQuery.toLowerCase()) ||\n237 |       c.id.toLowerCase().includes(searchQuery.toLowerCase());\n238 | \n239 |     const matchesStatus = statusFilter ? c.status === statusFilter : true;\n240 |     const matchesRegion = regionFilter ? c.region === regionFilter : true;\n241 |     const matchesIndustry = industryFilter ? c.industry === industryFilter : true;\n242 | \n243 |     return matchesSearch && matchesStatus && matchesRegion && matchesIndustry;\n244 |   });\n245 | \n246 |   // Global Telemetry Summary Metrics\n247 |   const totalEnclaves = clients.length;\n248 |   const healthyCount = clients.filter(c => c.healthStatus === \"Healthy\").length;\n249 |   const totalProjects = clients.reduce((acc, c) => acc + getProjectsForClient(c.id).length, 0);\n250 |   const totalAgents = clients.reduce((acc, c) => acc + getAgentOpsForClient(c.id).length, 0);\n251 | \n252 |   // Badge Styling Generators\n253 |   const getHealthBadge = (health: AdminClient[\"healthStatus\"]) => {\n254 |     const styles = {\n255 |       Healthy: \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\",\n256 |       Warning: \"bg-amber-500/10 text-amber-400 border-amber-500/20\",\n257 |       Critical: \"bg-red-500/10 text-red-400 border-red-500/20\",\n258 |       Offline: \"bg-white/5 text-white/40 border-white/10\"\n259 |     };\n260 |     return (\n261 |       <span className={`inline-flex items-center gap-1.5 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[health]}`}>\n262 |         <span className={`h-1.5 w-1.5 rounded-full ${health === \"Healthy\" ? \"bg-emerald-400 animate-pulse\" : health === \"Warning\" ? \"bg-amber-400 animate-pulse\" : health === \"Critical\" ? \"bg-red-500\" : \"bg-white/30\"}`} />\n263 |         {health}\n264 |       </span>\n265 |     );\n266 |   };\n267 | \n268 |   const getBillingBadge = (billing: AdminClient[\"billingStatus\"]) => {\n269 |     const styles = {\n270 |       Paid: \"bg-blue-500/10 text-blue-400 border-blue-500/20\",\n271 |       Unpaid: \"bg-red-500/10 text-red-400 border-red-500/20\",\n272 |       Processing: \"bg-purple-500/10 text-purple-400 border-purple-500/20\",\n273 |       Overdue: \"bg-amber-500/10 text-amber-400 border-amber-500/20\"\n274 |     };\n275 |     return (\n276 |       <span className={`inline-flex items-center gap-1 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[billing]}`}>\n277 |         {billing}\n278 |       </span>\n279 |     );\n280 |   };\n281 | \n282 |   const getTierBadge = (tier: ClientAccount[\"tier\"]) => {\n283 |     const styles = {\n284 |       Sovereign: \"bg-amber-400/10 text-amber-300 border-amber-400/25\",\n285 |       Enterprise: \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\",\n286 |       Standard: \"bg-white/5 text-white/60 border-white/15\"\n287 |     };\n288 |     return (\n289 |       <span className={`inline-flex items-center rounded px-1.5 py-0.5 text-[9px] font-mono font-bold uppercase border ${styles[tier]}`}>\n290 |         {tier}\n291 |       </span>\n292 |     );\n293 |   };\n294 | \n295 |   return (\n296 |     <div className=\"space-y-6\">\n297 |       \n298 |       {/* HEADER */}\n299 |       <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n300 |         <div>\n301 |           <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Sovereign Tenant Registry</h2>\n302 |           <p className=\"text-xs text-white/50 mt-1 font-mono\">\n303 |             Cryptographic tenant authorization, sandbox telemetry supervision, and continuous alignment verification.\n304 |           </p>\n305 |         </div>\n306 |         <button \n307 |           onClick={() => setIsAddModalOpen(true)}\n308 |           className=\"h-10 px-4 rounded-lg bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/35 hover:border-emerald-500/50 text-emerald-400 font-mono text-xs font-bold transition-all flex items-center justify-center gap-2 shadow-[0_0_20px_rgba(16,185,129,0.05)] hover:shadow-[0_0_25px_rgba(16,185,129,0.15)] cursor-pointer\"\n309 |         >\n310 |           <Plus className=\"w-4 h-4 text-emerald-400\" />\n311 |           <span>PROVISION TENANT ACCOUNT</span>\n312 |         </button>\n313 |       </div>\n314 | \n315 |       {/* OVERVIEW METRICS DECK */}\n316 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n317 |         \n318 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n319 |           <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Managed Enclaves</span>\n320 |           <div className=\"text-2xl font-bold text-white font-mono flex items-baseline gap-2\">\n321 |             <span>{totalEnclaves}</span>\n322 |             <span className=\"text-[10px] text-emerald-400 font-semibold font-mono\">+1 configured</span>\n323 |           </div>\n324 |           <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">ISO-27001-A.9 Tenant isolation</div>\n325 |         </div>\n326 | \n327 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n328 |           <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Health Level SLA</span>\n329 |           <div className=\"text-2xl font-bold text-emerald-400 font-mono flex items-baseline gap-2\">\n330 |             <span>{totalEnclaves > 0 ? ((healthyCount / totalEnclaves) * 100).toFixed(0) : \"0\"}%</span>\n331 |             <span className=\"text-[10px] text-emerald-400/70 font-mono\">operational</span>\n332 |           </div>\n333 |           <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">{healthyCount} healthy tenants</div>\n334 |         </div>\n335 | \n336 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n337 |           <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Sandbox Layers</span>\n338 |           <div className=\"text-2xl font-bold text-white font-mono flex items-baseline gap-2\">\n339 |             <span>{totalProjects}</span>\n340 |             <span className=\"text-[10px] text-white/40 font-mono\">active grids</span>\n341 |           </div>\n342 |           <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">{totalAgents} agent workloads monitored</div>\n343 |         </div>\n344 | \n345 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n346 |           <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Attestation Spends</span>\n347 |           <div className=\"text-2xl font-bold text-blue-400 font-mono flex items-baseline gap-2\">\n348 |             <span>812K</span>\n349 |             <span className=\"text-[10px] text-white/40 font-mono\">Epoch credits</span>\n350 |           </div>\n351 |           <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">Continuous billing telemetry</div>\n352 |         </div>\n353 | \n354 |       </div>\n355 | \n356 |       {/* FILTER & CONTROL PANEL */}\n357 |       <div className=\"rounded-xl border border-white/5 bg-[#030303]/40 p-4 space-y-3\">\n358 |         <div className=\"flex flex-col md:flex-row gap-3\">\n359 |           \n360 |           {/* Search */}\n361 |           <div className=\"relative flex-1\">\n362 |             <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n363 |             <input \n364 |               type=\"text\" \n365 |               value={searchQuery}\n366 |               onChange={(e) => setSearchQuery(e.target.value)}\n367 |               placeholder=\"Filter sovereign registry by name, ID, domain, region, industry, or owner...\"\n368 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n369 |             />\n370 |             {searchQuery && (\n371 |               <button \n372 |                 onClick={() => setSearchQuery(\"\")} \n373 |                 className=\"absolute right-3 top-2.5 text-white/40 hover:text-white cursor-pointer border-none bg-transparent\"\n374 |               >\n375 |                 <X className=\"w-4 h-4\" />\n376 |               </button>\n377 |             )}\n378 |           </div>\n379 | \n380 |           {/* Filter options */}\n381 |           <div className=\"flex flex-wrap items-center gap-3\">\n382 |             \n383 |             <div className=\"relative\">\n384 |               <select \n385 |                 value={statusFilter} \n386 |                 onChange={(e) => setStatusFilter(e.target.value)}\n387 |                 className=\"h-9 rounded-lg border border-white/5 bg-[#0c0c0c] pl-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n388 |               >\n389 |                 <option value=\"\">Status: All</option>\n390 |                 <option value=\"active\">Active</option>\n391 |                 <option value=\"pending\">Pending</option>\n392 |                 <option value=\"suspended\">Suspended</option>\n393 |               </select>\n394 |               <SlidersHorizontal className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n395 |             </div>\n396 | \n397 |             <div className=\"relative\">\n398 |               <select \n399 |                 value={regionFilter} \n400 |                 onChange={(e) => setRegionFilter(e.target.value)}\n401 |                 className=\"h-9 rounded-lg border border-white/5 bg-[#0c0c0c] pl-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n402 |               >\n403 |                 <option value=\"\">Region: All</option>\n404 |                 {uniqueRegions.map(r => (\n405 |                   <option key={r} value={r}>{r}</option>\n406 |                 ))}\n407 |               </select>\n408 |               <SlidersHorizontal className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n409 |             </div>\n410 | \n411 |             <div className=\"relative\">\n412 |               <select \n413 |                 value={industryFilter} \n414 |                 onChange={(e) => setIndustryFilter(e.target.value)}\n415 |                 className=\"h-9 rounded-lg border border-white/5 bg-[#0c0c0c] pl-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n416 |               >\n417 |                 <option value=\"\">Industry: All</option>\n418 |                 {uniqueIndustries.map(ind => (\n419 |                   <option key={ind} value={ind}>{ind}</option>\n420 |                 ))}\n421 |               </select>\n422 |               <SlidersHorizontal className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n423 |             </div>\n424 | \n425 |             {(statusFilter || regionFilter || industryFilter || searchQuery) && (\n426 |               <button \n427 |                 onClick={() => {\n428 |                   setStatusFilter(\"\");\n429 |                   setRegionFilter(\"\");\n430 |                   setIndustryFilter(\"\");\n431 |                   setSearchQuery(\"\");\n432 |                 }}\n433 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 hover:bg-red-500/5 text-red-400 font-mono text-[11px] transition-all cursor-pointer uppercase font-bold\"\n434 |               >\n435 |                 Reset Filters\n436 |               </button>\n437 |             )}\n438 | \n439 |           </div>\n440 | \n441 |         </div>\n442 |       </div>\n443 | \n444 |       {/* TENANT REGISTRY TABLE */}\n445 |       {filteredClients.length === 0 ? (\n446 |         <div className=\"rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm p-12 text-center font-mono space-y-3\">\n447 |           <div className=\"mx-auto w-12 h-12 rounded-lg border border-white/5 bg-white/[0.01] flex items-center justify-center text-white/30\">\n448 |             <ShieldAlert className=\"w-6 h-6\" />\n449 |           </div>\n450 |           <h3 className=\"text-white font-semibold text-[13px] uppercase\">No Matching Sovereign Tenants</h3>\n451 |           <p className=\"text-white/40 text-[11px] max-w-md mx-auto\">\n452 |             No active administrative partitions meet the specified search query or enclave filter parameters.\n453 |           </p>\n454 |           <button \n455 |             onClick={() => {\n456 |               setStatusFilter(\"\");\n457 |               setRegionFilter(\"\");\n458 |               setIndustryFilter(\"\");\n459 |               setSearchQuery(\"\");\n460 |             }}\n461 |             className=\"px-3 py-1.5 rounded border border-white/10 hover:bg-white/5 text-white text-[11px] transition-all cursor-pointer uppercase font-bold\"\n462 |           >\n463 |             Clear Active Filter Parameters\n464 |           </button>\n465 |         </div>\n466 |       ) : (\n467 |         <div className=\"overflow-hidden rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm\">\n468 |           <div className=\"overflow-x-auto\">\n469 |             <table className=\"w-full text-left border-collapse font-mono text-[11.5px]\" role=\"grid\">\n470 |               <thead>\n471 |                 <tr className=\"border-b border-white/5 bg-white/[0.01]\" role=\"row\">\n472 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Tenant / Namespace</th>\n473 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Industry</th>\n474 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Region & Tier</th>\n475 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider\">Account Owner</th>\n476 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Enclaves</th>\n477 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Billing Preview</th>\n478 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-center\">Health Status</th>\n479 |                   <th className=\"p-4 text-[10.5px] font-bold text-white/40 uppercase tracking-wider text-right\">Actions</th>\n480 |                 </tr>\n481 |               </thead>\n482 |               <tbody className=\"divide-y divide-white/[0.03]\">\n483 |                 {filteredClients.map((client) => {\n484 |                   const projectsCount = getProjectsForClient(client.id).length;\n485 |                   const agentsCount = getAgentOpsForClient(client.id).length;\n486 | \n487 |                   return (\n488 |                     <tr \n489 |                       key={client.id}\n490 |                       onClick={() => {\n491 |                         setSelectedClient(client);\n492 |                         setDrawerTab(\"overview\");\n493 |                       }}\n494 |                       className=\"hover:bg-white/[0.01] transition-all cursor-pointer group\"\n495 |                       role=\"row\"\n496 |                     >\n497 |                       \n498 |                       {/* Name / Domain */}\n499 |                       <td className=\"p-4\">\n500 |                         <div className=\"space-y-1 max-w-[200px]\">\n501 |                           <div className=\"flex items-center gap-1.5\">\n502 |                             <span className=\"font-bold text-white group-hover:text-[#009DFF] transition-colors\">{client.name}</span>\n503 |                             {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400 shrink-0\" />}\n504 |                           </div>\n505 |                           <div className=\"text-[10px] text-white/40 flex items-center gap-1.5 font-mono\">\n506 |                             <span className=\"text-[#009DFF]\">{client.domain}</span>\n507 |                             <span>•</span>\n508 |                             <span \n509 |                               onClick={(e) => handleCopyId(client.id, e)}\n510 |                               className=\"hover:text-white transition-colors cursor-pointer flex items-center gap-0.5\"\n511 |                             >\n512 |                               {client.id.toUpperCase()}\n513 |                               {copiedId === client.id ? <Check className=\"w-2.5 h-2.5 text-emerald-400\" /> : <Copy className=\"w-2.5 h-2.5 opacity-50 hover:opacity-100\" />}\n514 |                             </span>\n515 |                           </div>\n516 |                         </div>\n517 |                       </td>\n518 | \n519 |                       {/* Industry */}\n520 |                       <td className=\"p-4 text-white/70\">\n521 |                         <div className=\"flex items-center gap-1.5\">\n522 |                           <Building className=\"w-3.5 h-3.5 text-white/30\" />\n523 |                           <span>{client.industry}</span>\n524 |                         </div>\n525 |                       </td>\n526 | \n527 |                       {/* Region & Tier */}\n528 |                       <td className=\"p-4\">\n529 |                         <div className=\"space-y-1\">\n530 |                           <div className=\"flex items-center gap-1.5 text-white/80\">\n531 |                             <Globe className=\"w-3.5 h-3.5 text-white/30\" />\n532 |                             <span>{client.region}</span>\n533 |                           </div>\n534 |                           <div>{getTierBadge(client.tier)}</div>\n535 |                         </div>\n536 |                       </td>\n537 | \n538 |                       {/* Account Owner */}\n539 |                       <td className=\"p-4\">\n540 |                         <div className=\"flex items-center gap-2\">\n541 |                           <div className=\"w-5 h-5 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 font-mono text-[9px] font-bold\">\n542 |                             {client.accountOwner.split(\" \").pop()?.[0]}\n543 |                           </div>\n544 |                           <div className=\"space-y-0.5\">\n545 |                             <span className=\"text-white font-medium\">{client.accountOwner}</span>\n546 |                             <span \n547 |                               onClick={(e) => handleOpenAssignOwner(client, e)}\n548 |                               className=\"text-[9px] text-[#009DFF] hover:underline cursor-pointer block\"\n549 |                             >\n550 |                               Re-assign owner\n551 |                             </span>\n552 |                           </div>\n553 |                         </div>\n554 |                       </td>\n555 | \n556 |                       {/* Active Counts */}\n557 |                       <td className=\"p-4 text-center\">\n558 |                         <div className=\"inline-flex flex-col items-center gap-1\">\n559 |                           <span className=\"text-white font-bold\">{projectsCount}</span>\n560 |                           <span className=\"text-[9px] text-white/30 uppercase tracking-wider\">{projectsCount === 1 ? \"Project\" : \"Projects\"}</span>\n561 |                           {agentsCount > 0 && (\n562 |                             <span className=\"text-[9px] text-emerald-400/80 font-semibold uppercase\">\n563 |                               {agentsCount} Live {agentsCount === 1 ? \"Agent\" : \"Agents\"}\n564 |                             </span>\n565 |                           )}\n566 |                         </div>\n567 |                       </td>\n568 | \n569 |                       {/* Billing Status */}\n570 |                       <td className=\"p-4 text-center\">\n571 |                         {getBillingBadge(client.billingStatus)}\n572 |                       </td>\n573 | \n574 |                       {/* Health Status */}\n575 |                       <td className=\"p-4 text-center\">\n576 |                         {getHealthBadge(client.healthStatus)}\n577 |                       </td>\n578 | \n579 |                       {/* Actions */}\n580 |                       <td className=\"p-4 text-right\" onClick={(e) => e.stopPropagation()}>\n581 |                         <div className=\"flex items-center justify-end gap-2\">\n582 |                           <button\n