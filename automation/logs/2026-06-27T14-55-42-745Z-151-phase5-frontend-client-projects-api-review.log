 PRIORITY LEVEL ALPHA dispatch to GFF Engineering Guild...\"]);\n362 |     }, 1000);\n363 |     setTimeout(() => {\n364 |       setDispatchSuccess(true);\n365 |       setNotification(`Emergency program status update requested for project ${projId}`);\n366 |     }, 2200);\n367 |   };\n368 | \n369 |   const closeDrawer = () => {\n370 |     setIsDrawerOpen(false);\n371 |     setIsRequestingUpdate(false);\n372 |     setDispatchStep(0);\n373 |     setDispatchLogs([]);\n374 |     setDispatchSuccess(false);\n375 |   };\n376 | \n377 |   const handleOpenProjectDetails = (proj: ClientProject) => {\n378 |     setSelectedProject(proj);\n379 |     setIsDrawerOpen(true);\n380 |   };\n381 | \n382 |   useEffect(() => {\n383 |     if (notification) {\n384 |       const timer = setTimeout(() => setNotification(null), 5000);\n385 |       return () => clearTimeout(timer);\n386 |     }\n387 |   }, [notification]);\n388 | \n389 |   const filteredProjects = projects.filter(p => {\n390 |     const matchesSearch = \n391 |       p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n392 |       p.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n393 |       p.owner.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n394 |       p.description.toLowerCase().includes(searchQuery.toLowerCase());\n395 |     const matchesPhase = selectedPhase ? p.phase === selectedPhase : true;\n396 |     const matchesHealth = selectedHealth ? p.healthStatus === selectedHealth : true;\n397 |     return matchesSearch && matchesPhase && matchesHealth;\n398 |   });\n399 | \n400 |   const onTrackCount = projects.filter(p => p.healthStatus === \"On Track\").length;\n401 |   const warningCount = projects.filter(p => p.healthStatus === \"Warning\").length;\n402 |   const criticalCount = projects.filter(p => p.healthStatus === \"Critical\").length;\n403 | \n404 |   const garageCount = projects.filter(p => p.phase === \"Garage\").length;\n405 |   const foundryCount = projects.filter(p => p.phase === \"Foundry\").length;\n406 |   const factoryCount = projects.filter(p => p.phase === \"Factory\").length;\n407 |   const operateCount = projects.filter(p => p.phase === \"Operate\").length;\n408 |   const lifecycleBalance = `${garageCount}G | ${foundryCount}F | ${factoryCount}F | ${operateCount}O`;\n409 | \n410 |   const avgCompliance = projects.length > 0 \n411 |     ? (projects.reduce((acc, p) => acc + p.specs.complianceScore, 0) / projects.length).toFixed(2) + \"%\"\n412 |     : \"97.53%\";\n413 | \n414 |   return (\n415 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-16 select-none relative\">\n416 |       \n417 |       {/* 0. FLOATING NOTIFICATION */}\n418 |       {notification && (\n419 |         <div className=\"fixed top-6 right-6 z-50 animate-in fade-in slide-in-from-top duration-300\">\n420 |           <div className=\"border border-emerald-500/20 bg-emerald-950/70 backdrop-blur-md text-emerald-300 px-4 py-3 rounded-xl shadow-2xl flex items-center gap-3 font-mono text-[11.5px]\">\n421 |             <CheckCircle2 className=\"w-4 h-4 text-emerald-400 shrink-0\" />\n422 |             <span>{notification}</span>\n423 |             <button onClick={() => setNotification(null)} className=\"ml-2 hover:text-white text-emerald-300/60\">\n424 |               <X className=\"w-3.5 h-3.5\" />\n425 |             </button>\n426 |           </div>\n427 |         </div>\n428 |       )}\n429 | \n430 |       {/* 1. SECURE DISCLOSURE BANNER */}\n431 |       <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n432 |         <div className=\"flex items-center gap-2.5 text-white/70\">\n433 |           <Activity className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n434 |           <span>\n435 |             <strong className=\"text-white\">COCKPIT LEDGER SYNC:</strong> Active monitoring of your secure enclaves is online. Interactive parameters represent localized sandbox partitions.\n436 |           </span>\n437 |         </div>\n438 |         <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n439 |           SECURE PROTOCOL ACTIVE\n440 |         </span>\n441 |       </div>\n442 | \n443 |       {/* 2. PRIVATE PAGE WELCOME HEADER */}\n444 |       <PrivatePageHeader\n445 |         title=\"Delivery Program Control Deck\"\n446 |         desc=\"Audit high-end sandbox developments, core model lifecycle phases, compliance checks, and secure multi-agent sandboxes.\"\n447 |         badgeLabel=\"Level III Clearance\"\n448 |         actions={\n449 |           <div className=\"flex flex-wrap gap-2 w-full md:w-auto\">\n450 |             <button\n451 |               onClick={() => {\n452 |                 triggerUpdateRequest(\"GLOBAL-COCKPIT\");\n453 |                 setIsDrawerOpen(true);\n454 |               }}\n455 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.02] px-4 text-[11px] font-mono font-bold text-white hover:bg-white/[0.06] hover:border-white/20 transition-all cursor-pointer\"\n456 |             >\n457 |               <Send className=\"w-3.5 h-3.5 text-white/60\" />\n458 |               <span>REQUEST GLOBAL AUDIT</span>\n459 |             </button>\n460 |             <button\n461 |               onClick={() => router.push(\"/portal/support\")}\n462 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#009DFF] px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/90 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.2)]\"\n463 |             >\n464 |               <MessageSquare className=\"w-3.5 h-3.5\" />\n465 |               <span>SUPPORT WIRE</span>\n466 |             </button>\n467 |           </div>\n468 |         }\n469 |       />\n470 | \n471 |       {/* 3. REAL-TIME PROGRAM HEALTH METRICS */}\n472 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n473 |         <MetricTile\n474 |           title=\"Active Engagements\"\n475 |           value={`${projects.length} Enclaves`}\n476 |           delta={projects.length > 0 ? `+${projects.length}` : \"0\"}\n477 |           direction=\"up\"\n478 |           status=\"stable\"\n479 |           sparkPoints={[4, 5, 5, 5, 5, 6, 6, 6, 6, projects.length]}\n480 |         />\n481 |         <MetricTile\n482 |           title=\"Lifecycle Balance\"\n483 |           value={lifecycleBalance}\n484 |           delta=\"NOMINAL\"\n485 |           direction=\"neutral\"\n486 |           status=\"normal\"\n487 |           sparkPoints={[10, 15, 12, 18, 20, 24, 22, 28, 30, 32]}\n488 |         />\n489 |         <MetricTile\n490 |           title=\"Program Health Ratio\"\n491 |           value={`${onTrackCount} OK / ${warningCount} WRN` + (criticalCount > 0 ? ` / ${criticalCount} CRT` : \"\")}\n492 |           delta=\"STABLE\"\n493 |           direction=\"neutral\"\n494 |           status={criticalCount > 0 ? \"warning\" : \"normal\"}\n495 |           sparkPoints={[90, 92, 88, 93, 91, 95, 94, 96, 96, 96]}\n496 |         />\n497 |         <MetricTile\n498 |           title=\"Avg Compliance Guard\"\n499 |           value={avgCompliance}\n500 |           delta=\"+0.82%\"\n501 |           direction=\"up\"\n502 |           status=\"stable\"\n503 |           sparkPoints={[95.1, 95.8, 96.2, 96.0, 96.9, 97.2, 97.0, 97.4, 97.5, parseFloat(avgCompliance)]}\n504 |         />\n505 |       </div>\n506 | \n507 |       {/* 4. FILTER & VIEW CONTROL BAR */}\n508 |       <WorkspaceCard className=\"p-4 space-y-4 md:space-y-0 md:flex md:items-center md:justify-between gap-4\">\n509 |         {/* Search Input */}\n510 |         <div className=\"relative flex-grow max-w-lg\">\n511 |           <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n512 |           <input \n513 |             type=\"text\"\n514 |             value={searchQuery}\n515 |             onChange={(e) => setSearchQuery(e.target.value)}\n516 |             placeholder=\"Search by ID, program name, owner, description...\"\n517 |             className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n518 |           />\n519 |         </div>\n520 | \n521 |         {/* Filter Selectors */}\n522 |         <div className=\"flex flex-wrap items-center gap-3\">\n523 |           {/* Phase Filter */}\n524 |           <div className=\"relative\">\n525 |             <select\n526 |               value={selectedPhase}\n527 |               onChange={(e) => setSelectedPhase(e.target.value)}\n528 |               className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n529 |             >\n530 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL LIFECYCLE PHASES</option>\n531 |               {LIFECYCLE_PHASES.map(ph => (\n532 |                 <option key={ph} value={ph} className=\"bg-[#0c0c0c] text-white\">{ph.toUpperCase()}</option>\n533 |               ))}\n534 |             </select>\n535 |             <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n536 |           </div>\n537 | \n538 |           {/* Health Status Filter */}\n539 |           <div className=\"relative\">\n540 |             <select\n541 |               value={selectedHealth}\n542 |               onChange={(e) => setSelectedHealth(e.target.value)}\n543 |               className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n544 |             >\n545 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL HEALTH STATUSES</option>\n546 |               <option value=\"On Track\" className=\"bg-[#0c0c0c] text-white\">ON TRACK</option>\n547 |               <option value=\"Warning\" className=\"bg-[#0c0c0c] text-white\">WARNING</option>\n548 |               <option value=\"Critical\" className=\"bg-[#0c0c0c] text-white\">CRITICAL</option>\n549 |             </select>\n550 |             <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n551 |           </div>\n552 | \n553 |           {/* Toggle View Mode Buttons */}\n554 |           <div className=\"flex border border-white/5 rounded-lg overflow-hidden shrink-0\">\n555 |             <button\n556 |               onClick={() => setViewMode(\"grid\")}\n557 |               className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n558 |                 viewMode === \"grid\" \n559 |                   ? \"bg-white/5 text-white\" \n560 |                   : \"bg-transparent text-white/40 hover:text-white/60\"\n561 |               }`}\n562 |             >\n563 |               GRID\n564 |             </button>\n565 |             <button\n566 |               onClick={() => setViewMode(\"table\")}\n567 |               className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n568 |                 viewMode === \"table\" \n569 |                   ? \"bg-white/5 text-white\" \n570 |                   : \"bg-transparent text-white/40 hover:text-white/60\"\n571 |               }`}\n572 |             >\n573 |               TABLE\n574 |             </button>\n575 |           </div>\n576 | \n577 |           {/* Reset Filters Option */}\n578 |           {(searchQuery || selectedPhase || selectedHealth) && (\n579 |             <button\n580 |               onClick={() => {\n581 |                 setSearchQuery(\"\");\n582 |                 setSelectedPhase(\"\");\n583 |                 setSelectedHealth(\"\");\n584 |               }}\n585 |               className=\"text-[10px] font-mono text-red-400 hover:text-red-300 uppercase tracking-wider underline cursor-pointer\"\n586 |             >\n587 |               Clear Filters\n588 |             </button>\n589 |           )}\n590 |         </div>\n591 |       </WorkspaceCard>\n592 | \n593 |       {/* 5. MAIN CONTENT */}\n594 |       {loading ? (\n595 |         <ProjectsSkeleton />\n596 |       ) : error ? (\n597 |         <ProjectsErrorState message={error} onRetry={fetchProjects} />\n598 |       ) : filteredProjects.length === 0 ? (\n599 |         <EmptyState\n600 |           title=\"No Sandbox Program Records Match\"\n601 |           description=\"Clear filters to restore telemetry.\"\n602 |           actionLabel=\"RESET FILTERS\"\n603 |           onAction={() => { setSearchQuery(\"\"); setSelectedPhase(\"\"); setSelectedHealth(\"\"); }}\n604 |           icon={FolderOpen}\n605 |         />\n606 |       ) : viewMode === \"grid\" ? (\n607 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n608 |           {filteredProjects.map((p) => (\n609 |             <WorkspaceCard \n610 |               key={p.id} \n611 |               className=\"flex flex-col h-full border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-all p-5 rounded-2xl relative\"\n612 |               spotlightColor={p.healthStatus === \"On Track\" ? \"rgba(16,185,129,0.03)\" : p.healthStatus === \"Warning\" ? \"rgba(251,191,36,0.03)\" : \"rgba(228,0,15,0.03)\"}\n613 |             >\n614 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2.5\">\n615 |                 <div className=\"flex items-center gap-2\">\n616 |                   <span className=\"text-[12px] font-mono font-bold text-[#009DFF]\">{p.id}</span>\n617 |                   <span className=\"text-[9px] text-white/20 font-mono\">•</span>\n618 |                   <span className=\"text-[9.5px] font-mono text-white/40 bg-white/5 border border-white/10 px-1 py-0.2 rounded uppercase\">{p.env}</span>\n619 |                 </div>\n620 |                 <StatusBadge state={p.healthStatus === \"On Track\" ? \"stable\" : p.healthStatus === \"Warning\" ? \"warning\" : \"error\"} label={p.healthStatus} />\n621 |               </div>\n622 |               \n623 |               <div className=\"mt-3 flex-grow space-y-1\">\n624 |                 <h3 className=\"text-[13.5px] font-bold text-white font-mono uppercase truncate\">{p.name}</h3>\n625 |                 <p className=\"text-[11px] text-white/50 leading-relaxed font-mono font-light min-h-[50px]\">{p.description}</p>\n626 |               </div>\n627 |               \n628 |               <div className=\"mt-3 flex items-center gap-2 p-2 rounded-lg bg-white/[0.01] border border-white/5 text-[11px] font-mono\">\n629 |                 <div className=\"h-6 w-6 rounded bg-[#009DFF]/10 flex items-center justify-center text-[9px] font-bold text-[#009DFF]\">{p.owner.avatarInitials}</div>\n630 |                 <div>\n631 |                   <div className=\"text-[8px] font-mono text-white/30 uppercase\">Delivery Lead</div>\n632 |                   <div className=\"text-[10.5px] text-white/80 font-bold\">{p.owner.name}</div>\n633 |                 </div>\n634 |               </div>\n635 |               \n636 |               <div className=\"mt-3 space-y-1.5 p-2.5 bg-white/[0.01] border border-white/5 rounded-lg\">\n637 |                 <span className=\"text-[8.5px] font-mono text-white/30 uppercase block font-bold font-sans\">Lifecycle Stage</span>\n638 |                 <div className=\"relative flex justify-between px-1\">\n639 |                   <div className=\"absolute left-2 right-2 top-1/2 -translate-y-1/2 h-0.5 border-t border-dashed border-white/10\" />\n640 |                   {LIFECYCLE_PHASES.map((phase, idx) => {\n641 |                     const isCurrent = p.phase === phase;\n642 |                     const isPast = LIFECYCLE_PHASES.indexOf(p.phase) > idx;\n643 |                     return (\n644 |                       <div key={phase} className=\"flex flex-col items-center relative z-10\">\n645 |                         <div className={`h-4 w-4 rounded-full flex items-center justify-center text-[8px] font-bold border ${isCurrent ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF] shadow-[0_0_8px_rgba(0,157,255,0.4)]\" : isPast ? \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\" : \"bg-[#050505] border-white/5 text-white/20\"}`}>{isPast ? \"✓\" : idx + 1}</div>\n646 |                         <span className={`text-[8.5px] font-mono mt-0.5 ${isCurrent ? \"text-white font-bold\" : isPast ? \"text-white/50\" : \"text-white/20\"}`}>{phase}</span>\n647 |                       </div>\n648 |                     );\n649 |                   })}\n650 |                 </div>\n651 |               </div>\n652 | \n653 |               <div className=\"mt-3 space-y-1\">\n654 |                 <div className=\"flex justify-between items-center text-[9.5px] font-mono text-white/40\">\n655 |                   <span>DEPLOYMENT PROGRESS</span>\n656 |                   <span className=\"text-white/80 font-bold\">{p.progress}%</span>\n657 |                 </div>\n658 |                 <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n659 |                   <div className={`h-full rounded-full ${p.healthStatus === \"On Track\" ? \"bg-[#009DFF]\" : p.healthStatus === \"Warning\" ? \"bg-amber-400\" : \"bg-red-500\"}`} style={{ width: `${p.progress}%` }} />\n660 |                 </div>\n661 |               </div>\n662 | \n663 |               <div className=\"mt-3 pt-2.5 border-t border-white/5 flex items-start gap-2 text-[10px] font-mono text-white/45\">\n664 |                 <Calendar className=\"w-3.5 h-3.5 text-white/30 shrink-0\" />\n665 |                 <div className=\"space-y-0.5\">\n666 |                   <span className=\"text-white/20 text-[8px] block font-bold\">NEXT TARGET GATE</span>\n667 |                   <span className=\"text-white/80 font-medium block leading-tight truncate max-w-[200px]\">{p.nextMilestone}</span>\n668 |                 </div>\n669 |               </div>\n670 | \n671 |               <div className=\"mt-4 pt-3 border-t border-white/5 grid grid-cols-2 gap-2\">\n672 |                 <button onClick={() => triggerUpdateRequest(p.id)} className=\"h-7.5 rounded border border-white/5 hover:bg-white/5 text-[9.5px] font-mono text-white/50 hover:text-white uppercase tracking-wider cursor-pointer\">Request Update</button>\n673 |                 <button onClick={() => handleOpenProjectDetails(p)} className=\"h-7.5 rounded bg-[#009DFF]/10 text-[9.5px] font-mono text-[#009DFF] hover:text-white flex items-center justify-center gap-1 cursor-pointer\"><span>Inspect</span><ArrowUpRight className=\"w-3 h-3\" /></button>\n674 |               </div>\n675 |             </WorkspaceCard>\n676 |           ))}\n677 |         </div>\n678 |       ) : (\n679 |         /* TABLE VIEW */\n680 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm overflow-hidden\">\n681 |           <div className=\"overflow-x-auto\">\n682 |             <table className=\"w-full min-w-[800px] text-left font-mono text-[11.5px] text-white/70\">\n683 |               <thead>\n684 |                 <tr className=\"border-b border-white/5 text-white/30 text-[9px] uppercase\">\n685 |                   <th className=\"p-3 pl-5\">ID</th>\n686 |                   <th className=\"p-3\">Program / Project</th>\n687 |                   <th className=\"p-3\">Phase</th>\n688 |                   <th className=\"p-3\">Delivery Lead</th>\n689 |                   <th className=\"p-3 text-center\">Progress</th>\n690 |                   <th className=\"p-3\">Health</th>\n691 |                   <th className=\"p-3 text-right pr-5\">Actions</th>\n692 |                 </tr>\n693 |               </thead>\n694 |               <tbody className=\"divide-y divide-white/5\">\n695 |                 {filteredProjects.map((p) => (\n696 |                   <tr key={p.id} className=\"hover:bg-white/[0.01]\">\n697 |                     <td className=\"p-3 pl-5 text-[#009DFF] font-bold\">{p.id}</td>\n698 |                     <td className=\"p-3\">\n699 |                       <div className=\"font-semibold text-white uppercase text-[11px]\">{p.name}</div>\n700 |                       <div className=\"text-[9px] text-white/30\">{p.env}</div>\n701 |                     </td>\n702 |                     <td className=\"p-3\">\n703 |                       <span className=\"px-1.5 py-0.2 text-[8.5px] font-bold bg-[#009DFF]/10 text-[#009DFF] rounded border border-[#009DFF]/20 uppercase\">\n704 |                         {p.phase}\n705 |                       </span>\n706 |                     </td>\n707 |                     <td className=\"p-3\">\n708 |                       <div className=\"text-white/80 font-bold text-[10px]\">{p.owner.name}</div>\n709 |                     </td>\n710 |                     <td className=\"p-3 text-center font-bold text-white\">{p.progress}%</td>\n711 |                     <td className=\"p-3\">\n712 |                       <StatusBadge state={p.healthStatus === \"On Track\" ? \"stable\" : p.healthStatus === \"Warning\" ? \"warning\" : \"error\"} label={p.healthStatus} />\n713 |                     </td>\n714 |                     <td className=\"p-3 text-right pr-5 space-x-1.5\">\n715 |                       <button onClick={() => triggerUpdateRequest(p.id)} className=\"h-6 px-2 text-[9px] font-bold text-white/40 hover:text-white bg-white/5 border border-white/5 rounded cursor-pointer\">Update</button>\n716 |                       <button onClick={() => handleOpenProjectDetails(p)} cl