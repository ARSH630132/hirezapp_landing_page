n402 |         matchesProject && \n403 |         matchesType && \n404 |         matchesStatus && \n405 |         matchesOwner && \n406 |         matchesVersion\n407 |       );\n408 |     });\n409 |   }, [\n410 |     documents, searchQuery, filterClient, filterProject, \n411 |     filterType, filterStatus, filterOwner, filterVersion\n412 |   ]);\n413 | \n414 |   const metrics = useMemo(() => {\n415 |     const totalCount = documents.length;\n416 |     const verifiedCount = documents.filter(d => d.status === \"Verified\").length;\n417 |     const unassignedCount = documents.filter(d => d.projectId === \"UNASSIGNED\").length;\n418 |     const integrityRate = totalCount > 0 ? ((verifiedCount / totalCount) * 100).toFixed(1) : \"100.0\";\n419 | \n420 |     return {\n421 |       totalCount,\n422 |       verifiedCount,\n423 |       unassignedCount,\n424 |       integrityRate\n425 |     };\n426 |   }, [documents]);\n427 | \n428 |   const hasActiveFilters = useMemo(() => {\n429 |     return (\n430 |       searchQuery !== \"\" ||\n431 |       filterClient !== \"all\" ||\n432 |       filterProject !== \"all\" ||\n433 |       filterType !== \"all\" ||\n434 |       filterStatus !== \"all\" ||\n435 |       filterOwner !== \"all\" ||\n436 |       filterVersion !== \"all\"\n437 |     );\n438 |   }, [searchQuery, filterClient, filterProject, filterType, filterStatus, filterOwner, filterVersion]);\n439 | \n440 |   const getStatusBadgeStyle = (status: string) => {\n441 |     switch (status) {\n442 |       case \"Verified\":\n443 |         return \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400\";\n444 |       case \"Under Review\":\n445 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-400\";\n446 |       case \"Action Required\":\n447 |         return \"border-rose-500/20 bg-rose-500/5 text-rose-400\";\n448 |       case \"Superseded\":\n449 |         return \"border-white/10 bg-white/5 text-white/50\";\n450 |       default:\n451 |         return \"border-white/15 bg-white/5 text-white/60\";\n452 |     }\n453 |   };\n454 | \n455 |   const getTypeBadgeStyle = (type: string) => {\n456 |     switch (type) {\n457 |       case \"PDF\":\n458 |         return \"border-indigo-500/20 bg-indigo-500/5 text-indigo-400\";\n459 |       case \"JSON\":\n460 |         return \"border-cyan-500/20 bg-cyan-500/5 text-cyan-400\";\n461 |       case \"YAML\":\n462 |         return \"border-purple-500/20 bg-purple-500/5 text-purple-400\";\n463 |       case \"XML\":\n464 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-500\";\n465 |       default:\n466 |         return \"border-white/10 text-white/60\";\n467 |     }\n468 |   };\n469 | \n470 |   return (\n471 |     <div className=\"space-y-6 relative min-h-screen pb-12 font-mono\">\n472 |       {/* ============================================================================ */}\n473 |       {/* HEADER SECTION */}\n474 |       {/* ============================================================================ */}\n475 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-6\">\n476 |         <div>\n477 |           <div className=\"flex items-center gap-2 text-white/40 mb-1\">\n478 |             <ShieldCheck className=\"w-4 h-4 text-[#009DFF]\" />\n479 |             <span className=\"text-[10px] font-bold tracking-widest uppercase\">System Secure Console</span>\n480 |           </div>\n481 |           <h2 className=\"text-xl font-bold text-white tracking-tight uppercase\">\n482 |             Cryptographic Document Registry\n483 |           </h2>\n484 |           <p className=\"text-xs text-white/50 mt-1 max-w-2xl leading-relaxed\">\n485 |             Administrative flight deck for managing structural schemas, security certifications, and governance policies. Re-assign credentials to isolated enclave projects to enforce real-time hardware compliance bounds.\n486 |           </p>\n487 |         </div>\n488 |         <div className=\"shrink-0 flex items-center gap-3\">\n489 |           <button\n490 |             onClick={() => setIsRegisterModalOpen(true)}\n491 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n492 |           >\n493 |             <Plus className=\"w-4 h-4\" />\n494 |             <span>Register Asset</span>\n495 |           </button>\n496 |         </div>\n497 |       </div>\n498 | \n499 |       {/* ============================================================================ */}\n500 |       {/* PREMIUM METRICS SUMMARY RIBBON */}\n501 |       {/* ============================================================================ */}\n502 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n503 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n504 |           <div className=\"flex items-center justify-between\">\n505 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Vaulted Registries</span>\n506 |             <FileText className=\"w-4 h-4 text-[#009DFF]\" />\n507 |           </div>\n508 |           <div className=\"flex items-baseline gap-2 pt-1\">\n509 |             <span className=\"text-2xl font-bold text-white tracking-tight\">{metrics.totalCount}</span>\n510 |             <span className=\"text-[9px] text-[#00FFC2] font-bold bg-[#00FFC2]/5 border border-[#00FFC2]/15 px-1 rounded\">SECURE</span>\n511 |           </div>\n512 |           <div className=\"text-[9.5px] text-white/30 truncate\">Cryptographically sealed items</div>\n513 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#009DFF]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n514 |         </div>\n515 | \n516 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n517 |           <div className=\"flex items-center justify-between\">\n518 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Enclave Bound</span>\n519 |             <Layers className=\"w-4 h-4 text-[#00FFC2]\" />\n520 |           </div>\n521 |           <div className=\"flex items-baseline gap-2 pt-1\">\n522 |             <span className=\"text-2xl font-bold text-[#00FFC2] tracking-tight\">{metrics.totalCount - metrics.unassignedCount}</span>\n523 |             <span className=\"text-[9px] text-white/40 font-semibold\">MAPPED OBJECTS</span>\n524 |           </div>\n525 |           <div className=\"text-[9.5px] text-white/30 truncate\">Active alignment integrations</div>\n526 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#00FFC2]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n527 |         </div>\n528 | \n529 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n530 |           <div className=\"flex items-center justify-between\">\n531 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Verified Rate</span>\n532 |             <Cpu className=\"w-4 h-4 text-emerald-400\" />\n533 |           </div>\n534 |           <div className=\"flex items-baseline gap-2 pt-1\">\n535 |             <span className=\"text-2xl font-bold text-emerald-400 tracking-tight\">{metrics.integrityRate}%</span>\n536 |             <span className=\"text-[9px] text-emerald-400 bg-emerald-400/5 border border-emerald-400/20 px-1 rounded\">AUDITED</span>\n537 |           </div>\n538 |           <div className=\"text-[9.5px] text-white/30 truncate\">ISO-27001 checked standards</div>\n539 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-emerald-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n540 |         </div>\n541 | \n542 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-1 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n543 |           <div className=\"flex items-center justify-between\">\n544 |             <span className=\"text-[10px] font-bold text-white/40 tracking-wider uppercase\">Unassigned Sandbox</span>\n545 |             <AlertTriangle className=\"w-4 h-4 text-amber-400\" />\n546 |           </div>\n547 |           <div className=\"flex items-baseline gap-2 pt-1\">\n548 |             <span className=\"text-2xl font-bold text-amber-400 tracking-tight\">{metrics.unassignedCount}</span>\n549 |             <span className=\"text-[9px] text-amber-400 bg-amber-400/5 border border-amber-400/25 px-1 rounded\">PENDING</span>\n550 |           </div>\n551 |           <div className=\"text-[9.5px] text-white/30 truncate\">Unmapped general registry files</div>\n552 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-amber-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n553 |         </div>\n554 |       </div>\n555 | \n556 |       {/* ============================================================================ */}\n557 |       {/* SEARCH & DETAILED FILTER SYSTEM */}\n558 |       {/* ============================================================================ */}\n559 |       <div className=\"border border-white/5 rounded-xl bg-[#050505]/20 p-4 space-y-4\">\n560 |         {/* Search & Reset Row */}\n561 |         <div className=\"flex flex-col md:flex-row gap-3 items-stretch justify-between\">\n562 |           <div className=\"relative flex-1\">\n563 |             <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-white/30\" />\n564 |             <input\n565 |               type=\"text\"\n566 |               placeholder=\"Search registry by ID, title, SHA-256 hash, or technical specifications...\"\n567 |               value={searchQuery}\n568 |               onChange={(e) => setSearchQuery(e.target.value)}\n569 |               className=\"w-full h-9 pl-10 pr-4 rounded-lg border border-white/5 bg-white/[0.02] text-xs text-white outline-none focus:border-[#009DFF]/30 focus:bg-white/[0.03] transition-all\"\n570 |             />\n571 |             {searchQuery && (\n572 |               <button \n573 |                 onClick={() => setSearchQuery(\"\")}\n574 |                 className=\"absolute right-3 top-2.5 text-white/40 hover:text-white\"\n575 |               >\n576 |                 <X className=\"w-4 h-4\" />\n577 |               </button>\n578 |             )}\n579 |           </div>\n580 |           \n581 |           <div className=\"flex items-center gap-2\">\n582 |             {hasActiveFilters && (\n583 |               <button\n584 |                 onClick={handleResetFilters}\n585 |                 className=\"h-9 px-3 rounded-lg border border-white/10 hover:border-white/20 bg-white/5 text-[10.5px] text-white/80 hover:text-white flex items-center gap-1.5 transition-all cursor-pointer\"\n586 |               >\n587 |                 <RefreshCw className=\"w-3.5 h-3.5 shrink-0\" />\n588 |                 <span>Reset Filters</span>\n589 |               </button>\n590 |             )}\n591 |             <div className=\"h-9 px-3 rounded-lg border border-white/5 bg-white/[0.01] text-[10.5px] text-white/40 flex items-center gap-1.5 select-none font-bold\">\n592 |               <SlidersHorizontal className=\"w-3.5 h-3.5\" />\n593 |               <span>{filteredDocuments.length} OF {documents.length} SECURED</span>\n594 |             </div>\n595 |           </div>\n596 |         </div>\n597 | \n598 |         {/* Dropdowns Filters Row */}\n599 |         <div className=\"grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3\">\n600 |           {/* Client Filter */}\n601 |           <div className=\"space-y-1\">\n602 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Client Enclave</label>\n603 |             <select\n604 |               value={filterClient}\n605 |               onChange={(e) => setFilterClient(e.target.value)}\n606 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n607 |             >\n608 |               <option value=\"all\">ALL CLIENTS</option>\n609 |               {CLIENTS.map((c) => (\n610 |                 <option key={c} value={c}>\n611 |                   {c.replace(\" [Preview Client]\", \"\")}\n612 |                 </option>\n613 |               ))}\n614 |             </select>\n615 |           </div>\n616 | \n617 |           {/* Project Filter */}\n618 |           <div className=\"space-y-1\">\n619 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Target Project</label>\n620 |             <select\n621 |               value={filterProject}\n622 |               onChange={(e) => setFilterProject(e.target.value)}\n623 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n624 |             >\n625 |               <option value=\"all\">ALL PROJECTS</option>\n626 |               {PROJECTS.map((p) => (\n627 |                 <option key={p.id} value={p.id}>\n628 |                   {p.id === \"UNASSIGNED\" ? \"UNASSIGNED\" : `${p.id}: ${p.name.substring(0, 16)}...`}\n629 |                 </option>\n630 |               ))}\n631 |             </select>\n632 |           </div>\n633 | \n634 |           {/* Type Filter */}\n635 |           <div className=\"space-y-1\">\n636 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Document Type</label>\n637 |             <select\n638 |               value={filterType}\n639 |               onChange={(e) => setFilterType(e.target.value)}\n640 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n641 |             >\n642 |               <option value=\"all\">ALL TYPES</option>\n643 |               {TYPES.map((t) => (\n644 |                 <option key={t} value={t}>{t}</option>\n645 |               ))}\n646 |             </select>\n647 |           </div>\n648 | \n649 |           {/* Status Filter */}\n650 |           <div className=\"space-y-1\">\n651 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Governance Status</label>\n652 |             <select\n653 |               value={filterStatus}\n654 |               onChange={(e) => setFilterStatus(e.target.value)}\n655 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n656 |             >\n657 |               <option value=\"all\">ALL STATUSES</option>\n658 |               {STATUSES.map((s) => (\n659 |                 <option key={s} value={s}>{s.toUpperCase()}</option>\n660 |               ))}\n661 |             </select>\n662 |           </div>\n663 | \n664 |           {/* Owner Filter */}\n665 |           <div className=\"space-y-1\">\n666 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Registered Owner</label>\n667 |             <select\n668 |               value={filterOwner}\n669 |               onChange={(e) => setFilterOwner(e.target.value)}\n670 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n671 |             >\n672 |               <option value=\"all\">ALL OWNERS</option>\n673 |               {OWNERS.map((o) => (\n674 |                 <option key={o} value={o}>{o}</option>\n675 |               ))}\n676 |             </select>\n677 |           </div>\n678 | \n679 |           {/* Version Filter */}\n680 |           <div className=\"space-y-1\">\n681 |             <label className=\"text-[8.5px] text-white/40 uppercase font-bold tracking-wider block\">Revision Version</label>\n682 |             <select\n683 |               value={filterVersion}\n684 |               onChange={(e) => setFilterVersion(e.target.value)}\n685 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-[#090909] px-2 text-[11px] text-white outline-none focus:border-[#009DFF]/30 transition-all cursor-pointer font-bold\"\n686 |             >\n687 |               <option value=\"all\">ALL REVISIONS</option>\n688 |               {VERSIONS.map((v) => (\n689 |                 <option key={v} value={v}>{v}</option>\n690 |               ))}\n691 |             </select>\n692 |           </div>\n693 |         </div>\n694 |       </div>\n695 | \n696 |       {/* ============================================================================ */}\n697 |       {/* MAIN DOCUMENT WORKSPACE: DESKTOP TABLE */}\n698 |       {/* ============================================================================ */}\n699 |       <div className=\"hidden md:block overflow-hidden border border-white/5 rounded-xl bg-[#050505]/20\">\n700 |         <table className=\"w-full border-collapse text-left text-[11px] font-mono\">\n701 |           <thead>\n702 |             <tr className=\"border-b border-white/5 bg-white/[0.01] text-white/40 uppercase tracking-widest text-[9px] font-bold select-none\">\n703 |               <th className=\"py-3 px-4\">Identification & Title</th>\n704 |               <th className=\"py-3 px-4\">Mapped Enterprise / Project</th>\n705 |               <th className=\"py-3 px-4\">Governance Status</th>\n706 |               <th className=\"py-3 px-4\">Owner & Revision</th>\n707 |               <th className=\"py-3 px-4\">Cryptographic Hash (SHA-256)</th>\n708 |               <th className=\"py-3 px-4 text-right\">Actions</th>\n709 |             </tr>\n710 |           </thead>\n711 |           <tbody className=\"divide-y divide-white/5\">\n712 |             {filteredDocuments.map((doc) => {\n713 |               const matchedProj = PROJECTS.find(p => p.id === doc.projectId);\n714 |               const projectName = matchedProj ? matchedProj.name : \"Unassigned Registry\";\n715 |               const isUnassigned = doc.projectId === \"UNASSIGNED\";\n716 | \n717 |               return (\n718 |                 <tr \n719 |                   key={doc.id}\n720 |                   onClick={() => setSelectedDocId(doc.id)}\n721 |                   className={`hover:bg-white/[0.02] cursor-pointer transition-colors ${selectedDocId === doc.id ? \"bg-[#009DFF]/5 hover:bg-[#009DFF]/8\" : \"\"}`}\n722 |                 >\n723 |                   <td className=\"py-3.5 px-4 max-w-xs\">\n724 |                     <div className=\"flex items-start gap-2.5\">\n725 |                       <div className={`p-2 rounded mt-0.5 border shrink-0 ${getTypeBadgeStyle(doc.type)}`}>\n726 |                         <FileText className=\"w-4 h-4\" />\n727 |                       </div>\n728 |                       <div>\n729 |                         <div className=\"flex items-center gap-1.5\">\n730 |                           <span className=\"text-[10px] text-white/30 font-bold\">{doc.id}</span>\n731 |                           <span className={`text-[8.5px] border rounded px-1 py-0.2 font-bold ${getTypeBadgeStyle(doc.type)}`}>\n732 |                             {doc.type}\n733 |                           </span>\n734 |                         </div>\n735 |                         <h4 className=\"text-white font-bold tracking-tight text-[11.5px] mt-0.5 hover:text-[#009DFF] transition-colors leading-tight\">\n736 |                           {doc.title}\n737 |                         </h4>\n738 |                         <span className=\"text-[9.5px] text-white/30 block mt-0.5 select-none font-bold\">SIZE: {doc.fileSize}</span>\n739 |                       </div>\n740 |                     </div>\n741 |                   </td>\n742 | \n743 |                   <td className=\"py-3.5 px-4 max-w-[200px]\">\n744 |                     <div className=\"space-y-1\">\n745 |                       <span className=\"text-white/80 font-bold block truncate\" title={doc.client}>\n746 |                         {doc.client.replace(\" [Preview Client]\", \"\")}\n747 |                       </span>\n748 |                       {isUnassigned ? (\n749 |                         <div className=\"inline-flex items-center gap-1 text-[9px] text-amber-400 bg-amber-400/5 border border-amber-400/20 px-1.5 py-0.5 rounded font-bold\">\n750 |                           <AlertTriangle className=\"w-3 h-3 shrink-0\" />\n751 |                           <span>REGISTRY ONLY</span>\n752 |                         </div>\n753 |                       ) : (\n754 |                         <div className=\"inline-flex items-center gap-1 text-[9px] text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.5 rounded font-bold max-w-full truncate\" title={projectName}>\n755 |                           <Layers className=\"w-3 h-3 shrink-0 text-[#00FFC2]\" />\n756 |       