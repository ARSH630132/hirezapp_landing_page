{"ts":"2026-06-27T04:09:28.869Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"fkyvg25r","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/data-tables.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { \n  Search, X, ArrowUpDown, Terminal, Shield, Lock, Activity, \n  Copy, Check, ChevronRight, ChevronLeft, Calendar, User, \n  Hash, ShieldCheck, Cpu, SlidersHorizontal, Info, RefreshCw\n} from \"lucide-react\";\nimport { TableColumn } from \"./types\";\nimport { EmptyState } from \"./empty-state\";\n\nexport function DataTable<T extends { id: string | number }>({ \n  columns, \n  data = [], \n  pageSize = 5,\n  onRowClick,\n  searchPlaceholder = \"Search secure records...\",\n  searchKeys = [],\n  statusField,\n  statusOptions = [],\n  typeField,\n  typeOptions = [],\n  renderDetail,\n  detailTitle = \"Resource Telemetry Ledger\",\n  categoryLabel = \"SECURITY BOUNDARY\"\n}: { \n  columns: TableColumn<T>[]; \n  data: T[]; \n  pageSize?: number;\n  onRowClick?: (row: T) => void;\n  searchPlaceholder?: string;\n  searchKeys?: (keyof T | string)[];\n  statusField?: keyof T | string;\n  statusOptions?: { value: string; label: string }[];\n  typeField?: keyof T | string;\n  typeOptions?: { value: string; label: string }[];\n  renderDetail?: (row: T, onClose: () => void) => React.ReactNode;\n  detailTitle?: string | ((row: T) => string);\n  categoryLabel?: string;\n}) {\n  const [currentPage, setCurrentPage] = useState(1);\n  const [sortKey, setSortKey] = useState<keyof T | string | null>(null);\n  const [sortOrder, setSortOrder] = useState<\"asc\" | \"desc\">(\"asc\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  \n  const [selectedRow, setSelectedRow] = useState<T | null>(null);\n  const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n  const [isCopied, setIsCopied] = useState(false);\n  const [logs, setLogs] = useState<string[]>([]);\n  const [isLogSyncing, setIsLogSyncing] = useState(false);\n  const [focusedRowIndex, setFocusedRowIndex] = useState<number | null>(null);\n\n  const drawerRef = useRef<HTMLDivElement>(null);\n  const tableRowsRef = useRef<(HTMLTableRowElement | null)[]>([]);\n\n  // Focus trap inside the drawer\n  useEffect(() => {\n    if (isDrawerOpen && drawerRef.current) {\n      const focusableElements = drawerRef.current.querySelectorAll(\n        'button, [href], input, select, textarea, [tabindex=\"0\"]'\n      );\n      if (focusableElements.length > 0) {\n        (focusableElements[0] as HTMLElement).focus();\n      }\n    }\n  }, [isDrawerOpen]);\n\n  // Handle global keyboard listeners\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") {\n        if (isDrawerOpen) {\n          setIsDrawerOpen(false);\n        }\n      }\n    };\n    window.addEventListener(\"keydown\", handleKeyDown);\n    return () => window.removeEventListener(\"keydown\", handleKeyDown);\n  }, [isDrawerOpen]);\n\n  // Generate simulated secure telemetry logs when selected row changes\n  useEffect(() => {\n    if (selectedRow) {\n      setIsLogSyncing(true);\n      const rowId = String(selectedRow.id);\n      setLogs([\n        `[${new Date().toLocaleTimeString()}] CONNECT: Sovereign socket requested for target: ${rowId}`,\n        `[${new Date().toLocaleTimeString()}] ATTESTATION: Performing cryptographic binary handshake...`,\n        `[${new Date().toLocaleTimeString()}] SECURITY: AMD SEV-SNP execution partition fully verified.`,\n        `[${new Date().toLocaleTimeString()}] STATUS: Active loop synchronized (99.997% integrity).`\n      ]);\n      \n      const timer = setTimeout(() => {\n        setIsLogSyncing(false);\n      }, 600);\n      return () => clearTimeout(timer);\n    }\n  }, [selectedRow]);\n\n  // Periodic log streamer in drawer\n  useEffect(() => {\n    let interval: NodeJS.Timeout;\n    if (isDrawerOpen && selectedRow && !isLogSyncing) {\n      interval = setInterval(() => {\n        const timestamp = new Date().toLocaleTimeString();\n        const telemetryEvents = [\n          `Attesting isolated kernel memory structures... SECURE`,\n          `Verifying zero-trust socket tunnel bounds... NOMINAL`,\n          `Evaluating sandbox guardrails against ISO-27001 rulesets... COMPLIANT`,\n          `Flushing epoch telemetry streams to secure distributed ledger... SUCCESS`,\n          `eBPF kernel-level hook reporting 100% policy enforcement... APPROVED`\n        ];\n        const randomEvent = telemetryEvents[Math.floor(Math.random() * telemetryEvents.length)];\n        setLogs(prev => [...prev.slice(-6), `[${timestamp}] ${randomEvent}`]);\n      }, 3500);\n    }\n    return () => clearInterval(interval);\n  }, [isDrawerOpen, selectedRow, isLogSyncing]);\n\n  // Reset page when filter constraints change\n  useEffect(() => { \n    setCurrentPage(1); \n    setFocusedRowIndex(null);\n  }, [searchQuery, selectedStatus, selectedType]);\n\n  const handleRowSelect = (row: T) => {\n    setSelectedRow(row);\n    setIsDrawerOpen(true);\n    if (onRowClick) onRowClick(row);\n  };\n\n  const handleSort = (key: keyof T | string, sortable?: boolean) => {\n    if (!sortable) return;\n    if (sortKey === key) {\n      setSortOrder(sortOrder === \"asc\" ? \"desc\" : \"asc\");\n    } else {\n      setSortKey(key);\n      setSortOrder(\"asc\");\n    }\n  };\n\n  const copyToClipboard = (text: string) => {\n    navigator.clipboard.writeText(text);\n    setIsCopied(true);\n    setTimeout(() => setIsCopied(false), 2000);\n  };\n\n  // Safe status options extractor if not provided\n  const inferredStatusOptions = statusField && statusOptions.length === 0\n    ? Array.from(new Set(data.map(row => String(row[statusField as keyof T] || \"\")))).map(s => ({ value: s, label: s }))\n    : statusOptions;\n\n  // Safe type options extractor if not provided\n  const inferredTypeOptions = typeField && typeOptions.length === 0\n    ? Array.from(new Set(data.map(row => String(row[typeField as keyof T] || \"\")))).map(t => ({ value: t, label: t }))\n    : typeOptions;\n\n  // Filtering Logic\n  const filteredData = data.filter((row) => {\n    if (searchQuery.trim() !== \"\" && searchKeys.length > 0) {\n      const match = searchKeys.some((k) => \n        String(row[k as keyof T] || \"\").toLowerCase().includes(searchQuery.toLowerCase())\n      );\n      if (!match) return false;\n    }\n    if (selectedStatus && statusField) {\n      if (String(row[statusField as keyof T] || \"\").toLowerCase() !== selectedStatus.toLowerCase()) return false;\n    }\n    if (selectedType && typeField) {\n      if (String(row[typeField as keyof T] || \"\").toLowerCase() !== selectedType.toLowerCase()) return false;\n    }\n    return true;\n  });\n\n  // Sorting Logic\n  const sortedData = [...filteredData];\n  if (sortKey) {\n    sortedData.sort((a, b) => {\n      const aVal = a[sortKey as keyof T];\n      const bVal = b[sortKey as keyof T];\n      if (aVal === undefined || aVal === null) return 1;\n      if (bVal === undefined || bVal === null) return -1;\n      \n      const comparison = String(aVal).localeCompare(String(bVal), undefined, { numeric: true });\n      return sortOrder === \"asc\" ? comparison : -comparison;\n    });\n  }\n\n  const totalPages = Math.ceil(sortedData.length / pageSize) || 1;\n  const paginatedData = sortedData.slice((currentPage - 1) * pageSize, currentPage * pageSize);\n\n  const startEntry = (currentPage - 1) * pageSize + 1;\n  const endEntry = Math.min(currentPage * pageSize, sortedData.length);\n\n  // Keyboard navigation inside rows\n  const handleTableKeyDown = (e: React.KeyboardEvent, row: T, index: number) => {\n    if (e.key === \"Enter\" || e.key === \" \") {\n      e.preventDefault();\n      handleRowSelect(row);\n    } else if (e.key === \"ArrowDown\") {\n      e.preventDefault();\n      const nextIndex = Math.min(index + 1, paginatedData.length - 1);\n      setFocusedRowIndex(nextIndex);\n      tableRowsRef.current[nextIndex]?.focus();\n    } else if (e.key === \"ArrowUp\") {\n      e.preventDefault();\n      const prevIndex = Math.max(index - 1, 0);\n      setFocusedRowIndex(prevIndex);\n      tableRowsRef.current[prevIndex]?.focus();\n    }\n  };\n\n  // Helper to resolve nested fields for details view\n  const getDisplayValue = (val: any): string => {\n    if (typeof val === \"object\" && val !== null) {\n      if (\"name\" in val) return String(val.name);\n      return JSON.stringify(val);\n    }\n    return String(val ?? \"N/A\");\n  };\n\n  const getStatusDotColor = (status: string) => {\n    const s = status.toLowerCase();\n    if ([\"active\", \"healthy\", \"compliant\", \"verified\", \"paid\", \"resolved\", \"settled\", \"on track\"].includes(s)) {\n      return \"bg-[#00FFC2] shadow-[0_0_8px_rgba(0,255,194,0.4)]\";\n    }\n    if ([\"warning\", \"evaluating\", \"in_progress\", \"processing\", \"pending\", \"open\"].includes(s)) {\n      return \"bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.4)]\";\n    }\n    if ([\"critical\", \"decoupled\", \"unpaid\", \"overdue\", \"error\", \"offline\", \"suspended\", \"rejected\"].includes(s)) {\n      return \"bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]\";\n    }\n    return \"bg-white/40\";\n  };\n\n  return (\n    <div className=\"space-y-4\">\n      {/* 1. FILTER CONTROLS BAR */}\n      <div className=\"flex flex-col xl:flex-row xl:items-center justify-between gap-4 p-4 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm\">\n        <div className=\"relative flex-grow max-w-xl\">\n          <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n          <input \n            type=\"text\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            placeholder={searchPlaceholder}\n            className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n          />\n          {searchQuery && (\n            <button \n              onClick={() => setSearchQuery(\"\")} \n              className=\"absolute right-3 top-2.5 text-white/40 hover:text-white\"\n            >\n              <X className=\"w-4 h-4\" />\n            </button>\n          )}\n        </div>\n\n        <div className=\"flex flex-wrap items-center gap-3\">\n          {/* Status Filter */}\n          {statusField && inferredStatusOptions.length > 0 && (\n            <div className=\"relative\">\n              <select\n                value={selectedStatus}\n                onChange={(e) => setSelectedStatus(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n              >\n                <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL STATUSES</option>\n                {inferredStatusOptions.map(opt => (\n                  <option key={opt.value} value={opt.value} className=\"bg-[#0c0c0c] text-white\">\n                    {opt.label.toUpperCase()}\n                  </option>\n                ))}\n              </select>\n              <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {/* Type Filter */}\n          {typeField && inferredTypeOptions.length > 0 && (\n            <div className=\"relative\">\n              <select\n                value={selectedType}\n                onChange={(e) => setSelectedType(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n              >\n                <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL CLASSIFICATIONS</option>\n                {inferredTypeOptions.map(opt => (\n                  <option key={opt.value} value={opt.value} className=\"bg-[#0c0c0c] text-white\">\n                    {opt.label.toUpperCase()}\n                  </option>\n                ))}\n              </select>\n              <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {/* Active Constraints Tag Clear */}\n          {(selectedStatus || selectedType || searchQuery) && (\n            <button\n              onClick={() => {\n                setSelectedStatus(\"\");\n                setSelectedType(\"\");\n                setSearchQuery(\"\");\n              }}\n              className=\"h-9 px-3 rounded-lg border border-red-500/10 hover:border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-red-400 font-mono text-[10.5px] uppercase tracking-wider transition-all flex items-center gap-1.5 cursor-pointer\"\n            >\n              <span>Reset Filters</span>\n              <X className=\"w-3 h-3\" />\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* 2. TABLE AND CARDS FALLBACK AREA */}\n      {paginatedData.length === 0 ? (\n        <EmptyState \n          title=\"No Matching Records\" \n          description=\"Your security filter did not yield any active ledger entries. Adjust query or filters.\"\n          actionLabel=\"Clear Filters\"\n          onAction={() => {\n            setSearchQuery(\"\");\n            setSelectedStatus(\"\");\n            setSelectedType(\"\");\n          }}\n        />\n      ) : (\n        <div className=\"space-y-4\">\n          {/* A. PREMIUM DESKTOP DATA TABLE */}\n          <div className=\"hidden md:block overflow-hidden rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm\">\n            <table className=\"w-full text-left border-collapse\" role=\"grid\">\n              <thead>\n                <tr className=\"border-b border-white/5 bg-white/[0.01] select-none\" role=\"row\">\n                  {columns.map((col, idx) => (\n                    <th \n                      key={String(col.key)} \n                      role=\"columnheader\"\n                      aria-sort={sortKey === col.key ? (sortOrder === \"asc\" ? \"ascending\" : \"descending\") : undefined}\n                      onClick={() => handleSort(col.key, col.sortable)}\n                      className={`p-4 text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase ${col.sortable ? \"cursor-pointer hover:text-white transition-colors\" : \"\"}`}\n                    >\n                      <div className=\"flex items-center gap-1.5\">\n                        <span>{col.header}</span>\n                        {col.sortable && (\n                          <ArrowUpDown className={`w-3.5 h-3.5 transition-opacity ${sortKey === col.key ? \"text-white opacity-100\" : \"opacity-30 hover:opacity-75\"}`} />\n                        )}\n                      </div>\n                    </th>\n                  ))}\n                  <th className=\"p-4 text-right text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase w-10\">\n                    Ledger\n                  </th>\n                </tr>\n              </thead>\n              <tbody>\n                {paginatedData.map((row, rIdx) => {\n                  const isFocused = focusedRowIndex === rIdx;\n                  return (\n                    <tr\n                      key={row.id}\n                      role=\"row\"\n                      tabIndex={0}\n                      ref={(el) => { tableRowsRef.current[rIdx] = el; }}\n                      onClick={() => handleRowSelect(row)}\n                      onKeyDown={(e) => handleTableKeyDown(e, row, rIdx)}\n                      className={`border-b border-white/[0.02] hover:bg-white/[0.02] focus:bg-white/[0.03] outline-none transition-all duration-200 cursor-pointer ${\n                        isFocused ? \"bg-white/[0.02] border-l-2 border-[#009DFF]\" : \"\"\n                      }`}\n                    >\n                      {columns.map((col) => (\n                        <td key={String(col.key)} role=\"gridcell\" className=\"p-4 text-[12px] font-mono text-white/80\">\n                          {col.render ? (\n                            col.render(row)\n                          ) : (\n                            <span className=\"truncate max-w-[200px] block\">\n                              {getDisplayValue(row[col.key as keyof T])}\n                            </span>\n                          )}\n                        </td>\n                      ))}\n                      <td className=\"p-4 text-right\">\n                        <ChevronRight className=\"w-4 h-4 text-white/20 ml-auto\" />\n                      </td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </div>\n\n          {/* B. PREMIUM MOBILE RESPONSIVE CARDS FALLBACK */}\n          <div className=\"grid grid-cols-1 gap-4 md:hidden\">\n            {paginatedData.map((row) => (\n              <div \n                key={row.id}\n                onClick={() => handleRowSelect(row)}\n                className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 active:bg-white/[0.02] active:border-white/10 transition-all cursor-pointer space-y-3.5\"\n              >\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-[10px] font-mono font-bold text-white/40\">\n                    ID: {String(row.id).toUpperCase()}\n                  </span>\n                  \n                  {/* Status Indicator inside mobile cards */}\n                  {statusField && row[statusField as keyof T] && (\n                    <div className=\"flex items-center gap-1.5\">\n                      <span className={`w-1.5 h-1.5 rounded-full ${getStatusDotColor(String(row[statusField as keyof T]))}`} />\n                      <span className=\"text-[10px] font-mono font-semibold text-white/70 uppercase\">\n                        {String(row[statusField as keyof T])}\n                      </span>\n                    </div>\n                  )}\n                </div>\n\n                <div className=\"space-y-2\">\n                  {columns.map((col) => {\n                    // Avoid duplicating status or ID fields in the cards\n                    if (col.key === \"id\" || col.key === statusField) return null;\n                    return (\n                      <div key={String(col.key)} className=\"flex items-start justify-between gap-4\">\n                        <span className=\"text-[10px] font-bold font-mono text-white/30 uppercase shrink-0\">\n                          {col.header}:\n                        </span>\n                        <div className=\"text-[11.5px] font-mono text-white/80 text-right\">\n                          {col.render ? (\n                            col.render(row)\n                          ) : (\n                            <span>{getDisplayValue(row[col.key as keyof T])}</span>\n                          )}\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n\n                <div className=\"pt-2 border-t border-white/5 flex items-center justify-between text-[10px] font-mono text-[#009DFF]\">\n                  <span>EXPAND DETAILED AUDIT</span>\n                  <ChevronRight className=\"w-3.5 h-3.5\" />\n                </div>\n              </div>\n            ))}\n          </div>\n\n          {/* C. PREMIUM GRAPHIC PAGINATION BAR */}\n          <div className=\"flex flex-col sm:flex-row items-center justify-between gap-3 p-4 rounded-xl border border-white/5 bg-[#050505]/10 select-none\">\n            <span className=\"text-[11px] font-mono text-white/40\">\n              Showing <span className=\"text-white/70 font-semibold\">{startEntry}</span> to <span className=\"text-white/70 font-semibold\">{endEntry}</span> of <span className=\"text-white/70 font-semibold\">{sortedData.length}</span> secure nodes\n            </span>\n\n            <div className=\"flex items-center gap-2\">\n              <button\n                onClick={() => setCurrentPage(prev => Math.max(prev - 1, 1))}\n                disabled={currentPage === 1}\n                className=\"h-8 w-8 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] disabled:opacity-30 disabled:hover:bg-transparent flex items-center justify-center text-white transition-all cursor-pointer\"\n                aria-label=\"Previous page\"\n              >\n                <ChevronLeft className=\"w-4 h-4\" />\n              </button>\n\n              {Array.from({ length: totalPages }).map((_, i) => (\n                <button\n                  key={i}\n                  onClick={() => setCurrentPage(i + 1)}\n                  className={`h-8 min-w-[32px] px-2 rounded-lg border font-mono text-[11px] transition-all cursor-pointer ${\n                    currentPage === i + 1 \n                      ? \"border-[#009DFF]/30 bg-[#009DFF]/10 text-[#009DFF] font-bold\" \n                      : \"border-white/5 bg-white/[0.01] text-white/60 hover:text-white hover:bg-white/[0.03]\"\n                  }`}\n                >\n                  {i + 1}\n                </button>\n              ))}\n\n              <button\n                onClick={() => setCurrentPage(prev => Math.min(prev + 1, totalPages))}\n                disabled={currentPage === totalPages}\n                className=\"h-8 w-8 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] disabled:opacity-30 disabled:hover:bg-transparent flex items-center justify-center text-white transition-all cursor-pointer\"\n                aria-label=\"Next page\"\n              >\n                <ChevronRight className=\"w-4 h-4\" />\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* 3. PREMIUM SIDE DETAIL-DRAWER */}\n      {isDrawerOpen && selectedRow && (\n        <div className=\"fixed inset-0 z-50 flex justify-end select-none\">\n          {/* Backdrop */}\n          <div \n            className=\"absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity\"\n            onClick={() => setIsDrawerOpen(false)}\n          />\n\n          {/* Drawer Container */}\n          <div \n            ref={drawerRef}\n            className=\"relative w-full sm:max-w-md md:max-w-lg h-full bg-[#070707]/95 border-l border-white/10 backdrop-blur-xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex flex-col z-10 animate-in slide-in-from-right duration-300 outline-none\"\n            role=\"dialog\"\n            aria-modal=\"true\"\n            aria-label=\"Detailed cryptographic ledger\"\n            tabIndex={-1}\n          >\n            {/* Drawer Header */}\n            <div className=\"p-5 border-b border-white/5 flex items-start justify-between gap-4\">\n              <div className=\"space-y-1\">\n                <span className=\"text-[9.5px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded tracking-widest uppercase\">\n                  {categoryLabel}\n                </span>\n                <h3 className=\"text-[14px] font-bold font-mono text-white tracking-wider uppercase mt-1\">\n                  {typeof detailTitle === \"function\" ? detailTitle(selectedRow) : detailTitle}\n                </h3>\n                <div className=\"flex items-center gap-1.5\">\n                  <span className=\"text-[10px] font-mono text-white/40\">ID PATH:</span>\n                  <span className=\"text-[10.5px] font-mono font-bold text-white/85 flex items-center gap-1 select-all\">\n                    {String(selectedRow.id).toUpperCase()}\n                    <button \n                      onClick={() => copyToClipboard(String(selectedRow.id))}\n                      className=\"text-white/40 hover:text-white transition-colors\"\n                      title=\"Copy ID to Clipboard\"\n                    >\n                      {isCopied ? <Check className=\"w-3 h-3 text-[#00FFC2]\" /> : <Copy className=\"w-3 h-3\" />}\n                    </button>\n                  </span>\n                </div>\n              </div>\n\n              <button\n                onClick={() => setIsDrawerOpen(false)}\n                className=\"p-1.5 rounded-lg border border-white/5 bg-white/[0.01] text-white/50 hover:text-white hover:bg-white/[0.05] transition-all cursor-pointer\"\n                aria-label=\"Close drawer\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            {/* Scrollable Content */}\n            <div className=\"flex-grow overflow-y-auto p-5 space-y-6\">\n              {renderDetail ? (\n                // Custom detail rendering bypass\n                renderDetail(selectedRow, () => setIsDrawerOpen(false))\n              ) : (\n                // Default custom key-value details display\n                <div className=\"space-y-5\">\n                  {/* A. Ledger parameters */}\n                  <div className=\"space-y-2.5\">\n                    <h4 className=\"text-[10px] font-bold font-mono tracking-widest text-white/40 uppercase\">\n                      CRYPTOGRAPHIC ATTRIBUTES\n                    </h4>\n                    \n                    <div className=\"grid grid-cols-1 gap-2.5\">\n                      {Object.entries(selectedRow)\n                        .filter(([k]) => k !== \"id\" && k !== \"logs\")\n                        .map(([key, value]) => (\n                          <div \n                            key={key} \n                            className=\"p-3 rounded-lg border border-white/5 bg-[#020202]/40 flex flex-col gap-1 font-mono text-[11.5px]\"\n                          >\n                            <span className=\"text-white/30 text-[9.5px] uppercase font-semibold\">\n                              {key.replace(/([A-Z])/g, \" $1\").toUpperCase()}\n                            </span>\n                            <div className=\"flex items-center justify-between gap-4\">\n                              <span className=\"text-white/95 font-bold truncate\">\n                                {getDisplayValue(value)}\n                              </span>\n                              \n                              {key.toLowerCase().includes(\"status\") && (\n                                <span className={`w-1.5 h-1.5 rounded-full ${getStatusDotColor(getDisplayValue(value))}`} />\n                              )}\n                            </div>\n                          </div>\n                        ))}\n                    </div>\n                  </div>\n                </div>\n              )}\n\n              {/* B. Real-time Live Telemetry Logs Simulator Pane */}\n              <div className=\"space-y-3 pt-2\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n                    <h4 className=\"text-[10px] font-bold font-mono tracking-widest text-white/45 uppercase\">\n                      SECURE ATTESTATION FLUX\n                    </h4>\n                  </div>\n                  {isLogSyncing ? (\n                    <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin\" />\n                  ) : (\n                    <div className=\"flex items-center gap-1 text-[9px] font-mono text-green-400\">\n                      <span className=\"w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse\" />\n                      <span>LIVE TELEMETRY STREAM</span>\n                    </div>\n                  )}\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#020202] text-[10.5px] font-mono text-white/75 space-y-2 h-[210px] overflow-y-auto shadow-inner border-t-white/10 select-text\">\n                  {logs.map((log, idx) => (\n                    <div key={idx} className=\"leading-relaxed border-b border-white/[0.01] pb-1 font-mono select-text\">\n                      <span className=\"text-[#009DFF]/80\">&gt;</span> {log}\n                    </div>\n                  ))}\n                  <div className=\"text-[9.5px] text-white/30 pt-1 flex items-center gap-1\">\n                    <Shield className=\"w-3 h-3 text-[#00FFC2]\" />\n                    <span>Cryptographic attestations continuous</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            {/* Drawer Footer */}\n            <div className=\"p-5 border-t border-white/5 bg-black/[0.15] space-y-3\">\n              <div className=\"flex items-center gap-2 text-[10.5px] font-mono text-white/40\">\n                <Lock className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n                <span>Isolated Enclave Memory Lock Active</span>\n              </div>\n              <div className=\"grid grid-cols-2 gap-3\">\n                <button\n                  onClick={() => {\n                    const hashValue = `0xSHA256_${selectedRow ? String(selectedRow.id).toUpperCase() : \"\"}_${new Date().getFullYear()}`;\n                    copyToClipboard(hashValue);\n                  }}\n                  className=\"h-9 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.03] text-[11px] font-mono font-bold uppercase tracking-wider text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n                >\n                  <Copy className=\"w-3.5 h-3.5\" />\n                  <span>Copy Seal Hash</span>\n                </button>\n                <button\n                  onClick={() => setIsDrawerOpen(false)}\n                  className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n                >\n                  <span>Close Ledger</span>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
