{"ts":"2026-06-27T04:10:04.333Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"tkf34ca2","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/data-tables.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { Search, X, ArrowUpDown, Terminal, Shield, Lock, ChevronRight, ChevronLeft, Copy, Check, SlidersHorizontal, RefreshCw } from \"lucide-react\";\nimport { TableColumn } from \"./types\";\nimport { EmptyState } from \"./empty-state\";\n\nexport function DataTable<T extends { id: string | number }>({ \n  columns, data = [], pageSize = 5, onRowClick, searchPlaceholder = \"Search secure records...\",\n  searchKeys = [], statusField, statusOptions = [], typeField, typeOptions = [],\n  renderDetail, detailTitle = \"Resource Telemetry Ledger\", categoryLabel = \"SECURITY BOUNDARY\"\n}: { \n  columns: TableColumn<T>[]; data: T[]; pageSize?: number; onRowClick?: (row: T) => void;\n  searchPlaceholder?: string; searchKeys?: (keyof T | string)[]; statusField?: keyof T | string;\n  statusOptions?: { value: string; label: string }[]; typeField?: keyof T | string;\n  typeOptions?: { value: string; label: string }[]; renderDetail?: (row: T, onClose: () => void) => React.ReactNode;\n  detailTitle?: string | ((row: T) => string); categoryLabel?: string;\n}) {\n  const [currentPage, setCurrentPage] = useState(1);\n  const [sortKey, setSortKey] = useState<keyof T | string | null>(null);\n  const [sortOrder, setSortOrder] = useState<\"asc\" | \"desc\">(\"asc\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  \n  const [selectedRow, setSelectedRow] = useState<T | null>(null);\n  const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n  const [isCopied, setIsCopied] = useState(false);\n  const [logs, setLogs] = useState<string[]>([]);\n  const [isLogSyncing, setIsLogSyncing] = useState(false);\n  const [focusedIndex, setFocusedIndex] = useState<number | null>(null);\n\n  const drawerRef = useRef<HTMLDivElement>(null);\n  const rowRefs = useRef<(HTMLTableRowElement | null)[]>([]);\n\n  useEffect(() => {\n    if (isDrawerOpen && drawerRef.current) {\n      const el = drawerRef.current.querySelector('button, [tabindex=\"0\"]') as HTMLElement;\n      if (el) el.focus();\n    }\n  }, [isDrawerOpen]);\n\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => { if (e.key === \"Escape\" && isDrawerOpen) setIsDrawerOpen(false); };\n    window.addEventListener(\"keydown\", handleKeyDown);\n    return () => window.removeEventListener(\"keydown\", handleKeyDown);\n  }, [isDrawerOpen]);\n\n  useEffect(() => {\n    if (selectedRow) {\n      setIsLogSyncing(true);\n      setLogs([\n        `[${new Date().toLocaleTimeString()}] CONNECT: Handshake requested for node: ${selectedRow.id}`,\n        `[${new Date().toLocaleTimeString()}] SECURE: TLS 1.3 socket active. Verifying memory partition...`,\n        `[${new Date().toLocaleTimeString()}] ATTEST: AMD SEV-SNP cryptographic seal validated (100% compliant).`\n      ]);\n      const timer = setTimeout(() => setIsLogSyncing(false), 500);\n      return () => clearTimeout(timer);\n    }\n  }, [selectedRow]);\n\n  useEffect(() => {\n    let interval: NodeJS.Timeout;\n    if (isDrawerOpen && selectedRow && !isLogSyncing) {\n      interval = setInterval(() => {\n        const events = [\n          \"Attesting isolated container memory boundaries... SECURE\",\n          \"Syncing epoch log ledger blocks with central enclave... ACTIVE\",\n          \"Applying dynamic guardrail checks against regulatory ruleset... COMPLIANT\",\n          \"Enforcing Zero-Trust execution permissions... SUCCESS\"\n        ];\n        const evt = events[Math.floor(Math.random() * events.length)];\n        setLogs(prev => [...prev.slice(-5), `[${new Date().toLocaleTimeString()}] ${evt}`]);\n      }, 4000);\n    }\n    return () => clearInterval(interval);\n  }, [isDrawerOpen, selectedRow, isLogSyncing]);\n\n  useEffect(() => { setCurrentPage(1); setFocusedIndex(null); }, [searchQuery, selectedStatus, selectedType]);\n\n  const handleRowSelect = (row: T) => {\n    setSelectedRow(row);\n    setIsDrawerOpen(true);\n    if (onRowClick) onRowClick(row);\n  };\n\n  const handleSort = (key: keyof T | string, sortable?: boolean) => {\n    if (!sortable) return;\n    if (sortKey === key) {\n      setSortOrder(sortOrder === \"asc\" ? \"desc\" : \"asc\");\n    } else {\n      setSortKey(key);\n      setSortOrder(\"asc\");\n    }\n  };\n\n  const copyToClipboard = (text: string) => {\n    navigator.clipboard.writeText(text);\n    setIsCopied(true);\n    setTimeout(() => setIsCopied(false), 1500);\n  };\n\n  const infStatusOptions = statusField && statusOptions.length === 0\n    ? Array.from(new Set(data.map(row => String(row[statusField as keyof T] || \"\")))).map(s => ({ value: s, label: s }))\n    : statusOptions;\n\n  const infTypeOptions = typeField && typeOptions.length === 0\n    ? Array.from(new Set(data.map(row => String(row[typeField as keyof T] || \"\")))).map(t => ({ value: t, label: t }))\n    : typeOptions;\n\n  const filteredData = data.filter((row) => {\n    if (searchQuery.trim() !== \"\" && searchKeys.length > 0) {\n      const match = searchKeys.some((k) => String(row[k as keyof T] || \"\").toLowerCase().includes(searchQuery.toLowerCase()));\n      if (!match) return false;\n    }\n    if (selectedStatus && statusField && String(row[statusField as keyof T] || \"\").toLowerCase() !== selectedStatus.toLowerCase()) return false;\n    if (selectedType && typeField && String(row[typeField as keyof T] || \"\").toLowerCase() !== selectedType.toLowerCase()) return false;\n    return true;\n  });\n\n  const sortedData = [...filteredData];\n  if (sortKey) {\n    sortedData.sort((a, b) => {\n      const aVal = String(a[sortKey as keyof T] || \"\");\n      const bVal = String(b[sortKey as keyof T] || \"\");\n      return sortOrder === \"asc\" ? aVal.localeCompare(bVal, undefined, { numeric: true }) : bVal.localeCompare(aVal, undefined, { numeric: true });\n    });\n  }\n\n  const totalPages = Math.ceil(sortedData.length / pageSize) || 1;\n  const paginatedData = sortedData.slice((currentPage - 1) * pageSize, currentPage * pageSize);\n\n  const getStatusDotColor = (status: string) => {\n    const s = status.toLowerCase();\n    if ([\"active\", \"healthy\", \"compliant\", \"verified\", \"paid\", \"resolved\", \"settled\", \"on track\", \"stable\"].includes(s)) {\n      return \"bg-[#00FFC2] shadow-[0_0_8px_rgba(0,255,194,0.4)]\";\n    }\n    if ([\"warning\", \"evaluating\", \"in_progress\", \"processing\", \"pending\", \"open\"].includes(s)) {\n      return \"bg-amber-400 shadow-[0_0_8px_rgba(251,191,36,0.4)]\";\n    }\n    return \"bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.4)]\";\n  };\n\n  return (\n    <div className=\"space-y-4\">\n      {/* 1. FILTERS BAR */}\n      <div className=\"flex flex-col xl:flex-row xl:items-center justify-between gap-4 p-4 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm\">\n        <div className=\"relative flex-grow max-w-xl\">\n          <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n          <input \n            type=\"text\" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} placeholder={searchPlaceholder}\n            className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n          />\n          {searchQuery && (\n            <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-3 top-2.5 text-white/40 hover:text-white\">\n              <X className=\"w-4 h-4\" />\n            </button>\n          )}\n        </div>\n\n        <div className=\"flex flex-wrap items-center gap-3\">\n          {statusField && infStatusOptions.length > 0 && (\n            <div className=\"relative\">\n              <select\n                value={selectedStatus} onChange={(e) => setSelectedStatus(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n              >\n                <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL STATUSES</option>\n                {infStatusOptions.map(opt => <option key={opt.value} value={opt.value} className=\"bg-[#0c0c0c] text-white\">{opt.label.toUpperCase()}</option>)}\n              </select>\n              <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {typeField && infTypeOptions.length > 0 && (\n            <div className=\"relative\">\n              <select\n                value={selectedType} onChange={(e) => setSelectedType(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n              >\n                <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL CATEGORIES</option>\n                {infTypeOptions.map(opt => <option key={opt.value} value={opt.value} className=\"bg-[#0c0c0c] text-white\">{opt.label.toUpperCase()}</option>)}\n              </select>\n              <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {(selectedStatus || selectedType || searchQuery) && (\n            <button\n              onClick={() => { setSelectedStatus(\"\"); setSelectedType(\"\"); setSearchQuery(\"\"); }}\n              className=\"h-9 px-3 rounded-lg border border-red-500/10 hover:border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-red-400 font-mono text-[10.5px] uppercase tracking-wider transition-all flex items-center gap-1.5 cursor-pointer\"\n            >\n              <span>Reset</span>\n              <X className=\"w-3 h-3\" />\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* 2. TABLE AREA */}\n      {paginatedData.length === 0 ? (\n        <EmptyState \n          title=\"No Matching Records\" \n          description=\"Your security filter did not yield any active ledger entries. Adjust query or filters.\"\n          actionLabel=\"Clear Filters\"\n          onAction={() => { setSearchQuery(\"\"); setSelectedStatus(\"\"); setSelectedType(\"\"); }}\n        />\n      ) : (\n        <div className=\"space-y-4\">\n          <div className=\"hidden md:block overflow-hidden rounded-xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm\">\n            <table className=\"w-full text-left border-collapse\" role=\"grid\">\n              <thead>\n                <tr className=\"border-b border-white/5 bg-white/[0.01]\" role=\"row\">\n                  {columns.map((col) => (\n                    <th \n                      key={String(col.key)} role=\"columnheader\"\n                      onClick={() => handleSort(col.key, col.sortable)}\n                      className={`p-4 text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase ${col.sortable ? \"cursor-pointer hover:text-white transition-colors\" : \"\"}`}\n                    >\n                      <div className=\"flex items-center gap-1.5\">\n                        <span>{col.header}</span>\n                        {col.sortable && <ArrowUpDown className={`w-3.5 h-3.5 ${sortKey === col.key ? \"text-white opacity-100\" : \"opacity-30\"}`} />}\n                      </div>\n                    </th>\n                  ))}\n                  <th className=\"p-4 text-right text-[10.5px] font-bold font-mono text-white/40 tracking-wider uppercase w-10\">Ledger</th>\n                </tr>\n              </thead>\n              <tbody>\n                {paginatedData.map((row, rIdx) => {\n                  const isFocused = focusedIndex === rIdx;\n                  return (\n                    <tr\n                      key={row.id} role=\"row\" tabIndex={0}\n                      ref={(el) => { rowRefs.current[rIdx] = el; }}\n                      onClick={() => handleRowSelect(row)}\n                      onKeyDown={(e) => {\n                        if (e.key === \"Enter\" || e.key === \" \") { e.preventDefault(); handleRowSelect(row); }\n                        else if (e.key === \"ArrowDown\") { e.preventDefault(); const next = Math.min(rIdx + 1, paginatedData.length - 1); setFocusedIndex(next); rowRefs.current[next]?.focus(); }\n                        else if (e.key === \"ArrowUp\") { e.preventDefault(); const prev = Math.max(rIdx - 1, 0); setFocusedIndex(prev); rowRefs.current[prev]?.focus(); }\n                      }}\n                      className={`border-b border-white/[0.02] hover:bg-white/[0.02] focus:bg-white/[0.03] outline-none transition-all duration-200 cursor-pointer ${isFocused ? \"bg-white/[0.02] border-l-2 border-[#009DFF]\" : \"\"}`}\n                    >\n                      {columns.map((col) => (\n                        <td key={String(col.key)} role=\"gridcell\" className=\"p-4 text-[12px] font-mono text-white/80\">\n                          {col.render ? col.render(row) : <span className=\"truncate max-w-[200px] block\">{String(row[col.key as keyof T] ?? \"N/A\")}</span>}\n                        </td>\n                      ))}\n                      <td className=\"p-4 text-right\"><ChevronRight className=\"w-4 h-4 text-white/20 ml-auto\" /></td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </div>\n\n          {/* MOBILE CARDS FALLBACK */}\n          <div className=\"grid grid-cols-1 gap-4 md:hidden\">\n            {paginatedData.map((row) => (\n              <div \n                key={row.id} onClick={() => handleRowSelect(row)}\n                className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 active:bg-white/[0.02] active:border-white/10 transition-all cursor-pointer space-y-3\"\n              >\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-[10px] font-mono font-bold text-white/40\">ID: {String(row.id).toUpperCase()}</span>\n                  {statusField && row[statusField as keyof T] && (\n                    <div className=\"flex items-center gap-1.5\">\n                      <span className={`w-1.5 h-1.5 rounded-full ${getStatusDotColor(String(row[statusField as keyof T]))}`} />\n                      <span className=\"text-[10px] font-mono font-semibold text-white/70 uppercase\">{String(row[statusField as keyof T])}</span>\n                    </div>\n                  )}\n                </div>\n                <div className=\"space-y-2\">\n                  {columns.map((col) => {\n                    if (col.key === \"id\" || col.key === statusField) return null;\n                    return (\n                      <div key={String(col.key)} className=\"flex items-start justify-between gap-4\">\n                        <span className=\"text-[10px] font-bold font-mono text-white/30 uppercase shrink-0\">{col.header}:</span>\n                        <div className=\"text-[11.5px] font-mono text-white/80 text-right\">\n                          {col.render ? col.render(row) : <span>{String(row[col.key as keyof T] ?? \"N/A\")}</span>}\n                        </div>\n                      </div>\n                    );\n                  })}\n                </div>\n                <div className=\"pt-2 border-t border-white/5 flex items-center justify-between text-[10px] font-mono text-[#009DFF]\">\n                  <span>AUDIT TELEMETRY</span>\n                  <ChevronRight className=\"w-3.5 h-3.5\" />\n                </div>\n              </div>\n            ))}\n          </div>\n\n          {/* PAGINATION BAR */}\n          <div className=\"flex flex-col sm:flex-row items-center justify-between gap-3 p-4 rounded-xl border border-white/5 bg-[#050505]/10\">\n            <span className=\"text-[11px] font-mono text-white/40\">\n              Showing <span className=\"text-white/70 font-semibold\">{(currentPage - 1) * pageSize + 1}</span> to <span className=\"text-white/70 font-semibold\">{Math.min(currentPage * pageSize, sortedData.length)}</span> of <span className=\"text-white/70 font-semibold\">{sortedData.length}</span> nodes\n            </span>\n            <div className=\"flex items-center gap-1.5\">\n              <button\n                onClick={() => setCurrentPage(prev => Math.max(prev - 1, 1))} disabled={currentPage === 1}\n                className=\"h-8 w-8 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] disabled:opacity-30 disabled:hover:bg-transparent flex items-center justify-center text-white transition-all cursor-pointer\"\n              >\n                <ChevronLeft className=\"w-4 h-4\" />\n              </button>\n              {Array.from({ length: totalPages }).map((_, i) => (\n                <button\n                  key={i} onClick={() => setCurrentPage(i + 1)}\n                  className={`h-8 min-w-[32px] px-2 rounded-lg border font-mono text-[11px] transition-all cursor-pointer ${currentPage === i + 1 ? \"border-[#009DFF]/30 bg-[#009DFF]/10 text-[#009DFF] font-bold\" : \"border-white/5 bg-white/[0.01] text-white/60 hover:text-white\"}`}\n                >\n                  {i + 1}\n                </button>\n              ))}\n              <button\n                onClick={() => setCurrentPage(prev => Math.min(prev + 1, totalPages))} disabled={currentPage === totalPages}\n                className=\"h-8 w-8 rounded-lg border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] disabled:opacity-30 disabled:hover:bg-transparent flex items-center justify-center text-white transition-all cursor-pointer\"\n              >\n                <ChevronRight className=\"w-4 h-4\" />\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* 3. PREMIUM SIDE DETAIL-DRAWER */}\n      {isDrawerOpen && selectedRow && (\n        <div className=\"fixed inset-0 z-50 flex justify-end\">\n          <div className=\"absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity animate-fade-in\" onClick={() => setIsDrawerOpen(false)} />\n          <div \n            ref={drawerRef} tabIndex={-1} role=\"dialog\" aria-modal=\"true\"\n            className=\"relative w-full sm:max-w-md md:max-w-lg h-full bg-[#070707]/95 border-l border-white/10 backdrop-blur-xl shadow-[0_0_50px_rgba(0,0,0,0.8)] flex flex-col z-10 animate-in slide-in-from-right duration-300 outline-none\"\n          >\n            {/* Header */}\n            <div className=\"p-5 border-b border-white/5 flex items-start justify-between gap-4\">\n              <div className=\"space-y-1\">\n                <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded tracking-widest uppercase\">{categoryLabel}</span>\n                <h3 className=\"text-[13px] font-bold font-mono text-white tracking-wider uppercase mt-1\">\n                  {typeof detailTitle === \"function\" ? detailTitle(selectedRow) : detailTitle}\n                </h3>\n                <div className=\"flex items-center gap-1.5 font-mono text-[10.5px]\">\n                  <span className=\"text-white/45\">SECURE_ID:</span>\n                  <span className=\"text-white font-bold tracking-wider select-all flex items-center gap-1\">\n                    {String(selectedRow.id).toUpperCase()}\n                    <button onClick={() => copyToClipboard(String(selectedRow.id))} className=\"text-white/40 hover:text-white transition-colors\">\n                      {isCopied ? <Check className=\"w-3.5 h-3.5 text-[#00FFC2]\" /> : <Copy className=\"w-3.5 h-3.5\" />}\n                    </button>\n                  </span>\n                </div>\n              </div>\n              <button onClick={() => setIsDrawerOpen(false)} className=\"p-1.5 rounded-lg border border-white/5 bg-white/[0.01] text-white/50 hover:text-white hover:bg-white/[0.05] transition-all cursor-pointer\">\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            {/* Scrollable Attributes Content */}\n            <div className=\"flex-grow overflow-y-auto p-5 space-y-6\">\n              {renderDetail ? renderDetail(selectedRow, () => setIsDrawerOpen(false)) : (\n                <div className=\"space-y-2.5\">\n                  <h4 className=\"text-[10px] font-bold font-mono tracking-widest text-white/40 uppercase\">ENCLAVE LEDGER PARAMETERS</h4>\n                  <div className=\"grid grid-cols-1 gap-2.5\">\n                    {Object.entries(selectedRow)\n                      .filter(([k]) => k !== \"id\" && k !== \"logs\")\n                      .map(([key, val]) => (\n                        <div key={key} className=\"p-3 rounded-lg border border-white/5 bg-[#020202]/40 flex flex-col gap-1 font-mono text-[11.5px]\">\n                          <span className=\"text-white/30 text-[9px] uppercase font-semibold\">{key.replace(/([A-Z])/g, \" $1\").toUpperCase()}</span>\n                          <div className=\"flex items-center justify-between gap-4\">\n                            <span className=\"text-white font-bold truncate\">{typeof val === \"object\" && val !== null ? (\"name\" in val ? String(val.name) : JSON.stringify(val)) : String(val ?? \"N/A\")}</span>\n                            {key.toLowerCase().includes(\"status\") && <span className={`w-1.5 h-1.5 rounded-full ${getStatusDotColor(String(val))}`} />}\n                          </div>\n                        </div>\n                      ))}\n                  </div>\n                </div>\n              )}\n\n              {/* Secure Attestation Stream terminal */}\n              <div className=\"space-y-3 pt-2\">\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-1.5 font-mono text-[10px] text-white/40 uppercase font-semibold\">\n                    <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n                    <span>SECURE ATTESTATION FLUX</span>\n                  </div>\n                  {isLogSyncing ? <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin\" /> : (\n                    <div className=\"flex items-center gap-1 text-[9px] font-mono text-green-400\">\n                      <span className=\"w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse\" />\n                      <span>TELEMETRY STREAM LIVE</span>\n                    </div>\n                  )}\n                </div>\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#020202] text-[10.5px] font-mono text-white/75 space-y-2 h-[210px] overflow-y-auto select-text\">\n                  {logs.map((log, idx) => (\n                    <div key={idx} className=\"leading-relaxed border-b border-white/[0.01] pb-1 font-mono\">\n                      <span className=\"text-[#009DFF]/80\">&gt;</span> {log}\n                    </div>\n                  ))}\n                  <div className=\"text-[9.5px] text-white/30 pt-1 flex items-center gap-1\">\n                    <Shield className=\"w-3 h-3 text-[#00FFC2]\" />\n                    <span>Cryptographic attestation and policy enforcement bounds locked</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            {/* Footer */}\n            <div className=\"p-5 border-t border-white/5 bg-black/[0.15] space-y-3\">\n              <div className=\"flex items-center gap-2 text-[10.5px] font-mono text-white/40 select-none\">\n                <Lock className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n                <span>Isolated Enclave Memory Lock Active</span>\n              </div>\n              <div className=\"grid grid-cols-2 gap-3 select-none\">\n                <button\n                  onClick={() => copyToClipboard(`0xSHA256_${selectedRow ? String(selectedRow.id).toUpperCase() : \"\"}_2026`)}\n                  className=\"h-9 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n                >\n                  <Copy className=\"w-3.5 h-3.5\" />\n                  <span>Copy Seal Hash</span>\n                </button>\n                <button onClick={() => setIsDrawerOpen(false)} className=\"h-9 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase text-white flex items-center justify-center transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\">\n                  <span>Close Ledger</span>\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"}}}
