{"ts":"2026-06-26T07:35:29.032Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"1reb3yoz","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/company/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport CompanyNavigation from \"@/components/inner-pages/CompanyNavigation\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { Shield, Cpu, Network, Global, Building2, Layers, Search, CheckCircle2 } from \"lucide-react\";\n\nexport default function CompanyProfilePage() {\n  const highlights = [\n    {\n      title: \"Garage Foundry Factory Model\",\n      icon: <Layers className=\"w-5 h-5 text-[#E4000F]\" />,\n      desc: \"Our unique execution blueprint from sandbox testing to production-grade automation.\",\n    },\n    {\n      title: \"GFF AI Research Division\",\n      icon: <Cpu className=\"w-5 h-5 text-[#009DFF]\" />,\n      desc: \"Developing next-generation heuristic routing, state isolation, and secure agency.\",\n    },\n    {\n      title: \"Architects of the Agent Economy\",\n      icon: <Network className=\"w-5 h-5 text-purple-400\" />,\n      desc: \"Formulating standard protocols for secure, compliant multi-agent system execution.\",\n    },\n  ];\n\n  const entityDetails = [\n    { label: \"Registered Entity\", value: \"GFF AI PTE. LTD.\" },\n    { label: \"Unique Entity Number (UEN)\", value: \"202621347N\" },\n    { label: \"Jurisdiction\", value: \"Singapore Global Headquarters\" },\n    { label: \"Security Framework\", value: \"Zero-Trust Architecture\" },\n    { label: \"Global Presence\", value: \"Singapore, London, India\" },\n    { label: \"Auditing Loop\", value: \"SOC2 Compliance Pending\" },\n  ];\n\n  return (\n    <InnerPageShell>\n      <CompanyNavigation />\n\n      <InnerPageHero\n        category=\"Corporate Profile\"\n        title=\"Architects of the Agent Economy\"\n        highlightedWord=\"Agent Economy\"\n        description=\"GFF AI PTE. LTD. is a premier global AI strategy and deployment firm. We build and scale high-throughput, secure, and compliant agentic systems to run complex workflows for global enterprises.\"\n      />\n\n      {/* Narrative Section with custom SVG Visual */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-16 lg:pb-24\">\n        <div className=\"max-w-[1795px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <div className=\"lg:col-span-7 space-y-6\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">\n              Institutional Mandate\n            </span>\n            <h2 className=\"text-[28px] sm:text-[38px] font-bold text-white tracking-tight leading-tight\">\n              Industrializing Cognitive Intelligence\n            </h2>\n            <p className=\"text-[15px] leading-[1.7] text-white/70 font-light font-sans\">\n              Founded under the leadership of CEO Dr. Ashish Chandra, GFF AI stands as a specialized institution dedicated to bridging the gap between cutting-edge LLM reasoning and hard-nosed deterministic operational metrics. We reject the paradigm of unreliable, hallucinatory AI systems.\n            </p>\n            <p className=\"text-[15px] leading-[1.7] text-white/70 font-light font-sans\">\n              Through our trademarked <strong>Garage, Foundry, and Factory</strong> operating model, we transition enterprises from initial exploratory design sandboxes to industrial-scale, zero-trust autonomous agent clusters.\n            </p>\n\n            <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-6 pt-6 border-t border-white/5\">\n              <div>\n                <span className=\"text-[28px] font-bold text-white tracking-tight\">3+</span>\n  