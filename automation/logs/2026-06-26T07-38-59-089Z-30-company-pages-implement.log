>Guaranteed SLAs</p>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-5\">\n            <div className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4 relative overflow-hidden\">\n              <div className=\"absolute top-0 right-0 w-[150px] h-[150px] bg-gradient-to-bl from-[#009DFF]/10 to-transparent rounded-full blur-2xl\" />\n              <h3 className=\"text-[17px] font-semibold text-white tracking-tight flex items-center gap-2\">\n                <Shield className=\"w-5 h-5 text-[#009DFF]\" />\n                <span>Corporate Verification</span>\n              </h3>\n              <div className=\"space-y-3\">\n                {[\n                  { label: \"Registered Entity\", value: \"GFF AI PTE. LTD.\" },\n                  { label: \"UEN Identification\", value: \"202621347N\" },\n                  { label: \"Headquarters\", value: \"Singapore\" },\n                  { label: \"Security Protocol\", value: \"Zero-Trust Architecture\" },\n                  { label: \"Locations Hub\", value: \"Singapore, London, India\" },\n                ].map((item, idx) => (\n                  <div key={idx} className=\"flex justify-between items-center py-2 border-b border-white/5 text-[12.5px] last:border-b-0\">\n                    <span className=\"text-white/40 font-mono uppercase tracking-wider text-[10px]\">{item.label}</span>\n                    <span className=\"text-white/80 font-medium\">{item.value}</span>\n                  </div>\n                ))}\n              </div>\n              <div className=\"pt-2 text-center text-[9px] font-mono text-white/30\">\n                GFF AI PTE. LTD. • UEN 202621347N • ESTABLISHED 2026\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Organizational Divisions */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-16 border-t border-white/5 pt-16\">\n    