            <circle cx=\"0\" cy=\"0\" r=\"24\" fill=\"#050505\" stroke=\"#E4000F\" strokeWidth=\"1.5\" className=\"opacity-40\" />\n                    <text x=\"0\" y=\"4\" fill=\"white\" fontSize=\"9\" fontWeight=\"bold\" fontFamily=\"monospace\" textAnchor=\"middle\" className=\"opacity-60\">RESEARCH</text>\n                  </g>\n\n                  <g className=\"translate-x-[450px] translate-y-[90px]\">\n                    <circle cx=\"0\" cy=\"0\" r=\"24\" fill=\"#050505\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n                    <text x=\"0\" y=\"4\" fill=\"white\" fontSize=\"9\" fontWeight=\"bold\" fontFamily=\"monospace\" textAnchor=\"middle\">FACTORY</text>\n                  </g>\n\n                  <defs>\n                    <linearGradient id=\"conduitBlue\" x1=\"50\" y1=\"90\" x2=\"450\" y2=\"90\" gradientUnits=\"userSpaceOnUse\">\n                      <stop stopColor=\"#E4000F\" stopOpacity=\"0.2\" />\n                      <stop offset=\"0.5\" stopColor=\"#009DFF\" />\n                      <stop offset=\"1\" stopColor=\"#009DFF\" stopOpacity=\"0.8\" />\n                    </linearGradient>\n                    <linearGradient id=\"conduitRed\" x1=\"50\" y1=\"90\" x2=\"450\" y2=\"90\" gradientUnits=\"userSpaceOnUse\">\n                      <stop stopColor=\"#E4000F\" />\n                      <stop offset=\"0.5\" stopColor=\"#E4000F\" stopOpacity=\"0.8\" />\n                      <stop offset=\"1\" stopColor=\"#009DFF\" stopOpacity=\"0.2\" />\n                    </linearGradient>\n                  </defs>\n                </svg>\n\n                <div className=\"flex justify-between items-center text-[9px] font-mono text-white/40 border-t border-white/5 pt-3\">\n                  <span>GARAGE: SANDBOX_INIT</span>\n                  <span>FOUNDRY: PROTO_DEPLOY</span>\n                  <span>FACTORY: SLA_ACTIVE</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\