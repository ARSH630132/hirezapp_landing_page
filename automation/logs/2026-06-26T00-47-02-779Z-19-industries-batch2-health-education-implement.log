{"ts":"2026-06-26T00:43:49.749Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"4ruqxlnq","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/industries/healthcare/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport Carousel from \"@/components/inner-pages/Carousel\";\n\nconst CHALLENGES = [\n  { title: \"Operational Complexity\", desc: \"Clinician fatigue, multi-department coordination blocks, and delayed transitions in patient flow.\" },\n  { title: \"Patient Communications\", desc: \"Non-clinical scheduling bottlenecks and manual follow-ups strain care team bandwidth.\" },\n  { title: \"Staff Knowledge Access\", desc: \"Clinical guidelines, EHR protocols, and operational handbooks scattered across fragmented, outdated databases.\" },\n  { title: \"Administrative Burden\", desc: \"Heavy documentation requirements, manual pre-authorization forms, and EHR transcription overhead.\" },\n  { title: \"Compliance Boundaries\", desc: \"Strictest HIPAA & PHI safety regulations that require completely isolated, zero-retention data pipelines.\" }\n];\n\nconst AGENTS = [\n  { name: \"Care Operations Copilot\", role: \"Synthesizes discharge timelines and provides non-clinical patient flow coordination support.\" },\n  { name: \"Knowledge Search Agent\", role: \"Locates precise internal hospital bylaws, policy amendments, and operational sheets.\" },\n  { name: \"Document Intelligence Agent\", role: \"Pre-processes incoming insurance claims, forms, and administrative pre-authorizations.\" },\n  { name: \"Scheduling Assistant\", role: \"Coordinates dynamic clinic slots, patient reminders, and physician shift updates.\" },\n  { name: \"Executive Dashboard Agent\", role: \"Aggregates anonymous operational KPIs, bed occupancy, and bottleneck alerts.\" }\n];\n\nconst OUTCOMES = [\n  { title: \"Administrative Velocity\", desc: \"Drastically reduce time spent compiling administrative pre-authorization packets and parsing incoming documents.\" },\n  { title: \"Staff Cognitive Relief\", desc: \"Provide care teams with an instant, unified operational knowledge index to locate procedural guidelines immediately.\" },\n  { title: \"PHI Security Guardrails\", desc: \"Isolate client text pipelines through high-security airgapped gateways, ensuring zero-retention parameters.\" }\n];\n\nexport default function HealthcarePage() {\n  const [demoOutput, setDemoOutput] = useState(\"System ready. Select an administrative workflow to simulate Care Operations.\");\n  const [running, setRunning] = useState(false);\n  const [activeTab, setActiveTab] = useState(\"orchestrator\");\n\n  const runDemo = (type: \"preauth\" | \"knowledge\") => {\n    setRunning(true);\n    if (type === \"preauth\") {\n      setDemoOutput(\"Initializing Document Intelligence Agent... Parsing administrative pre-auth request for Procedure Code 43239...\");\n      setTimeout(() => {\n        setDemoOutput(\"OCR COMPLETE: Parsed patient history from EHR stream. Verifying compliance constraints...\");\n        setTimeout(() => {\n          setDemoOutput(\"SUCCESS: Documented 6-week failure of PPI therapy matches insurance protocol requirements. Draft pre-auth packet compiled (100% administrative support). Final human-in-the-loop sign-off triggered.\");\n          setRunning(false);\n        }, 800);\n      }, 800);\n    } else {\n      setDemoOutput(\"Initializing Knowledge Search Agent... Scanning Hospital Policy Bylaws Section 12...\");\n      setTimeout(() => {\n        setDemoOutput(\"SCAN COMPLETE: Located Policy 12.4 regarding outpatient discharge accompaniment requirements.\");\n        setTimeout(() => {\n          setDemoOutput(\"RESULT: 'Outpatient sedation discharges require an adult escort (>= 18 years old) present during check-out.' Source: Policy Book v4.2. Audit log recorded.\");\n          setRunning(false);\n        }, 800);\n      }, 800);\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Vertical Solutions\"\n        title=\"Enterprise Healthcare Cognitive Systems\"\n        highlightedWord=\"Healthcare\"\n        description=\"Deploy high-security, HIPAA-aligned cognitive routing layers to automate complex administrative workflows, unify internal knowledge, and streamline non-clinical operations.\"\n        breadcrumbs={[{ label: \"Industries\", href: \"/industries\" }, { label: \"Healthcare\" }]}\n      />\n\n      {/* Challenge Landscape */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-20\">\n        <div className=\"flex flex-col mb-10\">\n          <span className=\"text-[11px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-2\">OPERATIONAL PAIN POINTS</span>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">The Healthcare Challenge Landscape</h2>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n          {CHALLENGES.map((c, i) => (\n            <div key={i} className=\"p-6 rounded-2xl border border-white/5 bg-[#050507]/60 backdrop-blur-[12px] hover:border-white/10 transition-all flex flex-col justify-between\">\n              <div>\n                <span className=\"text-[#009DFF] font-mono text-xs block mb-3\">0{i+1} {\"//\"} {c.title}</span>\n                <p className=\"text-xs text-white/60 leading-relaxed font-light\">{c.desc}</p>\n              </div>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Reference Solution & Architecture Visual */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-20 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n        <div className=\"lg:col-span-5 flex flex-col justify-center\">\n          <span className=\"text-[11px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-2\">COGNITIVE BLUEPRINT</span>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight mb-4\">The Care Operations Architecture</h2>\n          <p className=\"text-xs sm:text-sm text-white/70 leading-relaxed font-light mb-6\">\n            Connecting medical systems of record with natural language orchestrators requires secure, airgapped boundaries. Our reference solution routes non-clinical inquiries through isolated cognitive layers, ensuring patient records are scrubbed of PHI before any agent processing.\n          </p>\n          <div className=\"space-y-2\">\n            {[\n              { id: \"gateway\", name: \"PHI Scrubbing & Ingestion Gateway\", desc: \"Zero-retention proxy cleans data of HIPAA identifiers before tokenization.\" },\n              { id: \"orchestrator\", name: \"Cognitive Care Orchestrator\", desc: \"Semantic routing engine directs operational intents to verified sandboxed agents.\" },\n              { id: \"audit\", name: \"Immutable Care Logs\", desc: \"Every action, document compilation, and search is recorded in high-security, tamper-evident audit logs.\" }\n            ].map((tab) => (\n              <button\n                key={tab.id}\n                onClick={() => setActiveTab(tab.id)}\n                className={`w-full p-4 rounded-xl text-left border transition-all flex flex-col gap-1 ${\n                  activeTab === tab.id ? \"bg-white/5 border-white/10 text-white shadow-lg\" : \"border-transparent text-white/50 hover:text-white\"\n                }`}\n              >\n                <span className=\"text-xs font-bold uppercase tracking-wider\">{tab.name}</span>\n                {activeTab === tab.id && <span className=\"text-[11px] text-white/60 leading-normal font-light\">{tab.desc}</span>}\n              </button>\n            ))}\n          </div>\n        </div>\n\n        {/* Architecture Visual SVG */}\n        <div className=\"lg:col-span-7 p-6 md:p-8 rounded-3xl border border-white/5 bg-[#050507]/40 backdrop-blur-[12px] flex flex-col items-center\">\n          <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest mb-6\">Interactive Healthcare Architecture Blueprint</span>\n          <div className=\"w-full max-w-[500px] h-[340px] relative flex items-center justify-center\">\n            <svg className=\"w-full h-full\" viewBox=\"0 0 500 340\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M250 40 L250 110 M250 150 L250 200 M250 240 L250 290\" stroke=\"url(#pipeGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"6 4\" />\n              \n              {/* Box 1: EHR Gateway */}\n              <g onClick={() => setActiveTab(\"gateway\")} className=\"cursor-pointer\">\n                <rect x=\"100\" y=\"20\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"gateway\" ? \"#009DFF\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"44\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\" letterSpacing=\"1\">1. SECURE EHR GATEWAY (HIPAA-ALIGNMENT)</text>\n              </g>\n\n              {/* Box 2: Cognitive Care Router */}\n              <g onClick={() => setActiveTab(\"orchestrator\")} className=\"cursor-pointer\">\n                <rect x=\"80\" y=\"110\" width=\"340\" height=\"40\" rx=\"8\" fill={activeTab === \"orchestrator\" ? \"url(#brandG)\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"134\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\" letterSpacing=\"1\">2. COGNITIVE CARE ORCHESTRATOR</text>\n              </g>\n\n              {/* Box 3: Agent Sandbox Map */}\n              <g className=\"opacity-70\">\n                <rect x=\"50\" y=\"190\" width=\"400\" height=\"50\" rx=\"8\" fill=\"#050507\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n                <text x=\"250\" y=\"210\" fill=\"#009DFF\" fontSize=\"9\" fontWeight=\"bold\" textAnchor=\"middle\">Care Copilots // Knowledge Search // Document Intelligence Agents</text>\n                <text x=\"250\" y=\"228\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" className=\"opacity-60\">Executing administrative tasks inside secured runtime environments</text>\n              </g>\n\n              {/* Box 4: Audit Logs */}\n              <g onClick={() => setActiveTab(\"audit\")} className=\"cursor-pointer\">\n                <rect x=\"100\" y=\"280\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"audit\" ? \"#E4000F\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"304\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\" letterSpacing=\"1\">3. IMMUTABLE CARE AUDIT TRAIL</text>\n              </g>\n\n              <defs>\n                <linearGradient id=\"brandG\" x1=\"0\" y1=\"0\" x2=\"340\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n                  <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n                </linearGradient>\n                <linearGradient id=\"pipeGlow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"340\" gradientUnits=\"userSpaceOnUse\">\n                  <stop stopColor=\"#E4000F\" /><stop offset=\"0.5\" stopColor=\"#FFFFFF\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n                </linearGradient>\n              </defs>\n            </svg>\n          </div>\n          <p className=\"text-xs text-white/50 text-center mt-4 font-light max-w-[420px]\">\n            {activeTab === \"gateway\" && \"First-hop encryption scrubs unstructured text arrays to eliminate health-identifying strings prior to query orchestration.\"}\n            {activeTab === \"orchestrator\" && \"High-performance cognitive routing layer parsing natural text intents and querying pre-approved vector memories.\"}\n            {activeTab === \"audit\" && \"Decentralized, tamper-evident action registry recording every micro-agent execution step to satisfy rigid corporate compliance teams.\"}\n          </p>\n        </div>\n      </div>\n\n      {/* Agent Map Carousel */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-20\">\n        <div className=\"flex flex-col mb-10\">\n          <span className=\"text-[11px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-2\">AGENT MATRIX</span>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">The Healthcare Agent Map</h2>\n          <p className=\"mt-2 text-xs sm:text-sm text-white/60 leading-relaxed font-light max-w-[700px]\">\n            Custom engineered specialized cognitive workers equipped with distinct toolkits to carry out high-fidelity clinical and non-clinical support.\n          </p>\n        </div>\n        <Carousel\n          items={AGENTS.map((a) => ({\n            title: a.name,\n            tag: \"Healthcare Agent\",\n            desc: a.role,\n            metric: \"Latency: <150ms\"\n          }))}\n        />\n      </div>\n\n      {/* Interactive Sandbox / Demo Preview */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-20 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n        <div className=\"lg:col-span-5 flex flex-col justify-center\">\n          <span className=\"text-[11px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-2\">SIMULATOR LABS</span>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight mb-4\">Interactive Care Operations Simulator</h2>\n          <p className=\"text-xs sm:text-sm text-white/70 leading-relaxed font-light mb-6\">\n            Test our Document Intelligence and Knowledge Search engines. Simulate real-time parsing of pre-authorization requests and guideline queries safely.\n          </p>\n          <div className=\"flex flex-wrap gap-3\">\n            <button\n              onClick={() => runDemo(\"preauth\")}\n              disabled={running}\n              className=\"px-5 py-3 rounded-full text-xs font-semibold bg-white text-black hover:bg-white/90 disabled:opacity-50 transition-all shadow-lg\"\n            >\n              {running ? \"Executing...\" : \"Simulate Pre-auth Document Check\"}\n            </button>\n            <button\n              onClick={() => runDemo(\"knowledge\")}\n              disabled={running}\n              className=\"px-5 py-3 rounded-full text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white disabled:opacity-50 transition-all\"\n            >\n              {running ? \"Searching...\" : \"Simulate Hospital Guidelines Search\"}\n            </button>\n          </div>\n        </div>\n\n        <div className=\"lg:col-span-7 p-6 rounded-2xl border border-white/5 bg-black/40 min-h-[180px] flex flex-col justify-between font-mono relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 p-2 text-[8px] bg-white/5 text-white/40 border-b border-l border-white/5 font-mono\">SANDBOX ENVIROMENT</div>\n          <div>\n            <span className=\"text-[10px] text-[#009DFF] block border-b border-white/5 pb-2 uppercase tracking-wider font-bold\">KNOWLEDGE RETRIEVAL & AUDIT LOG</span>\n            <p className=\"text-xs text-green-400 mt-4 leading-relaxed font-mono\">{demoOutput}</p>\n          </div>\n          <span className=\"text-[9px] text-white/30 text-right block pt-4\">GFF HEALTHCARE REAL-TIME INTERACTIVE PORTAL</span>\n        </div>\n      </div>\n\n      {/* Outcome Levers */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-24\">\n        <div className=\"flex flex-col mb-10\">\n          <span className=\"text-[11px] font-mono tracking-widest text-[#009DFF] uppercase font-bold mb-2\">BUSINESS RESULTS</span>\n          <h2 className=\"text-3xl font-bold text-white tracking-tight\">Structural ROI & Outcome Levers</h2>\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          {OUTCOMES.map((o, i) => (\n            <div key={i} className=\"p-6 rounded-2xl border border-white/5 bg-[#050507]/60 backdrop-blur-[12px] hover:border-white/10 transition-all\">\n              <h3 className=\"text-xs font-mono font-bold text-white uppercase mb-3 tracking-wider\">{o.title}</h3>\n              <p className=\"text-xs text-white/60 leading-relaxed font-light\">{o.desc}</p>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Related Platforms */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16 border-t border-white/5 pt-12\">\n        <h3 className=\"text-xs font-mono text-white/40 uppercase tracking-widest mb-4\">Related Capabilities & Platforms</h3>\n        <div className=\"flex flex-wrap gap-3\">\n          {[\"Sovereign Memory Store\", \"Foundry Core Gateway\", \"Agentic Security Sandboxes\", \"University OneVerse Network\", \"GFF AI Academy\"].map((cap, i) => (\n            <span key={i} className=\"px-3.5 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/70 font-mono\">{cap}</span>\n          ))}\n        </div>\n      </div>\n\n      {/* Talk to Agent CTA */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-20\">\n        <PremiumCTA\n          title=\"Architect Your Hospital's Cognitive Tier\"\n          description=\"Schedule a technical workspace review to design isolated EHR connections, vector knowledge grids, and pre-auth pipelines under complete sandboxed compliance.\"\n          primaryLabel=\"Talk to GFF Systems Architect\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
