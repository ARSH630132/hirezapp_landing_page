Query) {\n 89 |       const q = searchQuery.toLowerCase().trim();\n 90 |       projects = projects.filter(p => \n 91 |         p.name.toLowerCase().includes(q) || \n 92 |         p.desc.toLowerCase().includes(q) || \n 93 |         p.owner.toLowerCase().includes(q) ||\n 94 |         p.id.toLowerCase().includes(q)\n 95 |       );\n 96 |     }\n 97 | \n 98 |     const limitParam = searchParams.get(\"limit\");\n 99 |     const offsetParam = searchParams.get(\"offset\") || searchParams.get(\"skip\");\n100 |     const limit = limitParam ? Math.max(1, Math.min(1000, parseInt(limitParam, 10) || 100)) : 100;\n101 |     const offset = offsetParam ? Math.max(0, parseInt(offsetParam, 10) || 0) : 0;\n102 | \n103 |     const paginatedProjects = projects.slice(offset, offset + limit);\n104 | \n105 |     return NextResponse.json({ success: true, projects: paginatedProjects });\n106 |   } catch (err) {\n107 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n108 |   }\n109 | }\n110 | \n111 | export async function POST(req: Request) {\n112 |   try {\n113 |     const auth = getAuthCaller(req);\n114 |     if (\"status\" in auth) {\n115 |       return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n116 |     }\n117 |     const { caller } = auth;\n118 | \n119 |     // MVP constraints: admin create/update/archive only\n120 |     if (caller.role !== \"gff_admin\") {\n121 |       return NextResponse.json(\n122 |         { success: false, error: \"Forbidden\", message: \"Only administrators can create projects.\" },\n123 |         { status: 403 }\n124 |       );\n125 |     }\n126 | \n127 |     const body = await req.json().catch(() => null);\n128 |     if (!body) {\n129 |       return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid JSON body.\" }, { status: 400 });\n130 |     }\n131 | \n132 |     const { name, client_id, phase, status, health, owner, nodes