.error(\"[BCRYPT] Comparison error:\", err);\n 99 |   }\n100 | \n101 |   return false;\n102 | }\n103 | \n104 | export function mapDynamoUserToApiUser(dbUser: DynamoDbUser): any {\n105 |   const role = dbUser.role || \"client_member\";\n106 |   \n107 |   let clearance = \"CLEARANCE LEVEL I (BASIC VIEW-ONLY)\";\n108 |   let permissions: string[] = [\"read:telemetry\", \"read:projects\", \"read:ai-operations\", \"read:documents\", \"write:support\"];\n109 |   \n110 |   if (role === \"gff_admin\") {\n111 |     clearance = \"CLEARANCE LEVEL V (SECURE PLATFORM SUPERUSER)\";\n112 |     permissions = [\n113 |       \"all:*\", \"read:telemetry\", \"write:telemetry\", \"read:projects\", \"write:projects\",\n114 |       \"read:users\", \"write:users\", \"read:clients\", \"write:clients\", \"write:governance\"\n115 |     ];\n116 |   } else if (role === \"client_admin\") {\n117 |     clearance = \"CLEARANCE LEVEL III (SANDBOX OPERATOR)\";\n118 |     permissions = [\n119 |       \"read:telemetry\", \"read:projects\", \"write:projects\", \"read:ai-operations\",\n120 |       \"write:ai-operations\", \"read:documents\", \"write:documents\", \"write:support\"\n121 |     ];\n122 |   }\n123 | \n124 |   // Handle client association\n125 |   let clientAssociation = \"GFF AI Platform Core (Global Root)\";\n126 |   if (role !== \"gff_admin\") {\n127 |     if (dbUser.client_id !== undefined && dbUser.client_id !== null) {\n128 |       const cid = String(dbUser.client_id);\n129 |       if (cid === \"1\" || cid.toLowerCase().includes(\"apex\") || cid.toLowerCase().includes(\"client-001\")) {\n130 |         clientAssociation = \"Apex Sovereign Group [Preview Client]\";\n131 |       } else if (cid === \"2\" || cid.toLowerCase().includes(\"retail\") || cid.toLowerCase().includes(\"client-002\")) {\n132 |         clientAssociation = \"Global Retail Enclave [Preview Client]\";\n133 |       } else if (cid === \"3\" || cid.toLowerCase().includes(\"logistics\") || cid.toLowerCase().includes(\"client-