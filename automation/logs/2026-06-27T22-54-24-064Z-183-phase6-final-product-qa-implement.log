s\" in auth) {\n35 |       return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n36 |     }\n37 |     const { caller } = auth;\n38 | \n39 |     let callerClientId = getClientIdFromAssociation(caller.clientAssociation);\n40 |     const { searchParams } = new URL(req.url);\n41 |     const requestedClientId = searchParams.get(\"client_id\");\n42 | \n43 |     if (caller.role === \"gff_admin\") {\n44 |       if (requestedClientId) callerClientId = requestedClientId;\n45 |       else callerClientId = \"client-001\";\n46 |     } else {\n47 |       if (requestedClientId && requestedClientId !== callerClientId) {\n48 |         return NextResponse.json(\n49 |           { success: false, error: \"Forbidden\", message: \"Access denied to requested client's dashboard.\" },\n50 |           { status: 403 }\n51 |         );\n52 |       }\n53 |     }\n54 | \n55 |     const clientProjects = await dynamoDbListPortalItems(\"PROJECT\", callerClientId);\n56 |     const clientOps = await dynamoDbListPortalItems(\"AI_OPERATION\", callerClientId);\n57 |     const clientDocs = await dynamoDbListPortalItems(\"DOCUMENT\", callerClientId);\n58 |     const clientInvoices = await dynamoDbListPortalItems(\"INVOICE\", callerClientId);\n59 |     const clientTickets = await dynamoDbListPortalItems(\"SUPPORT\", callerClientId);\n60 |     const clientGov = await dynamoDbListPortalItems(\"GOVERNANCE\", callerClientId);\n61 | \n62 |     const activeProjectsCount = clientProjects.filter(p => p.status === \"active\").length;\n63 |     const activeOperationsCount = clientOps.filter(o => o.status === \"active\").length;\n64 |     const verifiedDocsCount = clientDocs.filter(d => d.status === \"Verified\" || d.status === \"verified\").length;\n65 |     const unpaidInvoicesCount = clientInvoices.filter(i => i.status === \"unpaid\" || i.status === \"processing\").length;\n66 |     const openSupportTicketsCount = clientTickets.filter(t => t.status !== \"RESOLVED\").length;\n67 |     const flaggedGovCount = clientGov.filter(g => g.status === \"Flagged\" || g.status === \"Critical\" || g.severity === \"Critical\").length;\n68 | \n69 |     const sortByDate = (items: any[]) => [...items].sort((a, b) => \n70 |       new Date(b.lastUpdated || b.updated_at || b.createdAt || b.created_at || b.createdDate || \"\").getTime() - \n71 |       new Date(a.lastUpdated || a.updated_at || a.createdAt || a.created_at || a.createdDate || \"\").getTime()\n72 |     ).slice(0, 5);\n73 | \n74 |     return NextResponse.json({\n75 |       success: true,\n76 |       client_id: callerClientId,\n77 |       summary: {\n78 |         projects: { activeCount: activeProjectsCount, totalCount: clientProjects.length, recent: sortByDate(clientProjects) },\n79 |         aiOperations: { activeCount: activeOperationsCount, totalCount: clientOps.length, recent: sortByDate(clientOps) },\n80 |         documents: { verifiedCount: verifiedDocsCount, totalCount: clientDocs.length, recent: sortByDate(clientDocs) },\n81 |         invoices: { unpaidCount: unpaidInvoicesCount, totalCount: clientInvoices.length, recent: sortByDate(clientInvoices) },\n82 |         supportTickets: { openCount: openSupportTicketsCount, totalCount: clientTickets.length, recent: sortByDate(clientTickets) },\n83 |         governance: { flaggedCount: flaggedGovCount, totalCount: clientGov.length, recent: sortByDate(clientGov) }\n84 |       }\n85 |     });\n86 |   } catch (err) {\n87 |     console.error(\"Dashboard client summary error:\", err);\n88 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n89 |   }\n90 | }\n91 | \n92 | \n93 | ","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/api/v1/dashboard/admin/route.ts:1-150","result":" 1 | import { NextResponse } from \"next/server\";\n 2 | import { API_MOCK_USERS, verifyJwt, MockUserDbEntry } from \"../../../../../lib/api-auth\";\n 3 | import { getUserF