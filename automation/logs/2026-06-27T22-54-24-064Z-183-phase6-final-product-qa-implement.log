h custom event to let other components know the session updated\n102 |     window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n103 |   }\n104 |   return session;\n105 | }\n106 | \n107 | export function clearPreviewSession(): void {\n108 |   if (typeof window !== \"undefined\") {\n109 |     localStorage.removeItem(SESSION_KEY);\n110 |     localStorage.removeItem(\"gff_ai_access_token\");\n111 |     localStorage.removeItem(\"gff_api_token\");\n112 |     window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n113 |   }\n114 | }\n115 | \n116 | export function hasRole(session: PreviewSession | null, allowedRoles: PreviewRole[]): boolean {\n117 |   if (!session) return false;\n118 |   return allowedRoles.includes(session.role);\n119 | }\n120 | \n121 | // Check access rules for Client Portal sections (/portal/[sectionId])\n122 | export function canAccessPortalSection(role: PreviewRole, sectionId: string): boolean {\n123 |   // GFF admin can access everything\n124 |   if (role === \"gff_admin\") return true;\n125 |   \n126 |   if (role === \"viewer\") {\n127 |     // Read-only auditor can view general stats but not settings/billing or write tools\n128 |     return [\"dashboard\", \"analytics\", \"governance\", \"activity\"].includes(sectionId);\n129 |   }\n130 |   \n131 |   if (role === \"client_member\") {\n132 |     // Client members can access everything except billing and settings\n133 |     return ![\"billing\", \"settings\"].includes(sectionId);\n134 |   }\n135 |   \n136 |   if (role === \"client_admin\") {\n137 |     // Client Admin can access all client portal sections\n138 |     return true;\n139 |   }\n140 | \n141 |   // GFF internal roles inside client portal layout:\n142 |   if (role === \"finance_admin\") {\n143 |     return [\"dashboard\", \"billing\", \"analytics\", \"activity\"].includes(sectionId);\n144 |   }\n145 |   if (role === \"support_agent\") {\n146 |     return [\"dashboard\", \"support\", \"activity\"].includes(sectionId);