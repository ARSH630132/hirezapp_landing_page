5 | }\n266 | \n267 | export async function dynamoDbDeletePortalItem(entityType: string, clientId: string, itemId: string): Promise<boolean> {\n268 |   const pk = `CLIENT#${clientId}`, sk = `${ENTITY_PREFIXES[entityType] || \"\"}${itemId}`;\n269 |   if (docClient) {\n270 |     try {\n271 |       await docClient.send(new DeleteCommand({ TableName: DYNAMODB_ITEMS_TABLE, Key: { PK: pk, SK: sk } }));\n272 |       return true;\n273 |     } catch (err) { return false; }\n274 |   }\n275 |   const store = getMockStore(entityType);\n276 |   if (store[itemId]) { delete store[itemId]; return true; }\n277 |   return false;\n278 | }\n279 | \n280 | function getMockStore(entityType: string): any {\n281 |   switch (entityType) {\n282 |     case \"PROJECT\": return (global as any)._apiMockProjects || {};\n283 |     case \"AI_OPERATION\": return (global as any)._apiMockAiOperations || {};\n284 |     case \"DOCUMENT\": return (global as any)._apiMockDocuments || {};\n285 |     case \"INVOICE\": return (global as any)._apiMockInvoices || {};\n286 |     case \"SUPPORT\": return (global as any)._apiMockSupportTickets || {};\n287 |     case \"GOVERNANCE\": return (global as any)._apiMockGovernance || {};\n288 |     default: return {};\n289 |   }\n290 | }\n291 | ","success":true}],"durationMs":9}}
