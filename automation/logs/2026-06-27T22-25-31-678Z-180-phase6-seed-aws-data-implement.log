(\"All ClientAccount CRUD API tests completed successfully!\")\n76 | \n77 | if __name__ == \"__main__\":\n78 |     try:\n79 |         run_api_tests()\n80 |         sys.exit(0)\n81 |     except AssertionError:\n82 |         import traceback\n83 |         traceback.print_exc()\n84 |         sys.exit(1)\n85 |     except Exception as e:\n86 |         print(f\"Failed: {e}\")\n87 |         import traceback\n88 |         traceback.print_exc()\n89 |         sys.exit(1)\n90 | ","success":true}],"durationMs":2}}
