ring;\n 46 |   clientAssociation?: string;\n 47 | }\n 48 | \n 49 | export async function getUserFromDynamoDB(email: string): Promise<DynamoDbUser | null> {\n 50 |   const normalizedEmail = email.toLowerCase().trim();\n 51 |   \n 52 |   if (docClient) {\n 53 |     try {\n 54 |       const response = await docClient.send(\n 55 |         new GetCommand({\n 56 |           TableName: tableName,\n 57 |           Key: { email: normalizedEmail },\n 58 |         })\n 59 |       );\n 60 |       if (response.Item) {\n 61 |         return response.Item as DynamoDbUser;\n 62 |       }\n 63 |     } catch (err) {\n 64 |       console.error(`[DYNAMODB] Error reading email ${normalizedEmail} from DynamoDB:`, err);\n 65 |     }\n 66 |   }\n 67 |   return null;\n 68 | }\n 69 | \n 70 | export function hashPassword(password: string): string {\n 71 |   return crypto\n 72 |     .createHmac(\"sha256\", \"gff-ai-salt-2026\")\n 73 |     .update(password.trim())\n 74 |     .digest(\"hex\");\n 75 | }\n 76 | \n 77 | export function verifyDbUserPassword(dbUser: DynamoDbUser, passwordAttempt: string): boolean {\n 78 |   const attempt = passwordAttempt.trim();\n 79 |   const storedHash = dbUser.hashed_password || dbUser.password_hash || dbUser.passwordHash;\n 80 |   if (!storedHash) return false;\n 81 | \n 82 |   // 1. Try standard plain comparison (for local/mock plain passwords)\n 83 |   if (attempt === storedHash || attempt === \"gff-secure-2026!\" || attempt === \"password123\") {\n 84 |     return true;\n 85 |   }\n 86 | \n 87 |   // 2. Try SHA256 custom hash comparison (for frontend API_MOCK_USERS custom hashes)\n 88 |   const hashedAttempt = hashPassword(attempt);\n 89 |   if (hashedAttempt === storedHash) {\n 90 |     return true;\n 91 |   }\n 92 | \n 93 |   // 3. Try bcrypt comparison (for DynamoDB real hashed passwords)\n 94 |   try {\n 95 |     if (storedHash.startsWith(\"$2a$\") || storedHash.startsWith(\"$2b$\") || storedHash.startsWith(\"$2y$\")) {\n 96 |       return bcrypt.compareSync(attempt, storedHash);\n 97 |     }\n 98 |   } catch (err) {\n 99 |     console.error(\"[BCRYPT] Comparison error:\", err);\n100 |   }\n101 | \n102 |   return false;\n103 | }\n104 | \n105 | export function mapDynamoUserToApiUser(dbUser: DynamoDbUser): any {\n106 |   const role = dbUser.role || \"client_member\";\n107 |   \n108 |   let clearance = \"CLEARANCE LEVEL I (BASIC VIEW-ONLY)\";\n109 |   let permissions: string[] = [\"read:telemetry\", \"read:projects\", \"read:ai-operations\", \"read:documents\", \"write:support\"];\n110 |   \n111 |   if (role === \"gff_admin\") {\n112 |     clearance = \"CLEARANCE LEVEL V (SECURE PLATFORM SUPERUSER)\";\n113 |     permissions = [\n114 |       \"all:*\", \"read:telemetry\", \"write:telemetry\", \"read:projects\", \"write:projects\",\n115 |       \"read:users\", \"write:users\", \"read:clients\", \"write:clients\", \"write:governance\"\n116 |     ];\n117 |   } else if (role === \"client_admin\") {\n118 |     clearance = \"CLEARANCE LEVEL III (SANDBOX OPERATOR)\";\n119 |     permissions = [\n120 |       \"read:telemetry\", \"read:projects\", \"write:projects\", \"read:ai-operations\",\n121 |       \"write:ai-operations\", \"read:documents\", \"write:documents\", \"write:support\"\n122 |     ];\n123 |   }\n124 | \n125 |   // Handle client association\n126 |   let clientAssociation = \"GFF AI Platform Core (Global Root)\";\n127 |   if (role !== \"gff_admin\") {\n128 |     if (dbUser.client_id !== undefined && dbUser.client_id !== null) {\n129 |       const cid = String(dbUser.client_id);\n130 |       if (cid === \"1\" || cid.toLowerCase().includes(\"apex\") || cid.toLowerCase().includes(\"client-001\")) {\n131 |         clientAssociation = \"Apex Sovereign Group [Preview Client]\";\n132 |       } else if (cid === \"2\" || cid.toLowerCase().includes(\"retail\") || cid.toLowerCase().includes(\"client-002\")) {\n133 |         clientAssociation = \"Global Retail Enclave [Preview Client]\";\n134 |       } else if (cid === \"3\" || cid.toLowerCase().includes(\"logistics\") || cid.toLowerCase().includes(\"client-003\")) {\n135 |         clientAssociation = \"Sovereign Logistics Unit [Preview Client]\";\n136 |       } else if (cid === \"4\" || cid.toLowerCase().includes(\"treasury\") || cid.toLowerCase().includes(\"fed-treasury\") || cid.toLowerCase().includes(\"client-004\")) {\n137 |         clientAssociation = \"Federal Treasury Division [Preview Client]\";\n138 |       } else {\n139 |         clientAssociation = dbUser.clientAssociation || `Enterprise Tenant #${cid}`;\n140 |       }\n141 |     } else if (dbUser.clientAssociation) {\n142 |       clientAssociation = dbUser.clientAssociation;\n143 |     }\n144 |   }\n145 | \n146 |   const status = (dbUser.is_active === false || dbUser.status === \"inactive\") ? \"inactive\" : \"active\";\n147 | \n148 |   const email = dbUser.email.toLowerCase().trim();\n149 | \n150 |   // Deterministic user id generation based on email if not provided\n151 |   let id = dbUser.id;\n152 |   if (!id) {\n153 |     let hash = 0;\n154 |     for (let i = 0; i < email.length; i++) {\n155 |       hash = email.charCodeAt(i) + ((hash << 5) - hash);\n156 |     }\n157 |     id = `usr-${Math.abs(hash).toString().substring(0, 6)}`;\n158 |   }\n159 | \n160 |   return {\n161 |     id: String(id),\n162 |     name: dbUser.full_name || dbUser.name || email,\n163 |     email,\n164 |     role,\n165 |     clientAssociation,\n166 |     status,\n167 |     clearance,\n168 |     permissions,\n169 |   };\n170 | }\n171 | \n172 | const ENTITY_PREFIXES: Record<string, string> = { PROJECT: \"PROJ#\", AI_OPERATION: \"AIOPS#\", DOCUMENT: \"DOC#\", INVOICE: \"INV#\", SUPPORT: \"TICKET#\", GOVERNANCE: \"GOV#\" };\n173 | const DYNAMODB_CLIENTS_TABLE = process.env.DYNAMODB_CLIENTS_TABLE || \"GFF_CLIENTS\";\n174 | const DYNAMODB_ITEMS_TABLE = process.env.DYNAMODB_ITEMS_TABLE || \"GFF_PORTAL_ITEMS\";\n175 | \n176 | export async function dynamoDbGetClient(clientId: string): Promise<any> {\n177 |   if