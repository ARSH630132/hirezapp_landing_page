rchestration\"],\n156 | };\n157 | \n158 | const riskGovernance: Record<string, string[]> = {\n159 |   conservative: [\"Strict Model Governance\", \"Human-in-the-Loop Controls\", \"Audit & Compliance Trails\", \"Ethics Review Board\"],\n160 |   moderate: [\"Policy-Based Guardrails\", \"Risk Tiering Framework\", \"Security & Privacy Controls\", \"Responsible AI Standards\"],\n161 |   aggressive: [\"Automated Policy Checks\", \"Rapid Release Gates\", \"Security Monitoring\", \"Ethics Guidelines\"],\n162 |   experimental: [\"Sandbox Environments\", \"Pilot Governance\", \"Fast Feedback Loops\", \"Ethics & Safety Reviews\"],\n163 | };\n164 | \n165 | const sizeRoadmapTiming: Record<string, [string, string, string, string]> = {\n166 |   startup: [\"0-2 Months\", \"2-6 Months\", \"6-12 Months\", \"12+ Months\"],\n167 |   \"mid-market\": [\"0-3 Months\", \"3-9 Months\", \"9-15 Months\", \"15+ Months\"],\n168 |   enterprise: [\"0-3 Months\", \"3-9 Months\", \"9-18 Months\", \"18+ Months\"],\n169 |   global: [\"0-4 Months\", \"4-12 Months\", \"12-24 Months\", \"24+ Months\"],\n170 | };\n171 | \n172 | function getOptionLabel(key: BlueprintFieldKey, value: string) {\n173 |   return blueprintFields.find((field) => field.key === key)?.options.find((option) => option.value === value)?.label ?? value;\n174 | }\n175 | \n176 | export function getEmptyBlueprintAnswers(): BlueprintAnswers {\n177 |   return {\n178 |     industry: \"\",\n179 |     enterpriseSize: \"\",\n180 |     aiGoals: \"\",\n181 |     workforceSize: \"\",\n182 |     existingSystems: \"\",\n183 |     riskAppetite: \"\",\n184 |   };\n185 | }\n186 | \n187 | export function isBlueprintComplete(answers: BlueprintAnswers) {\n188 |   return blueprintFields.every((field) => Boolean(answers[field.key]));\n189 | }\n190 | \n191 | export function generateBlueprint(answers: BlueprintAnswers): BlueprintResult {\n192 |   const industry = answers.industry;\n193 |   const operatingModel = industryOperatingModel[industry] ?? [\"Intelligent Workforce\", \"Agentic Automation\", \"Decision Intelligence\", \"Continuous Learning\"];\n194 |   const agents = goalAgents[answers.aiGoals] ?? { count: 24, types: [\"Workflow Agents\", \"Service Agents\", \"Analytics Agents\"] };\n195 |   const architecture = systemArchitecture[answers.existingSystems] ?? [\"Data & Intelligence Layer\", \"AI & Agent Layer\", \"Orchestration Layer\", \"Integration Layer\"];\n196 |   const governance = riskGovernance[answers.riskAppetite] ?? [\"Trust\", \"Risk\", \"Security\", \"Compliance\", \"Ethics\"];\n197 |   const timings = sizeRoadmapTiming[answers.enterpriseSize] ?? [\"0-3 Months\", \"3-9 Months\", \"9-18 Months\", \"18+ Months\"];\n198 | \n199 |   const workforceMultiplier =\n200 |     answers.workforceSize === \"very-large\" ? 1.35 : answers.workforceSize === \"large\" ? 1.2 : answers.workforceSize === \"medium\" ? 1.05 : 1;\n201 |   const agentCount = Math.round(agents.count * workforceMultiplier);\n202 | \n203 |   const industryLabel = getOptionLabel(\"industry\", industry);\n204 |   const goalLabel = getOptionLabel(\"aiGoals\", answers.aiGoals);\n205 |   const riskLabel = getOptionLabel(\"riskAppetite\", answers.riskAppetite);\n206 | \n207 |   return {\n208 |     operatingModel,\n209 |     agentCount,\n210 |     agentTypes: agents.types,\n211 |     architecture,\n212 |     governance,\n213 |     roadmap: [\n214 |       { phase: \"PHASE 1\", title: \"Foundation\", time: timings[0], focus: \"Data readiness, governance baseline, and priority use cases\" },\n215 |       { phase: \"PHASE 2\", title: \"Scale\", time: timings[1], focus: \"Agent deployment across high-impact workflows\" },\n216 |       { phase: \"PHASE 3\", title: \"Optimize\", time: timings[2], focus: \"Performance tuning, integration depth, and workforce adoption\" },\n217 |       { phase: \"PHASE 4\", title: \"Autonomous Enterprise\", time: timings[3], focus: \"Cross-functional agent orchestration at enterprise scale\" },\n218 |     ],\n219 |     insigh