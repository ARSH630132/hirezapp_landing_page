.key === key)?.label ?? key;\n241 | }\n242 | \n243 | export function getSelectedOptionLabel(key: BlueprintFieldKey, value: string) {\n244 |   return getOptionLabel(key, value);\n245 | }\n246 | \n247 | export function calculateBlueprintScore(input: {\n248 |   aiMaturityScore: number;\n249 |   businessNeedScore: number;\n250 |   dataReadinessScore: number;\n251 |   processComplexityScore: number;\n252 |   transformationReadinessScore: number;\n253 | }) {\n254 |   const {\n255 |     aiMaturityScore,\n256 |     businessNeedScore,\n257 |     dataReadinessScore,\n258 |     processComplexityScore,\n259 |     transformationReadinessScore,\n260 |   } = input;\n261 |   \n262 |   const score = \n263 |     (aiMaturityScore * 0.20) + \n264 |     (businessNeedScore * 0.25) + \n265 |     (dataReadinessScore * 0.20) + \n266 |     (processComplexityScore * 0.20) + \n267 |     (transformationReadinessScore * 0.15);\n268 |     \n269 |   return Math.round(score);\n270 | }\n271 | \n272 | export function getScoreCategory(score: number) {\n273 |   if (score <= 25) return \"AI Beginner\";\n274 |   if (score <= 50) return \"AI Explorer\";\n275 |   if (score <= 70) return \"AI Adopter\";\n276 |   if (score <= 85) return \"AI Transformer\";\n277 |   return \"AI-Native Leader\";\n278 | }\n279 | \n280 | export function getRecommendedOpportunities(industry: string, priorities: string[]) {\n281 |   const defaults = [\n282 |     \"Procurement Copilot\",\n283 |     \"HR Assistant\",\n284 |     \"Contract Intelligence\",\n285 |     \"Knowledge Search\",\n286 |     \"Executive Dashboard\"\n287 |   ];\n288 |   \n289 |   if (industry === \"Banking\" && priorities.includes(\"Strengthen Compliance\")) {\n290 |     return [\"Contract Intelligence\", \"Compliance Copilot\", \"Executive Dashboard\", \"Knowledge Search\", \"Risk Operations Assistant\"];\n291 |   }\n292 |   \n293 |   if (industry === \"Retail\" && (priorities.includes(\"Increase Revenue\") || priorities.includes(\"Improve Customer Experience\