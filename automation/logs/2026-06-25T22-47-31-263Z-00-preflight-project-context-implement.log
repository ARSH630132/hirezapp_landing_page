rganization balance speed and governance?\",\n 78 |     options: [\n 79 |       { value: \"conservative\", label: \"Conservative\", detail: \"Governance-first with phased, controlled rollouts\" },\n 80 |       { value: \"moderate\", label: \"Moderate\", detail: \"Balanced innovation with standard guardrails\" },\n 81 |       { value: \"aggressive\", label: \"Aggressive\", detail: \"Fast adoption with targeted risk controls\" },\n 82 |       { value: \"experimental\", label: \"Experimental\", detail: \"Pilot-heavy approach with rapid iteration\" },\n 83 |     ],\n 84 |   },\n 85 | ];\n 86 | \n 87 | export type BlueprintResult = {\n 88 |   operatingModel: string[];\n 89 |   agentCount: number;\n 90 |   agentTypes: string[];\n 91 |   architecture: string[];\n 92 |   governance: string[];\n 93 |   roadmap: { phase: string; title: string; time: string; focus: string }[];\n 94 |   insights: {\n 95 |     summary: string;\n 96 |     recommendations: string[];\n 97 |     agentEcosystemDetail: string;\n 98 |     architectureDetail: string;\n 99 |     governanceDetail: string;\n100 |     transformationNotes: string[];\n101 |   };\n102 | };\n103 | \n104 | export const defaultBlueprint: BlueprintResult = {\n105 |   operatingModel: [\"Intelligent Workforce\", \"Agentic Automation\", \"Decision Intelligence\", \"Continuous Learning\"],\n106 |   agentCount: 24,\n107 |   agentTypes: [\"Workflow Agents\", \"Service Agents\", \"Analytics Agents\"],\n108 |   architecture: [\"Data & Intelligence Layer\", \"AI & Agent Layer\", \"Orchestration Layer\", \"Integration Layer\"],\n109 |   governance: [\"Trust\", \"Risk\", \"Security\", \"Compliance\", \"Ethics\"],\n110 |   roadmap: [\n111 |     { phase: \"PHASE 1\", title: \"Foundation\", time: \"0-3 Months\", focus: \"Data readiness, governance baseline, and priority use cases\" },\n112 |     { phase: \"PHASE 2\", title: \"Scale\", time: \"3-9 Months\", focus: \"Agent deployment across high-impact workflows\" },\n113 |     { phase: \"PHASE 3\", title: \"Optimize\", time: \"9-18 Months\", focus: \"Performance tuning, integration depth, and workforce adoption\" },\n114 |     { phase: \"PHASE 4\", title: \"Autonomous Enterprise\", time: \"18+ Months\", focus: \"Cross-functional agent orchestration at enterprise scale\" },\n115 |   ],\n116 |   insights: {\n117 |     summary: \"A balanced AI enterprise blueprint designed to scale intelligent agents across your operating model, architecture, and governance layers.\",\n118 |     recommendations: [\n119 |       \"Start with intelligent workforce capabilities as the anchor for your first production agents.\",\n120 |       \"Deploy agents in waves, prioritizing workflow automation in phase one.\",\n121 |       \"Align architecture investments to your existing systems landscape before scaling.\",\n122 |       \"Establish trust and governance controls as the non-negotiable baseline for every agent release.\",\n123 |     ],\n124 |     agentEcosystemDetail: \"24 agents recommended across workflow, service, and analytics domains to support enterprise-wide AI transformation.\",\n125 |     architectureDetail: \"A layered architecture spanning data & intelligence, AI & agent, orchestration, and integration layers — designed for composable enterprise scale.\",\n126 |     governanceDetail: \"Governance should emphasize trust, risk, security, compliance, and ethics before broad rollout across the organization.\",\n127 |     transformationNotes: [\n128 |       \"Phase timelines reflect a typical enterprise transformation cadence.\",\n129 |       \"Success metrics should track operational impact within the first 90 days.\",\n130 |       \"Generate a personalized blueprint by completing all inputs on the left.\",\n131 |     ],\n132 |   },\n133 | };\n134 | \n135 | const industryOperatingModel: Record<string, string[]> = {\n136 |   \"financial-services\": [\"Regulated Agent Workflows\", \"Fraud & Compliance Intelligence\", \"Client Service Copilots\", \"Risk-Aware Decisioning\"