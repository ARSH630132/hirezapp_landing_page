{"ts":"2026-06-27T17:21:11.887Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"nm9guvjn","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useCallback, useMemo } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  RefreshCw, Cpu, Activity, ShieldCheck, Layers, Play, Pause, \n  Terminal, Server, HelpCircle, ArrowUpRight, CheckCircle, Info \n} from \"lucide-react\";\nimport { WorkspaceCard } from \"@/components/private-app\";\n\nexport default function ClientAnalyticsPage() {\n  const router = useRouter();\n  const [data, setData] = useState<any>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  \n  // Polling states\n  const [isLive, setIsLive] = useState(true);\n  const [pollInterval, setPollInterval] = useState(2000); // ms\n  const [lastSync, setLastSync] = useState<string>(\"\");\n\n  // Regional telemetry states\n  const [selectedRegion, setSelectedRegion] = useState<\"global\" | \"sg\" | \"lon\">(\"global\");\n  \n  // Real-time points for SVG chart\n  const [pts, setPts] = useState<number[]>([42, 45, 38, 52, 48, 65, 58, 72, 69, 85, 78, 82]);\n  \n  // Interactive Terminal log stream\n  const [terminalLogs, setTerminalLogs] = useState<string[]>([]);\n\n  const load = useCallback(async (isSilent = false) => {\n    if (!isSilent) {\n      setLoading(true);\n      setError(null);\n    }\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        setError(\"AUTHENTICATION EXPIRED.\");\n        router.push(\"/portal/login\");\n        return;\n      }\n      const r = await fetch(\"/api/v1/analytics/client\", { \n        headers: { \"Authorization\": `Bearer ${token}` } \n      });\n      if (!r.ok) throw new Error(`Status ${r.status}`);\n      const d = await r.json();\n      if (d.success && d.summary) {\n        setData(d.summary);\n        setLastSync(new Date().toLocaleTimeString());\n      } else {\n        throw new Error(\"Malformed registry returned from gateway.\");\n      }\n    } catch (err: any) {\n      if (!isSilent) {\n        setError(err.message || \"Failed to establish secure link.\");\n      }\n    } finally {\n      if (!isSilent) {\n        setLoading(false);\n      }\n    }\n  }, [router]);\n\n  // Initial and periodic load\n  useEffect(() => {\n    load();\n  }, [load]);\n\n  // Telemetry graph loop\n  useEffect(() => {\n    if (!isLive) return;\n\n    const t = setInterval(() => {\n      // Shift values randomly with weighted boundaries based on selected region\n      setPts(p => {\n        const last = p[p.length - 1];\n        let baseMin = 20;\n        let baseMax = 95;\n        \n        if (selectedRegion === \"sg\") {\n          baseMin = 30;\n          baseMax = 65;\n        } else if (selectedRegion === \"lon\") {\n          baseMin = 15;\n          baseMax = 50;\n        }\n\n        const change = Math.floor(Math.random() * 16) - 8;\n        const next = Math.min(baseMax, Math.max(baseMin, last + change));\n        return [...p.slice(1), next];\n      });\n\n      // Silently sync with backend to keep values fresh if live\n      load(true);\n\n      // Generate simulated telemetry event\n      const events = [\n        `[TELEMETRY] Query parsed inside Intel SGX isolated enclave. Latency: ${selectedRegion === \"sg\" ? \"4.1\" : selectedRegion === \"lon\" ? \"3.2\" : \"3.7\"}ms`,\n        `[SECURITY] zero-trust eBPF host syscall filter checks passed (100% compliant)`,\n        `[HSM] Cryptographic seal checked with master hardware module. Signature validated.`,\n        `[NET] Dual-signatory TLS 1.3 tunnels active. Packet checksum verified.`,\n        `[COMPUTATION] Running localized route/mesh neural thread state updates.`\n      ];\n      const randomEvent = events[Math.floor(Math.random() * events.length)];\n      setTerminalLogs(prev => [`[${new Date().toLocaleTimeString()}] ${randomEvent}`, ...prev.slice(0, 8)]);\n\n    }, pollInterval);\n\n    return () => clearInterval(t);\n  }, [isLive, pollInterval, selectedRegion, load]);\n\n  // SVG Plot computations\n  const chartWidth = 500;\n  const chartHeight = 120;\n  const maxVal = useMemo(() => Math.max(...pts, 100), [pts]);\n  const minVal = useMemo(() => Math.min(...pts, 0), [pts]);\n  const range = maxVal - minVal || 1;\n\n  const areaPoints = useMemo(() => {\n    return [\n      `0,${chartHeight}`,\n      ...pts.map((val, idx) => {\n        const x = (idx / (pts.length - 1)) * chartWidth;\n        const y = chartHeight - ((val - minVal) / range) * (chartHeight - 20) - 10;\n        return `${x},${y}`;\n      }),\n      `${chartWidth},${chartHeight}`\n    ].join(\" \");\n  }, [pts, minVal, range]);\n\n  const linePoints = useMemo(() => {\n    return pts.map((val, idx) => {\n      const x = (idx / (pts.length - 1)) * chartWidth;\n      const y = chartHeight - ((val - minVal) / range) * (chartHeight - 20) - 10;\n      return `${x},${y}`;\n    }).join(\" \");\n  }, [pts, minVal, range]);\n\n  if (loading) {\n    return (\n      <div className=\"space-y-6 max-w-[1700px] mx-auto pb-16 font-mono p-6 text-white min-h-[400px] flex flex-col justify-center items-center\">\n        <RefreshCw className=\"w-8 h-8 text-[#009DFF] animate-spin mb-4\" />\n        <div className=\"text-xs text-white/50 animate-pulse uppercase tracking-widest\">Coupling Enclave Telemetry Matrix...</div>\n      </div>\n    );\n  }\n\n  if (error) {\n    return (\n      <div className=\"p-8 text-center max-w-md mx-auto my-16 font-mono text-white border border-red-500/10 bg-red-950/5 rounded-xl\">\n        <ShieldCheck className=\"w-8 h-8 text-red-400 mx-auto mb-4 animate-pulse\" />\n        <h3 className=\"text-sm font-bold uppercase tracking-wider mb-2\">TELEMETRY LINK BREACHED</h3>\n        <p className=\"text-white/50 text-[11px] leading-relaxed mb-4\">{error}</p>\n        <button \n          onClick={() => load(false)} \n          className=\"mx-auto h-8 px-4 rounded bg-white/5 hover:bg-white/10 border border-white/10 text-[10px] font-bold uppercase flex items-center gap-1.5 transition-colors cursor-pointer\"\n        >\n          <RefreshCw className=\"w-3.5 h-3.5\" /> Re-establish Link\n        </button>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"space-y-6 font-mono text-white max-w-[1700px] mx-auto select-none\">\n      \n      {/* Header section with live controls */}\n      <div className=\"flex flex-col md:flex-row justify-between items-start md:items-center border-b border-white/5 pb-4 gap-4\">\n        <div>\n          <h2 className=\"text-md font-bold uppercase tracking-wider text-white\">Sovereign Enclave Telemetry</h2>\n          <p className=\"text-[10px] text-white/45 mt-0.5\">Real-time cross-cluster neural spends and cryptographic sandbox isolation matrix.</p>\n        </div>\n        \n        <div className=\"flex flex-wrap items-center gap-3\">\n          <div className=\"flex items-center gap-1.5 bg-black/40 border border-white/5 rounded-lg p-1\">\n            <button \n              onClick={() => setIsLive(true)}\n              className={`h-6 px-2.5 rounded text-[9px] font-bold uppercase flex items-center gap-1 cursor-pointer transition-all ${isLive ? \"bg-[#00FFC2]/10 text-[#00FFC2] border border-[#00FFC2]/20 shadow-[0_0_10px_rgba(0,255,194,0.15)]\" : \"text-white/40 hover:text-white\"}`}\n            >\n              <Play className=\"w-2.5 h-2.5\" /> Live\n            </button>\n            <button \n              onClick={() => setIsLive(false)}\n              className={`h-6 px-2.5 rounded text-[9px] font-bold uppercase flex items-center gap-1 cursor-pointer transition-all ${!isLive ? \"bg-amber-500/10 text-amber-400 border border-amber-500/20\" : \"text-white/40 hover:text-white\"}`}\n            >\n              <Pause className=\"w-2.5 h-2.5\" /> Paused\n            </button>\n          </div>\n\n          <div className=\"flex items-center gap-1 bg-black/40 border border-white/5 rounded-lg p-1\">\n            {[1000, 2000, 5000].map(interval => (\n              <button\n                key={interval}\n                onClick={() => setPollInterval(interval)}\n                className={`h-6 px-2 rounded text-[9px] font-bold transition-all cursor-pointer ${pollInterval === interval ? \"bg-white/5 text-white\" : \"text-white/30 hover:text-white/60\"}`}\n              >\n                {interval / 1000}s\n              </button>\n            ))}\n          </div>\n\n          <button \n            onClick={() => load(false)} \n            className=\"h-8 px-3 rounded bg-white/5 hover:bg-white/10 border border-white/10 text-[10px] font-bold uppercase flex items-center gap-1.5 transition-all cursor-pointer\"\n          >\n            <RefreshCw className=\"w-3.5 h-3.5\" />\n            <span>Sync</span>\n          </button>\n        </div>\n      </div>\n\n      {/* Primary Telemetry Stream Grid */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Dynamic Telemetry Graph */}\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <Activity className=\"w-4 h-4 text-[#009DFF] animate-pulse\" />\n              <span className=\"text-xs font-bold uppercase tracking-wider\">Dynamic CPU Telemetry Matrix</span>\n            </div>\n            \n            <div className=\"flex items-center gap-1 bg-black/50 border border-white/5 rounded-lg p-1\">\n              {[\n                { id: \"global\", label: \"Global\" },\n                { id: \"sg\", label: \"Singapore A\" },\n                { id: \"lon\", label: \"London C\" }\n              ].map(reg => (\n                <button\n                  key={reg.id}\n                  onClick={() => setSelectedRegion(reg.id as any)}\n                  className={`h-6 px-2.5 rounded text-[9px] font-bold uppercase transition-all cursor-pointer ${selectedRegion === reg.id ? \"bg-white/5 text-white border border-white/10\" : \"text-white/30 hover:text-white\"}`}\n                >\n                  {reg.label}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* SVG Graph Area */}\n          <div className=\"h-44 bg-black/30 border border-white/5 rounded-xl relative overflow-hidden flex items-end\">\n            \n            {/* Grid Line Overlays */}\n            <div className=\"absolute inset-0 flex flex-col justify-between pointer-events-none p-3 opacity-30 select-none\">\n              <div className=\"w-full border-t border-dashed border-white/5 text-[8px] text-white/30 text-right\">95% MAX</div>\n              <div className=\"w-full border-t border-dashed border-white/5 text-[8px] text-white/30 text-right\">50% MID</div>\n              <div className=\"w-full border-t border-dashed border-white/5 text-[8px] text-white/30 text-right\">10% MIN</div>\n            </div>\n\n            <svg className=\"absolute inset-0 h-full w-full pointer-events-none\" viewBox={`0 0 ${chartWidth} ${chartHeight}`} preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"glowGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                  <stop offset=\"0%\" stopColor=\"#009DFF\" stopOpacity=\"0.2\" />\n                  <stop offset=\"100%\" stopColor=\"#009DFF\" stopOpacity=\"0.0\" />\n                </linearGradient>\n              </defs>\n\n              {/* Area Shading */}\n              <polygon fill=\"url(#glowGrad)\" points={areaPoints} className=\"transition-all duration-300\" />\n\n              {/* Core Line */}\n              <polyline fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"2\" points={linePoints} className=\"transition-all duration-300\" />\n              <polyline fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"6\" points={linePoints} className=\"opacity-15 blur-sm transition-all duration-300\" />\n            </svg>\n\n            {/* Dynamic Status Badges */}\n            <div className=\"absolute top-3 left-4 flex gap-4 select-none font-mono text-[9px]\">\n              <div>\n                <span className=\"text-white/30 block\">Current Capacity</span>\n                <span className=\"text-white font-bold text-xs\">{pts[pts.length - 1]}% Load</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block\">Peak Load</span>\n                <span className=\"text-[#00FFC2] font-bold text-xs\">{maxVal}%</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block\">Telemetry Status</span>\n                <span className=\"text-[#009DFF] font-bold text-xs uppercase animate-pulse\">{isLive ? \"Active Stream\" : \"Frozen\"}</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Regional Network Grid */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 flex flex-col justify-between\">\n          <div>\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2.5 mb-3.5\">\n              <Server className=\"w-4 h-4 text-purple-400\" />\n              <h3 className=\"text-xs font-bold uppercase tracking-wider\">Cluster Hardware Health</h3>\n            </div>\n            \n            <div className=\"space-y-3 text-[10px] text-white/60\">\n              {[\n                { label: \"Singapore Zone A\", spec: \"AMD SEV-SNP 64-C\", ping: \"4ms\", load: `${pts[pts.length - 1] - 5}%` },\n                { label: \"London Zone C\", spec: \"Intel SGX 32-Core\", ping: \"3ms\", load: `${Math.max(10, Math.floor(pts[pts.length - 1] / 1.6))}%` },\n                { label: \"Local Enclave Mesh\", spec: \"Decoupled Virtual HSM\", ping: \"1ms\", load: \"9.4% (Idle)\" }\n              ].map((node, i) => (\n                <div key={i} className=\"flex justify-between items-center border-b border-white/5 pb-2.5 last:border-0 last:pb-0\">\n                  <div>\n                    <span className=\"text-white block font-bold\">{node.label}</span>\n                    <span className=\"text-[8px] text-white/35 block uppercase font-mono mt-0.5\">{node.spec}</span>\n                  </div>\n                  <div className=\"text-right\">\n                    <span className=\"text-[#00FFC2] font-bold block\">{node.ping}</span>\n                    <span className=\"text-white/40 block text-[8px]\">{node.load}</span>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          <div className=\"bg-black/30 border border-white/5 p-3 rounded-lg text-[9px] text-white/40 leading-relaxed mt-4\">\n            <span className=\"text-white font-bold uppercase block mb-1 flex items-center gap-1\">\n              <CheckCircle className=\"w-3 h-3 text-[#00FFC2]\" /> Isolated Memory Seal\n            </span>\n            Memory enclaves are cryptographically protected via hardware-level keys. Hardware attestation states checked on last synchronized heartbeats.\n          </div>\n        </div>\n      </div>\n\n      {/* Dynamic Metrics Row */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[110px] hover:border-white/10 transition-all\">\n          <span className=\"text-[9px] font-bold uppercase tracking-wider flex items-center gap-1.5 text-[#009DFF]\"><Layers className=\"w-3.5 h-3.5\" /> Active Enclaves</span>\n          <span className=\"text-2xl font-bold tracking-tight\">{data?.projects?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/35\">Running Host Configurations: {data?.projects?.byStatus?.active || 0}</span>\n        </WorkspaceCard>\n        \n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[110px] hover:border-white/10 transition-all\">\n          <span className=\"text-[9px] font-bold uppercase tracking-wider flex items-center gap-1.5 text-purple-400\"><Cpu className=\"w-3.5 h-3.5\" /> Running AI Operations</span>\n          <span className=\"text-2xl font-bold tracking-tight\">{data?.aiOperations?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/35\">Healthy: {data?.aiOperations?.byHealth?.healthy || 0}</span>\n        </WorkspaceCard>\n        \n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[110px] hover:border-white/10 transition-all\">\n          <span className=\"text-[9px] font-bold uppercase tracking-wider flex items-center gap-1.5 text-[#00FFC2]\"><ShieldCheck className=\"w-3.5 h-3.5\" /> Compliancy Rules</span>\n          <span className=\"text-2xl font-bold tracking-tight\">{data?.governance?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/35\">Validated Standards: ISO-27001, SOC2, HIPAA</span>\n        </WorkspaceCard>\n      </div>\n\n      {/* Live Cryptographic Handshake Terminal Log Output */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/50 space-y-2.5\">\n        <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n          <div className=\"flex items-center gap-1.5\">\n            <Terminal className=\"w-3.5 h-3.5 text-white/40\" />\n            <span className=\"text-[10px] font-bold uppercase tracking-wider text-white/50\">SECURE SHELL TELEMETRY LOGSTREAM</span>\n          </div>\n          <span className=\"text-[8.5px] text-white/30 uppercase tracking-widest flex items-center gap-1 select-none\">\n            <span className=\"w-1.5 h-1.5 bg-[#00FFC2] rounded-full animate-ping\" /> Connection Sealed (TLS 1.3)\n          </span>\n        </div>\n        \n        <div className=\"space-y-1.5 max-h-[160px] overflow-y-auto font-mono text-[10px] text-white/60 pt-1 select-text scrollbar-thin\">\n          {terminalLogs.length === 0 ? (\n            <div className=\"text-white/20 italic\">Waiting for telemetry heartbeat cycles...</div>\n          ) : (\n            terminalLogs.map((log, idx) => (\n              <div key={idx} className=\"truncate flex gap-2\">\n                <span className=\"text-[#009DFF] shrink-0\">&gt;</span>\n                <span className=\"leading-tight\">{log}</span>\n              </div>\n            ))\n          )}\n        </div>\n      </div>\n\n      {/* Static premium bottom info bar */}\n      <div className=\"flex flex-col md:flex-row justify-between items-center text-[9px] text-white/30 pt-2 border-t border-white/5 gap-2 select-none\">\n        <span>ENCLAVE DISPATCH EPOCH: 2026.E3 • LAST SYNC: {lastSync || \"NEVER\"}</span>\n        <span>SHA-256 SESSION VECTOR DECAPSULATED DIRECTLY IN LOCAL HOST CONTAINER</span>\n      </div>\n\n    </div>\n  );\n}\n"}}}
