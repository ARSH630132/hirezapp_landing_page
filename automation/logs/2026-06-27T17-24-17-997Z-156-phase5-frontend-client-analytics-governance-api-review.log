85 |     documents.forEach(d => {\n 86 |       const status = d.status || \"unknown\";\n 87 |       documentsByStatus[status] = (documentsByStatus[status] || 0) + 1;\n 88 |     });\n 89 | \n 90 |     // Aggregate Invoices\n 91 |     const invoicesByStatus: Record<string, number> = {};\n 92 |     invoices.forEach(i => {\n 93 |       const status = i.status || \"unknown\";\n 94 |       invoicesByStatus[status] = (invoicesByStatus[status] || 0) + 1;\n 95 |     });\n 96 | \n 97 |     // Aggregate Support Tickets\n 98 |     const supportByStatus: Record<string, number> = {};\n 99 |     const supportByPriority: Record<string, number> = {};\n100 |     supportTickets.forEach(t => {\n101 |       const status = t.status || \"unknown\";\n102 |       supportByStatus[status] = (supportByStatus[status] || 0) + 1;\n103 |       const priority = t.priority || \"unknown\";\n104 |       supportByPriority[priority] = (supportByPriority[priority] || 0) + 1;\n105 |     });\n106 | \n107 |     // Aggregate Governance\n108 |     const governanceByStatus: Record<string, number> = {};\n109 |     const governanceBySeverity: Record<string, number> = {};\n110 |     governance.forEach(g => {\n111 |       const status = g.status || \"unknown\";\n112 |       governanceByStatus[status] = (governanceByStatus[status] || 0) + 1;\n113 |       const severity = g.severity || \"unknown\";\n114 |       governanceBySeverity[severity] = (governanceBySeverity[severity] || 0) + 1;\n115 |     });\n116 | \n117 |     return NextResponse.json({\n118 |       success: true,\n119 |       summary: {\n120 |         projects: {\n121 |           totalCount: projects.length,\n122 |           byStatus: projectsByStatus,\n123 |           byPhase: projectsByPhase\n124 |         },\n125 |         aiOperations: {\n126 |           totalCount: operations.length,\n127 |           byStatus: operationsByStatus,\n128 |           byHealth: operationsByHealth\n129 |         },\n130 |         documents: {\n131 |           totalCount: do