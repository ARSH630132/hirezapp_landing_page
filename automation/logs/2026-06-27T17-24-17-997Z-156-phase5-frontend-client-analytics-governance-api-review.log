\"h-8 px-3 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 transition-colors flex items-center gap-1.5 cursor-pointer disabled:opacity-40 animate-none\"\n513 |           >\n514 |             <RefreshCw className={`w-3.5 h-3.5 ${loading ? \"animate-spin\" : \"\"}`} />\n515 |             <span>Sync</span>\n516 |           </button>\n517 |           <div className=\"text-[10px] text-white/45 bg-white/[0.01] border border-white/5 px-2.5 py-1.5 rounded-lg\">\n518 |             Enclave Epoch: <span className=\"text-white font-bold font-mono\">2026.E3</span>\n519 |           </div>\n520 |         </div>\n521 |       </div>\n522 | \n523 |       {/* Bento Grid: Metrics and Interceptor Diagram */}\n524 |       <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n525 |         \n526 |         {/* Metric Cards */}\n527 |         <div className=\"flex flex-col gap-4\">\n528 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px] border-[#00FFC2]/10\">\n529 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n530 |               <span className=\"text-white/45 uppercase tracking-wider\">Dynamic Trust Index</span>\n531 |               <StatusBadge state=\"active\" label=\"continuous check\" />\n532 |             </div>\n533 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n534 |               <div className=\"text-3xl font-bold text-white font-mono\">{trustScore}%</div>\n535 |               <span className=\"text-[9.5px] text-emerald-400 flex items-center gap-1\">\n536 |                 Optimized <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n537 |               </span>\n538 |             </div>\n539 |           </WorkspaceCard>\n540 | \n541 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px]\">\n542 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n543 |               <span className=\"text-white/45 uppercase tracking-wider\">AI Guardrails & Policies</span>\n544 |               <span className=\"text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20\">ACTIVE</span>\n545 |             </div>\n546 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n547 |               <div className=\"text-3xl font-bold text-white\">{policies.length}</div>\n548 |               <span className=\"text-[9.5px] text-white/40\">\n549 |                 {policies.filter(p => p.status === \"compliant\").length} Safe • {policies.filter(p => p.status !== \"compliant\").length} Alerts\n550 |               </span>\n551 |             </div>\n552 |           </WorkspaceCard>\n553 | \n554 |           <WorkspaceCard className={`flex flex-col justify-between h-[105px] transition-all ${pendingCount > 0 ? \"border-amber-500/20 bg-amber-500/[0.01]\" : \"\"}`}>\n555 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n556 |               <span className=\"text-white/45 uppercase tracking-wider\">Pending Interlocks</span>\n557 |               {pendingCount > 0 ? (\n558 |                 <span className=\"text-amber-400 bg-amber-400/10 px-1.5 py-0.5 rounded border border-amber-400/20 animate-pulse\">SIGN REQUIRED</span>\n559 |               ) : (\n560 |                 <span className=\"text-white/30\">ALL SIGNED</span>\n561 |               )}\n562 |             </div>\n563 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n564 |               <div className=\"text-3xl font-bold text-white\">{pendingCount}</div>\n565 |               <span className=\"text-[9.5px] text-white/40\">Awaiting client credentials</span>\n566 |             </div>\n567 |           </WorkspaceCard>\n568 |         </div>\n569 | \n570 |         {/* Dynamic Topology Flow Diagram */}\n571 |         <div className=\"lg:col-span-2\">\n572 |           <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n573 |             <style dangerouslySetInnerHTML={{ __html: `\n574 |               @keyframes flow { to { stroke-dashoffset: -20; } }\n575 |               .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n576 |             `}} />\n577 | \n578 |             <div className=\"flex-grow flex flex-col justify-between gap-4\">\n579 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n580 |                 <div className=\"flex items-center gap-1.5 font-mono text-[11px]\">\n581 |                   <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n582 |                   <span className=\"font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n583 |                 </div>\n584 |                 <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology</span>\n585 |               </div>\n586 | \n587 |               <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n588 |                 <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n589 |                   <svg className=\"w-full h-[2px] overflow-visible\">\n590 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n591 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n592 |                   </svg>\n593 |                 </div>\n594 | \n595 |                 {steps.map((st, idx) => {\n596 |                   const isActive = step === st.id;\n597 |                   const clr = \n598 |                     st.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n599 |                     st.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n600 |                     st.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n601 |                     st.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" : \"border-emerald-500/10 text-emerald-400\";\n602 |                   \n603 |                   const activeStyle = isActive \n604 |                     ? \"shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102\" \n605 |                     : \"bg-black/45 hover:border-white/10\";\n606 | \n607 |                   return (\n608 |                     <button \n609 |                       key={st.id} \n610 |                       onClick={() => setStep(st.id)}\n611 |                       className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${clr} ${activeStyle}`}\n612 |                     >\n613 |                       <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"}`}>\n614 |                         {st.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n615 |                         {st.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n616 |                         {st.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n617 |                         {st.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n618 |                         {st.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n619 |                       </div>\n620 |                       <div className=\"text-center font-mono select-none\">\n621 |                         <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n622 |                         <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">{st.id === \"step-1\" ? \"Ingress\" : st.id === \"step-2\" ? \"Guardrail\" : st.id === \"step-3\" ? \"Enclave\" : st.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}</span>\n623 |                       </div>\n624 |                     </button>\n625 |                   );\n626 |                 })}\n627 |               </div>\n628 |             </div>\n629 | \n630 |             {/* Node Telemetry Details card */}\n631 |             <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n632 |               {(() => {\n633 |                 const info = steps.find(s => s.id === step) || steps[0];\n634 |                 return (\n635 |                   <div className=\"space-y-3 h-full flex flex-col justify-between\">\n636 |                     <div className=\"space-y-1.5\">\n637 |                       <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">REALTIME METRICS</span>\n638 |                       <p className=\"text-white font-bold text-[11px] leading-tight\">{info.title}</p>\n639 |                       \n640 |                       <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n641 |                         <span className={`w-1 h-1 rounded-full ${step === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n642 |                         <span className=\"text-white/40\">Status:</span>\n643 |                         <span className={`font-bold ${step === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>{info.val}</span>\n644 |                       </div>\n645 |                       <p className=\"text-[10px] text-white/50 leading-normal pt-1\">{info.desc}</p>\n646 |                     </div>\n647 |                     \n648 |                     <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 select-none\">\n649 |                       <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n650 |                       <span>Mathematical boundary verified</span>\n651 |                     </div>\n652 |                   </div>\n653 |                 );\n654 |               })()}\n655 |             </div>\n656 | \n657 |           </div>\n658 |         </div>\n659 | \n660 |       </div>\n661 | \n662 |       {/* Dynamic Filters panel */}\n663 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#070707]/60 backdrop-blur-sm space-y-3 font-mono\">\n664 |         <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n665 |           <div className=\"flex items-center gap-1.5\">\n666 |             <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/50\" />\n667 |             <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Workspace Filters</h3>\n668 |           </div>\n669 |           {(selProj || selAgent || selStatus || selSeverity || search) && (\n670 |             <button onClick={resetAll} className=\"flex items-center gap-1 text-[10px] text-amber-500 hover:text-amber-400 cursor-pointer\">\n671 |               <RotateCcw className=\"w-3 h-3\" /> Reset Filters\n672 |             </button>\n673 |           )}\n674 |         </div>\n675 | \n676 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n677 |           \n678 |           <div>\n679 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Project Target</label>\n680 |             <select \n681 |               value={selProj} \n682 |               onChange={(e) => { setSelProj(e.target.value); triggerToast(\"Filter: Project target updated\", \"info\"); }}\n683 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n684 |             >\n685 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL PROJECTS</option>\n686 |               {projectOptions.map(p => <option key={p.id} value={p.id} className=\"bg-[#0c0c0c] text-white\">{p.name.toUpperCase()}</option>)}\n687 |             </select>\n688 |           </div>\n689 | \n690 |           <div>\n691 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Sovereign Agent</label>\n692 |             <select \n693 |               value={selAgent} \n694 |               onChange={(e) => { setSelAgent(e.target.value); triggerToast(\"Filter: Agent target updated\", \"info\"); }}\n695 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n696 |             >\n697 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL AGENTS</option>\n698 |               {agentOptions.map(a => <option key={a.id} value={a.id} className=\"bg-[#0c0c0c] text-white\">{a.name}</option>)}\n699 |             </select>\n700 |           </div>\n701 | \n702 |           <div>\n703 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Compliance State</label>\n704 |             <select \n705 |               value={selStatus} \n706 |               onChange={(e) => { setSelStatus(e.target.value); triggerToast(\"Filter: State updated\", \"info\"); }}\n707 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n708 |             >\n709 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL STATES</option>\n710 |               <option value=\"compliant\" className=\"bg-[#0c0c0c] text-green-400\">COMPLIANT</option>\n711 |               <option value=\"warning\" className=\"bg-[#0c0c0c] text-amber-400\">WARNING ALERT</option>\n712 |               <option value=\"critical\" className=\"bg-[#0c0c0c] text-red-400\">CRITICAL FAULT</option>\n713 |             </select>\n714 |           </div>\n715 | \n716 |           <div>\n717 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Risk Severity</label>\n718 |             <select \n719 |               value={selSeverity} \n720 |               onChange={(e) => { setSelSeverity(e.target.value); triggerToast(\"Filter: Severity updated\", \"info\"); }}\n721 |               className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n722 |             >\n723 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL SEVERITIES</option>\n724 |               <option value=\"high\" className=\"bg-[#0c0c0c] text-red-400 font-bold\">HIGH RISK</option>\n725 |               <option value=\"medium\" className=\"bg-[#0c0c0c] text-amber-400\">MEDIUM RISK</option>\n726 |               <option value=\"low\" className=\"bg-[#0c0c0c] text-blue-400\">LOW RISK</option>\n727 |             </select>\n728 |           </div>\n729 | \n730 |           <div>\n731 |             <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Log Search</label>\n732 |             <div className=\"relative\">\n733 |               <Search className=\"absolute left-2 top-2.5 w-3.5 h-3.5 text-white/35 font-mono\" />\n734 |               <input \n735 |                 type=\"text\" \n736 |                 value={search} \n737 |                 onChange={(e) => setSearch(e.target.value)}\n738 |                 placeholder=\"Search rule standard or ID...\"\n739 |                 className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] pl-7.5 pr-7 text-[10.5px] text-white outline-none focus:border-white/10\"\n740 |               />\n741 |               {search && <X className=\"absolute right-2 top-2.5 w-3.5 h-3.5 text-white/40 cursor-pointer font-mono\" onClick={() => setSearch(\"\")} />}\n742 |             </div>\n743 |           </div>\n744 | \n745 |         </div>\n746 |       </div>\n747 | \n748 |       {/* Tabs list */}\n749 |       <div className=\"space-y-4 font-mono\">\n750 |         <div className=\"flex border-b border-white/5 gap-6 select-none text-xs\">\n751 |           <button onClick={() => setTab(\"pols\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"pols\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n752 |             <span>AI Checks & Policies</span>\n753 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredPols.length}</span>\n754 |             {tab === \"pols\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n755 |           </button>\n756 |           \n757 |           <button onClick={() => setTab(\"oversight\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"oversight\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n758 |             <span>Human Oversight Interlocks</span>\n759 |             <span className={`px-1 rounded text-[9px] ${pendingCount > 0 ? \"bg-amber-400/10 text-amber-500\" : \"bg-white/5 text-white/50\"}`}>{filteredOversights.length}</span>\n760 |             {tab === \"oversight\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n761 |           </button>\n762 | \n763 |           <button onClick={() => setTab(\"docs\")} className={`py-2 font-bold uppercase transition-all relative flex items-center gap-1.5 cursor-pointer ${tab === \"docs\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"}`}>\n764 |             <span>Document Ledger</span>\n765 |             <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredDocs.length}</span>\n766 |       