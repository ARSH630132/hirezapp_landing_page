FF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[11px] uppercase tracking-wider transition-all disabled:opacity-50 cursor-pointer font-semibold\">\n          {attesting ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <ShieldCheck className=\"w-3.5 h-3.5\" />}\n          {attesting ? \"Attesting...\" : \"Verify Attestation\"}\n        </button>\n      </div>\n\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 font-mono text-[11px]\">\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] font-semibold\">CPU ALLOCATION</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"0%\" : isWarning ? \"94%\" : \"42%\"}</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div className=\"bg-emerald-500 h-full\" style={{ width: isDecoupled ? \"0%\" : isWarning ? \"94%\" : \"42%\" }} />\n          </div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] font-semibold\">RAM UTILIZATION</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"0%\" : isWarning ? \"89%\" : \"52%\"}</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div className=\"bg-[#009DFF] h-full\" style={{ width: isDecoupled ? \"0%\" : isWarning ? \"89%\" : \"52%\" }} />\n          </div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] font-semibold\">PULSE LATENCY</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"999 ms\" : isWarning ? \"88 ms\" : \"12 ms\"}</div>\n          <span className={`text-[9px] font-bold uppercase ${isWarning ? \"text-amber-400\" : isDecoupled ? \"text-white/30\" : \"text-emerald-400\"}`}>\n       