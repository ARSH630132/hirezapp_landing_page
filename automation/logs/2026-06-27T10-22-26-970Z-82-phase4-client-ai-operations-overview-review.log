ing SHA-256 integrity hash against secure ledger...\",\n      \"Validating eBPF telemetry hooks isolation metrics...\",\n      \"Zero-Trust key verification sequence completed.\"\n    ];\n\n    steps.forEach((step, index) => {\n      setTimeout(() => {\n        setAttestationSteps(prev => [...prev, `[${new Date().toLocaleTimeString()}] ${step}`]);\n        if (index === steps.length - 1) {\n          setAttestationRunning(false);\n          setAttestationComplete(true);\n        }\n      }, (index + 1) * 800);\n    });\n  };\n\n  const badgeState = agent.status === \"active\" ? \"active\" : agent.status === \"evaluating\" ? \"warning\" : agent.status === \"warning\" ? \"error\" : \"decoupled\";\n\n  return (\n    <div className=\"space-y-6\">\n      {/* HEADER SECTION */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n        <div className=\"flex items-center gap-4\">\n          <button\n            onClick={() => router.push(\"/portal/ai-operations\")}\n            className=\"p-2 rounded-lg border border-white/10 bg-white/[0.02] text-white/50 hover:text-white hover:bg-white/[0.06] cursor-pointer transition-all\"\n            aria-label=\"Back to AI Operations Overview\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider\">\n                {agent.type.toUpperCase()}\n              </span>\n              <StatusBadge state={badgeState} label={agent.status} />\n            </div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono mt-1 uppercase flex items-center gap-2\">\n              <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n              {agent.name}\n            </h2>\n          </div>\n        </div>\n\n        <div className=\"flex gap-2\">\n          <button\n            onClick={triggerAttestation}\n            disabled={attestationRunning}\n            className=\"inline-flex h-9 px-4 items-center justify-center gap-2 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[11px] uppercase tracking-wider transition-all disabled:opacity-50 cursor-pointer\"\n          >\n            {attestationRunning ? (\n              <>\n                <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n                Attesting Enclave...\n              </>\n            ) : (\n              <>\n                <ShieldCheck className=\"w-3.5 h-3.5\" />\n                Verify Hardware Attestation\n              </>\n            )}\n          </button>\n        </div>\n      </div>\n\n      {/* METRICS ROW */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 font-mono text-[11px]\">\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] tracking-wider\">CPU ALLOCATION</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.cpu}%</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div \n              className=\"bg-emerald-500 h-full rounded-full transition-all duration-500\" \n              style={{ width: `${agent.cpu}%` }}\n            />\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] tracking-wider\">RAM UTILIZATION</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.ram}%</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div \n              className=\"bg-[#009DFF] h-full rounded-full transition-all duration-500\" \n              style={{ width: `${agent.ram}%` }}\n            />\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] tracking-wider\">PULSE LATENCY</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.latency} ms</div>\n          <div className=\"flex items-center gap-1 text-[9px] text-emerald-400 font-bold\">\n            <CheckCircle2 className=\"w-3 h-3\" />\n            STABLE LIMITS\n          </div>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px] tracking-wider\">CERTIFIED UPTIME</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.uptime}%</div>\n          <div className=\"text-[9px] text-[#009DFF] font-bold uppercase tracking-wider\">\n            ZERO COMPROMISE RATIO\n          </div>\n        </WorkspaceCard>\n      </div>\n\n      {/* DETAILED ANALYSIS */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        {/* LEFT COLUMN: SPECS & TIMELINE */}\n        <div className=\"lg:col-span-2 space-y-6\">\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n              <Bot className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">Neural Parameter Mapping</h3>\n            </div>\n            \n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-[12px] font-mono text-white/70\">\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Model Architecture:</span>\n                <span className=\"text-white font-bold\">{agent.model}</span>\n              </div>\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Context State Cache:</span>\n                <span className=\"text-[#00FFC2] font-bold\">{agent.contextCache}</span>\n              </div>\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Inference Thread Pool:</span>\n                <span className=\"text-white font-bold\">{agent.threads} Parallel Workers</span>\n              </div>\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Temperature Enclave:</span>\n                <span className=\"text-white font-bold\">{agent.temperature}</span>\n              </div>\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Enclave Isolation:</span>\n                <span className=\"text-[#009DFF] font-bold\">{agent.isolation}</span>\n              </div>\n              <div className=\"p-3.5 bg-black/30 border border-white/5 rounded-lg flex justify-between items-center\">\n                <span className=\"text-white/40\">Project Bounds:</span>\n                <span className=\"text-white truncate max-w-[150px] font-bold\">{agent.projectName}</span>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n              <Terminal className=\"w-4 h-4 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">eBPF Telemetry Event Streams</h3>\n            </div>\n            <div className=\"space-y-3 font-mono text-[11px] text-white/50 bg-black/40 border border-white/5 p-4 rounded-xl max-h-64 overflow-y-auto\">\n              {agent.logs.map((log, index) => (\n                <div key={index} className=\"flex justify-between items-center border-b border-white/5 pb-2 last:border-0 last:pb-0\">\n                  <span className=\"flex items-center gap-1.5\">\n                    <span className=\"text-white/20\">&gt;</span>\n                    {log}\n                  </span>\n                  <span className=\"text-emerald-400 font-bold text-[10px] uppercase\">VERIFIED</span>\n                </div>\n              ))}\n              <div className=\"flex justify-between items-center text-white/30 pt-1\">\n                <span className=\"flex items-center gap-1.5\">\n                  <span className=\"text-white/20\">&gt;</span>\n                  Continuous zero-knowledge log loop tracking...\n                </span>\n                <span className=\"text-[#009DFF] font-mono animate-pulse text-[9px] uppercase font-bold\">MONITORING</span>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          {/* DYNAMIC ATTESTATION RESULTS TERMINAL */}\n          {(attestationRunning || attestationComplete) && (\n            <WorkspaceCard className=\"border border-[#00FFC2]/20 bg-emerald-950/5 p-5 space-y-4 rounded-xl\">\n              <div className=\"flex items-center justify-between border-b border-[#00FFC2]/10 pb-3\">\n                <div className=\"flex items-center gap-2\">\n                  <ShieldCheck className=\"w-5 h-5 text-[#00FFC2]\" />\n                  <h4 className=\"text-xs font-bold text-white font-mono uppercase tracking-widest\">\n                    Hardware Attestation Output\n                  </h4>\n                </div>\n                {attestationComplete ? (\n                  <span className=\"text-[10px] px-2 py-0.5 rounded bg-[#00FFC2]/10 border border-[#00FFC2]/20 text-[#00FFC2] font-bold font-mono\">\n                    PASS\n                  </span>\n                ) : (\n                  <span className=\"text-[10px] px-2 py-0.5 rounded bg-amber-400/10 border border-amber-400/20 text-amber-400 font-bold font-mono animate-pulse\">\n                    RUNNING TESTS\n                  </span>\n                )}\n              </div>\n\n              <div className=\"space-y-2 font-mono text-[10.5px] bg-black/50 p-4 rounded-lg text-white/60\">\n                {attestationSteps.map((step, idx) => (\n                  <div key={idx} className=\"flex items-center gap-2\">\n                    <span className=\"text-[#00FFC2]\">✔</span>\n                    <span>{step}</span>\n                  </div>\n                ))}\n                {attestationRunning && (\n                  <div className=\"flex items-center gap-2 text-white/30 animate-pulse\">\n                    <span className=\"h-1.5 w-1.5 rounded-full bg-[#009DFF]\" />\n                    <span>Executing cryptoprocessor verification trace...</span>\n                  </div>\n                )}\n                {attestationComplete && (\n                  <div className=\"border-t border-[#00FFC2]/10 pt-3 mt-3 text-center text-[#00FFC2] font-bold text-[11px] uppercase\">\n                    Silicon cryptographic signatures match. Secure partition is 100% genuine.\n                  </div>\n                )}\n              </div>\n            </WorkspaceCard>\n          )}\n        </div>\n\n        {/* RIGHT COLUMN: SECURITY MODEL DIAGRAM */}\n        <div className=\"space-y-6\">\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n              <Shield className=\"w-4 h-4 text-emerald-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">\n                Silicon-Level Enclave Map\n              </h3>\n            </div>\n            \n            <p className=\"text-[10.5px] font-mono text-white/45 leading-relaxed\">\n              This node's threads and weights are loaded exclusively inside physical hardware secure boundaries. Decoupled host architectures cannot inject parameters.\n            </p>\n\n            {/* HIGH-FIDELITY DIAGRAM OF ENCLAVE */}\n            <div className=\"border border-white/5 bg-black/40 rounded-xl p-4 font-mono text-[9px] relative overflow-hidden space-y-4\">\n              <div className=\"absolute inset-0 opacity-5 pointer-events-none bg-[radial-gradient(#009DFF_1px,transparent_1px)] [background-size:10px_10px]\" />\n              \n              <div className=\"border border-white/10 p-2.5 rounded text-center bg-white/[0.01]\">\n                <span className=\"text-white/45 block uppercase text-[8px]\">HOST ARCHITECTURE</span>\n                <span className=\"text-white font-medium\">Bare-Metal Sovereign Node</span>\n              </div>\n\n              <div className=\"flex items-center justify-center py-1\">\n                <div className=\"h-6 w-0.5 bg-[#009DFF]/30 relative\">\n                  <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-2 w-2 rounded-full bg-[#009DFF]\" />\n                </div>\n              </div>\n\n              <div className=\"border border-[#009DFF]/30 p-3 rounded bg-[#009DFF]/5 text-center relative\">\n                <div className=\"absolute top-1.5 right-1.5 h-1.5 w-1.5 rounded-full bg-[#009DFF]\" />\n                <span className=\"text-[#009DFF] font-bold block text-[10px] uppercase\">{agent.isolation}</span>\n                <span className=\"text-white/60 block mt-1 leading-normal\">\n                  Isolated Cryptographic RAM Segment Enclave\n                </span>\n                <div className=\"mt-2.5 flex items-center justify-center gap-1.5 text-emerald-400 font-bold bg-[#00FFC2]/5 border border-[#00FFC2]/15 px-2 py-0.5 rounded uppercase text-[8px]\">\n                  <Lock className=\"w-2.5 h-2.5\" />\n                  KEY INDEX LOCK ACTIVE\n                </div>\n              </div>\n\n              <div className=\"flex items-center justify-center py-1\">\n                <div className=\"h-6 w-0.5 bg-emerald-500/30 relative\">\n                  <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-2 w-2 rounded-full bg-emerald-500\" />\n                </div>\n              </div>\n\n              <div className=\"border border-emerald-500/30 p-3 rounded bg-emerald-500/5 text-center\">\n                <span className=\"text-emerald-400 font-bold block text-[9.5px] uppercase\">GUEST RUNTIME</span>\n                <span className=\"text-white block mt-1 leading-normal font-bold\">\n                  {agent.name} Sandbox Enclave\n                </span>\n                <span className=\"text-white/45 block mt-1\">\n                  Context Index Space: {agent.contextCache}\n                </span>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className=\"p-5 space-y-4 bg-gradient-to-br from-[#02050e] to-[#010204] border border-[#009DFF]/15\">\n            <div className=\"flex items-center gap-2 text-[#009DFF] font-mono\">\n              <Zap className=\"w-4 h-4 animate-pulse\" />\n              <span className=\"text-[10px] font-bold tracking-widest uppercase\">Operator Diagnostics</span>\n            </div>\n            <h4 className=\"text-[13px] font-bold text-white font-mono uppercase\">Decoupled Maintenance Mode</h4>\n            <p className=\"text-[10.5px] font-mono text-white/50 leading-relaxed\">\n              Need physical intervention or register reset? Open a high-priority ticket with GFF AI Operations Support to deploy HSM keys reset or scale allocated RAM frames instantly.\n            </p>\n            <Link \n              href=\"/portal/support\"\n              className=\"w-full inline-flex h-8 px-4 items-center justify-center gap-1.5 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 text-white font-mono font-bold text-[10px] uppercase tracking-wider transition-all\"\n            >\n              Contact Support\n            </Link>\n          </WorkspaceCard>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
