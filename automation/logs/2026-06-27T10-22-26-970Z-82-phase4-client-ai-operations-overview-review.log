d:grid-cols-2 gap-4 text-[12px] font-mono text-white/70\">\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Model Architecture:</span>\n                <span className=\"text-white font-bold\">GFF-Llama-70B-v4</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Context State Cache:</span>\n                <span className=\"text-emerald-400 font-bold\">DECOUPLED (128k)</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Inference Thread Pool:</span>\n                <span className=\"text-white\">32 Parallel Workers</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Temperature Enclave:</span>\n                <span className=\"text-white\">0.15 Enforced</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <h3 className=\"text-sm font-bold text-white font-mono uppercase border-b border-white/5 pb-2\">eBPF Telemetry Event Streams</h3>\n            <div className=\"space-y-2.5 font-mono text-[11px] text-white/50\">\n              <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                <span>[06:12:15] Context cache sync handshake initiated</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">SUCCESS</span>\n              </div>\n              <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                <span>[06:12:15] Guardrail safety policy matching score: 1.0</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">VERIFIED</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span>[06:12:16] Token count: 1.2M. Spend budget caps verified</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">OK</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n              <Shield className=\"w-4 h-4 text-green-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Guardrail Shield</h3>\n            </div>\n            <div className=\"space-y-3 font-mono text-[11px]\">\n              <div className=\"p-3 bg-green-500/5 border border-green-500/20 text-green-400 font-bold rounded flex items-center justify-between\">\n                <span>OVERRIDE SHIELD:</span>\n                <span>ACTIVE</span>\n              </div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">\n                All sensory outputs of this agent run are bound within secure sandbox overlays, fully protected against system privilege escalations or compliance drift.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { ArrowLeft, Bot, Shield, Cpu, Terminal, RefreshCw, ShieldCheck } from \"lucide-react\";\nimport { WorkspaceCard, StatusBadge } from \"@/components/private-app\";\n\nexport default function ClientAiOperationsDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const agentId = typeof id === \"string\" ? id : \"RETAIL-CORE-A1\";\n  const [attesting, setAttesting] = useState(false);\n  const [complete, setComplete] = useState(false);\n\n  const triggerAttestation = () => {\n    if (attesting) return;\n    setAttesting(true); setComplete(false);\n    setTimeout(() => { setAttesting(false); setComplete(true); }, 1200);\n  };\n\n  const isWarning = agentId.includes(\"H9\") || agentId.includes(\"004\");\n  const isDecoupled = agentId.includes(\"Z1\") || agentId.includes(\"005\");\n  const status = isDecoupled ? \"decoupled\" : isWarning ? \"warning\" : \"active\";\n\n  return (\n    <div className=\"space-y-6 font-mono text-[11px]\">\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n        <div className=\"flex items-center gap-4\">\n          <button onClick={() => router.push(\"/portal/ai-operations\")} className=\"p-2 rounded-lg border border-white/10 bg-white/[0.02] text-white/50 hover:text-white cursor-pointer\">\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[10px] text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase font-semibold\">\n                {isWarning ? \"Medical Enclave\" : isDecoupled ? \"Transport Node\" : \"Core Telemetry\"}\n              </span>\n              <StatusBadge state={status} label={status} />\n            </div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono mt-1 uppercase flex items-center gap-2\">\n              <Cpu className=\"w-5 h-5 text-[#009DFF]\" /> {agentId}\n            </h2>\n          </div>\n        </div>\n        <button onClick={triggerAttestation} disabled={attesting} className=\"inline-flex h-9 px-4 items-center justify-center gap-2 rounded-lg bg-[#009DFF] text-white uppercase tracking-wider disabled:opacity-50 cursor-pointer font-bold\">\n          {attesting ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <ShieldCheck className=\"w-3.5 h-3.5\" />}\n          {attesting ? \"Attesting...\" : \"Verify Attestation\"}\n        </button>\n      </div>\n\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block text-[9px]\">CPU ALLOCATION</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"0%\" : isWarning ? \"94%\" : \"42%\"}</div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block text-[9px]\">RAM UTILIZATION</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"0%\" : isWarning ? \"89%\" : \"52%\"}</div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block text-[9px]\">PULSE LATENCY</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"999 ms\" : isWarning ? \"88 ms\" : \"12 ms\"}</div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block text-[9px]\">CERTIFIED UPTIME</span>\n          <div className=\"text-2xl font-bold text-white\">{isDecoupled ? \"98.71%\" : isWarning ? \"99.95%\" : \"99.99%\"}</div>\n        </WorkspaceCard>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6 text-[12px]\">\n        <div className=\"lg:col-span-2 space-y-6\">\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <h3 className=\"text-sm font-bold text-white uppercase border-b border-white/5 pb-2\">Neural Parameter Mapping</h3>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-white/70\">\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span>Model:</span> <span className=\"text-white font-bold\">{isWarning ? \"GFF-Med-34B\" : \"GFF-Llama-70B\"}</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span>Isolation Type:</span> <span className=\"text-[#009DFF] font-bold\">{isWarning ? \"HSM Enclave\" : \"AMD SEV-SNP\"}</span>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <h3 className=\"text-sm font-bold text-white uppercase border-b border-white/5 pb-2\">eBPF Telemetry Event Streams</h3>\n            <div className=\"space-y-2 text-[11px] text-white/50 bg-black/40 border border-white/5 p-4 rounded-xl\">\n              {isDecoupled ? (\n                <div>[23:55:00] Enclave decoupled by operator. OK</div>\n              ) : (\n                <>\n                  <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                    <span>[06:12:15] Context cache sync handshake completed</span> <span className=\"text-emerald-400 font-bold\">SUCCESS</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span>[06:12:16] Token count verification complete</span> <span className=\"text-emerald-400 font-bold\">VERIFIED</span>\n                  </div>\n                </>\n              )}\n            </div>\n          </WorkspaceCard>\n\n          {complete && (\n            <WorkspaceCard className=\"border border-[#00FFC2]/20 bg-emerald-950/5 p-5 space-y-4 rounded-xl\">\n              <h4 className=\"text-xs font-bold text-white uppercase\">Attestation Results</h4>\n              <div className=\"text-[11px] bg-black/50 p-4 rounded-lg text-white/60 space-y-1\">\n                <div>✔ Silicon registers accessed successfully.</div>\n                <div>✔ Hardware cryptographic signature matches ledger.</div>\n                <div className=\"text-emerald-400 font-bold text-center pt-2 uppercase\">Secure Enclave Genuine & Verified</div>\n              </div>\n            </WorkspaceCard>\n          )}\n        </div>\n\n        <div className=\"space-y-6\">\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <h3 className=\"text-xs font-bold text-white uppercase border-b border-white/5 pb-2\">Silicon Enclave Map</h3>\n            <div className=\"border border-white/5 bg-black/40 rounded-xl p-4 text-[9px] space-y-3\">\n              <div className=\"border border-white/10 p-2 rounded text-center bg-white/[0.01]\">\n                <span className=\"text-white/45 block uppercase text-[8px]\">HOST LAYER</span>\n                <span className=\"text-white font-medium\">Bare-Metal Sovereign Node</span>\n              </div>\n              <div className=\"border border-[#009DFF]/30 p-2.5 rounded bg-[#009DFF]/5 text-center\">\n                <span className=\"text-[#009DFF] font-bold block uppercase text-[8px]\">{isWarning ? \"HSM Enclave\" : \"AMD SEV-SNP\"}</span>\n                <span className=\"text-white/60 block mt-1\">Cryptographic RAM Segment</span>\n              </div>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className=\"p-5 space-y-4 bg-gradient-to-br from-[#02050e] to-[#010204] border border-[#009DFF]/15\">\n            <h4 className=\"text-[12px] font-bold text-white uppercase\">Maintenance</h4>\n            <p className=\"text-[10px] text-white/50 leading-relaxed\">\n              Need physical intervention? Submit requests to GFF AI Operations Support.\n            </p>\n            <Link href=\"/portal/support\" className=\"w-full inline-flex h-8 px-4 items-center justify-center rounded bg-white/5 border border-white/10 hover:bg-white/10 text-white font-bold text-[10px] uppercase tracking-wider transition-all\">\n              Contact Support\n            </Link>\n          </WorkspaceCard>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
