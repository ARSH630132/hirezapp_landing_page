tingMap, setRebootingMap] = useState<Record<string, boolean>>({});\n227 |   \n228 |   // Interactive Filters State\n229 |   const [search, setSearch] = useState(\"\");\n230 |   const [selectedProject, setSelectedProject] = useState(\"all\");\n231 |   const [selectedType, setSelectedType] = useState(\"all\");\n232 |   const [selectedStatus, setSelectedStatus] = useState(\"all\");\n233 |   const [selectedStage, setSelectedStage] = useState(\"all\");\n234 | \n235 |   // Tabs State\n236 |   const [activeTab, setActiveTab] = useState<\"telemetry\" | \"hardware\" | \"governance\">(\"telemetry\");\n237 | \n238 |   // Dynamic Reboot Handler (Simulated Enclave Cycling)\n239 |   const handleRecycleEnclave = (agentId: string) => {\n240 |     if (rebootingMap[agentId]) return;\n241 | \n242 |     setRebootingMap(prev => ({ ...prev, [agentId]: true }));\n243 |     \n244 |     // Log reboot sequence initiation\n245 |     setAgents(prev => prev.map(agent => {\n246 |       if (agent.id === agentId) {\n247 |         return {\n248 |           ...agent,\n249 |           logs: [\n250 |             ...agent.logs,\n251 |             `[${new Date().toLocaleTimeString()}] CRITICAL: INITIATING COLD REBOOT SEQUENCE...`,\n252 |             `[${new Date().toLocaleTimeString()}] INTERRUPT VECTOR SEALS TRIGGERED`,\n253 |             `[${new Date().toLocaleTimeString()}] RE-INITIALIZING CRYPTOGRAPHIC HARDWARE...`\n254 |           ]\n255 |         };\n256 |       }\n257 |       return agent;\n258 |     }));\n259 | \n260 |     setTimeout(() => {\n261 |       setRebootingMap(prev => ({ ...prev, [agentId]: false }));\n262 |       setAgents(prev => prev.map(agent => {\n263 |         if (agent.id === agentId) {\n264 |           // If decoupled, return with active status on recycling\n265 |           const finalStatus = agent.status === \"decoupled\" ? \"active\" : agent.status;\n266 |           return {\n267 |             ...agent,\n268 |             status: finalStatus,\n269 |             logs: [\n270 |               ...agent.logs,\n271 |               `[${new Date().toLocaleTimeString()}] HARDWARE CORE RE-ALIGNED OK`,\n272 |               `[${new Date().toLocaleTimeString()}] ZERO-TRUST ATTESTATION INSTRUCTIONS INJECTED`,\n273 |               `[${new Date().toLocaleTimeString()}] TELEMETRY PORT STABLE (SHA256: 0x9AF8)`\n274 |             ]\n275 |           };\n276 |         }\n277 |         return agent;\n278 |       }));\n279 |     }, 1800);\n280 |   };\n281 | \n282 |   // Filter Agents Logic\n283 |   const filteredAgents = agents.filter(agent => {\n284 |     const matchesSearch = agent.name.toLowerCase().includes(search.toLowerCase()) || \n285 |                           agent.id.toLowerCase().includes(search.toLowerCase()) ||\n286 |                           agent.type.toLowerCase().includes(search.toLowerCase());\n287 |     const matchesProject = selectedProject === \"all\" || agent.projectId === selectedProject;\n288 |     const matchesType = selectedType === \"all\" || agent.type === selectedType;\n289 |     const matchesStatus = selectedStatus === \"all\" || agent.status === selectedStatus;\n290 |     const matchesStage = selectedStage === \"all\" || agent.stage === selectedStage;\n291 | \n292 |     return matchesSearch && matchesProject && matchesType && matchesStatus && matchesStage;\n293 |   });\n294 | \n295 |   const resetFilters = () => {\n296 |     setSearch(\"\");\n297 |     setSelectedProject(\"all\");\n298 |     setSelectedType(\"all\");\n299 |     setSelectedStatus(\"all\");\n300 |     setSelectedStage(\"all\");\n301 |   };\n302 | \n303 |   // Mock Timeline Steps for Governance\n304 |   const timelineSteps = [\n305 |     {\n306 |       title: \"HARDWARE INTENT COMPLIANCE SECURED\",\n307 |       desc: \"Hardware attestation successfully verified signatures across 5 isolated AMD SEV-SNP and Intel SGX runtimes.\",\n308 |       status: \"complete\" as const,\n309 |       timestamp: \"2 hours ago\"\n310 |     },\n311 |     {\n312 |       title: \"PROMPT INJECTION BARRIER RE-SEALED\",\n313 |       desc: \"Local Model Guardrails completed continuous validation scan. Compliance score locked at 1.0/1.0.\",\n314 |       status: \"complete\" as const,\n315 |       timestamp: \"5 hours ago\"\n316 |     },\n317 |     {\n318 |       title: \"HSM COMPLIANCE ROOT CHECK\",\n319 |       desc: \"Ongoing zero-trust validation of isolated memory partitions and decoupled system interfaces.\",\n320 |       status: \"current\" as const,\n321 |       timestamp: \"Ongoing\"\n322 |     },\n323 |     {\n324 |       title: \"WEEKLY HARDWARE ENCLAVE ROTATION\",\n325 |       desc: \"Automated cryptographic key rollover and fresh partition reallocation for continuous sandbox integrity.\",\n326 |       status: \"pending\" as const,\n327 |       timestamp: \"Scheduled\"\n328 |     }\n329 |   ];\n330 | \n331 | \n332 |   return (\n333 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none\">\n334 |       \n335 |       {/* 1. SECURE DISCLOSURE BANNER */}\n336 |       <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n337 |         <div className=\"flex items-center gap-2.5 text-white/70\">\n338 |           <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0 animate-pulse\" />\n339 |           <span>\n340 |             <strong className=\"text-white\">COCKPIT REPRESENTATIVE TELEMETRY:</strong> This control center displays emulated telemetry data and sandboxed system parameters. Real-time live production adjustments are emulated for security.\n341 |           </span>\n342 |         </div>\n343 |         <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n344 |           EMULATED RUNTIME\n345 |         </span>\n346 |       </div>\n347 | \n348 |       {/* 2. PAGE HEADER */}\n349 |       <PrivatePageHeader\n350 |         title=\"AI Operations Command Center\"\n351 |         desc=\"Central portal for continuous monitoring of managed sandbox runtimes, sovereign hardware partition metrics, and zero-trust policy validations.\"\n352 |         badgeLabel=\"Sovereign AI Ops\"\n353 |         actions={\n354 |           <div className=\"flex gap-2 w-full md:w-auto\">\n355 |             <Link\n356 |               href=\"/portal/control-center\"\n357 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[11px] px-4 uppercase tracking-wider transition-all hover:shadow-[0_0_12px_rgba(0,157,255,0.25)]\"\n358 |             >\n359 |               Hardware Control Center\n360 |               <ArrowUpRight className=\"w-3.5 h-3.5\" />\n361 |             </Link>\n362 |           </div>\n363 |         }\n364 |       />\n365 | \n366 | \n367 |       {/* 3. MANAGED OPERATION STATUS RAIL */}\n368 |       <div className=\"grid grid-cols-1 md:grid-cols-4 gap-3 border border-white/5 rounded-xl bg-white/[0.01] p-3.5 font-mono text-[11px]\">\n369 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n370 |           <span className=\"relative flex h-2 w-2 shrink-0\">\n371 |             <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n372 |             <span className=\"relative inline-flex rounded-full h-2 w-2 bg-emerald-500\"></span>\n373 |           </span>\n374 |           <span className=\"text-white/40\">OPS STATUS:</span>\n375 |           <span className=\"text-[#00FFC2] font-bold\">STEADY & COMPLIANT</span>\n376 |         </div>\n377 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n378 |           <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n379 |           <span className=\"text-white/40\">SYSTEM RUNTIMES:</span>\n380 |           <span className=\"text-white font-bold\">5 REPL SANDBOXES</span>\n381 |         </div>\n382 |         <div className=\"flex items-center gap-2.5 px-3 py-1 border-b md:border-b-0 md:border-r border-white/5\">\n383 |           <ShieldCheck className=\"w-3.5 h-3.5 text-emerald-400\" />\n384 |           <span className=\"text-white/40\">INTEGRITY LOCKS:</span>\n385 |           <span className=\"text-emerald-400 font-bold\">ISO-27001 ACTIVE</span>\n386 |         </div>\n387 |         <div className=\"flex items-center gap-2.5 px-3 py-1\">\n388 |           <Clock className=\"w-3.5 h-3.5 text-amber-400\" />\n389 |           <span className=\"text-white/40\">MAINTENANCE CYCLE:</span>\n390 |           <span className=\"text-white font-bold\">AUTOMATED (2H 45M)</span>\n391 |         </div>\n392 |       </div>\n393 | \n394 |       {/* 4. HEALTH OVERVIEW & RUNTIME STATUS (HEALTH RINGS) */}\n395 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n396 |         <HealthRing \n397 |           percentage={68} \n398 |           title=\"Avg Core CPU Load\" \n399 |           value=\"59.84 Gigaflops\" \n400 |           color=\"#10b981\" \n401 |         />\n402 |         <HealthRing \n403 |           percentage={78} \n404 |           title=\"Sandbox Memory Lock\" \n405 |           value=\"27.2 GB / 34.0 GB\" \n406 |           color=\"#009DFF\" \n407 |         />\n408 |         <HealthRing \n409 |           percentage={100} \n410 |           title=\"Guardrail Compliance\" \n411 |           value=\"4 / 4 Rules Enforced\" \n412 |           color=\"#00FFC2\" \n413 |         />\n414 |         \n415 |         {/* Rapid Overview Metric Tile */}\n416 |         <WorkspaceCard className=\"flex flex-col justify-between p-4 bg-[#050505]/20\">\n417 |           <div className=\"flex justify-between items-start font-mono\">\n418 |             <div>\n419 |               <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">Aggregate Pulse Latency</span>\n420 |               <span className=\"text-[18px] font-bold text-white mt-1.5 block\">16.42 ms</span>\n421 |             </div>\n422 |             <span className=\"text-[10px] px-2 py-0.5 rounded bg-[#00FFC2]/5 border border-[#00FFC2]/20 text-[#00FFC2] font-bold\">\n423 |               OPTIMAL\n424 |             </span>\n425 |           </div>\n426 |           <div className=\"border-t border-white/5 pt-2 mt-2 flex justify-between items-center text-[10px] font-mono text-white/45\">\n427 |             <span>UPTIME SCORE:</span>\n428 |             <span className=\"text-white font-bold\">99.998% CERTIFIED</span>\n429 |           </div>\n430 |         </WorkspaceCard>\n431 |       </div>\n432 | \n433 |       {/* 5. TABS SYSTEM */}\n434 |       <div className=\"flex border-b border-white/5 font-mono text-[12px]\">\n435 |         <button\n436 |           onClick={() => setActiveTab(\"telemetry\")}\n437 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n438 |             activeTab === \"telemetry\" \n439 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n440 |               : \"border-transparent text-white/40 hover:text-white/70\"\n441 |           }`}\n442 |         >\n443 |           ACTIVE TELEMETRY LEDGER\n444 |         </button>\n445 |         <button\n446 |           onClick={() => setActiveTab(\"hardware\")}\n447 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n448 |             activeTab === \"hardware\" \n449 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n450 |               : \"border-transparent text-white/40 hover:text-white/70\"\n451 |           }`}\n452 |         >\n453 |           HARDWARE & ENCLAVE ARCHITECTURE\n454 |         </button>\n455 |         <button\n456 |           onClick={() => setActiveTab(\"governance\")}\n457 |           className={`px-5 py-3 border-b-2 font-bold transition-all ${\n458 |             activeTab === \"governance\" \n459 |               ? \"border-[#009DFF] text-white bg-white/[0.02]\" \n460 |               : \"border-transparent text-white/40 hover:text-white/70\"\n461 |           }`}\n462 |         >\n463 |           GOVERNANCE & ACTIVITY LOG\n464 |         </button>\n465 |       </div>\n466 | \n467 |       {/* ==========================================\n468 |           TAB 1: TELEMETRY & ACTIVE AGENTS GRID\n469 |           ========================================== */}\n470 |       {activeTab === \"telemetry\" && (\n471 |         <div className=\"space-y-6\">\n472 |           <WorkspaceCard className=\"p-4 space-y-4\">\n473 |             <div className=\"flex items-center gap-2 pb-2 border-b border-white/5\">\n474 |               <SlidersHorizontal className=\"w-4 h-4 text-[#009DFF]\" />\n475 |               <h3 className=\"text-xs font-mono font-bold uppercase text-white tracking-widest\">Interactive Telemetry Filters</h3>\n476 |             </div>\n477 |             <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n478 |               <div className=\"relative\">\n479 |                 <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n480 |                 <input \n481 |                   type=\"text\"\n482 |                   value={search}\n483 |                   onChange={(e) => setSearch(e.target.value)}\n484 |                   placeholder=\"Search agent ID, name...\"\n485 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[11px] font-mono text-white placeholder-white/30 outline-none focus:border-[#009DFF]/50 focus:bg-white/[0.04] transition-all\"\n486 |                 />\n487 |               </div>\n488 |               <div className=\"relative\">\n489 |                 <select \n490 |                   value={selectedProject}\n491 |                   onChange={(e) => setSelectedProject(e.target.value)}\n492 |                   aria-label=\"Filter by Project\"\n493 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n494 |                 >\n495 |                   <option value=\"all\">ALL PROJECTS</option>\n496 |                   <option value=\"proj-001\">Sovereign Core Sandbox 02</option>\n497 |                   <option value=\"proj-002\">Model Guardrail Sandbox 04</option>\n498 |                   <option value=\"proj-003\">Sovereign Mining Intel Loop</option>\n499 |                 </select>\n500 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n501 |               </div>\n502 |               <div className=\"relative\">\n503 |                 <select \n504 |                   value={selectedType}\n505 |                   onChange={(e) => setSelectedType(e.target.value)}\n506 |                   aria-label=\"Filter by Agent Type\"\n507 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n508 |                 >\n509 |                   <option value=\"all\">ALL AGENT TYPES</option>\n510 |                   <option value=\"Core Telemetry\">Core Telemetry</option>\n511 |                   <option value=\"Alignment Guard\">Alignment Guard</option>\n512 |                   <option value=\"Seismic Processing\">Seismic Processing</option>\n513 |                   <option value=\"Medical Enclave\">Medical Enclave</option>\n514 |                   <option value=\"Transport Node\">Transport Node</option>\n515 |                 </select>\n516 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n517 |               </div>\n518 |               <div className=\"relative\">\n519 |                 <select \n520 |                   value={selectedStatus}\n521 |                   onChange={(e) => setSelectedStatus(e.target.value)}\n522 |                   aria-label=\"Filter by Status\"\n523 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n524 |                 >\n525 |                   <option value=\"all\">ALL PULSE STATES</option>\n526 |                   <option value=\"active\">Active</option>\n527 |                   <option value=\"evaluating\">Evaluating</option>\n528 |                   <option value=\"warning\">Warning</option>\n529 |                   <option value=\"decoupled\">Decoupled</option>\n530 |                 </select>\n531 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n532 |               </div>\n533 |               <div className=\"relative\">\n534 |                 <select \n535 |                   value={selectedStage}\n536 |                   onChange={(e) => setSelectedStage(e.target.value)}\n537 |                   aria-label=\"Filter by Operating Stage\"\n538 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n539 |                 >\n540 |                   <option value=\"all\">ALL SECURE STAGES</option>\n541 |                   <option value=\"Sandbox Emulation\">Sandbox Emulation</option>\n542 |                   <option value=\"Staging Enclave\">Staging Enclave</option>\n543 |                   <option value=\"Production Guardrail\">Production Guardrail</option>\n544 |                 </select>\n545 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n546 |               </div>\n547 |             </div>\n548 |             {(search || selectedProject !== \"all\" || selectedType !== \"all\" || selectedStatus !== \"all\" || selectedStage !== \"all\") && (\n549 |               <div className=\"flex justify-between items-center text-[10px] font-mono text-white/45 bg-white/[0.01] border border-white/5 px-3 py-1.5 rounded\">\n550 |                 <span>\n551 |                   Filtering active sandbox ledger: found <strong className=\"text-white\">{filteredAgents.length}</strong> matching agent nodes.\n552 |                 </span>\n553 |                 <button onClick={resetFilters} className=\"text-[#009DFF] hover:underline uppercase font-bold cursor-pointer\">\n554 |                   Reset Active Filters\n555 |                 </button>\n556 |               </div>\n557 |             )}\n558 |           </WorkspaceCard>\n559 | \n560 | \n561 |           {filteredAgents.length > 0 ? (\n562 |             <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n563 |               {filteredAgents.map((agent) => {\n564 |                 const isRebooting = rebootingMap[agent.id];\n565 |                 const badgeState = isRebooting ? \"warning\" : agent.status === \"active\" ? \"active\" : agent.status === \"evaluating\" ? \"warning\" : agent.status === \"warning\" ? \"error\" : \"decoupled\";\n566 |                 const badgeLabel = isRebooting ? \"RECYCLING\" : agent.status;\n567 | \n568 |                 return (\n569 |                   <WorkspaceCard key={agent.id} className=\"space-y-4\">\n570 |                     <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n571 |                       <div>\n572 |                         <span className=\"text-[8.5px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1.5 py-0.5 rounded\">\n573 |                           {agent.id.toUpperCase()} • {agent.type.toUpperCase()}\n574 |                         </span>\n575 |                         <h4 className=\"text-[13.5px] font-bold text-white font-mono mt-1.5 tracking-tight\">\n576 |                           {agent.name}\n577 |                         </h4>\n578 |                       </div>\n579 |                       <StatusBadge state={badgeState} label={badgeLabel} />\n580 |                     </div>\n581 | \n582 |                     <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono\">\n583 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n584 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Project Bounds</span>\n585 |                         <span className=\"text-white font-medium truncate block mt-1\">{agent.projectName}</span>\n586 |                       </div>\n587 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n588 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Enclave Stage</span>\n589 |                         <span className=\"text-white font-medium block mt-1\">{agent.stage}</span>\n590 |                       </div>\n591 |                     </div>\n592 | \n593 |                     <div className=\"grid grid-cols-3 gap-2 text-[10px] font-mono text-center select-none\">\n594 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n595 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Alloc CPU</span>\n596 |                         <span className=\"text-white font-bold block mt-0.5\">\n597 |                           {isRebooting ? \"--\" : `${agent.cpu}%`}\n598 |                         </span>\n599 |                       </div>\n600 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n601 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Memory State</span>\n602 |                         <span className=\"text-white font-bold block mt-0.5\">\n603 |                           {isRebooting ? \"--\" : agent.memory.split(\" / \")[0]}\n604 |                         </span>\n605 |                       </div>\n606 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n607 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Core Threads</span>\n608 |                         <span className=\"text-[#009DFF] font-bold block mt-0.5\">\n609 |                           {isRebooting ? \"0\" : `${agent.threads}`}\n610 |                         </span>\n611 |                       </div>\n612 |                     </div>\n613 | \n614 |                     <div className=\"border border-white/5 rounded-lg overflow-hidden bg-black/70 p-3 h-28 overflow-y-auto font-mono text-[9px] text-white/50 space-y-1\">\n615 |                       {agent.logs.map((log, index) => (\n616 |                         <div key={index} className=\"leading-normal flex\">\n617 |                           <span className=\"text-white/20 mr-1 shrink-0\">&gt;</span>\n618 |                           <span className={\n619 |                             log.includes(\"REBOOT\") || log.includes(\"CRITICAL\") ? \"text-[#009DFF]\" :\n620 |                             log.includes(\"Attestation\") || log.includes(\"successfully\") || log.includes(\"OK\") ? \"text-emerald-400 font-semibold\" : \n621 |                             log.includes(\"Warning\") ? \"text-amber-400\" : \"\"\n622 |                           }>\n623 |                             {log}\n624 |                           </span>\n625 |                         </div>\n626 |                       ))}\n627 |                     </div>\n628 | \n629 |                     <div className=\"flex gap-2 font-mono\">\n630 |                       <button\n631 |                         onClick={() => handleRecycleEnclave(agent.id