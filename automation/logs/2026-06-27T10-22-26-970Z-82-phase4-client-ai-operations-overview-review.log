d:grid-cols-2 gap-4 text-[12px] font-mono text-white/70\">\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Model Architecture:</span>\n                <span className=\"text-white font-bold\">GFF-Llama-70B-v4</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Context State Cache:</span>\n                <span className=\"text-emerald-400 font-bold\">DECOUPLED (128k)</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Inference Thread Pool:</span>\n                <span className=\"text-white\">32 Parallel Workers</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Temperature Enclave:</span>\n                <span className=\"text-white\">0.15 Enforced</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <h3 className=\"text-sm font-bold text-white font-mono uppercase border-b border-white/5 pb-2\">eBPF Telemetry Event Streams</h3>\n            <div className=\"space-y-2.5 font-mono text-[11px] text-white/50\">\n              <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                <span>[06:12:15] Context cache sync handshake initiated</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">SUCCESS</span>\n              </div>\n              <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                <span>[06:12:15] Guardrail safety policy matching score: 1.0</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">VERIFIED</span>\n              </div>\n              <div className=\"flex justify-between\">\n                <span>[06:12:16] Token count: 1.2M. Spend budget caps verified</span>\n                <span className=\"text-emerald-400 font-bold text-[10px]\">OK</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n              <Shield className=\"w-4 h-4 text-green-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Guardrail Shield</h3>\n            </div>\n            <div className=\"space-y-3 font-mono text-[11px]\">\n              <div className=\"p-3 bg-green-500/5 border border-green-500/20 text-green-400 font-bold rounded flex items-center justify-between\">\n                <span>OVERRIDE SHIELD:</span>\n                <span>ACTIVE</span>\n              </div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">\n                All sensory outputs of this agent run are bound within secure sandbox overlays, fully protected against system privilege escalations or compliance drift.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport Link from \"next/link\";\nimport { ArrowLeft, Bot, Shield, Cpu, Terminal, RefreshCw, ShieldCheck, Zap, Lock } from \"lucide-react\";\nimport { WorkspaceCard, StatusBadge } from \"@/components/private-app\";\n\nconst AGENTS_DICT: Record<string, {\n  name: string; type: string; status: \"active\" | \"evaluating\" | \"warning\" | \"decoupled\";\n  threads: number; memory: string; logs: string[]; cpu: number; ram: number; latency: number; uptime: number;\n  model: string; contextCache: string; isolation: string; projectName: string;\n}> = {\n  \"agent-001\": {\n    name: \"RETAIL-CORE-A1\", type: \"Core Telemetry\", status: \"active\",\n    threads: 24, memory: \"4.2 GB / 8.0 GB\", logs: [\"Core verification complete (SHA-256: FF81)\", \"Local memory state synchronized successfully\", \"eBPF telemetry boundary active\"],\n    cpu: 42, ram: 52, latency: 12, uptime: 99.998,\n    model: \"GFF-Llama-70B-v4\", contextCache: \"DECOUPLED (128k)\", isolation: \"AMD SEV-SNP\", projectName: \"Sovereign Core Sandbox 02\"\n  },\n  \"agent-002\": {\n    name: \"ALIGN-GUARD-A2\", type: \"Alignment Guard\", status: \"evaluating\",\n    threads: 16, memory: \"3.1 GB / 4.0 GB\", logs: [\"Policy verification pass 99.8%\", \"No direct model manipulation requests detected.\", \"Syncing guardrail ledger block...\"],\n    cpu: 18, ram: 77, latency: 24, uptime: 99.982,\n    model: \"GFF-Guard-8B-v2\", contextCache: \"ENCLAVE COMPACT (32k)\", isolation: \"Intel SGX\", projectName: \"Model Guardrail Sandbox 04\"\n  },\n  \"agent-003\": {\n    name: \"ORE-TUNNEL-X4\", type: \"Seismic Processing\", status: \"active\",\n    threads: 32, memory: \"12.8 GB / 16.0 GB\", logs: [\"Seismic array map loaded successfully.\", \"AMD SEV memory block verified securely.\", \"Telemetry streaming active\"],\n    cpu: 65, ram: 80, latency: 14, uptime: 99.991,\n    model: \"GFF-Seismic-Core-v1\", contextCache: \"MEM-MAPPED (256k)\", isolation: \"AMD SEV-SNP\", projectName: \"Sovereign Mining Intel Loop\"\n  },\n  \"agent-004\": {\n    name: \"MED-CLINIC-H9\", type: \"Medical Enclave\", status: \"warning\",\n    threads: 16, memory: \"7.1 GB / 8.0 GB\", logs: [\"Warning: Thread load above safety line (85%)\", \"Triggered telemetry frame check...\", \"Memory garbage collection triggered\"],\n    cpu: 94, ram: 89, latency: 88, uptime: 99.954,\n    model: \"GFF-Med-34B-v3\", contextCache: \"SECURE RAM (64k)\", isolation: \"Sovereign HSM Enclave\", projectName: \"Sovereign Core Sandbox 02\"\n  },\n  \"agent-005\": {\n    name: \"TRANS-LOOP-Z1\", type: \"Transport Node\", status: \"decoupled\",\n    threads: 0, memory: \"0.0 GB / 8.0 GB\", logs: [\"Thread execution terminated gracefully.\", \"State dumped to local cryptographic storage block.\", \"Hardware enclave decoupled.\"],\n    cpu: 0, ram: 0, latency: 999, uptime: 98.712,\n    model: \"GFF-Transport-13B-v2\", contextCache: \"PERSISTENT HDD\", isolation: \"AMD SEV-SNP\", projectName: \"Sovereign Core Sandbox 02\"\n  }\n};\n\nexport default function ClientAiOperationsDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const agentId = typeof id === \"string\" ? id : \"agent-001\";\n  const agent = AGENTS_DICT[agentId] || AGENTS_DICT[\"agent-001\"];\n\n  const [attestationRunning, setAttestationRunning] = useState(false);\n  const [attestationComplete, setAttestationComplete] = useState(false);\n  const [steps, setSteps] = useState<string[]>([]);\n\n  const triggerAttestation = () => {\n    if (attestationRunning) return;\n    setAttestationRunning(true);\n    setAttestationComplete(false);\n    setSteps([]);\n    const testSteps = [\n      \"Accessing hardware registers...\",\n      \"Requesting silicon signatures...\",\n      \"Verifying secure hash...\",\n      \"Validation completed successfully.\"\n    ];\n    testSteps.forEach((step, idx) => {\n      setTimeout(() => {\n        setSteps(prev => [...prev, `[${new Date().toLocaleTimeString()}] ${step}`]);\n        if (idx === testSteps.length - 1) {\n          setAttestationRunning(false);\n          setAttestationComplete(true);\n        }\n      }, (idx + 1) * 600);\n    });\n  };\n\n  const badgeState = agent.status === \"active\" ? \"active\" : agent.status === \"evaluating\" ? \"warning\" : agent.status === \"warning\" ? \"error\" : \"decoupled\";\n\n  return (\n    <div className=\"space-y-6\">\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n        <div className=\"flex items-center gap-4\">\n          <button\n            onClick={() => router.push(\"/portal/ai-operations\")}\n            className=\"p-2 rounded-lg border border-white/10 bg-white/[0.02] text-white/50 hover:text-white hover:bg-white/[0.06] cursor-pointer transition-all\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">\n                {agent.type}\n              </span>\n              <StatusBadge state={badgeState} label={agent.status} />\n            </div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono mt-1 uppercase flex items-center gap-2\">\n              <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n              {agent.name}\n            </h2>\n          </div>\n        </div>\n\n        <button\n          onClick={triggerAttestation}\n          disabled={attestationRunning}\n          className=\"inline-flex h-9 px-4 items-center justify-center gap-2 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[11px] uppercase tracking-wider transition-all disabled:opacity-50 cursor-pointer\"\n        >\n          {attestationRunning ? <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> : <ShieldCheck className=\"w-3.5 h-3.5\" />}\n          Verify Attestation\n        </button>\n      </div>\n\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 font-mono text-[11px]\">\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px]\">CPU ALLOCATION</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.cpu}%</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div className=\"bg-emerald-500 h-full rounded-full\" style={{ width: `${agent.cpu}%` }} />\n          </div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px]\">RAM UTILIZATION</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.ram}%</div>\n          <div className=\"w-full bg-white/5 h-1.5 rounded-full overflow-hidden\">\n            <div className=\"bg-[#009DFF] h-full rounded-full\" style={{ width: `${agent.ram}%` }} />\n          </div>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px]\">PULSE LATENCY</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.latency} ms</div>\n          <span className=\"text-[9px] text-emerald-400 font-bold uppercase\">STABLE LIMITS</span>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"p-4 space-y-2\">\n          <span className=\"text-white/40 block uppercase text-[9px]\">CERTIFIED UPTIME</span>\n          <div className=\"text-2xl font-bold text-white\">{agent.uptime}%</div>\n          <span className=\"text-[9px] text-[#009DFF] font-bold uppercase\">SECURED RATIO</span>\n        </WorkspaceCard>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 space-y-6\">\n          <WorkspaceCard className=\"p-5 space-y-4\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n              <Bot className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Neural Parameter Mapping</h3>\n            </div>\n            <div className=\"grid grid-cols-1 md:grid-cols