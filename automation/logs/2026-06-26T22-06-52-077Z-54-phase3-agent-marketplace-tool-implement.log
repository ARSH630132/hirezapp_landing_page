 Secret Engine\",\n 62 |     stages: [\"Agent Inbound\", \"eBPF Filter\", \"Policy Audit Engine\", \"Sanitized Gateway\"],\n 63 |     perfMetric: \"<12ms Interception Latency\"\n 64 |   },\n 65 |   {\n 66 |     id: \"cx-orchestrator\",\n 67 |     name: \"Hyper-Personalized CX Orchestrator\",\n 68 |     category: \"Customer Experience\",\n 69 |     desc: \"Orchestrates complex multi-channel corporate outreach, classifying real-time user intents and drafting highly accurate, policy-approved responses.\",\n 70 |     schema: \"Zendesk Webhook -> Classification Classifier -> Draft Synthesis -> Human Approval Gate\",\n 71 |     systemPrompt: \"Evaluate intent markers. Match drafts strictly against active subscription packages. Escalate multi-variable disputes to Tier 2 agents.\",\n 72 |     datasources: \"Salesforce CRM, Braze, Zendesk Support Hub\",\n 73 |     stages: [\"Zendesk Webhook\", \"Intent Classify\", \"Draft Gen Engine\", \"Human-in-the-Loop Gate\"],\n 74 |     perfMetric: \"82% Automated Resolution Rate\"\n 75 |   },\n 76 |   {\n 77 |     id: \"executive-advisor\",\n 78 |     name: \"Scenario Modeler & Executive Briefing Agent\",\n 79 |     category: \"Executive\",\n 80 |     desc: \"Generates multi-variable risk simulations, financial variance analyses, and secure briefing reports for board-level decision-making.\",\n 81 |     schema: \"Snowflake Ingest -> Monte Carlo Risk Simulation -> Metric Summarizer -> Signed Executive PDF\",\n 82 |     systemPrompt: \"Synthesize operational risk models. Restrict focus to cash flow margins and infrastructure security indexes. Include raw data source citations.\",\n 83 |     datasources: \"Grafana Telemetry, Snowflake, Workday Ledger\",\n 84 |     stages: [\"Snowflake Ingest\", \"Risk Simulation\", \"Briefing Generator\", \"Signed PDF Compile\"],\n 85 |     perfMetric: \"99.2% Trend Match Accuracy\"\n 86 |   },\n 87 |   {\n 88 |     id: \"doc-intel\",\n 89 |     name: \"Sovereign Multi-Format Document Analyzer\",\n 90 |     category: \"Document Intelligence\",\n 91 |     desc: \"Extracts, parses, and audits unstructured multi-page legal documents and SOX balance sheets, flagging ledger discrepancies in seconds.\",\n 92 |     schema: \"S3 Pipeline -> OCR Schema Normalizer -> Structural Matcher -> Discrepancy Ledger Export\",\n 93 |     systemPrompt: \"Perform cell-by-cell reconciliation on all tables. Highlight any department ledger mismatch exceeding 0.05% margin.\",\n 94 |     datasources: \"Amazon S3 Buckets, Legal DocuVault, ERP Local Cache\",\n 95 |     stages: [\"S3 PDF Pipeline\", \"OCR Schema Norm\", \"Structural Match\", \"Discrepancy Audit\"],\n 96 |     perfMetric: \"99.8% Extraction Accuracy\"\n 97 |   }\n 98 | ];\n 99 | \n100 | export default function AgentMarketplacePage() {\n101 |   const [activeCat, setActiveCat] = useState(\"All\");\n102 |   const [selectedId, setSelectedId] = useState(\"knowledge-synth\");\n103 |   const [sandboxActive, setSandboxActive] = useState<Record<string, boolean>>({});\n104 |   const [deployingId, setDeployingId] = useState<string | null>(null);\n105 | \n106 |   const filtered = AGENT_PATTERNS.filter(\n107 |     (acc) => activeCat === \"All\" || acc.category === activeCat\n108 |   );\n109 | \n110 |   const activeAcc = AGENT_PATTERNS.find((acc) => acc.id === selectedId) || AGENT_PATTERNS[0];\n111 | \n112 |   const handleDeploySandbox = (id: string) => {\n113 |     setDeployingId(id);\n114 |     setTimeout(() => {\n115 |       setSandboxActive((prev) => ({ ...prev, [id]: true }));\n116 |       setDeployingId(null);\n117 |     }, 1500);\n118 |   };\n119 | \n120 |   return (\n121 |     <InnerPageShell>\n122 |       <InnerPageHero\n123 |         category=\"Platforms & Modules\"\n124 |         title=\"Agent Marketplace and Enterprise Blueprint Registry\"\n125 |         highlightedWord=\"Marketplace\"\n126 |         highlightColor=\"blue\"\n127 |         description=\"Deploy verified, pre-scoped sovereign agent patterns designed for secure, autonomous operations across knowledge synthesis, deep regulatory auditing, complex supply chains, and executive decision-making.\"\n128 |         breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"Agent Marketplace\" }]}\n129 |       />\n130 | \n131 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n132 |         \n133 |         {/* Editorial Strategy Narrative */}\n134 |         <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-12 border-y border-white/5 items-center bg-white/[0.01] px-8 rounded-2xl relative overflow-hidden\">\n135 |           <div className=\"absolute top-0 left-0 w-[30%] h-full bg-gradient-to-r from-[#009DFF]/5 to-transparent pointer-events-none\" />\n136 |           <div className=\"lg:col-span-5 relative z-10\">\n137 |             <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Standardized Autonomy</span>\n138 |             <h2 className=\"text-3xl font-semibold text-white tracking-tight mt-2\">Zero-Trust Deterministic Blueprints</h2>\n139 |           </div>\n140 |           <div className=\"lg:col-span-7 relative z-10\">\n141 |             <p className=\"text-white/70 font-light text-sm sm:text-base leading-relaxed\">\n142 |               Autonomous digital labor shouldn't be built from chaotic, unguided models. The GFF Agent Marketplace delivers certified multi-agent blueprints engineered with strict input/output schemas, static tool bindings, and integrated system-level guardrails. This eliminates hallucination risk, sandbox jailbreaks, and configuration drift, enabling immediate integration into sovereign enterprise environments.\n143 |             </p>\n144 |           </div>\n145 |         </MotionReveal>\n146 | \n147 |         {/* Core Registry Explorer Section */}\n148 |         <MotionReveal className=\"space-y-8\">\n149 |           <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 border-b border-white/5 pb-6\">\n150 |             <div>\n151 |               <div className=\"flex items-center gap-2 text-white/40 text-[11px] font-mono uppercase tracking-widest\">\n152 |                 <Compass className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n153 |                 Interactive Registry Explorer\n154 |               </div>\n155 |               <h2 className=\"text-2xl sm:text-3xl font-bold text-white tracking-tight mt-1\">Sovereign Patterns</h2>\n156 |               <p className=\"text-white/50 text-xs sm:text-sm font-light mt-1.5\">Select and inspect verified architectures ready for containerized sandbox deployments.</p>\n157 |             </div>\n158 |             \n159 |             {/* Horizontal Scrollable Categories Filter */}\n160 |             <div className=\"flex gap-1.5 p-1 bg-white/5 rounded-xl border border-white/10 overflow-x-auto w-full lg:w-auto scrollbar-none\">\n161 |               {CATEGORIES.map((cat) => (\n162 |                 <button\n163 |                   key={cat}\n164 |                   onClick={() => {\n165 |                     setActiveCat(cat);\n166 |                     const firstOfCat = AGENT_PATTERNS.find(a => cat === \"All\" || a.category === cat);\n167 |                     if (firstOfCat) setSelectedId(firstOfCat.id);\n168 |                   }}\n169 |                   className={`px-3 py-1.5 text-[11px] font-semibold rounded-lg transition-all cursor-pointer whitespace-nowrap ${\n170 |                     activeCat === cat \n171 |                       ? \"bg-white/10 text-white shadow-sm border border-white/10\" \n172 |                       : \"text-white/50 hover:text-white border border-transparent\"\n173 |                   }`}\n174 |                 >\n175 |                   {cat}\n176 |                 </button>\n177 |               ))}\n178 |             </div>\n179 |           </div>\n180 | \n181 |           <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\">\n182 |             \n183 |             {/* Left side: Grid of Filtered Cards */}\n184 |             <div className=\"lg:col-span-6 grid grid-cols-1 sm:grid-cols-2 gap-4 h-fit\">\n185 |               {filtered.map((acc) => {\n186 |                 const isSelected = acc.id === selectedId;\n187 |                 const isStaged = sandboxActive[acc.id];\n188 |                 return (\n189 |                   <div\n190 |                     key={acc.id}\n191 |                     onClick={() => setSelectedId(acc.id)}\n192 |                     className={`p-6 rounded-xl border flex flex-col justify-between min-h-[220px] transition-all cursor-pointer relative group ${\n193 |                       isSelected \n194 |                         ? \"border-[#009DFF] bg-[#009DFF]/5 shadow-[0_0_20px_rgba(0,157,255,0.05)]\" \n195 |                         : \"border-white/5 bg-black/40 hover:border-white/15\"\n196 |                     }`}\n197 |                   >\n198 |                     <div>\n199 |                       <div className=\"flex justify-between items-start gap-2\">\n200 |                         <span className=\"px-2 py-0.5 rounded text-[8px] bg-white/5 text-white/50 border border-white/10 uppercase font-mono tracking-widest\">\n201 |                           {acc.category}\n202 |                         </span>\n203 |                         {isStaged ? (\n204 |                           <span className=\"text-[9px] font-mono font-bold text-green-400 flex items-center gap-1\">\n205 |                             <CheckCircle2 className=\"w-3.5 h-3.5\" /> STAGED\n206 |                           </span>\n207 |                         ) : (\n208 |                           <span className=\"text-[9px] font-mono text-white/30\">{acc.perfMetric}</span>\n209 |                         )}\n210 |                       </div>\n211 |                       <h3 className=\"text-base font-semibold text-white mt-4 group-hover:text-[#009DFF] transition-colors\">{acc.name}</h3>\n212 |                       <p className=\"text-xs text-white/50 font-light mt-2 line-clamp-3 leading-relaxed\">{acc.desc}</p>\n213 |                     </div>\n214 | \n215 |                     <div className=\"mt-6 pt-4 border-t border-white/5 flex items-center justify-between text-[11px] text-white/40\">\n216 |                       <span className=\"font-mono\">Inspect Blueprint Schema</span>\n217 |                       <ChevronRight className=\"w-4 h-4 group-hover:translate-x-1 transition-transform text-[#009DFF]\" />\n218 |                     </div>\n219 |                   </div>\n220 |                 );\n221 |               })}\n222 |             </div>\n223 | \n224 |             {/* Right side: Large Interactive Inspector Panel */}\n225 |             <div className=\"lg:col-span-6 bg-[#04060b] rounded-xl border border-white/10 p-6 flex flex-col justify-between shadow-2xl relative overflow-hidden min-h-[500px]\">\n226 |               <div className=\"absolute top-0 right-0 w-[50%] h-[40%] bg-gradient-to-bl from-[#009DFF]/10 to-transparent blur-[50px] pointer-events-none\" />\n227 |               \n228 |               <div className=\"space-y-6 relative z-10\">\n229 |                 <div className=\"flex items-start justify-between border-b border-white/5 pb-4\">\n230 |                   <div>\n231 |                     <span className=\"text-[9px] uppercase font-mono tracking-widest text-[#009DFF] font-bold\">Dynamic Inspector</span>\n232 |                     <h3 className=\"text-lg font-bold text-white mt-1\">{activeAcc.name}</h3>\n233 |                   </div>\n234 |                   <Server className=\"w-5 h-5 text-[#009DFF] shrink-0\" />\n235 |                 </div>\n236 | \n237 |                 <div className=\"border border-white/5 bg-black/60 rounded-xl p-4 flex flex-col items-center justify-center relative min-h-[140px]\">\n238 |                   <span className=\"text-[8px] font-mono text-white/40 absolute top-2 right-3 uppercase tracking-wider flex items-center gap-1\">\n239 |                     <span className=\"w-1.5 h-1.5 rounded-full bg-blue-500 animate-ping\" /> Execution DAG\n240 |                   </span>\n241 |                   \n242 |                   <div className=\"w-full flex flex-col sm:flex-row items-center justify-between px-2 mt-4 text-[9px] font-mono text-white/60 text-center gap-4 relative\">\n243 |                     {activeAcc.stages.map((st, i) => (\n244 |                       <div key={i} className=\"flex flex-col items-center flex-1 z-10\">\n245 |                         <div className=\"w-7 h-7 rounded-full border border-white/15 bg-black flex items-center justify-center mb-2 text-xs font-bold text-[#009DFF]\">\n246 |                           {i + 1}\n247 |                         </div>\n248 |                         <span className=\"text-[9px] font-medium text-white/80\">{st}</span>\n249 |                       </div>\n250 |                     ))}\n251 |                   </div>\n252 |                 </div>\n253 | \n254 |                 <div className=\"space-y-2\">\n255 |                   <div className=\"flex items-center gap-2 text-[10px] font-mono text-white/40 uppercase tracking-wider\">\n256 |                     <Terminal className=\"w-3.5 h-3.5 text-red-500\" /> Embedded Safety Directives\n257 |                   </div>\n258 |                   <div className=\"bg-black/80 rounded-lg p-4 border border-white/5 font-mono text-[11px] leading-relaxed text-white/80 relative\">\n259 |                     <span className=\"text-red-400\"># SYSTEM: </span>{activeAcc.systemPrompt}\n260 |                   </div>\n261 |                 </div>\n262 | \n263 |                 <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n264 |                   <div className=\"space-y-1\">\n265 |                     <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-[#009DFF] uppercase tracking-wider\">\n266 |                       <Database className=\"w-3.5 h-3.5\" /> Integrations\n267 |                     </div>\n268 |                     <div className=\"bg-black/40 px-3 py-2 rounded-lg border border-white/5 text-xs text-white/80 font-mono\">\n269 |                       {activeAcc.datasources}\n270 |                     </div>\n271 |                   </div>\n272 | \n273 |                   <div className=\"space-y-1\">\n274 |                     <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-teal-400 uppercase tracking-wider\">\n275 |                       <Activity className=\"w-3.5 h-3.5\" /> Performance Metrics\n276 |                     </div>\n277 |                     <div className=\"bg-black/40 px-3 py-2 rounded-lg border border-white/5 text-xs text-teal-400 font-mono flex items-center justify-between\">\n278 |                       <span>Telemetry</span>\n279 |                       <span>{activeAcc.perfMetric}</span>\n280 |                     </div>\n281 |                   </div>\n282 |                 </div>\n283 |               </div>\n284 | \n285 |               <div className=\"mt-8 pt-6 border-t border-white/5 relative z-10 flex items-center justify-between flex-wrap gap-4\">\n286 |                 <div className=\"flex flex-col\">\n287 |                   <span className=\"text-[10px] text-white/30 font-mono\">MANIFEST ID</span>\n288 |                   <span className=\"text-[11px] text-white/60 font-mono font-semibold\">{activeAcc.id}_v1.0</span>\n289 |                 </div>\n290 |                 \n291 |                 <button\n292 |                   onClick={() => handleDeploySandbox(activeAcc.id)}\n293 |                   disabled={sandboxActive[activeAcc.id] || deployingId === activeAcc.id}\n294 |                   className={`px-5 py-2.5 rounded-lg text-xs font-semibold flex items-center gap-2 transition-all cursor-pointer ${\n295 |                     sandboxActive[activeAcc.id]\n296 |                       ? \"bg-green-500/10 text-green-400 border border-green-500/30 cursor-default\"\n297 |                       : deployingId === activeAcc.id\n298 |                       ? \"bg-white/5 text-white/50 border border-white/10 cursor-not-allowed\"\n299 |                       : \"bg-[#009DFF] text-white hover:bg-[#009DFF]/90\"\n300 |                   }`}\n301 |                 >\n302 |                   {sandboxActive[activeAcc.id] ? (\n303 |                     <>\n304 |                       <CheckCircle2 className=\"w-4 h-4 text-green-400\" /> Active in Sandbox\n305 |                     </>\n306 |                   ) : deployingId === activeAcc.id ? (\n307 |                     <>Deploying...</>\n308 |                   ) : (\n309 |                     <>\n310 |                       <Play className=\"w-3.5 h-3.5 fill-current\" /> Deploy Sandbox\n311 |                     </>\n312 |                   )}\n313 |                 </button>\n314 |               </div>\n315 |             </div>\n316 | \n317 |           </div>\n318 |         </MotionReveal>\n319 | \n320 |         {/* Section 2: Technical Bento Grid mapping out the anatomy of GFF agents */}\n321 |         <MotionReveal className=\"space-y-12\">\n322 |           <div className=\"text-center max-w-3xl mx-auto space-y-3\">\n323 |             <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Standardized Blueprint Anatomy</span>\n324 |             <h2 className=\"text-2xl sm:text-3xl font-bold text-white tracking-tight\">Structured Agent Architecture</h2>\n325 |             <p className=\"text-white/50 text-sm font-light\">Every component in our registry is engineered across three foundational compliance and integration layers.</p>\n326 |           </div>\n327 | \n328 |           <BentoGrid>\n329 |             <BentoCard\n330 |               title=\"1. Context Boundary Spec\"\n331 |               description=\"Defines precise model parameters, token utilization thresholds, temperature limitations, and strict system context-window caps to guarantee deterministic outputs.\"\n332 |               icon={<Settings className=\"w-5 h-5 text-red-500\" />}\n333 |               badge=\"Deterministic Engine\"\n334 |               glowColor=\"red\"\n335 |             />\n336 |             <BentoCard\n337 |               title=\"2. Dynamic Safety Shields\"\n338 |               description=\"Enforces continuous, near-zero-latency policy checks on raw prompts, parsing and sanitizing personal data, code injections, and operational policy deviations.\"\n339 |               icon={<ShieldCheck className=\"w-5 h-5 text-blue-500\" />}\n340 |               badge=\"Security Filter\"\n341 |               glowColor=\"blue\"\n342 |             />\n343 |             <BentoCard\n344 |               title=\"3. Cryptographic Integrations\"\n345 |               description=\"Declares static tools and signed system webhooks, enabling highly auditable interactions with internal ERP portals, microservices, and databases.\"\n346 |               icon={<Layers className=\"w-5 h-5 text-purple-500\" />}\n347 |               badge=\"Integration Interface\"\n348 |               glowColor=\"purple\"\n349 |             />\n350 |           </BentoGrid>\n351 |         </MotionReveal>\n352 | \n353 |         {/* Related platform links to make navigation easy */}\n354 |         <MotionReveal className=\"border-t border-white/5 pt-16 grid grid-cols-1 md:grid-cols-2 gap-8\">\n355 |           <a \n356 |             href=\"/platforms/runtime-governance\"\n357 |             className=\"group p-8 rounded-2xl border border-white/5 bg-gradient-to-br from-black to-[#050505] hover:border-white/10 transition-all flex flex-col justify-between min-h-[160px]\"\n358 |           >\n359 |             <div>\n360 |               <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-widest\">Next Chapter</span>\n361 |               <h4 className=\"text-lg font-bold text-white group-hover:text-[#009DFF] transition-colors mt-2 flex items-center gap-1.5