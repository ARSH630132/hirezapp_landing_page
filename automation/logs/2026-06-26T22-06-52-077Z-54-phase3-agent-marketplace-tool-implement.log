55 |     <motion.div\n56 |       initial={{ opacity: 0, ...offset }}\n57 |       whileInView={{ opacity: 1, y: 0, x: 0 }}\n58 |       viewport={{ once: true, amount: threshold }}\n59 |       transition={{\n60 |         duration: duration,\n61 |         delay: delay,\n62 |         ease: [0.16, 1, 0.3, 1], // Custom premium cubic-bezier curve (easeOutExpo)\n63 |       }}\n64 |       className={className}\n65 |     >\n66 |       {children}\n67 |     </motion.div>\n68 |   );\n69 | }","success":true}],"durationMs":5}}
