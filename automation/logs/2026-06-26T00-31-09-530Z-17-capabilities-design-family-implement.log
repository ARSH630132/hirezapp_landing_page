{"ts":"2026-06-26T00:28:10.605Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"run_commands","toolCallId":"ag6cccxn","input":{"commands":["node -e '\nconst fs = require(\"fs\");\nconst code = `\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport RelatedPagesGrid from \"@/components/inner-pages/RelatedPagesGrid\";\nimport { CheckCircle, ArrowRight, Shield, Layers, Cpu, Settings, Activity, Compass, Network, Database, GraduationCap, Wrench, FlaskConical, Workflow } from \"lucide-react\";\n\n// Types\nexport interface UseCase {\n  title: string;\n  description: string;\n  badge: string;\n  metric?: { value: string; label: string };\n}\n\nexport interface DeliveryModel {\n  name: string;\n  desc: string;\n  features: string[];\n}\n\nexport interface BusinessOutcome {\n  value: string;\n  label: string;\n  desc: string;\n}\n\nexport interface RelatedPage {\n  title: string;\n  tag: string;\n  desc: string;\n  href: string;\n}\n\ninterface CapabilitySubpageProps {\n  slug: string;\n  category: string;\n  title: string;\n  highlightedWord: string;\n  description: string;\n  useCases: UseCase[];\n  activeLayerId: \"experience\" | \"agentic\" | \"knowledge\" | \"data\" | \"governance\" | \"operations\";\n  deliveryModels: DeliveryModel[];\n  outcomes: BusinessOutcome[];\n  nextSteps: RelatedPage[];\n  relatedPlatform: string;\n  relatedPlatformHref: string;\n}\n\nconst layersInfo = {\n  experience: { name: \"Experience Layer\", spec: \"Sub-50ms render loop, universal client portal endpoints.\" },\n  agentic: { name: \"Agentic AI Layer\", spec: \"State isolation sandboxing, dynamic multi-agent loops.\" },\n  knowledge: { name: \"Knowledge Graph Layer\", spec: \"10M+ relational nodes with deterministic lineage tracking.\" },\n  data: { name: \"Data & Integration Layer\", spec: \"Real-time CDC syncing and high-volume chunking pipelines.\" },\n  governance: { name: \"Governance & Safety Layer\", spec: \"99.9% PII scrubbing and compliance audit firewalls.\" },\n  operations: { name: \"Managed AI Operations Layer\", spec: \"Telemetry latency monitoring, cost curves, and auto-failovers.\" }\n};\n\nexport default function CapabilitySubpageFamily({\n  slug,\n  category,\n  title,\n  highlightedWord,\n  description,\n  useCases,\n  activeLayerId,\n  deliveryModels,\n  outcomes,\n  nextSteps,\n  relatedPlatform,\n  relatedPlatformHref\n}: CapabilitySubpageProps) {\n  const [activeModel, setActiveModel] = useState(0);\n\n  // Custom premium SVG hero visuals\n  const renderHeroVisual = () => {\n    const colors = {\n      red: \"#E4000F\",\n      blue: \"#009DFF\",\n      purple: \"#A855F7\",\n      emerald: \"#10B981\"\n    };\n\n    switch (slug) {\n      case \"strategy\":\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"100\" cy=\"100\" r=\"80\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"1\" />\n            <path d=\"M40 100 L160 100 M100 40 L100 160\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"0.8\" />\n            <path d=\"M40 40 L160 160\" stroke=\"url(#gG1)\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n            <circle cx=\"100\" cy=\"100\" r=\"10\" fill=\"#010101\" stroke=\"#E4000F\" strokeWidth=\"2\" />\n            <circle cx=\"150\" cy=\"150\" r=\"6\" fill=\"#009DFF\" />\n            <circle cx=\"50\" cy=\"50\" r=\"4\" fill=\"#A855F7\" />\n            <defs>\n              <linearGradient id=\"gG1\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n      case \"engineering\":\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"40\" y=\"40\" width=\"120\" height=\"120\" rx=\"12\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"1\" />\n            <path d=\"M100 20 L100 180 M20 100 L180 100\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"0.8\" />\n            <circle cx=\"100\" cy=\"100\" r=\"40\" stroke=\"url(#gG2)\" strokeWidth=\"1.5\" className=\"animate-spin\" style={{ transformOrigin: \"center\", animationDuration: \"12s\" }} />\n            <circle cx=\"100\" cy=\"100\" r=\"8\" fill=\"#010101\" stroke=\"#009DFF\" strokeWidth=\"2\" />\n            <circle cx=\"140\" cy=\"100\" r=\"4\" fill=\"#E4000F\" />\n            <circle cx=\"60\" cy=\"100\" r=\"4\" fill=\"#E4000F\" />\n            <defs>\n              <linearGradient id=\"gG2\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#009DFF\" /><stop offset=\"1\" stopColor=\"#A855F7\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n      case \"agents\":\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <g className=\"animate-pulse\" style={{ animationDuration: \"3s\" }}>\n              <polygon points=\"100,30 160,130 40,130\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"1\" />\n              <circle cx=\"100\" cy=\"30\" r=\"6\" fill=\"#A855F7\" />\n              <circle cx=\"160\" cy=\"130\" r=\"6\" fill=\"#009DFF\" />\n              <circle cx=\"40\" cy=\"130\" r=\"6\" fill=\"#E4000F\" />\n              <line x1=\"100\" y1=\"30\" x2=\"100\" y2=\"90\" stroke=\"url(#gG3)\" strokeWidth=\"1.2\" />\n              <line x1=\"40\" y1=\"130\" x2=\"100\" y2=\"90\" stroke=\"url(#gG3)\" strokeWidth=\"1.2\" />\n              <line x1=\"160\" y1=\"130\" x2=\"100\" y2=\"90\" stroke=\"url(#gG3)\" strokeWidth=\"1.2\" />\n              <circle cx=\"100\" cy=\"90\" r=\"10\" fill=\"#010101\" stroke=\"#FFF\" strokeWidth=\"2\" />\n            </g>\n            <defs>\n              <linearGradient id=\"gG3\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#A855F7\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n      case \"governance\":\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M100 30 L160 55 L160 110 C160 150 100 175 100 175 C100 175 40 150 40 110 L40 55 Z\" stroke=\"url(#gG4)\" strokeWidth=\"2\" />\n            <circle cx=\"100\" cy=\"100\" r=\"24\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n            <circle cx=\"100\" cy=\"100\" r=\"6\" fill=\"#10B981\" />\n            <defs>\n              <linearGradient id=\"gG4\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#10B981\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n      case \"data\":\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M30 60 H170 M30 100 H170 M30 140 H170\" stroke=\"rgba(255,255,255,0.05)\" strokeWidth=\"1.5\" />\n            <circle cx=\"50\" cy=\"60\" r=\"4\" fill=\"#009DFF\" />\n            <circle cx=\"100\" cy=\"100\" r=\"4\" fill=\"#E4000F\" />\n            <circle cx=\"150\" cy=\"140\" r=\"4\" fill=\"#A855F7\" />\n            <path d=\"M50 60 C80 80, 80 80, 100 100 S120 120, 150 140\" stroke=\"url(#gG5)\" strokeWidth=\"1.5\" strokeDasharray=\"3 3\" />\n            <defs>\n              <linearGradient id=\"gG5\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#009DFF\" /><stop offset=\"1\" stopColor=\"#E4000F\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n      default:\n        return (\n          <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"100\" cy=\"100\" r=\"60\" stroke=\"url(#gGen)\" strokeWidth=\"1.5\" strokeDasharray=\"10 5\" className=\"animate-spin\" style={{ transformOrigin: \"center\", animationDuration: \"25s\" }} />\n            <rect x=\"75\" y=\"75\" width=\"50\" height=\"50\" rx=\"8\" fill=\"#010101\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n            <circle cx=\"100\" cy=\"100\" r=\"4\" fill=\"#009DFF\" />\n            <defs>\n              <linearGradient id=\"gGen\" x1=\"0\" y1=\"0\" x2=\"200\" y2=\"200\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n              </linearGradient>\n            </defs>\n          </svg>\n        );\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      {/* Hero */}\n      <InnerPageHero\n        category={category}\n        title={title}\n        highlightedWord={highlightedWord}\n        description={description}\n        breadcrumbs={[\n          { label: \"Home\", href: \"/\" },\n          { label: \"Capabilities\", href: \"/capabilities\" },\n          { label: title }\n        ]}\n      />\n\n      {/* Tailored Custom Hero Graphics Panel (Visual differentiation for each subpage) */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-16 -mt-8\">\n        <div className=\"max-w-[1795px] mx-auto border border-white/5 bg-[#030304]/40 backdrop-blur-md rounded-[24px] p-8 flex flex-col md:flex-row items-center justify-between gap-8\">\n          <div className=\"flex-1\">\n            <span className=\"text-[10px] font-mono tracking-widest text-[#009DFF] uppercase font-bold\">SYSTEM VECTOR</span>\n            <h3 className=\"text-[20px] font-bold text-white mt-2\">Architectural Blueprint</h3>\n            <p className=\"mt-2 text-[13px] text-white/50 font-light leading-[1.6]\">\n              This specialized capability runs directly within our systems model. It interfaces cleanly with GFF core systems to secure determinism, low latency, and zero configuration leakage.\n            </p>\n          </div>\n          <div className=\"w-full md:w-auto shrink-0 flex justify-center items-center p-4 bg-black/40 border border-white/5 rounded-2xl min-w-[200px]\">\n            {renderHeroVisual()}\n          </div>\n        </div>\n      </section>\n\n      {/* Use Cases Grid */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-20 pt-8 border-t border-white/5\">\n        <div className=\"max-w-[1795px] mx-auto\">\n          <div className=\"text-center max-w-[800px] mx-auto mb-12\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#009DFF] uppercase font-bold\">TACTICAL VECTOR</span>\n            <h2 className=\"text-[28px] sm:text-[34px] font-bold text-white tracking-tight mt-2\">Enterprise Use Cases</h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n            {useCases.map((uc, i) => (\n              <div key={i} className=\"group relative p-6 rounded-2xl border border-white/5 bg-[#030304]/60 hover:border-white/10 transition-all duration-300\">\n                <span className=\"text-[9px] font-mono tracking-widest text-white/40 uppercase bg-white/5 px-2 py-0.5 rounded border border-white/10\">\n                  {uc.badge}\n                </span>\n                <h4 className=\"text-[17px] font-semibold text-white tracking-tight mt-4\">{uc.title}</h4>\n                <p className=\"mt-2 text-[13px] leading-[1.6] text-white/50 font-light group-hover:text-white/70 transition-colors\">\n                  {uc.description}\n                </p>\n                {uc.metric && (\n                  <div className=\"mt-6 pt-4 border-t border-white/5\">\n                    <span className=\"text-[24px] font-bold text-white tracking-tight leading-none\">\n                      {uc.metric.value}\n                    </span>\n                    <p className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mt-1\">\n                      {uc.metric.label}\n                    </p>\n                  </div>\n                )}\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Architecture Integration Spotlight */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-20 border-t border-white/5 pt-16\">\n        <div className=\"max-w-[1795px] mx-auto\">\n          <div className=\"text-center max-w-[800px] mx-auto mb-12\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">STACK INTEGRATION</span>\n            <h2 className=\"text-[28px] sm:text-[34px] font-bold text-white tracking-tight mt-2\">Active Architecture Placement</h2>\n          </div>\n\n          <div className=\"bg-[#030304]/60 border border-white/5 rounded-2xl p-6 lg:p-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n            <div className=\"lg:col-span-7 flex flex-col justify-center\">\n              <span className=\"text-[10px] font-mono text-white/30 uppercase tracking-widest mb-4\">6-LAYER ACTIVE DIRECTORY</span>\n              <div className=\"space-y-2\">\n                {Object.entries(layersInfo).map(([id, info]) => {\n                  const isActive = activeLayerId === id;\n                  return (\n                    <div\n                      key={id}\n                      className={`p-3.5 rounded-xl border transition-all flex justify-between items-center ${\n                        isActive ? \"bg-white/5 border-[#009DFF]\" : \"bg-black/20 border-white/5 opacity-55\"\n                      }`}\n                    >\n                      <div>\n                        <h4 className=\"text-[13.5px] font-semibold text-white\">{info.name}</h4>\n                        <span className=\"text-[10.5px] text-white/40 font-mono uppercase\">{isActive ? \"PRIMARY SYSTEM HOUSING\" : \"COMPATIBLE\"}</span>\n                      </div>\n                      <div className={`w-2.5 h-2.5 rounded-full ${isActive ? \"bg-[#009DFF]\" : \"bg-white/10\"}`} />\n                    </div>\n                  );\n                })}\n              </div>\n            </div>\n\n            <div className=\"lg:col-span-5 flex flex-col justify-between min-h-[220px]\">\n              <div>\n                <span className=\"text-[9px] font-mono tracking-widest text-[#009DFF] uppercase bg-[#009DFF]/5 px-2 py-0.5 rounded border border-[#009DFF]/10\">INTEGRATION DETAIL</span>\n                <h3 className=\"text-[19px] font-bold text-white mt-3\">\n                  Primarily Housed: {layersInfo[activeLayerId].name}\n                </h3>\n                <p className=\"mt-2.5 text-[13px] leading-[1.6] text-white/50 font-light\">\n                  This capability runs natively within the {layersInfo[activeLayerId].name}. It conforms to strict {layersInfo[activeLayerId].spec} standards to secure continuous uptime and clean orchestration flow.\n                </p>\n              </div>\n              <div className=\"mt-6 pt-4 border-t border-white/5\">\n                <a href=\"/capabilities\" className=\"text-[12px] font-mono text-[#009DFF] hover:text-white transition-colors flex items-center gap-2\">\n                  <span>VIEW FULL STACK DETAILS</span>\n                  <ArrowRight className=\"w-3.5 h-3.5\" />\n                </a>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Delivery Models Panels (Tabs/Carousels pattern) */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-20 border-t border-white/5 pt-16\">\n        <div className=\"max-w-[1795px] mx-auto\">\n          <div className=\"text-center max-w-[800px] mx-auto mb-12\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#009DFF] uppercase font-bold\">OPERATIONAL MODEL</span>\n            <h2 className=\"text-[28px] sm:text-[34px] font-bold text-white tracking-tight mt-2\">System Deployment Models</h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n            <div className=\"lg:col-span-4 flex flex-col gap-2\">\n              {deliveryModels.map((m, idx) => (\n                <button\n                  key={idx}\n                  onClick={() => setActiveModel(idx)}\n                  className={`w-full text-left p-4 rounded-xl border transition-all ${\n                    activeModel === idx ? \"bg-white/5 border-[#009DFF] text-white\" : \"bg-[#030304]/30 border-white/5 text-white/50 hover:border-white/10\"\n                  }`}\n                >\n                  <span className=\"text-[9px] font-mono block text-[#009DFF] mb-1\">DEPLOYMENT MODULE 0{idx+1}</span>\n                  <span className=\"text-[14.5px] font-semibold\">{m.name}</span>\n                </button>\n              ))}\n            </div>\n\n            <div className=\"lg:col-span-8 bg-[#030304]/60 border border-white/5 rounded-2xl p-6 lg:p-8 flex flex-col justify-between\">\n              <div>\n                <span className=\"text-[9px] font-mono tracking-widest text-[#009DFF] uppercase bg-[#009DFF]/5 px-2 py-0.5 rounded border border-[#009DFF]/10\">ACTIVE COMPILER</span>\n                <h3 className=\"text-[20px] font-bold text-white mt-3\">\n                  {deliveryModels[activeModel].name}\n                </h3>\n                <p className=\"mt-2.5 text-[13.5px] leading-[1.6] text-white/55 font-light\">\n                  {deliveryModels[activeModel].desc}\n                </p>\n\n                <div className=\"mt-6\">\n                  <span className=\"text-[10px] font-mono uppercase text-white/40 tracking-wider\">Features & Protocols</span>\n                  <ul className=\"mt-3 grid grid-cols-1 md:grid-cols-2 gap-2\">\n                    {deliveryModels[activeModel].features.map((feat, idx) => (\n                      <li key={idx} className=\"flex items-center gap-2.5 text-[12.5px] text-white/80 font-light\">\n                        <CheckCircle className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n                        <span>{feat}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Business Outcomes Section */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-20 border-t border-white/5 pt-16\">\n        <div className=\"max-w-[1795px] mx-auto\">\n          <div className=\"text-center max-w-[800px] mx-auto mb-12\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">SYSTEM METRIC IMPACT</span>\n            <h2 className=\"text-[28px] sm:text-[34px] font-bold text-white tracking-tight mt-2\">Operational Impact & Milestones</h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n            {outcomes.map((out, idx) => (\n              <div key={idx} className=\"p-6 rounded-2xl border border-white/5 bg-[#030304]/40 flex flex-col justify-between\">\n                <div>\n                  <span className=\"text-[32px] font-bold text-white tracking-tight leading-none bg-clip-text text-transparent bg-gradient-to-r from-white to-white/70\">\n                    {out.value}\n                  </span>\n                  <p className=\"text-[10.5px] font-mono text-[#E4000F] uppercase tracking-wider mt-1\">{out.label}</p>\n                  <p className=\"mt-3.5 text-[12.5px] leading-[1.5] text-white/50 font-light\">{out.desc}</p>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Related Platform Redirect */}\n      <section className=\"relative w-full px-6 lg:px-16 pb-20 border-t border-white/5 pt-16\">\n        <div className=\"max-w-[1795px] mx-auto bg-[#030304]/60 border border-white/5 rounded-2xl p-6 lg:p-8 flex flex-col md:flex-row items-center justify-between gap-6\">\n          <div>\n            <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-widest\">ECOSYSTEM MATRIX CONNECTION</span>\n            <h3 className=\"text-[18px] font-bold text-white mt-1\">Utilizes platform: {relatedPlatform}</h3>\n            <p className=\"mt-1 text-[13px] text-white/55 font-light\">This capability is actively integrated and supported by GFF {relatedPlatform} protocols.</p>\n          </div>\n          <a\n            href={relatedPlatformHref}\n            className=\"px-6 py-3 rounded-full text-[13px] font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/15 transition-all flex items-center gap-2 shrink-0\"\n          >\n            <span>Inspect {relatedPlatform}</span>\n            <ArrowRight className=\"w-3.5 h-3.5\" />\n          </a>\n        </div>\n      </section>\n\n      {/* Next Steps / Related Capabilities */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-20 border-t border-white/5 pt-16\">\n        <RelatedPagesGrid links={nextSteps} />\n      </div>\n\n      {/* CTA */}\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-16\">\n        <PremiumCTA\n          title={`Ready to Operationalize ${title}?`}\n          description=\"Schedule a strict technical architecture session with GFF lead engineers to map custom endpoints and verify regulatory compliance.\"\n          primaryLabel=\"Schedule Deep-Dive\"\n          secondaryLabel=\"View Capability Command\"\n          secondaryHref=\"/capabilities\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}\n`;\nfs.writeFileSync(\"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/inner-pages/CapabilitySubpageFamily.tsx\", code, \"utf8\");\nconsole.log(\"File CapabilitySubpageFamily.tsx written successfully.\");\n'"]}}}
