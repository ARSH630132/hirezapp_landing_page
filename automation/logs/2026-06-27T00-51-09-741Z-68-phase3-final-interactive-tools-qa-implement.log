==\n241 | // 2. Component Implementation & Layout Mathematics\n242 | // ==========================================\n243 | \n244 | interface NodePos {\n245 |   x: number; // percentage 0-100\n246 |   y: number; // percentage 0-100\n247 | }\n248 | \n249 | function getNodePositions(pattern: string, stagesList: any[]): NodePos[] {\n250 |   const N = stagesList.length;\n251 |   if (N === 0) return [];\n252 | \n253 |   if (N === 1) {\n254 |     return [{ x: 50, y: 50 }];\n255 |   }\n256 | \n257 |   const positions: NodePos[] = [];\n258 | \n259 |   if (pattern === \"sequential\") {\n260 |     // Linear pipeline\n261 |     // Distribute evenly along the X axis from 14% to 86%\n262 |     for (let i = 0; i < N; i++) {\n263 |       const x = 14 + (i / (N - 1)) * 72;\n264 |       // Alternate wave pattern if there are many nodes (to prevent vertical or horizontal crowding)\n265 |       const y = N > 5 ? (i % 2 === 0 ? 38 : 62) : 50;\n266 |       positions.push({ x, y });\n267 |     }\n268 |   } else if (pattern === \"hierarchical\") {\n269 |     // Supervisor node (first reasoning node, or node 0)\n270 |     // Put Supervisor at top center (50%, 22%)\n271 |     // Put all other nodes (workers) in a horizontal row at (50% + offset, 72%)\n272 |     let supervisorIdx = stagesList.findIndex(s => s.type === \"reasoning\");\n273 |     if (supervisorIdx === -1) supervisorIdx = 0;\n274 | \n275 |     const workerCount = N - 1;\n276 | \n277 |     let workerJ = 0;\n278 |     for (let i = 0; i < N; i++) {\n279 |       if (i === supervisorIdx) {\n280 |         positions.push({ x: 50, y: 22 });\n281 |       } else {\n282 |         const x = workerCount > 1 \n283 |           ? 14 + (workerJ / (workerCount - 1)) * 72\n284 |           : 50;\n285 |         positions.push({ x, y: 72 });\n286 |         workerJ++;\n287 |       }\n288 |     }\n289 |   } else if (pattern === \"swarm\") {\n290 |     // Arranged in an ellipse\n291 |     const cx = 50;\n292 |     const cy = 48;\n293 |     const rx = 33;\n294 |     const ry = 25;\n295 | \n296 |     for (let i = 0; i < N; i++) {\n297 |       const angle = (i / N) * 2 * Math.PI - Math.PI / 2; // start top-center\n298 |       const x = cx + rx * Math.cos(angle);\n299 |       const y = cy + ry * Math.sin(angle);\n300 |       positions.push({ x, y });","success":true}],"durationMs":2}}
