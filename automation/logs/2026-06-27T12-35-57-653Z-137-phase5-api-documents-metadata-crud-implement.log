{"ts":"2026-06-27T12:33:23.706Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"m6y0mlpo","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/scripts/test-document-apis.js","new_text":"/* eslint-disable */\n\nconst { execSync } = require('child_process');\nconst fs = require('fs');\nconst path = require('path');\nconst T = path.join(__dirname, '..', 'temp-document-build');\nif (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\ntry {\n  execSync('npx tsc lib/api-auth.ts app/api/v1/documents/route.ts app/api/v1/documents/[id]/route.ts --outDir temp-document-build --module commonjs --target es2022 --moduleResolution node --esModuleInterop --skipLibCheck', { stdio: 'ignore' });\n  console.log(\"✔ Compile success.\");\n} catch (e) {\n  console.error(\"Compilation error:\", e.message);\n  process.exit(1);\n}\nconst apiAuth = require('../temp-document-build/lib/api-auth.js');\nconst docRoute = require('../temp-document-build/app/api/v1/documents/route.js');\nconst didRoute = require('../temp-document-build/app/api/v1/documents/[id]/route.js');\n\nfunction getAuth(email) {\n  const u = apiAuth.API_MOCK_USERS[email];\n  return `Bearer ${apiAuth.signJwt({ sub: u.id, email: u.email, role: u.role, name: u.name, clientAssociation: u.clientAssociation })}`;\n}\n\nasync function run() {\n  try {\n    const admin = getAuth(\"s.vance@governance.gff.ai\");\n    const client = getAuth(\"a.mercer@apex-sovereign.gff.ai\"); // client-001\n    const member = getAuth(\"s.jenkins@fed-treasury.gff.ai\"); // client-004\n    const inactive = getAuth(\"m.vance@sovereign-logistics.gff.ai\");\n\n    // 1. Auth guards\n    let res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": inactive } }));\n    if (res.status !== 403) throw new Error(\"Inactive user must be 403\");\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\"));\n    if (res.status !== 401) throw new Error(\"No token must be 401\");\n\n    // 2. GET lists & filtering\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": admin } }));\n    let d = await res.json();\n    if (res.status !== 200 || d.documents.length < 5) throw new Error(\"Admin list failed\");\n\n    // Client Mercer (client-001) list should filter by client-001 and visibility !== 'admin_only'\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": client } }));\n    d = await res.json();\n    if (d.documents.some(doc => doc.client_id !== \"client-001\")) throw new Error(\"Client list leakage\");\n    if (d.documents.some(doc => doc.visibility === \"admin_only\")) throw new Error(\"Client see admin_only leakage\");\n\n    // Member Jenkins (client-004) has doc-004 which is client-004 but visibility is 'admin_only'.\n    // She should see 0 documents because visibility is admin_only.\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents\", { headers: { \"Authorization\": member } }));\n    d = await res.json();\n    if (d.documents.length !== 0) throw new Error(\"Client role saw admin_only document!\");\n\n    // Search filter\n    res = await docRoute.GET(new Request(\"http://l/api/v1/documents?search=Ruleset\", { headers: { \"Authorization\": admin } }));\n    d = await res.json();\n    if (d.documents.length !== 1 || !d.documents[0].title.includes(\"Ruleset\")) throw new Error(\"Search filter failed\");\n\n    // 3. GET single\n    res = await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-001\", { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: \"doc-001\" }) });\n    d = await res.json();\n    if (res.status !== 200 || d.document.id !== \"doc-001\") throw new Error(\"GET single failed\");\n\n    // Cross-tenant GET or admin_only GET by client must be 403\n    res = await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-004\", { headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: \"doc-004\" }) });\n    if (res.status !== 403) throw new Error(\"Cross-tenant GET must be 403\");\n\n    // Same-tenant but admin_only document GET by client must be 403\n    res = await didRoute.GET(new Request(\"http://l/api/v1/documents/doc-004\", { headers: { \"Authorization\": member } }), { params: Promise.resolve({ id: \"doc-004\" }) });\n    if (res.status !== 403) throw new Error(\"Client same tenant admin_only GET must be 403\");\n\n    // 4. POST create\n    const docData = { title: \"Test Doc Spec\", document_type: \"specification\", client_id: \"client-002\", desc: \"Test description\" };\n    res = await docRoute.POST(new Request(\"http://l/api/v1/documents\", { method: \"POST\", headers: { \"Authorization\": client }, body: JSON.stringify(docData) }));\n    if (res.status !== 403) throw new Error(\"Client POST must be 403\");\n\n    res = await docRoute.POST(new Request(\"http://l/api/v1/documents\", { method: \"POST\", headers: { \"Authorization\": admin }, body: JSON.stringify(docData) }));\n    if (res.status !== 201) throw new Error(\"POST failed\");\n    d = await res.json();\n    const createdId = d.document.id;\n    if (d.document.client_name !== \"Global Retail Enclave [Preview Client]\") throw new Error(\"Client mapping failed\");\n\n    // 5. PATCH update\n    res = await didRoute.PATCH(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": client }, body: JSON.stringify({ title: \"Hacked\" }) }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client PATCH must be 403\");\n\n    res = await didRoute.PATCH(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ title: \"Updated Title\", version: \"v2.0.0\" }) }), { params: Promise.resolve({ id: createdId }) });\n    d = await res.json();\n    if (res.status !== 200 || d.document.title !== \"Updated Title\" || d.document.version !== \"v2.0.0\") throw new Error(\"PATCH failed\");\n\n    // 6. DELETE\n    res = await didRoute.DELETE(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": client } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 403) throw new Error(\"Client DELETE must be 403\");\n\n    res = await didRoute.DELETE(new Request(\"http://l/api/v1/documents/\" + createdId, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 200) throw new Error(\"DELETE failed\");\n\n    res = await didRoute.GET(new Request(\"http://l/api/v1/documents/\" + createdId, { headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: createdId }) });\n    if (res.status !== 404) throw new Error(\"Lookup of deleted doc must return 404\");\n\n    console.log(\"\\x1b[32m✔ VERIFICATION SUCCESSFUL: Documents CRUD APIs Verified!\\x1b[0m\");\n    process.exit(0);\n  } catch (err) {\n    console.error(\"\\x1b[31m✖ Test failed:\\x1b[0m\", err.stack || err.message);\n    process.exit(1);\n  } finally {\n    if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n  }\n}\nrun();\n"}}}
