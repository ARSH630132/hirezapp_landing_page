documents associated with their client ID or are not marked as `admin_only`. I've also incorporated specific error handling to provide appropriate HTTP status codes (403 for Forbidden and 500 for Internal Server Error).\n\n\n**Validating Input Parameters**\n\nI'm now focusing on validating the input parameters for the PATCH request to `/api/v1/documents/[id]/route.ts`. I'm handling cases with a missing or malformed request body, returning 400 Bad Request accordingly. The focus is on validating the content of the body fields. I'm ensuring proper string trimming and type checks for fields like `title` and `document_type`, to prevent invalid data from being persisted.\n\n\n"}}
{"ts":"2026-06-27T12:33:05.378Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"md4srw08","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/api/v1/documents/[id]/route.ts","new_text":"import { NextResponse } from \"next/server\";\nimport { \n  API_MOCK_USERS, API_MOCK_DOCUMENTS, verifyJwt, \n  MockUserDbEntry, ApiDocument, getClientNameFromId, getClientIdFromAssociation \n} from \"../../../../../lib/api-auth\";\n\nexport const runtime = \"nodejs\";\n\nfunction getAuthCaller(req: Request) {\n  const auth = req.headers.get(\"authorization\");\n  if (!auth?.startsWith(\"Bearer \")) return null;\n  const decoded = verifyJwt(auth.substring(7));\n  if (!decoded?.email) return null;\n  const user = (API_MOCK_USERS as Record<string, MockUserDbEntry>)[decoded.email.toLowerCase().trim()];\n  return user && user.status !== \"inactive\" ? user : null;\n}\n\nexport async function GET(req: Request, { params }: { params: any }) {\n  try {\n    const caller = getAuthCaller(req);\n    if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n    const { id } = await params;\n    const doc = (API_MOCK_DOCUMENTS as Record<string, ApiDocument>)[id];\n    if (!doc) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n    \n    if (caller.role !== \"gff_admin\") {\n      const cid = getClientIdFromAssociation(caller.clientAssociation);\n      if (doc.client_id !== cid || doc.visibility === \"admin_only\") {\n        return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n      }\n    }\n    return NextResponse.json({ success: true, document: doc });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\nexport async function PATCH(req: Request, { params }: { params: any }) {\n  try {\n    const caller = getAuthCaller(req);\n    if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n    if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n    \n    const { id } = await params;\n    const doc = (API_MOCK_DOCUMENTS as Record<string, ApiDocument>)[id];\n    if (!doc) return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n    \n    const body = await req.json().catch(() => null);\n    if (!body) return NextResponse.json({ success: false, error: \"Bad Request\" }, { status: 400 });\n\n    const fields = [\"title\", \"document_type\", \"project_id\", \"status\", \"version\", \"owner\", \"visibility\", \"desc\", \"client_id\"];\n    for (const key of fields) {\n      if (body[key] !== undefined) {\n        if (key === \"title\" && (typeof body.title !== \"string\" || !body.title.trim())) {\n          return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid title\" }, { status: 400 });\n        }\n        if (key === \"document_type\" && (typeof body.document_type !== \"string\" || !body.document_type.trim())) {\n          return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid document_type\" }, { status: 400 });\n        }\n        if (key === \"client_id\") {\n          const valids = [\"client-001\", \"client-002\", \"client-003\", \"client-004\"];\n          if (!valids.includes(body.client_id)) {\n            return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id\" }, { status: 400 });\n          }\n          doc.client_id = body.client_id;\n          doc.client_name = getClientNameFromId(body.client_id);\n        } else {\n          (doc as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n        }\n      }\n    }\n    doc.lastUpdated = new Date().toISOString();\n    (API_MOCK_DOCUMENTS as Record<string, ApiDocument>)[id] = doc;\n    return NextResponse.json({ success: true, document: doc });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\nexport async function DELETE(req: Request, { params }: { params: any }) {\n  try {\n    const caller = getAuthCaller(req);\n    if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n    if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n    \n    const { id } = await params;\n    if (!(API_MOCK_DOCUMENTS as Record<string, ApiDocument>)[id]) {\n      return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n    }\n    delete (API_MOCK_DOCUMENTS as Record<string, ApiDocument>)[id];\n    return NextResponse.json({ success: true, message: \"Document deleted.\" });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n"}}}
