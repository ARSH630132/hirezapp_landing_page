let docs = Object.values(API_MOCK_DOCUMENTS) as ApiDocument[];\n\n    if (caller.role !== \"gff_admin\") {\n      const callerCid = getClientIdFromAssociation(caller.clientAssociation);\n      docs = docs.filter(d => d.client_id === callerCid && d.visibility !== \"admin_only\");\n      if (cid && cid !== callerCid) {\n        return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Access denied.\" }, { status: 403 });\n      }\n    } else if (cid) {\n      docs = docs.filter(d => d.client_id === cid);\n    }\n\n    if (pid) docs = docs.filter(d => d.project_id.toLowerCase() === pid.toLowerCase().trim());\n    if (doc_type) docs = docs.filter(d => d.document_type.toLowerCase() === doc_type.toLowerCase().trim());\n    if (status) docs = docs.filter(d => d.status.toLowerCase() === status.toLowerCase().trim());\n    if (visibility) {\n      const q = visibility.toLowerCase().trim();\n      if (caller.role !== \"gff_admin\" && q === \"admin_only\") {\n        return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Access denied.\" }, { status: 403 });\n      }\n      docs = docs.filter(d => d.visibility.toLowerCase() === q);\n    }\n    if (search) {\n      const q = search.toLowerCase().trim();\n      docs = docs.filter(d => \n        d.title.toLowerCase().includes(q) || d.id.toLowerCase().includes(q) ||\n        (d.desc && d.desc.toLowerCase().includes(q)) || d.owner.toLowerCase().includes(q)\n      );\n    }\n\n    return NextResponse.json({ success: true, documents: docs });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n  }\n}\n\nexport async function POST(req: Request) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) {\n      return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n    }\n    const { caller } = auth;\n    if (caller.role !== \"gff_admin\") {\n      return