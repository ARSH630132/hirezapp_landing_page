 function calculateBlueprintScore(answers: BlueprintAnswers) {\n152 |   const dims = calculateBlueprintDimensions(answers);\n153 |   const score = (0.20 * dims.aiMaturity) + (0.25 * dims.businessNeed) + (0.20 * dims.dataReadiness) + (0.20 * dims.processComplexity) + (0.15 * dims.transformationReadiness);\n154 |   return Math.round(score);\n155 | }\n156 | \n157 | export function getScoreCategory(score: number) {\n158 |   if (score <= 25) return \"AI Beginner\";\n159 |   if (score <= 50) return \"AI Explorer\";\n160 |   if (score <= 70) return \"AI Adopter\";\n161 |   if (score <= 85) return \"AI Transformer\";\n162 |   return \"AI-Native Leader\";\n163 | }\n164 | \n165 | \n166 | export function getRecommendedOpportunities(industry: string): string[] {\n167 |   if (industry === \"Banking\") {\n168 |     return [\n169 |       \"Sovereign AML & Transactions Ledger Analyst\",\n170 |       \"Regulatory Compliance Policy & Guardrails Auditing Engine\",\n171 |       \"Automated Credit Risk & Lending Underwriting Copilot\",\n172 |       \"Sovereign Search & Cognitive Synthesis Knowledge Graph\",\n173 |       \"High-Frequency Risk Intelligence & Simulation Agent\"\n174 |     ];\n175 |   }\n176 |   if (industry === \"Retail\") {\n177 |     return [\n178 |       \"AI-Driven Hyper-Personalization Recommendation Engine\",\n179 |       \"Dynamic Inventory & Agentic Supply Chain Optimizing Node\",\n180 |       \"Sovereign Customer Service & Chatbot Concierge\",\n181 |       \"Product Demand Forecasting & Market Simulation Engine\",\n182 |       \"Automated Merchandising Compliance Auditor\"\n183 |     ];\n184 |   }\n185 |   if (industry === \"Healthcare\") {\n186 |     return [\n187 |       \"Sovereign Clinical Note Synthesis & Patient Record Parser\",\n188 |       \"Regulatory FDA Compliance Auditing Guardrail\",\n189 |       \"Diagnostic Support & Medical Research Knowledge Search\",\n190 |       \"Patient Care Path Optimization Agent\",\n191 |       \"AI Billing & Claims Process