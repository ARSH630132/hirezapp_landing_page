ER v4.26</span>\n 873 |             <h2 className=\"text-base font-bold text-white mb-4\">Compiling Strategic SOW Blueprint</h2>\n 874 |             <div className=\"w-full p-4 rounded-xl bg-[#030305] border border-white/5 text-left mb-4 relative overflow-hidden\">\n 875 |               <div className=\"absolute top-0 left-0 h-0.5 bg-[#009DFF] transition-all duration-300\" style={{ width: `${((compilingStepIndex + 1) / compilingMessages.length) * 100}%` }} />\n 876 |               <div className=\"flex gap-2 font-mono text-[9px] text-white/50\">\n 877 |                 <span className=\"text-[#009DFF]\">&gt;</span>\n 878 |                 <p className=\"text-[#00FF9D] font-semibold leading-relaxed\">{compilingMessages[compilingStepIndex]}</p>\n 879 |               </div>\n 880 |             </div>\n 881 |             <p className=\"text-white/30 text-[8px] font-mono uppercase tracking-widest\">ZERO DATA RETENTION LAYER ACTIVATED</p>\n 882 |           </motion.div>\n 883 |         )}\n 884 | \n 885 |         {step === \"preview\" && (\n 886 |           <motion.div key=\"preview\" className=\"space-y-6\">\n 887 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n 888 |               {/* INDEX COLUMN (3 columns) */}\n 889 |               <div className=\"lg:col-span-3 space-y-4 sticky top-6 print:hidden\">\n 890 |                 <div className=\"p-4 rounded-2xl border border-white/5 bg-[#030306]/95 text-left\">\n 891 |                   <span className=\"text-[8px] font-mono text-[#009DFF] font-bold block mb-3 uppercase tracking-widest\">Dossier Index</span>\n 892 |                   <nav className=\"space-y-0.5\">\n 893 |                     {[\n 894 |                       { id: \"executive-summary\", label: \"Executive Summary\", icon: \"📄\" },\n 895 |                       { id: \"challenge-statement\", label: \"Challenge Statement\", icon: \"⚠️\" },\n 896 |                       { id: \"recommended-gff-path\", label: \"Recommended GFF Path\", icon: \"🚀\" },\n 897 |                       { id: \"proposed-workstreams\", label: \"Proposed Workstreams\", icon: \"🗺️\" },\n 898 |                       { id: \"ninety-day-roadmap\", label: \"90-Day Roadmap\", icon: \"📅\" },\n 899 |                       { id: \"suggested-squad\", label: \"Suggested Squad\", icon: \"👥\" },\n 900 |                       { id: \"governance-approach\", label: \"Governance Approach\", icon: \"⚖️\" },\n 901 |                       { id: \"success-measures\", label: \"Success Measures\", icon: \"📈\" },\n 902 |                       { id: \"assumptions\", label: \"Assumptions\", icon: \"📝\" },\n 903 |                       { id: \"risks-mitigations\", label: \"Risks & Mitigations\", icon: \"🔒\" },\n 904 |                       { id: \"next-steps\", label: \"Next Steps\", icon: \"🏁\" }\n 905 |                     ].map((sec, idx) => (\n 906 |                       <button\n 907 |                         key={sec.id}\n 908 |                         onClick={() => {\n 909 |                           setActivePreviewSection(sec.id);\n 910 |                           const el = document.getElementById(sec.id);\n 911 |                           if (el) el.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n 912 |                         }}\n 913 |                         className={`w-full text-left px-2.5 py-1.5 rounded text-[10px] font-mono transition flex items-center gap-2 ${activePreviewSection === sec.id ? \"bg-[#009DFF]/10 text-[#009DFF] font-bold border-l border-[#009DFF]\" : \"text-white/40 hover:text-white\"}`}\n 914 |                       >\n 915 |                         <span>{sec.icon}</span>\n 916 |                         <span>{String(idx + 1).padStart(2, \"0\")}. {sec.label}</span>\n 917 |                       </button>\n 918 |                     ))}\n 919 |                   </nav>\n 920 | \n 921 |                   <div className=\"mt-4 pt-3 border-t border-white/5 space-y-2\">\n 922 |            