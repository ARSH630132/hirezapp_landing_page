nst [isSigned, setIsSigned] = useState(false);\n154 |   const [mounted, setMounted] = useState(false);\n155 |   const [validationErrors, setValidationErrors] = useState<Record<string, string>>({});\n156 |   const [exportToast, setExportToast] = useState<string | null>(null);\n157 | \n158 |   const handleExportClick = (type: string) => {\n159 |     setExportToast(`Premium Feature Sandbox: Exporting as ${type} requires a GFF Enterprise Control Center gateway cloud connection. This offline terminal runs in strict zero-retention memory isolation.`);\n160 |     setTimeout(() => setExportToast(null), 6000);\n161 |   };\n162 | \n163 |   useEffect(() => {\n164 |     setMounted(true);\n165 |     if (typeof window !== \"undefined\") {\n166 |       const draft = localStorage.getItem(\"gff_proposal_draft_intake\");\n167 |       if (draft) setHasSavedDraft(true);\n168 |     }\n169 |   }, []);\n170 | \n171 |   const validateStep = (gate: 1 | 2 | 3): boolean => {\n172 |     const errors: Record<string, string> = {};\n173 |     if (gate === 1) {\n174 |       if (!inputs.industry) errors.industry = \"Please select a primary industry vertical.\";\n175 |       if (!inputs.companySize) errors.companySize = \"Please specify company scale.\";\n176 |     } else if (gate === 2) {\n177 |       if (!inputs.primaryChallenge) errors.primaryChallenge = \"Please identify your primary business challenge.\";\n178 |       if (inputs.primaryChallenge === \"other\" && !inputs.customChallenge.trim()) {\n179 |         errors.customChallenge = \"Please specify your custom corporate obstacle.\";\n180 |       }\n181 |       if (inputs.priorityOutcomes.length === 0) {\n182 |         errors.priorityOutcomes = \"Please select at least one priority target outcome.\";\n183 |       }\n184 |       if (!inputs.targetTimeline) errors.targetTimeline = \"Please select a target timeline.\";\n185 |     } else if (gate === 3) {\n186 |       if (!inputs.preferredEngagementPath) errors.preferredEngagementPath = \"Please select an engagement pathway.\";\n187 |     }\n188 | \n189 |     setValidationErrors(errors);\n190 |     return Object.keys(errors).length === 0;\n191 |   };\n192 | \n193 |   const handleNextGate = () => {\n194 |     if (validateStep(activeStepGate)) {\n195 |       setActiveStepGate((prev) => (prev + 1) as 1 | 2 | 3);\n196 |     }\n197 |   };\n198 | \n199 |   const handleCompile = () => {\n200 |     if (!validateStep(3)) return;\n201 |     setStep(\"compiling\");\n202 |     setCompilingStepIndex(0);\n203 |   };\n204 | \n205 |   useEffect(() => {\n206 |     if (step !== \"compiling\") return;\n207 |     const interval = setInterval(() => {\n208 |       setCompilingStepIndex((prev) => {\n209 |         if (prev < compilingMessages.length - 1) return prev + 1;\n210 |         clearInterval(interval);\n211 |         setStep(\"preview\");\n212 |         return prev;\n213 |       });\n214 |     }, 450);\n215 |     return () => clearInterval(interval);\n216 |   }, [step]);\n217 | \n218 |   const handleSaveDraft = () => {\n219 |     if (typeof window !== \"undefined\") {\n220 |       localStorage.setItem(\"gff_proposal_draft_intake\", JSON.stringify(inputs));\n221 |       setSaved(true);\n222 |       setHasSavedDraft(true);\n223 |       setTimeout(() => setSaved(false), 2000);\n224 |     }\n225 |   };\n226 | \n227 |   const handleRestoreDraft = () => {\n228 |     if (typeof window !== \"undefined\") {\n229 |       const draft = localStorage.getItem(\"gff_proposal_draft_intake\");\n230 |       if (draft) {\n231 |         setInputs(JSON.parse(draft));\n232 |         setHasSavedDraft(false);\n233 |       }\n234 |     }\n235 |   };\n236 | \n237 |   const handleReset = () => {\n238 |     setInputs(INITIAL_INTAKE_INPUTS);\n239 |     setStep(\"configure\");\n240 |     setActiveStepGate(1);\n241 |     setIsSigned(false);\n242 |     setSignName(\"\");\n243 |     setSignTitle(\"\");\n244 |     setValidationErrors({});\n245 |     if (typeof window !== \"undefined\") {\n246 |       localStorage.removeItem(\"gff_proposal_draft_intake\");\n247 |       setHasSavedDraft(false);\n248 |     }\n249 |   };\n250 | \n251 |   const handlePrint = () => {\n252 |     if (typeof window !== \"undefined\") window.print();\n253 |   };\n254 | \n255 |   const handleCopyOutline = () => {\n256 |     const data = generateProposalData();\n257 |     const p1 = data.p1;\n258 |     const p2 = data.p2;\n259 |     const p3 = data.p3;\n260 |     const weeks = data.weeks;\n261 | \n262 |     const outlineText = `GFF AI SOVEREIGN INTEGRATION PROPOSAL & OUTLINE (FRONTEND PREVIEW ONLY)\n263 | ======================================================================\n264 | CLIENT: ${data.org} | VERTICAL: ${data.industryLabel}\n265 | OPERATIONAL SCALE: ${data.companySizeLabel} (${data.companySizeRange})\n266 | VPC DEPLOYMENT REGION: ${data.geographyLabel}\n267 | PREFERRED ENGAGEMENT PATHWAY: ${data.engagementPathObj.label} (${data.engagementPathObj.badge})\n268 | CALCULATED SOW TIMELINE: ${weeks} Weeks | BUDGET: ${data.budgetLabel}\n269 | STAKEHOLDER SPONSORS: ${data.stakeholdersLabel}\n270 | \n271 | SECTION I: EXECUTIVE SUMMARY\n272 | GFF AI recommends deploying a dedicated ${data.engagementPathObj.label} framework inside the single-tenant VPC perimeter for ${data.org} to address strategic bottlenecks in the ${data.industryLabel} sector. Over ${weeks} Weeks, GFF establishes isolated secure pipelines, delivering sovereign capabilities like ${data.selectedOutcomeLabels.join(\", \")}.\n273 | \n274 | SECTION II: CHALLENGE STATEMENT\n275 | Third-party cloud-hosted AI APIs introduce severe compliance risks and telemetry leaks. The core technical bottleneck to resolve for ${data.org} is \"${data.challengeLabel}\". Left unmitigated, data fragmentation and cost explosion will slow down operational cycles.\n276 | \n277 | SECTION III: RECOMMENDED GFF PATH\n278 | We recommend the ${data.engagementPathObj.label} path (${data.engagementPathObj.badge}) deployed completely isolated on single-tenant architecture within ${data.geographyLabel} with a strict zero data-retention layer.\n279 | \n280 | SECTION IV: PROPOSED WORKSTREAMS\n281 | - Workstream A: Hardened Perimeter Setup (Weeks 1 - ${p1}): Configure VPC boundaries and verify zero-retention.\n282 | - Workstream B: Pipeline Core Integration (Weeks ${p1 + 1} - ${p1 + p2}): Deploy OmniMesh read-only connectors and metadata layers.\n283 | - Workstream C: Agent Orchestration & Tuning (Weeks ${p1 + p2 + 1} - ${p1 + p2 + p3}): Standardize agent configurations and workflow guardrails.\n284 | - Workstream D: Telemetry Logging & Handoff (Weeks ${p1 + p2 + p3 + 1} - ${weeks}): Integrate real-time audit ledgers and operator dashboards.\n285 | \n286 | SECTION V: 90-DAY ROADMAP\n287 | - Day 1-30: Perimeter Isolation: Connect legacy data silos via OmniMesh read-only boundaries.\n288 | - Day 31-60: Agent Workflow Design: Orchestrate multi-agent decision nodes and feedback loops.\n289 | - Day 61-90: Go-Live & Certification: Scale the agent fleet and complete sovereign compliance certification.\n290 | \n291 | SECTION VI: SUGGESTED SQUAD\n292 | Squad cohort: ${data.engagementPathObj.squad}\n293 | - Lead Solutions Architect (VPC & data boundary configuration)\n294 | - Systems Engineers (local weight tuning & pipeline performance)\n295 | - Security Compliance Auditor (zero-retention validation logging)\n296 | \n297 | SECTION VII: GOVERNANCE APPROACH\n298 | GFF enforces a \"Zero Trust, Zero Retention\" sovereign AI governance framework. Prompt-history is instantly zeroed out post-execution, and telemetry logs are recorded to a read-only audit ledger.\n299 | \n300 | SECTION VIII: SUCCESS MEASURES\n301 | - Latency: Sub-150ms dynamic cognitive decision loops.\n302 | - IP Safety: Absolute zero external IP leaks or SaaS memory retention logs.\n303 | - OpEx Reclamation: 30%+ reclaimed external SaaS token and licensing expenses.\n304 | - Telemetry Auditing: 100% logging coverage verified by the secure audit ledger.\n305 | \n306 | SECTION IX: ASSUMPTIONS\n307 | - Read-only database access is granted via VPC boundaries within 7 business days.\n308 | - Stakeholders listed (${data.stakeholdersLabel}) participate in weekly 15-minute syncs.\n309 | \n310 | SECTION X: RISKS & MITIGATIONS\n311 | - Risk: Legacy silo schema complexity. Mitigation: GFF OmniMesh builds semantic indices without altering original sources.\n312 | - Risk: Isolated hardware lead-times. Mitigation: Prototype on staging enclaves.\n313 | \n314 | SECTION XI: NEXT STEPS\n315 | 1. Complete digital sign-off.\n316 | 2. VPC configurations & discovery call.\n317 | 3. Mobilize co-innovation squad (${data.engagementPathObj.squad}) in 7 days.\n318 | `;\n319 |     navigator.clipboard.writeText(outlineText);\n320 |     setCopied(true);\n321 |     setTimeout(() => setCopied(false), 2000);\n322 |   };\n323 | \n324 |   const generateProposalData = () => {\n325 |     const org = inputs.companyName.trim() || \"Enterprise Client\";\n326 |     const indObj = INDUSTRIES.find((i) => i.id === inputs.industry) || INDUSTRIES[0];\n327 |     const sizeObj = COMPANY_SIZES.find((s) => s.id === inputs.companySize) || COMPANY_SIZES[2];\n328 |     const pathObj = ENGAGEMENT_PATHS.find((p) => p.id === inputs.preferredEngagementPath) || ENGAGEMENT_PATHS[1];\n329 |     const timelineObj = TIMELINES.find((t) => t.id === inputs.targetTimeline) || TIMELINES[1];\n330 |     const budgetObj = BUDGET_RANGES.find((b) => b.id === inputs.budgetRange) || BUDGET_RANGES[1];\n331 | \n332 |     const challengeLabel = inputs.primaryChallenge === \"other\" && inputs.customChallenge.trim()\n333 |       ? inputs.customChallenge.trim()\n334 |       : (CHALLENGES.find((c) => c.id === inputs.primaryChallenge)?.label || \"Sovereign Integration\");\n335 | \n336 |     const geographyLabel = inputs.geography.trim() || \"Global Private VPC Network Perimeter\";\n337 |     const stakeholdersLabel = inputs.stakeholders.trim() || \"Chief Technology Officer, Compliance Committee\";\n338 | \n339 |     const selectedOutcomeLabels = inputs.priorityOutcomes.map(\n340 |       (out) => OUTCOMES.find((o) => o.id === out)?.label || out\n341 |     );\n342 | \n343 |     let calculatedWeeks = timelineObj.weeks;\n344 |     if (inputs.preferredEngagementPath === \"garage\") calculatedWeeks = 4;\n345 |     else if (inputs.preferredEngagementPath === \"operate\") calculatedWeeks = 52;\n346 |     else {\n347 |       if (inputs.companySize === \"small\") calculatedWeeks = Math.max(4, calculatedWeeks - 4);\n348 |       else if (inputs.companySize === \"global-conglomerate\") calculatedWeeks = calculatedWeeks + 4;\n349 |     }\n350 | \n351 |     const p1 = Math.max(1, Math.round(calculatedWeeks * 0.15));\n352 |     const p2 = Math.max(1, Math.round(calculatedWeeks * 0.30));\n353 |     const p3 = Math.max(1, Math.round(calculatedWeeks * 0.40));\n354 |     const p4 = Math.max(1, calculatedWeeks - (p1 + p2 + p3));\n355 | \n356 |     let deliverables: string[] = [];\n357 |     if (inputs.preferredEngagementPath === \"garage\") {\n358 |       deliverables = [\n359 |         \"Interactive high-velocity client sandbox prototype\",\n360 |         \"Strategic SOW architecture topology outline schema\",\n361 |         \"Initial data pipeline schema risk audit assessment\",\n362 |         \"Targeted performance benchmarking telemetry sheet\"\n363 |       ];\n364 |     } else if (inputs.preferredEngagementPath === \"foundry\") {\n365 |       deliverables = [\n366 |         \"Fully provisioned, isolated single-tenant private VPC perimeter\",\n367 |         \"Tailored multi-agent consensus network and workflow configurations\",\n368 |         \"Hardened OmniMesh read-only legacy data connector pipelines\",\n369 |         \"Enterprise-wide compliance audit ledger logging software\"\n370 |       ];\n371 |     } else if (inputs.preferredEngagementPath === \"factory\") {\n372 |       deliverables = [\n373 |         \"Industrial-scale federated data mesh network connectors\",\n374 |         \"Autonomous auto-scaling cross-department agent fleet systems\",\n375 |         \"Highly integrated compliance watchdog and safety enforcer software\",\n376 |         \"Sovereign multi-region VPC peering configurations\"\n377 |       ];\n378 |     } else {\n379 |       deliverables = [\n380 |         \"Active monitoring uptime and model performance telemetry panels\",\n381 |         \"Guaranteed 99.9% operational performance SLA monitoring setup\",\n382 |         \"Proactive scheduled compliance and data policy updates\",\n383 |         \"Weekly technical optimization analysis reports and audit files\"\n384 |       ];\n385 |     }\n386 | \n387 |     return {\n388 |       org,\n389 |       industryLabel: indObj.label,\n390 |       industryDesc: indObj.desc,\n391 |       industryIcon: indObj.icon,\n392 |       companySizeLabel: sizeObj.label,\n393 |       companySizeDesc: sizeObj.desc,\n394 |       companySizeRange: sizeObj.range,\n395 |       challengeLabel,\n396 |       timelineLabel: timelineObj.label,\n397 |       weeks: calculatedWeeks,\n398 |       engagementPathObj: pathObj,\n399 |       budgetLabel: inputs.budgetRange ? budgetObj.label : \"Tailored Strategic Budget\",\n400 |       geographyLabel,\n401 |       stakeholdersLabel,\n402 |       selectedOutcomeLabels,\n403 |       deliverables,\n404 |       p1, p2, p3, p4\n405 |     };\n406 |   };\n407 | \n408 |   const pData = generateProposalData();\n409 | \n410 |   const renderTopologyDiagram = (path: \"garage\" | \"foundry\" | \"factory\" | \"operate\") => {\n411 |     return (\n412 |       <div className=\"p-4 rounded-xl bg-[#030305] border border-white/5 font-mono text-[9px] text-white/50 space-y-3\">\n413 |         <div className=\"flex justify-between items-center text-[7px] text-white/30 uppercase tracking-widest\">\n414 |           <span>DEPLOYMENT TOPOLOGY MAP</span>\n415 |           <span className=\"text-[#00FF9D] font-bold\">{path.toUpperCase()}_ACTIVE_NODE</span>\n416 |         </div>\n417 |         <div className=\"grid grid-cols-1 sm:grid-cols-5 gap-2 items-center text-center\">\n418 |           <div className=\"p-2 border border-white/10 rounded bg-white/[0.01]\">📥 LOCAL INGEST</div>\n419 |           <div className=\"text-white/20 text-[8px] hidden sm:block\">────────▶</div>\n420 |           <div className=\"p-2.5 border border-[#009DFF]/30 rounded bg-[#009DFF]/5 font-bold text-white uppercase\">GFF_{path}</div>\n421 |           <div className=\"text-white/20 text-[8px] hidden sm:block\">────────▶</div>\n422 |           <div className=\"p-2 border border-[#00FF9D]/30 rounded bg-[#00FF9D]/5\">🛡️ SECURE ENCLAVE</div>\n423 |         </div>\n424 |         <p className=\"text-[8px] text-white/30 leading-snug\">\n425 |           <strong>COMPLIANCE SUMMARY:</strong> Workloads are fully orchestrated inside single-tenant enclaves inside the geographical boundary. Memory queues are cleared instantly post-token processing with absolute zero persistent retention pipelines.\n426 |         </p>\n427 |       </div>\n428 |     );\n429 |   };\n430 | \n431 |   if (!mounted) {\n432 |     return (\n433 |       <div className=\"min-h-screen bg-[#020204] flex items-center justify-center text-white font-mono text-xs\">\n434 |         Booting GFF Enterprise proposal workspace...\n435 |       </div>\n436 |     );\n437 |   }\n438 | \n439 |   return (\n440 |     <ToolPageShell showContact={step !== \"preview\"}>\n441 |       \n442 |       <ToolHero\n443 |         category=\"PHASE 3 // STRATEGIC ADVISORY SOW BUILDER\"\n444 |         title=\"Sovereign AI Proposal\"\n445 |         highlightedWord=\"Proposal\"\n446 |         description=\"Configure strategic integration models, design multi-agent topologies, and compile localized statement of work (SOW) blueprints completely offline.\"\n447 |       />\n448 | \n449 |       <AnimatePresence mode=\"wait\">\n450 |         \n451 |         {step === \"configure\" && (\n452 |           <motion.div\n453 |             key=\"configure\"\n454 |             initial={{ opacity: 0, y: 12 }}\n455 |             animate={{ opacity: 1, y: 0 }}\n456 |             exit={{ opacity: 0, y: -12 }}\n457 |             className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\"\n458 |           >\n459 |             <div className=\"lg:col-span-8 space-y-6\">\n460 |               {hasSavedDraft && (\n461 |                 <div className=\"p-4 rounded-xl border border-[#009DFF]/20 bg-[#009DFF]/5 flex items-center justify-between text-xs text-white animate-fadeIn\">\n462 |                   <div className=\"flex items-center gap-2\">\n463 |                     <span className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF] animate-pulse\" />\n464 |                     <span>In-progress draft detected from your previous workspace session.</span>\n465 |                   </div>\n466 |                   <div className=\"flex gap-2\">\n467 |                     <button onClick={handleRestoreDraft} className=\"px-3 py-1.5 bg-[#009DFF]/20 border border-[#009DFF]/40 text-[#009DFF] text-[10px] font-mono hover:bg-[#009DFF]/40 transition uppercase font-bold rounded\">Restore Draft</button>\n468 |                     <button onClick={() => setHasSavedDraft(false)} className=\"px-2 py-1.5 text-white/40 text-[10px] font-mono hover:text-white uppercase\">Ignore</button>\n469 |                   </div>\n470 |                 </div>\n471 |               )}\n472 | \n473 |               {/* STEP TIMELINE GATE HEADER */}\n474 |               <div className=\"p-1 rounded-lg bg-black/45 border border-white/5 flex text-center text-[10px] font-mono\">\n475 |                 {[1, 2, 3].map((g) => (\n476 |                   <button\n477 |                     key={g}\n478 |                     type=\"button\"\n479 |                     onClick={() => { if (validateStep(1) && (g < 3 || validateStep(2))) setActiveStepGate(g as 1 | 2 | 3); }}\n480 |                     className={`flex-1 py-2 rounded transition font-semibold uppercase ${activeStepGate === g ? \"bg-white/5 text-[#009DFF] border border-white/10\" : \"text-white/40 hover:text-white\"}`}\n481 |                     disabled={g > activeStepGate && !validateStep(activeStepGate)}\n482 |                   >\n483 |                     0{g} {\"//\"} {g === 1 ? \"Baseline Profile\" : g === 2 ? \"Strategy & Outcomes\" : \"Deployment Pathway\"}\n484 |                   </button>\n485 |                 ))}\n486 |               </div>\n487 | \n488 |               {/* FORM WRAPPER CARD */}\n489 |               <div className=\"p-6 lg:p-8 rounded-2xl border border-white/5 bg-[#030306]/95 relative overflow-hidden\">\n490 |                 <div className=\"absolute top-0 right-0 p-4 font-mono text-[8px] text-white/20\">\n491 |                   GFF_PROPOSAL_STUDIO // REV_2026\n492 |                 </div>\n493 | \n494 |                 {/* GATE 1: BASELINE */}\n495 |                 {activeStepGate === 1 && (\n496 |                   <div className=\"space-y-5 animate-fadeIn\">\n497 |                     <div className=\"border-b border-white/5 pb-3\">\n498 |                       <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider font-bold\">GATE 01 OF 03</span>\n499 |                       <h2 className=\"text-lg font-bold text-white mt-1\">Corporate Baseline Profile</h2>\n500 |                       <p className=\"text-white/40 text-[10px] font-light\">Specify your organization, vertical sector, operational scale, and target regional boundary constraints.</p>\n501 |                     </div>\n502 | \n503 |                     <div className=\"space-y-1.5\">\n504 |                       <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Organization Name (Optional)</label>\n505 |                       <input\n506 |                         type=\"text\"\n507 |                         value={inputs.companyName}\n508 |                         onChange={(e) => setInputs({ ...inputs, companyName: e.target.value })}\n509