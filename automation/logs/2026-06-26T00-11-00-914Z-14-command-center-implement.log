{"ts":"2026-06-26T00:08:19.128Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ia0sreel","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/sandbox/page.tsx","new_text":"\"use client\";\n\nimport { useState, useEffect, useRef } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\ntype LogLine = {\n  type: \"info\" | \"success\" | \"warning\" | \"agent\" | \"system\";\n  text: string;\n  time: string;\n};\n\nconst TEMPLATES = [\n  {\n    id: \"finance\",\n    name: \"Sovereign Core Auditing Enclave\",\n    desc: \"Simulates continuous multi-agent consensus validation across high-throughput financial transactions.\",\n    logs: [\n      { type: \"system\", text: \"Initializing cryptographic enclave for transaction routing...\" },\n      { type: \"info\", text: \"Spawning Supervisor Agent [AS-09] on secure tenant boundary.\" },\n      { type: \"info\", text: \"Deploying Policy Guardrail modules (v2.6.4).\" },\n      { type: \"agent\", text: \"[Supervisor] Pulling daily ledger balance traces...\" },\n      { type: \"agent\", text: \"[Auditor-01] Re-calculating checksums on block 1,948,012...\" },\n      { type: \"success\", text: \"[Auditor-01] Consensus verified. Checksums match core database.\" },\n      { type: \"warning\", text: \"[Compliance-02] Detected dynamic rate variance on API endpoint 4b.\" },\n      { type: \"agent\", text: \"[Supervisor] Mitigating drift: applying secure token bucket rate-limits.\" },\n      { type: \"success\", text: \"Transaction validation completed. 0 anomalies detected. Safe state reached.\" }\n    ]\n  },\n  {\n    id: \"supply-chain\",\n    name: \"SAP Supply Chain Pipeline Optimizer\",\n    desc: \"Simulates autonomous container routing and port congestion mitigation using heuristic agents.\",\n    logs: [\n      { type: \"system\", text: \"Mounting SAP ERP connector interface...\" },\n      { type: \"info\", text: \"Retrieving active shipment DAG logs...\" },\n      { type: \"warning\", text: \"[Logistics-Alpha] Congestion detected at Rotterdam port. Delay queue: 34h.\" },\n      { type: \"agent\", text: \"[Supervisor] Querying global freight routing heuristics...\" },\n      { type: \"agent\", text: \"[Router-Beta] Computing alternative overland paths through terminal 7...\" },\n      { type: \"info\", text: \"Evaluating compliance parameters for multi-border transfer...\" },\n      { type: \"success\", text: \"[Router-Beta] Alternate route locked. ETA reduced by 18 hours.\" },\n      { type: \"agent\", text: \"[Supervisor] Committing updated route vectors to SAP core ledger.\" },\n      { type: \"success\", text: \"Simulation complete. Pipeline efficiency optimized +14%.\" }\n    ]\n  },\n  {\n    id: \"hipaa\",\n    name: \"Zero-Trust HIPAA Ingestion Sandbox\",\n    desc: \"Simulates PII redacting and cryptographic data isolation on ingestion boundaries.\",\n    logs: [\n      { type: \"system\", text: \"Configuring cryptographically isolated sandbox enclave...\" },\n      { type: \"info\", text: \"Listening on simulated webhook pipeline: /v1/ingest\" },\n      { type: \"info\", text: \"Received simulated payload containing patient medical telemetry.\" },\n      { type: \"agent\", text: \"[Privacy-Guard] Commencing real-time OCR regex scan...\" },\n      { type: \"warning\", text: \"[Privacy-Guard] Plaintext Social Security Number detected in payload.\" },\n      { type: \"agent\", text: \"[Supervisor] Executing AES-256-GCM tokenization trace...\" },\n      { type: \"success\", text: \"[Privacy-Guard] Tokenized PII fields. Saved audit proof hash to ledger.\" },\n      { type: \"success\", text: \"Payload parsed. Compliant schema transmitted to downstream storage.\" }\n    ]\n  }\n];\n\nexport default function SandboxPage() {\n  const [selectedTemplate, setSelectedTemplate] = useState(TEMPLATES[0]);\n  const [isRunning, setIsRunning] = useState(false);\n  const [currentLogs, setCurrentLogs] = useState<LogLine[]>([]);\n  const [progress, setProgress] = useState(0);\n  const logEndRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    if (!isRunning) return;\n\n    setCurrentLogs([]);\n    setProgress(0);\n    let step = 0;\n\n    const interval = setInterval(() => {\n      if (step < selectedTemplate.logs.length) {\n        const now = new Date();\n        const timeStr = `${now.getHours().toString().padStart(2, \"0\")}:${now\n          .getMinutes()\n          .toString()\n          .padStart(2, \"0\")}:${now.getSeconds().toString().padStart(2, \"0\")}.${now\n          .getMilliseconds()\n          .toString()\n          .padStart(3, \"0\")}`;\n\n        setCurrentLogs((prev) => [\n          ...prev,\n          {\n            type: selectedTemplate.logs[step].type as any,\n            text: selectedTemplate.logs[step].text,\n            time: timeStr\n          }\n        ]);\n        setProgress(Math.round(((step + 1) / selectedTemplate.logs.length) * 100));\n        step++;\n      } else {\n        clearInterval(interval);\n        setIsRunning(false);\n      }\n    }, 900);\n\n    return () => clearInterval(interval);\n  }, [isRunning, selectedTemplate]);\n\n  useEffect(() => {\n    logEndRef.current?.scrollIntoView({ behavior: \"smooth\" });\n  }, [currentLogs]);\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Interactive Sandbox\"\n        title=\"Zero-Trust Simulation Enclave\"\n        description=\"Launch real-time local agent DAG simulations to stress-test your autonomous pipelines within a simulated secure hardware enclave.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-8\">\n        {/* Sidebar Controls */}\n        <div className=\"lg:col-span-4 space-y-6\">\n          <div className=\"rounded-2xl border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] p-6 space-y-4\">\n            <h3 className=\"text-sm font-bold text-white/40 uppercase tracking-wider\">Select Enclave Profile</h3>\n            <div className=\"space-y-3\">\n              {TEMPLATES.map((tmpl) => (\n                <button\n                  key={tmpl.id}\n                  onClick={() => {\n                    if (!isRunning) {\n                      setSelectedTemplate(tmpl);\n                      setCurrentLogs([]);\n                    }\n                  }}\n                  disabled={isRunning}\n                  className={`w-full text-left p-4 rounded-xl border transition-all ${\n                    selectedTemplate.id === tmpl.id\n                      ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n                      : \"bg-white/[0.01] border-white/5 text-white/70 hover:bg-white/[0.03] disabled:opacity-50\"\n                  }`}\n                >\n                  <span className=\"text-xs font-bold text-[#009DFF] uppercase tracking-wider\">{tmpl.name}</span>\n                  <p className=\"text-xs text-white/50 mt-1 leading-relaxed\">{tmpl.desc}</p>\n                </button>\n              ))}\n            </div>\n\n            <button\n              onClick={() => setIsRunning(true)}\n              disabled={isRunning}\n              className={`w-full h-[46px] rounded-lg text-xs font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2 ${\n                isRunning\n                  ? \"bg-white/10 text-white/40 cursor-not-allowed\"\n                  : \"bg-gradient-to-r from-[#E4000F] to-[#009DFF] text-white hover:opacity-90\"\n              }`}\n            >\n              {isRunning ? (\n                <>\n                  <svg className=\"animate-spin h-4 w-4 text-white\" fill=\"none\" viewBox=\"0 0 24 24\">\n                    <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n                    <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\" />\n                  </svg>\n                  Simulation Active ({progress}%)\n                </>\n              ) : (\n                \"Launch Simulated Sandbox\"\n              )}\n            </button>\n          </div>\n        </div>\n\n        {/* Live Enclave Output */}\n        <div className=\"lg:col-span-8 flex flex-col h-[520px] rounded-2xl border border-white/10 bg-[#020202] overflow-hidden\">\n          {/* Header */}\n          <div className=\"flex items-center justify-between px-6 py-4 border-b border-white/5 bg-[#050505]\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"flex h-2 w-2 relative\">\n                <span className={`animate-ping absolute inline-flex h-full w-full rounded-full opacity-75 ${isRunning ? \"bg-[#009DFF]\" : \"bg-emerald-500\"}`} />\n                <span className={`relative inline-flex rounded-full h-2 w-2 ${isRunning ? \"bg-[#009DFF]\" : \"bg-emerald-500\"}`} />\n              </span>\n              <span className=\"text-xs font-mono font-bold text-white/80 tracking-wider\">SECURE ENCLAVE TELEMETRY</span>\n            </div>\n            <div className=\"flex items-center gap-1.5\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-white/10\" />\n              <span className=\"w-2.5 h-2.5 rounded-full bg-white/10\" />\n              <span className=\"w-2.5 h-2.5 rounded-full bg-white/10\" />\n            </div>\n          </div>\n\n          {/* Console Screen */}\n          <div className=\"flex-1 p-6 overflow-y-auto font-mono text-xs space-y-3 bg-black\">\n            {currentLogs.length === 0 ? (\n              <div className=\"h-full flex flex-col items-center justify-center text-center text-white/30 space-y-2\">\n                <svg className=\"w-8 h-8 opacity-40 text-[#009DFF]\" fil