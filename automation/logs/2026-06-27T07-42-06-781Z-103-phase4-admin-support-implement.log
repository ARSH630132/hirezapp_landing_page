.2.0\",\n191 |     lastUpdated: \"2026-06-27T08:15:00Z\",\n192 |     description: \"Hardware-level attestation measurements verified against reference hashes inside the AMD SEV-SNP secure processor enclave.\",\n193 |     governanceChecks: [\n194 |       { label: \"Hardware measurement verification (MMEASURE)\", checked: true, framework: \"AMD SEV-SNP\" },\n195 |       { label: \"Host hypervisor isolation cryptographic proof\", checked: true, framework: \"NIST SP 800\" }\n196 |     ]\n197 |   }\n198 | ];\n199 | \n200 | export default function AdminDocumentsPage() {\n201 |   // ==========================================\n202 |   // 3. REACT STATE MANAGEMENT\n203 |   // ==========================================\n204 |   const [documents, setDocuments] = useState<DocumentItem[]>(INITIAL_DOCUMENTS);\n205 |   const [selectedDocId, setSelectedDocId] = useState<string | null>(null);\n206 |   \n207 |   // Filter states\n208 |   const [searchQuery, setSearchQuery] = useState(\"\");\n209 |   const [filterClient, setFilterClient] = useState(\"all\");\n210 |   const [filterProject, setFilterProject] = useState(\"all\");\n211 |   const [filterType, setFilterType] = useState(\"all\");\n212 |   const [filterStatus, setFilterStatus] = useState(\"all\");\n213 |   const [filterOwner, setFilterOwner] = useState(\"all\");\n214 |   const [filterVersion, setFilterVersion] = useState(\"all\");\n215 | \n216 |   // Interaction states\n217 |   const [assigningProjectId, setAssigningProjectId] = useState(\"UNASSIGNED\");\n218 |   const [downloadingDocId, setDownloadingDocId] = useState<string | null>(null);\n219 |   const [isRegisterModalOpen, setIsRegisterModalOpen] = useState(false);\n220 |   const [toast, setToast] = useState<{ visible: boolean; message: string }>({ visible: false, message: \"\" });\n221 | \n222 |   // Document registration form states\n223 |   const [newTitle, setNewTitle] = useState(\"\");\n224 |   const [newType, setNewType] = useState<\"PDF\" | \"JSON\" | \"YAML\" | \"XML\">(\"PDF\");\n225 |   const [newClient, setNewClient] = useState(CLIENTS[0]);\n226 |   const [newProject, setNewProject] = useState(\"UNASSIGNED\");\n227 |   const [newStatus, setNewStatus] = useState<\"Verified\" | \"Under Review\" | \"Action Required\">(\"Verified\");\n228 |   const [newOwner, setNewOwner] = useState(OWNERS[0]);\n229 |   const [newVersion, setNewVersion] = useState(\"v1.0.0\");\n230 |   const [newFileSize, setNewFileSize] = useState(\"1.5 MB\");\n231 |   const [newDesc, setNewDesc] = useState(\"\");\n232 | \n233 |   // Get active selected document details dynamically\n234 |   const selectedDoc = useMemo(() => {\n235 |     return documents.find(doc => doc.id === selectedDocId) || null;\n236 |   }, [documents, selectedDocId]);\n237 | \n238 |   // Sync re-assignment selector when selected document changes\n239 |   useEffect(() => {\n240 |     if (selectedDoc) {\n241 |       setAssigningProjectId(selectedDoc.projectId);\n242 |     }\n243 |   }, [selectedDoc]);\n244 | \n245 |   // Auto-dismiss toast\n246 |   useEffect(() => {\n247 |     if (toast.visible) {\n248 |       const timer = setTimeout(() => {\n249 |         setToast({ visible: false, message: \"\" });\n250 |       }, 3500);\n251 |       return () => clearTimeout(timer);\n252 |     }\n253 |   }, [toast]);\n254 | \n255 |   const showToast = (message: string) => {\n256 |     setToast({ visible: true, message });\n257 |   };\n258 | \n259 |   // ==========================================\n260 |   // 4. ACTION HANDLERS\n261 |   // ==========================================\n262 |   \n263 |   // Assign Document to Project\n264 |   const handleAssignProject = (docId: string, projectId: string) => {\n265 |     setDocuments(prevDocs => \n266 |       prevDocs.map(doc => {\n267 |         if (doc.id === docId) {\n268 |           const targetProj = PROJECTS.find(p => p.id === projectId);\n269 |           const updatedClient = targetProj && targetProj.id !== \"UNASSIGNED\" ? targetProj.client : doc.client;\n270 |           return { \n271 |             ...doc, \n272 |             projectId, \n273 |             client: updatedClient,\n274 |             lastUpdated: new Date().toISOString()\n275 |           };\n276 |         }\n277 |         return doc;\n278 |       })\n279 |     );\n280 |     const projName = PROJECTS.find(p => p.id === projectId)?.name || \"Unassigned Registry\";\n281 |     showToast(`Cryptographic association established: Document bound to ${projName}`);\n282 |   };\n283 | \n284 |   // Simulate secure administrator download\n285 |   const handleSimulatedDownload = (docId: string, title: string) => {\n286 |     setDownloadingDocId(docId);\n287 |     setTimeout(() => {\n288 |       setDownloadingDocId(null);\n289 |       showToast(`Audit log registered: Secure admin transfer of \"${title}\" completed.`);\n290 |       alert(`[SECURE VAULT API] Administrator copy successfully transferred.\\n\\nDocument: ${title}\\nSHA-256 integrity checks completed over airgapped connection.`);\n291 |     }, 1500);\n292 |   };\n293 | \n294 |   // Toggle checklist inside drawer\n295 |   const handleToggleCheck = (docId: string, checkIndex: number) => {\n296 |     setDocuments(prevDocs => \n297 |       prevDocs.map(doc => {\n298 |         if (doc.id === docId) {\n299 |           const updatedChecks = [...doc.governanceChecks];\n300 |           updatedChecks[checkIndex] = {\n301 |             ...updatedChecks[checkIndex],\n302 |             checked: !updatedChecks[checkIndex].checked\n303 |           };\n304 |           return {\n305 |             ...doc,\n306 |             governanceChecks: updatedChecks,\n307 |             lastUpdated: new Date().toISOString()\n308 |           };\n309 |         }\n310 |         return doc;\n311 |       })\n312 |     );\n313 |     showToast(`Governance checklist updated. Audit state synchronized locally.`);\n314 |   };\n315 | \n316 |   // Register New Document Mock Submit\n317 |   const handleRegisterSubmit = (e: React.FormEvent) => {\n318 |     e.preventDefault();\n319 |     if (!newTitle.trim()) return;\n320 | \n321 |     const randomHex = Array.from({ length: 32 }, () => \n322 |       Math.floor(Math.random() * 16).toString(16).toUpperCase()\n323 |     ).join(\"\");\n324 |     const mockHash = `0x${randomHex.substring(0, 37)}`;\n325 |     const newDocId = `DOC-${800 + documents.length + 1}`;\n326 | \n327 |     const newDocItem: DocumentItem = {\n328 |       id: newDocId,\n329 |       title: newTitle,\n330 |       fileSize: newFileSize || \"1.0 MB\",\n331 |       type: newType,\n332 |       sha256: mockHash,\n333 |       client: newProject !== \"UNASSIGNED\" \n334 |         ? PROJECTS.find(p => p.id === newProject)?.client || newClient\n335 |         : newClient,\n336 |       projectId: newProject,\n337 |       status: newStatus,\n338 |       owner: newOwner,\n339 |       version: newVersion || \"v1.0.0\",\n340 |       lastUpdated: new Date().toISOString(),\n341 |       description: newDesc || \"Custom compliance specification uploaded through interactive admin console.\",\n342 |       governanceChecks: [\n343 |         { label: \"Hardware Cryptographic Key Attestation\", checked: true, framework: \"ISO-27001\" },\n344 |         { label: \"Organization Policy Sign-off validation\", checked: newStatus === \"Verified\", framework: \"SOC2 Compliance\" },\n345 |         { label: \"Continuous Airgapped Event Verification\", checked: false, framework: \"NIST SP 800\" }\n346 |       ]\n347 |     };\n348 | \n349 |     setDocuments(prev => [newDocItem, ...prev]);\n350 |     setIsRegisterModalOpen(false);\n351 |     showToast(`Document Registry expanded: Created ${newDocId}`);\n352 | \n353 |     // Reset fields\n354 |     setNewTitle(\"\");\n355 |     setNewDesc(\"\");\n356 |     setNewFileSize(\"1.5 MB\");\n357 |     setNewVersion(\"v1.0.0\");\n358 |   };\n359 | \n360 |   // Reset Filters helper\n361 |   const handleResetFilters = () => {\n362 |     setSearchQuery(\"\");\n363 |     setFilterClient(\"all\");\n364 |     setFilterProject(\"all\");\n365 |     setFilterType(\"all\");\n366 |     setFilterStatus(\"all\");\n367 |     setFilterOwner(\"all\");\n368 |     setFilterVersion(\"all\");\n369 |     showToast(\"Filtering workspace cleared. All registry objects displayed.\");\n370 |   };\n371 | \n372 |   // Delete document preview\n373 |   const handleDeleteDocument = (id: string, title: string) => {\n374 |     if (confirm(`Deprovision document ${id} (\"${title}\") from administrative registry?`)) {\n375 |       setDocuments(prev => prev.filter(d => d.id !== id));\n376 |       if (selectedDocId === id) setSelectedDocId(null);\n377 |       showToast(`Document ${id} unlinked and removed from local memory.`);\n378 |     }\n379 |   };\n380 | \n381 |   // ==========================================\n382 |   // 5. QUERY FILTERING LOGIC\n383 |   // ==========================================\n384 |   const filteredDocuments = useMemo(() => {\n385 |     return documents.filter(doc => {\n386 |       const matchesSearch = \n387 |         doc.title.toLowerCase().includes(searchQuery.toLowerCase()) ||\n388 |         doc.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n389 |         doc.sha256.toLowerCase().includes(searchQuery.toLowerCase()) ||\n390 |         doc.description.toLowerCase().includes(searchQuery.toLowerCase());\n391 | \n392 |       const matchesClient = filterClient === \"all\" || doc.client === filterClient;\n393 |       const matchesProject = filterProject === \"all\" || doc.projectId === filterProject;\n394 |       const matchesType = filterType === \"all\" || doc.type === filterType;\n395 |       const matchesStatus = filterStatus === \"all\" || doc.status === filterStatus;\n396 |       const matchesOwner = filterOwner === \"all\" || doc.owner === filterOwner;\n397 |       const matchesVersion = filterVersion === \"all\" || doc.version === filterVersion;\n398 | \n399 |       return (\n400 |         matchesSearch && \n401 |         matchesClient && \n402 |         matchesProject && \n403 |         matchesType && \n404 |         matchesStatus && \n405 |         matchesOwner && \n406 |         matchesVersion\n407 |       );\n408 |     });\n409 |   }, [\n410 |     documents, searchQuery, filterClient, filterProject, \n411 |     filterType, filterStatus, filterOwner, filterVersion\n412 |   ]);\n413 | \n414 |   const metrics = useMemo(() => {\n415 |     const totalCount = documents.length;\n416 |     const verifiedCount = documents.filter(d => d.status === \"Verified\").length;\n417 |     const unassignedCount = documents.filter(d => d.projectId === \"UNASSIGNED\").length;\n418 |     const integrityRate = totalCount > 0 ? ((verifiedCount / totalCount) * 100).toFixed(1) : \"100.0\";\n419 | \n420 |     return {\n421 |       totalCount,\n422 |       verifiedCount,\n423 |       unassignedCount,\n424 |       integrityRate\n425 |     };\n426 |   }, [documents]);\n427 | \n428 |   const hasActiveFilters = useMemo(() => {\n429 |     return (\n430 |       searchQuery !== \"\" ||\n431 |       filterClient !== \"all\" ||\n432 |       filterProject !== \"all\" ||\n433 |       filterType !== \"all\" ||\n434 |       filterStatus !== \"all\" ||\n435 |       filterOwner !== \"all\" ||\n436 |       filterVersion !== \"all\"\n437 |     );\n438 |   }, [searchQuery, filterClient, filterProject, filterType, filterStatus, filterOwner, filterVersion]);\n439 | \n440 |   const getStatusBadgeStyle = (status: string) => {\n441 |     switch (status) {\n442 |       case \"Verified\":\n443 |         return \"border-emerald-500/20 bg-emerald-500/5 text-emerald-400\";\n444 |       case \"Under Review\":\n445 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-400\";\n446 |       case \"Action Required\":\n447 |         return \"border-rose-500/20 bg-rose-500/5 text-rose-400\";\n448 |       case \"Superseded\":\n449 |         return \"border-white/10 bg-white/5 text-white/50\";\n450 |       default:\n451 |         return \"border-white/15 bg-white/5 text-white/60\";\n452 |     }\n453 |   };\n454 | \n455 |   const getTypeBadgeStyle = (type: string) => {\n456 |     switch (type) {\n457 |       case \"PDF\":\n458 |         return \"border-indigo-500/20 bg-indigo-500/5 text-indigo-400\";\n459 |       case \"JSON\":\n460 |         return \"border-cyan-500/20 bg-cyan-500/5 text-cyan-400\";\n461 |       case \"YAML\":\n462 |         return \"border-purple-500/20 bg-purple-500/5 text-purple-400\";\n463 |       case \"XML\":\n464 |         return \"border-amber-500/20 bg-amber-500/5 text-amber-500\";\n465 |       default:\n466 |         return \"border-white/10 text-white/60\";\n467 |     }\n468 |   };\n469 | \n470 |   return (\n471 |     <div className=\"space-y-6 relative min-h-screen pb-12 font-mono\">\n472 |       {/* ============================================================================ */}\n473 |       {/* HEADER SECTION */}\n474 |       {/* ============================================================================ */}\n475 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-6\">\n476 |         <div>\n477 |           <div className=\"flex items-center gap-2 text-white/40 mb-1\">\n478 |             <ShieldCheck className=\"w-4 h-4 text-[#009DFF]\" />\n479 |             <span className=\"text-[10px] font-bold tracking-widest uppercase\">System Secure Console</span>\n480 |           </div>\n481 |           <h2 className=\"text-xl font-bold text-white tracking-tight uppercase\">\n482 |             Cryptographic Document Registry\n483 |           </h2>\n484 |           <p className=\"text-xs text-white/50 mt-1 max-w-2xl leading-relaxed\">\n485 |             Administrative flight deck for managing structural schemas, security certifications, and governance policies. Re-assign credentials to isolated enclave projects to enforce real-time hardware compliance bounds.\n486 |           </p>\n487 |         </div>\n488 |         <div className=\"sh