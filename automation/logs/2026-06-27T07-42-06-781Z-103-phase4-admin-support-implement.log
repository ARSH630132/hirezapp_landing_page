   description: \"Structured policy ruleset defining sensory bounds, alignment tolerances, and real-time model override guardrails applied to agent networks.\",\n118 |     governanceChecks: [\n119 |       { label: \"Static Model Behavioral Rules Match\", checked: true, framework: \"NIST SP 800\" },\n120 |       { label: \"Dynamic Runtime Guardrail Policy Validation\", checked: false, framework: \"EU AI Act\" },\n121 |       { label: \"Emergency Kill-Switch Interface Enforceability\", checked: true, framework: \"GFF Gov Core\" }\n122 |     ]\n123 |   },\n124 |   {\n125 |     id: \"DOC-804\",\n126 |     title: \"NIST Federal Treasury Integration Schema\",\n127 |     fileSize: \"750 KB\",\n128 |     type: \"YAML\",\n129 |     sha256: \"0x99A1C4E72B7FD40A9D8E3C2C77E1546C1A4B0\",\n130 |     client: \"Federal Treasury Division [Preview Client]\",\n131 |     projectId: \"PROJ-204\",\n132 |     status: \"Verified\",\n133 |     owner: \"Evelyn Carter\",\n134 |     version: \"v1.0.5\",\n135 |     lastUpdated: \"2026-06-27T09:30:00Z\",\n136 |     description: \"NIST-compliant hardware enclave schema isolating cryptographic treasury signatures and financial auditing models from general compute networks.\",\n137 |     governanceChecks: [\n138 |       { label: \"FIPS 140-3 Cryptographic Module Verification\", checked: true, framework: \"FIPS-140-3\" },\n139 |       { label: \"Hardware-enforced Security Boundary Isolation\", checked: true, framework: \"NIST SP 800\" },\n140 |       { label: \"Dual-Custodian Sign-off Enforcement Logic\", checked: true, framework: \"Treasury SEC\" }\n141 |     ]\n142 |   },\n143 |   {\n144 |     id: \"DOC-805\",\n145 |     title: \"Sovereign Health HIPAA Sensory Consent Log\",\n146 |     fileSize: \"8.3 MB\",\n147 |     type: \"PDF\",\n148 |     sha256: \"0xEE7302195ACBD90B8EEFF01A3D1C8C570E28B\",\n149 |     client: \"National Health Enclave [Preview Client]\",\n150 |     projectId: \"PROJ-205\",\n151 |     status: \"Action Required\",\n152 |     ow