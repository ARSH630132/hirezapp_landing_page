\",\n40 |     \"eslint\": \"^9\",\n41 |     \"eslint-config-next\": \"16.2.9\",\n42 |     \"tailwindcss\": \"^4\",\n43 |     \"typescript\": \"^5\"\n44 |   }\n45 | }","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/app/test_backend_smoke.py","result":"  1 | import sys\n  2 | import os\n  3 | sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n  4 | \n  5 | import pytest\n  6 | from fastapi.testclient import TestClient\n  7 | \n  8 | from app.main import app\n  9 | from app.seed import seed_db\n 10 | from app.db.session import SessionLocal\n 11 | from app.models.user import User\n 12 | from app.models.client_account import ClientAccount\n 13 | from app.models.project import Project\n 14 | from app.models.support_ticket import SupportTicket\n 15 | \n 16 | client = TestClient(app)\n 17 | \n 18 | @pytest.fixture(scope=\"module\", autouse=True)\n 19 | def setup_database():\n 20 |     \"\"\"\n 21 |     Ensure the SQLite database is freshly initialized and seeded before running smoke tests.\n 22 |     \"\"\"\n 23 |     # Seed the database\n 24 |     seed_db(reset=True)\n 25 |     yield\n 26 | \n 27 | def test_1_health_endpoint():\n 28 |     \"\"\"\n 29 |     1. Verify the health check endpoint returns 200 and healthy statuses.\n 30 |     \"\"\"\n 31 |     response = client.get(\"/api/v1/health\")\n 32 |     assert response.status_code == 200\n 33 |     data = response.json()\n 34 |     assert data[\"status\"] == \"ok\"\n 35 |     assert data[\"database\"][\"status\"] == \"healthy\"\n 36 |     assert data[\"services\"][\"api\"] == \"healthy\"\n 37 | \n 38 | def test_2_auth_login():\n 39 |     \"\"\"\n 40 |     2. Verify authentication flow - login and JWT token generation.\n 41 |     \"\"\"\n 42 |     # Test valid login for admin\n 43 |     response = client.post(\n 44 |         \"/api/v1/auth/login\",\n 45 |         data={\"username\": \"gff_admin@gff.ai\", \"password\": \"password123\"}\n 46 |     )\n 47 |     assert response.status_code == 200\n 48 |     data = response.json()\n 49 |     assert \"access_token\" in data\n 50 |     assert data[\"role\"] == \"gff_admin\"\n 51 | \n 52 |     # Test valid login for client admin\n 53 |     response_client = client.post(\n 54 |         \"/api/v1/auth/login\",\n 55 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n 56 |     )\n 57 |     assert response_client.status_code == 200\n 58 |     assert \"access_token\" in response_client.json()\n 59 | \n 60 |     # Test invalid login credentials\n 61 |     response_invalid = client.post(\n 62 |         \"/api/v1/auth/login\",\n 63 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"wrongpassword\"}\n 64 |     )\n 65 |     assert response_invalid.status_code == 400\n 66 |     assert \"Incorrect email or password\" in response_invalid.json()[\"detail\"]\n 67 | \n 68 | def test_3_auth_me():\n 69 |     \"\"\"\n 70 |     3. Verify auth/me endpoint retrieves current authenticated user profile.\n 71 |     \"\"\"\n 72 |     # Get token for client_admin\n 73 |     login_res = client.post(\n 74 |         \"/api/v1/auth/login\",\n 75 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n 76 |     )\n 77 |     token = login_res.json()[\"access_token\"]\n 78 | \n 79 |     # Request /me with Bearer token\n 80 |     headers = {\"Authorization\": f\"Bearer {token}\"}\n 81 |     me_res = client.get(\"/api/v1/auth/me\", headers=headers)\n 82 |     assert me_res.status_code == 200\n 83 |     user_data = me_res.json()\n 84 |     assert user_data[\"email\"] == \"client_admin@apex.com\"\n 85 |     assert user_data[\"role\"] == \"client_admin\"\n 86 |     assert user_data[\"client_id\"] is not None\n 87 | \n 88 | def test_4_rbac_blocked_admin_route_for_client_user():\n 89 |     \"\"\"\n 90 |     4. Verify RBAC blocks client users from admin-only routes.\n 91 |     \"\"\"\n 92 |     # Get token for client_member (a non-admin role)\n 93 |     login_res = client.post(\n 94 |         \"/api/v1/auth/login\",\n 95 |         data={\"username\": \"client_member@apex.com\", \"password\": \"password123\"}\n 96 |     )\n 97 |     token = login_res.json()[\"access_token\"]\n 98 |     headers = {\"Authorization\": f\"Bearer {token}\"}\n 99 | \n100 |     # /api/v1/clients is an admin-only route that requires 'require_admin'\n101 |     response = client.get(\"/api/v1/clients\", headers=headers)\n102 |     assert response.status_code == 403\n103 |     assert \"Operation not permitted\" in response.json()[\"detail\"]\n104 | \n105 | \n106 | def test_5_client_dashboard_data_scoping():\n107 |     \"\"\"\n108 |     5. Verify client dashboard data scoping and multi-tenant isolation.\n109 |     \"\"\"\n110 |     # Get token for client_admin at Apex Global\n111 |     login_res = client.post(\n112 |         \"/api/v1/auth/login\",\n113 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n114 |     )\n115 |     apex_token = login_res.json()[\"access_token\"]\n116 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n117 | \n118 |     # Get apex user details to find client_id\n119 |     me_res = client.get(\"/api/v1/auth/me\", headers=apex_headers)\n120 |     apex_client_id = me_res.json()[\"client_id\"]\n121 | \n122 |     # Verify client user can access their own dashboard\n123 |     res_own = client.get(f\"/api/v1/dashboard/client?client_id={apex_client_id}\", headers=apex_headers)\n124 |     assert res_own.status_code == 200\n125 |     assert res_own.json()[\"success\"] is True\n126 |     assert res_own.json()[\"client_id\"] == apex_client_id\n127 | \n128 |     # Verify client user is BLOCKED from accessing another client's dashboard (e.g. client_id + 1)\n129 |     other_client_id = apex_client_id + 1\n130 |     res_other = client.get(f\"/api/v1/dashboard/client?client_id={other_client_id}\", headers=apex_headers)\n131 |     assert res_other.status_code == 403\n132 |     assert \"Access denied\" in res_other.json()[\"detail\"]\n133 | \n134 | def test_6_projects_list_data_scoping():\n135 |     \"\"\"\n136 |     6. Verify project listing is scoped to the user's client account.\n137 |     \"\"\"\n138 |     # Get token for client_admin at Apex Global\n139 |     login_res = client.post(\n140 |         \"/api/v1/auth/login\",\n141 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n142 |     )\n143 |     apex_token = login_res.json()[\"access_token\"]\n144 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n145 | \n146 |     # Retrieve projects list for Apex Global\n147 |     response = client.get(\"/api/v1/projects\", headers=apex_headers)\n148 |     assert response.status_code == 200\n149 |     projects = response.json()\n150 |     \n151 |     # Check that all retrieved projects belong to the same client_id\n152 |     db = SessionLocal()\n153 |     apex_user = db.query(User).filter(User.email == \"client_admin@apex.com\").first()\n154 |     assert apex_user is not None\n155 |     \n156 |     for proj in projects:\n157 |         assert proj[\"client_id\"] == apex_user.client_id\n158 |     db.close()\n159 | \n160 | def test_7_support_ticket_create_isolation():\n161 |     \"\"\"\n162 |     7. Verify support ticket creation successfully saves data and prevents cross-tenant submissions.\n163 |     \"\"\"\n164 |     # Get token for client_admin at Apex Global\n165 |     login_res = client.post(\n166 |         \"/api/v1/auth/login\",\n167 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n168 |     )\n169 |     apex_token = login_res.json()[\"access_token\"]\n170 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n171 | \n172 |     db = SessionLocal()\n173 |     apex_user = db.query(User).filter(User.email == \"client_admin@apex.com\").first()\n174 |     apex_client_id = apex_user.client_id\n175 |     other_client = db.query(ClientAccount).filter(ClientAccount.id != apex_client_id).first()\n176 |     other_client_id = other_client.id\n177 |     db.close()\n178 | \n179 |     # Create a valid ticket under own client account\n180 |     ticket_payload = {\n181 |         \"client_id\": apex_client_id,\n182 |         \"title\": \"Smoke Test Ticket\",\n183 |         \"category\": \"Technical\",\n184 |         \"priority\": \"low\",\n185 |         \"status\": \"open\",\n186 |         \"description\": \"This is a backend smoke test ticket description.\"\n187 |     }\n188 |     response_create = client.post(\"/api/v1/support-tickets\", json=ticket_payload, headers=apex_headers)\n189 |     assert response_create.status_code == 201\n190 |     created_ticket = response_create.json()\n191 |     assert created_ticket[\"title\"] == \"Smoke Test Ticket\"\n192 |     assert created_ticket[\"client_id\"] == apex_client_id\n193 | \n194 |     # Try to create a ticket for another client account and verify 403 Forbidden\n195 |     invalid_ticket_payload = {\n196 |         \"client_id\": other_client_id,\n197 |         \"title\": \"Malicious Cross-Tenant Ticket\",\n198 |         \"category\": \"Security\",\n199 |         \"priority\": \"critical\",\n200 |         \"status\": \"open\",\n201 |         \"description\": \"Attempting to insert a ticket into another client account.\"\n202 |     }\n203 |     response_invalid = client.post(\"/api/v1/support-tickets\", json=invalid_ticket_payload, headers=apex_headers)\n204 |     assert response_invalid.status_code == 403\n205 |     assert \"You can only create tickets for your own client account\" in response_invalid.json()[\"detail\"]\n206 | ","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/README.md","result":"  1 | # GFF AI Local MVP Backend Foundation\n  2 | \n  3 | Welcome to the local FastAPI MVP backend foundation for the GFF AI Enterprise platform. This module provides local developer API capabilities, SQLite storage connectivity, system health monitoring, and a fully configured local CORS workspace to interface seamlessly with the Next.js frontend.\n  4 | \n  5 | ---\n  6 | \n  7 | ## 🚀 Quick Start (Root Convenience Commands)\n  8 | \n  9 | For rapid development, convenience scripts have been added to the repository's root `package.json`. These allow you to manage and run the backend seamlessly without manually creating or activating Python virtual environments in your active terminal.\n 10 | \n 11 | From the **root directory** of the project, you can run:\n 12 | \n 13 | *   **Install Backend Dependencies & Environment Setup**:\n 14 |     ```bash\n 15 |     npm run backend:install\n 16 |     ```\n 17 |     *This automatically creates the Python virtual environment (`venv`), installs all required pip dependencies, and copies `.env.example` to `.env` if not already present.*\n 18 | \n 19 | *   **Initialize & Seed Local SQLite Database**:\n 20 |     ```bash\n 21 |     npm run backend:seed\n 22 |     ```\n 23 |     *This executes the database seeder to bootstrap SQLite (`dev.db`) with multi-tenant enterprise development data (including GFF Admin, Apex Tenant Admin, Apex Client Members, as well as mock client accounts, projects, support tickets, invoices, and compliance logs).*\n 24 | \n 25 | *   **Run Backend Development Server (FastAPI)**:\n 26 |     ```bash\n 27 |     npm run backend:dev\n 28 |     ```\n 29 |     *Starts the FastAPI application via Uvicorn on [http://localhost:8000](http://localhost:8000) with hot-reloading enabled.*\n 30 | \n 31 | *   **Run Backend Security, RBAC & End-To-End Smoke Tests**:\n 32 |     ```bash\n 33 |     npm run backend:check\n 34 |     ```\n 35 |     *Executes both the security utility suite (`test_security_utilities.py`) and the comprehensive pytest-driven smoke tests (`test_backend_smoke.py`). It validates: JWT parsing, bcrypt hashing, RBAC rules, health endpoints, user profile retrieval (`/auth/me`), multi-tenant data boundaries, client dashboard scoping, projects listing, and support ticket creation isolation.*\n 36 | \n 37 | ---\n 38 | \n 39 | ## Architecture Overview\n 40 | \n 41 | The backend uses a standard, modular clean-architecture layout built for Python 3.12+ and FastAPI:\n 42 | \n 43 | ```text\n 44 | backend/\n 45 | ├── app/\n 46 | │   ├── __init__.py\n 47 | │   ├── api.py           # Core endpoints (Health, SystemLogs)\n 48 | │   ├── config.py        # Settings & Pydantic Config Validation\n 49 | │   ├── database.py      # SQLAlchemy DB Connection & Dependency Injection\n 50 | │   ├── main.py          # FastAPI App Entrypoint & CORS Middleware\n 51 | │   ├── models.py        # SQLAlchemy Declarative Models\n 52 | │   └── schemas.py       # Pydantic Schemas (V2)\n 53 | ├── .env.example         # Template for environment configuration\n 54 | ├── .gitignore           # Local development ignores\n 55 | ├── README.md            # Execution manual\n 56 | └── requirements.txt     # Python Dependencies\n 57 | ```\n 58 | \n 59 | ## Features\n 60 | \n 61 | - **Automated DB Bootstrap**: Automatically boots a local SQLite database (`dev.db`) on application launch.\n 62 | - **Enterprise Logs**: A simple, high-performance database logger schema for auditing backend/frontend handshakes.\n 63 | - **Health Verification**: An endpoint at `/api/v1/health` that dynamically validates database status and platform health.\n 64 | - **Next.js Alignment**: Built-in CORS and request timing telemetry middleware matching frontend-dev requirements.\n 65 | - **Clean Interactive Specs**: Automatic redirect of root `/` path to the interactive OpenAPI UI (`/docs`).\n 66 | \n 67 | ---\n 68 | \n 69 | ## Local Setup & Run Guide\n 70 | \n 71 | ### 1. Prerequisites\n 72 | Ensure you have **Python 3.12+** and **pip** installed:\n 73 | ```bash\n 74 | python3 --version\n 75 | pip3 --version\n 76 | ```\n 77 | \n 78 | ### 2. Set Up Virtual Environment\n 79 | Move to the backend folder and create a clean Python virtual environment:\n 80 | ```bash\n 81 | cd backend\n 82 | python3 -m venv venv\n 83 | ```\n 84 | \n 85 | Activate the environment:\n 86 | - **macOS / Linux**:\n 87 |   ```bash\n 88 |   source venv/bin/activate\n 89 |   ```\n 90 | - **Windows**:\n 91 |   ```bash\n 92 |   venv\\Scripts\\activate\n 93 |   ```\n 94 | \n 95 | ### 3. Install Dependencies\n 96 | ```bash\n 97 | pip install -r requirements.txt\n 98 | ```\n 99 | \n100 | ### 4. Set Up Environment Config\n101 | Copy the example environment file:\n102 | ```bash\n103 | cp .env.example .env\n104 | ```\n105 | The defaults in `.env` are pre-tuned for seamless local development with the Next.js local frontend.\n106 | \n107 | > ⚠️ **Production Security Warning**:\n108 | > In local development mode, `JWT_SECRET` defaults to a safe developer-only fallback key. However, for any production deployment, you **MUST** override `JWT_SECRET` in your environment variables with a cryptographically secure, high-entropy key (e.g., generated via `openssl rand -hex 32`). Leaving the default key active in production compromises token verification and authentication security.\n109 | \n110 | ### 5. Seed the Local Database\n111 | Seed the SQLite database with representative GFF AI multi-tenant development data (including 4 client accounts, 4 projects, 4 agent operations, 4 documents, 4 invoices, 3 support tickets, and 3 governance compliance records) and pre-configured role-based development users:\n112 | \n113 | ```bash\n114 | python app/seed.py\n115 | ```\n116 | \n117 | #### Pre-Configured Developer Accounts & Roles:\n118 | - **GFF Admin Lead** (Global Operations):\n119 |   - Email: `gff_admin@gff.ai`\n120 |   - Role: `gff_admin`\n121 |   - Password: `password123`\n122 | - **Apex Admin Lead** (Client Tenant Admin):\n123 |   - Email: `client_admin@apex.com`\n124 |   - Role: `client_admin`\n125 |   - Tenant: Apex Global\n126 |   - Password: `password123`\n127 | - **Apex Analyst** (Client Tenant Member):\n128 |   - Email: `client_member@apex.com`\n129 |   - Role: `client_member`\n130 |   - Tenant: Apex Global\n131 |   - Password: `password123`\n132 | - **Legacy Fallback Admin**:\n133 |   - Email: `admin@gff.ai`\n134 |   - Role: `admin`\n135 |   - Password: `gff_enterprise_admin_pass_2026`\n136 | - **Legacy Fallback Client**:\n137 |   - Email: `client@chevron.com`\n138 |   - Role: `client`\n139 |   - Tenant: Chevron Corporation\n140 |   - Password: `chevron_secure_pass_2026`\n141 | \n142 | #### Idempotency & Database Resetting:\n143 | - Running `python app/seed.py` repeatedly is perfectly **idempotent**; it checks for existing records before inserting, ensuring no duplicated keys or rows.\n144 | - To safely **wipe all tables and fresh-seed** a clean slate, run with the `--reset` flag:\n145 |   ```bash\n146 |   python app/seed.py --reset\n147 |   ```\n148 | \n149 | ### 6. Run the Server\n150 | Launch the development server via Uvicorn:\n151 | ```bash\n152 | uvicorn app.main:app --reload --port 8000\n153 | ```\n154 | \n155 | Once running, you can access:\n156 | - **Interactive OpenAPI Documentation**: [http://localhost:8000/docs](http://localhost:8000/docs)\n157 | - **Service Health Check Endpoint**: [http://localhost:8000/api/v1/health](http://localhost:8000/api/v1/health)\n158 | \n159 | ---\n160 | \n161 | ## API Documentation\n162 | \n163 | ### GET `/api/v1/health`\n164 | Checks backend and database health.\n165 | **Response (200 OK)**:\n166 | ```json\n167 | {\n168 |   \"status\": \"healthy\",\n169 |   \"timestamp\": 1719493200.0,\n170 |   \"database\": {\n171 |     \"status\": \"healthy\",\n172 |     \"error\": null\n173 |   },\n174 |   \"services\": {\n175 |     \"api\": \"healthy\",\n176 |     \"gff_core\": \"operational\"\n177 |   },\n178 |   \"version\": \"1.0.0\"\n179 | }\n180 | ```\n181 | \n182 | ### GET `/api/v1/logs`\n183 | Returns the recent list of system log entries.\n184 | **Response (200 OK)**:\n185 | ```json\n186 | []\n187 | ```\n188 | \n189 | ### POST `/api/v1/logs`\n190 | Creates a test system log.\n191 | **Request Payload**:\n192 | ```json\n193 | {\n194 |   \"level\": \"INFO\",\n195 |   \"message\": \"Next.js frontend handshake completed successfully\",\n196 |   \"module\": \"handshake\"\n197 | }\n198 | ```\n199 | **Response (201 Created)**:\n200 | ```json\n201 | {\n202 |   \"id\": 1,\n203 |   \"level\": \"INFO\",\n204 |   \"message\": \"Next.js frontend handshake completed successfully\",\n205 |   \"module\": \"handshake\",\n206 |   \"created_at\": \"2026-06-27T15:10:00.000000\"\n207 | }\n208 | ```","success":true}],"durationMs":12}}
