 print(\"All ClientAccount CRUD API tests completed successfully!\")\n75 | \n76 | if __name__ == \"__main__\":\n77 |     try:\n78 |         run_api_tests()\n79 |         sys.exit(0)\n80 |     except AssertionError:\n81 |         import traceback\n82 |         traceback.print_exc()\n83 |         sys.exit(1)\n84 |     except Exception as e:\n85 |         print(f\"Failed: {e}\")\n86 |         import traceback\n87 |         traceback.print_exc()\n88 |         sys.exit(1)\n89 | ","success":true}],"durationMs":1}}
