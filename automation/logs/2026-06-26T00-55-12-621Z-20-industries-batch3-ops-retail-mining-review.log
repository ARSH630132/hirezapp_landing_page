er delivery schedules, flags logistics discrepancies, and audits material compliance.\" }\n 21 | ];\n 22 | \n 23 | const OUTCOMES = [\n 24 |   { title: \"Reduced Assembly Downtime\", desc: \"Automate anomaly detection and repair dispatch before micro-stoppages cascade into line-wide outages.\" },\n 25 |   { title: \"Standardized Defect Mitigation\", desc: \"Accelerate non-conformance loops through real-time quality audits, ensuring compliance with global manufacturing regulations.\" },\n 26 |   { title: \"Seamless Knowledge Retention\", desc: \"Preserve decades of machine-specific operating procedures, translating manual notes into high-speed mobile technician guidance.\" }\n 27 | ];\n 28 | \n 29 | export default function ManufacturingPage() {\n 30 |   const [demoOutput, setDemoOutput] = useState(\"System ready. Select a control center task to simulate.\");\n 31 |   const [running, setRunning] = useState(false);\n 32 |   const [activeTab, setActiveTab] = useState(\"orchestrator\");\n 33 | \n 34 |   const runDemo = (type: \"telemetry\" | \"quality\") => {\n 35 |     setRunning(true);\n 36 |     if (type === \"telemetry\") {\n 37 |       setDemoOutput(\"Analyzing vibration spikes on Line 4 Lathe... Accessing Maintenance Copilot telemetry...\");\n 38 |       setTimeout(() => {\n 39 |         setDemoOutput(\"WARNING: Bearing temp at 92°C (threshold: 85°C). Maintenance Copilot generated Work Order #8204. Scheduled replacement.\");\n 40 |         setRunning(false);\n 41 |       }, 600);\n 42 |     } else {\n 43 |       setDemoOutput(\"Scanning Quality Control logs for batch #M-402... Running compliance check...\");\n 44 |       setTimeout(() => {\n 45 |         setDemoOutput(\"SUCCESS: Batch #M-402 passes all QA tolerance checks. ISO-9001 quality certificate generated.\");\n 46 |         setRunning(false);\n 47 |       }, 600);\n 48 |     }\n 49 |   };\n 50 | \n 51 |   return (\n 52 |     <InnerPageShell>\n 53 |       <InnerPageHero\n 54 |         category=\"Vertical Solu