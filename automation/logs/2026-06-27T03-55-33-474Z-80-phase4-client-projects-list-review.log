          \"Establishing transient eBPF socket listener on port 443...\",\n196 |           \"Zero-Trust isolation check: SECURE (100% compliant)...\"\n197 |         ];\n198 |         const randomTemplate = templates[Math.floor(Math.random() * templates.length)];\n199 |         setLogs(prev => [...prev.slice(-4), `[${new Date().toLocaleTimeString()}] ${randomTemplate}`]);\n200 |       }, 4000);\n201 |     }\n202 |     return () => clearInterval(interval);\n203 |   }, [isDrawerOpen, selectedProject, isRequestingUpdate]);\n204 | \n205 |   const handleSyncTelemetry = () => {\n206 |     setIsLogSyncing(true);\n207 |     setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] MANUAL RE-SYNC INITIATED...`]);\n208 |     setTimeout(() => {\n209 |       setIsLogSyncing(false);\n210 |       setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] RE-SYNC COMPLETE. SECURITY ENCLAVE NOMINAL.`]);\n211 |     }, 1200);\n212 |   };\n213 | \n214 |   const triggerUpdateRequest = (projId: string) => {\n215 |     setIsRequestingUpdate(true);\n216 |     setDispatchStep(1);\n217 |     setDispatchSuccess(false);\n218 |     setDispatchLogs([\"Initializing sovereign socket handshake...\"]);\n219 |     setTimeout(() => {\n220 |       setDispatchStep(2);\n221 |       setDispatchLogs(prev => [...prev, \"Broadcasting PRIORITY LEVEL ALPHA dispatch to GFF Engineering Guild...\"]);\n222 |     }, 1000);\n223 |     setTimeout(() => {\n224 |       setDispatchSuccess(true);\n225 |       setNotification(`Emergency program status update requested for project ${projId}`);\n226 |     }, 2200);\n227 |   };\n228 | \n229 |   const closeDrawer = () => {\n230 |     setIsDrawerOpen(false);\n231 |     setIsRequestingUpdate(false);\n232 |     setDispatchStep(0);\n233 |     setDispatchLogs([]);\n234 |     setDispatchSuccess(false);\n235 |   };\n236 | \n237 |   const handleOpenProjectDetails = (proj: ClientProject) => {\n238 |     setSelectedProject(proj);\n239 |     setIsDrawerOpen(true);\n240 |   };\n241 | \n242 |   useEffect(() => {\n243 |     if (notification) {\n244 |       const timer = setTimeout(() => setNotification(null), 5000);\n245 |       return () => clearTimeout(timer);\n246 |     }\n247 |   }, [notification]);\n248 | \n249 |   const filteredProjects = mockProjects.filter(p => {\n250 |     const matchesSearch = \n251 |       p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n252 |       p.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n253 |       p.owner.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n254 |       p.description.toLowerCase().includes(searchQuery.toLowerCase());\n255 |     const matchesPhase = selectedPhase ? p.phase === selectedPhase : true;\n256 |     const matchesHealth = selectedHealth ? p.healthStatus === selectedHealth : true;\n257 |     return matchesSearch && matchesPhase && matchesHealth;\n258 |   });\n259 | \n260 |   const onTrackCount = mockProjects.filter(p => p.healthStatus === \"On Track\").length;\n261 |   const warningCount = mockProjects.filter(p => p.healthStatus === \"Warning\").length;\n262 |   const criticalCount = mockProjects.filter(p => p.healthStatus === \"Critical\").length;\n263 | \n264 |   return (\n265 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-16 select-none relative\">\n266 |       \n267 |       {/* 0. FLOATING NOTIFICATION */}\n268 |       {notification && (\n269 |         <div className=\"fixed top-6 right-6 z-50 animate-in fade-in slide-in-from-top duration-300\">\n270 |           <div className=\"border border-emerald-500/20 bg-emerald-950/70 backdrop-blur-md text-emerald-300 px-4 py-3 rounded-xl shadow-2xl flex items-center gap-3 font-mono text-[11.5px]\">\n271 |             <CheckCircle2 className=\"w-4 h-4 text-emerald-400 shrink-0\" />\n272 |             <span>{notification}</span>\n273 |             <button onClick={() => setNotification(null)} className=\"ml-2 hover:text-white text-emerald-300/60\">\n274 |               <X className=\"w-3.5 h-3.5\" />\n275 |             </button>\n276 |           </div>\n277 |         </div>\n278 |       )}\n279 | \n280 |       {/* 1. SECURE DISCLOSURE BANNER */}\n281 |       <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n282 |         <div className=\"flex items-center gap-2.5 text-white/70\">\n283 |           <Activity className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n284 |           <span>\n285 |             <strong className=\"text-white\">COCKPIT LEDGER SYNC:</strong> Active monitoring of your secure enclaves is online. Interactive parameters represent localized sandbox partitions.\n286 |           </span>\n287 |         </div>\n288 |         <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n289 |           SECURE PROTOCOL ACTIVE\n290 |         </span>\n291 |       </div>\n292 | \n293 |       {/* 2. PRIVATE PAGE WELCOME HEADER */}\n294 |       <PrivatePageHeader\n295 |         title=\"Delivery Program Control Deck\"\n296 |         desc=\"Audit high-end sandbox developments, core model lifecycle phases, compliance checks, and secure multi-agent sandboxes.\"\n297 |         badgeLabel=\"Level III Clearance\"\n298 |         actions={\n299 |           <div className=\"flex flex-wrap gap-2 w-full md:w-auto\">\n300 |             <button\n301 |               onClick={() => {\n302 |                 triggerUpdateRequest(\"GLOBAL-COCKPIT\");\n303 |                 setIsDrawerOpen(true);\n304 |               }}\n305 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.02] px-4 text-[11px] font-mono font-bold text-white hover:bg-white/[0.06] hover:border-white/20 transition-all cursor-pointer\"\n306 |             >\n307 |               <Send className=\"w-3.5 h-3.5 text-white/60\" />\n308 |               <span>REQUEST GLOBAL AUDIT</span>\n309 |             </button>\n310 |             <button\n311 |               onClick={() => router.push(\"/portal/support\")}\n312 |               className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#009DFF] px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/90 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.2)]\"\n313 |             >\n314 |               <MessageSquare className=\"w-3.5 h-3.5\" />\n315 |               <span>SUPPORT WIRE</span>\n316 |             </button>\n317 |           </div>\n318 |         }\n319 |       />\n320 | \n321 |       {/* 3. REAL-TIME PROGRAM HEALTH METRICS */}\n322 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n323 |         <MetricTile\n324 |           title=\"Active Engagements\"\n325 |           value={`${mockProjects.length} Enclaves`}\n326 |           delta=\"+1\"\n327 |           direction=\"up\"\n328 |           status=\"stable\"\n329 |           sparkPoints={[4, 5, 5, 5, 5, 6, 6, 6, 6, 6]}\n330 |         />\n331 |         <MetricTile\n332 |           title=\"Lifecycle Balance\"\n333 |           value=\"2G | 1F | 1F | 1O\"\n334 |           delta=\"NOMINAL\"\n335 |           direction=\"neutral\"\n336 |           status=\"normal\"\n337 |           sparkPoints={[10, 15, 12, 18, 20, 24, 22, 28, 30, 32]}\n338 |         />\n339 |         <MetricTile\n340 |           title=\"Program Health Ratio\"\n341 |           value={`${onTrackCount} OK / ${warningCount} WRN` + (criticalCount > 0 ? ` / ${criticalCount} CRT` : \"\")}\n342 |           delta=\"STABLE\"\n343 |           direction=\"neutral\"\n344 |           status={criticalCount > 0 ? \"warning\" : \"normal\"}\n345 |           sparkPoints={[90, 92, 88, 93, 91, 95, 94, 96, 96, 96]}\n346 |         />\n347 |         <MetricTile\n348 |           title=\"Avg Compliance Guard\"\n349 |           value=\"97.53%\"\n350 |           delta=\"+0.82%\"\n351 |           direction=\"up\"\n352 |           status=\"stable\"\n353 |           sparkPoints={[95.1, 95.8, 96.2, 96.0, 96.9, 97.2, 97.0, 97.4, 97.5, 97.53]}\n354 |         />\n355 |       </div>\n356 | \n357 |       {/* 4. FILTER & VIEW CONTROL BAR */}\n358 |       <WorkspaceCard className=\"p-4 space-y-4 md:space-y-0 md:flex md:items-center md:justify-between gap-4\">\n359 |         {/* Search Input */}\n360 |         <div className=\"relative flex-grow max-w-lg\">\n361 |           <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n362 |           <input \n363 |             type=\"text\"\n364 |             value={searchQuery}\n365 |             onChange={(e) => setSearchQuery(e.target.value)}\n366 |             placeholder=\"Search by ID, program name, owner, description...\"\n367 |             className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n368 |           />\n369 |         </div>\n370 | \n371 |         {/* Filter Selectors */}\n372 |         <div className=\"flex flex-wrap items-center gap-3\">\n373 |           {/* Phase Filter */}\n374 |           <div className=\"relative\">\n375 |             <select\n376 |               value={selectedPhase}\n377 |               onChange={(e) => setSelectedPhase(e.target.value)}\n378 |               className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n379 |             >\n380 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL LIFECYCLE PHASES</option>\n381 |               {LIFECYCLE_PHASES.map(ph => (\n382 |                 <option key={ph} value={ph} className=\"bg-[#0c0c0c] text-white\">{ph.toUpperCase()}</option>\n383 |               ))}\n384 |             </select>\n385 |             <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n386 |           </div>\n387 | \n388 |           {/* Health Status Filter */}\n389 |           <div className=\"relative\">\n390 |             <select\n391 |               value={selectedHealth}\n392 |               onChange={(e) => setSelectedHealth(e.target.value)}\n393 |               className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n394 |             >\n395 |               <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL HEALTH STATUSES</option>\n396 |               <option value=\"On Track\" className=\"bg-[#0c0c0c] text-white\">ON TRACK</option>\n397 |               <option value=\"Warning\" className=\"bg-[#0c0c0c] text-white\">WARNING</option>\n398 |               <option value=\"Critical\" className=\"bg-[#0c0c0c] text-white\">CRITICAL</option>\n399 |             </select>\n400 |             <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n401 |           </div>\n402 | \n403 |           {/* Toggle View Mode Buttons */}\n404 |           <div className=\"flex border border-white/5 rounded-lg overflow-hidden shrink-0\">\n405 |             <button\n406 |               onClick={() => setViewMode(\"grid\")}\n407 |               className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n408 |                 viewMode === \"grid\" \n409 |                   ? \"bg-white/5 text-white\" \n410 |                   : \"bg-transparent text-white/40 hover:text-white/60\"\n411 |               }`}\n412 |             >\n413 |               GRID\n414 |             </button>\n415 |             <button\n416 |               onClick={() => setViewMode(\"table\")}\n417 |               className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n418 |                 viewMode === \"table\" \n419 |                   ? \"bg-white/5 text-white\" \n420 |                   : \"bg-transparent text-white/40 hover:text-white/60\"\n421 |               }`}\n422 |             >\n423 |               TABLE\n424 |             </button>\n425 |           </div>\n426 | \n427 |           {/* Reset Filters Option */}\n428 |           {(searchQuery || selectedPhase || selectedHealth) && (\n429 |             <button\n430 |               onClick={() => {\n431 |                 setSearchQuery(\"\");\n432 |                 setSelectedPhase(\"\");\n433 |                 setSelectedHealth(\"\");\n434 |               }}\n435 |               className=\"text-[10px] font-mono text-red-400 hover:text-red-300 uppercase tracking-wider underline cursor-pointer\"\n436 |             >\n437 |               Clear Filters\n438 |             </button>\n439 |           )}\n440 |         </div>\n441 |       </WorkspaceCard>\n442 | \n443 |       {/* 5. MAIN CONTENT */}\n444 |       {filteredProjects.length === 0 ? (\n445 |         <EmptyState\n446 |           title=\"No Sandbox Program Records Match\"\n447 |           description=\"Clear filters to restore telemetry.\"\n448 |           actionLabel=\"RESET FILTERS\"\n449 |           onAction={() => { setSearchQuery(\"\"); setSelectedPhase(\"\"); setSelectedHealth(\"\"); }}\n450 |           icon={FolderOpen}\n451 |         />\n452 |       ) : viewMode === \"grid\" ? (\n453 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n454 |           {filteredProjects.map((p) => (\n455 |             <WorkspaceCard \n456 |               key={p.id} \n457 |               className=\"flex flex-col h-full border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-all p-5 rounded-2xl relative\"\n458 |               spotlightColor={p.healthStatus === \"On Track\" ? \"rgba(16,185,129,0.03)\" : p.healthStatus === \"Warning\" ? \"rgba(251,191,36,0.03)\" : \"rgba(228,0,15,0.03)\"}\n459 |             >\n460 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2.5\">\n461 |                 <div className=\"flex items-center gap-2\">\n462 |                   <span className=\"text-[12px] font-mono font-bold text-[#009DFF]\">{p.id}</span>\n463 |                   <span className=\"text-[9px] text-white/20 font-mono\">•</span>\n464 |                   <span className=\"text-[9.5px] font-mono text-white/40 bg-white/5 border border-white/10 px-1 py-0.2 rounded uppercase\">{p.env}</span>\n465 |                 </div>\n466 |                 <StatusBadge state={p.healthStatus === \"On Track\" ? \"stable\" : p.healthStatus === \"Warning\" ? \"warning\" : \"error\"} label={p.healthStatus} />\n467 |               </div>\n468 |               \n469 |               <div className=\"mt-3 flex-grow space-y-1\">\n470 |                 <h3 className=\"text-[13.5px] font-bold text-white font-mono uppercase truncate\">{p.name}</h3>\n471 |                 <p className=\"text-[11px] text-white/50 leading-relaxed font-mono font-light min-h-[50px]\">{p.description}</p>\n472 |               </div>\n473 |               \n474 |               <div className=\"mt-3 flex items-center gap-2 p-2 rounded-lg bg-white/[0.01] border border-white/5 text-[11px] font-mono\">\n475 |                 <div className=\"h-6 w-6 rounded bg-[#009DFF]/10 flex items-center justify-center text-[9px] font-bold text-[#009DFF]\">{p.owner.avatarInitials}</div>\n476 |                 <div>\n477 |                   <div className=\"text-[8px] font-mono text-white/30 uppercase\">Delivery Lead</div>\n478 |                   <div className=\"text-[10.5px] text-white/80 font-bold\">{p.owner.name}</div>\n479 |                 </div>\n480 |               </div>\n481 |               \n482 |               <div className=\"mt-3 space-y-1.5 p-2.5 bg-white/[0.01] border border-white/5 rounded-lg\">\n483 |                 <span className=\"text-[8.5px] font-mono text-white/30 uppercase block font-bold font-sans\">Lifecycle Stage</span>\n484 |                 <div className=\"relative flex justify-between px-1\">\n485 |                   <div className=\"absolute left-2 right-2 top-1/2 -translate-y-1/2 h-0.5 border-t border-dashed border-white/10\" />\n486 |                   {LIFECYCLE_PHASES.map((phase, idx) => {\n487 |                     const isCurrent = p.phase === phase;\n488 |                     const isPast = LIFECYCLE_PHASES.indexOf(p.phase) > idx;\n489 |                     return (\n490 |                       <div key={phase} className=\"flex flex-col items-center relative z-10\">\n491 |                         <div className={`h-4 w-4 rounded-full flex items-center justify-center text-[8px] font-bold border ${isCurrent ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF] shadow-[0_0_8px_rgba(0,157,255,0.4)]\" : isPast ? \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\" : \"bg-[#050505] border-white/5 text-white/20\"}`}>{isPast ? \"✓\" : idx + 1}</div>\n492 |                         <span className={`text-[8.5px] font-mono mt-0.5 ${isCurrent ? \"text-white font-bold\" : isPast ? \"text-white/50\" : \"text-white/20\"}`}>{phase}</span>\n493 |                       </div>\n494 |                     );\n495 |                   })}\n496 |                 </div>\n497 |               </div>\n498 | \n499 |               <div className=\"mt-3 space-y-1\">\n500 |                 <div className=\"flex justify-between items-center text-[9.5px] font-mono text-white/40\">\n501 |                   <span>DEPLOYMENT PROGRESS</span>\n502 |                   <span className=\"text-white/80 font-bold\">{p.progress}%</span>\n503 |                 </div>\n504 |                 <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n505 |                   <div className={`h-full rounded-full ${p.healthStatus === \"On Track\" ? \"bg-[#009DFF]\" : p.healthStatus === \"Warning\" ? \"bg-amber-400\" : \"bg-red-500\"}`} style={{ width: `${p.progress}%` }} />\n506 |                 </div>\n507 |               </div>\n508 | \n509 |               <div className=\"mt-3 pt-2.5 border-t border-white/5 flex items-start gap-2 text-[10px] font-mono text-white/45\">\n510 |                 <Calendar className=\"w-3.5 h-3.5 text-white/30 shrink-0\" />\n511 |                 <div className=\"space-y-0.5\">\n512 |                   <span className=\"text-white/20 text-[8px] block font-bold\">NEXT TARGET GATE</span>\n513 |                   <span className=\"text-white/80 font-medium block leading-tight truncate max-w-[200px]\">{p.nextMilestone}</span>\n514 |                 </div>\n515 |               </div>\n516 | \n517 |               <div className=\"mt-4 pt-3 border-t border-white/5 grid grid-cols-2 gap-2\">\n518 |                 <button onClick={() => triggerUpdateRequest(p.id)} className=\"h-7.5 rounded border border-white/5 hover:bg-white/5 text-[9.5px] font-mono text-white/50 hover:text-white uppercase tracking-wider cursor-pointer\">Request Update</button>\n519 |                 <button onClick={() => handleOpenProjectDetails(p)} className=\"h-7.5 rounded bg-[#009DFF]/10 text-[9.5px] font-mono text-[#009DFF] hover:text-white flex items-center justify-center gap-1 cursor-pointer\"><span>Inspect</span><ArrowUpRight className=\"w-3 h-3\" /></button>\n520 |               </div>\n521 |             </WorkspaceCard>\n522 |           ))}\n523 |         </div>\n524 |       ) : (\n525 |         /* TABLE VIEW */\n526 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm overflow-hidden\">\n527 |           <div className=\"overflow-x-auto\">\n528 |             <table className=\"w-full min-w-[800px] text-left font-mono text-[11.5px] text-white/70\">\n529 |               <thead>\n530 |          