{"ts":"2026-06-26T09:15:33.713Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"uvkwh5nw","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/ClientSuccessSection.tsx","old_text":"          /* JSX_PART_5 */","new_text":"          {/* Right panel: Active Preview Workspace (Architecture SVG or Live Simulation Video) */}\n          <div className=\"lg:col-span-5 flex flex-col\">\n            <div className=\"relative rounded-2xl border border-white/5 bg-[#060606] overflow-hidden flex flex-col h-full min-h-[480px]\">\n              \n              {/* Workspace Tab Bar */}\n              <div className=\"border-b border-white/5 px-4 py-3 bg-[#0A0A0A] flex items-center justify-between shrink-0\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-[#E4000F]/30\" />\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-[#E98828]/30\" />\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-emerald-500/30\" />\n                  <span className=\"text-[10px] font-mono text-[#707070] ml-2 tracking-widest uppercase\">\n                    DEPLOYMENT WORKSPACE\n                  </span>\n                </div>\n                \n                {/* Visual View Selector */}\n                <div className=\"flex bg-[#020202] rounded-lg p-0.5 border border-white/5\">\n                  <button\n                    onClick={() => setActiveTab(\"architecture\")}\n                    className={`px-3 py-1 text-[10px] font-mono rounded cursor-pointer transition-colors ${\n                      activeTab === \"architecture\" \n                        ? \"bg-[#E98828] text-black font-semibold\" \n                        : \"text-[#707070] hover:text-[#A0A0A0]\"\n                    }`}\n                  >\n                    BLUEPRINT\n                  </button>\n                  <button\n                    onClick={() => setActiveTab(\"video\")}\n                    className={`px-3 py-1 text-[10px] font-mono rounded cursor-pointer transition-colors ${\n                      activeTab === \"video\" \n                        ? \"bg-[#E98828] text-black font-semibold\" \n                        : \"text-[#707070] hover:text-[#A0A0A0]\"\n                    }`}\n                  >\n                    SIMULATOR\n                  </button>\n                </div>\n              </div>\n\n              {/* TAB CONTENT: DEPLOYMENT ARCHITECTURE SVG MAP */}\n              {activeTab === \"architecture\" && (\n                <div className=\"p-6 flex flex-col justify-between flex-grow\">\n                  <div>\n                    <span className=\"text-[10px] font-mono text-[#707070] tracking-widest uppercase block mb-3\">\n                      SYSTEM TOPOLOGY BLUEPRINT\n                    </span>\n                    <p className=\"text-[12px] text-[#808080] font-light leading-relaxed mb-6\">\n                      Interact with the deployment topology below. Hover over nodes to inspect runtime and data boundaries.\n                    </p>\n\n                    {/* Architecture SVG Map */}\n                    <div className=\"relative bg-[#020202] rounded-xl border border-white/5 p-4 flex items-center justify-center min-h-[160px] overflow-hidden\">\n                      <svg width=\"100%\" height=\"120\" viewBox=\"0 0 100 100\" className=\"w-full h-auto overflow-visible select-none\">\n                        <defs>\n                          <marker id=\"arrow\" viewBox=\"0 0 10 10\" refX=\"6\" refY=\"5\" markerWidth=\"6\" markerHeight=\"6\" orient=\"auto-start-reverse\">\n                            <path d=\"M 0 2 L 8 5 L 0 8 z\" fill=\"#303030\" />\n                          </marker>\n                        </defs>\n\n                        {/* Animated flowing data lines */}\n                        {activePattern.connections.map((conn, idx) => {\n                          const fromNode = activePattern.nodes.find(n => n.id === conn.from);\n                          const toNode = activePattern.nodes.find(n => n.id === conn.to);\n                          if (!fromNode || !toNode) return null;\n                          return (\n                            <g key={idx}>\n                              <line \n                                x1={`${fromNode.x}%`} \n                                y1={`${fromNode.y}%`} \n                                x2={`${toNode.x}%`} \n                                y2={`${toNode.y}%`} \n                                stroke=\"#1A1A1A\" \n                                strokeWidth=\"2\"\n                                markerEnd=\"url(#arrow)\"\n                              />\n                              <line \n                                x1={`${fromNode.x}%`} \n                                y1={`${fromNode.y}%`} \n                                x2={`${toNode.x}%`} \n                                y2={`${toNode.y}%`} \n                                stroke=\"#E98828\" \n                                strokeWidth=\"1.5\"\n                                strokeDasharray=\"4 12\"\n                                strokeDashoffset=\"0\"\n                                className=\"animate-[dash_4s_linear_infinite]\"\n                              />\n                            </g>\n                          );\n                        })}\n\n                        {/* Interactive Node Anchors */}\n                        {activePattern.nodes.map((node) => {\n                          const isHovered = hoveredNode?.id === node.id;\n                          return (\n                            <g \n                              key={node.id} \n                              className=\"cursor-help\"\n                              onMouseEnter={() => setHoveredNode(node)}\n                              onMouseLeave={() => setHoveredNode(null)}\n                            >\n                              <circle \n                                cx={`${node.x}%`} \n                                cy={`${node.y}%`} \n                                r={isHovered ? \"7%\" : \"4.5%\"} \n                                fill={isHovered ? \"rgba(233, 136, 40, 0.15)\" : \"rgba(255, 255, 255, 0.02)\"} \n                                className=\"transition-all duration-300\"\n                                stroke={isHovered ? \"#E98828\" : \"#303030\"}\n                                strokeWidth=\"1\"\n                              />\n                              <circle \n                                cx={`${node.x}%`} \n                                cy={`${node.y}%`} \n                                r=\"1.5%\" \n                                fill={isHovered ? \"#E98828\" : \"#A0A0A0\"}\n                                className=\"transition-colors duration-300\"\n                              />\n                              <text \n                                x={`${node.x}%`} \n                                y={`${node.y - 7}%`} \n                                textAnchor=\"middle\" \n                                fill={isHovered ? \"#E98828\" : \"#606060\"} \n                                className=\"text-[3.5px] font-mono uppercase font-bold transition-colors duration-300\"\n                              >\n                                {node.label.split(\" \")[0]}\n                              </text>\n                            </g>\n                          );\n                        })}\n                      </svg>\n                    </div>\n                  </div>\n\n                  {/* Node inspector panel */}\n                  <div className=\"bg-[#020202] border border-white/5 rounded-xl p-4 min-h-[130px] flex flex-col justify-center\">\n                    <AnimatePresence mode=\"wait\">\n                      {hoveredNode ? (\n                        <motion.div\n                          key={hoveredNode.id}\n                          initial={{ opacity: 0, y: 5 }}\n                          animate={{ opacity: 1, y: 0 }}\n                          exit={{ opacity: 0, y: -5 }}\n                          transition={{ duration: 0.15 }}\n                        >\n                          <div className=\"flex items-center gap-2 mb-2\">\n                            <span className=\"w-1.5 h-1.5 rounded-full bg-[#E98828]\" />\n                            <h4 className=\"text-[13px] font-mono uppercase text-[#E98828] font-bold\">\n                              {hoveredNode.label}\n                            </h4>\n                          </div>\n                          <p className=\"text-[12px] text-[#A0A0A0] font-light leading-relaxed\">\n                            {hoveredNode.desc}\n                          </p>\n                        </motion.div>\n                      ) : (\n                        <motion.div\n                          key=\"default\"\n                          initial={{ opacity: 0 }}\n                          animate={{ opacity: 1 }}\n                          exit={{ opacity: 0 }}\n                          className=\"text-center py-2\"\n                        >\n                          <svg className=\"w-5 h-5 mx-auto text-[#404040] mb-2\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                            <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122\" />\n                          </svg>\n                          <span className=\"text-[11px] font-mono text-[#505050] uppercase tracking-wider\">\n                            HOVER SYSTEM BLUEPRINT NODES TO INSPECT LOGIC\n                          </span>\n                        </motion.div>\n                      )}\n                    </AnimatePresence>\n                  </div>\n                </div>\n              )}\n\n              {/* TAB CONTENT: LIVE AGENT LOG EXECUTION WALKTHROUGH (VIDEO PREVIEW SIMULATOR) */}\n              {activeTab === \"video\" && (\n                <div className=\"p-6 flex flex-col justify-between flex-grow\">\n                  <div>\n                    <div className=\"flex items-center justify-between mb-2\">\n                      <span className=\"text-[10px] font-mono text-[#707070] tracking-widest uppercase\">\n                        AGENT EXECUTION STREAM Walkthrough\n                      </span>\n                      <span className=\"flex items-center gap-1.5 text-[9px] font-mono text-[#E98828]\">\n                        <span className=\"relative flex h-1.5 w-1.5\">\n                          <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-[#E98828] opacity-75\"></span>\n                          <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-[#E98828]\"></span>\n                        </span>\n                        OPERATIONAL LIVE\n                      </span>\n                    </div>\n                    <p className=\"text-[12px] text-[#808080] font-light leading-relaxed mb-4\">\n                      Simulated agent workflow playout. Demonstrates task coordination, policy checks, and core-system ledger executions.\n                    </p>\n\n                    {/* Simulated terminal readout */}\n                    <div className=\"bg-[#020202] rounded-xl border border-white/5 p-4 min-h-[190px] max-h-[220px] overflow-y-auto font-mono text-[10.5px] leading-relaxed flex flex-col justify-end\">\n                      <div className=\"space-y-1.5\">\n                        {streamedLogs.map((log, index) => {\n                          let typeColor = \"text-white/60\";\n                          let prefix = \"[SYS]\";\n                          \n                          if (log.type === \"event\") {\n                            typeColor = \"text-[#E98828] font-semibold\";\n                            prefix = \"[TRG]\";\n                          } else if (log.type === \"agent\") {\n                            typeColor = \"text-sky-400\";\n                            prefix = \"[AGT]\";\n                          } else if (log.type === \"success\") {\n                            typeColor = \"text-emerald-400 font-semibold\";\n                            prefix = \"[OK ]\";\n                          }\n\n                          return (\n                            <motion.div \n                              key={index}\n                              initial={{ opacity: 0, x: -5 }}\n                              animate={{ opacity: 1, x: 0 }}\n                              transition={{ duration: 0.1 }}\n                              className=\"flex gap-2 items-start\"\n                            >\n                              <span className=\"text-[#404040] select-none shrink-0\">{log.time}</span>\n                              <span className={`${typeColor} shrink-0`}>{prefix}</span>\n                              <span className=\"text-white/80\">{log.msg}</span>\n                            </motion.div>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Simulated timeline video controls */}\n                  <div className=\"bg-[#020202] border border-white/5 rounded-xl p-4 flex flex-col sm:flex-row items-center justify-between gap-4 shrink-0 mt-4\">\n                    <div className=\"flex items-center gap-3\">\n                      <button\n                        onClick={handleTogglePlay}\n                        className=\"w-8 h-8 rounded-full border border-white/10 hover:border-[#E98828] bg-white/5 hover:bg-[#E98828]/5 flex items-center justify-center cursor-pointer transition-colors\"\n                        title={isPlaying ? \"Pause Stream\" : \"Play Stream\"}\n                      >\n                        {isPlaying ? (\n                          <svg className=\"w-3.5 h-3.5 text-white\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path d=\"M6 19h4V5H6v14zm8-14v14h4V5h-4z\" />\n                          </svg>\n                        ) : (\n                          <svg className=\"w-3.5 h-3.5 text-white ml-0.5\" fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path d=\"M8 5v14l11-7z\" />\n                          </svg>\n                        )}\n                      </button>\n\n                      <button\n                        onClick={handleResetStream}\n                        className=\"w-8 h-8 rounded-full border border-white/10 hover:border-white/30 bg-white/5 flex items-center justify-center cursor-pointer transition-colors\"\n                        title=\"Restart Simulation\"\n                      >\n                        <svg className=\"w-3.5 h-3.5 text-[#A0A0A0]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 6H16\" />\n                        </svg>\n                      </button>\n\n                      <div className=\"h-4 w-[1px] bg-white/10\" />\n\n                      {/* Speed selector */}\n                      <div className=\"flex gap-1.5\">\n                        <button\n                          onClick={() => setPlaySpeed(1500)}\n                          className={`px-2 py-0.5 text-[8px] font-mono rounded cursor-pointer transition-colors ${\n                            playSpeed === 1500 ? \"bg-[#E98828]/20 text-[#E98828] border border-[#E98828]/30\" : \"bg-white/5 text-[#707070]\"\n                          }`}\n                        >\n                          0.5x\n                        </button>\n                        <button\n                          onClick={() => setPlaySpeed(1000)}\n                          className={`px-2 py-0.5 text-[8px] font-mono rounded cursor-pointer transition-colors ${\n                            playSpeed === 1000 ? \"bg-[#E98828]/20 text-[#E98828] border border-[#E98828]/30\" : \"bg-white/5 text-[#707070]\"\n                          }`}\n                        >\n                          1.0x\n                        </button>\n                        <button\n                          onClick={() => setPlaySpeed(400)}\n                          className={`px-2 py-0.5 text-[8px] font-mono rounded cursor-pointer transition-colors ${\n                            playSpeed === 400 ? \"bg-[#E98828]/20 text-[#E98828] border border-[#E98828]/30\" : \"bg-white/5 text-[#707070]\"\n                          }`}\n                        >\n                          2.5x\n                        </button>\n                      </div>\n                    </div>\n\n                    <span className=\"text-[10px] font-mono text-[#505050]\">\n                      PLAYING EXECUTOR v2.04\n                    </span>\n                  </div>\n                </div>\n              )}\n\n            </div>\n          </div>"}}}
