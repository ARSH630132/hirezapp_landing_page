er-[#050507] ${\n587 |                                 user.status === \"active\" ? \"bg-emerald-400\" : \"bg-neutral-600\"\n588 |                               }`} />\n589 |                             </div>\n590 |                             <div className=\"min-w-0\">\n591 |                               <p className=\"text-xs font-bold text-white group-hover:text-[#009DFF] transition-colors truncate max-w-[150px]\">\n592 |                                 {user.name}\n593 |                               </p>\n594 |                               <p className=\"text-[10px] font-mono text-white/40 truncate max-w-[150px]\">{user.email}</p>\n595 |                             </div>\n596 |                           </div>\n597 |                         </td>\n598 |                         <td className=\"py-3.5 px-4\">\n599 |                           <span className={`inline-flex items-center px-2 py-0.5 rounded text-[9px] font-mono font-bold border ${\n600 |                             user.role === \"gff_admin\"\n601 |                               ? \"bg-purple-500/5 text-purple-400 border-purple-500/20\"\n602 |                               : user.role === \"client_admin\"\n603 |                               ? \"bg-[#009DFF]/5 text-[#009DFF] border-[#009DFF]/20\"\n604 |                               : \"bg-emerald-500/5 text-emerald-400 border-emerald-500/20\"\n605 |                           }`}>\n606 |                             {user.role === \"gff_admin\" ? \"GFF ADMIN\" : user.role === \"client_admin\" ? \"CLIENT ADMIN\" : \"CLIENT MEMBER\"}\n607 |                           </span>\n608 |                         </td>\n609 |                         <td className=\"py-3.5 px-4\">\n610 |                           <p className=\"text-[10.5px] font-mono text-white/70 truncate max-w-[150px]\" title={user.clientAssociation}>\n611 |                             {user.clientAssociation.replace(\" [Preview Client]\", \"\")}\n612 |                           </p>\n613 |                         </td>\n614 |                         <td className=\"py-3.5 px-4\">\n615 |                           <span className={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold ${\n616 |                             user.status === \"active\" ? \"text-emerald-400\" : \"text-white/30\"\n617 |                           }`}>\n618 |                             <span className={`w-1.5 h-1.5 rounded-full ${\n619 |                               user.status === \"active\" ? \"bg-emerald-400 animate-pulse\" : \"bg-neutral-600\"\n620 |                             }`} />\n621 |                             {user.status === \"active\" ? \"ACTIVE\" : \"INACTIVE\"}\n622 |                           </span>\n623 |                         </td>\n624 |                         <td className=\"py-3.5 px-4 text-right\">\n625 |                           <span className=\"text-[9.5px] font-mono text-amber-500/80 font-bold tracking-tight\">\n626 |                             {user.clearance.split(\" \")[2]}\n627 |                           </span>\n628 |                         </td>\n629 |                       </tr>\n630 |                     );\n631 |                   })\n632 |                 )}\n633 |               </tbody>\n634 |             </table>\n635 |           </div>\n636 |         </div>\n637 | \n638 | \n639 |         {/* Right Side: Identity Cryptographic Ledger / Action Panel */}\n640 |         <div className=\"xl:col-span-5 space-y-4\">\n641 |           {selectedUser ? (\n642 |             <div className=\"bg-[#030303]/40 border border-white/5 rounded-xl p-5 space-y-5 relative overflow-hidden\">\n643 |               {/* Graphic Decal Label */}\n644 |               <div className=\"absolute top-0 right-0 px-2 py-0.5 bg-white/[0.02] border-b border-l border-white/5 font-mono text-[8px] text-white/30 uppercase tracking-widest select-none\">\n645 |                 ENCLAVE REGISTRY BOUNDS\n646 |               </div>\n647 | \n648 |           