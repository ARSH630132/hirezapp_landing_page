ned Trust Enclave</span>\n674 |                   <div className=\"flex items-center gap-1.5 text-white font-bold truncate\">\n675 |                     <Server className=\"w-3.5 h-3.5 text-cyan-400 shrink-0\" />\n676 |                     <span className=\"truncate\">{selectedUser.clientAssociation}</span>\n677 |                   </div>\n678 |                 </div>\n679 | \n680 |                 <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1\">\n681 |                   <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Clearance Tier</span>\n682 |                   <span className=\"text-amber-500 font-bold block truncate\">\n683 |                     {selectedUser.clearance.replace(\"CLEARANCE LEVEL \", \"LVL-\")}\n684 |                   </span>\n685 |                 </div>\n686 | \n687 |                 <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1\">\n688 |                   <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Session Link</span>\n689 |                   <span className={`font-bold block ${selectedUser.status === \"active\" ? \"text-emerald-400\" : \"text-white/40\"}`}>\n690 |                     {selectedUser.status === \"active\" ? \"LIVE SYNC\" : \"FLUSHED\"}\n691 |                   </span>\n692 |                 </div>\n693 |               </div>\n694 | \n695 |               {/* Dynamic Permissions Matrix Grid */}\n696 |               <div className=\"space-y-2\">\n697 |                 <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase font-bold border-b border-white/5 pb-1 select-none\">\n698 |                   <span>Enclave Permissions Bound</span>\n699 |                   <span className=\"text-purple-400 font-mono text-[9px]\">\n700 |                     {selectedUser.permissions.length} Keys Assigned\n701 |                   </span>\n702 |                 </div>\n703 |                 <div className=\"flex flex-wrap gap-1.5 max-h-[100px] overflow-y-auto pr-1\">\n704 |                   {selectedUser.permissions.map((perm) => (\n705 |                     <span\n706 |                       key={perm}\n707 |                       className=\"px-2 py-0.5 text-[9px] font-mono font-semibold bg-[#00FFC2]/5 text-[#00FFC2] rounded border border-[#00FFC2]/20 shadow-[0_0_8px_rgba(0,255,194,0.02)]\"\n708 |                     >\n709 |                       {perm}\n710 |                     </span>\n711 |                   ))}\n712 |                 </div>\n713 |               </div>\n714 | \n715 | \n716 |               {/* Secure Local Actions */}\n717 |               <div className=\"space-y-3 pt-2 border-t border-white/5\">\n718 |                 <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40 uppercase font-bold select-none\">\n719 |                   <Settings className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n720 |                   <span>Emulated Identity Controls</span>\n721 |                 </div>\n722 | \n723 |                 <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n724 |                   {/* Action: Change Role Dropdown */}\n725 |                   <div className=\"bg-white/[0.01] border border-white/5 rounded-lg p-2.5 flex flex-col gap-1.5 font-mono\">\n726 |                     <span className=\"text-[9px] font-mono text-white/30 uppercase font-bold\">Role Hierarchy</span>\n727 |                     <select\n728 |                       value={selectedUser.role}\n729 |                       onChange={(e) => handleRoleChange(selectedUser.id, e.target.value as any)}\n730 |                       className=\"px-2 py-1 bg-[#09090b] border border-white/10 focus:border-[#009DFF]/50 focus:outline-none rounded text-[11px] font-mono text-white cursor-pointer transition-all\"\n731 |                     >\n732 |                       <option value=\"gff_admin\">gff_admin</option>\n733 |                       <option value=\"client_admin\">client_admin</option>\n734 |                       <option value=\"client_member\">client_member</option>\n735 |                     </select>\n736 |                   </div>\n737 | \n738 |                   {/* Action: Deactivate status toggle button */}\n739 |                   <div className=\"bg-white/[0.01] border border-white/5 rounded-lg p-2.5 flex flex-col gap-1.5 justify-between\">\n740 |                     <span className=\"text-[9px] font-mono text-white/30 uppercase font-bold\">Access Status</span>\n741 |                     <button\n742 |                       onClick={() => handleToggleStatus(selectedUser.id)}\n743 |                       className={`w-full py-1.5 rounded text-[10px] font-mono font-bold uppercase transition-all cursor-pointer border ${\n744 |                         selectedUser.status === \"active\"\n745 |                           ? \"bg-red-500/10 hover:bg-red-500/20 text-red-400 border-red-500/25 hover:border-red-500/40\"\n746 |                           : \"bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border-emerald-500/25 hover:border-emerald-500/40\"\n747 |                       }`}\n748 |                     >\n749 |                       {selectedUser.status === \"active\" ? \"Deactivate Key\" : \"Re-Activate Key\"}\n750 |                     </button>\n751 |                   </div>\n752 | \n753 |                   {/* Action: Reset Credentials button */}\n754 |                   <button\n755 |                     onClick={() => handleResetCredentials(selectedUser.id)}\n756 |                     disabled={isResetting}\n757 |                     className=\"sm:col-span-2 py-2.5 px-3 rounded bg-[#009DFF]/10 hover:bg-[#009DFF]/20 text-[#009DFF] border border-[#009DFF]/25 hover:border-[#009DFF]/45 text-[11px] font-mono font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50\"\n758 |                   >\n759 |                     {isResetting ? (\n760 |                       <>\n761 |                         <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n762 |                         <span>ROLLING HSM KEYS...</span>\n763 |                       </>\n764 |                     ) : (\n765 |                       <>\n766 |                         <KeyRound className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n767 |                         <span>Reset Dual-Key FIDO2 Access</span>\n768 |                       </>\n769 |                     )}\n770 |                   </button>\n771 |                 </div>\n772 |               </div>\n773 | \n774 |               {/* Secure Audit Logs Stream */}\n775 |               <div className=\"space-y-2\">\n776 |                 <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase font-bold border-b border-white/5 pb-1 select-none\">\n777 |                   <span>Operator Audit Flux</span>\n778 |                   <span className=\"flex items-center gap-1 text-[8.5px] text-green-400 font-mono\">\n779 |                     <span className=\"w-1 h-1 rounded-full bg-green-400 animate-pulse\" />\n780 |                     STREAM ACTIVE\n781 |                   </span>\n782 |                 </div>\n783 |                 <div className=\"p-3 rounded bg-black/60 border border-white/5 font-mono text-[9.5px] text-white/70 space-y-1.5 h-[120px] overflow-y-auto\">\n784 |                   {auditLogs.map((log, idx) => (\n785 |                     <div key={idx} className=\"leading-tight border-b border-white/[0.02] pb-1 select-text\">\n786 |                       <span className=\"text-[#009DFF]/60 font-mono\">&gt;</span> {log}\n787 |                     </div>\n788 |                   ))}\n789 |                   <div className=\"text-[8px] text-white/30 pt-1 flex items-center gap-1 select-none\">\n790 |                     <Lock className=\"w-2.5 h-2.5 text-[#00FFC2]\" />\n791 |                     <span>Cryptographic session signature locked</span>\n792 |                   </div>\n793 |                 </div>\n794 |               </div>\n795 |             </div>\n796 |           ) : (\n797 |             <div className=\"bg-[#030303]/40 border border-white/5 rounded-xl p-8 text-center space-y-3\">\n798 |               <Shield className=\"w-12 h-12 text-white/10 mx-auto\" />\n799 |               <p className=\"text-xs font-mono text-white/50 uppercase select-none\">\n800 |                 Select an Identity operator card to inspect credentials and policy bounds.\n801 |               </p>\n802 |             </div>\n803 |           )}\n804 |         </div>\n805 |       </div>\n806 | \n807 | \n808 |       {/* Verification Handshake Diagnostic Dialog */}\n809 |       {showHandshakeLogs && (\n810 |         <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4 animate-fadeIn\">\n811 |           <div className=\"w-full max-w-2xl bg-[#09090b] border border-white/10 rounded-xl overflow-hidden shadow-2xl\">\n812 |             <div className=\"p-4 border-b border-white/10 bg-[#0c0c0e] flex items-center justify-between\">\n813 |               <div className=\"flex items-center gap-2 select-none\">\n814 |                 <Terminal className=\"w-4 h-4 text-amber-500 animate-pulse\" />\n815 |                 <span className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">\n816 |                   Vanguard Auth OIDC Handshake Diagnostic Stream\n817 |                 </span>\n818 |               </div>\n819 |               <button\n820 |                 onClick={() => setShowHandshakeLogs(false)}\n821 |                 className=\"text-white/40 hover:text-white p-1 rounded hover:bg-white/5 transition-all cursor-pointer\"\n822 |               >\n823 |                 <X className=\"w-4 h-4\" />\n824 |               </button>\n825 |             </div>\n826 |             <div className=\"p-6 space-y-4 font-mono text-xs text-white/90\">\n827 |               <div className=\"p-4 bg-black/60 rounded-lg border border-white/5 space-y-2 h-[260px] overflow-y-auto font-mono\">\n828 |                 <p className=\"text-white/30 font-mono text-[10px] select-none\">[SYSTEM INITIALIZING OIDC DIAGNOSTIC PROBE]</p>\n829 |                 <p className=\"text-amber-400 font-mono\">&gt; Connecting to OIDC Provider at federated.auth.gff.ai...</p>\n830 |                 <p className=\"text-green-400 font-mono\">&gt; [OK] Connected. SSL/TLS 1.3 Handshake completed. Cipher Suite: TLS_AES_256_GCM_SHA384</p>\n831 |                 <p className=\"text-white/60 font-mono\">&gt; GET /.well-known/openid-configuration HTTP/1.1</p>\n832 |                 <p className=\"text-green-400 font-mono\">&gt; [200 OK] Metadata loaded. JWKS URI verified: https://auth.gff.ai/oauth2/keys</p>\n833 |                 <p className=\"text-white/60 font-mono\">&gt; POST /oauth2/v1/token - grant_type=client_credentials&amp;scope=gff_admin+openid</p>\n834 |                 <p className=\"text-[#009DFF] font-mono\">&gt; [TOKEN RECEIVED] JWT Token Header: {\"{\\\"alg\\\":\\\"RS256\\\",\\\"kid\\\":\\\"gff-vanguard-key-01\\\"}\"}</p>\n835 |                 <p className=\"text-green-400 font-mono\">&gt; JWT Payload Decoded: {\"{\\\"iss\\\":\\\"gff.ai\\\",\\\"sub\\\":\\\"vanguard-operator-agent\\\",\\\"clearance\\\":\\\"LEVEL_V\\\",\\\"exp\\\":1782568400}\"}</p>\n836 |                 <p className=\"text-[#00FFC2] font-mono\">&gt; Cryptographic signature verified against GFF AI Key Management Service (KMS).</p>\n837 |                 <p className=\"text-white/30 font-mono text-[10px] select-none pt-2\">--- END OF HANDSHAKE DISCOVERY ---</p>\n838 |                 <p className=\"text-[#00FFC2] font-semibold animate-pulse font-mono select-none\">&gt; STATUS: OIDC IDENTITY COUPLING STANDBY (PHASE 5 READINESS CONFIRMED)</p>\n839 |               </div>\n840 |               <div className=\"text-[10.5px] text-white/40 leading-relaxed select-none\">\