tSearchQuery] = useState(\"\");\n148 |   const [selectedRoleFilter, setSelectedRoleFilter] = useState<\"all\" | \"gff_admin\" | \"client_admin\" | \"client_member\">(\"all\");\n149 |   const [selectedClientFilter, setSelectedClientFilter] = useState<\"all\" | string>(\"all\");\n150 | \n151 |   // Interaction logs\n152 |   const [auditLogs, setAuditLogs] = useState<string[]>([\n153 |     `[${new Date().toLocaleTimeString()}] AUDIT: Sandboxed identity ledger loaded successfully.`,\n154 |     `[${new Date().toLocaleTimeString()}] CRYPTO: Validated FIDO2 secure keys for all active administrators.`,\n155 |     `[${new Date().toLocaleTimeString()}] GUARDRAIL: Zero-Drift compliance score confirmed.`\n156 |   ]);\n157 | \n158 |   // Loading / Actions States\n159 |   const [isResetting, setIsResetting] = useState(false);\n160 |   const [showHandshakeLogs, setShowHandshakeLogs] = useState(false);\n161 |   const [copiedToken, setCopiedToken] = useState(false);\n162 | \n163 |   // Invite Modal State\n164 |   const [isInviteOpen, setIsInviteOpen] = useState(false);\n165 |   const [inviteName, setInviteName] = useState(\"\");\n166 |   const [inviteEmail, setInviteEmail] = useState(\"\");\n167 |   const [inviteRole, setInviteRole] = useState<\"gff_admin\" | \"client_admin\" | \"client_member\">(\"client_member\");\n168 |   const [inviteClient, setInviteClient] = useState(\"Apex Sovereign Group [Preview Client]\");\n169 |   const [inviteStep, setInviteStep] = useState<\"form\" | \"generating\" | \"success\">(\"form\");\n170 |   const [generatedToken, setGeneratedToken] = useState(\"\");\n171 | \n172 |   // Set default selected user upon initial mount\n173 |   useEffect(() => {\n174 |     if (users.length > 0 && !selectedUser) {\n175 |       setSelectedUser(users[0]);\n176 |     }\n177 |   }, [users, selectedUser]);\n178 | \n179 |   // Handle Role Shift\n180 |   const handleRoleChange = (userId: string, newRole: \"gff_admin\" | \"client_admin\" | \"client_member\") => {\n181 |     const updatedUsers = users.map((u) => {\n182 |       if (u.id === userId) {\n183 |         const updated: LocalUser = {\n184 |           ...u,\n185 |           role: newRole,\n186 |           clearance: ROLE_CLEARANCES[newRole],\n187 |           permissions: ROLE_PERMISSIONS[newRole]\n188 |         };\n189 |         if (selectedUser?.id === userId) {\n190 |           setSelectedUser(updated);\n191 |         }\n192 |         return updated;\n193 |       }\n194 |       return u;\n195 |     });\n196 | \n197 |     setUsers(updatedUsers);\n198 | \n199 |     const timestamp = new Date().toLocaleTimeString();\n200 |     setAuditLogs((prev) => [\n201 |       `[${timestamp}] AUDIT: Shifted role for Operator ${userId} -> ${newRole.toUpperCase()}.`,\n202 |       `[${timestamp}] POLICY: Cryptographically mapped ${ROLE_PERMISSIONS[newRole].length} target clearance bounds.`,\n203 |       ...prev\n204 |     ]);\n205 |   };\n206 | \n207 |   // Handle Access Status Toggle\n208 |   const handleToggleStatus = (userId: string) => {\n209 |     const updatedUsers = users.map((u) => {\n210 |       if (u.id === userId) {\n211 |         const updatedStatus = u.status === \"active\" ? \"inactive\" : \"active\";\n212 |         const updated: LocalUser = { ...u, status: updatedStatus };\n213 |         if (selectedUser?.id === userId) {\n214 |           setSelectedUser(updated);\n215 |         }\n216 |         return updated;\n217 |       }\n218 |       return u;\n219 |     });\n220 | \n221 |     setUsers(updatedUsers);\n222 | \n223 |     const targetUser = users.find((u) => u.id === userId);\n224 |     const stateText = targetUser?.status === \"active\" ? \"REVOKED (OFFLINE)\" : \"RESTORED (ONLINE)\";\n225 |     const timestamp = new Date().toLocaleTimeString();\n226 |     setAuditLogs((prev) => [\n227 |       `[${timestamp}] LOCKDOWN: Access status for Operator ${userId} set to ${stateText}.`,\n228 |       `[${timestamp}] SECURITY: Terminated active session credentials & rolled local telemetry locks.`,\n229 |       ...prev\n230 |     ]);\n231 |   };\n232 | \n233 |   // Handle Dual-Key FIDO2 Access Reset\n234 |   const handleResetCredentials = (userId: string) => {\n235 |     setIsResetting(true);\n236 |     const timestamp = new Date().toLocaleTimeString();\n237 |     setAuditLogs((prev) => [\n238 |       `[${timestamp}] INITIALIZE: Initiating Dual-Key FIDO2 credential reset for ${userId}.`,\n239 |       `[${timestamp}] HSM: Rolling over hardware security module encryption bounds...`,\n240 |       ...prev\n241 |     ]);\n242 | \n243 |     setTimeout(() => {\n244 |       setIsResetting(false);\n245 |       const finishedTimestamp = new Date().toLocaleTimeString();\n246 |       const generatedBackupCode = `GFF-FIDO2-0x${Math.random().toString(16).slice(2, 10).toUpperCase()}`;\n247 |       setAuditLogs((prev) => [\n248 |         `[${finishedTimestamp}] SUCCESS: Sealed backup coordinates with HSM signature.`,\n249 |         `[${finishedTimestamp}] CRYPTO: Bound public keys. Temp Recovery Code: ${generatedBackupCode}`,\n250 |         ...prev\n251 |       ]);\n252 |       alert(`Cryptographic FIDO2 access reset successful!\\n\\nTemporary Recovery Token (Local Simulation):\\n${generatedBackupCode}\\n\\nNote: The user key card has been re-bound in local memory.`);\n253 |     }, 1200);\n254 |   };\n255 | \n256 | \n257 |   // Handle Invite Form Submission\n258 |   const handleInviteSubmit = (e: React.FormEvent) => {\n259 |     e.preventDefault();\n260 |     if (!inviteName.trim() || !inviteEmail.trim()) return;\n261 | \n262 |     setInviteStep(\"generating\");\n263 |     \n264 |     setTimeout(() => {\n265 |       const token = `gff_envelope_0x${Math.random().toString(16).slice(2, 14).toUpperCase()}`;\n266 |       setGeneratedToken(token);\n267 | \n268 |       const newUser: LocalUser = {\n269 |         id: `usr-${Math.floor(100 + Math.random() * 900)}`,\n270 |         name: inviteName,\n271 |         email: inviteEmail,\n272 |         role: inviteRole,\n273 |         clientAssociation: inviteRole === \"gff_admin\" ? \"GFF AI Platform Core (Global Root)\" : inviteClient,\n274 |         status: \"inactive\", // inactive until accepted in simulation\n275 |         clearance: ROLE_CLEARANCES[inviteRole],\n276 |         lastActive: \"Never\",\n277 |         createdAt: new Date().toISOString().split(\"T\")[0],\n278 |         permissions: ROLE_PERMISSIONS[inviteRole]\n279 |       };\n280 | \n281 |       setUsers((prev) => [...prev, newUser]);\n282 |       setSelectedUser(newUser);\n283 |       \n284 |       const timestamp = new Date().toLocaleTimeString();\n285 |       setAuditLogs((prev) => [\n286 |         `[${timestamp}] PROVISION: Sealed dual-key cryptographic invitation envelope for ${inviteEmail}.`,\n287 |         `[${timestamp}] ENVELOPE: Token ${token} queued. Access bounds mapped to ${inviteRole.toUpperCase()}.`,\n288 |         ...prev\n289 |       ]);\n290 | \n291 |       setInviteStep(\"success\");\n292 |     }, 1000);\n293 |   };\n294 | \n295 |   // Emulate Accepting the Invite (instantly makes the newly added user active)\n296 |   const handleAcceptInviteSimulated = () => {\n297 |     const lastUser = users[users.length - 1];\n298 |     if (lastUser) {\n299 |       const updatedUsers = users.map((u) => \n300 |         u.id === lastUser.id ? { ...u, status: \"active\" as const, lastActive: \"Just now\" } : u\n301 |       );\n302 |       setUsers(updatedUsers);\n303 |       setSelectedUser({ ...lastUser, status: \"active\" as const, lastActive: \"Just now\" });\n304 | \n305 |       const timestamp = new Date().toLocaleTimeString();\n306 |       setAuditLogs((prev) => [\n307 |         `[${timestamp}] ACCEPTANCE: Operator ${lastUser.name} accepted invite token.`,\n308 |         `[${timestamp}] ACCESS: Cryptographic session established. FIDO2 security token bound.`,\n309 |         ...prev\n310 |       ]);\n311 |     }\n312 |     setIsInviteOpen(false);\n313 |     setInviteStep(\"form\");\n314 |     setInviteName(\"\");\n315 |     setInviteEmail(\"\");\n316 |   };\n317 | \n318 |   // Copy simulated invite link/token\n319 |   const copyTokenToClipboard = () => {\n320 |     navigator.clipboard.writeText(generatedToken);\n321 |     setCopiedToken(true);\n322 |     setTimeout(() => setCopiedToken(false), 2000);\n323 |   };\n324 | \n325 |   // Derive unique clients list for filtering\n326 |   const uniqueClients = Array.from(\n327 |     new Set(users.map((u) => u.clientAssociation).filter((c) => c !== \"GFF AI Platform Core (Global Root)\"))\n328 |   );\n329 | \n330 |   // Filter Users\n331 |   const filteredUsers = users.filter((user) => {\n332 |     // Search filter\n333 |     if (\n334 |       searchQuery.trim() !== \"\" &&\n335 |       !user.name.toLowerCase().includes(searchQuery.toLowerCase()) &&\n336 |       !user.email.toLowerCase().includes(searchQuery.toLowerCase()) &&\n337 |       !user.id.toLowerCase().includes(searchQuery.toLowerCase())\n338 |     ) {\n339 |       return false;\n340 |     }\n341 | \n342 |     // Role filter\n343 |     if (selectedRoleFilter !== \"all\" && user.role !== selectedRoleFilter) {\n344 |       return false;\n345 |     }\n346 | \n347 |     // Client filter\n348 |     if (selectedClientFilter !== \"all\" && user.clientAssociation !== selectedClientFilter) {\n349 |       return false;\n350 |     }\n351 | \n352 |     return true;\n353 |   });\n354 | \n355 | \n356 |   return (\n357 |     <div className=\"space-y-6 max-w-7xl mx-auto px-1\">\n358 |       {/* Page Header */}\n359 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n360 |         <div>\n361 |           <h1 className=\"text-xl md:text-2xl font-bold text-white tracking-tight font-mono uppercase\">\n362 |             RBAC & Identity Access Console\n363 |           </h1>\n364 |           <p className=\"text-xs text-white/50 mt-1\">\n365 |             Audit and configure platform identity states, govern isolated client enclaves, assign cryptographic permissions, and trigger credential resets.\n366 |           </p>\n367 |         </div>\n368 |         <button\n369 |           onClick={() => {\n370 |             setInviteStep(\"form\");\n371 |             setIsInviteOpen(true);\n372 |           }}\n373 |           className=\"px-4 py-2 bg-gradient-to-r from-emerald-500/10 to-[#009DFF]/10 hover:from-emerald-500/20 hover:to-[#009DFF]/20 text-white rounded border border-emerald-500/25 hover:border-emerald-500/55 font-mono text-xs uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer shadow-[0_0_15px_rgba(16,185,129,0.05)] hover:shadow-[0_0_20px_rgba(16,185,129,0.15)] self-start md:self-auto\"\n374 |         >\n375 |           <UserPlus className=\"w-4 h-4 text-emerald-400\" />\n376 |           <span>Provision Identity</span>\n377 |         </button>\n378 |       </div>\n379 | \n380 |       {/* Backend / Auth Integration Phase Notice */}\n381 |       <div className=\"p-4 rounded-xl border border-amber-500/20 bg-amber-500/[0.015] space-y-3 relative overflow-hidden\">\n382 |         <div className=\"absolute top-0 right-0 px-2 py-0.5 bg-amber-500/10 text-amber-400 font-mono text-[8px] uppercase tracking-widest border-b border-l border-amber-500/20 select-none\">\n383 |           PHASE 4 EMULATION\n384 |         </div>\n385 |         <div className=\"flex items-start gap-3\">\n386 |           <div className=\"p-2 rounded bg-amber-500/10 border border-amber-500/20 mt-0.5\">\n387 |             <ShieldAlert className=\"w-4 h-4 text-amber-500\" />\n388 |           </div>\n389 |           <div className=\"space-y-1\">\n390 |             <h3 className=\"text-xs font-bold text-amber-400 font-mono uppercase tracking-wider\">\n391 |               Identity Management Sandbox (Frontend-Only Preview)\n392 |             </h3>\n393 |             <p className=\"text-[11px] text-white/70 leading-relaxed max-w-4xl\">\n394 |               This administration dashboard is operating in <span className=\"text-amber-300 font-semibold font-mono\">Secure Local Emulation Mode</span>. \n395 |               All role changes, credential revocations, and provisions occur entirely in session-local memory. \n396 |               Actual Okta, SAML, or OIDC directories are decoupled; real network invitation dispatches are suppressed.\n397 |             </p>\n398 |           </div>\n399 |         </div>\n400 |         <div className=\"flex flex-wrap items-center gap-x-4 gap-y-2 pt-1 pl-11\">\n401 |           <button\n402 |             onClick={() => setShowHandshakeLogs(true)}\n403 |             className=\"px-2.5 py-1 bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 hover:text-amber-300 text-[10px] font-mono rounded border border-amber-500/20 hover:border-amber-500/40 transition-all flex items-center gap-1.5 cursor-pointer\"\n404 |           >\n405 |             <RefreshCw className=\"w-3 h-3 animate-pulse\" />\n406 |             <span>Verify Vanguard OIDC Handshake</span>\n407 |           </button>\n408 |           <span className=\"text-[9.5px] text-white/30 font-mono select-none\">\n409 |             Federated Identity Gateway: <span className=\"text-amber-500/45 font-mono\">https://auth.gff.ai/v1/emulated</span>\n410 |           </span>\n411 |         </div>\n412 |       </div>\n413 | \n414 | \n415 |       {/* Stats Indicator Bar */}\n416 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n417 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n418 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n419 |             <span>Operator Directory</span>\n420 |             <Users className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n421 |           </div>\n422 |           <div className=\"flex items-baseline gap-2 pt-0.5\">\n423 |             <span className=\"text-2xl font-bold text-white tracking-tight font-mono\">{users.length}</span>\n424 |             <span className=\"text-[9.5px] text-green-400 font-mono\">Bound</span>\n425 |           </div>\n426 |         </div>\n427 | \n428 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n429 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n430 |             <span>Role Distribution</span>\n431 |             <Shield className=\"w-3.5 h-3.5 text-purple-400\" />\n432 |           </div>\n433 |           <div className=\"pt-1.5\">\n434 |             <span className=\"text-[11px] font-mono text-white/70 block leading-tight\">\n435 |               {users.filter(u => u.role === \"gff_admin\").length} GFF Admin / {users.filter(u => u.role === \"client_admin\").length} Client Admin\n436 |             </span>\n437 |           </div>\n438 |         </div>\n439 | \n440 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n441 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n442 |             <span>Active Enclaves</span>\n443 |             <Server className=\"w-3.5 h-3.5 text-cyan-400\" />\n444 |           </div>\n445 |           <div className=\"flex items-baseline gap-1 pt-0.5\">\n446 |             <span className=\"text-2xl font-bold text-white tracking-tight font-mono\">\n447 |               {uniqueClients.length}\n448 |             </span>\n449 |             <span className=\"text-[9.5px] text-white/30 font-mono\">Bound Enclaves</span>\n450 |           </div>\n451 |         </div>\n452 | \n453 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n454 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n455 |             <span>Audit Key Drift</span>\n456 |             <BadgeCheck className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n457 |           </div>\n458 |           <div className=\"flex items-baseline gap-1 pt-0.5\">\n459 |             <span className=\"text-2xl font-bold text-[#00FFC2] tracking-tight font-mono\">0.00%</span>\n460 |             <span className=\"text-[9.5px] text-[#00FFC2]/60 font-mono\">Fully Verified</span>\n461 |           </div>\n462 |         </div>\n463 |       </div>\n464 | \n465 |       {/* Main Workspace Grid */}\n466 |       <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-6 items-start\">\n467 | \n468 |         {/* Left Side: Directory Table & Filters */}\n469 |         <div className=\"xl:col-span-7 bg-[#030303]/40 border border-white/5 rounded-xl p-5 space-y-4\">\n470 |           <div className=\"flex flex-col md:flex-row items-center gap-3\">\n471 |             {/* Search Input */}\n472 |             <div className=\"relative w-full md:w-64\">\n473 |               <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n474 |               <input\n475 |                 type=\"text\"\n476 |                 placeholder=\"Search identifier or email...\"\n477 |                 value={searchQuery}\n478 |                 onChange={(e) => setSearchQuery(e.target.value)}\n479 |                 className=\"w-full pl-9 pr-4 py-2 bg-[#0a0a0c] border border-white/5 hover:border-white/10 focus:border-white/20 focus:outline-none rounded text-xs font-mono text-white placeholder-white/30 transition-all\"\n480 |               />\n481 |               {searchQuery && (\n482 |                 <button\n483 |                   onClick={() => setSearchQuery(\"\")}\n484 |                   className=\"absolute right-3 top-2.5 text-white/30 hover:text-white\"\n485 |                 >\n486 |                   <X className=\"w-3.5 h-3.5\" />\n487 |                 </button>\n488 |               )}\n489 |             </div>\n490 | \n491 |             {/* Client Enclave Filter */}\n492 |             <div className=\"w-full md:w-48\">\n493 |               <select\n494 |                 value={selectedClientFilter}\n495 |                 onChange={(e) => setSelectedClientFilter(e.target.value)}\n496 |                 className=\"w-full px-3 py-2 bg-[#0a0a0c] border border-white/5 focus:border-white/20 focus:outline-none rounded text-xs font-mono text-white/80 transition-all cursor-pointer\"\n497 |               >\n498 |                 <option value=\"all\">All Enclaves</option>\n499 |                 {uniqueClients.map((client) => (\n500 |                   <option key={client} value={client}>\n501 |                     {client.replace(\" [Preview Client]\", \"\")}\n502 |                   </option>\n503 |                 ))}\n504 |               </select>\n505 |             </div>\n506 | \n507 |             {/* Role Filter Pills */}\n508 |             <div className=\"flex items-center gap-1 overflow-x-auto w-full md:w-auto pb-1 md:pb-0 scrollbar-none\">\n509 |               {([\"all\", \"gff_admin\", \"client_admin\", \"client_member\"] as const).map((role) => (\n510 |                 <button\n511 |                   key={role}\n512 |                   onClick={() => setSelectedRoleFilter(role)}\n513 |                   className={`px-2.5 py-1.5 rounded text-[10px] font-mono font-semibold uppercase tracking-wider border transition-all cursor-pointer whitespace-nowrap ${\n514 |                     selectedRoleFilter === role\n515 |                       ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/30 shadow-[0_0_10px_rgba(0,157,255,0.15)]\"\n516 |                       : \"bg-white/[0.01] text-white/50 border-white/5 hover:text-white/80 hover:border-white/10\"\n517 |                   }`}\n518 |                 >\n519 |                   {role === \"all\" ? \"All Roles\" : role.replace(\"_\", \" \")}\n520 |                 </button>\n521 |               ))}\n522 |             </div>\n523 |           </div>\n524 | \n525 | \n526 |           {/* Table container */}\n527 |           <div className=\"overflow-x-auto rounded border border-white/5 bg-[#050507]\">\n528 |             <table className=\"w-full min-w-[620px] border-collapse text-left\">\n529 |               <thead>\n530 |                 <tr className=\"border-b border-white/5 bg-white/[0.02] text-[10px] font-mono text-white/40 uppercase tracking-wider\">\n531 |                   <th className=\"py-3 px-4 font-semibold\">Operator & Secure ID</th>\n532 |                   <th className=\"py-3 px-4 font-semibold\">Role Allocation</th>\n533 |                   <th className=\"py-3 px-4 font-semibold\">Client Association</th>\n534 |                   <th className=\"py-3 px-4 font-semibold\">Status</th>\n535 |                   <th className=\"py-3 px-4 font-semibold text-right\">Clearance</th>\n536 |                 </tr>\n537 |               </thead>\n538 |               <tbody className=\"divide-y divide-white/5\">\n539 |                 {filteredUsers.length === 0 ? (\n540 |                   <tr>\n541 |                     <td colSpan={5} className=\"py-12 text-center\">\n542 |                       <div className=\"flex flex-col items-center justify-center gap-2\">\n543 |                         <Users className=\"w-8 h-8 text-white/10\" />\n544 |                         <p className=\"text-xs font-mono text-white/40 uppercase\">No operators found matching criteria</p>\n545 |                         <button\n546 |                           onClick={() => {\n547 |                             setSearchQuery(\"\");\n548 |                             setSelectedRoleFilter(\"all\");\n549 |                             setSelectedClientFilter(\"all\");\n550 |                           }}\n551 |                           className=\"mt-2 text-[10px] font-mono text-[#009DFF] hover:underline\"\n552 |                         >\n553 |                           Reset Console Filters\n554 |                         </button>\n555 |                       </div>\n556 |                     </td>\n557 |                