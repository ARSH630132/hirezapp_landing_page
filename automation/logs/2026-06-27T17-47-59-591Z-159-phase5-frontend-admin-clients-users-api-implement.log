{"ts":"2026-06-27T17:44:10.351Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ksvr2urw","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/clients/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  previewProjects, \n  previewAgentOperations,\n  ClientAccount,\n  Project,\n  AgentOperation\n} from \"@/lib/mock-data-model\";\nimport { \n  Search, Plus, User, ExternalLink, Shield, Check, Copy, \n  ChevronRight, Info, SlidersHorizontal, Clock, CreditCard, Layers, \n  Bot, AlertTriangle, CheckCircle2, X, Building, Globe, RefreshCw, Lock,\n  ShieldAlert, BadgeCheck, Trash2, Edit, Sliders\n} from \"lucide-react\";\n\n// Extended Admin Client Interface\ninterface AdminClient {\n  id: string;\n  name: string;\n  domain: string;\n  status: \"active\" | \"suspended\" | \"pending\" | \"archived\";\n  tier: \"Sovereign\" | \"Enterprise\" | \"Standard\";\n  createdAt: string;\n  region: string;\n  complianceLevel: string;\n  contactName: string;\n  contactEmail: string;\n  industry: string;\n  accountOwner: string;\n  billingStatus: \"Paid\" | \"Unpaid\" | \"Processing\" | \"Overdue\";\n  healthStatus: \"Healthy\" | \"Warning\" | \"Critical\" | \"Offline\";\n}\n\nexport default function AdminClientsPage() {\n  const router = useRouter();\n\n  // ---------------------------------------------------------------------------\n  // 1. STATE INITIALIZATION\n  // ---------------------------------------------------------------------------\n  const [clients, setClients] = useState<AdminClient[]>([]);\n  const [currentUser, setCurrentUser] = useState<any>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [validationError, setValidationError] = useState<string | null>(null);\n  const [successMessage, setSuccessMessage] = useState<string | null>(null);\n\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [statusFilter, setStatusFilter] = useState(\"\");\n  const [regionFilter, setRegionFilter] = useState(\"\");\n  const [industryFilter, setIndustryFilter] = useState(\"\");\n  const [copiedId, setCopiedId] = useState<string | null>(null);\n\n  // Modals & Drawer State\n  const [selectedClient, setSelectedClient] = useState<AdminClient | null>(null);\n  const [drawerTab, setDrawerTab] = useState<\"overview\" | \"projects\" | \"agents\" | \"billing\">(\"overview\");\n  \n  const [isAddModalOpen, setIsAddModalOpen] = useState(false);\n  const [isEditModalOpen, setIsEditModalOpen] = useState(false);\n  const [editingClient, setEditingClient] = useState<AdminClient | null>(null);\n\n  const [isAssignModalOpen, setIsAssignModalOpen] = useState(false);\n  const [assigningClient, setAssigningClient] = useState<AdminClient | null>(null);\n  \n  // Handshake Connection State\n  const [handshakeClient, setHandshakeClient] = useState<AdminClient | null>(null);\n  const [handshakeStep, setHandshakeStep] = useState(0);\n\n  // Form Fields for Add Client\n  const [newName, setNewName] = useState(\"\");\n  const [newDomain, setNewDomain] = useState(\"\");\n  const [newIndustry, setNewIndustry] = useState(\"Cybersecurity & Defense\");\n  const [newTier, setNewTier] = useState<\"Sovereign\" | \"Enterprise\" | \"Standard\">(\"Sovereign\");\n  const [newRegion, setNewRegion] = useState(\"EU-West (Isolated)\");\n  const [newOwner, setNewOwner] = useState(\"Dr. Sarah Vance\");\n  const [newHealth, setNewHealth] = useState<\"Healthy\" | \"Warning\" | \"Critical\" | \"Offline\">(\"Healthy\");\n  const [newBilling, setNewBilling] = useState<\"Paid\" | \"Unpaid\" | \"Processing\" | \"Overdue\">(\"Paid\");\n  const [newContactName, setNewContactName] = useState(\"\");\n  const [newContactEmail, setNewContactEmail] = useState(\"\");\n\n  // Form Fields for Assign Owner\n  const [assignedOwner, setAssignedOwner] = useState(\"Dr. Sarah Vance\");\n\n  // Fetch from APIs\n  const fetchData = async () => {\n    setLoading(true);\n    setError(null);\n    try {\n      let token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n      \n      // Auto-authenticate if no token\n      if (!token) {\n        const loginRes = await fetch(\"/api/v1/auth/login\", {\n          method: \"POST\",\n          headers: { \"Content-Type\": \"application/json\" },\n          body: JSON.stringify({\n            email: \"s.vance@governance.gff.ai\",\n            password: \"VanceSecure2026!\"\n          })\n        });\n        if (loginRes.ok) {\n          const authData = await loginRes.json();\n          if (authData.success && authData.accessToken) {\n            token = authData.accessToken;\n            if (typeof window !== \"undefined\" && token) {\n              localStorage.setItem(\"gff_ai_access_token\", token);\n              localStorage.setItem(\"gff_api_token\", token);\n            }\n          }\n        }\n      }\n\n      if (!token) {\n        throw new Error(\"Unable to establish secure identity token. Please login again.\");\n      }\n\n      // Fetch Me\n      const meRes = await fetch(\"/api/v1/auth/me\", {\n        headers: { \"Authorization\": `Bearer ${token}` }\n      });\n      if (meRes.ok) {\n        const meData = await meRes.json();\n        if (meData.success) {\n          setCurrentUser(meData.user);\n        }\n      }\n\n      // Fetch Clients\n      const clientsRes = await fetch(\"/api/v1/clients\", {\n        headers: { \"Authorization\": `Bearer ${token}` }\n      });\n      \n      if (!clientsRes.ok) {\n        throw new Error(`Failed to load clients: Status ${clientsRes.status}`);\n      }\n\n      const clientsData = await clientsRes.json();\n      if (clientsData.success) {\n        setClients(clientsData.clients);\n      } else {\n        throw new Error(clientsData.message || \"Failed to load clients.\");\n      }\n    } catch (err: any) {\n      console.error(\"Fetch Data Error:\", err);\n      setError(err.message || \"Failed to establish secure enclave bridge.\");\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchData();\n  }, []);\n\n  // ---------------------------------------------------------------------------\n  // 2. HELPERS AND ACTIONS\n  // ---------------------------------------------------------------------------\n  const handleInitiateHandshake = (client: AdminClient, e?: React.MouseEvent) => {\n    if (e) e.stopPropagation();\n    setHandshakeClient(client);\n    setHandshakeStep(1);\n  };\n\n  useEffect(() => {\n    if (handshakeStep > 0 && handshakeStep < 4) {\n      const timer = setTimeout(() => {\n        setHandshakeStep(prev => prev + 1);\n      }, 900);\n      return () => clearTimeout(timer);\n    }\n  }, [handshakeStep]);\n\n  const handleCopyId = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    navigator.clipboard.writeText(id);\n    setCopiedId(id);\n    setTimeout(() => setCopiedId(null), 2000);\n  };\n\n  const handleOpenAssignOwner = (client: AdminClient) => {\n    setAssigningClient(client);\n    setAssignedOwner(client.accountOwner);\n    setIsAssignModalOpen(true);\n  };\n\n  const handleSaveAssignOwner = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!assigningClient) return;\n    setValidationError(null);\n\n    try {\n      let token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n      const res = await fetch(`/api/v1/clients/${assigningClient.id}`, {\n        method: \"PATCH\",\n        headers: {\n          \"Authorization\": `Bearer ${token}`,\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify({ accountOwner: assignedOwner })\n      });\n\n      const data = await res.json();\n      if (res.ok && data.success) {\n        setSuccessMessage(`Account owner assigned successfully.`);\n        setIsAssignModalOpen(false);\n        setAssigningClient(null);\n        fetchData();\n      } else {\n        setValidationError(data.message || \"Failed to assign owner.\");\n      }\n    } catch (err: any) {\n      setValidationError(err.message || \"An unexpected error occurred.\");\n    }\n  };\n\n  const handleAddClient = async (e: React.FormEvent) => {\n    e.preventDefault();\n    setValidationError(null);\n    setSuccessMessage(null);\n\n    // Validation\n    if (newName.trim().length < 3) {\n      setValidationError(\"Client Name must be at least 3 characters.\");\n      return;\n    }\n    if (!newDomain.includes(\".\") || newDomain.trim().length < 4) {\n      setValidationError(\"A valid domain name is required (e.g., domain.com).\");\n      return;\n    }\n    if (!newContactEmail.includes(\"@\") || newContactEmail.trim().length < 5) {\n      setValidationError(\"A valid secure business email is required.\");\n      return;\n    }\n\n    try {\n      let token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n      const res = await fetch(\"/api/v1/clients\", {\n        method: \"POST\",\n        headers: {\n          \"Authorization\": `Bearer ${token}`,\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify({\n          name: newName,\n          domain: newDomain,\n          tier: newTier,\n          region: newRegion,\n          industry: newIndustry,\n          accountOwner: newOwner,\n          healthStatus: newHealth,\n          billingStatus: newBilling,\n          contactName: newContactName || \"Enclave Representative\",\n          contactEmail: newContactEmail,\n        })\n      });\n\n      const data = await res.json();\n      if (res.ok && data.success) {\n        setSuccessMessage(`Tenant Enclave \"${newName}\" successfully registered.`);\n        setIsAddModalOpen(false);\n        // Clear fields\n        setNewName(\"\");\n        setNewDomain(\"\");\n        setNewContactName(\"\");\n        setNewContactEmail(\"\");\n        // Refresh\n        fetchData();\n      } else {\n        setValidationError(data.message || \"Failed to register new tenant enclave.\");\n      }\n    } catch (err: any) {\n      setValidationError(err.message || \"An unexpected error occurred.\");\n    }\n  };\n\n  const handleOpenEdit = (client: AdminClient, e: React.MouseEvent) => {\n    e.stopPropagation();\n    setEditingClient({ ...client });\n    setIsEditModalOpen(true);\n  };\n\n  const handleEditClientSubmit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!editingClient) return;\n    setValidationError(null);\n    setSuccessMessage(null);\n\n    if (editingClient.name.trim().length < 3) {\n      setValidationError(\"Client Name must be at least 3 characters.\");\n      return;\n    }\n    if (!editingClient.domain.includes(\".\") || editingClient.domain.trim().length < 4) {\n      setValidationError(\"A valid domain name is required.\");\n      return;\n    }\n\n    try {\n      let token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n      const res = await fetch(`/api/v1/clients/${editingClient.id}`, {\n        method: \"PATCH\",\n        headers: {\n          \"Authorization\": `Bearer ${token}`,\n          \"Content-Type\": \"application/json\"\n        },\n        body: JSON.stringify(editingClient)\n      });\n\n      const data = await res.json();\n      if (res.ok && data.success) {\n        setSuccessMessage(`Tenant \"${editingClient.name}\" configurations successfully updated.`);\n        setIsEditModalOpen(false);\n        setEditingClient(null);\n        if (selectedClient?.id === editingClient.id) {\n          setSelectedClient(data.client);\n        }\n        fetchData();\n      } else {\n        setValidationError(data.message || \"Failed to update tenant configurations.\");\n      }\n    } catch (err: any) {\n      setValidationError(err.message || \"An unexpected error occurred.\");\n    }\n  };\n\n  const handleArchiveClient = async (clientId: string, clientName: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    if (!confirm(`Are you sure you want to suspend/archive the enclave for \"${clientName}\"?`)) return;\n    \n    setLoading(true);\n    setError(null);\n    try {\n      let token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n      const res = await fetch(`/api/v1/clients/${clientId}`, {\n        method: \"DELETE\",\n        headers: {\n          \"Authorization\": `Bearer ${token}`\n        }\n      });\n\n      const data = await res.json();\n      if (res.ok && data.success) {\n        setSuccessMessage(`Enclave \"${clientName}\" has been successfully suspended.`);\n        setSelectedClient(null);\n        fetchData();\n      } else {\n        setError(data.message || \"Failed to archive/suspend tenant enclave.\");\n        setLoading(false);\n      }\n    } catch (err: any) {\n      setError(err.message || \"An unexpected error occurred.\");\n      setLoading(false);\n    }\n  };\n\n  // Get project data for deep drawer\n  const getProjectsForClient = (id: string) => {\n    return previewProjects.filter(p => p.clientAccountId === id);\n  };\n\n  const getAgentsForProjects = (projectIds: string[]) => {\n    return previewAgentOperations.filter(a => projectIds.includes(a.projectId));\n  };\n\n  // ---------------------------------------------------------------------------\n  // 3. STATS COMPUTATIONS\n  // ---------------------------------------------------------------------------\n  const totalEnclaves = clients.length;\n  const healthyCount = clients.filter(c => c.healthStatus === \"Healthy\").length;\n  const totalProjects = clients.reduce((acc, c) => acc + getProjectsForClient(c.id).length, 0);\n  const totalAgents = clients.reduce((acc, c) => {\n    const pIds = getProjectsForClient(c.id).map(p => p.id);\n    return acc + getAgentsForProjects(pIds).length;\n  }, 0);\n\n  // ---------------------------------------------------------------------------\n  // 4. FILTERING LOGIC\n  // ---------------------------------------------------------------------------\n  const filteredClients = clients.filter(c => {\n    const matchesSearch = \n      c.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      c.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      c.domain.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      c.region.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      c.industry.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      c.accountOwner.toLowerCase().includes(searchQuery.toLowerCase());\n\n    const matchesStatus = statusFilter === \"\" || c.status === statusFilter;\n    const matchesRegion = regionFilter === \"\" || c.region === regionFilter;\n    const matchesIndustry = industryFilter === \"\" || c.industry === industryFilter;\n\n    return matchesSearch && matchesStatus && matchesRegion && matchesIndustry;\n  });\n\n  // Unique lists for filtering dropdowns\n  const uniqueRegions = Array.from(new Set(clients.map(c => c.region)));\n  const uniqueIndustries = Array.from(new Set(clients.map(c => c.industry)));\n\n  // Badge functions\n  const getStatusBadge = (status: AdminClient[\"status\"]) => {\n    const styles = {\n      active: \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\",\n      suspended: \"bg-rose-500/10 text-rose-400 border-rose-500/20\",\n      pending: \"bg-amber-500/10 text-amber-400 border-amber-500/20\",\n      archived: \"bg-zinc-500/10 text-zinc-400 border-zinc-500/20\"\n    };\n    return (\n      <span className={`inline-flex items-center gap-1 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[status] || styles.active}`}>\n        <span className={`h-1.5 w-1.5 rounded-full ${status === \"active\" ? \"bg-emerald-400 animate-pulse\" : status === \"pending\" ? \"bg-amber-400\" : \"bg-rose-500\"}`} />\n        {status}\n      </span>\n    );\n  };\n\n  const getHealthBadge = (health: AdminClient[\"healthStatus\"]) => {\n    const styles = {\n      Healthy: \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\",\n      Warning: \"bg-amber-500/10 text-amber-400 border-amber-500/20\",\n      Critical: \"bg-red-500/10 text-red-400 border-red-500/20\",\n      Offline: \"bg-white/5 text-white/40 border-white/10\"\n    };\n    return (\n      <span className={`inline-flex items-center gap-1.5 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[health] || styles.Healthy}`}>\n        <span className={`h-1.5 w-1.5 rounded-full ${health === \"Healthy\" ? \"bg-emerald-400 animate-pulse\" : health === \"Warning\" ? \"bg-amber-400 animate-pulse\" : health === \"Critical\" ? \"bg-red-500\" : \"bg-white/30\"}`} />\n        {health}\n      </span>\n    );\n  };\n\n  const getBillingBadge = (billing: AdminClient[\"billingStatus\"]) => {\n    const styles = {\n      Paid: \"bg-blue-500/10 text-blue-400 border-blue-500/20\",\n      Unpaid: \"bg-red-500/10 text-red-400 border-red-500/20\",\n      Processing: \"bg-purple-500/10 text-purple-400 border-purple-500/20\",\n      Overdue: \"bg-amber-500/10 text-amber-400 border-amber-500/20\"\n    };\n    return (\n      <span className={`inline-flex items-center gap-1 rounded px-2 py-0.5 text-[10px] font-mono font-bold uppercase border ${styles[billing] || styles.Paid}`}>\n        {billing}\n      </span>\n    );\n  };\n\n  const getTierBadge = (tier: ClientAccount[\"tier\"]) => {\n    const styles = {\n      Sovereign: \"bg-amber-400/10 text-amber-300 border-amber-400/25\",\n      Enterprise: \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/25\",\n      Standard: \"bg-white/5 text-white/60 border-white/15\"\n    };\n    return (\n      <span className={`inline-flex items-center rounded px-1.5 py-0.5 text-[9px] font-mono font-bold uppercase border ${styles[tier] || styles.Standard}`}>\n        {tier}\n      </span>\n    );\n  };\n\n  // Enforce role authorization\n  const isPlatformAdmin = currentUser?.role === \"gff_admin\";\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* HEADER */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Sovereign Tenant Registry</h2>\n          <p className=\"text-xs text-white/50 mt-1 font-mono\">\n            Cryptographic tenant authorization, sandbox telemetry supervision, and continuous alignment verification.\n          </p>\n          {!isPlatformAdmin && currentUser && (\n            <div className=\"mt-2 text-[10px] text-amber-400/80 font-mono bg-amber-500/5 px-2.5 py-1 rounded border border-amber-500/10 inline-block\">\n              ⚠️ READ-ONLY OPERATOR: Your account role ({currentUser.role}) does not possess enclave provisioning clearance.\n            </div>\n          )}\n        </div>\n        <button \n          onClick={() => {\n            if (!isPlatformAdmin) {\n              alert(\"Unauthorized: Only platform administrators can register new enclaves.\");\n              return;\n            }\n            setIsAddModalOpen(true);\n          }}\n          disabled={!isPlatformAdmin}\n          className={`h-10 px-4 rounded-lg font-mono text-xs font-bold transition-all flex items-center justify-center gap-2 shadow-lg ${\n            isPlatformAdmin \n              ? \"bg-emerald-500/10 hover:bg-emerald-500/20 border border-emerald-500/35 hover:border-emerald-500/50 text-emerald-400 hover:shadow-[0_0_25px_rgba(16,185,129,0.15)] cursor-pointer\"\n              : \"bg-zinc-800/20 border border-zinc-700/30 text-zinc-500 cursor-not-allowed\"\n          }`}\n        >\n          <Plus className=\"w-4 h-4\" />\n          <span>PROVISION TENANT ACCOUNT</span>\n        </button>\n      </div>\n\n      {/* OVERVIEW METRICS DECK */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        \n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n          <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Managed Enclaves</span>\n          <div className=\"text-2xl font-bold text-white font-mono flex items-baseline gap-2\">\n            <span>{loading ? \"...\" : totalEnclaves}</span>\n            {!loading && <span className=\"text-[10px] text-emerald-400 font-semibold font-mono\">+1 configured</span>}\n          </div>\n          <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">ISO-27001-A.9 Tenant isolation</div>\n        </div>\n\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n          <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Health Level SLA</span>\n          <div className=\"text-2xl font-bold text-emerald-400 font-mono flex items-baseline gap-2\">\n            <span>{loading ? \"...\" : (totalEnclaves > 0 ? ((healthyCount / totalEnclaves) * 100).toFixed(0) : \"0\")}%</span>\n            <span className=\"text-[10px] text-emerald-400/70 font-mono\">operational</span>\n          </div>\n          <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">{healthyCount} healthy tenants</div>\n        </div>\n\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n          <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Sandbox Layers</span>\n          <div className=\"text-2xl font-bold text-white font-mono flex items-baseline gap-2\">\n            <span>{loading ? \"...\" : totalProjects}</span>\n            <span className=\"text-[10px] text-white/40 font-mono\">active grids</span>\n          </div>\n          <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">{totalAgents} workloads monitored</div>\n        </div>\n\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 font-mono space-y-1\">\n          <span className=\"text-[10px] text-white/40 uppercase tracking-widest block font-bold\">Attestation Spends</span>\n          <div className=\"text-2xl font-bold text-blue-400 font-mono flex items-baseline gap-2\">\n            <span>812K</span>\n            <span className=\"text-[10px] text-white/40 font-mono\">Epoch credits</span>\n          </div>\n          <div className=\"text-[10px] text-white/30 pt-1 border-t border-white/[0.03]\">Continuous billing telemetry</div>\n        </div>\n\n      </div>\n\n      {/* SUCCESS / ERROR NOTIFICATIONS */}\n      {successMessage && (\n        <div className=\"p-4 bg-emerald-500/5 border border-emerald-500/20 text-emerald-400 rounded-xl font-mono text-xs flex items-center justify-between\">\n          <div className=\"flex items-center gap-2\">\n            <CheckCircle2 className=\"w-4 h-4 shrink-0\" />\n            <span>{successMessage}</span>\n          </div>\n          <button onClick={() => setSuccessMessage(null)} className=\"text-emerald-400/60 hover:text-emerald-400\">\n            <X className=\"w-4 h-4\" />\n          </button>\n        </div>\n      )}\n\n      {/* FILTER & CONTROL PANEL */}\n      <div className=\"rounded-xl border border-white/5 bg-[#030303]/40 p-4 space-y-3\">\n        <div className=\"flex flex-col md:flex-row gap-3\">\n          \n          {/* Search */}\n          <div className=\"relative flex-1\">\n            <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n            <input \n              type=\"text\" \n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder=\"Filter sovereign registry by name, ID, domain, region, industry, or owner...\"\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n            />\n            {searchQuery && (\n              <button \n                onClick={() => setSearchQuery(\"\")}\n                className=\"absolute right-3 top-2.5 text-white/30 hover:text-white\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            )}\n          </div>\n\n          {/* Region Filter */}\n          <select\n            value={regionFilter}\n            onChange={(e) => setRegionFilter(e.target.value)}\n            className=\"h-9 px-3 rounded-lg border border-white/5 bg-[#030303] text-[11px] font-mono text-white outline-none focus:border-white/15 cursor-pointer\"\n          >\n            <option value=\"\">All Regions</option>\n            {uniqueRegions.map(region => (\n              <option key={region} value={region}>{region}</option>\n            ))}\n          </select>\n\n          {/* Industry Filter */}\n          <select\n            value={industryFilter}\n            onChange={(e) => setIndustryFilter(e.target.value)}\n            className=\"h-9 px-3 rounded-lg border border-white/5 bg-[#030303] text-[11px] font-mono text-white outline-none focus:border-white/15 cursor-pointer\"\n          >\n            <option value=\"\">All Industries</option>\n            {uniqueIndustries.map(industry => (\n              <option key={industry} value={industry}>{industry}</option>\n            ))}\n          </select>\n\n          {/* Status Filter */}\n          <select\n            value={statusFilter}\n            onChange={(e) => setStatusFilter(e.target.value)}\n            className=\"h-9 px-3 rounded-lg border border-white/5 bg-[#030303] text-[11px] font-mono text-white outline-none focus:border-white/15 cursor-pointer\"\n          >\n            <option value=\"\">All Statuses</option>\n            <option value=\"active\">Active</option>\n            <option value=\"suspended\">Suspended</option>\n            <option value=\"pending\">Pending</option>\n          </select>\n\n          <button \n            onClick={() => {\n              setSearchQuery(\"\");\n              setStatusFilter(\"\");\n              setRegionFilter(\"\");\n              setIndustryFilter(\"\");\n              fetchData();\n            }}\n            className=\"h-9 px-3 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.01] text-[11px] font-mono font-bold uppercase text-white transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n            title=\"Refresh Ledger\"\n          >\n            <RefreshCw className=\"w-3.5 h-3.5\" />\n            <span>SYNC</span>\n          </button>\n        </div>\n      </div>\n\n      {/* CORE DATA VIEWER */}\n      {loading ? (\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-12 text-center space-y-4\">\n          <RefreshCw className=\"w-8 h-8 text-[#009DFF] animate-spin mx-auto\" />\n          <p className=\"text-xs text-white/50 font-mono\">Syncing sovereign cryptographic client registries...</p>\n        </div>\n      ) : error ? (\n        <div className=\"rounded-xl border border-red-500/10 bg-red-500/5 p-8 text-center space-y-4\">\n          <AlertTriangle className=\"w-10 h-10 text-red-400 mx-auto\" />\n          <div className=\"space-y-1\">\n            <p className=\"text-sm font-mono font-bold text-white uppercase\">Cryptographic Sync Broken</p>\n            <p className=\"text-xs font-mono text-white/50 max-w-md mx-auto\">{error}</p>\n          </div>\n          <button \n            onClick={fetchData}\n            className=\"h-9 px-4 rounded bg-red-500/20 hover:bg-red-500/30 text-red-400 border border-red-500/30 text-xs font-mono font-bold uppercase transition-all\"\n          >\n            Retry Secure Wire Connection\n          </button>\n        </div>\n      ) : filteredClients.length === 0 ? (\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-12 text-center space-y-2\">\n          <Building className=\"w-10 h-10 text-white/20 mx-auto\" />\n          <p className=\"text-sm font-bold text-white uppercase font-mono\">No Enclave Registries Found</p>\n          <p className=\"text-xs text-white/45 font-mono max-w-sm mx-auto\">\n            No sovereign clients matched the filter constraints. Clear queries to reload global registries.\n          </p>\n        </div>\n      ) : (\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 overflow-hidden\">\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full text-left border-collapse font-mono text-[11.5px]\" role=\"grid\">\n              <thead>\n                <tr className=\"border-b border-white/5 bg-white/[0.01]\" role=\"row\">\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px]\">Partition ID & Domain</th>\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px]\">Enclave Tenant Name</th>\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px]\">Health & Billing</th>\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px]\">Compliance Standard</th>\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px]\">Tier</th>\n                  <th className=\"p-3 text-white/35 font-bold uppercase text-[10px] text-right\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/5\">\n                {filteredClients.map((client) => {\n                  const clientProjects = getProjectsForClient(client.id);\n                  const isSuspended = client.status === \"suspended\";\n\n                  return (\n                    <tr \n                      key={client.id}\n                      onClick={() => {\n                        setSelectedClient(client);\n                        setDrawerTab(\"overview\");\n                      }}\n                      className={`hover:bg-white/[0.02] active:bg-white/[0.04] transition-colors cursor-pointer ${isSuspended ? \"opacity-50\" : \"\"}`}\n                      role=\"row\"\n                    >\n                      {/* ID & Domain */}\n                      <td className=\"p-3\">\n                        <div className=\"font-bold text-white flex items-center gap-1.5\">\n                          <span className=\"text-[#009DFF]\">{client.id}</span>\n                          <button \n                            onClick={(e) => handleCopyId(client.id, e)}\n                            className=\"p-1 rounded text-white/30 hover:text-white hover:bg-white/5 transition-all\"\n                            title=\"Copy ID\"\n                          >\n                            {copiedId === client.id ? <Check className=\"w-3 h-3 text-emerald-400\" /> : <Copy className=\"w-3 h-3\" />}\n                          </button>\n                        </div>\n                        <div className=\"text-[10px] text-white/45 flex items-center gap-1 mt-0.5\">\n                          <Globe className=\"w-3 h-3\" />\n                          <span>{client.domain}</span>\n                        </div>\n                      </td>\n\n                      {/* Name & Owner */}\n                      <td className=\"p-3\">\n                        <div className=\"text-white font-bold leading-tight flex items-center gap-2\">\n                          <Building className=\"w-3.5 h-3.5 text-zinc-400 shrink-0\" />\n                          <span className=\"truncate max-w-[200px]\">{client.name}</span>\n                        </div>\n                        <div className=\"text-[9.5px] text-white/45 flex items-center gap-1 mt-0.5\">\n                          <User className=\"w-3 h-3 text-[#009DFF]\" />\n                          <span>Owner: {client.accountOwner}</span>\n                        </div>\n                      </td>\n\n                      {/* Health & Billing */}\n                      <td className=\"p-3 space-y-1\">\n                        <div className=\"flex gap-1.5 items-center\">\n                          {getHealthBadge(client.healthStatus)}\n                          {getStatusBadge(client.status)}\n                        </div>\n                        <div>\n                          {getBillingBadge(client.billingStatus)}\n                        </div>\n                      </td>\n\n                      {/* Compliance */}\n                      <td className=\"p-3\">\n                        <span className=\"text-xs font-semibold text-[#00FFC2] block\">{client.complianceLevel}</span>\n                        <span className=\"text-[9px] text-white/35 font-mono\">{client.region}</span>\n                      </td>\n\n                      {/* Tier */}\n                      <td className=\"p-3\">\n                        {getTierBadge(client.tier)}\n                      </td>\n\n                      {/* Actions */}\n                      <td className=\"p-3 text-right\">\n                        <div className=\"flex items-center justify-end gap-1.5\" onClick={(e) => e.stopPropagation()}>\n                          <button\n                            onClick={() => handleInitiateHandshake(client)}\n                            className=\"p-1 rounded hover:bg-white/5 text-amber-400 hover:text-amber-300 transition-colors cursor-pointer\"\n                            title=\"Diagnostics Handshake\"\n                          >\n                            <RefreshCw className=\"w-3.5 h-3.5\" />\n                          </button>\n                          \n                          {isPlatformAdmin && (\n                            <>\n                              <button\n                                onClick={(e) => handleOpenEdit(client, e)}\n                                className=\"p-1 rounded hover:bg-white/5 text-emerald-400 hover:text-emerald-300 transition-colors cursor-pointer\"\n                                title=\"Edit Configuration\"\n                              >\n                                <Edit className=\"w-3.5 h-3.5\" />\n                              </button>\n                              <button\n                                onClick={() => handleOpenAssignOwner(client)}\n                                className=\"p-1 rounded hover:bg-white/5 text-[#009DFF] hover:text-[#009DFF]/80 transition-colors cursor-pointer\"\n                                title=\"Assign Owner\"\n                              >\n                                <User className=\"w-3.5 h-3.5\" />\n                              </button>\n                              <button\n                                onClick={(e) => handleArchiveClient(client.id, client.name, e)}\n                                className=\"p-1 rounded hover:bg-white/5 text-rose-500 hover:text-rose-400 transition-colors cursor-pointer\"\n                                title=\"Archive/Suspend Enclave\"\n                              >\n                                <X className=\"w-3.5 h-3.5\" />\n                              </button>\n                            </>\n                          )}\n                          \n                          <button\n                            onClick={() => {\n                              setSelectedClient(client);\n                              setDrawerTab(\"overview\");\n                            }}\n                            className=\"p-1 rounded hover:bg-white/5 text-white/40 hover:text-white transition-colors cursor-pointer\"\n                            title=\"Open Telemetry Drawer\"\n                          >\n                            <ChevronRight className=\"w-4 h-4\" />\n                          </button>\n                        </div>\n                      </td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* -----------------------------------------------------------------------\n          MODAL: ADD NEW ENCLAVE CLIENT\n          ----------------------------------------------------------------------- */}\n      {isAddModalOpen && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-sm p-4\">\n          <div className=\"w-full max-w-lg bg-[#09090b] border border-white/10 rounded-xl overflow-hidden shadow-2xl\">\n            <div className=\"p-4 border-b border-white/10 bg-[#0c0c0e] flex items-center justify-between\">\n              <span className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">\n                Provision Sovereign Tenant Enclave\n              </span>\n              <button onClick={() => setIsAddModalOpen(false)} className=\"text-white/40 hover:text-white cursor-pointer\">\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleAddClient} className=\"p-6 space-y-4 font-mono text-xs text-white\">\n              {validationError && (\n                <div className=\"p-3 rounded bg-red-500/10 border border-red-500/25 text-red-400 font-mono text-[11px]\">\n                  {validationError}\n                </div>\n              )}\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Client / Organization Name</label>\n                <input \n                  type=\"text\" \n                  value={newName}\n                  onChange={(e) => setNewName(e.target.value)}\n                  placeholder=\"e.g. Lockheed Space Enclave\"\n                  className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Sovereign Domain Endpoint</label>\n                <input \n                  type=\"text\" \n                  value={newDomain}\n                  onChange={(e) => setNewDomain(e.target.value)}\n                  placeholder=\"e.g. space.lockheed.ai\"\n                  className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                  required\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Enclave Tier</label>\n                  <select \n                    value={newTier}\n                    onChange={(e) => setNewTier(e.target.value as any)}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10 focus:border-[#009DFF]/50 outline-none cursor-pointer\"\n                  >\n                    <option value=\"Sovereign\">Sovereign</option>\n                    <option value=\"Enterprise\">Enterprise</option>\n                    <option value=\"Standard\">Standard</option>\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Enclave Isolation Region</label>\n                  <select \n                    value={newRegion}\n                    onChange={(e) => setNewRegion(e.target.value)}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10 focus:border-[#009DFF]/50 outline-none cursor-pointer\"\n                  >\n                    <option value=\"EU-West (Isolated)\">EU-West (Isolated)</option>\n                    <option value=\"US-East (Dedicated)\">US-East (Dedicated)</option>\n                    <option value=\"US-GovWest (Airgapped)\">US-GovWest (Airgapped)</option>\n                    <option value=\"APAC-South (Shared)\">APAC-South (Shared)</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Primary Tenant Administrator</label>\n                  <input \n                    type=\"text\" \n                    value={newContactName}\n                    onChange={(e) => setNewContactName(e.target.value)}\n                    placeholder=\"e.g. Commander Robert\"\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                    required\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Secure Admin Email</label>\n                  <input \n                    type=\"email\" \n                    value={newContactEmail}\n                    onChange={(e) => setNewContactEmail(e.target.value)}\n                    placeholder=\"e.g. robert@lockheed.ai\"\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                    required\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Operational Industry</label>\n                  <input \n                    type=\"text\" \n                    value={newIndustry}\n                    onChange={(e) => setNewIndustry(e.target.value)}\n                    placeholder=\"e.g. Defense & Aero\"\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Platform Account Owner</label>\n                  <input \n                    type=\"text\" \n                    value={newOwner}\n                    onChange={(e) => setNewOwner(e.target.value)}\n                    placeholder=\"Dr. Sarah Vance\"\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none transition-all\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Initial Health</label>\n                  <select \n                    value={newHealth}\n                    onChange={(e) => setNewHealth(e.target.value as any)}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10 focus:border-[#009DFF]/50 outline-none cursor-pointer\"\n                  >\n                    <option value=\"Healthy\">Healthy</option>\n                    <option value=\"Warning\">Warning</option>\n                    <option value=\"Critical\">Critical</option>\n                    <option value=\"Offline\">Offline</option>\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Billing Ledger Status</label>\n                  <select \n                    value={newBilling}\n                    onChange={(e) => setNewBilling(e.target.value as any)}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10 focus:border-[#009DFF]/50 outline-none cursor-pointer\"\n                  >\n                    <option value=\"Paid\">Paid</option>\n                    <option value=\"Unpaid\">Unpaid</option>\n                    <option value=\"Processing\">Processing</option>\n                    <option value=\"Overdue\">Overdue</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"flex justify-end gap-3 pt-4 border-t border-white/10\">\n                <button \n                  type=\"button\" \n                  onClick={() => setIsAddModalOpen(false)}\n                  className=\"px-4 py-2 bg-white/5 hover:bg-white/10 text-white rounded cursor-pointer border border-white/10\"\n                >\n                  Cancel\n                </button>\n                <button \n                  type=\"submit\"\n                  className=\"px-4 py-2 bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 rounded cursor-pointer\"\n                >\n                  Confirm Provision Key\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* -----------------------------------------------------------------------\n          MODAL: EDIT CLIENT CONFIGURATION\n          ----------------------------------------------------------------------- */}\n      {isEditModalOpen && editingClient && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-sm p-4\">\n          <div className=\"w-full max-w-lg bg-[#09090b] border border-white/10 rounded-xl overflow-hidden shadow-2xl\">\n            <div className=\"p-4 border-b border-white/10 bg-[#0c0c0e] flex items-center justify-between\">\n              <span className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">\n                Edit Enclave Tenant Configurations ({editingClient.id})\n              </span>\n              <button onClick={() => setIsEditModalOpen(false)} className=\"text-white/40 hover:text-white cursor-pointer\">\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n\n            <form onSubmit={handleEditClientSubmit} className=\"p-6 space-y-4 font-mono text-xs text-white\">\n              {validationError && (\n                <div className=\"p-3 rounded bg-red-500/10 border border-red-500/25 text-red-400 font-mono text-[11px]\">\n                  {validationError}\n                </div>\n              )}\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Client Name</label>\n                <input \n                  type=\"text\" \n                  value={editingClient.name}\n                  onChange={(e) => setEditingClient({ ...editingClient, name: e.target.value })}\n                  className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  required\n                />\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Domain Endpoint</label>\n                <input \n                  type=\"text\" \n                  value={editingClient.domain}\n                  onChange={(e) => setEditingClient({ ...editingClient, domain: e.target.value })}\n                  className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  required\n                />\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Enclave Tier</label>\n                  <select \n                    value={editingClient.tier}\n                    onChange={(e) => setEditingClient({ ...editingClient, tier: e.target.value as any })}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10 focus:border-[#009DFF]/50 outline-none\"\n                  >\n                    <option value=\"Sovereign\">Sovereign</option>\n                    <option value=\"Enterprise\">Enterprise</option>\n                    <option value=\"Standard\">Standard</option>\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Region</label>\n                  <input \n                    type=\"text\" \n                    value={editingClient.region}\n                    onChange={(e) => setEditingClient({ ...editingClient, region: e.target.value })}\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Tenant Admin Name</label>\n                  <input \n                    type=\"text\" \n                    value={editingClient.contactName}\n                    onChange={(e) => setEditingClient({ ...editingClient, contactName: e.target.value })}\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  />\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Tenant Admin Email</label>\n                  <input \n                    type=\"email\" \n                    value={editingClient.contactEmail}\n                    onChange={(e) => setEditingClient({ ...editingClient, contactEmail: e.target.value })}\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Health Status</label>\n                  <select \n                    value={editingClient.healthStatus}\n                    onChange={(e) => setEditingClient({ ...editingClient, healthStatus: e.target.value as any })}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10\"\n                  >\n                    <option value=\"Healthy\">Healthy</option>\n                    <option value=\"Warning\">Warning</option>\n                    <option value=\"Critical\">Critical</option>\n                    <option value=\"Offline\">Offline</option>\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Billing Status</label>\n                  <select \n                    value={editingClient.billingStatus}\n                    onChange={(e) => setEditingClient({ ...editingClient, billingStatus: e.target.value as any })}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10\"\n                  >\n                    <option value=\"Paid\">Paid</option>\n                    <option value=\"Unpaid\">Unpaid</option>\n                    <option value=\"Processing\">Processing</option>\n                    <option value=\"Overdue\">Overdue</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-2 gap-4\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Status</label>\n                  <select \n                    value={editingClient.status}\n                    onChange={(e) => setEditingClient({ ...editingClient, status: e.target.value as any })}\n                    className=\"w-full h-9 px-2 bg-black border border-white/10\"\n                  >\n                    <option value=\"active\">Active</option>\n                    <option value=\"suspended\">Suspended</option>\n                    <option value=\"pending\">Pending</option>\n                  </select>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Compliance Standard</label>\n                  <input \n                    type=\"text\" \n                    value={editingClient.complianceLevel}\n                    onChange={(e) => setEditingClient({ ...editingClient, complianceLevel: e.target.value })}\n                    className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-white focus:border-[#009DFF]/50 outline-none\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"flex justify-end gap-3 pt-4 border-t border-white/10\">\n                <button \n                  type=\"button\" \n                  onClick={() => setIsEditModalOpen(false)}\n                  className=\"px-4 py-2 bg-white/5 hover:bg-white/10 text-white rounded cursor-pointer border border-white/10\"\n                >\n                  Cancel\n                </button>\n                <button \n                  type=\"submit\"\n                  className=\"px-4 py-2 bg-[#009DFF] hover:bg-[#0082d4] text-white rounded cursor-pointer border border-none\"\n                >\n                  Save Changes\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* -----------------------------------------------------------------------\n          MODAL: ASSIGN OWNER\n          ----------------------------------------------------------------------- */}\n      {isAssignModalOpen && assigningClient && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4\">\n          <div className=\"w-full max-w-sm bg-[#09090b] border border-white/10 rounded-xl overflow-hidden shadow-2xl font-mono text-xs\">\n            <div className=\"p-4 border-b border-white/10 bg-[#0c0c0e] flex items-center justify-between\">\n              <span className=\"text-[11px] font-bold text-white uppercase tracking-wider\">\n                Assign Enclave Account Owner\n              </span>\n              <button onClick={() => setIsAssignModalOpen(false)} className=\"text-white/40 hover:text-white cursor-pointer\">\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            \n            <form onSubmit={handleSaveAssignOwner} className=\"p-5 space-y-4 text-white\">\n              <div className=\"space-y-1\">\n                <p className=\"text-white/40 text-[9px] uppercase font-bold\">TARGET PARTITION</p>\n                <p className=\"text-xs font-bold text-white bg-white/5 p-2 rounded border border-white/5\">\n                  {assigningClient.name} ({assigningClient.id})\n                </p>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"text-white/45 text-[10px] uppercase font-bold block\">Assigned Platform Owner</label>\n                <select\n                  value={assignedOwner}\n                  onChange={(e) => setAssignedOwner(e.target.value)}\n                  className=\"w-full h-9 px-2 bg-black border border-white/10 text-xs focus:border-[#009DFF]/50 outline-none cursor-pointer\"\n                >\n                  <option value=\"Dr. Sarah Vance\">Dr. Sarah Vance (Global Admin)</option>\n                  <option value=\"Alexander Mercer\">Alexander Mercer (Apex Specialist)</option>\n                  <option value=\"Evelyn Carter\">Evelyn Carter (Retail Specialist)</option>\n                  <option value=\"Sarah Jenkins\">Sarah Jenkins (Treasury Lead)</option>\n                  <option value=\"Marcus Vance\">Marcus Vance (Logistics Lead)</option>\n                </select>\n              </div>\n\n              <div className=\"flex justify-end gap-2.5 pt-3 border-t border-white/5\">\n                <button \n                  type=\"button\"\n                  onClick={() => setIsAssignModalOpen(false)}\n                  className=\"h-8 px-3 rounded bg-white/5 hover:bg-white/10 text-white border border-white/10 text-[10px] font-bold uppercase cursor-pointer\"\n                >\n                  Cancel\n                </button>\n                <button \n                  type=\"submit\"\n                  className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] text-white text-[10px] font-bold uppercase cursor-pointer\"\n                >\n                  Save Owner Binding\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* -----------------------------------------------------------------------\n          DRAWER: ENCLAVE TELEMETRY DRAWER\n          ----------------------------------------------------------------------- */}\n      {selectedClient && (\n        <div className=\"fixed inset-y-0 right-0 z-50 w-full max-w-lg bg-[#070709] border-l border-white/10 shadow-2xl flex flex-col justify-between\">\n          <div className=\"flex-1 overflow-y-auto\">\n            {/* Drawer Header */}\n            <div className=\"p-5 border-b border-white/10 bg-[#0a0a0d] flex items-center justify-between\">\n              <div className=\"flex items-center gap-2.5\">\n                <div className=\"w-8 h-8 rounded-lg bg-[#009DFF]/10 border border-[#009DFF]/25 flex items-center justify-center\">\n                  <Shield className=\"w-4 h-4 text-[#009DFF]\" />\n                </div>\n                <div>\n                  <h3 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">\n                    Sovereign Client Telemetry\n                  </h3>\n                  <p className=\"text-[10px] text-white/40 font-mono mt-0.5\">\n                    {selectedClient.id} • Secure Sandbox Boundary\n                  </p>\n                </div>\n              </div>\n              <button \n                onClick={() => setSelectedClient(null)}\n                className=\"text-white/40 hover:text-white p-1 rounded hover:bg-white/5 transition-all cursor-pointer\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            {/* Navigation Tabs */}\n            <div className=\"px-5 border-b border-white/5 bg-[#09090c] flex gap-4 text-[10.5px] font-mono select-none\">\n              {([\"overview\", \"projects\", \"agents\", \"billing\"] as const).map(tab => (\n                <button\n                  key={tab}\n                  onClick={() => setDrawerTab(tab)}\n                  className={`py-3 font-bold uppercase transition-all border-b-2 relative -bottom-[1px] cursor-pointer ${\n                    drawerTab === tab \n                      ? \"text-[#009DFF] border-[#009DFF]\" \n                      : \"text-white/40 border-transparent hover:text-white/70\"\n                  }`}\n                >\n                  {tab}\n                </button>\n              ))}\n            </div>\n\n            {/* Tab Contents */}\n            <div className=\"p-5 font-mono text-xs text-white/90 space-y-5\">\n              \n              {/* TAB 1: OVERVIEW */}\n              {drawerTab === \"overview\" && (\n                <div className=\"space-y-4 animate-fadeIn\">\n                  \n                  {/* General Profile card */}\n                  <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n                    <div className=\"text-white/30 text-[9.5px] uppercase font-bold border-b border-white/5 pb-1 select-none\">\n                      Enclave Tenant Overview\n                    </div>\n                    <div className=\"grid grid-cols-2 gap-y-3 gap-x-4\">\n                      <div>\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Company Name</span>\n                        <span className=\"text-white font-semibold\">{selectedClient.name}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Assigned Owner</span>\n                        <span className=\"text-white font-semibold\">{selectedClient.accountOwner}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Enclave Tier</span>\n                        <span className=\"text-amber-300 font-bold\">{selectedClient.tier.toUpperCase()}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Mapped Enclave Region</span>\n                        <span className=\"text-white\">{selectedClient.region}</span>\n                      </div>\n                      <div>\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Created Epoch</span>\n                        <span className=\"text-white\">{new Date(selectedClient.createdAt).toLocaleDateString()}</span>\n                      </div>\n                      <div className=\"col-span-2\">\n                        <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Active Compliance Standard</span>\n                        <span className=\"text-[#00FFC2] font-semibold\">{selectedClient.complianceLevel}</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Primary Contact */}\n                  <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n                    <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold border-b border-white/5 pb-1\">\n                      <User className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                      <span>Tenant Enclave Admin</span>\n                    </div>\n                    <div className=\"space-y-1\">\n                      <div className=\"text-white font-bold\">{selectedClient.contactName}</div>\n                      <div className=\"text-white/50 text-[10.5px]\">{selectedClient.contactEmail}</div>\n                    </div>\n                  </div>\n\n                  {/* Cryptographic Attestation Block */}\n                  <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-2\">\n                    <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold\">\n                      <Lock className=\"w-3.5 h-3.5 text-amber-500\" />\n                      <span>PKI Root Attestation Seal</span>\n                    </div>\n                    <p className=\"text-[10px] text-white/50 leading-relaxed\">\n                      Sovereign partition cryptographic handshake bound to Hardware Security Module (HSM).\n                    </p>\n                    <div className=\"p-2.5 rounded bg-[#020202] border border-white/5 flex items-center justify-between text-[9.5px] font-mono text-[#009DFF] select-text\">\n                      <span className=\"truncate\">0xSHA256_{selectedClient.id.toUpperCase()}_ROOT_CERTIFICATE_SEAL_V26</span>\n                      <CheckCircle2 className=\"w-4 h-4 text-[#00FFC2] shrink-0\" />\n                    </div>\n                  </div>\n\n                </div>\n              )}\n\n              {/* TAB 2: PROJECTS */}\n              {drawerTab === \"projects\" && (\n                <div className=\"space-y-4\">\n                  <div className=\"flex items-center justify-between text-white/40 text-[10px] uppercase font-bold border-b border-white/5 pb-1\">\n                    <span>Provisioned Enclaves</span>\n                    <span>{getProjectsForClient(selectedClient.id).length} Active</span>\n                  </div>\n\n                  {getProjectsForClient(selectedClient.id).length === 0 ? (\n                    <div className=\"p-8 text-center border border-white/5 rounded-lg bg-[#020202]/20\">\n                      <p className=\"text-white/30 text-xs\">No sandbox enclaves provisioned for this tenant.</p>\n                    </div>\n                  ) : (\n                    <div className=\"space-y-2.5\">\n                      {getProjectsForClient(selectedClient.id).map(proj => (\n                        <div key={proj.id} className=\"p-3 bg-[#020202]/40 rounded-lg border border-white/5 space-y-1.5\">\n                          <div className=\"flex items-center justify-between\">\n                            <span className=\"font-bold text-white hover:text-[#009DFF] cursor-pointer transition-colors\" onClick={() => router.push(`/admin/projects/${proj.id}`)}>\n                              {proj.name}\n                            </span>\n                            <span className=\"text-[9px] px-1.5 py-0.5 rounded bg-white/5 text-[#009DFF] border border-[#009DFF]/20 font-bold uppercase font-mono\">\n                              {proj.enclaveType}\n                            </span>\n                          </div>\n                          <p className=\"text-[10.5px] text-white/50 line-clamp-1 leading-relaxed\">{proj.desc}</p>\n                          <div className=\"flex justify-between text-[9.5px] text-white/30 pt-1.5 border-t border-white/[0.03]\">\n                            <span>Nodes: <strong className=\"text-white\">{proj.nodesCount}</strong></span>\n                            <span>Status: <strong className=\"text-emerald-400 uppercase\">{proj.status}</strong></span>\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n\n                </div>\n              )}\n\n              {/* TAB 3: AGENTS */}\n              {drawerTab === \"agents\" && (\n                <div className=\"space-y-4\">\n                  <div className=\"flex items-center justify-between text-white/40 text-[10px] uppercase font-bold border-b border-white/5 pb-1\">\n                    <span>Active Workloads</span>\n                    <span>{getAgentsForProjects(getProjectsForClient(selectedClient.id).map(p => p.id)).length} Run-threads</span>\n                  </div>\n\n                  {getAgentsForProjects(getProjectsForClient(selectedClient.id).map(p => p.id)).length === 0 ? (\n                    <div className=\"p-8 text-center border border-white/5 rounded-lg bg-[#020202]/20\">\n                      <p className=\"text-white/30 text-xs\">No active agent models running in sandbox tunnels.</p>\n                    </div>\n                  ) : (\n                    <div className=\"space-y-2.5\">\n                      {getAgentsForProjects(getProjectsForClient(selectedClient.id).map(p => p.id)).map(agent => (\n                        <div key={agent.id} className=\"p-3 bg-[#020202]/40 rounded-lg border border-white/5 space-y-2\">\n                          <div className=\"flex items-center justify-between\">\n                            <span className=\"font-bold text-white flex items-center gap-1.5\">\n                              <Bot className=\"w-3.5 h-3.5 text-amber-500\" />\n                              <span>{agent.name}</span>\n                            </span>\n                            <span className={`text-[8.5px] px-1.5 py-0.5 rounded uppercase font-bold font-mono ${\n                              agent.status === \"active\" ? \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" : \"bg-amber-500/10 text-amber-400 border border-amber-500/20\"\n                            }`}>\n                              {agent.status}\n                            </span>\n                          </div>\n                          <div className=\"grid grid-cols-3 gap-2 text-[9.5px] text-white/45 bg-[#020202]/40 p-2 rounded border border-white/[0.02]\">\n                            <div>Threads: <strong className=\"text-white block\">{agent.threads}</strong></div>\n                            <div>Memory: <strong className=\"text-white block\">{agent.memory}</strong></div>\n                            <div>Heartbeat: <strong className=\"text-[#009DFF] block\">{agent.lastHeartbeat}</strong></div>\n                          </div>\n                        </div>\n                      ))}\n                    </div>\n                  )}\n\n                </div>\n              )}\n\n              {/* TAB 4: BILLING */}\n              {drawerTab === \"billing\" && (\n                <div className=\"space-y-4\">\n                  <div className=\"text-white/40 text-[10px] uppercase font-bold border-b border-white/5 pb-1\">\n                    Settlement Epoch Invoices\n                  </div>\n\n                  <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n                    <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold select-none\">\n                      <CreditCard className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                      <span>Financial Balance Summary</span>\n                    </div>\n                    <div className=\"grid grid-cols-2 gap-2 text-[10.5px]\">\n                      <div className=\"flex justify-between col-span-2\"><span className=\"text-white/45\">Account Status:</span><span className=\"text-[#00FFC2] font-semibold\">Active & Audited</span></div>\n                      <div className=\"flex justify-between col-span-2\"><span className=\"text-white/45\">Epoch credit allocations:</span><span className=\"text-white font-bold\">1,500,000 Credits</span></div>\n                      <div className=\"flex justify-between col-span-2\"><span className=\"text-white/45\">Attestation ledger billing:</span><span className=\"text-[#00FFC2] font-semibold\">Automatic via PKI count</span></div>\n                    </div>\n                  </div>\n\n                  {/* Ledger logs */}\n                  <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/40 space-y-3\">\n                    <div className=\"flex items-center gap-1.5 text-white/30 text-[9.5px] uppercase font-bold\">\n                      <Clock className=\"w-3.5 h-3.5 text-amber-500\" />\n                      <span>Simulation Invoice Telemetry</span>\n                    </div>\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between p-2 rounded bg-[#020202]/40 border border-white/5 text-[10.5px]\">\n                        <div>\n                          <p className=\"text-white font-semibold uppercase\">Epoch Q2 Spend</p>\n                          <p className=\"text-[9px] text-white/30\">Due on 2026-07-15</p>\n                        </div>\n                        <div className=\"text-right\">\n                          <p className=\"text-white font-bold\">$12,450.00</p>\n                          <span className=\"text-[8.5px] px-1 py-0.5 rounded bg-blue-500/15 text-blue-400 uppercase font-bold font-mono\">SEALED</span>\n                        </div>\n                      </div>\n\n                      <div className=\"flex items-center justify-between p-2 rounded bg-[#020202]/40 border border-white/5 text-[10.5px]\">\n                        <div>\n                          <p className=\"text-white font-semibold uppercase\">SLA SecWire Support</p>\n                          <p className=\"text-[9px] text-white/30\">Cleared 2026-06-15</p>\n                        </div>\n                        <div className=\"text-right\">\n                          <p className=\"text-emerald-400 font-bold\">$2,500.00</p>\n                          <span className=\"text-[8.5px] px-1 py-0.5 rounded bg-emerald-500/15 text-emerald-400 uppercase font-bold font-mono\">PAID</span>\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n\n                </div>\n              )}\n\n            </div>\n\n            {/* Drawer Footer Actions */}\n            <div className=\"p-5 border-t border-white/5 bg-[#090909] space-y-3\">\n              <button \n                onClick={(e) => handleInitiateHandshake(selectedClient, e)}\n                className=\"w-full h-10 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer border-none\"\n              >\n                <ExternalLink className=\"w-4 h-4\" />\n                <span>Establish Portal Mirror Handshake</span>\n              </button>\n\n              <button \n                onClick={() => router.push(`/admin/clients/${selectedClient.id}`)}\n                className=\"w-full h-9 rounded border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.04] text-[11px] font-mono font-bold uppercase text-white flex items-center justify-center gap-1.5 transition-all cursor-pointer\"\n              >\n                <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                <span>Open Deep Audit Record</span>\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* -----------------------------------------------------------------------\n          MODAL: HANDSHAKE SIMULATION DRAWER / DIALOG\n          ----------------------------------------------------------------------- */}\n      {handshakeStep > 0 && handshakeClient && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-sm p-4\">\n          <div className=\"w-full max-w-md bg-[#09090b] border border-white/10 rounded-xl overflow-hidden shadow-2xl\">\n            <div className=\"p-4 border-b border-white/10 bg-[#0c0c0e] flex items-center justify-between select-none\">\n              <span className=\"text-xs font-mono font-bold text-white uppercase tracking-wider flex items-center gap-2\">\n                <RefreshCw className=\"w-4 h-4 text-[#009DFF] animate-spin\" />\n                <span>eBPF Telemetry Handshake Probe</span>\n              </span>\n              {handshakeStep === 4 && (\n                <button onClick={() => setHandshakeStep(0)} className=\"text-white/40 hover:text-white cursor-pointer\">\n                  <X className=\"w-4 h-4\" />\n                </button>\n              )}\n            </div>\n\n            <div className=\"p-6 font-mono text-xs space-y-4\">\n              <div className=\"p-3 rounded bg-black border border-white/5 h-[160px] overflow-y-auto space-y-1 text-zinc-300\">\n                <p className=\"text-white/35\">[INITIATING SOVEREIGN DIAL-IN TO {handshakeClient.id.toUpperCase()}]</p>\n                {handshakeStep >= 1 && <p className=\"text-amber-400\">&gt; Connecting to node bridge at {handshakeClient.domain}...</p>}\n                {handshakeStep >= 2 && <p className=\"text-[#009DFF]\">&gt; TLS 1.3 dual-handshake key verified with HSM PKI signature.</p>}\n                {handshakeStep >= 3 && <p className=\"text-[#00FFC2]\">&gt; [OK] eBPF telemetry kernel hook established on sandbox cluster namespace.</p>}\n                {handshakeStep >= 4 && (\n                  <>\n                    <p className=\"text-green-400 font-bold\">&gt; TELEMETRY STREAM ESTABLISHED (SLA STATUS: EXCELLENT)</p>\n                    <p className=\"text-white/35\">[HANDSHAKE SECURE - SYSTEM MONITOR ACTIVE]</p>\n                  </>\n                )}\n              </div>\n\n              {handshakeStep === 4 && (\n                <div className=\"flex justify-end pt-2 border-t border-white/5\">\n                  <button \n                    onClick={() => setHandshakeStep(0)}\n                    className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-white text-xs font-bold uppercase transition-all cursor-pointer border-none\"\n                  >\n                    Acknowledge & Close\n                  </button>\n                </div>\n              )}\n            </div>\n          </div>\n        </div>\n      )}\n\n    </div>\n  );\n}"}}}
