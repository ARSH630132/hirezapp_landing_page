client.tier)}\n646 |                     <span className=\"text-[8.5px] text-white/30\">{client.id.toUpperCase()}</span>\n647 |                   </div>\n648 |                 </div>\n649 | \n650 |                 <div className=\"grid grid-cols-2 gap-3 text-white/60 text-[10px] text-left\">\n651 |                   <div className=\"space-y-1\">\n652 |                     <span className=\"text-white/30 block uppercase text-[8px] font-bold\">Industry & Region</span>\n653 |                     <div className=\"text-white/85 font-medium truncate\">{client.industry}</div>\n654 |                     <div className=\"text-white/50 text-[9px]\">{client.region}</div>\n655 |                   </div>\n656 |                   <div className=\"space-y-1\">\n657 |                     <span className=\"text-white/30 block uppercase text-[8px] font-bold\">Enclaves Status</span>\n658 |                     <div className=\"text-white font-bold\">{projectsCount} {projectsCount === 1 ? \"Project\" : \"Projects\"}</div>\n659 |                     {agentsCount > 0 && <div className=\"text-emerald-400 text-[9px] font-semibold\">{agentsCount} Live Agents</div>}\n660 |                   </div>\n661 |                 </div>\n662 | \n663 |                 <div className=\"grid grid-cols-2 gap-3 text-white/60 text-[10px] text-left border-t border-white/[0.03] pt-2\">\n664 |                   <div className=\"space-y-1\">\n665 |                     <span className=\"text-white/30 block uppercase text-[8px] font-bold\">Billing & Health</span>\n666 |                     <div className=\"flex items-center gap-1.5 mt-0.5\">\n667 |                       {getBillingBadge(client.billingStatus)}\n668 |                       {getHealthBadge(client.healthStatus)}\n669 |                     </div>\n670 |                   </div>\n671 |                   <div className=\"space-y-1\">\n672 |                     <span className=\"text-white/30 block uppercase text-[8px] font-bold\">Account Owner</span>\n673 |                     <div className=\"text-white/80 font-medium truncate mt-0.5\">{client.accountOwner}</div>\n674 |                   </div>\n675 |                 </div>\n676 | \n677 |                 <div className=\"flex items-center justify-between pt-2 border-t border-white/5 text-[#009DFF]\" onClick={(e) => e.stopPropagation()}>\n678 |                   <button\n679 |                     onClick={(e) => handleInitiateHandshake(client, e)}\n680 |                     className=\"h-7 px-2.5 rounded border border-[#009DFF]/30 bg-[#009DFF]/5 hover:bg-[#009DFF]/15 text-[#009DFF] text-[9.5px] font-bold uppercase flex items-center gap-1 transition-all cursor-pointer\"\n681 |                   >\n682 |                     <ExternalLink className=\"w-3 h-3\" />\n683 |                     <span>Preview Portal</span>\n684 |                   </button>\n685 |                   <button\n686 |                     onClick={() => {\n687 |                       setSelectedClient(client);\n688 |                       setDrawerTab(\"overview\");\n689 |                     }}\n690 |                     className=\"text-[10px] flex items-center gap-1 font-bold text-[#009DFF]\"\n691 |                   >\n692 |                     <span>INSPECT</span>\n693 |                     <ChevronRight className=\"w-3.5 h-3.5\" />\n694 |                   </button>\n695 |                 </div>\n696 |               </div>\n697 |             );\n698 |           })}\n699 |         </div>\n700 |         </>\n701 |       )}\n702 | \n703 |       {/* -----------------------------------------------------------------------\n704 |           5. DETAILS SIDE-DRAWER\n705 |           ----------------------------------------------------------------------- */}\n706 |       {selectedClient && (\n707 |         <div className=\"fixed inset-0 z-50 flex justify-end\">\n708 |           \n709 |           {/* Backdrop */}\n710 |           <div \n711 |             onClick={() => setSelectedClient(null)}\n712 |   