F] border-[#009DFF]/30 shadow-[0_0_10px_rgba(0,157,255,0.15)]\"\n 516 |                       : \"bg-white/[0.01] text-white/50 border-white/5 hover:text-white/80 hover:border-white/10\"\n 517 |                   }`}\n 518 |                 >\n 519 |                   {role === \"all\" ? \"All Roles\" : role.replace(\"_\", \" \")}\n 520 |                 </button>\n 521 |               ))}\n 522 |             </div>\n 523 |           </div>\n 524 | \n 525 | \n 526 |           {/* Table container */}\n 527 |           <div className=\"overflow-x-auto rounded border border-white/5 bg-[#050507]\">\n 528 |             <table className=\"w-full min-w-[620px] border-collapse text-left\">\n 529 |               <thead>\n 530 |                 <tr className=\"border-b border-white/5 bg-white/[0.02] text-[10px] font-mono text-white/40 uppercase tracking-wider\">\n 531 |                   <th className=\"py-3 px-4 font-semibold\">Operator & Secure ID</th>\n 532 |                   <th className=\"py-3 px-4 font-semibold\">Role Allocation</th>\n 533 |                   <th className=\"py-3 px-4 font-semibold\">Client Association</th>\n 534 |                   <th className=\"py-3 px-4 font-semibold\">Status</th>\n 535 |                   <th className=\"py-3 px-4 font-semibold text-right\">Clearance</th>\n 536 |                 </tr>\n 537 |               </thead>\n 538 |               <tbody className=\"divide-y divide-white/5\">\n 539 |                 {filteredUsers.length === 0 ? (\n 540 |                   <tr>\n 541 |                     <td colSpan={5} className=\"py-12 text-center\">\n 542 |                       <div className=\"flex flex-col items-center justify-center gap-2\">\n 543 |                         <Users className=\"w-8 h-8 text-white/10\" />\n 544 |                         <p className=\"text-xs font-mono text-white/40 uppercase\">No operators found matching criteria</p>\n 545 |                         <button\n 546 |                           onClick={() => {\n 547 |                             setSearchQuery(\"\");\n 548 |                             setSelectedRoleFilter(\"all\");\n 549 |                             setSelectedClientFilter(\"all\");\n 550 |                           }}\n 551 |                           className=\"mt-2 text-[10px] font-mono text-[#009DFF] hover:underline\"\n 552 |                         >\n 553 |                           Reset Console Filters\n 554 |                         </button>\n 555 |                       </div>\n 556 |                     </td>\n 557 |                   </tr>\n 558 |                 ) : (\n 559 | \n 560 |                   filteredUsers.map((user) => {\n 561 |                     const isSelected = selectedUser?.id === user.id;\n 562 |                     return (\n 563 |                       <tr\n 564 |                         key={user.id}\n 565 |                         onClick={() => setSelectedUser(user)}\n 566 |                         className={`group cursor-pointer transition-all ${\n 567 |                           isSelected\n 568 |                             ? \"bg-[#009DFF]/5 hover:bg-[#009DFF]/5 border-l-2 border-l-[#009DFF]\"\n 569 |                             : \"hover:bg-white/[0.015]\"\n 570 |                         }`}\n 571 |                       >\n 572 |                         <td className=\"py-3.5 px-4\">\n 573 |                           <div className=\"flex items-center gap-3\">\n 574 |                             <div className=\"relative\">\n 575 |                               <div className={`w-8 h-8 rounded-full border flex items-center justify-center text-xs font-mono font-semibold uppercase transition-all ${\n 576 |                                 user.status === \"inactive\"\n 577 |                                   ? \"bg-white/5 border-white/10 text-white/30\"\n 578 |                                   : user.role === \"gff_admin\"\n 579 |                                   ? \"bg-purple-500/10 border-purple-500/30 text-purple-300\"\n 580 |                                   : user.role === \"client_admin\"\n 581 |                                   ? \"bg-[#009DFF]/10 border-[#009DFF]/30 text-[#009DFF]\"\n 582 |                                   : \"bg-emerald-500/10 border-emerald-500/30 text-emerald-300\"\n 583 |                               }`}>\n 584 |                                 {user.name.split(\" \").map(n => n[0]).join(\"\")}\n 585 |                               </div>\n 586 |                               <span className={`absolute bottom-0 right-0 w-2.5 h-2.5 rounded-full border-2 border-[#050507] ${\n 587 |                                 user.status === \"active\" ? \"bg-emerald-400\" : \"bg-neutral-600\"\n 588 |                               }`} />\n 589 |                             </div>\n 590 |                             <div className=\"min-w-0\">\n 591 |                               <p className=\"text-xs font-bold text-white group-hover:text-[#009DFF] transition-colors truncate max-w-[150px]\">\n 592 |                                 {user.name}\n 593 |                               </p>\n 594 |                               <p className=\"text-[10px] font-mono text-white/40 truncate max-w-[150px]\">{user.email}</p>\n 595 |                             </div>\n 596 |                           </div>\n 597 |                         </td>\n 598 |                         <td className=\"py-3.5 px-4\">\n 599 |                           <span className={`inline-flex items-center px-2 py-0.5 rounded text-[9px] font-mono font-bold border ${\n 600 |                             user.role === \"gff_admin\"\n 601 |                               ? \"bg-purple-500/5 text-purple-400 border-purple-500/20\"\n 602 |                               : user.role === \"client_admin\"\n 603 |                               ? \"bg-[#009DFF]/5 text-[#009DFF] border-[#009DFF]/20\"\n 604 |                               : \"bg-emerald-500/5 text-emerald-400 border-emerald-500/20\"\n 605 |                           }`}>\n 606 |                             {user.role === \"gff_admin\" ? \"GFF ADMIN\" : user.role === \"client_admin\" ? \"CLIENT ADMIN\" : \"CLIENT MEMBER\"}\n 607 |                           </span>\n 608 |                         </td>\n 609 |                         <td className=\"py-3.5 px-4\">\n 610 |                           <p className=\"text-[10.5px] font-mono text-white/70 truncate max-w-[150px]\" title={user.clientAssociation}>\n 611 |                             {user.clientAssociation.replace(\" [Preview Client]\", \"\")}\n 612 |                           </p>\n 613 |                         </td>\n 614 |                         <td className=\"py-3.5 px-4\">\n 615 |                           <span className={`inline-flex items-center gap-1.5 text-[10px] font-mono font-semibold ${\n 616 |                             user.status === \"active\" ? \"text-emerald-400\" : \"text-white/30\"\n 617 |                           }`}>\n 618 |                             <span className={`w-1.5 h-1.5 rounded-full ${\n 619 |                               user.status === \"active\" ? \"bg-emerald-400 animate-pulse\" : \"bg-neutral-600\"\n 620 |                             }`} />\n 621 |                             {user.status === \"active\" ? \"ACTIVE\" : \"INACTIVE\"}\n 622 |                           </span>\n 623 |                         </td>\n 624 |                         <td className=\"py-3.5 px-4 text-right\">\n 625 |                           <span className=\"text-[9.5px] font-mono text-amber-500/80 font-bold tracking-tight\">\n 626 |                             {user.clearance.split(\" \")[2]}\n 627 |                           </span>\n 628 |                         </td>\n 629 |                       </tr>\n 630 |                     );\n 631 |                   })\n 632 |                 )}\n 633 |               </tbody>\n 634 |             </table>\n 635 |           </div>\n 636 |         </div>\n 637 | \n 638 | \n 639 |         {/* Right Side: Identity Cryptographic Ledger / Action Panel */}\n 640 |         <div className=\"xl:col-span-5 space-y-4\">\n 641 |           {selectedUser ? (\n 642 |             <div className=\"bg-[#030303]/40 border border-white/5 rounded-xl p-5 space-y-5 relative overflow-hidden\">\n 643 |               {/* Graphic Decal Label */}\n 644 |               <div className=\"absolute top-0 right-0 px-2 py-0.5 bg-white/[0.02] border-b border-l border-white/5 font-mono text-[8px] text-white/30 uppercase tracking-widest select-none\">\n 645 |                 ENCLAVE REGISTRY BOUNDS\n 646 |               </div>\n 647 | \n 648 |               {/* Profile card summary */}\n 649 |               <div className=\"flex items-start gap-4 pb-4 border-b border-white/5\">\n 650 |                 <div className={`w-14 h-14 rounded-xl border flex items-center justify-center font-mono font-bold text-lg relative overflow-hidden ${\n 651 |                   selectedUser.role === \"gff_admin\"\n 652 |                     ? \"bg-purple-500/10 border-purple-500/25 text-purple-300\"\n 653 |                     : selectedUser.role === \"client_admin\"\n 654 |                     ? \"bg-[#009DFF]/10 border-[#009DFF]/25 text-[#009DFF]\"\n 655 |                     : \"bg-emerald-500/10 border-emerald-500/25 text-emerald-300\"\n 656 |                 }`}>\n 657 |                   <Shield className=\"absolute inset-0 w-full h-full p-2.5 text-white/[0.015] pointer-events-none\" />\n 658 |                   <span className=\"relative z-10\">{selectedUser.name.split(\" \").map(n => n[0]).join(\"\")}</span>\n 659 |                 </div>\n 660 |                 <div className=\"space-y-0.5 min-w-0 flex-1\">\n 661 |                   <span className=\"text-[9px] font-mono text-white/30 uppercase tracking-widest block font-bold\">\n 662 |                     SECURITY CREDENTIAL MATRIX\n 663 |                   </span>\n 664 |                   <h2 className=\"text-sm font-bold text-white truncate\">{selectedUser.name}</h2>\n 665 |                   <p className=\"text-xs font-mono text-[#009DFF] truncate\">{selectedUser.email}</p>\n 666 |                   <p className=\"text-[10px] font-mono text-white/40\">UUID: {selectedUser.id}</p>\n 667 |                 </div>\n 668 |               </div>\n 669 | \n 670 |               {/* Details grid list */}\n 671 |               <div className=\"grid grid-cols-2 gap-3 text-[11px] font-mono\">\n 672 |                 <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1 col-span-2\">\n 673 |                   <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Assigned Trust Enclave</span>\n 674 |                   <div className=\"flex items-center gap-1.5 text-white font-bold truncate\">\n 675 |                     <Server className=\"w-3.5 h-3.5 text-cyan-400 shrink-0\" />\n 676 |                     <span className=\"truncate\">{selectedUser.clientAssociation}</span>\n 677 |                   </div>\n 678 |                 </div>\n 679 | \n 680 |                 <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1\">\n 681 |                   <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Clearance Tier</span>\n 682 |                   <span className=\"text-amber-500 font-bold block truncate\">\n 683 |                     {selectedUser.clearance.replace(\"CLEARANCE LEVEL \", \"LVL-\")}\n 684 |                   </span>\n 685 |                 </div>\n 686 | \n 687 |                 <div className=\"p-3 bg-white/[0.01] border border-white/5 rounded-lg space-y-1\">\n 688 |                   <span className=\"text-white/30 text-[9px] uppercase font-bold block\">Session Link</span>\n 689 |                   <span className={`font-bold block ${selectedUser.status === \"active\" ? \"text-emerald-400\" : \"text-white/40\"}`}>\n 690 |                     {selectedUser.status === \"active\" ? \"LIVE SYNC\" : \"FLUSHED\"}\n 691 |                   </span>\n 692 |                 </div>\n 693 |               </div>\n 694 | \n 695 |               {/* Dynamic Permissions Matrix Grid */}\n 696 |               <div className=\"space-y-2\">\n 697 |                 <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase font-bold border-b border-white/5 pb-1 select-none\">\n 698 |                   <span>Enclave Permissions Bound</span>\n 699 |                   <span className=\"text-purple-400 font-mono text-[9px]\">\n 700 |                     {selectedUser.permissions.length} Keys Assigned\n 701 |                   </span>\n 702 |                 </div>\n 703 |                 <div className=\"flex flex-wrap gap-1.5 max-h-[100px] overflow-y-auto pr-1\">\n 704 |                   {selectedUser.permissions.map((perm) => (\n 705 |                     <span\n 706 |                       key={perm}\n 707 |                       className=\"px-2 py-0.5 text-[9px] font-mono font-semibold bg-[#00FFC2]/5 text-[#00FFC2] rounded border border-[#00FFC2]/20 shadow-[0_0_8px_rgba(0,255,194,0.02)]\"\n 708 |                     >\n 709 |                       {perm}\n 710 |                     </span>\n 711 |                   ))}\n 712 |                 </div>\n 713 |               </div>\n 714 | \n 715 | \n 716 |               {/* Secure Local Actions */}\n 717 |               <div className=\"space-y-3 pt-2 border-t border-white/5\">\n 718 |                 <div className=\"flex items-center gap-1.5 text-[10px] font-mono text-white/40 uppercase font-bold select-none\">\n 719 |                   <Settings className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n 720 |                   <span>Emulated Identity Controls</span>\n 721 |                 </div>\n 722 | \n 723 |                 <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n 724 |                   {/* Action: Change Role Dropdown */}\n 725 |                   <div className=\"bg-white/[0.01] border border-white/5 rounded-lg p-2.5 flex flex-col gap-1.5 font-mono\">\n 726 |                     <span className=\"text-[9px] font-mono text-white/30 uppercase font-bold\">Role Hierarchy</span>\n 727 |                     <select\n 728 |                       value={selectedUser.role}\n 729 |                       onChange={(e) => handleRoleChange(selectedUser.id, e.target.value as any)}\n 730 |                       className=\"px-2 py-1 bg-[#09090b] border border-white/10 focus:border-[#009DFF]/50 focus:outline-none rounded text-[11px] font-mono text-white cursor-pointer transition-all\"\n 731 |                     >\n 732 |                       <option value=\"gff_admin\">gff_admin</option>\n 733 |                       <option value=\"client_admin\">client_admin</option>\n 734 |                       <option value=\"client_member\">client_member</option>\n 735 |                     </select>\n 736 |                   </div>\n 737 | \n 738 |                   {/* Action: Deactivate status toggle button */}\n 739 |                   <div className=\"bg-white/[0.01] border border-white/5 rounded-lg p-2.5 flex flex-col gap-1.5 justify-between\">\n 740 |                     <span className=\"text-[9px] font-mono text-white/30 uppercase font-bold\">Access Status</span>\n 741 |                     <button\n 742 |                       onClick={() => handleToggleStatus(selectedUser.id)}\n 743 |                       className={`w-full py-1.5 rounded text-[10px] font-mono font-bold uppercase transition-all cursor-pointer border ${\n 744 |                         selectedUser.status === \"active\"\n 745 |                           ? \"bg-red-500/10 hover:bg-red-500/20 text-red-400 border-red-500/25 hover:border-red-500/40\"\n 746 |                           : \"bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 border-emerald-500/25 hover:border-emerald-500/40\"\n 747 |                       }`}\n 748 |                     >\n 749 |                       {selectedUser.status === \"active\" ? \"Deactivate Key\" : \"Re-Activate Key\"}\n 750 |                     </button>\n 751 |                   </div>\n 752 | \n 753 |                   {/* Action: Reset Credentials button */}\n 754 |                   <button\n 755 |                     onClick={() => handleResetCredentials(selectedUser.id)}\n 756 |                     disabled={isResetting}\n 757 |                     className=\"sm:col-span-2 py-2.5 px-3 rounded bg-[#009DFF]/10 hover:bg-[#009DFF]/20 text-[#009DFF] border border-[#009DFF]/25 hover:border-[#009DFF]/45 text-[11px] font-mono font-bold uppercase tracking-wider transition-all flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50\"\n 758 |                   >\n 759 |                     {isResetting ? (\n 760 |                       <>\n 761 |                         <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n 762 |                         <span>ROLLING HSM KEYS...</span>\n 763 |                       </>\n 764 |                     ) : (\n 765 |                       <>\n 766 |                         <KeyRound className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n 767 |                         <span>Reset Dual-Key FIDO2 Access</span>\n 768 |                       </>\n 769 |                     )}\n 770 |                   </button>\n 771 |                 </div>\n 772 |               </div>\n 773 | \n 774 |               {/* Secure Audit Logs Stream */}\n 775 |               <div className=\"space-y-2\">\n 776 |                 <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase font-bold border-b border-white/5 pb-1 select-none\">\n 777 |                   <span>Operator Audit Flux</span>\n 778 |                   <span className=\"flex items-center gap-1 text-[8.5px] text-green-400 font-mono\">\n 779 |                     <span className=\"w-1 h-1 rounded-full bg-green-400 animate-pulse\" />\n 780 |                     STREAM AC