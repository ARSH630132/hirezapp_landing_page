://auth.gff.ai/v1/emulated</span>\n410 |           </span>\n411 |         </div>\n412 |       </div>\n413 | \n414 | \n415 |       {/* Stats Indicator Bar */}\n416 |       <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n417 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n418 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n419 |             <span>Operator Directory</span>\n420 |             <Users className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n421 |           </div>\n422 |           <div className=\"flex items-baseline gap-2 pt-0.5\">\n423 |             <span className=\"text-2xl font-bold text-white tracking-tight font-mono\">{users.length}</span>\n424 |             <span className=\"text-[9.5px] text-green-400 font-mono\">Bound</span>\n425 |           </div>\n426 |         </div>\n427 | \n428 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n429 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n430 |             <span>Role Distribution</span>\n431 |             <Shield className=\"w-3.5 h-3.5 text-purple-400\" />\n432 |           </div>\n433 |           <div className=\"pt-1.5\">\n434 |             <span className=\"text-[11px] font-mono text-white/70 block leading-tight\">\n435 |               {users.filter(u => u.role === \"gff_admin\").length} GFF Admin / {users.filter(u => u.role === \"client_admin\").length} Client Admin\n436 |             </span>\n437 |           </div>\n438 |         </div>\n439 | \n440 |         <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/60 space-y-1\">\n441 |           <div className=\"flex items-center justify-between text-[10px] font-mono text-white/40 uppercase tracking-widest\">\n442 |             <span>Active Enclaves</span>\n443 |             <Server classN