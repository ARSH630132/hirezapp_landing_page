bold text-white group-hover:text-[#009DFF] transition-colors\">{client.name}</span>\n504 |                             {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400 shrink-0\" />}\n505 |                           </div>\n506 |                           <div className=\"text-[10px] text-white/40 flex items-center gap-1.5 font-mono\">\n507 |                             <span className=\"text-[#009DFF]\">{client.domain}</span>\n508 |                             <span>•</span>\n509 |                             <span \n510 |                               onClick={(e) => handleCopyId(client.id, e)}\n511 |                               className=\"hover:text-white transition-colors cursor-pointer flex items-center gap-0.5\"\n512 |                             >\n513 |                               {client.id.toUpperCase()}\n514 |                               {copiedId === client.id ? <Check className=\"w-2.5 h-2.5 text-emerald-400\" /> : <Copy className=\"w-2.5 h-2.5 opacity-50 hover:opacity-100\" />}\n515 |                             </span>\n516 |                           </div>\n517 |                         </div>\n518 |                       </td>\n519 | \n520 |                       {/* Industry */}\n521 |                       <td className=\"p-4 text-white/70\">\n522 |                         <div className=\"flex items-center gap-1.5\">\n523 |                           <Building className=\"w-3.5 h-3.5 text-white/30\" />\n524 |                           <span>{client.industry}</span>\n525 |                         </div>\n526 |                       </td>\n527 | \n528 |                       {/* Region & Tier */}\n529 |                       <td className=\"p-4\">\n530 |                         <div className=\"space-y-1\">\n531 |                           <div className=\"flex items-center gap-1.5 text-white/80\">\n532 |                             <Globe className=\"w-3.5 h-3.5 text-white/30\" />\n533 |                             <span>{client.region}</span>\n534 |                           </div>\n535 |                           <div>{getTierBadge(client.tier)}</div>\n536 |                         </div>\n537 |                       </td>\n538 | \n539 |                       {/* Account Owner */}\n540 |                       <td className=\"p-4\">\n541 |                         <div className=\"flex items-center gap-2\">\n542 |                           <div className=\"w-5 h-5 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 font-mono text-[9px] font-bold\">\n543 |                             {client.accountOwner.split(\" \").pop()?.[0]}\n544 |                           </div>\n545 |                           <div className=\"space-y-0.5\">\n546 |                             <span className=\"text-white font-medium\">{client.accountOwner}</span>\n547 |                             <span \n548 |                               onClick={(e) => handleOpenAssignOwner(client, e)}\n549 |                               className=\"text-[9px] text-[#009DFF] hover:underline cursor-pointer block\"\n550 |                             >\n551 |                               Re-assign owner\n552 |                             </span>\n553 |                           </div>\n554 |                         </div>\n555 |                       </td>\n556 | \n557 |                       {/* Active Counts */}\n558 |                       <td className=\"p-4 text-center\">\n559 |                         <div className=\"inline-flex flex-col items-center gap-1\">\n560 |                           <span className=\"text-white font-bold\">{projectsCount}</span>\n561 |                           <span className=\"text-[9px] text-white/30 uppercase tracking-wider\">{projectsCount === 1 ? \"Project\" : \"Projects\"}</span>\n562 |                           {agentsCount > 0 && (\n563 |                             <span className=\"text-[9px] text-emerald-400/80 font-semibold uppercase\">\n564 |                               {agentsCount} Live {agentsCount === 1 ? \"Agent\" : \"Agents\"}\n565 |                             </span>\n566 |                           )}\n567 |                         </div>\n568 |                       </td>\n569 | \n570 |                       {/* Billing Status */}\n571 |                       <td className=\"p-4 text-center\">\n572 |                         {getBillingBadge(client.billingStatus)}\n573 |                       </td>\n574 | \n575 |                       {/* Health Status */}\n576 |                       <td className=\"p-4 text-center\">\n577 |                         {getHealthBadge(client.healthStatus)}\n578 |                       </td>\n579 | \n580 |                       {/* Actions */}\n581 |                       <td className=\"p-4 text-right\" onClick={(e) => e.stopPropagation()}>\n582 |                         <div className=\"flex items-center justify-end gap-2\">\n583 |                           <button\n584 |                             onClick={(e) => handleInitiateHandshake(client, e)}\n585 |                             className=\"h-7 px-2.5 rounded border border-[#009DFF]/30 bg-[#009DFF]/5 hover:bg-[#009DFF]/15 text-[#009DFF] text-[10px] font-bold uppercase flex items-center gap-1 transition-all cursor-pointer\"\n586 |                             title=\"Mirror Client Portal\"\n587 |                           >\n588 |                             <ExternalLink className=\"w-3 h-3\" />\n589 |                             <span>Preview Portal</span>\n590 |                           </button>\n591 |                           \n592 |                           <button\n593 |                             onClick={() => {\n594 |                               setSelectedClient(client);\n595 |                               setDrawerTab(\"overview\");\n596 |                             }}\n597 |                             className=\"h-7 w-7 rounded border border-white/5 hover:border-white/15 hover:bg-white/5 text-white/50 hover:text-white flex items-center justify-center transition-all cursor-pointer\"\n598 |                             title=\"Open Telemetry Ledger\"\n599 |                           >\n600 |                             <ChevronRight className=\"w-4 h-4\" />\n601 |                           </button>\n602 |                         </div>\n603 |                       </td>\n604 | \n605 |                     </tr>\n606 |                   );\n607 |                 })}\n608 |               </tbody>\n609 |             </table>\n610 |           </div>\n611 |           <div className=\"p-4 border-t border-white/5 bg-[#050505]/10 flex flex-col sm:flex-row items-center justify-between gap-3 text-[11px] font-mono\">\n612 |             <span className=\"text-white/40\">\n613 |               Showing <span className=\"text-white/70 font-semibold\">{filteredClients.length}</span> of <span className=\"text-white/70 font-semibold\">{clients.length}</span> sovereign domains configured\n614 |             </span>\n615 |             <div className=\"text-white/30 text-[10px] flex items-center gap-1\">\n616 |               <Shield className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n617 |               <span>Attestation registry locked with administrative cryptographic keys</span>\n618 |             </div>\n619 |           </div>\n620 |         </div>\n621 | \n622 |         {/* Mobile Card Layout */}\n623 |         <div className=\"lg:hidden space-y-4 animate-fade-in mt-4\">\n624 |           {filteredClients.map((client) => {\n625 |             const projectsCount = getProjectsForClient(client.id).length;\n626 |             const agentsCount = getAgentOpsForClient(client.id).length;\n627 |             return (\n628 |               <div \n629 |                 key={client.id}\n630 |                 onClick={() => {\n631 |                   setSelectedClient(client);\n632 |                   setDrawerTab(\"overview\");\n633 |                 }}\n634 |         