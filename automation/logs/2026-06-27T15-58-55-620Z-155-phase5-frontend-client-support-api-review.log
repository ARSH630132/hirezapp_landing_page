                </div>\n580 | \n581 |                     {activeTicket.replies?.map((r, i) => {\n582 |                       const isClient = r.sender.includes(\"Client\") || r.sender.includes(\"Mercer\");\n583 |                       return (\n584 |                         <div \n585 |                           key={i} \n586 |                           className={`p-3 rounded-xl border text-[10.5px] space-y-1.5 max-w-[90%] transition-all ${\n587 |                             isClient \n588 |                               ? \"border-[#009DFF]/20 bg-[#009DFF]/5 ml-auto text-right shadow-[0_0_12px_rgba(0,157,255,0.03)]\" \n589 |                               : \"border-emerald-500/15 bg-emerald-500/[0.02]\"\n590 |                           }`}\n591 |                         >\n592 |                           <div className={`flex items-center gap-1.5 font-mono text-[9px] font-bold select-none ${isClient ? \"justify-end text-[#009DFF]\" : \"text-emerald-400\"}`}>\n593 |                             {!isClient && <Cpu className=\"w-3.5 h-3.5 text-emerald-400\" />}\n594 |                             <span>{r.sender.toUpperCase()}</span>\n595 |                           </div>\n596 |                           <p className=\"text-white/85 leading-relaxed select-text font-mono\">{r.text}</p>\n597 |                           <span className=\"text-[8px] text-white/30 block text-right select-none\">{new Date(r.timestamp).toLocaleTimeString()}</span>\n598 |                         </div>\n599 |                       );\n600 |                     })}\n601 | \n602 |                     {isReplying && (\n603 |                       <div className=\"p-3 rounded-lg border border-white/5 text-[10px] text-white/30 flex items-center gap-2 animate-pulse max-w-[80%] select-none font-mono\">\n604 |                         <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-emerald-400\" />\n605 |                         <span>On-call systems engineer decoding secure telemetry stream...</span>\n606 |                       </div>\n607 |                     )}\n608 |                     <div ref={chatEndRef} />\n609 |                   </div>\n610 |                 </div>\n611 |               </div>\n612 | \n613 |               {/* Chat Input block */}\n614 |               <div className=\"p-3 border-t border-white/5 bg-black/40\">\n615 |                 <form onSubmit={handleSendReply} className=\"relative\">\n616 |                   <textarea\n617 |                     required\n618 |                     disabled={isReplying}\n619 |                     placeholder=\"Type secured diagnostics reply and press Enter...\"\n620 |                     value={replyText}\n621 |                     onChange={e => setReplyText(e.target.value)}\n622 |                     onKeyDown={e => { if (e.key === \"Enter\" && !e.shiftKey) { e.preventDefault(); handleSendReply(e); } }}\n623 |                     className=\"w-full h-15 rounded-lg border border-white/10 bg-black/60 pl-3.5 pr-12 py-3 text-white text-[11px] outline-none resize-none leading-relaxed focus:border-[#009DFF]/30 transition-all font-mono\"\n624 |                   />\n625 |                   <button \n626 |                     type=\"submit\" \n627 |                     disabled={!replyText.trim() || isReplying} \n628 |                     className=\"absolute right-2.5 bottom-3.5 p-2 rounded-md bg-white text-black hover:bg-white/95 disabled:opacity-25 disabled:bg-white cursor-pointer transition-all flex items-center justify-center shadow-lg\"\n629 |                   >\n630 |                     <Send className=\"w-3.5 h-3.5\" />\n631 |                   </button>\n632 |                 </form>\n633 |               </div>\n634 |             </div>\n635 |           ) : (\n636 |             /* Tabbed Selector when no ticket is active */\n637 |             <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm overflow-hidden font-mono text-left shadow-2xl flex flex-col min-h-[580px]\">\n638 |               \n639 |               {/* Tab Selector Headings */}\n640 |               <div className=\"flex border-b border-white/5 bg-black/20 select-none\">\n641 |                 <button \n642 |                   onClick={() => { setRightTab(\"intake\"); setSelectedSvgNode(\"shield\"); }} \n643 |                   className={`flex-1 py-3 text-center font-mono text-[10px] font-extrabold uppercase tracking-widest cursor-pointer transition-all border-b-2 ${\n644 |                     rightTab === \"intake\" ? \"border-[#009DFF] text-white bg-white/[0.01]\" : \"border-transparent text-white/40\"\n645 |                   }`}\n646 |                 >\n647 |                   Secured Intake Wire\n648 |                 </button>\n649 |                 <button \n650 |                   onClick={() => setRightTab(\"topology\")} \n651 |                   className={`flex-1 py-3 text-center font-mono text-[10px] font-extrabold uppercase tracking-widest cursor-pointer transition-all border-b-2 ${\n652 |                     rightTab === \"topology\" ? \"border-[#00FFC2] text-white bg-white/[0.01]\" : \"border-transparent text-white/40\"\n653 |                   }`}\n654 |                 >\n655 |                   Tunnel Security Gateway\n656 |                 </button>\n657 |               </div>\n658 | \n659 |               {/* TAB 1: INTAKE FORM */}\n660 |               {rightTab === \"intake\" && (\n661 |                 <div className=\"p-5 flex-1 flex flex-col justify-between\">\n662 |                   {isSubmittingForm ? (\n663 |                     <div className=\"flex-1 flex flex-col items-center justify-center text-center p-8 space-y-4\">\n664 |                       <RefreshCw className=\"w-10 h-10 text-[#009DFF] animate-spin\" />\n665 |                       <div className=\"space-y-1.5 font-mono\">\n666 |                         <h4 className=\"text-xs font-bold text-white uppercase tracking-wider\">CREATING SECURE HANDSHAKE...</h4>\n667 |                         <p className=\"text-[9.5px] text-white/40\">Deploying Intel SGX Isolated Tunnel</p>\n668 |                       </div>\n669 | \n670 |                       <div className=\"w-full max-w-sm p-3 bg-black/80 rounded border border-white/5 text-[9px] text-left leading-normal font-mono space-y-1 text-emerald-400 select-text\">\n671 |                         {submittingLogs.map((log, idx) => (\n672 |                           <div key={idx}>&gt; {log}</div>\n673 |                         ))}\n674 |                       </div>\n675 |                     </div>\n676 |                   ) : (\n677 |                     <>\n678 |                       <div className=\"space-y-4\">\n679 |                         <div className=\"flex items-center gap-2 border-b border-white/5 pb-3 select-none\">\n680 |                           <MessageSquare className=\"w-4 h-4 text-[#009DFF]\" />\n681 |                           <div>\n682 |                             <h3 className=\"text-[12px] font-bold text-white uppercase tracking-wider\">Initialize Support Wire</h3>\n683 |                             <p className=\"text-[9px] text-white/40 mt-0.5 uppercase tracking-tight\">Route real-time diagnostics securely to GFF systems triage.</p>\n684 |                           </div>\n685 |                         </div>\n686 | \n687 |                         <form onSubmit={handleCreate} className=\"space-y-3.5 text-[10px]\">\n688 |                           <div className=\"space-y-1.5\">\n689 |                             <label className=\"text-white/45 uppercase tracking-wider font-extrabold block\">Summary Subject</label>\n690 |                             <input\n691 |                               required\n692 |                               placeholder=\"Briefly describe system issue...\"\n693 |                               value={subject}\n694 |                               onChange={e => setSubject(e.target.value)}\n695 |                               className=\"w-full h-10 rounded-lg border border-white/10 bg-black/50 px-3.5 text-white text-[11px] outline-none focus:border-[#009DFF]/35 transition-all font-mono\"\n696 |                             />\n697 |                           </div>\n698 | \n699 |                           <div className=\"grid grid-cols-2 gap-3\">\n700 |                             <div className=\"space-y-1.5\">","success":true}],"durationMs":5}}
