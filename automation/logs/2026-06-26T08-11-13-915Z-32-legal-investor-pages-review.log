{"ts":"2026-06-26T08:10:03.319Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"hz5hx5ar","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/investor-relations/page.tsx","old_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { TrendingUp } from \"lucide-react\";\n\nexport default function InvestorRelationsPage() {\n  const [pathway, setPathway] = useState(\"strategic\");\n\n  const phases = [\n    { num: \"I\", title: \"Core Incubation\", desc: \"Constructing zero-trust enclaves and multi-agent DAG architectures.\" },\n    { num: \"II\", title: \"Enterprise Scaling\", desc: \"Capturing recurring SLA-backed allocations in logistics and banking.\" },\n    { num: \"III\", title: \"Sovereign Hubs\", desc: \"Deploying localized regional model clusters to lock geographic regulatory nodes.\" }\n  ];\n\n  const pathways: Record<string, { title: string; desc: string; action: string }> = {\n    strategic: {\n      title: \"Strategic Venture & Equity\",\n      desc: \"We interface with premier institutional funds seeking asymmetric exposure to highly efficient, software-only cognitive infrastructure.\",\n      action: \"Request Equity Deck\"\n    },\n    advisory: {\n      title: \"Institutional Advisories\",\n      desc: \"We coordinate with corporate advisors to align systems deployments with multi-jurisdictional compliance and industrial policy goals.\",\n      action: \"Contact Corp Dev\"\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Financial Operations\"\n        title=\"Investor Relations Pathway\"\n        highlightedWord=\"Investor\"\n        description=\"Access GFF AI's institutional milestones, strategic corporate phases, and capital-efficient enterprise growth trajectories.\"\n      />\n\n      <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 space-y-12 relative z-10\">\n        \n        <div className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-3\">\n          <h2 className=\"text-[18px] font-semibold text-white tracking-tight flex items-center gap-2\">\n            <TrendingUp className=\"w-4 h-4 text-[#009DFF]\" /> Capital-Efficient Cognitive Infrastructure\n          </h2>\n          <p className=\"text-white/70 leading-relaxed text-[13px] font-light\">\n            GFF AI addresses the massive enterprise orchestration gap with high-performance, productized cognitive assets. By separating cloud compute licensing from core proprietary logical structures, we maintain high margins and low physical overhead, securing Bilateral Stability and highly predictable enterprise retention.\n          </p>\n        </div>\n\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          {phases.map((phase, idx) => (\n            <div key={idx} className=\"p-6 rounded-[24px] border border-white/5 bg-gradient-to-b from-[#08080a] to-[#010101] relative overflow-hidden group\">\n              <span className=\"absolute top-4 right-4 text-[38px] font-mono font-bold leading-none text-white/5\">{phase.num}</span>\n              <h4 className=\"text-[14px] font-semibold text-white tracking-tight mt-2\">{phase.title}</h4>\n              <p className=\"mt-2 text-[12px] leading-relaxed text-white/50 font-light\">{phase.desc}</p>\n            </div>\n          ))}\n        </div>\n\n        <div className=\"p-6 rounded-[24px] border border-white/5 bg-[#030304]/80 space-y-4 max-w-xl mx-auto\">\n          <div className=\"space-y-1 text-center\">\n            <span className=\"inline-flex px-2.5 py-0.5 text-[9px] font-mono tracking-widest text-[#009DFF] border border-[#009DFF]/25 bg-[#009DFF]/5 rounded-full uppercase\">Allocators Portal</span>\n            <h3 className=\"text-[18px] font-semibold text-white tracking-tight\">Institutional Inquiries</h3>\n          </div>\n\n          <div className=\"flex justify-center gap-2 border-b border-white/5 pb-2\">\n            {Object.keys(pathways).map((key) => (\n              <button\n                key={key}\n                onClick={() => setPathway(key)}\n                className={`px-3 py-1.5 text-[11px] font-medium transition-all rounded-lg ${\n                  pathway === key ? \"text-white bg-white/5 border border-white/10\" : \"text-white/40 hover:text-white\"\n                }`}\n              >\n                {key === \"strategic\" ? \"Strategic Equity\" : \"Corporate Advisory\"}\n              </button>\n            ))}\n          </div>\n\n          <div className=\"p-4 rounded-xl border border-white/5 bg-black/40 space-y-3 text-center\">\n            <h4 className=\"text-[14px] font-semibold text-white\">{pathways[pathway].title}</h4>\n            <p className=\"text-white/60 text-[12px] font-light leading-relaxed\">{pathways[pathway].desc}</p>\n            <a\n              href={`/contact?pathway=${pathway}`}\n              className=\"inline-block px-5 py-2 rounded-full text-[11px] font-semibold text-white bg-gradient-to-r from-[#E4000F] to-[#009DFF] hover:opacity-95\"\n            >\n              {pathways[pathway].action}\n            </a>\n          </div>\n        </div>\n\n        <PremiumCTA\n          title=\"Interested in GFF AI's Corporate Governance?\"\n          description=\"Qualified representatives from strategic allocators, commercial partners, and family offices may request a detailed operational review.\"\n          primaryLabel=\"Connect with IR Desk\"\n          primaryHref=\"mailto:investors@gff.ai\"\n          secondaryLabel=\"Review Privacy Framework\"\n          secondaryHref=\"/privacy\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport AnimatedBackgroundGrid from \"@/components/inner-pages/AnimatedBackgroundGrid\";\nimport { TrendingUp, Globe, Shield } from \"lucide-react\";\n\nexport default function InvestorRelationsPage() {\n  const [active, setActive] = useState<\"milestones\" | \"strategy\">(\"milestones\");\n\n  const phases = [\n    { n: \"I\", t: \"Core Incubation\", d: \"Constructing zero-trust enclaves and multi-agent DAG architectures.\" },\n    { n: \"II\", t: \"Enterprise Scaling\", d: \"Capturing recurring SLA-backed allocations in logistics and banking.\" },\n    { n: \"III\", t: \"Sovereign Hubs\", d: \"Deploying localized regional model clusters to lock geographic regulatory nodes.\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <div className=\"relative overflow-hidden min-h-screen pb-16\">\n        <AnimatedBackgroundGrid />\n        \n        <InnerPageHero\n          category=\"Financial Operations\"\n          title=\"Investor Relations Pathway\"\n          highlightedWord=\"Investor\"\n          description=\"Access GFF AI's institutional milestones, strategic corporate phases, and capital-efficient enterprise growth trajectories.\"\n        />\n\n        <div className=\"max-w-[1200px] mx-auto px-6 lg:px-16 pb-24 space-y-12 relative z-10\">\n          \n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px]\">\n            <div className=\"lg:col-span-8 space-y-3\">\n              <div className=\"flex items-center gap-2 text-[#009DFF] text-[10px] font-mono uppercase font-bold\">\n                <TrendingUp className=\"w-3.5 h-3.5\" /> High-Yield Cognitive Assets\n              </div>\n              <h2 className=\"text-[20px] font-semibold text-white tracking-tight\">Capital-Efficient Cognitive Infrastructure</h2>\n              <p className=\"text-white/70 text-[13px] font-light leading-relaxed\">\n                GFF AI addresses the massive enterprise orchestration gap with high-performance, productized cognitive assets. By separating cloud compute licensing from core proprietary logical structures, we maintain high margins and low physical overhead.\n              </p>\n            </div>\n            \n            <div className=\"lg:col-span-4 p-4 rounded-xl border border-white/5 bg-black/40 flex flex-col gap-2\">\n              <div className=\"flex justify-between text-[11px] font-mono text-white/40\">\n                <span>EST. DIRECT ASSETS</span>\n                <span className=\"text-[#009DFF]\">100% PROPRIETARY</span>\n              </div>\n              <div className=\"h-[2px] w-full bg-white/5 rounded\">\n                <div className=\"h-full w-[80%] bg-gradient-to-r from-[#E4000F] to-[#009DFF]\" />\n              </div>\n            </div>\n          </div>\n\n          <div className=\"space-y-6\">\n            <div className=\"flex justify-center gap-4 border-b border-white/5 pb-2\">\n              {[\"milestones\", \"strategy\"].map((tab) => (\n                <button\n                  key={tab}\n                  onClick={() => setActive(tab as any)}\n                  className={`px-4 py-2 text-[12px] font-mono uppercase tracking-wider transition-all border-b-2 ${\n                    active === tab ? \"text-white border-[#009DFF]\" : \"text-white/40 border-transparent hover:text-white\"\n                  }`}\n                >\n                  {tab === \"milestones\" ? \"Corporate Milestones\" : \"Investment Strategy\"}\n                </button>\n              ))}\n            </div>\n\n            {active === \"milestones\" ? (\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                {phases.map((p, idx) => (\n                  <div key={idx} className=\"p-6 rounded-[24px] border border-white/5 bg-gradient-to-b from-[#08080a] to-[#010101] relative overflow-hidden\">\n                    <span className=\"absolute top-4 right-4 text-[38px] font-mono font-bold leading-none text-white/5\">{p.n}</span>\n                    <h4 className=\"text-[14px] font-semibold text-white tracking-tight mt-2\">{p.t}</h4>\n                    <p className=\"mt-2 text-[12px] leading-relaxed text-white/50 font-light\">{p.d}</p>\n                  </div>\n                ))}\n              </div>\n            ) : (\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                <div className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-2\">\n                  <Globe className=\"w-6 h-6 text-[#009DFF]\" />\n                  <h4 className=\"text-[15px] font-semibold text-white\">Bilateral Stability</h4>\n                  <p className=\"text-[12.5px] text-white/60 font-light font-sans\">We leverage regional localized models conforming fully with sovereign laws to capture geographically locked markets.</p>\n                </div>\n                <div className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-2\">\n                  <Shield className=\"w-6 h-6 text-[#E4000F]\" />\n                  <h4 className=\"text-[15px] font-semibold text-white font-sans\">Sovereign Cloud Alliances</h4>\n                  <p className=\"text-[12.5px] text-white/60 font-light\">By orchestrating on national cloud complexes, we offer hardware decoupling, maximizing our corporate margin structure.</p>\n                </div>\n              </div>\n            )}\n          </div>\n\n          <PremiumCTA\n            title=\"Interested in GFF AI's Corporate Governance?\"\n            description=\"Qualified representatives from strategic allocators, commercial partners, and family offices may request a detailed operational review.\"\n            primaryLabel=\"Connect with IR Desk\"\n            primaryHref=\"mailto:investors@gff.ai\"\n            secondaryLabel=\"Review Privacy Framework\"\n            secondaryHref=\"/privacy\"\n          />\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
