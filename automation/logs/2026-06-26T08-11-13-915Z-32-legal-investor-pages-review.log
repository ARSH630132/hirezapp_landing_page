ct\";\n\nexport default function PrivacyPolicyPage() {\n  const [active, setActive] = useState<\"vpc\" | \"weights\" | \"telemetry\">(\"vpc\");\n\n  const standards = [\n    { label: \"SOC2 TYPE II\", status: \"Certified Audit\", desc: \"Rigorous operational security & data integrity controls.\" },\n    { label: \"GDPR COMPLIANT\", status: \"Fully Localized\", desc: \"No cross-border transfers. Regional cloud enclaves.\" },\n    { label: \"HIPAA SECURE\", status: \"Sovereign BAA\", desc: \"Cryptographic health data protection under enclaves.\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <div className=\"relative overflow-hidden min-h-screen pb-16\">\n        <AnimatedBackgroundGrid />\n\n        <InnerPageHero\n          category=\"Legal & Compliance\"\n          title=\"Privacy & Data Sovereign Policy\"\n          highlightedWord=\"Sovereign\"\n          description=\"Learn how GFF AI enforces cryptographic boundaries, strict tenant decoupling, and SOC2-compliant logging.\"\n        />\n\n        {/* Compliance Bar */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-12 relative z-10\">\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px]\">\n            {standards.map((std, i) => (\n              <div key={i} className=\"flex flex-col border-l border-white/5 pl-4 first:border-0\">\n                <div className=\"flex items-center gap-2\">\n                  <CheckCircle className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  <span className=\"text-[10px] font-mono tracking-[0.1em] text-[#009DFF] uppercase font-bold\">{std.label}</span>\n                </div>\n                <span className=\"text-[13px] text-white font-medium mt-1\">{std.status}</span>\n                <span className=\"text-[11.5px] text-white/55 mt-0.5 font-light\">{std.desc}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Console Section */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-20 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10\">\n          <div className=\"lg:col-span-6 space-y-6\">\n            <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">Interactive Sandbox Console</span>\n            <h2 className=\"text-[24px] sm:text-[32px] font-bold text-white tracking-tight leading-tight\">Inspect Our Decoupling & Isolation</h2>\n            <p className=\"text-[13.5px] leading-[1.6] text-white/70 font-light\">\n              Click the selectors below to inspect how we secure and isolate your valuable enterprise data assets.\n            </p>\n\n            <div className=\"space-y-3 pt-4\">\n              {[\n                { id: \"vpc\", t: \"Cryptographic Sandboxing\", d: \"Enforces virtual private cloud (VPC) isolation with no raw text escape routes.\" },\n                { id: \"weights\", t: \"Model Weight Decoupling\", d: \"Keeps fine-tuning layers stored in private KMS enclaves; never backpropagates.\" },\n                { id: \"telemetry\", t: \"Non-Intrusive Telemetry\", d: \"Streams only resource metrics (CPU, latency). Zero raw payload logging.\" }\n              ].map((tab) => (\n                <button\n                  key={tab.id}\n                  onClick={() => setActive(tab.id as any)}\n                  className={`w-full text-left p-4 rounded-xl border transition-all flex items-start gap-4 ${\n                    active === tab.id ? \"border-white/12 bg-white/[0.04] shadow-lg\" : \"border-white/5 bg-transparent hover:border-white/8\"\n                  }`}\n                >\n                  <div className={`p-2 rounded-lg border ${active === tab.id ? \"bg-[#009DFF]/10 border-[#009DFF]/30 text-[#009DFF]\" : \"bg-white/5 text-white/60\"}`}>\n                    {tab.id === \"vpc\" ? <Shield className=\"w-4 h-4\" /> : tab.id === \"weights\" ? <Lock className=\"w-4 h-4\" /> : <Eye className=\"w-4 h-4\" />}\n                  </div>\n                  <div>\n                    <h4 className=\"text-[14px] font-semibold text-white\">{tab.t}</h4>\n                    <p className=\"text-[12px] text-white/50 mt-1 font-light\">{tab.d}</p>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-6 flex flex-col justify-center\">\n            <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/70 backdrop-blur-[12px] p-6 space-y-6 shadow-2xl relative min-h-[350px] flex flex-col justify-between\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-4\">\n                <div>\n                  <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-widest font-bold\">ACTIVE MODULE</span>\n                  <h3 className=\"text-[15px] font-semibold text-white mt-1 uppercase tracking-tight\">\n                    {active === \"vpc\" ? \"SEC_VPC_ISOLATION\" : active === \"weights\" ? \"SEC_KMS_DECOUPLER\" : \"SEC_ZERO_PAYLOAD\"}\n                  </h3>\n                </div>\n                <span className=\"flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-emerald-400/20 bg-emerald-400/5 text-[9px] font-mono text-emerald-400\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" /> SECURE\n                </span>\n              </div>\n\n              {/* Console Graphic */}\n              <div className=\"flex-grow flex items-center justify-center py-6 min-h-[160px] border border-white/5 rounded-xl bg-black/40\">\n                {active === \"vpc\" ? (\n                  <div className=\"flex items-center gap-8 text-center\">\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-white/5 border border-white/10\">\n                      <Database className=\"w-6 h-6 text-[#009DFF] mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Client DB</span>\n                    </div>\n                    <div className=\"text-[10px] text-white/40 font-mono tracking-widest animate-pulse\">TLS 1.3 SECURE ➔</div>\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-white/5 border border-[#E4000F]/30 shadow-[0_0_15px_rgba(228,0,15,0.1)]\">\n                      <Server className=\"w-6 h-6 text-[#E4000F] mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Isolated Enclave</span>\n                    </div>\n                  </div>\n                ) : active === \"weights\" ? (\n                  <div className=\"flex items-center gap-8 text-center\">\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-white/5 border border-white/10 opacity-60\">\n                      <Cpu className=\"w-6 h-6 text-white/50 mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Base Model</span>\n                    </div>\n                    <div className=\"text-[10px] text-red-500 font-mono uppercase font-bold px-2 py-1 bg-red-950/20 border border-red-900/30 rounded\">Decoupled</div>\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-[#E4000F]/5 border border-[#E4000F]/30\">\n                      <Lock className=\"w-6 h-6 text-[#E4000F] mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Custom Weight KMS</span>\n                    </div>\n                  </div>\n                ) : (\n                  <div className=\"flex items-center gap-8 text-center\">\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-white/5 border border-white/10\">\n                      <Cpu className=\"w-6 h-6 text-[#009DFF] mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Agent Logic</span>\n                    </div>\n                    <div className=\"text-[10px] text-white/40 font-mono\">eBPF Probe ➔</div>\n                    <div className=\"flex flex-col items-center p-3 rounded-lg bg-[#009DFF]/5 border border-[#009DFF]/30\">\n                      <CheckCircle className=\"w-6 h-6 text-emerald-400 mb-1\" />\n                      <span className=\"text-[10px] text-white font-mono\">Uptime / CPU only</span>\n                    </div>\n                  </div>\n                )}\n              </div>\n\n              <div className=\"bg-white/[0.02] border border-white/5 rounded-xl p-4 text-[12.5px] leading-relaxed font-light text-white/70\">\n                {active === \"vpc\" && \"Bespoke network topologies ensure all pipeline steps occur strictly inside isolated execution environments with no outbound WAN escape routes.\"}\n                {active === \"weights\" && \"To isolate cognitive intelligence, custom weights created during training are protected with customer-managed keys (CMK) and never backpropagated.\"}\n                {active === \"telemetry\" && \"Continuous uptime tracking streams metadata parameters only. System prompt texts, contexts, and keys are physically excluded by our kernel level logging probe.\"}\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Framework Section */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-16 relative z-10 border-t border-white/5 pt-16 space-y-16\">\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n            {[\n              { title: \"1. Cryptographic Sandboxing\", subtitle: \"Absolute Tenant Isolation\", desc: \"At GFF AI, client data ingestion is cryptographically sandboxed in designated local containers. We enforce a zero-trust network perimeter. No raw text escapes your VPC configurations.\" },\n              { title: \"2. Model Weight Decoupling\", subtitle: \"Securing Proprietary Logical Core\", desc: \"Your model weights, cognitive adjustments, and blueprints remain yours. Fine-tuning weights in any stage are decoupled and never backpropagated into public base models.\" },\n              { title: \"3. Non-Intrusive Telemetry\", subtitle: \"Zero-Payload Audits\", desc: \"We log structural metrics: CPU loads, active agent latency, and token consumption. We do not log, inspect, or retain prompts, responses, or memory caches, adhering strictly to SOC2.\" }\n            ].map((sect, i) => (\n              <div key={i} className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-4\">\n                <div className=\"p-3 w-fit rounded-xl bg-white/5 border border-white/10 text-[#009DFF]\">\n                  {i === 0 ? <Shield className=\"w-5 h-5 text-[#E4000F]\" /> : i === 1 ? <Lock className=\"w-5 h-5 text-[#009DFF]\" /> : <Eye className=\"w-5 h-5 text-white\" />}\n                </div>\n                <div>\n                  <h3 className=\"text-[16px] font-semibold text-white tracking-tight\">{sect.title}</h3>\n                  <p className=\"text-[11px] text-[#009DFF] tracking-wider font-mono uppercase mt-1\">{sect.subtitle}</p>\n                </div>\n                <p className=\"text-white/70 text-[13.5px] leading-relaxed font-light\">{sect.desc}</p>\n              </div>\n            ))}\n          </div>\n\n          <PremiumCTA\n            title=\"Have custom governance requirements?\"\n            description=\"Our specialized integration architects configure isolated model deployments for global finance, logtech, and healthcare institutions.\"\n            primaryLabel=\"Initiate Security Review\"\n            primaryHref=\"/contact?pathway=governance\"\n            secondaryLabel=\"Explore Architecture Specs\"\n            secondaryHref=\"/resources/architecture-library\"\n          />\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
