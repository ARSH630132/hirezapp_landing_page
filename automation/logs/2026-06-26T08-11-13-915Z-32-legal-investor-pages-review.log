{"ts":"2026-06-26T08:05:50.139Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7ivl65e8","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/privacy/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport AnimatedBackgroundGrid from \"@/components/inner-pages/AnimatedBackgroundGrid\";\nimport { Shield, Lock, Eye, CheckCircle, Database, Network, Cpu, Server } from \"lucide-react\";\n\nexport default function PrivacyPolicyPage() {\n  const [activeTab, setActiveTab] = useState<\"vpc\" | \"weights\" | \"telemetry\">(\"vpc\");\n\n  const complianceStandards = [\n    { label: \"SOC2 TYPE II\", status: \"Certified Audit\", desc: \"Rigorous operational security and data integrity controls.\" },\n    { label: \"GDPR / SOVEREIGNTY\", status: \"Fully Compliant\", desc: \"No cross-border transfers. Regional localized cloud hubs.\" },\n    { label: \"ISO 27001\", status: \"Aligned\", desc: \"Systematic information security management systems.\" },\n    { label: \"HIPAA COMPLIANT\", status: \"Enclaves available\", desc: \"Cryptographic health data protection under BAA.\" }\n  ];\n\n  return (\n    <InnerPageShell>\n      <div className=\"relative overflow-hidden min-h-screen\">\n        {/* Animated grid in the background to provide premium context and luxury SaaS look */}\n        <AnimatedBackgroundGrid />\n\n        <InnerPageHero\n          category=\"Legal & Compliance\"\n          title=\"Privacy & Data Sovereign Policy\"\n          highlightedWord=\"Sovereign\"\n          description=\"Learn how GFF AI enforces cryptographic boundaries, strict tenant decoupling, and SOC2-compliant non-intrusive logging to protect enterprise assets.\"\n        />\n\n        {/* Strategic Compliance Metric Bar */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-12 relative z-10\">\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px]\">\n            {complianceStandards.map((std, i) => (\n              <div key={i} className=\"flex flex-col border-l border-white/5 pl-4 first:border-0\">\n                <div className=\"flex items-center gap-2\">\n                  <CheckCircle className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  <span className=\"text-[10px] font-mono tracking-[0.1em] text-[#009DFF] uppercase font-bold\">{std.label}</span>\n                </div>\n                <span className=\"text-[13px] text-white font-medium mt-1\">{std.status}</span>\n                <span className=\"text-[11.5px] text-white/55 mt-0.5 font-light leading-relaxed\">{std.desc}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Main Content & Interactive Isolation Console */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10\">\n          \n          {/* Left Column: Interactive Visual Selector */}\n          <div className=\"lg:col-span-6 space-y-6 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">Interactive Sandbox Console</span>\n              <h2 className=\"text-[24px] sm:text-[32px] font-bold text-white tracking-tight leading-tight\">\n                Inspect Our Decoupling & Isolation Architecture\n              </h2>\n              <p className=\"text-[13.5px] leading-[1.6] text-white/70 font-light max-w-xl\">\n                At GFF AI, client security is not just an insurance policy—it is hard-coded into the orchestration nodes. Click the quadrants below to see how our systems isolate your valuable data assets.\n              </p>\n            </div>\n\n            {/* Interactive Tab Selectors */}\n            <div className=\"space-y-3 pt-6\">\n              {[\n                {\n                  id: \"vpc\",\n                  icon: <Shield className=\"w-4 h-4\" />,\n                  title: \"Cryptographic Sandboxing\",\n                  desc: \"Enforces virtual private cloud (VPC) isolation with no raw text escape routes.\",\n                },\n                {\n                  id: \"weights\",\n                  icon: <Lock className=\"w-4 h-4\" />,\n                  title: \"Model Weight Decoupling\",\n                  desc: \"Keeps fine-tuning layers stored in private KMS enclaves; never backpropagates to base LLMs.\",\n                },\n                {\n                  id: \"telemetry\",\n                  icon: <Eye className=\"w-4 h-4\" />,\n                  title: \"Non-Intrusive Telemetry\",\n                  desc: \"Streams only resource metrics (CPU, latency). Zero raw payload or context logging.\",\n                }\n              ].map((tab) => (\n                <button\n                  key={tab.id}\n                  onClick={() => setActiveTab(tab.id as any)}\n                  className={`w-full text-left p-4 rounded-xl border transition-all flex items-start gap-4 ${\n                    activeTab === tab.id\n                      ? \"border-white/12 bg-white/[0.04] shadow-lg\"\n                      : \"border-white/5 bg-transparent hover:border-white/8 hover:bg-white/[0.01]\"\n                  }`}\n                >\n                  <div className={`p-2 rounded-lg border transition-colors ${\n                    activeTab === tab.id ? \"bg-[#009DFF]/10 border-[#009DFF]/30 text-[#009DFF]\" : \"bg-white/5 border-white/10 text-white/60\"\n                  }`}>\n                    {tab.icon}\n                  </div>\n                  <div>\n                    <h4 className={`text-[14px] font-semibold transition-colors ${activeTab === tab.id ? \"text-white\" : \"text-white/80\"}`}>{tab.title}</h4>\n                    <p className=\"text-[12px] text-white/50 mt-1 font-light leading-relaxed\">{tab.desc}</p>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Right Column: Visual System Blueprint */}\n          <div className=\"lg:col-span-6 flex flex-col justify-center items-center\">\n            <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/70 backdrop-blur-[12px] p-6 lg:p-8 space-y-6 shadow-2xl relative min-h-[460px] flex flex-col justify-between\">\n              \n              {/* Dynamic Header */}\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-4\">\n                <div>\n                  <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-widest font-bold\">ACTIVE PROTOCOL SEC_MODULE</span>\n                  <h3 className=\"text-[16px] font-semibold text-white mt-1 uppercase tracking-tight\">\n                    {activeTab === \"vpc\" && \"SEC_VPC_ISOLATION_ENGINE\"}\n                    {activeTab === \"weights\" && \"SEC_WEIGHTS_KMS_DECOUPLER\"}\n                    {activeTab === \"telemetry\" && \"SEC_EBPF_ZERO_PAYLOAD_MONITOR\"}\n                  </h3>\n                </div>\n                <div className=\"flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-[#009DFF]/20 bg-[#009DFF]/5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n                  <span className=\"text-[9px] font-mono text-white/60\">ACTIVE</span>\n                </div>\n              </div>\n\n              {/* Dynamic SVG Architectures depending on selection */}\n              <div className=\"flex-grow flex items-center justify-center py-6 min-h-[220px]\">\n                {activeTab === \"vpc\" && (\n                  <svg className=\"w-full max-w-[400px] h-[220px]\" viewBox=\"0 0 400 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    {/* Outer VPC Boundary */}\n                    <rect x=\"10\" y=\"10\" width=\"380\" height=\"200\" rx=\"16\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" className=\"opacity-70\" />\n                    <text x=\"25\" y=\"28\" fill=\"#009DFF\" fontSize=\"9\" fontWeight=\"bold\" fontFamily=\"monospace\">ENTERPRISE CLOUD VPC BOUNDARY</text>\n\n                    {/* Data Source */}\n                    <rect x=\"40\" y=\"80\" width=\"80\" height=\"50\" rx=\"8\" fill=\"#0c0c0e\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1.5\" />\n                    <Database className=\"w-4 h-4 text-white/50 absolute\" style={{ transform: \"translate(72px, 92px)\" }} />\n                    <text x=\"80\" y=\"122\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Client Database</text>\n\n                    {/* Enclave Container */}\n                    <rect x=\"250\" y=\"60\" width=\"110\" height=\"90\" rx=\"12\" fill=\"#0A0A0C\" stroke=\"#E4000F\" strokeWidth=\"1.5\" />\n                    <Server className=\"w-4 h-4 text-[#E4000F] absolute\" style={{ transform: \"translate(295px, 80px)\" }} />\n                    <text x=\"305\" y=\"112\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">GFF Enclave</text>\n                    <text x=\"305\" y=\"128\" fill=\"white\" opacity=\"0.5\" fontSize=\"7\" textAnchor=\"middle\">SOC2 Decoupled Node</text>\n\n                    {/* Encrypted flow paths */}\n                    <path d=\"M120 105 L250 105\" stroke=\"#009DFF\" strokeWidth=\"1.5\" strokeDasharray=\"3 3\" />\n                    <polygon points=\"120,105 130,100 130,110\" fill=\"#009DFF\" />\n                    <polygon points=\"250,105 240,100 240,110\" fill=\"#009DFF\" />\n\n                    <rect x=\"145\" y=\"85\" width=\"80\" height=\"20\" rx=\"4\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"185\" y=\"98\" fill=\"white\" opacity=\"0.6\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">TLS 1.3 / ENCRYPTED</text>\n                  </svg>\n                )}\n\n                {activeTab === \"weights\" && (\n                  <svg className=\"w-full max-w-[400px] h-[220px]\" viewBox=\"0 0 400 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    {/* Core Shared Model (Left) */}\n                    <rect x=\"30\" y=\"70\" width=\"90\" height=\"70\" rx=\"12\" fill=\"#0A0A0C\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                    <Cpu className=\"w-4 h-4 text-white/40 absolute\" style={{ transform: \"translate(65px, 85px)\" }} />\n                    <text x=\"75\" y=\"120\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Base LLM Core</text>\n                    <text x=\"75\" y=\"132\" fill=\"white\" opacity=\"0.4\" fontSize=\"7\" textAnchor=\"middle\">Read-Only Weights</text>\n\n                    {/* Isolated KMS Vault (Right) */}\n                    <rect x=\"250\" y=\"55\" width=\"120\" height=\"100\" rx=\"16\" fill=\"none\" stroke=\"#E4000F\" strokeWidth=\"1.5\" />\n                    <rect x=\"260\" y=\"65\" width=\"100\" height=\"80\" rx=\"10\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <Lock className=\"w-4 h-4 text-[#E4000F] absolute\" style={{ transform: \"translate(300px, 80px)\" }} />\n                    <text x=\"310\" y=\"118\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Custom Fine-Tuning</text>\n                    <text x=\"310\" y=\"130\" fill=\"#E4000F\" fontSize=\"8\" textAnchor=\"middle\" fontFamily=\"monospace\" fontWeight=\"bold\">KMS ENCRYPTED</text>\n\n                    {/* Severed flow path */}\n                    <path d=\"M120 105 L250 105\" stroke=\"#FF5555\" strokeWidth=\"1\" strokeDasharray=\"5 5\" />\n                    <line x1=\"180\" y1=\"95\" x2=\"190\" y2=\"115\" stroke=\"#E4000F\" strokeWidth=\"2\" />\n                    <line x1=\"190\" y1=\"95\" x2=\"180\" y2=\"115\" stroke=\"#E4000F\" strokeWidth=\"2\" />\n                    \n                    <rect x=\"145\" y=\"125\" width=\"80\" height=\"18\" rx=\"4\" fill=\"#E4000F\" fillOpacity=\"0.05\" stroke=\"#E4000F\" strokeOpacity=\"0.2\" strokeWidth=\"1\" />\n                    <text x=\"185\" y=\"137\" fill=\"#E4000F\" fontSize=\"7\" textAnchor=\"middle\" fontWeight=\"bold\">NO BACKPROPAGATION</text>\n                  </svg>\n                )}\n\n                {activeTab === \"telemetry\" && (\n                  <svg className=\"w-full max-w-[400px] h-[220px]\" viewBox=\"0 0 400 220\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    {/* Execution Stack */}\n                    <rect x=\"20\" y=\"40\" width=\"120\" height=\"130\" rx=\"12\" fill=\"#0A0A0C\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                    <text x=\"80\" y=\"60\" fill=\"white\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\">Agent Execution</text>\n                    \n                    <rect x=\"30\" y=\"75\" width=\"100\" height=\"20\" rx=\"4\" fill=\"#E4000F\" fillOpacity=\"0.1\" stroke=\"#E4000F\" strokeOpacity=\"0.3\" strokeWidth=\"1\" />\n                    <text x=\"80\" y=\"88\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">Prompt Payload</text>\n\n                    <rect x=\"30\" y=\"105\" width=\"100\" height=\"20\" rx=\"4\" fill=\"#009DFF\" fillOpacity=\"0.1\" stroke=\"#009DFF\" strokeOpacity=\"0.3\" strokeWidth=\"1\" />\n                    <text x=\"80\" y=\"118\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">Execution Context</text>\n\n                    <rect x=\"30\" y=\"135\" width=\"100\" height=\"20\" rx=\"4\" fill=\"#22C55E\" fillOpacity=\"0.1\" stroke=\"#22C55E\" strokeOpacity=\"0.3\" strokeWidth=\"1\" />\n                    <text x=\"80\" y=\"148\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\">Active Output Token</text>\n\n                    {/* Telemetry Target */}\n                    <rect x=\"270\" y=\"65\" width=\"110\" height=\"80\" rx=\"12\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1.5\" />\n                    <text x=\"325\" y=\"85\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">GFF Audit Logs</text>\n                    <text x=\"325\" y=\"105\" fill=\"#009DFF\" fontSize=\"12\" textAnchor=\"middle\" fontWeight=\"bold\">CPU & LATENCY</text>\n                    <text x=\"325\" y=\"125\" fill=\"#22C55E\" fontSize=\"9\" textAnchor=\"middle\" fontFamily=\"monospace\">99.99% OK</text>\n\n                    {/* eBPF Probe bridge */}\n                    <path d=\"M140 145 L210 145 L210 105 L270 105\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n                    <circle cx=\"210\" cy=\"145\" r=\"4\" fill=\"#009DFF\" />\n                    \n                    <rect x=\"150\" y=\"160\" width=\"110\" height=\"18\" rx=\"4\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"205\" y=\"172\" fill=\"white\" opacity=\"0.6\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">eBPF KERNEL FILTER (METADATA ONLY)</text>\n                  </svg>\n                )}\n              </div>\n\n              {/* Dynamic Bottom Stats */}\n              <div className=\"bg-white/[0.02] border border-white/5 rounded-xl p-4\">\n                <p className=\"text-white/80 text-[12.5px] leading-relaxed font-light\">\n                  {activeTab === \"vpc\" && \"Bespoke network topologies ensure all pipeline steps—including vector indexing and document scraping—occur strictly inside isolated execution environments with no outbound WAN escape routes.\"}\n                  {activeTab === \"weights\" && \"To isolate cognitive intelligence, custom weights created during reinforcement learning feedback are protected with customer-managed keys (CMK) and never backpropagated to standard production LLMs.\"}\n                  {activeTab === \"telemetry\" && \"Continuous uptime tracking streams metadata parameters only. System prompt texts, user contexts, and vector search keys are physically excluded by our kernel level logging probe.\"}\n                </p>\n              </div>\n\n            </div>\n          </div>\n\n        </div>\n\n        {/* Detailed Sections (Replacing previous boring content with deep, well-spaced structures) */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 relative z-10 space-y-16\">\n          <div className=\"border-t border-white/5 pt-16\">\n            <h2 className=\"text-[22px] sm:text-[28px] font-bold text-white tracking-tight mb-8\">Full Sovereignty Framework</h2>\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n              {[\n                {\n                  title: \"1. Cryptographic Sandboxing\",\n                  subtitle: \"Absolute Tenant Isolation Protocols\",\n                  text: \"At GFF AI, client data ingestion is cryptographically sandboxed in designated local containers. We enforce a zero-trust network perimeter. No raw text, structured files, or vector embeddings escape your approved virtual private cloud (VPC) configurations.\"\n                },\n                {\n                  title: \"2. Model Weight Decoupling\",\n                  subtitle: \"Securing Proprietary Logical Core\",\n                  text: \"Your model weights, cognitive adjustments, and system blueprints remain exclusively yours. Custom fine-tuning weights operating in the Garage, Foundry, or Factory stages are completely decoupled and are never backpropagated into our public base models.\"\n                },\n                {\n                  title: \"3. Non-Intrusive Telemetry\",\n                  subtitle: \"Zero-Payload Operational Audit Logging\",\n                  text: \"To power real-time client dashboards, we log structural metrics: CPU loads, active agent latency, and token consumption. GFF AI does not log, inspect, or retain prompts, responses, execution contexts, or memory caches, adhering strictly to SOC2.\"\n                }\n              ].map((sect, i) => (\n                <div key={i} className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-4\">\n                  <div className=\"p-3 w-fit rounded-xl bg-white/5 border border-white/10\">\n                    {i === 0 && <Shield className=\"w-5 h-5 text-[#E4000F]\" />}\n                    {i === 1 && <Lock className=\"w-5 h-5 text-[#009DFF]\" />}\n                    {i === 2 && <Eye className=\"w-5 h-5 text-white\" />}\n                  </div>\n                  <div>\n                    <h3 className=\"text-[16px] font-semibold text-white tracking-tight\">{sect.title}</h3>\n                    <p className=\"text-[11px] text-[#009DFF] tracking-wider font-mono uppercase mt-1\">{sect.subtitle}</p>\n                  </div>\n                  <p className=\"text-white/70 text-[13.5px] leading-relaxed font-light font-sans\">{sect.text}</p>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          <PremiumCTA\n            title=\"Have custom governance requirements?\"\n            description=\"Our specialized integration architects regularly configure bespoke isolated model deployments for global finance, logtech, and healthcare institutions.\"\n            primaryLabel=\"Initiate Security Review\"\n            primaryHref=\"/contact?pathway=governance\"\n            secondaryLabel=\"Explore Architecture Specs\"\n            secondaryHref=\"/resources/architecture-library\"\n          />\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
