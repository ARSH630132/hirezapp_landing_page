{"ts":"2026-06-26T08:07:21.625Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"jz945ymv","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/privacy/page.tsx","old_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport { Shield, Lock, Eye } from \"lucide-react\";\n\nexport default function PrivacyPolicyPage() {\n  const [activeTab, setActiveTab] = useState(\"telemetry\");\n  const [activeSec, setActiveSec] = useState(\"sec-1\");\n\n  const sections = [\n    {\n      id: \"sec-1\",\n      icon: <Shield className=\"w-4 h-4 text-[#E4000F]\" />,\n      title: \"1. Cryptographic Sandboxing\",\n      subtitle: \"Absolute Tenant Isolation Protocols\",\n      text: \"At GFF AI, client data ingestion is cryptographically sandboxed in designated local containers. We enforce a zero-trust network perimeter. No raw text, structured files, or vector embeddings escape your approved virtual private cloud (VPC) configurations.\"\n    },\n    {\n      id: \"sec-2\",\n      icon: <Lock className=\"w-4 h-4 text-[#009DFF]\" />,\n      title: \"2. Model Weight Decoupling\",\n      subtitle: \"Securing Proprietary Logical Core\",\n      text: \"Your model weights, cognitive adjustments, and system blueprints remain exclusively yours. Custom fine-tuning weights operating in the Garage, Foundry, or Factory stages are completely decoupled and are never backpropagated into our public base models.\"\n    },\n    {\n      id: \"sec-3\",\n      icon: <Eye className=\"w-4 h-4 text-white\" />,\n      title: \"3. Non-Intrusive Telemetry\",\n      subtitle: \"Zero-Payload Operational Audit Logging\",\n      text: \"To power real-time client dashboards, we log structural metrics: CPU loads, active agent latency, and token consumption. GFF AI does not log, inspect, or retain prompts, responses, execution contexts, or memory caches, adhering strictly to SOC2.\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Legal & Compliance\"\n        title=\"Privacy & Data Sovereign Policy\"\n        highlightedWord=\"Sovereign\"\n        description=\"Learn how GFF AI enforces cryptographic boundaries, strict tenant decoupling, and SOC2-compliant non-intrusive logging to protect enterprise assets.\"\n      />\n\n      <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10\">\n        <aside className=\"lg:col-span-4 hidden lg:block\">\n          <div className=\"sticky top-[110px] p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] space-y-4\">\n            <div className=\"text-[10px] font-mono uppercase tracking-[0.15em] text-white/40\">Sections Index</div>\n            <nav className=\"space-y-1.5\">\n              {sections.map((sect) => (\n                <button\n                  key={sect.id}\n                  onClick={() => {\n                    const el = document.getElementById(sect.id);\n                    if (el) window.scrollTo({ top: el.offsetTop - 110, behavior: \"smooth\" });\n                    setActiveSec(sect.id);\n                  }}\n                  className={`w-full flex items-center gap-3 text-left py-2 px-3 rounded-lg text-[13px] transition-all ${\n                    activeSec === sect.id ? \"text-[#009DFF] bg-[#009DFF]/5 font-medium border-l border-[#009DFF]\" : \"text-white/50 hover:text-white\"\n                  }`}\n                >\n                  {sect.icon}\n                  <span className=\"truncate\">{sect.title.substring(3)}</span>\n                </button>\n              ))}\n            </nav>\n          </div>\n        </aside>\n\n        <main className=\"lg:col-span-8 space-y-8\