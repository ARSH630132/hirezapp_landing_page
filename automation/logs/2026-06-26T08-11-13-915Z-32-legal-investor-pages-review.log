>\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 p-6 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px]\">\n            {complianceStandards.map((std, i) => (\n              <div key={i} className=\"flex flex-col border-l border-white/5 pl-4 first:border-0\">\n                <div className=\"flex items-center gap-2\">\n                  <CheckCircle className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  <span className=\"text-[10px] font-mono tracking-[0.1em] text-[#009DFF] uppercase font-bold\">{std.label}</span>\n                </div>\n                <span className=\"text-[13px] text-white font-medium mt-1\">{std.status}</span>\n                <span className=\"text-[11.5px] text-white/55 mt-0.5 font-light leading-relaxed\">{std.desc}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Main Content & Interactive Isolation Console */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10\">\n          \n          {/* Left Column: Interactive Visual Selector */}\n          <div className=\"lg:col-span-6 space-y-6 flex flex-col justify-between\">\n            <div className=\"space-y-4\">\n              <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#E4000F] uppercase font-bold\">Interactive Sandbox Console</span>\n              <h2 className=\"text-[24px] sm:text-[32px] font-bold text-white tracking-tight leading-tight\">\n                Inspect Our Decoupling & Isolation Architecture\n              </h2>\n              <p className=\"text-[13.5px] leading-[1.6] text-white/70 font-light max-w-xl\">\n                At GFF AI, client security is not just an insurance policy—it is hard-coded into the orchestration nodes. Click the quadrants below to see how our systems isolate your valuable data assets.\n              </p>\n            </div>\n\n            {/* Interactive Tab Selectors */}\n            <div className=\"space-y-3 pt-6\">\n              {[\n                { id: \"vpc\", icon: <Shield className=\"w-4 h-4\" />, title: \"Cryptographic Sandboxing\", desc: \"Enforces virtual private cloud (VPC) isolation with no raw text escape routes.\" },\n                { id: \"weights\", icon: <Lock className=\"w-4 h-4\" />, title: \"Model Weight Decoupling\", desc: \"Keeps fine-tuning layers stored in private KMS enclaves; never backpropagates.\" },\n                { id: \"telemetry\", icon: <Eye className=\"w-4 h-4\" />, title: \"Non-Intrusive Telemetry\", desc: \"Streams only resource metrics (CPU, latency). Zero raw payload logging.\" }\n              ].map((tab) => (\n                <button\n                  key={tab.id}\n                  onClick={() => setActiveTab(tab.id as any)}\n                  className={`w-full text-left p-4 rounded-xl border transition-all flex items-start gap-4 ${\n                    activeTab === tab.id\n                      ? \"border-white/12 bg-white/[0.04] shadow-lg\"\n                      : \"border-white/5 bg-transparent hover:border-white/8 hover:bg-white/[0.01]\"\n                  }`}\n                >\n                  <div className={`p-2 rounded-lg border transition-colors ${\n                    activeTab === tab.id ? \"bg-[#009DFF]/10 border-[#009DFF]/30 text-[#009DFF]\" : \"bg-white/5 border-white/10 text-white/60\"\n                  }`}>\n                    {tab.icon}\n                  </div>\n                  <div>\n                    <h4 className={`text-[14px] font-semibold transition-colors ${activeTab === tab.id ? \"text-white\" : \"text-white/80\"}`}>{tab.title}</h4>\n                    <p className=\"text-[12px] text-white/50 mt-1 font-light leading-relaxed\">{tab.desc}</p>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Right Column: Visual System Blueprint */}\n          <div className=\"lg:col-span-6 flex flex-col justify-center items-center\">\n            <div className=\"w-full rounded-[24px] border border-white/5 bg-[#050505]/70 backdrop-blur-[12px] p-6 lg:p-8 space-y-6 shadow-2xl relative min-h-[420px] flex flex-col justify-between\">\n              \n              <div className=\"flex items-center justify-between border-b border-white/5 pb-4\">\n                <div>\n                  <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-widest font-bold font-semibold\">ACTIVE MODULE</span>\n                  <h3 className=\"text-[15px] font-semibold text-white mt-1 uppercase tracking-tight\">\n                    {activeTab === \"vpc\" ? \"SEC_VPC_ISOLATION_ENGINE\" : activeTab === \"weights\" ? \"SEC_WEIGHTS_KMS_DECOUPLER\" : \"SEC_ZERO_PAYLOAD_MONITOR\"}\n                  </h3>\n                </div>\n                <div className=\"flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-[#009DFF]/20 bg-[#009DFF]/5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n                  <span className=\"text-[9px] font-mono text-white/60\">ONLINE</span>\n                </div>\n              </div>\n\n              {/* Dynamic SVG Blueprint */}\n              <div className=\"flex-grow flex items-center justify-center py-4 min-h-[200px]\">\n                {activeTab === \"vpc\" ? (\n                  <svg className=\"w-full max-w-[360px] h-[180px]\" viewBox=\"0 0 360 180\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <rect x=\"5\" y=\"5\" width=\"350\" height=\"170\" rx=\"12\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"3 3\" className=\"opacity-50\" />\n                    <rect x=\"25\" y=\"65\" width=\"80\" height=\"50\" rx=\"6\" fill=\"#0A0A0C\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"65\" y=\"95\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Client DB</text>\n                    <rect x=\"245\" y=\"55\" width=\"90\" height=\"70\" rx=\"10\" fill=\"#0A0A0C\" stroke=\"#E4000F\" strokeWidth=\"1\" />\n                    <text x=\"290\" y=\"95\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">GFF Enclave</text>\n                    <path d=\"M105 90 L245 90\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"2 2\" />\n                    <polygon points=\"105,90 115,86 115,94\" fill=\"#009DFF\" />\n                    <polygon points=\"245,90 235,86 235,94\" fill=\"#009DFF\" />\n                    <rect x=\"130\" y=\"75\" width=\"90\" height=\"15\" rx=\"3\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"175\" y=\"85\" fill=\"white\" opacity=\"0.6\" fontSize=\"7\" textAnchor=\"middle\" fontFamily=\"monospace\">TLS 1.3 SECURE</text>\n                  </svg>\n                ) : activeTab === \"weights\" ? (\n                  <svg className=\"w-full max-w-[360px] h-[180px]\" viewBox=\"0 0 360 180\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <rect x=\"25\" y=\"55\" width=\"85\" height=\"70\" rx=\"10\" fill=\"#0A0A0C\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"67\" y=\"95\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Base LLM</text>\n                    <rect x=\"245\" y=\"45\" width=\"95\" height=\"90\" rx=\"12\" fill=\"none\" stroke=\"#E4000F\" strokeWidth=\"1\" />\n                    <rect x=\"252\" y=\"52\" width=\"81\" height=\"76\" rx=\"8\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"292\" y=\"95\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Private Weights</text>\n                    <path d=\"M110 90 L245 90\" stroke=\"#FF5555\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n                    <line x1=\"172\" y1=\"80\" x2=\"182\" y2=\"100\" stroke=\"#E4000F\" strokeWidth=\"2\" />\n                    <line x1=\"182\" y1=\"80\" x2=\"172\" y2=\"100\" stroke=\"#E4000F\" strokeWidth=\"2\" />\n                    <text x=\"177\" y=\"120\" fill=\"#E4000F\" fontSize=\"7\" textAnchor=\"middle\" fontWeight=\"bold\">DECOUPLED</text>\n                  </svg>\n                ) : (\n                  <svg className=\"w-full max-w-[360px] h-[180px]\" viewBox=\"0 0 360 180\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <rect x=\"15\" y=\"35\" width=\"110\" height=\"110\" rx=\"10\" fill=\"#0A0A0C\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"70\" y=\"55\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">Execution Stack</text>\n                    <rect x=\"25\" y=\"70\" width=\"90\" height=\"18\" rx=\"3\" fill=\"#E4000F\" fillOpacity=\"0.1\" stroke=\"#E4000F\" strokeOpacity=\"0.2\" />\n                    <text x=\"70\" y=\"81\" fill=\"white\" opacity=\"0.7\" fontSize=\"7\" textAnchor=\"middle\">Prompt Payload</text>\n                    <rect x=\"25\" y=\"100\" width=\"90\" height=\"18\" rx=\"3\" fill=\"#009DFF\" fillOpacity=\"0.1\" stroke=\"#009DFF\" strokeOpacity=\"0.2\" />\n                    <text x=\"70\" y=\"111\" fill=\"white\" opacity=\"0.7\" fontSize=\"7\" textAnchor=\"middle\">Active Output</text>\n                    <rect x=\"250\" y=\"55\" width=\"95\" height=\"70\" rx=\"10\" fill=\"#050505\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n                    <text x=\"297\" y=\"85\" fill=\"white\" fontSize=\"9\" textAnchor=\"middle\" fontWeight=\"bold\">GFF Audit Logs</text>\n                    <text x=\"297\" y=\"105\" fill=\"#009DFF\" fontSize=\"10\" textAnchor=\"middle\" fontWeight=\"bold\" fontFamily=\"monospace\">CPU / LATENCY</text>\n                    <path d=\"M125 110 L190 110 L190 90 L250 90\" stroke=\"#009DFF\" strokeWidth=\"1\" />\n                    <text x=\"190\" y=\"135\" fill=\"white\" opacity=\"0.5\" fontSize=\"6.5\" textAnchor=\"middle\" fontFamily=\"monospace\">eBPF FILTER</text>\n                  </svg>\n                )}\n              </div>\n\n              {/* Dynamic Bottom Description */}\n              <div className=\"bg-white/[0.02] border border-white/5 rounded-xl p-4 text-[12.5px] leading-relaxed font-light text-white/70\">\n                {activeTab === \"vpc\" && \"Bespoke network topologies ensure all pipeline steps—including vector indexing and document scraping—occur strictly inside isolated execution environments with no outbound WAN escape routes.\"}\n                {activeTab === \"weights\" && \"To isolate cognitive intelligence, custom weights created during reinforcement learning feedback are protected with customer-managed keys (CMK) and never backpropagated to standard production LLMs.\"}\n                {activeTab === \"telemetry\" && \"Continuous uptime tracking streams metadata parameters only. System prompt texts, user contexts, and vector search keys are physically excluded by our kernel level logging probe.\"}\n              </div>\n\n            </div>\n          </div>\n\n        </div>\n\n        {/* Detailed Sections */}\n        <div className=\"max-w-[1400px] mx-auto px-6 lg:px-12 pb-24 relative z-10 space-y-16\">\n          <div className=\"border-t border-white/5 pt-16\">\n            <h2 className=\"text-[22px] sm:text-[28px] font-bold text-white tracking-tight mb-8\">Full Sovereignty Framework</h2>\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n              {[\n                {\n                  title: \"1. Cryptographic Sandboxing\",\n                  subtitle: \"Absolute Tenant Isolation\",\n                  text: \"At GFF AI, client data ingestion is cryptographically sandboxed in designated local containers. We enforce a zero-trust network perimeter. No raw text, structured files, or vector embeddings escape your approved virtual private cloud (VPC) configurations.\"\n                },\n                {\n                  title: \"2. Model Weight Decoupling\",\n                  subtitle: \"Securing Proprietary Logical Core\",\n                  text: \"Your model weights, cognitive adjustments, and system blueprints remain exclusively yours. Custom fine-tuning weights operating in the Garage, Foundry, or Factory stages are completely decoupled and are never backpropagated into our public base models.\"\n                },\n                {\n                  title: \"3. Non-Intrusive Telemetry\",\n                  subtitle: \"Zero-Payload Audits\",\n                  text: \"To power real-time client dashboards, we log structural metrics: CPU loads, active agent latency, and token consumption. GFF AI does not log, inspect, or retain prompts, responses, execution contexts, or memory caches, adhering strictly to SOC2.\"\n                }\n              ].map((sect, i) => (\n                <div key={i} className=\"p-6 rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] space-y-4\">\n                  <div className=\"p-3 w-fit rounded-xl bg-white/5 border border-white/10\">\n                    {i === 0 && <Shield className=\"w-5 h-5 text-[#E4000F]\" />}\n                    {i === 1 && <Lock className=\"w-5 h-5 text-[#009DFF]\" />}\n                    {i === 2 && <Eye className=\"w-5 h-5 text-white\" />}\n                  </div>\n                  <div>\n                    <h3 className=\"text-[16px] font-semibold text-white tracking-tight\">{sect.title}</h3>\n                    <p className=\"text-[11px] text-[#009DFF] tracking-wider font-mono uppercase mt-1\">{sect.subtitle}</p>\n                  </div>\n                  <p className=\"text-white/70 text-[13.5px] leading-relaxed font-light font-sans\">{sect.text}</p>\n                </div>\n              ))}\n            </div>\n          </div>\n\n          <PremiumCTA\n            title=\"Have custom governance requirements?\"\n            description=\"Our specialized integration architects regularly configure bespoke isolated model deployments for global finance, logtech, and healthcare institutions.\"\n            primaryLabel=\"Initiate Security Review\"\n            primaryHref=\"/contact?pathway=governance\"\n            secondaryLabel=\"Explore Architecture Specs\"\n            secondaryHref=\"/resources/architecture-library\"\n          />\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
