ted successfully\",\n122 |   \"module\": \"handshake\"\n123 | }\n124 | ```\n125 | **Response (201 Created)**:\n126 | ```json\n127 | {\n128 |   \"id\": 1,\n129 |   \"level\": \"INFO\",\n130 |   \"message\": \"Next.js frontend handshake completed successfully\",\n131 |   \"module\": \"handshake\",\n132 |   \"created_at\": \"2026-06-27T15:10:00.000000\"\n133 | }\n134 | ```","success":true}],"durationMs":5}}
