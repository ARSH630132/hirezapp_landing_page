n 84 |               <span className=\"text-[10px] font-mono text-[#E4000F] uppercase block mb-2\">Semantic Router</span>\n 85 |               <p className=\"text-[11px] text-white/50 leading-relaxed\">Validates and routes query intent to sandboxed context sheets.</p>\n 86 |             </div>\n 87 |             <div className=\"p-4 rounded-xl border border-white/5 bg-black/40\">\n 88 |               <span className=\"text-[10px] font-mono text-[#009DFF] uppercase block mb-2\">Secure API Dispatch</span>\n 89 |               <p className=\"text-[11px] text-white/50 leading-relaxed\">Human-approved webhooks for legacy back-office actions.</p>\n 90 |             </div>\n 91 |           </div>\n 92 |         </div>\n 93 |       </div>\n 94 | \n 95 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n 96 |         <h2 className=\"text-2xl font-bold text-white mb-6\">Active Agent Blueprints</h2>\n 97 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\n 98 |           {AGENTS.map((a, i) => (\n 99 |             <div key={i} className=\"p-5 rounded-2xl border border-white/5 bg-[#050507]/60\">\n100 |               <h3 className=\"text-xs font-mono font-bold text-[#009DFF] uppercase\">{a.name}</h3>\n101 |               <p className=\"text-xs text-white/60 mt-2 leading-relaxed\">{a.role}</p>\n102 |             </div>\n103 |           ))}\n104 |         </div>\n105 |       </div>\n106 | \n107 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n108 |         <div className=\"lg:col-span-6\">\n109 |           <h2 className=\"text-2xl font-bold text-white mb-4\">Interactive Knowledge Sandbox</h2>\n110 |           <p className=\"text-xs text-white/60 leading-relaxed mb-6\">\n111 |             Test the Banking Knowledge Agent below by executing sample operational or document-audit tasks.\n112 |           </p>\n113 |           <div className=\"flex gap-3\">\n114 |             <butt