{"ts":"2026-06-26T01:03:24.254Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ejvpwcry","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/industries/audit/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport Carousel from \"@/components/inner-pages/Carousel\";\n\nconst CHALLENGES = [\n  { title: \"Evidence Collection\", desc: \"Digesting heterogeneous document trails, transactional logs, and system snapshots across isolated ledger networks.\" },\n  { title: \"Documentation Review\", desc: \"Sifting through dynamic checklists and operational folders without single-schema formats.\" },\n  { title: \"Risk Assessment\", desc: \"Analyzing transaction records and identifying anomalous pattern gaps retroactively.\" },\n  { title: \"Workflow Consistency\", desc: \"Standardizing review parameters across international offices and complex client portfolios.\" },\n  { title: \"Knowledge Retrieval\", desc: \"Accessing internal auditing guidance, GAAP/IFRS standards, and historical sample reports.\" }\n];\n\nconst AGENTS = [\n  { name: \"Evidence Review Agent\", role: \"Aggregates, categorizes, and indexes unstructured evidence records in isolated memory sandboxes.\" },\n  { name: \"Audit Knowledge Assistant\", role: \"Retrieves context and references from global GAAP/IFRS standards and tax code registries.\" },\n  { name: \"Risk Review Agent\", role: \"Scans compiled ledger items and indexes anomaly flags for human-in-the-loop review.\" }\n];\n\nexport default function AuditPage() {\n  const [demoOutput, setDemoOutput] = useState(\"System ready. Select an operational query below to simulate.\");\n  const [running, setRunning] = useState(false);\n  const [activeTab, setActiveTab] = useState(\"cognitive\");\n\n  const runDemo = (type: \"evidence\" | \"gaap\") => {\n    setRunning(true);\n    if (type === \"evidence\") {\n      setDemoOutput(\"Evidence Review: Digesting unstructured client evidence files inside secure sandboxed container...\");\n      setTimeout(() => {\n        setDemoOutput(\"SUCCESS: Digested 25 client files in 420ms. Classified 12 bank statements, 8 invoices, 5 lease contracts. Zero data leaks, metadata logged to immutable registry.\");\n        setRunning(false);\n      }, 700);\n    } else {\n      setDemoOutput(\"GAAP Check: Scanning transaction data against lease classification codes (ASC 842)...\");\n      setTimeout(() => {\n        setDemoOutput(\"RESULT: Check complete. Lease term matches criteria. Flagged 1 minor classification anomaly on rent schedule page 4. Reference: GAAP ASC-842-10.\");\n        setRunning(false);\n      }, 700);\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Vertical Solutions\"\n        title=\"Enterprise Audit Cognitive Infrastructure\"\n        highlightedWord=\"Audit\"\n        description=\"Deploy secure, read-only sovereign agent systems over isolated registries to augment professional audit workflows without compromising compliance or data ownership.\"\n        breadcrumbs={[{ label: \"Industries\", href: \"/industries\" }, { label: \"Audit\" }]}\n      />\n\n      {/* Challenge Landscape */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n        <h2 className=\"text-2xl font-bold text-white mb-6\">Challenge Landscape</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n          {CHALLENGES.map((c, i) => (\n            <div key={i} className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60 hover:border-white/10 transition-colors\">\n              <span className=\"text-[#E4000F] font-mono text-xs block mb-2\">0{i+1} {\"//\"} {c.title}</span>\n              <p className=\"text-xs text-white/60 leading-relaxed\">{c.desc}</p>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Reference Architecture & SVG */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\">\n        <div className=\"lg:col-span-5 flex flex-col justify-between\">\n          <div>\n            <h2 className=\"text-2xl font-bold text-white mb-4\">Reference Architecture</h2>\n            <p className=\"text-xs text-white/70 leading-relaxed mb-6\">\n              Our professional services architecture decouples customer document networks from model endpoints, deploying isolated memory sandboxes that function strictly in read-only configurations.\n            </p>\n            \n            <div className=\"space-y-2 mb-6\">\n              <button\n                onClick={() => setActiveTab(\"ingestion\")}\n                className={`w-full p-3.5 rounded-xl text-left border text-xs font-semibold transition-all ${\n                  activeTab === \"ingestion\" ? \"bg-white/5 border-white/15 text-white\" : \"border-transparent text-white/50 hover:text-white\"\n                }`}\n              >\n                1. Secure Document & Evidence Ingestion\n              </button>\n              <button\n                onClick={() => setActiveTab(\"cognitive\")}\n                className={`w-full p-3.5 rounded-xl text-left border text-xs font-semibold transition-all ${\n                  activeTab === \"cognitive\" ? \"bg-white/5 border-white/15 text-white\" : \"border-transparent text-white/50 hover:text-white\"\n                }`}\n              >\n                2. Sandboxed Cognitive Verification Layer\n              </button>\n              <button\n                onClick={() => setActiveTab(\"registry\")}\n                className={`w-full p-3.5 rounded-xl text-left border text-xs font-semibold transition-all ${\n                  activeTab === \"registry\" ? \"bg-white/5 border-white/15 text-white\" : \"border-transparent text-white/50 hover:text-white\"\n                }`}\n              >\n                3. Immutable Operational Logging & Registry\n              </button>\n            </div>\n          </div>\n\n          <div className=\"p-5 rounded-xl border border-white/5 bg-black/40\">\n            <h4 className=\"text-xs font-bold text-white uppercase mb-2\">\n              {activeTab === \"ingestion\" && \"Sovereign Raw Data Sync\"}\n              {activeTab === \"cognitive\" && \"Sovereign Cognitive Sandbox\"}\n              {activeTab === \"registry\" && \"Verified Metadata Ledger\"}\n            </h4>\n            <p className=\"text-xs text-white/60 leading-relaxed\">\n              {activeTab === \"ingestion\" && \"Direct read-only mirrors secure customer folders. No raw files are ever cached in public models or external vectors.\"}\n              {activeTab === \"cognitive\" && \"Agents execute on ephemeral worker instances. Memory buffers are fully cleared immediately upon audit session termination.\"}\n              {activeTab === \"registry\" && \"Metadata signatures and step verification trails are committed to an isolated database for human audit and review.\"}\n            </p>\n          </div>\n        </div>\n\n        <div className=\"lg:col-span-7 p-6 rounded-2xl border border-white/5 bg-[#050507]/40 backdrop-blur-[12px] flex flex-col items-center justify-center\">\n          <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest mb-6\">Interactive Audit Architecture Blueprint</span>\n          <div className=\"w-full max-w-[440px] h-[300px] relative\">\n            <svg className=\"w-full h-full\" viewBox=\"0 0 500 340\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n              <path d=\"M250 40 L250 110 M250 150 L250 200 M250 240 L250 290\" stroke=\"url(#pipeGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"6 4\" />\n              \n              <g onClick={() => setActiveTab(\"ingestion\")} className=\"cursor-pointer\">\n                <rect x=\"100\" y=\"20\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"ingestion\" ? \"#009DFF\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"44\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">1. SECURE RECORD INGESTION GATEWAY</text>\n              </g>\n              \n              <g onClick={() => setActiveTab(\"cognitive\")} className=\"cursor-pointer\">\n                <rect x=\"80\" y=\"110\" width=\"340\" height=\"40\" rx=\"8\" fill={activeTab === \"cognitive\" ? \"url(#brandG)\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"134\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">2. COGNITIVE AUDIT CONTAINER (EPHEMERAL)</text>\n              </g>\n              \n              <g className=\"opacity-70\">\n                <rect x=\"50\" y=\"190\" width=\"400\" height=\"50\" rx=\"8\" fill=\"#050507\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n                <text x=\"250\" y=\"210\" fill=\"#009DFF\" fontSize=\"9\" fontWeight=\"bold\" textAnchor=\"middle\">Evidence Review Agent // Audit Knowledge Assistant // Risk Review Agent</text>\n                <text x=\"250\" y=\"228\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" className=\"opacity-60\">Executing operations inside secure, stateless runtimes</text>\n              </g>\n              \n              <g onClick={() => setActiveTab(\"registry\")} className=\"cursor-pointer\">\n                <rect x=\"100\" y=\"280\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"registry\" ? \"#E4000F\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n                <text x=\"250\" y=\"304\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">3. VERIFIED OPERATIONAL REGISTRY</text>\n              </g>\n              \n              <defs>\n                <linearGradient id=\"brandG\" x1=\"0\" y1=\"0\" x2=\"340\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n                  <stop stopColor=\"#E4000F\" />\n                  <stop offset=\"1\" stopColor=\"#009DFF\" />\n                </linearGradient>\n                <linearGradient id=\"pipeGlow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"340\" gradientUnits=\"userSpaceOnUse\">\n                  <stop stopColor=\"#E4000F\" />\n                  <stop offset=\"0.5\" stopColor=\"#FFFFFF\" />\n                  <stop offset=\"1\" stopColor=\"#009DFF\" />\n                </linearGradient>\n              </defs>\n            </svg>\n          </div>\n        </div>\n      </div>\n\n      {/* Agent Map Carousel */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n        <h2 className=\"text-2xl font-bold text-white mb-6\">The Audit Agent Map</h2>\n        <Carousel\n          items={AGENTS.map((a) => ({\n            title: a.name,\n            tag: \"Audit Suite Agent\",\n            desc: a.role,\n            metric: \"Verified Isolated Runtime\"\n          }))}\n        />\n      </div>\n\n      {/* Interactive Simulator */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n        <div className=\"lg:col-span-6\">\n          <h2 className=\"text-2xl font-bold text-white mb-4\">Interactive Audit Simulator</h2>\n          <p className=\"text-xs text-white/60 leading-relaxed mb-6\">\n            Execute local, non-persistent simulations of audit cognitive steps. All tasks run locally inside the client browser context, strictly demonstrating the platform's orchestration capabilities.\n          </p>\n          <div className=\"flex flex-wrap gap-3\">\n            <button\n              onClick={() => runDemo(\"evidence\")}\n              disabled={running}\n              className=\"px-5 py-2.5 rounded-full text-xs font-semibold bg-white text-black hover:bg-white/90 disabled:opacity-50 transition-all\"\n            >\n              Simulate Evidence Review\n            </button>\n            <button\n              onClick={() => runDemo(\"gaap\")}\n              disabled={running}\n              className=\"px-5 py-2.5 rounded-full text-xs font-semibold bg-white/5 border border-white/10 text-white hover:bg-white/10 disabled:opacity-50 transition-all\"\n            >\n              Check GAAP Code Reference\n            </button>\n          </div>\n        </div>\n        <div className=\"lg:col-span-6 p-5 rounded-xl border border-white/5 bg-black/40 min-h-[150px] flex flex-col justify-between font-mono\">\n          <span className=\"text-[10px] text-white/40 block border-b border-white/5 pb-2 uppercase tracking-wider\">SECURE AUDIT CONTAINER LOGS</span>\n          <p className=\"text-xs text-green-400 mt-3 leading-relaxed\">{demoOutput}</p>\n          <span className=\"text-[9px] text-white/30 text-right block pt-2\">AUDIT SYSTEM // SANDBOX SESSION ACTIVE</span>\n        </div>\n      </div>\n\n      {/* Outcomes & ROI Levers */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n        <h2 className=\"text-2xl font-bold text-white mb-6\">Structural ROI & Outcome Levers</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-2\">Evidence Indexing Speed</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed font-light\">Reduce file categorization and preliminary cross-checks from multiple days of manual searching to near-instantaneous search layers.</p>\n          </div>\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-2\">Checklist Workflow Compliance</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed font-light\">Enforce programmatic check consistency across hundreds of client record sets, flagging minor anomalies instantly.</p>\n          </div>\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-2\">Complete Verification Log</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed font-light\">Maintain solid, SOC-2 compliant transaction traces for every query, preserving the chain of human accountability.</p>\n          </div>\n        </div>\n      </div>\n\n      {/* Related Capabilities */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16 border-t border-white/5 pt-12\">\n        <h3 className=\"text-xs font-mono text-white/40 uppercase tracking-widest mb-4\">Related Capabilities & Platforms</h3>\n        <div className=\"flex flex-wrap gap-3\">\n          {[\"Foundry Visual Studio\", \"Private Vector Memory\", \"Secure Ledger Gateway\", \"Continuous Auditing\"].map((cap, i) => (\n            <span key={i} className=\"px-3.5 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-white/70\">{cap}</span>\n          ))}\n        </div>\n      </div>\n\n      {/* CTA */}\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n        <PremiumCTA\n          title=\"Architect Your Private Audit Cognitive Layer\"\n          description=\"Consult with our systems engineers to outline secure document mirrors, zero-cache gateways, and private enterprise sandboxes.\"\n          primaryLabel=\"Consult with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
