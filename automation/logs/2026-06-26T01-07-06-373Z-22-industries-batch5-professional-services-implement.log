{"ts":"2026-06-26T01:05:06.747Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"1dqvn9ct","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/industries/tax/page.tsx","new_text":"\"use client\";\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\nimport Carousel from \"@/components/inner-pages/Carousel\";\n\nconst CHALLENGES = [\n  { title: \"Document-Heavy Workflows\", desc: \"Processing corporate schedules, K-1s, and unstructured general ledgers manually.\" },\n  { title: \"Knowledge Search\", desc: \"Navigating deep, shifting local, state, and federal tax laws and treaty details.\" },\n  { title: \"Advisory Support\", desc: \"Aggregating complex histories to draft initial structured research memos.\" },\n  { title: \"Compliance Tracking\", desc: \"Monitoring disparate deadline calendars and regional tax revisions.\" },\n  { title: \"Client Response Time\", desc: \"Addressing time-sensitive inquiries and gathering missing documentation.\" }\n];\n\nconst AGENTS = [\n  { name: \"Tax Knowledge Agent\", role: \"Instantly queries tax codes and regional regulatory updates.\" },\n  { name: \"Compliance Assistant\", role: \"Traces dynamic filing checklists and tax calendars to preempt deadlines.\" },\n  { name: \"Document Intelligence Agent\", role: \"Parses and reconciles dense corporate schedules and unstructured tables.\" }\n];\n\nexport default function TaxPage() {\n  const [log, setLog] = useState(\"System idle. Ready to initiate tax lookup.\");\n  const [running, setRunning] = useState(false);\n\n  const runDemo = (type: string) => {\n    setRunning(true);\n    setLog(type === \"code\" ? \"Tax Knowledge: Searching multi-state regulations...\" : \"Doc Intelligence: Restructuring asset schedule...\");\n    setTimeout(() => {\n      setLog(type === \"code\" ? \"FOUND: Code Sec. 163(j) limitations. Applicable limit is 30% of adjusted taxable income.\" : \"SUCCESS: Extracted 140 entries from PDF asset schedules. Reconciled with GL.\");\n      setRunning(false);\n    }, 400);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Vertical Solutions\"\n        title=\"Sovereign Tax Intelligence Architectures\"\n        highlightedWord=\"Tax\"\n        description=\"Integrate high-accuracy document intelligence layers and dynamic compliance search networks over secure corporate records.\"\n        breadcrumbs={[{ label: \"Industries\", href: \"/industries\" }, { label: \"Tax\" }]}\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-12\">\n        <h2 className=\"text-xl font-bold text-white mb-6\">Challenge Landscape</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n          {CHALLENGES.map((c, i) => (\n            <div key={i} className=\"p-4 rounded-xl border border-white/5 bg-[#050507]/60\">\n              <span className=\"text-[#009DFF] font-mono text-xs block mb-1\">0{i+1} {\"//\"} {c.title}</span>\n              <p className=\"text-[11px] text-white/60 leading-relaxed\">{c.desc}</p>\n            </div>\n          ))}\n        </div>\n      </div>\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-12\">\n        <h2 className=\"text-xl font-bold text-white mb-4\">The Tax Agent Map</h2>\n        <Carousel items={AGENTS.map((a) => ({ title: a.name, tag: \"Tax Suite Agent\", desc: a.role, metric: \"Secure Ingestion\" }))} />\n      </div>\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-12 grid grid-cols-1 lg:grid-cols-12 gap-6 items-center\">\n        <div className=\"lg:col-span-6\">\n          <h2 className=\"text-xl font-bold text-white mb-3\">Interactive Tax Sandbox</h2>\n          <p className=\"text-xs text-white/60 leading-relaxed mb-4\">Simulate secure, read-only queries of corporate records and tax codes inside the GFF sandboxes.</p>\n          <div className=\"flex gap-2\">\n            <button onClick={() => runDemo(\"code\")} disabled={running} className=\"px-4 py-2 rounded-full text-xs font-semibold bg-white text-black\">Query Tax Code</button>\n            <button onClick={() => runDemo(\"doc\")} disabled={running} className=\"px-4 py-2 rounded-full text-xs font-semibold bg-white/5 border border-white/10 text-white\">Parse Schedule Document</button>\n          </div>\n        </div>\n        <div className=\"lg:col-span-6 p-4 rounded-xl border border-white/5 bg-black/40 min-h-[120px] flex flex-col justify-between font-mono\">\n          <span className=\"text-[9px] text-white/40 block border-b border-white/5 pb-1 uppercase tracking-wider\">TAX SANDBOX LOGS</span>\n          <p className=\"text-xs text-[#009DFF] my-2\">{log}</p>\n          <span className=\"text-[8px] text-white/30 text-right\">TAX CONTEXT // LOCAL WORKSPACE</span>\n        </div>\n      </div>\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-12\">\n        <h2 className=\"text-xl font-bold text-white mb-4\">Outcome Levers</h2>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-1\">Processing Speed</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed\">Extract and reconcile structured data from complex schedules without manual intervention.</p>\n          </div>\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-1\">Compliance Safety</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed\">Map updates across regional codes preemptively, minimizing filing and checklist errors.</p>\n          </div>\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050507]/60\">\n            <h3 className=\"text-xs font-bold text-white uppercase mb-1\">Knowledge Accessibility</h3>\n            <p className=\"text-xs text-white/60 leading-relaxed\">Index historic advisory briefs and memorandum files to scale consulting response times.</p>\n          </div>\n        </div>\n      </div>\n      <div className=\"max-w-[1795px] mx-auto px-6 pb-12\">\n        <PremiumCTA title=\"Architect Your Private Tax Intelligence Layer\" description=\"Consult with GFF AI systems engineers to map your document ingestion loops and sovereign compliance memory.\" primaryLabel=\"Connect with GFF AI\" primaryHref=\"/contact\" />\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
