                   {q.options.map((opt) => {\n630 |                               const selected = selectedScore === opt.score;\n631 |                               return (\n632 |                                 <button\n633 |                                   key={opt.score}\n634 |                                   type=\"button\"\n635 |                                   onClick={() => handleSelectOption(q.id, opt.score)}\n636 |                                   className={`p-3 rounded-xl border text-left transition-all flex items-start gap-3 group relative ${\n637 |                                     selected \n638 |                                       ? \"bg-white/[0.02] text-white\" \n639 |                                       : \"bg-[#040609] border-white/5 text-white/60 hover:text-white/95 hover:bg-white/[0.005] hover:border-white/10\"\n640 |                                   }`}\n641 |                                   style={selected ? { borderColor: `${activeDimension.color}40` } : undefined}\n642 |                                 >\n643 |                                   <div \n644 |                                     className={`w-5 h-5 rounded-md border flex items-center justify-center font-mono text-[10px] font-bold flex-shrink-0 transition-all ${\n645 |                                       selected ? \"text-black\" : \"border-white/10 text-white/30 group-hover:border-white/20\"\n646 |                                     }`}\n647 |                                     style={selected ? { backgroundColor: activeDimension.color, borderColor: activeDimension.color } : undefined}\n648 |                                   >\n649 |                                     {opt.score}\n650 |                                   </div>\n651 |                                   <div className=\"space-y-0.5 min-w-0\">\n652 |                                     <span className=\"text-xs font-bold tracking-tight block\">{opt.label}</span>\n653 |                       