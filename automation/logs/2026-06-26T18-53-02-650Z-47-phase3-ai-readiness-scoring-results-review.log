tor = res.avg / 4.0;\n426 |       const r = factor * radius;\n427 |       const x = center + r * Math.cos(angleRad);\n428 |       const y = center + r * Math.sin(angleRad);\n429 |       return { x, y, name: res.shortName, score: res.avg, color: res.color, id: res.id };\n430 |     });\n431 |   };\n432 | \n433 |   const getGridOctagons = () => {\n434 |     const center = 150;\n435 |     const radius = 95;\n436 |     const levels = [0.25, 0.5, 0.75, 1.0];\n437 |     return levels.map((level) => {\n438 |       const points = Array.from({ length: 8 }).map((_, i) => {\n439 |         const angleRad = (i * 45 - 90) * (Math.PI / 180);\n440 |         const r = level * radius;\n441 |         const x = center + r * Math.cos(angleRad);\n442 |         const y = center + r * Math.sin(angleRad);\n443 |         return `${x},${y}`;\n444 |       }).join(\" \");\n445 |       return { points, levelLabel: level * 4 };\n446 |     });\n447 |   };\n448 | \n449 |   const getRadarSpokes = () => {\n450 |     const center = 150;","success":true}],"durationMs":238}}
