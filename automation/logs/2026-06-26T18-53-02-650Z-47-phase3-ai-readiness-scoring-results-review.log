  accent: \"#E5A93C\",\n1138 |                     badge: \"Context & Ingestion\",\n1139 |                     desc: \"Integrate specialized local vector cache nodes and model enclaves, preparing context boundaries to prevent public leakage risks.\",\n1140 |                     focus: \"Contextual Graphs, Sovereign VPCs, Secure Gateways\"\n1141 |                   },\n1142 |                   {\n1143 |                     id: \"factory\",\n1144 |                     name: \"GFF Factory\",\n1145 |                     accent: \"#3B82F6\",\n1146 |                     badge: \"Fleet Deployment\",\n1147 |                     desc: \"Scale multi-agent fleets with custom semantic routing gateways, establishing robust CI/CD sandboxes to compress release cycles.\",\n1148 |                     focus: \"Fleet DAG Orchestration, Containerization, Automated Tests\"\n1149 |                   },\n1150 |                   {\n1151 |                     id: \"operate\",\n1152 |                     name: \"GFF Operate\",\n1153 |                     accent: \"#00FF9D\",\n1154 |                     badge: \"Continuous Guardrails\",\n1155 |                     desc: \"Deploy full-duplex human-agent networks supported by active security supervisor nodes to constantly inspect schemas at 99.9% uptime.\",\n1156 |                     focus: \"Live Schema Supervision, Drift Inspection, Feedback Loops\"\n1157 |                   }\n1158 |                 ].map((path) => {\n1159 |                   const isRecommended = report.recommendedPath.id === path.id;\n1160 | \n1161 |                   return (\n1162 |                     <div\n1163 |                       key={path.id}\n1164 |                       className={`p-6 rounded-2xl border transition-all flex flex-col justify-between space-y-4 relative overflow-hidden group ${\n1165 |                         isRecommended \n1166 |                           ? \"bg-white/[0.03] border-white/15 shadow-[0_0_20px_rgba(255,255,255,0.01)]\" \n1167 |                           : \"bg-[#030306]/90 border-white/5 opacity-50 hover:opacity-75\"\n1168 |                       }`}\n1169 |                       style={isRecommended ? { borderColor: `${path.accent}30` } : undefined}\n1170 |                     >\n1171 |                       {/* Recommended Header Overlay Badge */}\n1172 |                       {isRecommended && (\n1173 |                         <div \n1174 |                           className=\"absolute top-0 right-0 left-0 py-1 text-center font-mono text-[7px] font-extrabold tracking-widest text-black uppercase\"\n1175 |                           style={{ backgroundColor: path.accent }}\n1176 |                         >\n1177 |                           RECOMMENDED ENGAGEMENT PATHWAY\n1178 |                         </div>\n1179 |                       )}\n1180 | \n1181 |                       <div className=\"space-y-2 pt-2\">\n1182 |                         <div className=\"flex items-center justify-between\">\n1183 |                           <span className=\"text-sm font-bold text-white tracking-tight\">{path.name}</span>\n1184 |                           <span className=\"text-[7.5px] font-mono px-1.5 py-0.5 rounded border border-white/10 uppercase text-white/50\">\n1185 |                             {path.badge}\n1186 |                           </span>\n1187 |                         </div>\n1188 |                         <p className=\"text-[11px] text-white/50 leading-relaxed font-light\">\n1189 |                           {path.desc}\n1190 |                         </p>\n1191 |                       </div>\n1192 | \n1193 |                       <div className=\"pt-3 border-t border-white/5 space-y-1\">\n1194 |                         <span className=\"text-[7px] font-mono uppercase tracking-widest block\" style={{ color: path.accent }}>\n1195 |                           CORE OPERATIONAL FOCUS\n1196 |                         </span>\n1197 |                         <p className=\"text-[10px] tex