 827 |               {/* Overall Score Ring */}\n 828 |               <div className=\"lg:col-span-4 p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col items-center justify-center text-center space-y-4 font-mono relative overflow-hidden\">\n 829 |                 <div className=\"absolute inset-0 bg-gradient-to-b from-[#009DFF]/2 to-transparent pointer-events-none\" />\n 830 |                 <span className=\"text-[9px] text-white/40 uppercase tracking-widest font-semibold\">OVERALL READINESS SCORE</span>\n 831 |                 \n 832 |                 <div className=\"relative w-40 h-40 flex items-center justify-center\">\n 833 |                   <svg className=\"absolute inset-0 w-full h-full transform -rotate-90\">\n 834 |                     <circle cx=\"80\" cy=\"80\" r=\"72\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"6\" fill=\"transparent\" />\n 835 |                     <circle \n 836 |                       cx=\"80\" \n 837 |                       cy=\"80\" \n 838 |                       r=\"72\" \n 839 |                       stroke=\"url(#scoreRingGradient)\" \n 840 |                       strokeWidth=\"6\" \n 841 |                       fill=\"transparent\" \n 842 |                       strokeDasharray={452}\n 843 |                       strokeDashoffset={452 - (452 * report.percentage) / 100}\n 844 |                       strokeLinecap=\"round\"\n 845 |                     />\n 846 |                     <defs>\n 847 |                       <linearGradient id=\"scoreRingGradient\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n 848 |                         <stop offset=\"0%\" stopColor=\"#009DFF\" />\n 849 |                         <stop offset=\"100%\" stopColor=\"#00FF9D\" />\n 850 |                       </linearGradient>\n 851 |                     </defs>\n 852 |                   </svg>\n 853 |                   <div className=\"text-center\">\n 854 |                     <span className=\"text-4xl font-extrabold text-white block tracking-tighter\">{report.percentage}%</span>\n 855 |                     <span className=\"text-[8px] text-white/30 uppercase tracking-widest block mt-0.5\">READINESS</span>\n 856 |                   </div>\n 857 |                 </div>\n 858 | \n 859 |                 <div className=\"text-center space-y-1 z-10\">\n 860 |                   <span className={`text-[11px] font-bold tracking-wide uppercase ${report.tierColor}`}>\n 861 |                     {report.tierName}\n 862 |                   </span>\n 863 |                   <span className=\"text-[8px] text-white/20 uppercase block\">DATA SECURITY STATUS: COMPLIANT</span>\n 864 |                 </div>\n 865 |               </div>\n 866 |               {/* Maturity Ladder Visual */}\n 867 |               <div className=\"lg:col-span-4 p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between space-y-4 font-mono\">\n 868 |                 <span className=\"text-[9px] text-white/40 uppercase tracking-widest font-semibold\">MATURITY TIER LADDER</span>\n 869 |                 \n 870 |                 <div className=\"space-y-2.5 my-auto\">\n 871 |                   {[\n 872 |                     { level: \"IV\", name: \"Sovereign Agentic Grid\", range: \"85% - 100%\", color: \"text-[#00FF9D]\", active: report.percentage >= 85 },\n 873 |                     { level: \"III\", name: \"Strategic Federated Mesh\", range: \"60% - 84%\", color: \"text-[#3B82F6]\", active: report.percentage >= 60 && report.percentage < 85 },\n 874 |                     { level: \"II\", name: \"Experimental Siloed Enclave\", range: \"35% - 59%\", color: \"text-[#E5A93C]\", active: report.percentage >= 35 && report.percentage < 60 },\n 875 |                     { level: \"I\", name: \"Reactive Discovery Sandbox\", range: \"0% - 34%\", color: \"text-[#E4000F]\", active: report.percentage < 35 }\n 876 |                   ].map((tier) => (\n 877 |                     <div \n 878 |                       key={tier.level}\n 879 |                       className={`p-2.5 rounded-xl border flex items-center justify-between transition-all relative ${\n 880 |                         tier.active \n 881 |                           ? \"bg-white/[0.02] border-white/10\" \n 882 |                           : \"border-transparent opacity-30\"\n 883 |                       }`}\n 884 |                     >\n 885 |                       <div className=\"flex items-center gap-3\">\n 886 |                         <span className={`w-6 h-6 rounded border flex items-center justify-center text-[10px] font-extrabold ${\n 887 |                           tier.active ? \"bg-white/5 border-white/15\" : \"border-white/5\"\n 888 |                         }`}>\n 889 |                           {tier.level}\n 890 |                         </span>\n 891 |                         <div className=\"space-y-0.5\">\n 892 |                           <span className=\"text-[10px] text-white font-bold block leading-none\">{tier.name}</span>\n 893 |                           <span className=\"text-[8px] text-white/30 block leading-none\">{tier.range} range</span>\n 894 |                         </div>\n 895 |                       </div>\n 896 | \n 897 |                       {tier.active && (\n 898 |                         <span className=\"flex items-center gap-1\">\n 899 |                           <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF9D] animate-pulse\" />\n 900 |                           <span className=\"text-[8px] font-bold text-[#00FF9D] tracking-tighter\">CURRENT</span>\n 901 |                         </span>\n 902 |                       )}\n 903 |                     </div>\n 904 |                   ))}\n 905 |                 </div>\n 906 |               </div>\n 907 | \n 908 |               {/* Executive Commentary Card */}\n 909 |               <div className=\"lg:col-span-4 p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between space-y-4\">\n 910 |               </div>\n 911 |             </div>\n 912 | \n 913 |             {/* INTERACTIVE RADAR CHART SECTION */}\n 914 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n 915 |               {/* Radar Chart SVG panel */}\n 916 |               <div className=\"lg:col-span-5 flex flex-col items-center justify-center p-6 rounded-2xl border border-white/5 bg-[#030306]/95 relative overflow-hidden min-h-[360px]\">\n 917 |                 <div className=\"absolute top-4 left-4 font-mono text-[9px] text-white/35 uppercase tracking-wider\">\n 918 |                   8-DIMENSIONAL MATURITY RADAR\n 919 |                 </div>\n 920 | \n 921 |                 <div className=\"w-full max-w-[280px] aspect-square relative z-10\">\n 922 |                   <svg className=\"w-full h-full\" viewBox=\"0 0 300 300\">\n 923 |                     <defs>\n 924 |                       <radialGradient id=\"radarCenterGlow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n 925 |                         <stop offset=\"0%\" stopColor=\"#009DFF\" stopOpacity=\"0.15\" />\n 926 |                         <stop offset=\"100%\" stopColor=\"transparent\" stopOpacity=\"0\" />\n 927 |                       </radialGradient>\n 928 |                     </defs>\n 929 | \n 930 |                     <circle cx=\"150\" cy=\"150\" r=\"100\" fill=\"url(#radarCenterGlow)\" />\n 931 | \n 932 |                     {getGridOctagons().map((oct, oIdx) => (\n 933 |                       <polygon \n 934 |                         key={oIdx}\n 935 |                         points={oct.points}\n 936 |                         fill=\"none\"\n 937 |                         stroke=\"rgba(255,255,255,0.03)\"\n 938 |                         strokeWidth=\"1\"\n 939 |                       />\n 940 |                     ))}\n 941 | \n 942 |                     {getRadarSpokes().map((spoke, sIdx) => (\n 943 |                       <line \n 944 |                         key={sIdx}\n 945 |                         x1={spoke.x1}\n 946 |                         y1={spoke.y1}\n 947 |                         x2={spoke.x2}\n 948 |                         y2={spoke.y2}\n 949 |                         stroke=\"rgba(255,255,255,0.02)\"\n 950 |                         strokeWidth=\"1.5\"\n 951 |                         strokeDasharray={sIdx % 2 === 1 ? \"2,2\" : undefined}\n 952 |                       />\n 953 |                     ))}\n 954 | \n 955 |                     <polygon \n 956 |                       points={getRadarCoordinates(report.dimensionBreakdowns).map(c => `${c.x},${c.y}`).join(\" \")}\n 957 |                       fill=\"rgba(0, 157, 255, 0.12)\"\n 958 |                       stroke=\"#009DFF\"\n 959 |                       strokeWidth=\"2.5\"\n 960 |                     />\n 961 | \n 962 |                     {getRadarCoordinates(report.dimensionBreakdowns).map((c, idx) => {\n 963 |                       const isHovered = hoveredRadarIdx === idx;\n 964 |                       return (\n 965 |                         <g key={idx}>\n 966 |                           <circle \n 967 |                             cx={c.x}\n 968 |                             cy={c.y}\n 969 |                             r={isHovered ? \"7\" : \"3.5\"}\n 970 |                             fill={c.color}\n 971 |                             className=\"transition-all duration-300 cursor-pointer\"\n 972 |                             onMouseEnter={() => setHoveredRadarIdx(idx)}\n 973 |                             onMouseLeave={() => setHoveredRadarIdx(null)}\n 974 |                           />\n 975 |                           <circle \n 976 |                             cx={c.x}\n 977 |                             cy={c.y}\n 978 |                             r=\"1.5\"\n 979 |                             fill=\"#020204\"\n 980 |                             pointerEvents=\"none\"\n 981 |                           />\n 982 |                         </g>\n 983 |                       );\n 984 |                     })}\n 985 |                     {getRadarCoordinates(report.dimensionBreakdowns).map((c, idx) => {\n 986 |                       const angleRad = (idx * 45 - 90) * (Math.PI / 180);\n 987 |                       const labelRadius = 114;\n 988 |                       const lx = 150 + labelRadius * Math.cos(angleRad);\n 989 |                       const ly = 150 + labelRadius * Math.sin(angleRad);\n 990 |                       const isHovered = hoveredRadarIdx === idx;\n 991 | \n 992 |                       return (\n 993 |                         <text\n 994 |                           key={idx}\n 995 |                           x={lx}\n 996 |                           y={ly + 3}\n 997 |                           textAnchor=\"middle\"\n 998 |                           className={`font-mono text-[8px] font-bold transition-all ${\n 999 |                             isHovered ? \"fill-white\" : \"fill-white/30\"\n1000 |                           }`}\n1001 |                         >\n1002 |                           {c.name.toUpperCase()}\n1003 |                         </text>\n1004 |                       );\n1005 |                     })}\n1006 | \n1007 |                     <circle \n1008 |                       cx=\"150\" \n1009 |                       cy=\"150\" \n1010 |                       r=\"32\" \n1011 |                       fill=\"#020204\" \n1012 |                       stroke=\"rgba(255,255,255,0.08)\"\n1013 |                       strokeWidth=\"1.5\"\n1014 |                     />\n1015 | \n1016 |                     {hoveredRadarIdx !== null ? (\n1017 |                       <>\n1018 |                         <text x=\"150\" y=\"145\" textAnchor=\"middle\" className=\"font-mono text-[7px] fill-white/40 tracking-wider\">\n1019 |                           {report.dimensionBreakdowns[hoveredRadarIdx].shortName.toUpperCase()}\n1020 |                         </text>\n1021 |                         <text \n1022 |                           x=\"150\" \n1023 |                           y=\"159\" \n1024 |                           textAnchor=\"middle\" \n1025 |                           className=\"font-mono text-xs font-extrabold\"\n1026 |                           style={{ fill: report.dimensionBreakdowns[hoveredRadarIdx].color }}\n1027 |                         >\n1028 |                           {report.dimensionBreakdowns[hoveredRadarIdx].avg} / 4.0\n1029 |                         </text>\n1030 |                       </>\n1031 |                     ) : (\n1032 |                       <>\n1033 |                         <text x=\"150\" y=\"146\" textAnchor=\"middle\" className=\"font-mono text-[7px] fill-white/30 tracking-widest uppercase\">\n1034 |                           GFF DIAG\n1035 |                         </text>\n1036 |                         <text x=\"150\" y=\"157\" textAnchor=\"middle\" className=\"font-mono text-[9px] font-bold fill-white tracking-tight\">\n1037 |                           METRIC INDEX\n1038 |                         </text>\n1039 |                       </>\n1040 |                     )}\n1041 |                   </svg>\n1042 |                 </div>\n1043 | \n1044 |                 <div className=\"absolute bottom-4 text-[9px] font-mono text-white/20\">\n1045 |                   HOVER MARKERS TO QUERY DIMENSION OVERLAYS\n1046 |                 </div>\n1047 |               </div>\n1048 |               {/* Strengths & Risks */}\n1049 |               <div className=\"lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-6 h-full\">\n1050 |                 {/* Column 1: Strengths */}\n1051 |                 <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col space-y-4 h-full\">\n1052 |                   <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n1053 |                     <span className=\"p-1 rounded bg-[#00FF9D]/10 border border-[#00FF9D]/20 text-[#00FF9D]\">\n1054 |                       <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n1055 |                         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n1056 |                       </svg>\n1057 |                     </span>\n1058 |                     <span className=\"text-xs font-bold text-white font-mono tracking-wider\">KEY STRENGTHS</span>\n1059 |                   </div>\n1060 | \n1061 |                   <div className=\"space-y-4 overflow-y-auto max-h-[250px] pr-1 scrollbar-thin\">\n1062 |                     {report.strengths.length > 0 ? (\n1063 |                       report.strengths.map((str, sIdx) => (\n1064 |                         <div key={sIdx} className=\"space-y-1\">\n1065 |                           <span className=\"text-[10px] font-bold text-white block font-mono\">{str.name}</span>\n1066 |                           <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">{str.desc}</p>\n1067 |                         </div>\n1068 |                       ))\n1069 |                     ) : (\n1070 |                       <div className=\"space-y-1\">\n1071 |                         <span className=\"text-[10px] font-bold text-white block font-mono\">POTENTIAL DISCOVERY</span>\n1072 |                         <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">\n1073 |                           Your active participation in compiling this local assessment shows critical risk foresight before committing enterprise capital.\n1074 |                         </p>\n1075 |                       </div>\n1076 |                     )}\n1077 |                   </div>\n1078 |                 </div>\n1079 | \n1080 |                 {/* Column 2: Risks */}\n1081 |                 <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col space-y-4 h-full\">\n1082 |                   <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n1083 |                     <span className=\"p-1 rounded bg-[#E4000F]/10 border border-[#E4000F]/20 text-[#E4000F]\">\n1084 |                       <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n1085 |                         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n1086 |                       </svg>\n1087 |                     </span>\n1088 |                     <span className=\"text-xs font-bold text-white font-mono tracking-wider\">DETECTED RISKS</span>\n1089 |                   </div>\n1090 | \n1091 |                   <div className=\"space-y-4 overflow-y-auto max-h-[250px] pr-1 scrollbar-thin\">\n1092 |                     {report.risks.length > 0 ? (\n1093 |                       report.risks.map((risk, rIdx) => (\n1094 |                         <div key={rIdx} className=\"space-y-1\">\n1095 |                           <span className=\"text-[10px] font-bold text-amber-500 block font-mono\">{risk.name}</span>\n1096 |                           <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">{risk.desc}</p>\n1097 |                         </div>\n1098 |                       ))\n1099 |                     ) : (\n1100 |                       <div className=\"space-y-1\">\n1101 |                         <span className=\"text-[10px] font-bold text-white block font-mono\">RESIDUAL PLATFORM DRIFT</span>\n1102 |                         <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">\n1103 |                           Even optimized structures carry risk. Ongoing third-party API model changes and latency shifts require continuous g