nt = Math.round((answeredQuestionsCount / totalQuestions) * 100);\n 97 | \n 98 |   const getDimensionAnsweredCount = (dim: Dimension) => {\n 99 |     return dim.questions.filter(q => answers[q.id] !== undefined).length;\n100 |   };\n101 | \n102 |   const isDimensionComplete = (dim: Dimension) => {\n103 |     return getDimensionAnsweredCount(dim) === dim.questions.length;\n104 |   };\n105 | \n106 |   const getLiveLevelEstimate = () => {\n107 |     if (answeredQuestionsCount === 0) return { name: \"Awaiting Input\", color: \"text-white/40\" };\n108 |     \n109 |     const sum = Object.values(answers).reduce((acc, val) => acc + val, 0);\n110 |     const avg = sum / answeredQuestionsCount;\n111 |     \n112 |     if (avg >= 3.4) return { name: \"Sovereign Mesh (Level IV)\", color: \"text-[#00FF9D]\" };\n113 |     if (avg >= 2.5) return { name: \"Federated Mesh (Level III)\", color: \"text-[#3B82F6]\" };\n114 |     if (avg >= 1.7) return { name: \"Siloed Enclave (Level II)\", color: \"text-[#E5A93C]\" };\n115 |     return { name: \"Reactive Sandbox (Level I)\", color: \"text-[#E4000F]\" };\n116 |   };\n117 | \n118 |   useEffect(() => {\n119 |     if (!isCompiling) return;\n120 |     const interval = setInterval(() => {\n121 |       setCompilingStep((prev) => {\n122 |         if (prev < COMPILING_MESSAGES.length - 1) {\n123 |           return prev + 1;\n124 |         } else {\n125 |           clearInterval(interval);\n126 |           setIsCompiling(false);\n127 |           setShowResult(true);\n128 |           return prev;\n129 |         }\n130 |       });\n131 |     }, 350);\n132 |     return () => clearInterval(interval);\n133 |   }, [isCompiling]);\n134 | \n135 |   const handleSelectOption = (questionId: string, score: number) => {\n136 |     setValidationError(null);\n137 |     setAnswers(prev => ({ ...prev, [questionId]: score }));\n138 |   };\n139 | \n140 |   const handleCompileTrigger = () => {\n141 |     setValidationError(null);\n142 |     const incompleteDims: string[] = [];\n143 |     \n144 |     DIMENSIONS.forEach(dim => {\n145 |       if (!isDimensionComplete(dim)) {\n146 |         incompleteDims.push(dim.shortName);\n147 |       }\n148 |     });\n149 | \n150 |     if (incompleteDims.length > 0) {\n151 |       setValidationError(\n152 |         `VALIDATION ALERT: Please resolve all diagnostic segments before compiling. Incomplete categories: ${incompleteDims.join(\", \")}.`\n153 |       );\n154 |       return;\n155 |     }\n156 | \n157 |     setIsCompiling(true);\n158 |     setCompilingStep(0);\n159 |   };\n160 | \n161 |   const handleReset = () => {\n162 |     setAnswers({});\n163 |     setActiveDimensionIndex(0);\n164 |     setValidationError(null);\n165 |     setIsCompiling(false);\n166 |     setShowResult(false);\n167 |     setCompilingStep(0);\n168 |   };\n169 | \n170 |   // Generate dynamic results\n171 |   const calculateResults = () => {\n172 |     const totalScore = Object.values(answers).reduce((acc, val) => acc + val, 0);\n173 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n174 | \n175 |     let tierName = \"\";\n176 |     let tierColor = \"\";\n177 |     let borderAccent = \"\";\n178 |     let commentary = \"\";\n179 | \n180 |     if (percentage >= 85) {\n181 |       tierName = \"Maturity Level IV: Sovereign Agentic Grid\";\n182 |       tierColor = \"text-[#00FF9D]\";\n183 |       borderAccent = \"border-[#00FF9D]/30 shadow-[0_0_20px_rgba(0,255,157,0.03)]\";\n184 |       commentary = \"Your organization exhibits world-class capabilities tailored to host autonomous multi-agent systems inside isolated network subnets. Your data pipelines feature semantic linking and real-time context ingestion. We recommend establishing custom local vector nodes and deploying sovereign supervisor enclaves to transition your pilot workflows into immediate production lines with zero data retention risks.\";\n185 |     } else if (percentage >= 60) {\n186 |       tierName = \"Maturity Level III: Strategic Federated Mesh\";\n187 |       tierColor = \"text-[#3B82F6]\";\n188 |       borderAccent = \"border-[#3B82F6]/30 shadow-[0_0_20px_rgba(59,130,246,0.03)]\";\n189 |       commentary = \"You have established strong structural foundations. Your private cloud setups and operational documentation are highly mature, but data pipelines lack clean semantic structure and legacy writebacks remain constrained by human latency. Implementing localized vector cache enclaves and a federated AI Center of Excellence can resolve these bottlenecks and compress deployment timelines down to 30 days.\";\n190 |     } else if (percentage >= 35) {\n191 |       tierName = \"Maturity Level II: Experimental Siloed Enclave\";\n192 |       tierColor = \"text-[#E5A93C]\";\n193 |       borderAccent = \"border-[#E5A93C]/30 shadow-[0_0_20px_rgba(229,169,60,0.03)]\";\n194 |       commentary = \"Your AI efforts are fragmented, relying on cloud endpoints with manual review workflows and isolated scripts. While individual talent exists, the lack of centralized governance and structured vector data pipelines limits your ability to scale. Establishing a standardized sandbox environment is an essential next gate to coordinate telemetry protocols and secure a dedicated capital runway.\";\n195 |     } else {\n196 |       tierName = \"Maturity Level I: Reactive Discovery Sandbox\";\n197 |       tierColor = \"text-[#E4000F]\";\n198 |       borderAccent = \"border-[#E4000F]/30 shadow-[0_0_20px_rgba(228,0,15,0.03)]\";\n199 |       commentary = \"Your systems are locked in legacy databases with siloed, undocumented processes and minimal in-house AI engineering capabilities. Running unstructured commercial chatbots introduces high data-leakage and regulatory risks. We strongly suggest launching a controlled GFF Labs sandbox trial to securely model your security schemas before attempting any cloud or on-premises deployments.\";\n200 |     }\n201 | \n202 |     const dimensionBreakdowns = DIMENSIONS.map(dim => {\n203 |       const qIds = dim.questions.map(q => q.id);\n204 |       const scores = qIds.map(id => answers[id] || 1);\n205 |       const avg = Number((scores.reduce((a, b) => a + b, 0) / qIds.length).toFixed(1));\n206 | \n207 |       let status = \"GAP IDENTIFIED\";\n208 |       let statusStyle = \"text-[#E5A93C] bg-[#E5A93C]/5 border-[#E5A93C]/15\";\n209 |       let rec = \"\";\n210 | \n211 |       if (avg >= 3.5) {\n212 |         status = \"OPTIMIZED\";\n213 |         statusStyle = \"text-[#00FF9D] bg-[#00FF9D]/5 border-[#00FF9D]/15\";\n214 |       } else if (avg >= 2.5) {\n215 |         status = \"STABLE\";\n216 |         statusStyle = \"text-[#3B82F6] bg-[#3B82F6]/5 border-[#3B82F6]/15\";\n217 |       }\n218 | \n219 |       if (dim.id === \"strategy\") {\n220 |         rec = avg >= 2.5 \n221 |           ? \"Establish continuous strategy discovery boards mapping specific business bottlenecks to complex Multi-Agent DAG blueprints.\"\n222 |           : \"Secure executive board-level sponsorship to align corporate multi-year capital directly with structured pilot outcomes.\";\n223 |       } else if (dim.id === \"data\") {\n224 |         rec = avg >= 2.5\n225 |           ? \"Integrate GFF Context Knowledge Graphs to feed your active local agent enclaves with synchronized contextual context mapping.\"\n226 |           : \"Construct automated data ingestion pipelines using semantic chunkers to process legacy PDFs, SOPs, and manual logs securely.\";\n227 |       } else if (dim.id === \"process\") {\n228 |         rec = avg >= 2.5\n229 |           ? \"Deploy passive supervisor nodes to constantly measure multi-agent DAG latency bottlenecks and optimize step executions.\"\n230 |           : \"Digitize core manual workflows and document decision state boundaries before modeling autonomous handoffs.\";\n231 |       } else if (dim.id === \"talent\") {\n232 |         rec = avg >= 2.5\n233 |           ? \"Adopt Platform-as-a-Product structures to let internal engineering teams spin up isolated, pre-governed agents independently.\"\n234 |           : \"Roll out GFF AI Academy modules across target divisions to improve prompt literacy and reduce digital-transition friction.\";\n235 |       } else if (dim.id === \"governance\") {\n236 |         rec = avg >= 2.5\n237 |           ? \"Implement zero-retention boundary policies and cryptographically sign execution steps for high-integrity regulatory audits.\"\n238 |           : \"Install automated input/output security middleware to detect and redact sensitive customer identifiers (PII) at the edge.\";\n239 |       } else if (dim.id === \"techstack\") {\n240 |         rec = avg >= 2.5\n241 |           ? \"Introduce GFF Orchestration Gateways to dynamically route model calls based on cost, latency thresholds, and residency rules.\"\n242 |           : \"Transition operational workloads from public cloud API keys to private cloud enclaves or local containerized serving structures.\";\n243 |       } else if (dim.id === \"leadership\") {\n244 |         rec = avg >= 2.5\n245 |           ? \"Co-develop custom proprietary model adapters and pioneer topologies in collaborative syncs with GFF Labs.\"\n246 |           : \"Secure protected, multi-year CAPEX reserves to insulate early-stage pilot models from short-term financial fluctuations.\";\n247 |       } else {\n248 |         rec = avg >= 2.5\n249 |           ? \"Design full-duplex human-agent queues allowing operators and active supervisor bots to collaboratively resolve complex tasks.\"\n250 |           : \"Adopt a federated Center of Excellence (CoE) to streamline compliance clearances and standardize deployable templates.\";\n251 |       }\n252 | \n253 |       return { ...dim, avg, status, statusStyle, rec };\n254 |     });\n255 | \n256 |     // Dynamic Strengths mapping based on actual scores\n257 |     const strengths = dimensionBreakdowns\n258 |       .filter(d => d.avg >= 2.5)\n259 |       .map(d => {\n260 |         let desc = \"\";\n261 |         if (d.id === \"strategy\") desc = \"High alignment ensures capital allocation tracks execution metrics closely.\";\n262 |         else if (d.id === \"data\") desc = \"Clean unstructured semantic storage structures simplify embedding enclaves.\";\n263 |         else if (d.id === \"process\") desc = \"Clear manual decision handoffs prevent deadlocks during agent execution loops.\";\n264 |         else if (d.id === \"talent\") desc = \"Internal prompt literacy minimizes transitional engineering blockages.\";\n265 |         else if (d.id === \"governance\") desc = \"Existing boundary structures satisfy core regulatory redaction standards.\";\n266 |         else if (d.id === \"techstack\") desc = \"Private server architectures support fully containerized local execution environments.\";\n267 |         else if (d.id === \"leadership\") desc = \"Calculated risk tolerance empowers engineering to pilot proprietary adaptors.\";\n268 |         else desc = \"Centralized templates standardise pipelines and facilitate sandbox promotion.\";\n269 |         \n270 |         return { name: d.name, desc };\n271 |       });\n272 | \n273 |     // Dynamic Risks mapping based on actual scores\n274 |     const risks = dimensionBreakdowns\n275 |       .filter(d => d.avg < 2.5)\n276 |       .map(d => {\n277 |         let desc = \"\";\n278 |         if (d.id === \"strategy\") desc = \"Fragmented ad-hoc prioritizing risks budget drift and redundant departmental tooling.\";\n279 |         else if (d.id === \"data\") desc = \"Legacy database structures introduce hallucination variables and slow context ingestion.\";\n280 |         else if (d.id === \"process\") desc = \"High manual latency and unmapped workflows choke autonomous multi-agent scaling.\";\n281 |         else if (d.id === \"talent\") desc = \"Lack of dedicated prompt modeling capacity slows platform integration.\";\n282 |         else if (d.id === \"governance\") desc = \"Standard API endpoints with open access keys risk accidental telemetry leaks.\";\n283 |         else if (d.id === \"techstack\") desc = \"Third-party model dependencies expose enterprise systems to latency fluctuations.\";\n284 |         else if (d.id === \"leadership\") desc = \"Risk-averse capital allocation parameters threaten competitive multi-year stagnation.\";\n285 |         else desc = \"Siloed delivery channels delay software deployment cycles past 6 months.\";\n286 | \n287 |         return { name: d.name, desc };\n288 |       });\n289 | \n290 |     // Recommended GFF pathway details\n291 |     let recommendedPath = {\n292 |       id: \"garage\",\n293 |       name: \"GFF Garage\",\n294 |       badge: \"Rapid Sandbox & Pilot Scaling\",\n295 |       color: \"text-[#E4000F]\",\n296 |       borderColor: \"border-[#E4000F]/30\",\n297 |       glowBg: \"bg-[#E4000F]/5\",\n298 |       desc: \"Perfect for organizations in early strategic stages. GFF Garage provides rapid, risk-insulated Web Sandboxes and prompt literacy modules. Start by modeling isolated workflows, validating key decision barriers, and securing dedicated executive sponsorship without extensive capital exposure.\",\n299 |       focus: \"Ideation, Pilot Scoping, Basic Sandboxing, and Executive Alignment.\"\n300 |     };\n301 | \n302 |     if (percentage >= 85) {\n303 |       recommendedPath = {\n304 |         id: \"operate\",\n305 |         name: \"GFF Operate\",\n306 |         badge: \"Continuous Symbiosis & Autonomy\",\n307 |         color: \"text-[#00FF9D]\",\n308 |         borderColor: \"border-[#00FF9D]/30\",\n309 |         glowBg: \"bg-[#00FF9D]/5\",\n310 |         desc: \"Designed for world-class digital grids. GFF Operate launches full-duplex human-agent collaborative queues, deploys active security supervisor nodes to constantly inspect schemas at runtime, and runs continuous model guardrails to prevent token drift at 99.9% telemetry success.\",\n311 |         focus: \"Full-Duplex Handoffs, Real-Time Guardrails, Dynamic Optimization, and Active Supervisors.\"\n312 |       };\n313 |     } else if (percentage >= 60) {\n314 |       recommendedPath = {\n315 |         id: \"factory\",\n316 |         name: \"GFF Factory\",\n317 |         badge: \"Production Scaling & Fleet Orchestration\",\n318 |         color: \"text-[#3B82F6]\",\n319 |         borderColor: \"border-[#3B82F6]/30\",\n320 |         glowBg: \"bg-[#3B82F6]/5\",\n321 |         desc: \"Tailored for organizations with proven data context and private cloud enclaves. GFF Factory coordinates high-velocity agent fleets, deploys advanced semantic orchestration gateways, and standardizes continuous deployment (CI/CD) of secure agentic microservices across systems.\",\n322 |         focus: \"Multi-Agent Fleet Coordination, Routing Gateways, and Continuous Compliance Integration.\"\n323 |       };\n324 |     } else if (percentage >= 35) {\n325 |       recommendedPath = {\n326 |         id: \"foundry\",\n327 |         name: \"GFF Foundry\",\n328 |         badge: \"Contextual Enclaves & Secure Ingestion\",\n329 |         color: \"text-[#E5A93C]\",\n330 |         borderColor: \"border-[#E5A93C]/30\",\n331 |         glowBg: \"bg-[#E5A93C]/5\",\n332 |         desc: \"Optimized for bridging the gap between isolated scripts and standardized platforms. GFF Foundry constructs enterprise-grade private cloud enclaves, implements Context Knowledge Graphs, and sets up secure vector cache servers to ingest legacy repositories cleanly.\",\n333 |         focus: \"Contextual Databases, Sovereign VPC Boundaries, Model Adapters, and Secure Gateways.\"\n334 |       };\n335 |     }\n336 | \n337 |     const nextActions = [\n338 |       \"Launch a local GFF Zero-Trust Sandbox session to safely trace sample multi-system agentic handoffs.\",\n339 |       \"Conduct a structured diagnostic scan of structured and unstructured context repositories to identify vector database prerequisites.\",\n340 |       \"Sync with GFF Labs to explore custom proprietary model adapters designed for strict local data retention rules.\",\n341 |       \"Generate an automated Topological Blueprint and draft an Algorithmic SOW to establish operational milestones.\"\n342 |     ];\n343 | \n344 |     return { percentage, tierName, tierColor, borderAccent, commentary, dimensionBreakdowns, strengths, risks, recommendedPath, nextActions };\n345 |   };\n346 | \n347 |   const report = showResult ? calculateResults() : null;\n348 | \n349 |   // Local-only handlers\n350 |   const handleCopyReport = () => {\n351 |     if (!report) return;\n352 |     const dimensionText = report.dimensionBreakdowns.map((d: any) => \n353 |       `- ${d.name}: ${d.avg}/4.0 (${d.status})\\n  Recommendation: ${d.rec}`\n354 |     ).join(\"\\n\");\n355 |     const strengthsText = report.strengths.map((s: any) => `- ${s.name}: ${s.desc}`).join(\"\\n\");\n356 |     const risksText = report.risks.map((r: any) => `- ${r.name}: ${r.desc}`).join(\"\\n\");\n357 |     const pathText = `Recommended GFF Pathway: ${report.recommendedPath.name}\\n${report.recommendedPath.desc}`;\n358 | \n359 |     const reportMarkdown = `\n360 | # GFF AI READINESS ASSESSMENT REPORT\n361 | Generated on: ${new Date().toLocaleDateString()}\n362 | Security Context: LOCAL SECURED TELEMETRY\n363 | \n364 | ## OVERALL READINESS SCORE: ${report.percentage}%\n365 | Maturity Band: ${report.tierName}\n366 | \n367 | ## KEY METRIC DIAGNOSIS\n368 | ${dimensionText}\n369 | \n370 | ## KEY STRENGTHS\n371 | ${strengthsText || \"None identified with average score >= 2.5.\"}\n372 | \n373 | ## DETECTED RISKS\n374 | ${risksText || \"None identified with average score < 2.5.\"}\n375 | \n376 | ## STRATEGIC GFF PATHWAY\n377 | ${pathText}\n378 | \n379 | ---\n380 | CONFIDENTIALITY NOTICE: This report was compiled locally in a zero-retention environment and is for directional planning only. No outcomes are guaranteed.\n381 |     `.trim();\n382 | \n383 |     navigator.clipboard.writeText(reportMarkdown);\n384 |     setCopied(true);\n385 |     setTimeout(() => setCopied(false), 2000);\n386 |   };\n387 | \n388 |   const handleExportArchive = () => {\n389 |     if (!report) return;\n390 |     const payload = {\n391 |       timestamp: new Date().toISOString(),\n392 |       score: report.percentage,\n393 |       maturity: report.tierName,\n394 |       answers,\n395 |       dimensionBreakdowns: report.dimensionBreakdowns.map((d: any) => ({\n396 |         id: d.id,\n397 |         name: d.name,\n398 |         score: d.avg,\n399 |         status: d.status,\n400 |         recommendation: d.rec\n401 |       })),\n402 |       strengths: report.strengths,\n403 |       risks: report.risks,\n404 |       path: report.recommendedPath,\n405 |       security: \"LOCAL VPC COMPLIANT\"\n406 |     };\n407 | \n408 |     const dataStr = \"data:text/json;charset=utf-8,\" + encodeURIComponent(JSON.stringify(payload, null, 2));\n409 |     const downloadAnchor = document.createElement('a');\n410 |     downloadAnchor.setAttribute(\"href\", dataStr);\n411 |     downloadAnchor.setAttribute(\"download\", `gff_ai_readiness_report_${report.percentage}pct.json`);\n412 |     document.body.appendChild(downloadAnchor);\n413 |     downloadAnchor.click();\n414 |     downloadAnchor.remove();\n415 |     setSaved(true);\n416 |     setTimeout(() => setSaved(false), 2000);\n417 |   };\n418 | \n419 |   // Helper arrays for Native SVG Radar Chart\n420 |   const getRadarCoordinates = (dimensionBreakdowns: any[]) => {\n421 |     const center = 150;\n422 |     const radius = 95;\n423 |     return dimensionBreakdowns.map((res, i) => {\n424 |       const angleRad = (i * 45 - 90) * (Math.PI / 180);\n425 |       const factor = res.avg / 4.0;\n426 |       const r = factor * radius;\n427 |       const x = center + r * Math.cos(angleRad);\n428 |       const y = center + r * Math.sin(angleRad);\n429 |       return { x, y, name: res.shortName, score: res.avg, color: res.color, id: res.id };\n430 |     });\n431 |   };\n432 | \n433 |   const getGridOctagons = () => {\n434 |     const center = 150;\n435 |     const radius = 95;\n436 |     const levels = [0.25, 0.5, 0.75, 1.0];\n437 |     return levels.map((level) => {\n438 |       const points = Array.from({ length: 8 }).map((_, i) => {\n439 |         const angleRad = (i * 45 - 90) * (Math.PI / 180);\n440 |         const r = level * radius;\n441 |         const x = center + r * Math.cos(angleRad);\n442 |         const y = center + r * Math.sin(angleRad);\n443 |         return `${x},${y}`;\n444 |       }).join(\" \");\n445 |       return { points, levelLabel: level * 4 };\n446 |     });\n447 |   };\n448 | \n449 |   const getRadarSpokes = () => {\n450 |     const center = 150;\n451 |     const radius = 95;\n452 |     return Array.from({ length: 8 }).map((_, i) => {\n453 |       const angleRad = (i * 45 - 90) * (Math.PI / 180);\n454 |       const x = center + radius * Math.cos(angleRad);\n455 |       const y = center + radius * Math.sin(angleRad);\n456 |       return { x1: center, y1: center, x2: x, y2: y };\n457 |     });\n458 |   };\n459 | \n460 | \n461 |   return (\n462 |     <ToolPageShell showContact={!showResult}>\n463 |       <AnimatePresence mode=\"wait\">\n464 |         {/* COMPILED LOADING SCREEN */}\n465 |         {isCompiling && (\n466 |           <motion.div\n467 |             key=\"compiling\"\n468 |             initial={{ opacity: 0 }}\n469 |             animate={{ opacity: 1 }}\n470 |             exit={{ opacity: 0 }}\n471 |             className=\"min-h-[550px] flex flex-col items-center justify-center py-16 text-center space-y-8\"\n472 |           >\n473 |             <div className=\"relative w-24 h-24 flex items-center justify-center\">\n474 |               <div className=\"absolute inset-0 rounded-full border-2 border-[#009DFF]/20 animate-ping\" />\n475 |               <div className=\"absolute inset-2 rounded-full border border-[#00FF9D]/30 animate-pulse\" />\n476 |               <div className=\"w-12 h-12 rounded-full bg-[#030306] border border-white/10 flex items-center justify