or: res.color }}>\n1231 |                             {getDimensionIcon(res.id)}\n1232 |                           </span>\n1233 |                           <span className=\"text-xs font-bold text-white tracking-tight truncate\">{res.shortName}</span>\n1234 |                         </div>\n1235 |                         <span className={`text-[8px] font-mono font-extrabold px-1.5 py-0.5 rounded border ${res.statusStyle}`}>\n1236 |                           {res.status}\n1237 |                         </span>\n1238 |                       </div>\n1239 | \n1240 |                       <div className=\"space-y-1\">\n1241 |                         <div className=\"flex justify-between items-baseline font-mono text-xs\">\n1242 |                           <span className=\"text-white/30 text-[9px]\">SEGMENT SCORE</span>\n1243 |                           <span className=\"font-bold text-white\">{res.avg} / 4.0</span>\n1244 |                         </div>\n1245 |                         <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n1246 |                           <div \n1247 |                             className=\"h-full transition-all duration-500\"\n1248 |                             style={{ width: `${(res.avg / 4) * 100}%`, backgroundColor: res.color }}\n1249 |                           />\n1250 |                         </div>\n1251 |                       </div>\n1252 | \n1253 |                       <p className=\"text-[11px] text-white/50 leading-relaxed font-light pt-1\">\n1254 |                         {res.description}\n1255 |                       </p>\n1256 |                     </div>\n1257 | \n1258 |                     <div className=\"pt-3 border-t border-white/5 space-y-1 bg-white/[0.005] p-2.5 rounded-lg border border-white/[0.02]\">\n1259 |                       <span className=\"text-[8px] font-mono text-[#009DFF] font-extrabold uppercase tracking-widest block\">TACTICAL RECOMMENDATION</span>\n1260 |                       <p cla