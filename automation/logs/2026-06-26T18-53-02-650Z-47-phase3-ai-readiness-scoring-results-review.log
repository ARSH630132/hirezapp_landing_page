 before committing enterprise capital.\n1074 |                         </p>\n1075 |                       </div>\n1076 |                     )}\n1077 |                   </div>\n1078 |                 </div>\n1079 | \n1080 |                 {/* Column 2: Risks */}\n1081 |                 <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col space-y-4 h-full\">\n1082 |                   <div className=\"flex items-center gap-2 border-b border-white/5 pb-3\">\n1083 |                     <span className=\"p-1 rounded bg-[#E4000F]/10 border border-[#E4000F]/20 text-[#E4000F]\">\n1084 |                       <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n1085 |                         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n1086 |                       </svg>\n1087 |                     </span>\n1088 |                     <span className=\"text-xs font-bold text-white font-mono tracking-wider\">DETECTED RISKS</span>\n1089 |                   </div>\n1090 | \n1091 |                   <div className=\"space-y-4 overflow-y-auto max-h-[250px] pr-1 scrollbar-thin\">\n1092 |                     {report.risks.length > 0 ? (\n1093 |                       report.risks.map((risk, rIdx) => (\n1094 |                         <div key={rIdx} className=\"space-y-1\">\n1095 |                           <span className=\"text-[10px] font-bold text-amber-500 block font-mono\">{risk.name}</span>\n1096 |                           <p className=\"text-white/50 text-[11px] leading-relaxed font-light\">{risk.desc}</p>\n1097 |                         </div>\n1098 |                       ))\n1099 |                     ) : (\n1100 |                       <div className=\"space-y-1\">\n1101 |                         <span className=\"text-[10px] font-bold t