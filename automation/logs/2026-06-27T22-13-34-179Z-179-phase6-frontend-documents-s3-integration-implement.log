al Ledger Enclave Alpha\",\n107 |     status: \"Approved\",\n108 |     version: \"v2.0\",\n109 |     owner: \"Auditor Jenkins\",\n110 |     visibility: \"LEVEL_V (Strictly Confidential)\",\n111 |     desc: \"Comprehensive security evaluation of zero-knowledge node communications and encrypted telemetry streams.\"\n112 |   },\n113 |   {\n114 |     id: \"DOC-INV-005\",\n115 |     name: \"Invoice_GFF_2026_Q2_Epoch_Compute.pdf\",\n116 |     category: \"Invoices\",\n117 |     format: \"PDF\",\n118 |     size: \"1.1 MB\",\n119 |     hash: \"0x11B8A02FEE907C10BDE8267FEE10BC91A23D4FFA289F02ECBC12A349CDE150FA\",\n120 |     uploadedAt: \"2026-06-01T08:00:00Z\",\n121 |     project: \"Sovereign Core Sandbox 02\",\n122 |     status: \"Signed\",\n123 |     version: \"v1.1\",\n124 |     owner: \"Finance Operations\",\n125 |     visibility: \"LEVEL_III (Internal Use)\",\n126 |     desc: \"Q2 computation allocation billing, auditing active node-hours, thread capacity, and secure bandwidth streams.\"\n127 |   },\n128 |   {\n129 |     id: \"DOC-GOV-006\",\n130 |     name: \"Model_Guardrail_Alignment_Directives.json\",\n131 |     category: \"Governance\",\n132 |     format: \"JSON\",\n133 |     size: \"45 KB\",\n134 |     hash: \"0x56EFA90CC7FFADE138EE87A02FF90A11BDE897FF021BC8102C019FFAD998E125\",\n135 |     uploadedAt: \"2026-06-20T17:10:00Z\",\n136 |     project: \"Model Guardrail Sandbox 04\",\n137 |     status: \"Active\",\n138 |     version: \"v1.2-RC1\",\n139 |     owner: \"Dr. Sarah Vance\",\n140 |     visibility: \"LEVEL_IV (Restricted)\",\n141 |     desc: \"Cryptographically locked prompt and completion alignment filters applied directly to sovereign agent pipelines.\"\n142 |   },\n143 |   {\n144 |     id: \"DOC-MTG-007\",\n145 |     name: \"Architecture_Interlock_Review_Notes_2026_06_18.docx\",\n146 |     category: \"Meeting Notes\",\n147 |     format: \"DOCX\",\n148 |     size: \"312 KB\",\n149 |     hash: \"0x09F23D4FFA289F02ECBC12A349CDE150FA11B8A02FEE907C10BDE8267FEE10BC\",\n150 |     uploadedAt: \"2026-06-18T15:30:00Z\",\n151 |     project: \"Global Platform (No Project)\",\n152 |     status: \"In Review\",\n153 |     version: \"v1.0\",\n154 |     owner: \"Elena Rostova\",\n155 |     visibility: \"LEVEL_III (Internal Use)\",\n156 |     desc: \"Engineering alignment session minutes detailing HSM hardware key rotation synchronization hurdles with Sovereign Sandbox Core 02.\"\n157 |   },\n158 |   {\n159 |     id: \"DOC-AST-008\",\n160 |     name: \"Isolated_HSM_Core_Config_Secure_Build.zip\",\n161 |     category: \"Delivery Assets\",\n162 |     format: \"ZIP\",\n163 |     size: \"48.2 MB\",\n164 |     hash: \"0xFA02CE8274A08B0192A45C89FBC104923FBC128EE809FF9CC9810A88AA11B8FF\",\n165 |     uploadedAt: \"2026-06-25T12:00:00Z\",\n166 |     project: \"Sovereign Core Sandbox 02\",\n167 |     status: \"Approved\",\n168 |     version: \"v4.0-release\",\n169 |     owner: \"Evelyn Carter\",\n170 |     visibility: \"LEVEL_V (Strictly Confidential)\",\n171 |     desc: \"Cryptographically signed system bundle, including isolated host memory parameters, kernel configurations, and attestation scripts.\"\n172 |   },\n173 |   {\n174 |     id: \"DOC-SOW-009\",\n175 |     name: \"Federal_Ledger_Scope_SOW_Draft.docx\",\n176 |     category: \"SOW\",\n177 |     format: \"DOCX\",\n178 |     size: \"780 KB\",\n179 |     hash: \"0x7890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF123456\",\n180 |     uploadedAt: \"2026-06-26T10:45:00Z\",\n181 |     project: \"Federal Ledger Enclave Alpha\",\n182 |     status: \"Pending Review\",\n183 |     version: \"v0.8-draft\",\n184 |     owner: \"Alexander Mercer\",\n185 |     visibility: \"LEVEL_IV (Restricted)\",\n186 |     desc: \"Initial scope definitions and governance protocols for regional ledger integrations with AMD SEV validation nodes.\"\n187 |   },\n188 |   {\n189 |     id: \"DOC-PRP-010\",\n190 |     name: \"GFF_Enterprise_Legacy_Proposal_2025.pdf\",\n191 |     category: \"Proposals\",\n192 |     format: \"PDF\",\n193 |     size: \"5.2 MB\",\n194 |     hash: \"0xAB88AA11B8FFFA02CE8274A08B0192A45C89FBC104923FBC128EE809FF9CC981\",\n195 |     uploadedAt: \"2025-11-15T14:20:00Z\",\n196 |     project: \"Global Platform (No Project)\",\n197 |     status: \"Archived\",\n198 |     version: \"v1.0\",\n199 |     owner: \"Elena Rostova\",\n200 |     visibility: \"LEVEL_I (Client View)\",\n201 |     desc: \"Archived initial technical brief for older AMD SEV architecture compatibility study.\"\n202 |   }\n203 | ];\n204 | \n205 | // Available filter choices\n206 | const CATEGORIES = [\"Proposals\", \"SOW\", \"Architecture\", \"Reports\", \"Invoices\", \"Governance\", \"Meeting Notes\", \"Delivery Assets\"];\n207 | const PROJECTS = [\n208 |   \"Apex Sovereign Group [Preview Client]\",\n209 |   \"Global Retail Enclave [Preview Client]\",\n210 |   \"Sovereign Logistics Unit [Preview Client]\",\n211 |   \"Federal Treasury Division [Preview Client]\",\n212 |   \"Global Platform (No Project)\"\n213 | ];\n214 | const FORMATS = [\"PDF\", \"JSON\", \"YAML\", \"CSV\", \"DOCX\", \"ZIP\", \"PPTX\"];\n215 | const STATUSES = [\"Approved\", \"Signed\", \"In Review\", \"Pending Review\", \"Active\", \"Archived\"];\n216 | \n217 | function mapApiDocToPortalDoc(apiDoc: any): PortalDocument {\n218 |   // Map formats\n219 |   const format: any = apiDoc.type || \"PDF\";\n220 |   \n221 |   // Map categories based on name keywords\n222 |   let category: any = \"Reports\";\n223 |   const titleLower = (apiDoc.title || apiDoc.name || \"\").toLowerCase();\n224 |   if (titleLower.includes(\"proposal\")) {\n225 |     category = \"Proposals\";\n226 |   } else if (titleLower.includes(\"sow\") || titleLower.includes(\"statement of work\") || titleLower.includes(\"contract\")) {\n227 |     category = \"SOW\";\n228 |   } else if (titleLower.includes(\"blueprint\") || titleLower.includes(\"architecture\") || titleLower.includes(\"topology\")) {\n229 |     category = \"Architecture\";\n230 |   } else if (titleLower.includes(\"ruleset\") || titleLower.includes(\"governance\") || titleLower.includes(\"directive\") || titleLower.includes(\"compliance\")) {\n231 |     category = \"Governance\";\n232 |   } else if (titleLower.includes(\"audit\") || titleLower.includes(\"report\")) {\n233 |     category = \"Reports\";\n234 |   } else if (titleLower.includes(\"invoice\") || titleLower.includes(\"billing\")) {\n235 |     category = \"Invoices\";\n236 |   } else if (titleLower.includes(\"meeting\") || titleLower.includes(\"notes\")) {\n237 |     category = \"Meeting Notes\";\n238 |   } else if (apiDoc.type === \"ZIP\" || titleLower.includes(\"asset\") || titleLower.includes(\"config\")) {\n239 |     category = \"Delivery Assets\";\n240 |   }\n241 | \n242 |   // Map status\n243 |   let status: any = \"Approved\";\n244 |   if (apiDoc.status === \"Verified\") {\n245 |     status = \"Approved\";\n246 |   } else if (apiDoc.status === \"Under Review\") {\n247 |     status = \"In Review\";\n248 |   } else if (apiDoc.status === \"Action Required\") {\n249 |     status = \"Pending Review\";\n250 |   } else if (apiDoc.status === \"Superseded\") {\n251 |     status = \"Archived\";\n252 |   } else {\n253 |     status = apiDoc.status || \"Approved\";\n254 |   }\n255 | \n256 |   return {\n257 |     id: apiDoc.id,\n258 |     name: apiDoc.title || apiDoc.name,\n259 |     category: category,\n260 |     format: format,\n261 |     size: apiDoc.fileSize || \"1.0 MB\",\n262 |     hash: apiDoc.sha256 || \"0xHASH\",\n263 |     uploadedAt: apiDoc.lastUpdated || new Date().toISOString(),\n264 |     project: apiDoc.client_name || \"Global Platform (No Project)\",\n265 |     status: status,\n266 |     version: apiDoc.version || \"v1.0\",\n267 |     owner: apiDoc.owner || \"Dr. Sarah Vance\",\n268 |     visibility: apiDoc.client_id === \"client-001\" ? \"LEVEL_IV (Restricted)\" : \"LEVEL_I (Client View)\",\n269 |     desc: apiDoc.description || apiDoc.desc || \"Cryptographically secured enclave system documentation.\"\n270 |   };\n271 | }\n272 | \n273 | \n274 | function DocumentsSkeleton() {\n275 |   return (\n276 |     <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n277 |       {[1, 2, 3, 4, 5, 6].map((n) => (\n278 |         <WorkspaceCard key={n} className=\"flex flex-col h-[280px] justify-between border-white/[0.03] bg-[#050505]/20 p-5 rounded-2xl relative animate-pulse\">\n279 |           <div className=\"space-y-3\">\n280 |             <div className=\"flex justify-between items-start\">\n281 |               <div className=\"flex items-center gap-2\">\n282 |                 <div className=\"h-4 bg-white/5 rounded w-16 animate-pulse\" />\n283 |                 <div className=\"h-4 bg-white/5 rounded w-12 animate-pulse\" />\n284 |               </div>\n285 |               <div className=\"h-4 bg-white/5 rounded w-10 animate-pulse\" />\n286 |             </div>\n287 |             <div className=\"space-y-2 pt-2\">\n288 |               <div className=\"h-5 bg-white/5 rounded w-5/6 animate-pulse\" />\n289 |               <div className=\"h-3 bg-white/5 rounded w-full animate-pulse\" />\n290 |               <div className=\"h-3 bg-white/5 rounded w-4/5 animate-pulse\" />\n291 |             </div>\n292 |           </div>\n293 |           <div className=\"border-t border-white/5 pt-3 mt-4 space-y-3\">\n294 |             <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/35\">\n295 |               <div className=\"h-3 bg-white/5 rounded w-12 animate-pulse\" />\n296 |               <div className=\"h-3 bg-white/5 rounded w-12 ml-auto animate-pulse\" />\n297 |             </div>\n298 |             <div className=\"grid grid-cols-2 gap-2 pt-1\">\n299 |               <div className=\"h-8 bg-white/5 rounded animate-pulse\" />\n300 |               <div className=\"h-8 bg-white/5 rounded animate-pulse\" />\n301 |             </div>\n302 |           </div>\n303 |         </WorkspaceCard>\n304 |       ))}\n305 |     </div>\n306 |   );\n307 | }\n308 | \n309 | function DocumentsErrorState({ message, onRetry }: { message: string; onRetry: () => void }) {\n310 |   return (\n311 |     <div className=\"p-12 text-center rounded-2xl border border-red-500/10 bg-red-950/5 backdrop-blur-sm max-w-xl mx-auto space-y-4\">\n312 |       <div className=\"p-4 rounded-full bg-red-500/10 border border-red-500/20 inline-flex text-red-400\">\n313 |         <Shield className=\"w-8 h-8\" />\n314 |       </div>\n315 |       <div className=\"space-y-1\">\n316 |         <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">HSM Verification Failed</h3>\n317 |         <p className=\"text-[12.5px] text-white/50 max-w-sm mx-auto font-sans leading-relaxed\">\n318 |           {message}\n319 |         </p>\n320 |       </div>\n321 |       <button \n322 |         onClick={onRetry}\n323 |         className=\"h-9 px-4 rounded-lg bg-red-600 hover:bg-red-500 text-[11px] font-mono font-bold uppercase text-white transition-all cursor-pointer shadow-[0_0_15px_rgba(239,68,68,0.2)] inline-flex items-center gap-1.5\"\n324 |       >\n325 |         <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" />\n326 |         <span>RETRY VERIFICATION</span>\n327 |       </button>\n328 |     </div>\n329 |   );\n330 | }\n331 | \n332 | export default function ClientDocumentsPage() {\n333 |   const router = useRouter();\n334 | \n335 |   // Dynamic API Fetching States\n336 |   const [documents, setDocuments] = useState<PortalDocument[]>([]);\n337 |   const [loading, setLoading] = useState(true);\n338 |   const [error, setError] = useState<string | null>(null);\n339 | \n340 |   // User Profile & Scoped client ID\n341 |   const [currentClientId, setCurrentClientId] = useState<number | null>(null);\n342 |   const [currentUserRole, setCurrentUserRole] = useState<string | null>(null);\n343 |   const [availableProjects, setAvailableProjects] = useState<any[]>([]);\n344 | \n345 |   // Real upload modal state variables\n346 |   const [isUploadModalOpen, setIsUploadModalOpen] = useState(false);\n347 |   const [uploadFile, setUploadFile] = useState<File | null>(null);\n348 |   const [uploadTitle, setUploadTitle] = useState(\"\");\n349 |   const [uploadCategory, setUploadCategory] = useState(\"Reports\");\n350 |   const [uploadProjectId, setUploadProjectId] = useState<string>(\"\");\n351 |   const [uploadVersion, setUploadVersion] = useState(\"1.0.0\");\n352 |   const [uploadVisibility, setUploadVisibility] = useState(\"private\");\n353 |   const [uploadDescription, setUploadDescription] = useState(\"\");\n354 |   const [uploading, setUploading] = useState(false);\n355 |   const [uploadError, setUploadError] = useState<string | null>(null);\n356 | \n357 |   // Filter States\n358 |   const [searchQuery, setSearchQuery] = useState(\"\");\n359 |   const [selectedCategory, setSelectedCategory] = useState(\"\");\n360 |   const [selectedProject, setSelectedProject] = useState(\"\");\n361 |   const [selectedFormat, setSelectedFormat] = useState(\"\");\n362 |   const [selectedStatus, setSelectedStatus] = useState(\"\");\n363 |   \n364 |   const fetchDocuments = useCallback(async () => {\n365 |     setLoading(true);\n366 |     setError(null);\n367 |     try {\n368 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n369 |       if (!token) {\n370 |         setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n371 |         router.push(\"/portal/login\");\n372 |         return;\n373 |       }\n374 | \n375 |       const res = await fetch(\"/api/v1/documents\", {\n376 |         headers: {\n377 |           \"Authorization\": `Bearer ${token}`,\n378 |           \"Content-Type\": \"application/json\"\n379 |         }\n380 |       });\n381 | \n382 |       if (!res.ok) {\n383 |         throw new Error(`Enclave sync failed with status ${res.status}`);\n384 |       }\n385 | \n386 |       const data = await res.json();\n387 |       let docArray = null;\n388 |       if (Array.isArray(data)) {\n389 |         docArray = data;\n390 |       } else if (data && data.success && Array.isArray(data.documents)) {\n391 |         docArray = data.documents;\n392 |       }\n393 | \n394 |       if (docArray) {\n395 |         const mapped = docArray.map((d: any) => mapApiDocToPortalDoc(d));\n396 |         setDocuments(mapped);\n397 |       } else {\n398 |         throw new Error(\"Handshake returned malformed enclave register.\");\n399 |       }\n400 |     } catch (err: any) {\n401 |       console.error(\"Error fetching documents:\", err);\n402 |       setError(err.message || \"Decentralized ledger handshake timed out.\");\n403 |     } finally {\n404 |       setLoading(false);\n405 |     }\n406 |   }, [router]);\n407 | \n408 |   useEffect(() => {\n409 |     fetchDocuments();\n410 |   }, [fetchDocuments]);\n411 | \n412 |   // Layout States\n413 |   const [layoutMode, setLayoutMode] = useState<\"grid\" | \"list\">(\"grid\");\n414 | \n415 |   // Drawer & Attestation Log States\n416 |   const [selectedDoc, setSelectedDoc] = useState<PortalDocument | null>(null);\n417 |   const [terminalLogs, setTerminalLogs] = useState<string[]>([]);\n418 |   const [isLogsSyncing, setIsLogsSyncing] = useState(false);\n419 |   const [copiedHash, setCopiedHash] = useState(false);\n420 | \n421 |   // Custom Toast Notification States\n422 |   const [toastMessage, setToastMessage] = useState<string | null>(null);\n423 |   const [toastType, setToastType] = useState<\"info\" | \"warning\" | \"success\" | null>(null);\n424 | \n425 |   // Trigger Toast Helper\n426 |   const showToast = (message: string, type: \"info\" | \"warning\" | \"success\" = \"info\") => {\n427 |     setToastMessage(message);\n428 |     setToastType(type);\n429 |   };\n430 | \n431 |   // Close Toast automatically after 3.5 seconds\n432 |   useEffect(() => {\n433 |     if (toastMessage) {\n434 |       const timer = setTimeout(() => {\n435 |         setToastMessage(null);\n436 |         setToastType(null);\n437 |       }, 3500);\n438 |       return () => clearTimeout(timer);\n439 |     }\n440 |   }, [toastMessage]);\n441 | \n442 |   // Terminal Handshake Log Simulator inside Drawer\n443 |   useEffect(() => {\n444 |     if (!selectedDoc) {\n445 |       setTerminalLogs([]);\n446 |       return;\n447 |     }\n448 | \n449 |     setIsLogsSyncing(true);\n450 |     setTerminalLogs([\n451 |       `[${new Date().toLocaleTimeString()}] LOCK_INIT: Connection opened to air-gapped sovereign HSM node.`,\n452 |       `[${new Date().toLocaleTimeString()}] AUTH_CHECK: Level III Clearance validation in progress...`\n453 |     ]);\n454 | \n455 |     const logsArray = [\n456 |       `[${new Date().toLocaleTimeString()}] SIGN_CHECK: Verified signature: AMD SEV-SNP cryptographic seal validated (100% compliant).`,\n457 |       `[${new Date().toLocaleTimeString()}] INTEGRITY: SHA-256 integrity hash verification matches master repository: ${selectedDoc.hash.substring(0, 16)}...`,\n458 |       `[${new Date().toLocaleTimeString()}] CLEARANCE: Mapped access level is authorized for user account clearance level.`,\n459 |       `[${new Date().toLocaleTimeString()}] SECURE_PREVIEW: Safe, decapsulated read stream established for [${selectedDoc.id}].`\n460 |     ];\n461 | \n462 |     let timerIndex = 0;\n463 |     const interval = setInterval(() => {\n464 |       if (timerIndex < logsArray.length) {\n465 |         setTerminalLogs((prev) => [...prev, logsArray[timerIndex]]);\n466 |         timerIndex++;\n467 |       } else {\n468 |         setIsLogsSyncing(false);\n469 |         clearInterval(interval);\n470 |       }\n471 |     }, 450);\n472 | \n473 |     return () => clearInterval(interval);\n474 |   }, [selectedDoc]);\n475 | \n476 |   // Copy Clipboard Helper\n477 |   const handleCopyHash = (text: string) => {\n478 |     navigator.clipboard.writeText(text);\n479 |     setCopiedHash(true);\n480 |     showToast(\"Cryptographic SHA-256 copied to clipboard.\", \"success\");\n481 |     setTimeout(() => setCopiedHash(false), 1500);\n482 |   };\n483 | \n484 |   // Reset Filters Helper\n485 |   const handleResetFilters = () => {\n486 |     setSearchQuery(\"\");\n487 |     setSelectedCategory(\"\");\n488 |     setSelectedProject(\"\");\n489 |     setSelectedFormat(\"\");\n490 |     setSelectedStatus(\"\");\n491 |     showToast(\"All filters reset successfully.\", \"info\");\n492 |   };\n493 | \n494 |   // Fetch Current User & Projects for uploading\n495 |   useEffect(() => {\n496 |     const fetchUserDataAndProjects = async () => {\n497 |       try {\n498 |         const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n499 |         if (!token) return;\n500 |         \n501 |         // Fetch user\n502 |         const meRes = await fetch(\"/api/v1/auth/me\", {\n503 |           headers: { \"Authorization\": `Bearer ${token}` }\n504 |         });\n505 |         if (meRes.ok) {\n506 |           const data = await meRes.json();\n507 |           if (data) {\n508 |             setCurrentClientId(data.client_id || null);\n509 |             setCurrentUserRole(data.role || null);\n510 |           }\n511 |         }\n512 | \n513 |         // Fetch projects\n514 |         const projRes = await fetch(\"/api/v1/projects\", {\n515 |           headers: { \"Authorization\": `Bearer ${token}` }\n516 |         });\n517 |         if (projRes.ok) {\n518 |           const data = await projRes.json();\n519 |           const projectsList = Array.isArray(data) ? data : (data.success && Array.isArray(data.projects) ? data.projects : []);\n520 |           setAvailableProjects(projectsList);\n521 |         }\n522 |       } catch (err) {\n523 |         console.error(\"Error fetching user data/projects:\", err);\n524 |       }\n525 |     };\n526 |     fetchUserDataAndProjects();\n527 |   }, []);\n528 | \n529 |   // Real secure download via API\n530 |   const handleRealDownload = async (doc: PortalDocument) => {\n531 |     try {\n532 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n533 |       if (!token) {\n534 |         showToast(\"Authentication token not found.\", \"warning\");\n535 |         return;\n536 |       }\n537 |       showToast(`Transferring certified copy: ${doc.name}...`, \"info\");\n538 |       \n539 |       const res = await fetch(`/api/v1/documents/download/${doc.id}`, {\n540 |         headers: {\n541 |           \"Authorization\": `Bearer ${token}`\n542 |         }\n543 |       });\n544 |       \n545 |       if (!res.ok) {\n546 |         throw new Error(`Download failed with status ${res.status}`);\n547 |       }\n548 |       \n549 |       const blob = await res.blob();\n550 |       const url = window.URL.createObjectURL(blob);\n551 |       const a = document.createElement(\"a\");\n552 |       a.href = url;\n553 |       a.download = doc.name;\n554 |       document.body.appendChild(a);\n555 |       a.click();\n556 |       a.remove();\n557 |       window.URL.revokeObjectURL(url);\n558 |       \n559 |       showToast(`Securely downloaded: ${doc.name}`, \"success\");\n560 |     } catch (err: any) {\n561 |       console.error(\"Error downloading document:\", err);\n562 |       showToast(`Download blocked: ${err.message}`, \"warning\");\n563 |     }\n564 |   };\n565 | \n566 |   // Real multipart upload\n567 |   const handleRealUpload = async (e: React.FormEvent) => {\n568 |     e.preventDefault();\n569 |     if (!uploadFile) {\n570 |       setUploadError(\"Please select a file to upload.\");\n571 |       return;\n572 |     }\n573 |     \n574 |     setUploading(true);\n575 |     setUploadError(null);\n576 |     \n577 |     try {\n578 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n579 |       if (!token) {\n580 |         throw new Error(\"Authentication token not found.\");\n581 |       }\n582 |       \n583 |       let targetClientId = currentClientId;\n584 |       if (!targetClientId) {\n585 |         const meRes = await fetch(\"/api/v1/auth/me\", {\n586 |           headers: { \"Authorization\": `Bearer ${token}` }\n587 |         });\n588 |         if (meRes.ok) {\n589 |           const meData = await meRes.json();\n590 |           targetClientId = meData.client_id;\n591 |         }\n592 |       }\n593 |       \n594 |       if (!targetClientId) {\n595 |         throw new Error(\"Could not resolve your client account assignment. Please contact support.\");\n596 |       }\n597 |       \n598 |       const formData = new FormData();\n599 |       formData.append(\"file\", uploadFile);\n600 |       formData.append(\"client_id\", String(targetClientId));\n601 |       if (uploadProjectId) {\n602 |         formData.append(\"project_id\", uploadProjectId);\n603 |       }\n604 |       formData.append(\"title\", uploadTitle || uploadFile.name);\n605 |       formData.append(\"document_type\", uploadCategory);\n606 |       formData.append(\"version\", uploadVersion);\n607 |       formData.append(\"visibility\", uploadVisibility);\n608 |       formData.append(\"description\", uploadDescription || \"Cryptographically secured enclave system documentation.\");\n609 |       \n610 |       const res = await fetch(\"/api/v1/documents/upload\", {\n611 |         method: \"POST\",\n612 |         headers: {\n613 |           \"Authorization\": `Bearer ${token}`\n614 |         },\n615 |         body: formData\n616 |       });\n617 |       \n618 |       if (!res.ok) {\n619 |         const errData = await res.json().catch(() => ({}));\n620 |         throw new Error(errData.detail || `Upload failed with status ${res.status}`);\n621 |       }\n622 |       \n623 |       const data = await res.json();\n624 |       if (data.success) {\n625 |         showToast(`Document uploaded and sealed: ${uploadFile.name}`, \"success\");\n626 |         setUploadFile(null);\n627 |         setUploadTitle(\"\");\n628 |         setUploadDescription(\"\");\n629 |         setUploadVersion(\"1.0.0\");\n630 |         setIsUploadModalOpen(false);\n631 |         fetchDocuments();\n632 |       } else {\n633 |         throw new Error(data.message || \"Failed to process document upload.\");\n634 |       }\n635 |     } catch (err: any) {\n636 |       console.error(\"Upload error:\", err);\n637 |       setUploadError(err.message || \"An unexpected error occurred during secure file transfer.\");\n638 |     } finally {\n639 |       setUploading(false);\n640 |     }\n641 |   };\n642 | \n643 |   // Simulated Actions\n644 |   const handleSimulatedDownload = (doc: PortalDocument) => {\n645 |     handleRealDownload(doc);\n646 |   };\n647 | \n648 |   const handleSimulatedUploadClick = () => {\n649 |     setIsUploadModalOpen(true);\n650 |   };\n651 | \n652 |   // Filtering Logic\n653 |   const filteredDocuments = documents.filter((doc) => {\n654 |     // 1. Text Search query (checks title, hash, id, owner)\n655 |     if (searchQuery.trim() !== \"\") {\n656 |       const query = searchQuery.toLowerCase();\n657 |       const matchText = \n658 |         doc.name.toLowerCase().includes(query) ||\n659 |         doc.id.toLowerCase().includes(query) ||\n660 |         doc.hash.toLowerCase().includes(query) ||\n661 |         doc.owner.toLowerCase().includes(query) ||\n662 |         doc.desc.toLowerCase().includes(query);\n663 |       if (!matchText) return false;\n664 |     }\n665 |     // 2. Category\n666 |     if (selectedCategory !== \"\" && doc.category !== selectedCategory) return false;\n667 |     // 3. Related Project\n668 |     if (selectedProject !== \"\" && doc.project !== selectedProject) return false;\n669 |     // 4. File Format (Type)\n670 |     if (selectedFormat !== \"\" && doc.format !== selectedFormat) return false;\n671 |     // 5. Status\n672 |     if (selectedStatus !== \"\" && doc.status !== selectedStatus) return false;\n673 | \n674 |     return true;\n675 |   });\n676 | \n677 |   // Calculate quick document statistics\n678 |   const totalSeals = documents.length;\n679 |   const activeSows = documents.filter(d => d.category === \"SOW\").length;\n680 |   const auditReports = documents.filter(d => d.category === \"Reports\" || d.category === \"Architecture\").length;\n681 |   const pendingReviews = documents.filter(d => d.status === \"Pending Review\" || d.status === \"In Review\").length;\n682 | \n683 |   const getStatusColor = (status: string) => {\n684 |     const s = status.toLowerCase();\n685 |     if (s === \"approved\" || s === \"signed\" || s === \"active\") return \"text-[#00FFC2] border-[#00FFC2]/20 bg-[#00FFC2]/5\";\n686 |     if (s === \"in review\" || s === \"pending review\") return \"text-amber-400 border-amber-400/20 bg-amber-400/5\";\n687 |     return \"text-white/40 border-white/10 bg-white/5\";\n688 |   };\n689 | \n690 |   const getFormatBadgeColor = (fmt: string) => {\n691 |     const f = fmt.toLowerCase();\n692 |     if (f === \"pdf\") return \"text-red-400 border-red-500/20 bg-red-500/5\";\n693 |     if (f === \"yaml\" || f === \"json\") return \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\";\n694 |     if (f === \"zip\") return \"text-indigo-400 border-indigo-500/20 bg-indigo-500/5\";\n695 |     return \"text-white/60 border-white/10 bg-white/5\";\n696 |   };\n697 | \n698 |   const hasActiveFilters = searchQuery !== \"\" || selectedCategory !== \"\" || selectedProject !== \"\" || selectedFormat !== \"\" || selectedStatus !== \"\";\n699 | \n700 |   return (\n701 |     <div className=\"space-y-6 max-w-[1750px] mx-auto pb-12 select-none relative\">\n702 |       \n703 |       {/* 1. TOAST NOTIFICATION WINDOW */}\n704 |       {toastMessage && (\n705 |         <div className=\"fixed bottom-20 lg:bottom-6 right-4 lg:right-6 z-50 animate-in fade-in slide-in-from-bottom duration-300\">\n706 |           <div className={`p-4 rounded-xl border backdrop-blur-xl shadow-2xl flex items-center gap-3 font-mono text-[12px] max-w-sm ${\n707 |             toastType === \"warning\" ? \"border-amber-500/30 bg-amber-950/70 text-amber-300\" :\n708 |             toastType === \"success\" ? \"border-[#00FFC2]/30 bg-black/80 text-[#00FFC2]\" :\n709 |             \"border-white/10 bg-black/80 text-white/80\"\n710 |           }`}>\n711 |             <Shield className={`w-4 h-4 shrink-0 ${\n712 |               toastType === \"warning\" ? \"text-amber-400\" :\n713 |               toastType === \"success\" ? \"text-[#00FFC2]\" :\n714 |               \"text-[#009DFF]\"\n715 |             }`} />\n716 |             <div>\n717 |               <span className=\"font-bold uppercase tracking-wider block text-[10px]\">\n718 |                 {toastType === \"warning\" ? \"SECURITY ALIGNMENT LOCK\" : toastType === \"success\" ? \"INTEGRITY ATTESTED\" : \"SYSTEM MESSAGE\"}\n719 |               </span>\n720 |               <p className=\"mt-0.5 font-sans leading-snug\">{toastMessage}</p>\n721 |             </div>\n722 |             <button onClick={() => setToastMessage(null)} className=\"p-0.5 text-white/40 hover:text-white rounded shrink-0 transition-colors ml-auto\">\n723 |               <X className=\"w-3.5 h-3.5\" />\n724 |             </button>\n725 |           </div>\n726 |         </div>\n727 |       )}\n728 | \n729 |       {/* 2. DEMO RESTRICTED BANNER */}\n730 |       <div className=\"border border-white/5 bg-[#050505]/30 rounded-xl px-4 py-3 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 font-mono text-[11px] backdrop-blur-sm\">\n731 |         <div className=\"flex items-center gap-2.5 text-white/50\">\n732 |           <Info className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n733 |           <span>\n734 |             <strong className=\"text-white/80\">AIRGAPPED DOCUMENT REPOSITORY:</strong> In alignment with SOC2 and ISO27001 policies, download and upload actions are cryptographically suspended inside client preview portals.\n735 |           </span>\n736 |         </div>\n737 |         <span className=\"text-[9.5px] text-[#009DFF] font-bold bg-