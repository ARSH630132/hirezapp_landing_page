 useState(\"1.5 MB\");\n325 |   const [newDesc, setNewDesc] = useState(\"\");\n326 |   const [adminFile, setAdminFile] = useState<File | null>(null);\n327 | \n328 |   // Get active selected document details dynamically\n329 |   const selectedDoc = useMemo(() => {\n330 |     return documents.find(doc => doc.id === selectedDocId) || null;\n331 |   }, [documents, selectedDocId]);\n332 | \n333 |   // Sync re-assignment selector when selected document changes\n334 |   useEffect(() => {\n335 |     if (selectedDoc) {\n336 |       setAssigningProjectId(selectedDoc.projectId);\n337 |     }\n338 |   }, [selectedDoc]);\n339 | \n340 |   // Auto-dismiss toast\n341 |   useEffect(() => {\n342 |     if (toast.visible) {\n343 |       const timer = setTimeout(() => {\n344 |         setToast({ visible: false, message: \"\" });\n345 |       }, 3500);\n346 |       return () => clearTimeout(timer);\n347 |     }\n348 |   }, [toast]);\n349 | \n350 |   const showToast = (message: string) => {\n351 |     setToast({ visible: true, message });\n352 |   };\n353 | \n354 |   // ==========================================\n355 |   // 4. ACTION HANDLERS WITH BACKEND METADATA CRUD\n356 |   // ==========================================\n357 |   \n358 |   // Assign Document to Project (PATCH metadata)\n359 |   const handleAssignProject = async (docId: string, projectId: string) => {\n360 |     setLoading(true);\n361 |     try {\n362 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n363 |       const targetProj = projects.find(p => p.id === projectId);\n364 |       const targetClientId = targetProj && targetProj.id !== \"UNASSIGNED\" ? getClientIdFromClientName(targetProj.client) : undefined;\n365 | \n366 |       const res = await fetch(`/api/v1/documents/${docId}`, {\n367 |         method: \"PATCH\",\n368 |         headers: {\n369 |           \"Content-Type\": \"application/json\",\n370 |           \"Authorization\": `Bearer ${token}`\n371 |         },\n372 |         body: JSON.stringify({\n373 |           project_id: projectId === \"UNASSIGNED\" ? \"\" : projectId,\n374 |           projectId: projectId === \"UNASSIGNED\" ? \"\" : projectId,\n375 |           client_id: targetClientId\n376 |         })\n377 |       });\n378 |       const data = await res.json();\n379 |       if (data.success) {\n380 |         showToast(`Cryptographic association established: Document bound successfully.`);\n381 |         await fetchData();\n382 |       } else {\n383 |         showToast(`Failed to update project re-assignment: ${data.message || \"Unknown error\"}`);\n384 |       }\n385 |     } catch (err) {\n386 |       showToast(`Error communicating update with secure enclave.`);\n387 |     } finally {\n388 |       setLoading(false);\n389 |     }\n390 |   };\n391 | \n392 |   // Real secure administrator download from S3\n393 |   const handleRealDownload = async (docId: string, filename: string) => {\n394 |     setDownloadingDocId(docId);\n395 |     try {\n396 |       const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\") : null;\n397 |       if (!token) {\n398 |         showToast(\"Authentication token not found.\");\n399 |         return;\n400 |       }\n401 |       showToast(`Initiating secure administrator copy transfer...`);\n402 |       \n403 |       const res = await fetch(`/api/v1/documents/download/${docId}`, {\n404 |         headers: {\n405 |           \"Authorization\": `Bearer ${token}`\n406 |         }\n407 |       });\n408 |       \n409 |       if (!res.ok) {\n410 |         throw new Error(`Download failed with status ${res.status}`);\n411 |       }\n412 |       \n413 |       const blob = await res.blob();\n414 |       const url = window.URL.createObjectURL(blob);\n415 |       const a = document.createElement(\"a\");\n416 |       a.href = url;\n417 |       a.download = filename;\n418 |       document.body.appendChild(a);\n419 |       a.click();\n420 |       a.remove();\n421 |       window.URL.revokeObjectURL(url);\n422 |       \n423 |       showToast(`Audit log registered: Secure admin transfer of \"${filename}\" completed.`);\n424 |     } catch (err: any) {\n425 |       console.error(\"Error downloading document:\", err);\n426 |       showToast(`Download failed: ${err.message}`);\n427 |     } finally {\n428 |       setDownloadingDocId(null);\n429 |     }\n430 |   };\n431 | \n432 |   const handleSimulatedDownload = (docId: string, title: string) => {\n433 |     handleRealDownload(docId, title);\n434 |   };\n435 | \n436 |   // Toggle checklist inside drawer (PATCH metadata)\n437 |   const handleToggleCheck = async (docId: string, checkIndex: number) => {\n438 |     const doc = documents.find(d => d.id === docId);\n439 |     if (!doc) return;\n440 | \n441 |     const updatedChecks = [...doc.governanceChecks];\n442 |     updatedChecks[checkIndex] = {\n443 |       ...updatedChecks[checkIndex],\n444 |       checked: !updatedChecks[checkIndex].checked\n445 |     };\n446 | \n447 |     try {\n448 |       const token = localStorage.getItem(\"gff_ai_access_token\");\n449 |       const res = await fetch(`/api/v1/documents/${docId}`, {\n450 |         method: \"PATCH\",\n451 |         headers: {\n452 |           \"Content-Type\": \"application/json\",\n453 |           \"Authorization\": `Bearer ${token}`\n454 |         },\n455 |         body: JSON.stringify({\n456 |           governanceChecks: updatedChecks\n457 |         })\n458 |       });\n459 |       const data = await res.json();\n460 |       if (data.success) {\n461 |         showToast(`Governance checklist updated. Audit state synchronized.`);\n462 |         setDocuments(prevDocs => \n463 |           prevDocs.map(d => d.id === docId ? { ...d, governanceChecks: updatedChecks } : d)\n464 |         );\n465 |       } else {\n466 |         showToast(`Failed to sync checklist: ${data.message || \"Unknown error\"}`);\n467 |       }\n468 |     } catch (err) {\n469 |       showToast(`Error syncing checklist with secure enclave.`);\n470 |     }\n471 |   };\n472 | \n473 |   // Register New Document Submit (POST multipart upload)\n474 |   const handleRegisterSubmit = async (e: React.FormEvent) => {\n475 |     e.preventDefault();\n476 |     if (!adminFile) {\n477 |       showToast(\"Please select a file to upload.\");\n478 |       return;\n479 |     }\n480 |     if (!newTitle.trim()) return;\n481 | \n482 |     setLoading(true);\n483 |     try {\n484 |       const token = localStorage.getItem(\"gff_ai_access_token\") || localStorage.getItem(\"gff_api_token\");\n485 |       \n486 |       let resolvedClientId = 1; // default fallback\n487 |       try {\n488 |         const clientsRes = await fetch(\"/api/v1/clients\", {\n489 |           headers: { \"Authorization\": `Bearer ${token}` }\n490 |         });\n491 |         if (clientsRes.ok) {\n492 |           const clientsData = await clientsRes.json();\n493 |           const clientsList = Array.isArray(clientsData) ? clientsData : (clientsData.success && Array.isArray(clientsData.clients) ? clientsData.clients : []);\n494 |           \n495 |           const cleanNewClient = newClient.replace(\" [Preview Client]\", \"\").toLowerCase();\n496 |           const matchedClient = clientsList.find((c: any) => \n497 |             cleanNewClient.includes(c.name.toLowerCase()) || \n498 |             c.name.toLowerCase().includes(cleanNewClient) ||\n499 |             (cleanNewClient.includes(\"apex\") && c.name.toLowerCase().includes(\"apex\")) ||\n500 |             (cleanNewClient.includes(\"retail\") && c.name.toLowerCase().includes(\"retail\")) ||\n501 |             (cleanNewClient.includes(\"logistics\") && c.name.toLowerCase().includes(\"orion\")) ||\n502 |             (cleanNewClient.includes(\"treasury\") && c.name.toLowerCase().includes(\"nova\")) ||\n503 |             (cleanNewClient.includes(\"health\") && c.name.toLowerCase().includes(\"orion\"))\n504 |           );\n505 |           if (matchedClient) {\n506 |             resolvedClientId = matchedClient.id;\n507 |           } else if (clientsList.length > 0) {\n508 |             resolvedClientId = clientsList[0].id;\n509 |           }\n510 |         }\n511 |       } catch (err) {\n512 |         console.error(\"Error resolving client ID:\", err);\n513 |       }\n514 | \n515 |       const formData = new FormData();\n516 |       formData.append(\"file\", adminFile);\n517 |       formData.append(\"client_id\", String(resolvedClientId));\n518 |       if (newProject && newProject !== \"UNASSIGNED\") {\n519 |         formData.append(\"project_id\", newProject);\n520 |       }\n521 |       formData.append(\"title\", newTitle.trim());\n522 |       formData.append(\"document_type\", newType);\n523 |       formData.append(\"version\", newVersion);\n524 |       formData.append(\"visibility\", \"private\");\n525 |       formData.append(\"description\", newDesc || \"Custom compliance specification uploaded through interactive admin console.\");\n526 | \n527 |       const res = await fetch(\"/api/v1/documents/upload\", {\n528 |         method: \"POST\",\n529 |         headers: {\n530 |           \"Authorization\": `Bearer ${token}`\n531 |         },\n532 |         body: formData\n533 |       });\n534 |       const data = await res.json();\n535 |       if (data.success && data.document) {\n536 |         setIsRegisterModalOpen(false);\n537 |         showToast(`Document Registry expanded: Created ${data.document.id}`);\n538 |         setNewTitle(\"\");\n539 |         setNewDesc(\"\");\n540 |         setNewFileSize(\"1.5 MB\");\n541 |         setNewVersion(\"v1.0.0\");\n542 |         setAdminFile(null);\n543 |         await fetchData();\n544 |       } else {\n545 |         showToast(`Failed to register document: ${data.message || \"Unknown error\"}`);\n546 |       }\n547 |     } catch (err) {\n548 |       showToast(`Error creating document in enclave registry.`);\n549 |     } finally {\n550 |       setLoading(false);\n551 |     }\n552 |   };\