lative flex-grow max-w-xl\">\n788 |             <Search className=\"absolute left-3.5 top-2.5 w-4 h-4 text-white/30\" />\n789 |             <input \n790 |               type=\"text\" \n791 |               value={searchQuery} \n792 |               onChange={(e) => setSearchQuery(e.target.value)} \n793 |               placeholder=\"Search by title, security hash, owner, or details...\"\n794 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.01] pl-10 pr-10 text-[12px] font-mono text-white placeholder-white/25 outline-none focus:border-white/15 focus:bg-white/[0.03] transition-all\"\n795 |             />\n796 |             {searchQuery && (\n797 |               <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-3.5 top-2.5 text-white/40 hover:text-white transition-colors\">\n798 |                 <X className=\"w-4 h-4\" />\n799 |               </button>\n800 |             )}\n801 |           </div>\n802 | \n803 |           {/* Controls Right Alignment: Layout Switch & Clear */}\n804 |           <div className=\"flex flex-wrap items-center gap-3 self-end xl:self-auto\">\n805 |             {hasActiveFilters && (\n806 |               <button \n807 |                 onClick={handleResetFilters}\n808 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-[11px] font-mono font-bold text-red-400 uppercase transition-all flex items-center gap-1.5 cursor-pointer\"\n809 |               >\n810 |                 <X className=\"w-3.5 h-3.5\" />\n811 |                 <span>Reset Filters</span>\n812 |               </button>\n813 |             )}\n814 | \n815 |             {/* Layout Toggler (Segmented Control style) */}\n816 |             <div className=\"flex items-center rounded-lg border border-white/5 p-1 bg-black/40\">\n817 |               <button \n818 |                 onClick={() => setLayoutMode(\"grid\")}\n819 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n820 |                   layoutMode === \"grid\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n821 |                 }`}\n822 |               >\n823 |                 <LayoutGrid className=\"w-3.5 h-3.5\" />\n824 |                 <span className=\"hidden sm:inline\">Bento Grid</span>\n825 |               </button>\n826 |               <button \n827 |                 onClick={() => setLayoutMode(\"list\")}\n828 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n829 |                   layoutMode === \"list\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n830 |                 }`}\n831 |               >\n832 |                 <List className=\"w-3.5 h-3.5\" />\n833 |                 <span className=\"hidden sm:inline\">Sovereign Ledger</span>\n834 |               </button>\n835 |             </div>\n836 | \n837 |           </div>\n838 |         </div>\n839 | \n840 |         {/* Dropdown Filters row */}\n841 |         <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 border-t border-white/5 pt-4\">\n842 |           \n843 |           {/* Category Dropdown */}\n844 |           <div className=\"space-y-1.5\">\n845 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Category</span>\n846 |             <div className=\"relative\">\n847 |               <select \n848 |                 value={selectedCategory} \n849 |                 onChange={(e) => setSelectedCategory(e.target.value)} \n850 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-n