   doc.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n602 |         doc.sha256.toLowerCase().includes(searchQuery.toLowerCase()) ||\n603 |         doc.description.toLowerCase().includes(searchQuery.toLowerCase());\n604 | \n605 |       const matchesClient = filterClient === \"all\" || doc.client === filterClient;\n606 |       const matchesProject = filterProject === \"all\" || doc.projectId === filterProject;\n607 |       const matchesType = filterType === \"all\" || doc.type === filterType;\n608 |       const matchesStatus = filterStatus === \"all\" || doc.status === filterStatus;\n609 |       const matchesOwner = filterOwner === \"all\" || doc.owner === filterOwner;\n610 |       const matchesVersion = filterVersion === \"all\" || doc.version === filterVersion;\n611 | \n612 |       return (\n613 |         matchesSearch && \n614 |         matchesClient && \n615 |         matchesProject && \n616 |         matchesType && \n617 |         matchesStatus && \n618 |         matchesOwner && \n619 |         matchesVersion\n620 |       );\n621 |     });\n622 |   }, [\n623 |     documents, searchQuery, filterClient, filterProject, \n624 |     filterType, filterStatus, filterOwner, filterVersion\n625 |   ]);\n626 | \n627 |   const metrics = useMemo(() => {\n628 |     const totalCount = documents.length;\n629 |     const verifiedCount = documents.filter(d => d.status === \"Verified\").length;\n630 |     const unassignedCount = documents.filter(d => d.projectId === \"UNASSIGNED\").length;\n631 |     const integrityRate = totalCount > 0 ? ((verifiedCount / totalCount) * 100).toFixed(1) : \"100.0\";\n632 | \n633 |     return {\n634 |       totalCount,\n635 |       verifiedCount,\n636 |       unassignedCount,\n637 |       integrityRate\n638 |     };\n639 |   }, [documents]);\n640 | \n641 |   const hasActiveFilters = useMemo(() => {\n642 |     return (\n643 |       searchQuery !== \"\" ||\n644 |       filterClient !== \"all\" ||\n645 |       filterProject !== \"all\" ||\n646