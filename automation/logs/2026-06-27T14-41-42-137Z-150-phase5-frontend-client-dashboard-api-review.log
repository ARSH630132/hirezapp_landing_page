ont-bold\">WEEK 26 (ACTIVE)</span>\n451 |                         </div>\n452 |                       </div>\n453 |                     )}\n454 | \n455 |                     {activeModule.id === \"governance\" && (\n456 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 pt-1\">\n457 |                         <div className=\"p-4 rounded-lg border border-white/5 bg-white/[0.01]\">\n458 |                           <span className=\"block text-[9px] font-mono text-white/40 uppercase\">Real-Time Toxicity Check</span>\n459 |                           <span className=\"text-[20px] font-bold text-emerald-400 tracking-tight block mt-1 font-mono\">100% ACTIVE</span>\n460 |                           <span className=\"text-[10px] text-white/50 leading-relaxed font-light mt-0.5 block font-sans\">Zero hazardous or out-of-bounds agent operations permitted.</span>\n461 |                         </div>\n462 |                         <div className=\"p-4 rounded-lg border border-white/5 bg-white/[0.01]\">\n463 |                           <span className=\"block text-[9px] font-mono text-white/40 uppercase\">eBPF Security Guardrail Status</span>\n464 |                           <span className=\"text-[20px] font-bold text-[#E4000F] tracking-tight block mt-1 font-mono\">FULLY ENFORCED</span>\n465 |                           <span className=\"text-[10px] text-white/50 leading-relaxed font-light mt-0.5 block font-sans\">Automated hypervisor process auditing validated daily.</span>\n466 |                         </div>\n467 |                       </div>\n468 |                     )}\n469 | \n470 |                   </div>\n471 | \n472 |                   {/* Terminal Log Console */}\n473 |                   <div className=\"p-4 rounded-xl border border-white/5 bg-black/80 font-mono text-[10.5px] leading-relaxed text-white/50 space-y-1 relative\">\n474 |                     <div className=\"absolute top-3 right-4 flex items-center gap-1.5\">\n475 |            