 * 500) / (dataPoints.length - 1)} ${112 - (val * 0.9)}`).join(' ')} L 500 112 Z`}\n494 |                     fill=\"url(#sparklineGrad)\"\n495 |                     stroke=\"none\"\n496 |                     className=\"transition-all duration-500 ease-out\"\n497 |                   />\n498 |                   \n499 |                   {/* Stroke Line */}\n500 |                   <path\n501 |                     d={dataPoints.map((val, idx) => `${idx === 0 ? 'M' : 'L'} ${(idx * 500) / (dataPoints.length - 1)} ${112 - (val * 0.9)}`).join(' ')}\n502 |                     fill=\"none\"\n503 |                     stroke=\"#009DFF\"\n504 |                     strokeWidth=\"1.5\"\n505 |                     className=\"transition-all duration-500 ease-out\"\n506 |                   />\n507 |                   \n508 |                   {/* Pulsing indicator dot on last point */}\n509 |                   <circle\n510 |                     cx=\"500\"\n511 |                     cy={112 - (dataPoints[dataPoints.length - 1] * 0.9)}\n512 |                     r=\"4\"\n513 |                     className=\"fill-[#009DFF]\"\n514 |                   />\n515 |                 </svg>\n516 |               </div>\n517 |             </div>\n518 | \n519 |             <div className=\"border border-white/5 rounded-xl overflow-hidden overflow-x-auto scrollbar-thin scrollbar-thumb-white/10\">\n520 |               <table className=\"w-full min-w-[500px] text-left font-mono text-[12px] text-white/70\">\n521 |                 <thead>\n522 |                   <tr className=\"bg-white/[0.02] border-b border-white/5 text-white/40 text-[10px] uppercase\">\n523 |                     <th className=\"p-4\">Node Hash</th>\n524 |                     <th className=\"p-4\">eBPF Telemetry</th>\n525 |                     <th className=\"p-4\">Allocated Threads</th>\n526 |                     <th className=\"p-4 text-right\">Ping</th>\n527 |                   </tr>\n528 |                 </thead>\n529 |                 <tbody className=\"divide-y divide-white/5\">\n530 |                   {[\n531 |                     { hash: \"f3a8b291c9\", eBPF: \"Core Enforced\", threads: \"24 Threads\", ping: \"4ms\" },\n532 |                     { hash: \"e88d123880\", eBPF: \"Kernel Audited\", threads: \"16 Threads\", ping: \"3ms\" },\n533 |                     { hash: \"a01fe99211\", eBPF: \"Core Enforced\", threads: \"32 Threads\", ping: \"5ms\" }\n534 |                   ].map(node => (\n535 |                     <tr key={node.hash} className=\"hover:bg-white/[0.01]\">\n536 |                       <td className=\"p-4 text-[#009DFF]\">{node.hash}</td>\n537 |                       <td className=\"p-4 text-white/55\">{node.eBPF}</td>\n538 |                       <td className=\"p-4\">{node.threads}</td>\n539 |                       <td className=\"p-4 text-right text-green-400 font-bold\">{node.ping}</td>\n540 |                     </tr>\n541 |                   ))}\n542 |                 </tbody>\n543 |               </table>\n544 |             </div>\n545 |           </div>\n546 |         )}\n547 | \n548 |         {/* TAB 10: Governance */}\n549 |         {activeTab === \"governance\" && (\n550 |           <div className=\"space-y-4\">\n551 |             <h3 className=\"text-lg font-bold text-white tracking-tight\">Sovereign Compliance & Policies</h3>\n552 |             <p className=\"text-sm text-white/60\">Active guardrail rulebooks, sandbox boundaries, and policy compliance.</p>\n553 |             <div className=\"space-y-3 pt-3 font-mono text-[11px] text-white/60\">\n554 |               <div className=\"p-4 rounded-lg border border-white/5 bg-[#020202]/30 flex justify-between\">\n555 |                 <span>[RULE_01] Block unauthorized external API calls</span>\n556 |                 <span className=\"text-green-400 font-bold uppercase tracking-wider\">Active</span>\n557 |               </div>\n558 |               <div className=\"p-4 rounded-lg border border-white/5 bg-[#