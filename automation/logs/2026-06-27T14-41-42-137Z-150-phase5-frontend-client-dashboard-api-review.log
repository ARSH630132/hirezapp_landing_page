  <defs>\n381 |                 <pattern id=\"diag-grid\" width=\"20\" height=\"20\" patternUnits=\"userSpaceOnUse\">\n382 |                   <path d=\"M 20 0 L 0 0 0 20\" fill=\"none\" stroke=\"rgba(255, 255, 255, 0.02)\" strokeWidth=\"1\" />\n383 |                 </pattern>\n384 |                 <style>\n385 |                   {`\n386 |                     @keyframes pathFlow {\n387 |                       from { stroke-dashoffset: 28; }\n388 |                       to { stroke-dashoffset: 0; }\n389 |                     }\n390 |                     .anim-flow {\n391 |                       stroke-dasharray: 8, 20;\n392 |                       animation: pathFlow 3s linear infinite;\n393 |                     }\n394 |                   `}\n395 |                 </style>\n396 |               </defs>\n397 |               <rect width=\"100%\" height=\"100%\" fill=\"url(#diag-grid)\" />\n398 |               \n399 |               <path d=\"M 70 150 L 200 150\" stroke=\"rgba(255, 255, 255, 0.08)\" strokeWidth=\"1.5\" strokeDasharray=\"5,5\" />\n400 |               <path d=\"M 200 150 L 330 80\" stroke=\"rgba(255, 255, 255, 0.08)\" strokeWidth=\"1.5\" />\n401 |               <path d=\"M 200 150 L 330 220\" stroke=\"rgba(255, 255, 255, 0.08)\" strokeWidth=\"1.5\" />\n402 |               \n403 |               {/* Pulsating flows */}\n404 |               <line x1=\"70\" y1=\"150\" x2=\"200\" y2=\"150\" stroke=\"#06b6d4\" strokeWidth=\"2\" className=\"anim-flow\" />\n405 |               \n406 |               {/* Node 1: Client Gateway */}\n407 |               <g>\n408 |                 <circle cx=\"70\" cy=\"150\" r=\"16\" fill=\"#030303\" stroke=\"rgba(6, 182, 212, 0.3)\" strokeWidth=\"2\" />\n409 |                 <circle cx=\"70\" cy=\"150\" r=\"24\" fill=\"none\" stroke=\"rgba(6, 182, 212, 0.1)\" strokeWidth=\"1\" className=\"animate-ping\" style={{ animationDuration: '4s' }} />\n410 |                 <circle cx=\"70\" cy=\"150\" r=\"4\" fill=\"#06b6d4\" />\n411 |                 <text x=\"70\" y=\"184\" textAnchor=\"middle\" fill=\"rgba(255,255,255,0.3)\" fontSize=\"9\" fontFamily=\"monospace\" fontWeight=\"bold\">GATEWAY</text>\n412 |               </g>\n413 | \n414 |               {/* Node 2: Crypto Decryption Enclave (Locked state) */}\n415 |               <g>\n416 |                 <rect x=\"176\" y=\"126\" width=\"48\" height=\"48\" rx=\"8\" fill=\"#050505\" stroke=\"rgba(239, 68, 68, 0.3)\" strokeWidth=\"1.5\" />\n417 |                 <rect x=\"176\" y=\"126\" width=\"48\" height=\"48\" rx=\"8\" fill=\"none\" stroke=\"rgba(239, 68, 68, 0.05)\" strokeWidth=\"4\" className=\"animate-pulse\" />\n418 |                 <path d=\"M 194 153 L 206 153 M 197 153 L 197 146 C 197 142.7 199.7 141 200 141 C 200.3 141 203 142.7 203 146 L 203 153\" stroke=\"#ef4444\" strokeWidth=\"1.5\" strokeLinecap=\"round\" />\n419 |                 <rect x=\"194\" y=\"149\" width=\"12\" height=\"9\" rx=\"1.5\" fill=\"#ef4444\" />\n420 |                 <text x=\"200\" y=\"191\" textAnchor=\"middle\" fill=\"#ef4444\" fontSize=\"9\" fontFamily=\"monospace\" fontWeight=\"bold\">DECOUPLED</text>\n421 |               </g>\n422 | \n423 |               {/* Node 3: Target Portal */}\n424 |               <g className=\"opacity-35\">\n425 |                 <circle cx=\"330\" cy=\"80\" r=\"12\" fill=\"#030303\" stroke=\"rgba(255, 255, 255, 0.15)\" strokeWidth=\"1.5\" />\n426 |                 <circle cx=\"330\" cy=\"80\" r=\"3\" fill=\"rgba(255,255,255,0.3)\" />\n427 |                 <text x=\"330\" y=\"104\" textAnchor=\"middle\" fill=\"rgba(255,255,255,0.3)\" fontSize=\"8\" fontFamily=\"monospace\">PORTAL</text>\n428 |               </g>\n429 | \n430 |               {/* Node 4: Target Admin */}\n431 |               <g className=\"opacity-35\">\n432 |                 <circle cx=\"330\" cy=\"220\" r=\"12\" fill=\"#030303\" stroke=\"rgba(255, 255, 255, 0.15)\" strokeWidth=\"1.5\" />\n433 |                 <circle cx=\"330\" cy=\"220\" r=\"3\" fill=\"rgba(255,255,255,0.3)\" />\n434 |                 <text x=\"330\" y=\"244\" textAnchor=\"middle\" fill=\"rgba(255,255,255,0.3)\" fontSize=\"8\" fontFamily=\"monospace\">ADMIN</text>\n435 |               </g>\n436 |             </svg>\n437 |           </div>\n438 | \n439 |           {/* Telemetry log terminal */}\n440 |           <div className=\"bg-black/50 border border-white/5 rounded-xl p-4 font-mono text-[9px] text-zinc-500 space-y-1.5 shadow-inner\">\n441 |             <div className=\"flex items-center justify-between text-[8px] text-zinc-400 border-b border-white/5 pb-1.5 mb-2 select-none\">\n442 |               <span className=\"flex items-center gap-1.5\">\n443 |                 <span className=\"w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse\" />\n444 |                 SECURE TELEMETRY BUFFER\n445 |               </span>\n446 |               <span>UTC LOGS</span>\n447 |             </div>\n448 |             <div className=\"space-y-1 select-text h-[70px] overflow-hidden flex flex-col justify-end\" aria-live=\"polite\">\n449 |               {terminalLogs.map((log, idx) => (\n450 |                 <div key={idx} className={log.includes(\"WARNING\") ? \"text-red-400 font-bold\" : log.includes(\"AUTHORIZED\") ? \"text-emerald-400 font-bold\" : \"text-zinc-500\"}>\n451 |                   {log}\n452 |                 </div>\n453 |               ))}\n454 |             </div>\n455 |           </div>\n456 |         </div>\n457 | \n458 |         {/* Right Side: Identity Controls and Simulator Bypass (Interactive form) */}\n459 |         <div className=\"col-span-1 lg:col-span-7 flex flex-col justify-center p-6 md:p-12 lg:p-16 max-w-2xl mx-auto w-full\">\n460 |           <div className=\"space-y-8\">\n461 |             <div className=\"space-y-3\">\n462 |               <span className=\"text-[8px] tracking-widest font-bold uppercase px-2.5 py-1 rounded bg-zinc-900 border border-white/5 text-zinc-400 select-none\">\n463 |                 ENCLAVE DISCOVERY GATEWAY\n464 |               </span>\n465 |               <h1 className=\"text-2xl md:text-3xl font-extrabold tracking-tight text-white uppercase font-sans\">\n466 |                 Identity Decoupled\n467 |               </h1>\n468 |               <p className=\"text-[11px] md:text-xs text-zinc-400 leading-relaxed font-sans max-w-md\">\n469 |                 No simulated preview session is currently associated with your browser client. To access the interactive sandbox of GFF AI, authorize your token.\n470 |               </p>\n471 |             </div>\n472 | \n473 |             {/* Countdown redirect bar */}\n474 |             <div className=\"space-y-1.5 bg-zinc-950/40 p-4 rounded-xl border border-white/5\">\n475 |               <div className=\"flex justify-between items-center text-[9px] font-mono text-zinc-500 tracking-wider\">\n476 |                 <span className=\"flex items-center gap-1.5\">\n477 |                   <RefreshCw className=\"w-3 h-3 text-red-500 animate-spin\" />\n478 |                   STANDBY: REDIRECTING TO IDENTITY GATEWAY\n479 |                 </span>\n480 |                 <span className=\"font-bold\">{countdown}S</span>\n481 |               </div>\n482 |               <div className=\"h-1 bg-zinc-900 border border-white/5 rounded-full overflow-hidden\">\n483 |                 <div \n484 |                   className=\"h-full bg-red-500/80 transition-all duration-1000 ease-linear\" \n485 |                   style={{ width: `${pct}%` }} \n486 |                 />\n487 |               </div>\n488 |               <div className=\"flex flex-col sm:flex-row gap-3 pt-2\">\n489 |                 <button \n490 |                   onClick={() => router.push(type === \"admin\" ? \"/admin/login\" : \"/portal/login\")}\n491 |                   className=\"w-full h-10 rounded-lg bg-white hover:bg-zinc-200 text-black text-[10px] font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center justify-center gap-2 shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-white\"\n492 |                 >\n493 |                   <Fingerprint className=\"w-3.5 h-3.5\" />\n494 |                   <span>Authenticate Manually</span>\n495 |                 </button>\n496 |               </div>\n497 |             </div>\n498 | \n499 |             {/* Simulated Workspace Quick Launch Grid */}\n500 |             <div className=\"space-y-4\">\n501 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n502 |                 <span className=\"text-[9px] font-mono text-zinc-500 font-bold uppercase tracking-widest\">\n503 |                   Quick-Authenticate Sandbox Simulation\n504 |                 </span>\n505 |                 <span className=\"text-[8px] font-mono text-cyan-400/60 font-semibold select-none\">\n506 |                   DEVELOPER BYPASS\n507 |                 </span>\n508 |               </div>\n509 |               <p className=\"text-[10px] text-zinc-500 leading-relaxed\">\n510 |                 Skip full credential checks and force-bind a mock clearance identity to instantly traverse this portal sector:\n511 |               </p>\n512 | \n513 |               <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n514 |                 {simProfiles.map((roleId) => {\n515 |                   const meta = ROLE_METADATA[roleId];\n516 |                   const isNegotiating = negotiating === roleId;\n517 | \n518 |                   return (\n519 |                     <button\n520 |                       key={roleId}\n521 |                       onClick={() => handleBypass(roleId)}\n522 |                       disabled={negotiating !== null}\n523 |                       className=\"text-left p-4 rounded-xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all duration-300 group relative overflow-hidden flex flex-col justify-between h-36 cursor-pointer hover:border-white/15 focus-visible:outline focus-visible:outline-1 focus-visible:outline-cyan-500 disabled:opacity-40\"\n524 |                       style={{\n525 |                         boxShadow: isNegotiating ? `0 0 24px ${meta.glowColor}` : \"none\",\n526 |                       }}\n527 |                     >\n528 |                       <div className=\"space-y-1.5\">\n529 |                         <div className=\"flex justify-between items-start\">\n530 |                           <span className={`text-[7.5px] font-mono font-bold tracking-widest px-1.5 py-0.5 rounded border uppercase ${meta.badgeClass}`}>\n531 |                             {meta.clearance}\n532 |                           </span>\n533 |                           {isNegotiating ? (\n534 |                             <RefreshCw className=\"w-3 h-3 text-cyan-400 animate-spin\" />\n535 |                           ) : (\n536 |                             <Key className=\"w-3 h-3 text-white/20 group-hover:text-white/55 transition-colors\" />\n537 |                           )}\n538 |                         </div>\n539 |                         <h3 className=\"text-xs font-bold text-white tracking-wide\">{meta.title}</h3>\n540 |                         <p className=\"text-[10px] text-zinc-500 leading-normal line-clamp-2\">{meta.desc}</p>\n541 |                       </div>\n542 |                       \n543 |                       <div className=\"flex items-center gap-1.5 text-[9px] font-mono font-bold text-white/40 group-hover:text-white/85 transition-all pt-2.5 border-t border-white/[0.03]\">\n544 |                         {isNegotiating ? (\n545 |                           <span className=\"text-cyan-400 animate-pulse\">NEGOTIATING HANDSHAKE...</span>\n546 |                         ) : (\n547 |                           <>\n548 |                             <span>FORCE DEPLOY SIMULATION</span>\n549 |                             <ArrowRight className=\"w-2.5 h-2.5 transform group-hover:translate-x-1 transition-transform text-white/40 group-hover:text-cyan-400\" />\n550 |                           </>\n551 |                         )}\n552 |                       </div>\n553 |                     </button>\n554 |                   );\n555 |                 })}\n556 |               </div>\n557 |             </div>\n558 |           </div>\n559 |         </div>\n560 |       </div>\n561 |     );\n562 |   }\n563 | \n564 |   // SCREEN 2: Clearance Insufficient / Restricted Boundary (Split-Panel Layout)\n565 |   if (!hasAccess) {\n566 |     const authorizedRoles = getAuthorizedRoles();\n567 | \n568 |     return (\n569 |       <div className=\"min-h-screen grid grid-cols-1 lg:grid-cols-12 bg-[#030303] text-white font-sans antialiased selection:bg-red-500/20 selection:text-red-300\">\n570 |         \n571 |         {/* Left Side: Real-time interactive access matrix visual timeline & logs (Desktop only) */}\n572 |         <div className=\"hidden lg:flex lg:col-span-5 border-r border-white/5 bg-[#050505]/60 flex-col justify-between p-10 font-mono\">\n573 |           <div className=\"space-y-6\">\n574 |             <div className=\"flex items-center gap-2 text-white/30 text-[9px] uppercase tracking-widest font-bold\">\n575 |               <Shield className=\"w-3.5 h-3.5 text-red-500\" />\n576 |               <span>GFF Cryptographic Firewall</span>\n577 |             </div>\n578 |             \n579 |             {/* Visual Timeline of Clearance levels */}\n580 |             <div className=\"space-y-4\">\n581 |               <div className=\"text-zinc-400 text-xs font-mono font-bold tracking-wider uppercase mb-3 flex items-center gap-2\">\n582 |                 <Shield className=\"w-4 h-4 text-zinc-400\" />\n583 |                 Active Access Matrix\n584 |               </div>\n585 |               \n586 |               <div className=\"space-y-3 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[1px] before:bg-white/10\">\n587 |                 {CLEARANCE_TIERS.map((tier) => {\n588 |                   const isCurrent = tier.roles.includes(session.role);\n589 |                   const isRouteAllowed = tier.roles.some(r => \n590 |                     type === \"portal\" \n591 |                       ? canAccessPortalSection(r as PreviewRole, activeSec) \n592 |                       : canAccessAdminSection(r as PreviewRole, activeSec)\n593 |                   );\n594 | \n595 |                   return (\n596 |                     <div key={tier.level} className={`flex gap-4 relative transition-all duration-300 ${isCurrent ? \"scale-[1.01] translate-x-0.5\" : \"\"}`}>\n597 |                       <div className=\"relative z-10 flex items-center justify-center\">\n598 |                         {isCurrent ? (\n599 |                           <div className=\"w-6 h-6 rounded-full bg-red-950/80 border border-red-500 flex items-center justify-center animate-pulse shadow-[0_0_12px_rgba(239,68,68,0.4)]\">\n600 |                             <span className=\"w-2 h-2 rounded-full bg-red-500\" />\n601 |                           </div>\n602 |                         ) : isRouteAllowed ? (\n603 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-900 border border-emerald-500/30 flex items-center justify-center\">\n604 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" />\n605 |                           </div>\n606 |                         ) : (\n607 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-950 border border-white/10 flex items-center justify-center\">\n608 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-zinc-700\" />\n609 |                           </div>\n610 |                         )}\n611 |                       </div>\n612 | \n613 |                       <div className={`flex-1 p-3.5 rounded-xl border transition-all ${\n614 |                         isCurrent \n615 |                           ? \"bg-red-500/[0.02] border-red-500/20 shadow-[0_4px_20px_rgba(239,68,68,0.05)]\" \n616 |                           : isRouteAllowed \n617 |                             ? \"bg-white/[0.01] border-white/10\" \n618 |                             : \"bg-black/40 border-white/5 opacity-40\"\n619 |                       }`}>\n620 |                         <div className=\"flex items-center justify-between\">\n621 |                           <div className=\"flex items-center gap-2\">\n622 |                             <span className=\"text-[9px] font-mono font-bold tracking-wider text-white/50\">{tier.level}</span>\n623 |                             <span className=\"text-[10px] font-bold text-white tracking-wide uppercase\">{tier.name}</span>\n624 |                           </div>\n625 |                           <div>\n626 |                             {isCurrent ? (\n627 |                               <span className=\"text-[8px] font-mono text-red-400 bg-red-500/10 border border-red-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-widest\">Active Identity</span>\n628 |                             ) : isRouteAllowed ? (\n629 |                               <span className=\"text-[8px] font-mono text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-widest font-semibold\">Allowed</span>\n630 |                             ) : (\n631 |                               <span className=\"text-[8px] font-mono text-white/30 bg-white/5 border border-white/10 px-2 py-0.5 rounded uppercase font-bold tracking-widest font-semibold\">Restricted</span>\n632 |                             )}\n633 |                           </div>\n634 |                         </div>\n635 |                         <div className=\"mt-1.5 text-[9.5px] text-zinc-500 leading-normal\">\n636 |                           Authorized: <span className=\"text-zinc-400 font-mono\">{tier.roles.map(r => ROLE_METADATA[r as PreviewRole]?.title).join(\", \")}</span>\n637 |                         </div>\n638 |                       </div>\n639 |                     </div>\n640 |                   );\n641 |                 })}\n642 |               </div>\n643 |             </div>\n644 |           </div>\n645 | \n646 |           {/* Telemetry log terminal */}\n647 |           <div className=\"bg-black/50 border border-white/5 rounded-xl p-4 font-mono text-[9px] text-zinc-500 space-y-1.5 shadow-inner mt-6\">\n648 |             <div className=\"flex items-center justify-between text-[8px] text-zinc-400 border-b border-white/5 pb-1.5 mb-2 select-none\">\n649 |               <span className=\"flex items-center gap-1.5\">\n650 |                 <span className=\"w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse\" />\n651 |                 SECURE TELEMETRY BUFFER\n652 |               </span>\n653 |               <span>UTC LOGS</span>\n654 |             </div>\n655 |             <div className=\"space-y-1 select-text h-[70px] overflow-hidden flex flex-col justify-end\" aria-live=\"polite\">\n656 |               {terminalLogs.map((log, idx) => (\n657 |                 <div key={idx} className={log.includes(\"WARNING\") || log.includes(\"BLOCK\") ? \"text-red-400 font-bold\" : log.includes(\"AUTHORIZED\") ? \"text-emerald-400 font-bold\" : \"text-zinc-500\"}>\n658 |                   {log}\n659 |                 </div>\n660 |               ))}\n661 |             </div>\n662 |           </div>\n663 |         </div>\n664 | \n665 |         {/* Right Side: Identity swap & fallback triggers (Interactive form) */}\n666 |         <div className=\"col-span-1 lg:col-span-7 flex flex-col justify-center p-6 md:p-12 lg:p-16 max-w-2xl mx-auto w-full\">\n667 |           <div className=\"space-y-8\">\n668 |             <div className=\"space-y-3\">\n669 |               <span className=\"text-[8px] tracking-widest font-bold uppercase px-2.5 py-1 rounded bg-red-500/10 border border-red-500/20 text-red-400 select-none\">\n670 |                 RESTRICTED SEGMENT BOUNDARY\n671 |               </s