stify-between pt-2\">\n373 |                 <span className=\"text-xs text-white/55\">Billing Status</span>\n374 |                 <span className=\"text-green-400 font-mono font-bold uppercase tracking-wider text-xs\">Good Standing</span>\n375 |               </div>\n376 |             </div>\n377 |           </div>\n378 |         )}\n379 | \n380 |         {/* TAB 7: Approvals */}\n381 |         {activeTab === \"approvals\" && (\n382 |           <div className=\"space-y-4\">\n383 |             <h3 className=\"text-lg font-bold text-white tracking-tight\">Active Approvals Queue</h3>\n384 |             <p className=\"text-sm text-white/60\">Human-in-the-loop authorization gates for sensitive agent overrides.</p>\n385 |             <div className=\"space-y-3 pt-3\">\n386 |               {[\n387 |                 { rule: \"Allow secondary ledger write privileges\", agent: \"RetailMesh-Agent-02A\", time: \"Pending approval\" },\n388 |                 { rule: \"Alter maximum sensory memory cache bounds\", agent: \"Foundry-Agent-11\", time: \"Pending approval\" }\n389 |               ].map((app, i) => (\n390 |                 <div key={i} className=\"p-4 rounded-lg border border-white/5 bg-white/[0.01] flex flex-col sm:flex-row sm:items-center justify-between gap-4\">\n391 |                   <div>\n392 |                     <span className=\"text-[10px] font-mono text-[#009DFF] uppercase tracking-wider\">{app.agent}</span>\n393 |                     <h4 className=\"text-[13px] font-bold text-white mt-1\">{app.rule}</h4>\n394 |                   </div>\n395 |                   <div className=\"flex gap-2 self-start sm:self-auto\">\n396 |                     <button className=\"px-3 py-1.5 rounded text-[11px] font-mono bg-green-500/10 border border-green-500/20 text-green-400 cursor-pointer\">Approve</button>\n397 |                     <button className=\"px-3 py-1.5 rounded text-[11px] font-mono bg-[#E4000F]/10 border border-[#E4000F]/20 text-[#E4000F] cursor-pointer\">Deny</button>\n398 |                   </div>\n399 |                 </div>\n400 |               ))}\n401 |             </div>\n402 |           </div>\n403 |         )}\n404 | \n405 |         {/* TAB 8: Support */}\n406 |         {activeTab === \"support\" && (\n407 |           <div className=\"space-y-6\">\n408 |             <h3 className=\"text-lg font-bold text-white tracking-tight\">Secure Technical Support</h3>\n409 |             <p className=\"text-sm text-white/60\">Communicate directly with our systems engineers through a secure decoupled loop.</p>\n410 |             \n411 |             <form onSubmit={handleAddTicket} className=\"space-y-3 max-w-[500px]\">\n412 |               <input \n413 |                 required \n414 |                 placeholder=\"Enter technical query or ticket subject...\" \n415 |                 value={newSubject}\n416 |                 onChange={e => setNewSubject(e.target.value)}\n417 |                 className=\"w-full h-10 rounded-lg border border-white/10 bg-white/[0.01] px-4 text-white text-[12.5px] outline-none font-mono focus:border-white/20\"\n418 |               />\n419 |               <button type=\"submit\" className=\"px-4 h-9 rounded bg-white text-black font-semibold text-xs tracking-wider uppercase cursor-pointer\">Submit Support Ticket</button>\n420 |             </form>\n421 | \n422 |             <div className=\"border border-white/5 rounded-xl overflow-hidden mt-6\">\n423 |               <div className=\"bg-white/[0.02] border-b border-white/5 px-4 py-2 text-[10.5px] font-mono text-white/40 uppercase\">Sovereign Support Tickets</div>\n424 |               <div className=\"p-4 space-y-2.5 font-mono text-[11px]\">\n425 |                 {tickets.map((t, i) => (\n426 |                   <div key={i} className=\"flex justify-between border-b border-white/5 pb-2 last:border-b-0 last:pb-0\">\n427 |                     <div>\n428 |                       <span className=\"text-[#009DFF] font-bold mr-2\">{t.id}</span>\n429 