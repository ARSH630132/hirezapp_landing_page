03 |       \n304 |       let allowed = false;\n305 |       if (type === \"portal\") {\n306 |         if (isClient || role === \"gff_admin\") {\n307 |           allowed = canAccessPortalSection(role, sec);\n308 |         }\n309 |       } else if (type === \"admin\") {\n310 |         if (isAdmin) {\n311 |           allowed = canAccessAdminSection(role, sec);\n312 |         }\n313 |       }\n314 |       \n315 |       if (allowed) {\n316 |         // Refresh or traverse cleanly to the exact page they requested\n317 |         router.push(pathname);\n318 |       } else {\n319 |         // Fall back to dashboard of the respective section\n320 |         router.push(role.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n321 |       }\n322 |     }, 1000);\n323 |   };\n324 | \n325 |   // Helper to dynamically calculate which roles are authorized for the blocked section\n326 |   const getAuthorizedRoles = (): PreviewRole[] => {\n327 |     return ALL_ROLES.filter(role => {\n328 |       const isClient = role === \"client_admin\" || role === \"client_member\";\n329 |       const isAdmin = [\"gff_admin\", \"gff_operator\", \"finance_admin\", \"support_agent\", \"viewer\"].includes(role);\n330 |       \n331 |       if (type === \"portal\") {\n332 |         if (isClient || role === \"gff_admin\") {\n333 |           return canAccessPortalSection(role, activeSec);\n334 |         }\n335 |       } else if (type === \"admin\") {\n336 |         if (isAdmin) {\n337 |           return canAccessAdminSection(role, activeSec);\n338 |         }\n339 |       }\n340 |       return false;\n341 |     });\n342 |   };\n343 | \n344 |   if (!mounted) return <div className=\"min-h-screen bg-[#030303]\" />;\n345 | \n346 |   // Verify loading state\n347 |   if (loading) {\n348 |     return (\n349 |       <div className=\"min-h-screen bg-[#030303] text-white flex flex-col items-center justify-center font-mono\">\n350 |         <RefreshCw className=\"w-5 h-5 text-cyan-400 animate-spin