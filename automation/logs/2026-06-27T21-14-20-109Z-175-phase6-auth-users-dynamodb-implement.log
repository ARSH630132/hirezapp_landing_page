meData = await meRes.json();\n290 |             if (meData.success && meData.user) {\n291 |               const u = meData.user;\n292 |               logTelemetry(`[AUTH] Enclave identity verified: ${u.name} (${u.role.toUpperCase()})`);\n293 | \n294 |               // Store session in localStorage under key gff_ai_preview_session_v1\n295 |               const sessionObj = {\n296 |                 name: u.name,\n297 |                 email: u.email,\n298 |                 role: u.role as any,\n299 |                 clearance: u.clearance || \"CLEARANCE LEVEL III (SANDBOX OPERATOR)\",\n300 |                 isMock: false,\n301 |                 label: `REST-API AUTH: ${u.clientAssociation || \"Core\"}`\n302 |               };\n303 |               localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify(sessionObj));\n304 |               \n305 |               // Dispatch change event to notify other components\n306 |               window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n307 | \n308 |               await new Promise(r => setTimeout(r, 400));\n309 |               setScanning(false);\n310 | \n311 |               // Redirect based on role\n312 |               const isGffStaff = !u.role.startsWith(\"client_\");\n313 |               router.push(isGffStaff ? \"/admin/dashboard\" : \"/portal/dashboard\");\n314 |               return;\n315 |             }\n316 |           }\n317 |         }\n318 |       } else {\n319 |         const errBody = await res.json().catch(() => null);\n320 |         if (errBody && errBody.message) {\n321 |           setError(errBody.message);\n322 |           logTelemetry(`[ERROR] Verification rejected: ${errBody.message}`);\n323 |           setScanning(false);\n324 |           return;\n325 |         }\n326 |       }\n327 |     } catch (err) {\n328 |       logTelemetry(\"[SYS] API gateway unreachable. Activating cryptographic preview fallback...\");\n329 |     }\n330 | \n331 |     // --- PRESERVE ROLE PREVIEW FALLB