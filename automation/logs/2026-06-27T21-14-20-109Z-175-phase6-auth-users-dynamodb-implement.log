e)\n 93 |     login_res = client.post(\n 94 |         \"/api/v1/auth/login\",\n 95 |         data={\"username\": \"client_member@apex.com\", \"password\": \"password123\"}\n 96 |     )\n 97 |     token = login_res.json()[\"access_token\"]\n 98 |     headers = {\"Authorization\": f\"Bearer {token}\"}\n 99 | \n100 |     # /api/v1/clients is an admin-only route that requires 'require_admin'\n101 |     response = client.get(\"/api/v1/clients\", headers=headers)\n102 |     assert response.status_code == 403\n103 |     assert \"Operation not permitted\" in response.json()[\"detail\"]\n104 | \n105 | \n106 | def test_5_client_dashboard_data_scoping():\n107 |     \"\"\"\n108 |     5. Verify client dashboard data scoping and multi-tenant isolation.\n109 |     \"\"\"\n110 |     # Get token for client_admin at Apex Global\n111 |     login_res = client.post(\n112 |         \"/api/v1/auth/login\",\n113 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n114 |     )\n115 |     apex_token = login_res.json()[\"access_token\"]\n116 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n117 | \n118 |     # Get apex user details to find client_id\n119 |     me_res = client.get(\"/api/v1/auth/me\", headers=apex_headers)\n120 |     apex_client_id = me_res.json()[\"client_id\"]\n121 | \n122 |     # Verify client user can access their own dashboard\n123 |     res_own = client.get(f\"/api/v1/dashboard/client?client_id={apex_client_id}\", headers=apex_headers)\n124 |     assert res_own.status_code == 200\n125 |     assert res_own.json()[\"success\"] is True\n126 |     assert res_own.json()[\"client_id\"] == apex_client_id\n127 | \n128 |     # Verify client user is BLOCKED from accessing another client's dashboard (e.g. client_id + 1)\n129 |     other_client_id = apex_client_id + 1\n130 |     res_other = client.get(f\"/api/v1/dashboard/client?client_id={other_client_id}\", headers=apex_headers)\n131 |     assert res_other.status_code == 403\n1