2 |       case \"Core Terminal\":\n373 |         return [\"client_admin\", \"client_member\", \"gff_operator\", \"finance_admin\", \"support_agent\"].includes(role)\n374 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n375 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n376 |       case \"AI Operations\":\n377 |         return [\"client_admin\", \"client_member\", \"gff_operator\"].includes(role)\n378 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n379 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n380 |       case \"AI Governance\":\n381 |         return [\"client_admin\", \"client_member\", \"gff_operator\"].includes(role)\n382 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n383 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n384 |       case \"Financial Ledger\":\n385 |         return [\"client_admin\", \"finance_admin\"].includes(role)\n386 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n387 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n388 |       case \"Sovereign Control\":\n389 |         return [\"gff_operator\"].includes(role)\n390 |           ? { status: \"AUTHORIZED\", color: \"text-emerald-400 border-emerald-500/20 bg-emerald-500/5\", dot: \"bg-emerald-400\" }\n391 |           : { status: \"RESTRICTED\", color: \"text-zinc-600 border-zinc-800 bg-zinc-950/20\", dot: \"bg-zinc-700\" };\n392 |       case \"Support Enclave\":