ntAccount).filter(ClientAccount.id != apex_client_id).first()\n176 |     other_client_id = other_client.id\n177 |     db.close()\n178 | \n179 |     # Create a valid ticket under own client account\n180 |     ticket_payload = {\n181 |         \"client_id\": apex_client_id,\n182 |         \"title\": \"Smoke Test Ticket\",\n183 |         \"category\": \"Technical\",\n184 |         \"priority\": \"low\",\n185 |         \"status\": \"open\",\n186 |         \"description\": \"This is a backend smoke test ticket description.\"\n187 |     }\n188 |     response_create = client.post(\"/api/v1/support-tickets\", json=ticket_payload, headers=apex_headers)\n189 |     assert response_create.status_code == 201\n190 |     created_ticket = response_create.json()\n191 |     assert created_ticket[\"title\"] == \"Smoke Test Ticket\"\n192 |     assert created_ticket[\"client_id\"] == apex_client_id\n193 | \n194 |     # Try to create a ticket for another client account and verify 403 Forbidden\n195 |     invalid_ticket_payload = {\n196 |         \"client_id\": other_client_id,\n197 |         \"title\": \"Malicious Cross-Tenant Ticket\",\n198 |         \"category\": \"Security\",\n199 |         \"priority\": \"critical\",\n200 |         \"status\": \"open\",\n201 |         \"description\": \"Attempting to insert a ticket into another client account.\"\n202 |     }\n203 |     response_invalid = client.post(\"/api/v1/support-tickets\", json=invalid_ticket_payload, headers=apex_headers)\n204 |     assert response_invalid.status_code == 403\n205 |     assert \"You can only create tickets for your own client account\" in response_invalid.json()[\"detail\"]\n206 | ","success":true}],"durationMs":6}}
