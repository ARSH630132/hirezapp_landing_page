any client account.\")\n 42 |         if ticket_in.client_id != current_user.client_id:\n 43 |             raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You can only create tickets for your own client account.\")\n 44 |             \n 45 |     item_data = {\n 46 |         \"project_id\": ticket_in.project_id,\n 47 |         \"title\": ticket_in.title,\n 48 |         \"category\": ticket_in.category,\n 49 |         \"priority\": ticket_in.priority,\n 50 |         \"status\": ticket_in.status,\n 51 |         \"assigned_to\": ticket_in.assigned_to,\n 52 |         \"created_by\": current_user.email,\n 53 |         \"description\": ticket_in.description,\n 54 |         \"comments\": ticket_in.comments or \"[]\"\n 55 |     }\n 56 |     return portal_items_repo.create_item(\"SUPPORT\", str(ticket_in.client_id), item_data)\n 57 | \n 58 | @router.get(\"\", response_model=List[SupportTicketResponse])\n 59 | def list_support_tickets(\n 60 |     status: Optional[str] = None,\n 61 |     priority: Optional[str] = None,\n 62 |     category: Optional[str] = None,\n 63 |     client_id: Optional[int] = None,\n 64 |     project_id: Optional[int] = None,\n 65 |     assigned_to: Optional[str] = None,\n 66 |     search: Optional[str] = None,\n 67 |     limit: int = Query(100, ge=1, le=1000),\n 68 |     offset: int = Query(0, ge=0),\n 69 |     skip: Optional[int] = Query(None, ge=0),\n 70 |     db = Depends(get_db),\n 71 |     current_user: User = Depends(get_current_user)\n 72 | ):\n 73 |     \"\"\"List support tickets scoped to user's client account unless admin.\"\"\"\n 74 |     is_admin_or_support = current_user.role in [\"admin\", \"gff_admin\", \"support_agent\"]\n 75 |     if not is_admin_or_support:\n 76 |         if client_id is not None and client_id != current_user.client_id:\n 77 |             raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You do not have permission to view other client accounts' tickets.\")\n 78 |         query_clien