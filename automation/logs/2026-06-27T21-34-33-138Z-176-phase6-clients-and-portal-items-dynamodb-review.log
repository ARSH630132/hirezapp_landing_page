ON.stringify({ name: \"API Updated\", clearance: \"L4\" }) }), { params: Promise.resolve({ id: cid }) });\n47 |     if (res.status !== 200) throw new Error(\"Expected patch success\");\n48 |     res = await statusRoute.PATCH(new Request(`http://l/api/v1/users/${cid}/status`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ status: \"inactive\" }) }), { params: Promise.resolve({ id: cid }) });\n49 |     if (res.status !== 200) throw new Error(\"Expected status success\");\n50 |     res = await roleRoute.PATCH(new Request(`http://l/api/v1/users/${cid}/role`, { method: \"PATCH\", headers: { \"Authorization\": admin }, body: JSON.stringify({ role: \"client_admin\" }) }), { params: Promise.resolve({ id: cid }) });\n51 |     if (res.status !== 200) throw new Error(\"Expected role success\");\n52 |     d = await res.json();\n53 |     if (d.user.role !== \"client_admin\" || !d.user.permissions.includes(\"write:projects\")) throw new Error(\"Role sync failed\");\n54 |     res = await userIdRoute.DELETE(new Request(`http://l/api/v1/users/${cid}`, { method: \"DELETE\", headers: { \"Authorization\": admin } }), { params: Promise.resolve({ id: cid }) });\n55 |     if (res.status !== 200) throw new Error(\"Expected delete success\");\n56 |     if (apiAuth.API_MOCK_USERS[\"apitest@gff.ai\"] !== undefined) throw new Error(\"User not deleted\");\n57 |     console.log(\"\\x1b[32m✔ All User Admin CRUD API tests passed successfully!\\x1b[0m\");\n58 |     process.exit(0);\n59 |   } catch (err) {\n60 |     console.error(\"\\x1b[31m✖ Test failed:\\x1b[0m\", err.stack || err.message);\n61 |     process.exit(1);\n62 |   } finally {\n63 |     if (fs.existsSync(T)) fs.rmSync(T, { recursive: true, force: true });\n64 |   }\n65 | }\n66 | run();","success":true}],"durationMs":3}}
