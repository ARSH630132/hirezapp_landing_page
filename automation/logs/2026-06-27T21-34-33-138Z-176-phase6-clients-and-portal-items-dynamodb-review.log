     return bcrypt.compareSync(attempt, storedHash);\n 97 |     }\n 98 |   } catch (err) {\n 99 |     console.error(\"[BCRYPT] Comparison error:\", err);\n100 |   }\n101 | \n102 |   return false;\n103 | }\n104 | \n105 | export function mapDynamoUserToApiUser(dbUser: DynamoDbUser): any {\n106 |   const role = dbUser.role || \"client_member\";\n107 |   \n108 |   let clearance = \"CLEARANCE LEVEL I (BASIC VIEW-ONLY)\";\n109 |   let permissions: string[] = [\"read:telemetry\", \"read:projects\", \"read:ai-operations\", \"read:documents\", \"write:support\"];\n110 |   \n111 |   if (role === \"gff_admin\") {\n112 |     clearance = \"CLEARANCE LEVEL V (SECURE PLATFORM SUPERUSER)\";\n113 |     permissions = [\n114 |       \"all:*\", \"read:telemetry\", \"write:telemetry\", \"read:projects\", \"write:projects\",\n115 |       \"read:users\", \"write:users\", \"read:clients\", \"write:clients\", \"write:governance\"\n116 |     ];\n117 |   } else if (role === \"client_admin\") {\n118 |     clearance = \"CLEARANCE LEVEL III (SANDBOX OPERATOR)\";\n119 |     permissions = [\n120 |       \"read:telemetry\", \"read:projects\", \"write:projects\", \"read:ai-operations\",\n121 |       \"write:ai-operations\", \"read:documents\", \"write:documents\", \"write:support\"\n122 |     ];\n123 |   }\n124 | \n125 |   // Handle client association\n126 |   let clientAssociation = \"GFF AI Platform Core (Global Root)\";\n127 |   if (role !== \"gff_admin\") {\n128 |     if (dbUser.client_id !== undefined && dbUser.client_id !== null) {\n129 |       const cid = String(dbUser.client_id);\n130 |       if (cid === \"1\" || cid.toLowerCase().includes(\"apex\") || cid.toLowerCase().includes(\"client-001\")) {\n131 |         clientAssociation = \"Apex Sovereign Group [Preview Client]\";\n132 |       } else if (cid === \"2\" || cid.toLowerCase().includes(\"retail\") || cid.toLowerCase().includes(\"client-002\")) {\n133 |         clientAssociation = \"Global Retail Enclave [Preview Client]\";\n134 |       