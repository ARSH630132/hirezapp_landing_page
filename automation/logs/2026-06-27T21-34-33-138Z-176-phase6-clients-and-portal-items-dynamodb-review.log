: SupportTicketUpdate,\n118 |     db = Depends(get_db),\n119 |     current_user: User = Depends(get_current_user)\n120 | ):\n121 |     \"\"\"Update a support ticket.\"\"\"\n122 |     db_ticket = find_ticket(id)\n123 |     is_admin_or_support = current_user.role in [\"admin\", \"gff_admin\", \"support_agent\"]\n124 |     if not is_admin_or_support:\n125 |         if db_ticket.client_id != current_user.client_id:\n126 |             raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You do not have permission to modify this ticket.\")\n127 |         if ticket_in.client_id is not None or ticket_in.assigned_to is not None:\n128 |             raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You cannot change client association or assignment.\")\n129 |             \n130 |     update_data = ticket_in.model_dump(exclude_unset=True)\n131 |     return portal_items_repo.update_item(\"SUPPORT\", str(db_ticket.client_id), str(db_ticket.id), update_data)\n132 | \n133 | @router.patch(\"/{id}/status\", response_model=SupportTicketResponse)\n134 | def update_support_ticket_status(\n135 |     id: int,\n136 |     status_in: StatusUpdate,\n137 |     db = Depends(get_db),\n138 |     current_user: User = Depends(get_current_user)\n139 | ):\n140 |     \"\"\"Update status.\"\"\"\n141 |     db_ticket = find_ticket(id)\n142 |     is_admin_or_support = current_user.role in [\"admin\", \"gff_admin\", \"support_agent\"]\n143 |     if not is_admin_or_support and db_ticket.client_id != current_user.client_id:\n144 |         raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You do not have permission to modify this ticket.\")\n145 |     return portal_items_repo.update_item(\"SUPPORT\", str(db_ticket.client_id), str(db_ticket.id), {\"status\": status_in.status})\n146 | \n147 | @router.patch(\"/{id}/assign\", response_model=SupportTicketResponse)\n148 | def assign_support_ticket(\n149 |     id: int,\n150 |     assign_in: AssignUpdate,\n151 |     db = Depends(get_db),\n152 |     current_user: User = Depends(get_current_user)\n153 | ):\n154 |     \"\"\"Assign ticket.\"\"\"\n155 |     db_ticket = find_ticket(id)\n156 |     is_admin_or_support = current_user.role in [\"admin\", \"gff_admin\", \"support_agent\"]\n157 |     if not is_admin_or_support:\n158 |         raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"Only administrators and support agents can assign tickets.\")\n159 |     return portal_items_repo.update_item(\"SUPPORT\", str(db_ticket.client_id), str(db_ticket.id), {\"assigned_to\": assign_in.assigned_to})\n160 | \n161 | @router.post(\"/{id}/comments\", response_model=SupportTicketResponse)\n162 | @router.post(\"/{id}/comment\", response_model=SupportTicketResponse)\n163 | def add_support_ticket_comment(\n164 |     id: int,\n165 |     comment_in: CommentCreate,\n166 |     db = Depends(get_db),\n167 |     current_user: User = Depends(get_current_user)\n168 | ):\n169 |     \"\"\"Add a comment.\"\"\"\n170 |     db_ticket = find_ticket(id)\n171 |     is_admin_or_support = current_user.role in [\"admin\", \"gff_admin\", \"support_agent\"]\n172 |     if not is_admin_or_support and db_ticket.client_id != current_user.client_id:\n173 |         raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"You do not have permission to comment on this ticket.\")\n174 |             \n175 |     try: comments_list = json.loads(db_ticket.comments or \"[]\")\n176 |     except Exception: comments_list = []\n177 |         \n178 |     comments_list.append({\n179 |         \"sender\": current_user.name or current_user.email,\n180 |         \"text\": comment_in.text,\n181 |         \"timestamp\": datetime.datetime.utcnow().isoformat()\n182 |     })\n183 |     return portal_items_repo.update_item(\"SUPPORT\", str(db_ticket.client_id), str(db_ticket.id), {\"comments\": json.dumps(comments_list)})\n184 | \n185 | @router.delete(\"/{id}\", response_model=SupportTicketResponse)\n186 | def delete_support_ticket(\n187 |     id: int,\n188 |     db = Depends(get_db),\n189 |     current_user: User = Depends(get_current_user)\n190 | ):\n191 |     \"\"\"Delete ticket.\"\"\"\n192 |     db_ticket = find_ticket(id)\n193 |     is_admin = current_user.role in [\"admin\", \"gff_admin\"]\n194 |     if not is_admin:\n195 |         raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"Only administrators can delete support tickets.\")\n196 |     portal_items_repo.delete_item(\"SUPPORT\", str(db_ticket.client_id), str(db_ticket.id))\n197 |     return db_ticket\n198 | ","success":true}],"durationMs":2}}
