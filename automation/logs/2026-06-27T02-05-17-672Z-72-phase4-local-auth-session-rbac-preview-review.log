|| \"US\"}\n                      </div>\n                      <div className=\"truncate\">\n                        <div className=\"text-[11px] font-bold text-white uppercase truncate\">{currentMockUser.name}</div>\n                        <div className=\"text-[8px] text-white/40 mt-0.5 truncate\">{currentMockUser.email}</div>\n                      </div>\n                    </div>\n\n                    <div className=\"h-[1px] bg-white/5 w-full\" />\n\n                    <div className=\"space-y-1.5 text-[9px]\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-white/40\">CLEARANCE:</span>\n                        <span className=\"text-[#009DFF] font-bold\">{selectedRoleDetails.clearance}</span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-white/40\">SYSTEM ROLE:</span>\n                        <span className=\"text-white font-bold\">{selectedRoleDetails.label.toUpperCase()}</span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-white/40\">STATUS:</span>\n                        <span className=\"text-emerald-400 font-bold flex items-center gap-1\">\n                          <span className=\"h-1 w-1 rounded-full bg-emerald-400 animate-ping\" />\n                          VERIFIED\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Context note */}\n                  <div className=\"p-3 bg-blue-950/10 border border-blue-500/10 rounded-xl space-y-1\">\n                    <div className=\"text-[#009DFF] text-[8px] font-bold flex items-center gap-1\">\n                      <AlertCircle className=\"w-3 h-3 shrink-0\" />\n                      SIMULATOR SCOPE\n                    </div>\n                    <p className=\"text-[8px] text-white/50 leading-relaxed font-sans\">\n                      Clearance routing is fully managed in the local sandbox loop using cryptographic session representations. No server-side auth exists. OAuth connects in backend phase.\n                    </p>\n                  </div>\n                </div>\n\n                {/* Authenticate Trigger */}\n                <button \n                  onClick={handleAuthenticate} \n                  className=\"w-full h-11 rounded-xl bg-white text-black font-bold text-[10px] uppercase tracking-widest flex items-center justify-center gap-2 cursor-pointer hover:bg-white/90 active:scale-[0.98] transition-all hover:shadow-[0_0_20px_rgba(255,255,255,0.1)]\"\n                >\n                  <Key className=\"w-3.5 h-3.5\" /> Authenticate Enclave\n                </button>\n              </div>\n            </>\n          ) : (\n            /* Scanning State: Full Screen Console Experience */\n            <div className=\"col-span-12 py-10 flex flex-col items-center justify-center space-y-6\">\n              <div className=\"relative h-20 w-20 bg-black/40 border border-[#009DFF]/20 rounded-full flex items-center justify-center overflow-hidden shadow-[0_0_30px_rgba(0,157,255,0.05)]\">\n                <div className=\"absolute left-0 right-0 h-[1.5px] bg-[#009DFF]/80 animate-pulse\" style={{ top: \"45%\" }} />\n                <RefreshCw className=\"w-6 h-6 text-[#009DFF] animate-spin\" />\n              </div>\n\n              <div className=\"w-full max-w-md space-y-3\">\n                <div className=\"flex justify-between items-center text-[9px] text-white/40 px-1\">\n                  <span>CRYPTOGRAPHIC LINK SETUP</span>\n                  <span>{Math.round((scanStep + 1) / scanMessages.length * 100)}%</span>\n                </div>\n                <div className=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\">\n                  <motion.div \n                    initial={{ width: 0 }} \n                    animate={{ width: `${(scanStep + 1) / scanMessages.length * 100}%` }} \n                    transition={{ duration: 0.2 }}\n                    className=\"h-full bg-gradient-to-r from-[#009DFF] to-blue-500 shadow-[0_0_10px_rgba(0,157,255,0.5)]\" \n                  />\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-black/60 min-h-[140px] text-[9.5px] leading-relaxed space-y-2\">\n                  {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                    <motion.div \n                      key={idx} \n                      initial={{ opacity: 0, x: -5 }} \n                      animate={{ opacity: 1, x: 0 }} \n                      className=\"flex items-center gap-2 text-white/80\"\n                    >\n                      {idx < scanStep ? (\n                        <CheckCircle className=\"w-3.5 h-3.5 text-emerald-400 shrink-0\" />\n                      ) : (\n                        <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin shrink-0\" />\n                      )}\n                      <span className={idx < scanStep ? \"text-white/35 font-normal\" : \"text-white font-bold\"}>\n                        {msg}\n                      </span>\n                    </motion.div>\n                  ))}\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        {/* Footer info */}\n        <p className=\"text-center text-[8px] text-white/20 select-none\">\n          GFF AI SOVEREIGN PROTOCOL v2.4 • ESTABLISHED 2026.06.27 • CRYPTOGRAPHIC LAYER ACTIVE\n        </p>\n      </div>\n    </div>\n  );\n}"}}}
