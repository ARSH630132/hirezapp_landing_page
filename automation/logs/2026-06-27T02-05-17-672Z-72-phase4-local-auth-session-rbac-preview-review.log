{"ts":"2026-06-27T02:03:02.680Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"k8vksrrk","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/portal/SecureLogin.tsx","old_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { Lock, Shield, Key, CheckCircle, RefreshCw, Layers, Eye, Users, Cpu, FileText, HelpCircle } from \"lucide-react\";\nimport { setPreviewSession, PreviewRole, MOCK_PREVIEW_USERS } from \"@/lib/preview-auth\";\n\nexport default function SecureLogin({ defaultRole }: { defaultRole?: string }) {\n  const router = useRouter();\n  const [selectedRole, setSelectedRole] = useState<PreviewRole>(\n    defaultRole === \"Administrator\" ? \"gff_admin\" : \"client_admin\"\n  );\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n\n  const rolesList: { id: PreviewRole; label: string; clearance: string }[] = [\n    { id: \"client_admin\", label: \"Client Admin\", clearance: \"Level III\" },\n    { id: \"client_member\", label: \"Client Member\", clearance: \"Level II\" },\n    { id: \"gff_admin\", label: \"GFF Admin\", clearance: \"Level V\" },\n    { id: \"gff_operator\", label: \"GFF Operator\", clearance: \"Level IV\" },\n    { id: \"finance_admin\", label: \"Finance Admin\", clearance: \"Level III\" },\n    { id: \"support_agent\", label: \"Support Agent\", clearance: \"Level III\" },\n    { id: \"viewer\", label: \"Auditor (Viewer)\", clearance: \"Level I\" },\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => setScanStep(p => p < 3 ? p + 1 : p), 200);\n    await new Promise(r => setTimeout(r, 900));\n    clearInterval(interval);\n    setScanning(false);\n    setPreviewSession(selectedRole);\n    router.push(selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative px-4 py-8 select-none font-mono\">\n      <div className=\"w-full max-w-xl z-10 space-y-6\">\n        <div className=\"text-center space-y-2\">\n          <div className=\"inline-flex h-9 w-9 items-center justify-center rounded-xl border border-white/5 bg-[#0a0a0a] text-[#009DFF]\"><Shield className=\"w-4 h-4\" /></div>\n          <div><span className=\"text-[8px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded-full\">ZERO-TRUST IDENTITY DECK</span></div>\n          <h1 className=\"text-xs font-bold uppercase\">Sovereign <span className=\"text-[#009DFF]\">Access Gateway</span></h1>\n          <p className=\"text-[9px] text-white/40\">Select simulated role to inspect respective workspace dashboards.</p>\n        </div>\n\n        <div className=\"p-5 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-md space-y-4\">\n          {!scanning ? (\n            <div className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-1.5\">\n                {rolesList.map((r) => {\n                  const isSel = selectedRole === r.id;\n                  return (\n                    <button\n                      key={r.id}\n                      onClick={() => setSelectedRole(r.id)}\n                      className={`p-2 rounded-lg border text-left cursor-pointer flex justify-between items-center transition-all text-[11px] ${\n                        isSel ? \"border-[#009DFF]/40 bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.02] text-white/50\"\n                      }`}\n                    >\n                      <span className=\"font-bold truncate\">{r.label}</span>\n                      <span className=\"text-[7px] border border-white/10 rounded-sm px-1 shrink-0\">{r.clearance}</span>\n                    </button>\n                  );\n                })}\n              </div>\n\n              <div className=\"p-3 rounded-lg border border-white/5 bg-black/40 text-[9px] space-y-1\">\n                <div className=\"text-[#009DFF] font-bold text-[8px]\">SIMULATED DETAILS</div>\n                <div className=\"flex justify-between\">\n                  <span>NAME: <strong className=\"text-white\">{currentMockUser.name}</strong></span>\n                  <span>LEVEL: <strong className=\"text-white\">{currentMockUser.clearance}</strong></span>\n                </div>\n              </div>\n\n              <button onClick={handleAuthenticate} className=\"w-full h-10 rounded-lg bg-white text-black font-bold text-[10px] uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer hover:bg-white/90\">\n                <Key className=\"w-3.5 h-3.5\" /> Authenticate Simulated Session\n              </button>\n\n              <div className=\"p-2.5 bg-blue-950/10 border border-blue-500/10 text-blue-400 rounded-lg text-[8.5px] leading-relaxed\">\n                <strong>FRONTEND PREVIEW MODE:</strong> Local simulator only. States are saved in localStorage. Production OAuth/AD connects in backend implementation.\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-3 py-2 text-center text-[10px]\">\n              <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto\" />\n              <p className=\"text-white/40\">Isolating local browser enclaves and key hooks...</p>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { Lock, Shield, Key, CheckCircle, RefreshCw, Layers, Eye, Users, Cpu, FileText, HelpCircle } from \"lucide-react\";\nimport { setPreviewSession, PreviewRole, MOCK_PREVIEW_USERS } from \"@/lib/preview-auth\";\n\nexport default function SecureLogin({ defaultRole }: { defaultRole?: string }) {\n  const router = useRouter();\n  const [selectedRole, setSelectedRole] = useState<PreviewRole>(\n    defaultRole === \"Administrator\" ? \"gff_admin\" : \"client_admin\"\n  );\n  const [scanning, setScanning] = useState(false);\n  const [scanStep, setScanStep] = useState(0);\n\n  const rolesList = [\n    { id: \"client_admin\" as PreviewRole, label: \"Client Admin\", clearance: \"Level III\", desc: \"Sandbox gateway owner\", icon: Users, color: \"text-cyan-400\" },\n    { id: \"client_member\" as PreviewRole, label: \"Client Member\", clearance: \"Level II\", desc: \"Sandbox layer worker\", icon: Layers, color: \"text-blue-400\" },\n    { id: \"gff_admin\" as PreviewRole, label: \"GFF Admin\", clearance: \"Level V\", desc: \"Root platform controller\", icon: Shield, color: \"text-red-400\" },\n    { id: \"gff_operator\" as PreviewRole, label: \"GFF Operator\", clearance: \"Level IV\", desc: \"Model architecture manager\", icon: Cpu, color: \"text-purple-400\" },\n    { id: \"finance_admin\" as PreviewRole, label: \"Finance Admin\", clearance: \"Level III\", desc: \"Epoch financial controller\", icon: FileText, color: \"text-emerald-400\" },\n    { id: \"support_agent\" as PreviewRole, label: \"Support Agent\", clearance: \"Level III\", desc: \"SLA wire representative\", icon: HelpCircle, color: \"text-orange-400\" },\n    { id: \"viewer\" as PreviewRole, label: \"Auditor (Viewer)\", clearance: \"Level I\", desc: \"Read-only observers\", icon: Eye, color: \"text-slate-400\" },\n  ];\n\n  const scanMessages = [\n    \"Establishing zero-trust gateway handshake...\",\n    \"Isolating local browser enclaves...\",\n    \"Exchanging SHA-256 keys (GFF_0x7FFA)...\",\n    \"Provisioning clearance keycards...\"\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => setScanStep(p => p < 3 ? p + 1 : p), 220);\n    await new Promise(r => setTimeout(r, 1000));\n    clearInterval(interval);\n    setScanning(false);\n    setPreviewSession(selectedRole);\n    router.push(selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n  const activeRoleObj = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative px-4 py-8 select-none font-mono overflow-hidden\">\n      <div className=\"absolute top-1/4 left-1/4 w-80 h-80 rounded-full bg-[#009DFF]/5 blur-[120px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-[#E4000F]/3 blur-[120px] pointer-events-none\" />\n      <div className=\"absolute inset-0 bg-[radial-gradient(rgba(255,255,255,0.012)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n\n      <div className=\"w-full max-w-2xl z-10 space-y-6\">\n        <div className=\"text-center space-y-2 font-sans\">\n          <div className=\"inline-flex h-9 w-9 items-center justify-center rounded-xl border border-white/5 bg-[#0a0a0a] text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.1)]\">\n            <Shield className=\"w-4 h-4\" />\n          </div>\n          <div><span className=\"text-[8px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded-full uppercase tracking-wider\">ZERO-TRUST IDENTITY DECK</span></div>\n          <h1 className=\"text-xs font-mono font-bold uppercase tracking-wider\">Sovereign <span className=\"text-[#009DFF]\">Access Gateway</span></h1>\n          <p className=\"text-[9.5px] text-white/40 max-w-sm mx-auto\">Select a simulated identity to audit respective workspace dashboards.</p>\n        </div>\n\n        <div className=\"p-5 rounded-[20px] border border-white/5 bg-[#050505]/60 backdrop-blur-md\">\n          {!scanning ? (\n            <div className=\"grid grid-cols-1 md:grid-cols-12 gap-5\">\n              {/* Roles selection list */}\n              <div className=\"md:col-span-7 space-y-1.5 max-h-[300px] overflow-y-auto pr-1\">\n                {rolesList.map((r) => {\n                  const isSel = selectedRole === r.id;\n                  const RoleIcon = r.icon;\n                  return (\n                    <button\n                      key={r.id}\n                      onClick={() => setSelectedRole(r.id)}\n                      className={`w-full p-2 rounded-xl border text-left cursor-pointer flex justify-between items-center transition-all text-[11px] group ${\n                        isSel ? \"border-[#009DFF]/40 bg-[#009DFF]/5 text-white\" : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.02] text-white/50\"\n                      }`}\n                    >\n                      <div className=\"flex items-center gap-2.5 truncate\">\n                        <RoleIcon className={`w-3.5 h-3.5 ${r.color} shrink-0`} />\n                        <div className=\"truncate\">\n                          <span className=\"font-bold block\">{r.label}</span>\n                          <span className=\"text-[8px] text-white/30 font-sans block truncate\">{r.desc}</span>\n                        </div>\n                      </div>\n                      <span className={`text-[7px] border rounded-sm px-1 shrink-0 ${isSel ? \"border-[#009DFF]/30 text-[#009DFF]\" : \"border-white/10 text-white/30\"}`}>{r.clearance}</span>\n                    </button>\n                  );\n                })}\n              </div>\n\n              {/* Identity view & auth trigger */}\n              <div className=\"md:col-span-5 flex flex-col justify-between space-y-4\">\n                <div className=\"space-y-3\">\n                  <div className=\"p-3.5 rounded-xl border border-white/5 bg-black/40 space-y-2.5\">\n                    <div className=\"text-[7.5px] font-bold text-white/30 uppercase tracking-widest\">Simulated Enclave Identity</div>\n                    <div className=\"space-y-1\">\n                      <div className=\"text-[10px] font-bold uppercase truncate text-white\">{currentMockUser.name}</div>\n                      <div className=\"text-[8px] text-white/40 truncate\">{currentMockUser.email}</div>\n                    </div>\n                    <div className=\"h-[1px] bg-white/5\" />\n                    <div className=\"text-[8.5px] text-white/50 leading-relaxed font-sans\">\n                      Clearance: <strong className=\"text-[#009DFF] font-mono\">{activeRoleObj.clearance}</strong><br />\n                      Authorized: <strong className=\"text-white font-mono\">{activeRoleObj.label}</strong>\n                    </div>\n                  </div>\n\n                  <div className=\"p-2.5 bg-blue-950/10 border border-blue-500/10 text-blue-400 rounded-lg text-[8px] leading-relaxed font-sans\">\n                    <strong>PREVIEW GATEWAY:</strong> States are sandbox-isolated. Real OAuth AD links in backend integration.\n                  </div>\n                </div>\n\n                <button onClick={handleAuthenticate} className=\"w-full h-10 rounded-lg bg-white hover:bg-white/90 text-black font-bold text-[10px] uppercase tracking-wider flex items-center justify-center gap-1.5 cursor-pointer active:scale-[0.98] transition-all\">\n                  <Key className=\"w-3.5 h-3.5\" /> Authenticate Enclave\n                </button>\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-4 py-4 max-w-sm mx-auto text-center\">\n              <RefreshCw className=\"w-6 h-6 text-[#009DFF] animate-spin mx-auto\" />\n              <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\">\n                <div className=\"h-full bg-[#009DFF] transition-all duration-200\" style={{ width: `${(scanStep + 1) * 25}%` }} />\n              </div>\n              <div className=\"p-3 rounded-lg border border-white/5 bg-black/40 min-h-[96px] text-[9px] text-left space-y-1.5 font-mono\">\n                {scanMessages.slice(0, scanStep + 1).map((msg, idx) => (\n                  <div key={idx} className=\"flex items-center gap-1.5 text-white/80\">\n                    {idx < scanStep ? <CheckCircle className=\"w-3.5 h-3.5 text-emerald-400 shrink-0\" /> : <RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin shrink-0\" />}\n                    <span className={idx < scanStep ? \"text-white/30\" : \"text-white font-bold\"}>{msg}</span>\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
