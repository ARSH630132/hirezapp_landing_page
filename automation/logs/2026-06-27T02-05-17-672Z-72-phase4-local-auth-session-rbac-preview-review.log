, \n      color: \"text-red-400\",\n      glow: \"border-red-500/20 bg-red-950/5 text-red-400\"\n    },\n    { \n      id: \"gff_operator\" as PreviewRole, \n      label: \"GFF Operator\", \n      clearance: \"Level IV\", \n      desc: \"Simulate technical system operator with active engine and agent lifecycle monitoring clearance.\",\n      icon: Cpu, \n      color: \"text-purple-400\",\n      glow: \"border-purple-500/20 bg-purple-950/5 text-purple-400\"\n    },\n    { \n      id: \"finance_admin\" as PreviewRole, \n      label: \"Finance Admin\", \n      clearance: \"Level III\", \n      desc: \"Simulate GFF corporate controller auditing epoch financial ledgers & invoices.\",\n      icon: FileText, \n      color: \"text-emerald-400\",\n      glow: \"border-emerald-500/20 bg-emerald-950/5 text-emerald-400\"\n    },\n    { \n      id: \"support_agent\" as PreviewRole, \n      label: \"Support Agent\", \n      clearance: \"Level III\", \n      desc: \"Simulate SLA escalation representative handling secure user tickets and customer wires.\",\n      icon: HelpCircle, \n      color: \"text-orange-400\",\n      glow: \"border-orange-500/20 bg-orange-950/5 text-orange-400\"\n    },\n    { \n      id: \"viewer\" as PreviewRole, \n      label: \"Auditor (Viewer)\", \n      clearance: \"Level I\", \n      desc: \"Simulate read-only observer to inspect live telemetry and compliance guardrail reports.\",\n      icon: Eye, \n      color: \"text-slate-400\",\n      glow: \"border-slate-500/20 bg-slate-950/5 text-slate-400\"\n    },\n  ];\n\n  const scanMessages = [\n    \"Establishing zero-trust gateway TLS handshake...\",\n    \"Isolating local browser enclaves...\",\n    \"Exchanging SHA-256 cryptographic keys (GFF_0x7FFA)...\",\n    \"Provisioning ephemeral compliance clearance keys...\",\n    \"Mounting multi-tenant sandbox environment dashboards...\"\n  ];\n\n  const handleAuthenticate = async () => {\n    setScanning(true);\n    setScanStep(0);\n    const interval = setInterval(() => {\n      setScanStep(p => p < scanMessages.length - 1 ? p + 1 : p);\n    }, 280);\n    await new Promise(r => setTimeout(r, 1600));\n    clearInterval(interval);\n    setScanning(false);\n    setPreviewSession(selectedRole);\n    router.push(selectedRole.startsWith(\"client_\") ? \"/portal/dashboard\" : \"/admin/dashboard\");\n  };\n\n  const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n  const selectedRoleDetails = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n  const SelectedIcon = selectedRoleDetails.icon;\n\n  return (\n    <div className=\"min-h-screen w-full bg-[#030303] text-white flex flex-col items-center justify-center relative px-4 py-12 select-none font-mono overflow-hidden\">\n      {/* Premium subtle visual styling */}\n      <div className=\"absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-[#009DFF]/3 blur-[120px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-1/4 w-96 h-96 rounded-full bg-[#E4000F]/2 blur-[120px] pointer-events-none\" />\n      <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.012)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.012)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none\" />\n\n      <div className=\"w-full max-w-4xl z-10 space-y-8 flex flex-col items-center\">\n        {/* Header Section */}\n        <div className=\"text-center space-y-2.5 max-w-lg font-sans\">\n          <div className=\"inline-flex h-9 w-9 items-center justify-center rounded-xl border border-white/5 bg-[#0a0a0a] text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.1)]\">\n            <Shield className=\"w-4 h-4\" />\n          </div>\n          <div>\n            <span className=\"text-[8px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2.5 py-0.5 rounded-full uppercase tracking-wider\">\n              ZERO-TRUST IDENTITY DECK\n            </span>\n          </div>\n          <h1 className=\"text-sm font-bold uppercase tracking-widest text-white font-mono\">\n            Sovereign <span className=\"text-[#009DFF]\">Access Gateway</span>\n          </h1>\n          <p className=\"text-[10px] text-white/40 leading-relaxed\">\n            Select a simulated cryptographic role profile below to instantly authenticate and evaluate the GFF AI sandboxed dashboards.\n          </p>\n        </div>\n\n        {/* Console Panel */}\n        <div className=\"w-full grid grid-cols-1 md:grid-cols-12 gap-6 bg-[#050505]/60 border border-white/5 rounded-[24px] p-6 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.8)]\">\n          {!scanning ? (\n            <>\n              {/* Left Column: Roles Selection Grid */}\n              <div className=\"md:col-span-7 space-y-3.5\">\n                <div className=\"text-[9px] text-white/30 uppercase font-bold tracking-widest border-b border-white/5 pb-2 flex justify-between\">\n                  <span>Simulated Roles</span>\n                  <span>Clearance Level</span>\n                </div>\n                <div className=\"space-y-1.5 max-h-[380px] overflow-y-auto pr-1\">\n                  {rolesList.map((r) => {\n                    const isSel = selectedRole === r.id;\n                    const RoleIcon = r.icon;\n                    return (\n                      <button\n                        key={r.id}\n                        onClick={() => setSelectedRole(r.id)}\n                        className={`w-full p-3 rounded-xl border text-left cursor-pointer flex items-center justify-between transition-all group ${\n                          isSel \n                            ? \"border-[#009DFF]/40 bg-[#009DFF]/5 text-white shadow-[0_0_15px_rgba(0,157,255,0.03)]\" \n                            : \"border-white/5 bg-white/[0.01] hover:bg-white/[0.02] text-white/50 hover:text-white/80\"\n                        }`}\n                      >\n                        <div className=\"flex items-center gap-3 truncate\">\n             