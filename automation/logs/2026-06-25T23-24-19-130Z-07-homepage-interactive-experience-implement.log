{"ts":"2026-06-25T23:21:30.188Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"bkrdmlpj","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/InteractiveExperienceSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport SectionHeading from \"@/components/SectionHeading\";\nimport Link from \"next/link\";\n\nexport default function InteractiveExperienceSection() {\n  const [activeTab, setActiveTab] = useState(0);\n  const tools = [\n    { name: \"Talk to Agent\", link: \"/build/talk\", color: \"#009DFF\" },\n    { name: \"Blueprint Generator\", link: \"/build/blueprint\", color: \"#E98828\" },\n    { name: \"AI Readiness\", link: \"/build/assessment\", color: \"#9D00FF\" },\n    { name: \"ROI Calculator\", link: \"/build/roi\", color: \"#E4000F\" },\n    { name: \"Marketplace\", link: \"/platforms/marketplace\", color: \"#0186E4\" },\n    { name: \"Foundry Studio\", link: \"/platforms/foundry\", color: \"#00FF9D\" },\n  ];\n\n  // Tool 1: Talk to Agent\n  const [messages, setMessages] = useState([{ sender: \"agent\", text: \"Supervisor online. Ask about cloud spend, compliance, or shipping.\" }]);\n  const [chatIn, setChatIn] = useState(\"\");\n  const handleChat = (txt: string) => {\n    if (!txt.trim()) return;\n    const ans = txt.toLowerCase().includes(\"cloud\") ? \"Cloud Auditor: Optimized resources saving $45k annually.\" : txt.toLowerCase().includes(\"compliance\") ? \"Compliance Agent: S3 security drift auto-patched.\" : \"Supervisor: Context mounted in local sandbox. Live cluster connection recommended.\";\n    setMessages((p) => [...p, { sender: \"user\", text: txt }, { sender: \"agent\", text: ans }]);\n    setChatIn(\"\");\n  };\n\n  // Tool 2: Blueprint\n  const [bpGen, setBpGen] = useState(false);\n\n  // Tool 3: Readiness\n  const [rd, setRd] = useState(3);\n\n  // Tool 4: ROI\n  const [roiSize, setRoiSize] = useState(250);\n  const annualSavings = Math.round(roiSize * 8 * 52 * 65 * 0.85);\n\n  // Tool 5: Marketplace\n  const [installed, setInstalled] = useState<Record<string, boolean>>({});\n\n  // Tool 6: Foundry\n  const [flowLog, setFlowLog] = useState(\"Status: Idle\");\n\n  return (\n    <section className=\"w-full bg-[#020202] px-6 lg:px-16 py-16 relative overflow-hidden\">\n      <div className=\"absolute top-10 left-10 w-72 h-72 bg-[#009DFF]/5 rounded-full blur-[100px] pointer-events-none\" />\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        <SectionHeading\n          title={<h2 className=\"text-[26px] sm:text-[32px] leading-none font-semibold text-center uppercase text-white\">INTERACTIVE <span className=\"text-[#009DFF]\">EXPERIENCE</span></h2>}\n          titleClassName=\"text-center\"\n          dividerWidthClassName=\"w-[260px]\"\n        />\n        <p className=\"mt-4 text-center text-xs sm:text-sm text-white/40 max-w-2xl mx-auto uppercase tracking-[0.2em] mb-12\">\n          Hands-on simulation tools. Preview GFF multi-agent capabilities in secure sandboxes.\n        </p>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          {/* Tabs */}\n          <div className=\"lg:col-span-4 flex lg:flex-col gap-3 overflow-x-auto pb-4 lg:pb-0 scrollbar-none\">\n            {tools.map((t, idx) => (\n              <button\n                key={t.name}\n                type=\"button\"\n                onClick={() => setActiveTab(idx)}\n                className={`flex-shrink-0 w-[220px] lg:w-full text-left rounded-xl border p-4 transition-all ${\n                  activeTab === idx ? \"bg-[#050B18] border-white/15\" : \"bg-[#010101]/60 border-white/5 hover:bg-white/[0.02]\"\n                }`}\n              >\n                <span className=\"text-[10px] font-mono text-white/30 uppercase\">0{idx + 1} / tool</span>\n                <h3 className=\"text-[15px] font-semibold text-white/90 mt-1\">{t.name}</h3>\n              </button>\n            ))}\n          </div>\n\n          {/* Sandbox Area */}\n          <div className=\"lg:col-span-8\">\n            <div className=\"w-full min-h-[420px] rounded-2xl border border-white/10 bg-[#04060b] p-6 sm:p-8 flex flex-col justify-between shadow-2xl\">\n              <div>\n                <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-white/5 pb-4\">\n                  <div>\n                    <span className=\"px-2 py-0.5 text-[9px] font-mono rounded bg-white/5 border border-white/10 text-white/60 uppercase\">{tools[activeTab].name} Simulator</span>\n                    <h2 className=\"mt-2 text-lg sm:text-xl font-semibold text-white\">\n                      {activeTab === 0 && \"Autonomous Multi-Agent Chat Studio\"}\n                      {activeTab === 1 && \"Enterprise Infrastructure Blueprint Generator\"}\n                      {activeTab === 2 && \"Infrastructure AI Readiness Evaluator\"}\n                      {activeTab === 3 && \"Productivity & Operational ROI Calculator\"}\n                      {activeTab === 4 && \"Enterprise Secure Plug-In Registry\"}\n                      {activeTab === 5 && \"Foundry Workflow Visual Studio\"}\n                    </h2>\n                  </div>\n                  <Link href={tools[activeTab].link} className=\"shrink-0 text-xs font-semibold px-4 py-2 rounded-lg text-white border border-white/10 bg-white/5 hover:bg-white/10 transition-all text-center\">Launch Full Tool &rarr;</Link>\n                </div>\n\n                {/* Main Content Area */}\n                <div className=\"mt-6\">\n                  {activeTab === 0 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"h-[180px] rounded-lg border border-white/5 bg-black/50 p-4 overflow-y-auto font-mono text-[11px] leading-relaxed space-y-2\">\n                        {messages.map((m, i) => (\n                          <div key={i} className={`flex ${m.sender === \"user\" ? \"justify-end\" : \"justify-start\"}`}>\n                            <span className={`rounded-md px-3 py-1 ${m.sender === \"user\" ? \"bg-[#009DFF]/20 text-white\" : \"bg-white/[0.04] text-white/80\"}`}>{m.sender === \"user\" ? \"> \" : \"\"}{m.text}</span>\n                          </div>\n                        ))}\n                      </div>\n                      <div className=\"flex flex-wrap gap-2 text-[10px]\">\n                        <button type=\"button\" onClick={() => handleChat(\"Optimize cloud spend\")} className=\"px-2.5 py-1 bg-white/5 rounded border border-white/5 text-white/70 hover:bg-white/10\">⚡ Cloud Spend</button>\n                        <button type=\"button\" onClick={() => handleChat(\"Check SOC2 compliance\")} className=\"px-2.5 py-1 bg-white/5 rounded border border-white/5 text-white/70 hover:bg-white/10\">🛡️ Compliance</button>\n                      </div>\n                      <form onSubmit={(e) => { e.preventDefault(); handleChat(chatIn); }} className=\"flex gap-2\">\n                        <input type=\"text\" value={chatIn} onChange={(e) => setChatIn(e.target.value)} placeholder=\"Type cloud spend, compliance, etc...\" className=\"flex-grow h-[36px] rounded border border-white/10 bg-[#010101]/60 px-3 text-xs text-white focus:outline-none\" />\n                        <button type=\"submit\" className=\"px-4 rounded bg-[#009DFF] text-xs font-semibold text-white\">Send</button>\n                      </form>\n                    </div>\n                  )}\n\n                  {activeTab === 1 && (\n                    <div className=\"space-y-4\">\n                      <p className=\"text-xs text-white/60\">Simulate structural DAG mapping. Choose a target VPC architecture.</p>\n                      <button type=\"button\" onClick={() => setBpGen(true)} className=\"h-[36px] px-4 rounded bg-[#E98828] text-xs font-semibold text-white\">Generate Preview</button>\n                      {bpGen && (\n                        <div className=\"rounded-lg border border-white/5 bg-[#070c18] p-4 text-xs space-y-2\">\n                          <p className=\"font-semibold text-[#E98828]\">Blueprint Generated Successfully</p>\n                          <p className=\"text-white/60\">Topology mapping completed on client-side cache. Click below or use the full form at the bottom of the page.</p>\n                          <button onClick={() => { document.getElementById(\"blueprint\")?.scrollIntoView({ behavior: \"smooth\" }) }} className=\"text-[#E98828] underline font-bold\">Scroll down to full Blueprint Generator &darr;</button>\n                        </div>\n                      )}\n                    </div>\n                  )}\n\n                  {activeTab === 2 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"flex items-center justify-between text-xs mb-2\">\n                        <span className=\"text-white/60\">Data Infrastructure Integration Layer</span>\n                        <span className=\"text-[#9D00FF] font-bold\">LVL {rd} / 5</span>\n                      </div>\n                      <input type=\"range\" min=\"1\" max=\"5\" value={rd} onChange={(e) => setRd(Number(e.target.value))} className=\"w-full accent-[#9D00FF]\" />\n                      <div className=\"p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center mt-4\">\n                        <p className=\"text-[10px] text-white/40 uppercase tracking-wider\">Estimated GFF Readiness</p>\n                        <p className=\"text-2xl font-bold text-[#9D00FF] mt-1\">{rd * 20}%</p>\n                        <p className=\"text-[11px] text-white/60 mt-1\">{rd >= 4 ? \"Ready for enterprise deployment.\" : \"Sandbox testing recommended.\"}</p>\n                      </div>\n                    </div>\n                  )}\n\n                  {activeTab === 3 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"flex justify-between text-xs mb-1\">\n                        <span className=\"text-white/60\">Automated Workgroup Size</span>\n                        <span className=\"text-[#E4000F] font-bold\">{roiSize} employees</span>\n                      </div>\n                      <input type=\"range\" min=\"10\" max=\"1000\" step=\"10\" value={roiSize} onChange={(e) => setRoiSize(Number(e.target.value))} className=\"w-full accent-[#E4000F]\" />\n                      <div className=\"p-4 rounded-xl bg-[#050101] border border-white/5 flex flex-col items-center\">\n                        <span className=\"text-[10px] text-white/40 uppercase tracking-wider\">Est. Annual Labor Saved</span>\n                        <span className=\"text-xl sm:text-2xl font-bold text-[#00FF9D] mt-2\">${annualSavings.toLocaleString()}</span>\n                        <span className=\"text-[10px] text-white/30 mt-1\">Based on saving 8 hrs/week at a $65/hr blended rate.</span>\n                      </div>\n                    </div>\n                  )}\n\n                  {activeTab === 4 && (\n                    <div className=\"space-y-4\">\n                      <p className=\"text-xs text-white/60\">Activate pre-built GFF agent nodes within your secure secure tenant container.</p>\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex flex-col justify-between\">\n                          <h4 className=\"text-xs font-bold text-white\">Compliance Auditor Node</h4>\n                          <p className=\"text-[10px] text-white/50 mt-1\">Runs real-time scans on active cloud database policies.</p>\n                          <button type=\"button\" onClick={() => setInstalled(p => ({ ...p, c: true }))} className={`mt-3 w-full h-[28px] rounded text-xs font-semibold ${installed.c ? \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"