{"ts":"2026-06-25T23:21:09.469Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"jmgw2iee","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/InteractiveExperienceSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport { useState, useEffect, useRef } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\nimport Link from \"next/link\";\n\ninterface Message {\n  sender: \"user\" | \"agent\";\n  text: string;\n}\n\nexport default function InteractiveExperienceSection() {\n  const [activeTab, setActiveTab] = useState<number>(0);\n\n  const tools = [\n    { id: \"talk\", name: \"Talk to Agent\", link: \"/build/talk\", color: \"#009DFF\" },\n    { id: \"blueprint\", name: \"Blueprint Generator\", link: \"/build/blueprint\", color: \"#E98828\" },\n    { id: \"assessment\", name: \"AI Readiness\", link: \"/build/assessment\", color: \"#9D00FF\" },\n    { id: \"roi\", name: \"ROI Calculator\", link: \"/build/roi\", color: \"#E4000F\" },\n    { id: \"marketplace\", name: \"Marketplace\", link: \"/platforms/marketplace\", color: \"#0186E4\" },\n    { id: \"foundry\", name: \"Foundry Studio\", link: \"/platforms/foundry\", color: \"#00FF9D\" },\n  ];\n\n  // Tool 1: Talk to Agent\n  const [chatMessages, setChatMessages] = useState<Message[]>([\n    { sender: \"agent\", text: \"Supervisor online. Select a scenario below or enter custom prompt.\" },\n  ]);\n  const [chatLoading, setChatLoading] = useState(false);\n  const [chatInput, setChatInput] = useState(\"\");\n  const chatBottomRef = useRef<HTMLDivElement>(null);\n\n  const handleSendChat = (text: string) => {\n    if (!text.trim() || chatLoading) return;\n    setChatMessages((p) => [...p, { sender: \"user\", text }]);\n    setChatInput(\"\");\n    setChatLoading(true);\n    setTimeout(() => {\n      let reply = \"Specialized agent cohort initialized. Operating context mounted.\";\n      if (text.toLowerCase().includes(\"cloud\")) {\n        reply = \"[Cloud Auditor] Isolated $45k annual idle cost savings in non-production cluster.\";\n      } else if (text.toLowerCase().includes(\"compliance\")) {\n        reply = \"[Security Shield] Audit complete. S3 policy drift patched. SOC2 telemetry logs generated.\";\n      } else if (text.toLowerCase().includes(\"supply\")) {\n        reply = \"[Logistics Agent] Ports congestion detected. Re-routed 12 land corridors via SAP.\";\n      }\n      setChatMessages((p) => [...p, { sender: \"agent\", text: reply }]);\n      setChatLoading(false);\n    }, 900);\n  };\n\n  useEffect(() => {\n    chatBottomRef.current?.scrollIntoView({ behavior: \"smooth\" });\n  }, [chatMessages, chatLoading]);\n\n  // Tool 2: Blueprint Generator\n  const [bpSec, setBpSec] = useState(\"vpc\");\n  const [bpGen, setBpGen] = useState(false);\n\n  // Tool 3: AI Readiness\n  const [rdData, setRdData] = useState(3);\n  const [rdComp, setRdComp] = useState(2);\n  const rdScore = Math.round(((rdData + rdComp) / 10) * 100);\n\n  // Tool 4: ROI Calculator\n  const [roiSize, setRoiSize] = useState(250);\n  const [roiHours, setRoiHours] = useState(8);\n  const annualSavings = Math.round(roiSize * roiHours * 52 * 65 * 0.85);\n\n  // Tool 5: Marketplace\n  const [installed, setInstalled] = useState<Record<string, boolean>>({});\n\n  // Tool 6: Foundry Studio\n  const [selectedNode, setSelectedNode] = useState(\"core\");\n  const [flowRunning, setFlowRunning] = useState(false);\n  const [flowLog, setFlowLog] = useState(\"Ready\");\n\n  const runFlowTest = () => {\n    setFlowRunning(true);\n    setFlowLog(\"Compiling DAG...\");\n    setTimeout(() => {\n      setFlowLog(\"Processing node data...\");\n      setTimeout(() => {\n        setFlowLog(\"Completed. Latency: 480ms. Cost: $0.003\");\n        setFlowRunning(false);\n      }, 700);\n    }, 700);\n  };\n\n  return (\n    <section className=\"w-full bg-[#020202] px-6 lg:px-16 lg:py-24 py-16 overflow-hidden relative\">\n      <div className=\"absolute top-10 left-10 w-[300px] h-[300px] bg-[#009DFF]/5 rounded-full blur-[100px] pointer-events-none\" />\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        <SectionHeading\n          title={\n            <h2 className=\"text-[28px] sm:text-[36px] leading-none font-semibold text-center uppercase text-white tracking-wide\">\n              INTERACTIVE <span className=\"text-[#009DFF]\">EXPERIENCE</span>\n            </h2>\n          }\n          titleClassName=\"text-center\"\n          dividerWidthClassName=\"w-[280px]\"\n        />\n        <p className=\"mt-4 text-center text-xs sm:text-sm text-white/45 max-w-2xl mx-auto font-medium uppercase tracking-[0.2em] mb-12\">\n          Hands-on simulation tools. Preview GFF multi-agent pipelines in secure, client-side sandboxes.\n        </p>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          {/* Left: Tab Selectors */}\n          <div className=\"lg:col-span-4 flex lg:flex-col gap-3 overflow-x-auto pb-4 lg:pb-0 scrollbar-none snap-x\">\n            {tools.map((t, idx) => (\n              <button\n                key={t.id}\n                type=\"button\"\n                onClick={() => setActiveTab(idx)}\n                className={`flex-shrink-0 w-[240px] lg:w-full snap-start text-left rounded-[16px] border p-4 transition-all relative overflow-hidden group ${\n                  activeTab === idx\n                    ? \"bg-[#050B18] border-white/15\"\n                    : \"bg-[#010101]/60 border-white/5 hover:border-white/10 hover:bg-[#030303]\"\n                }`}\n              >\n                {activeTab === idx && (\n                  <motion.div\n                    layoutId=\"activeTabIndicator\"\n                    className=\"absolute left-0 top-0 bottom-0 w-[4px]\"\n                    style={{ backgroundColor: t.color }}\n                  />\n                )}\n                <span className=\"text-[9px] font-bold uppercase tracking-wider text-white/30\">0{idx + 1}</span>\n                <h3 className={`mt-1 text-[16px] font-semibold ${activeTab === idx ? \"text-white\" : \"text-white/60 group-hover:text-white/80\"}`}>\n                  {t.name}\n                </h3>\n              </button>\n            ))}\n          </div>\n\n          {/* Right: Active Sandbox Preview */}\n          <div className=\"lg:col-span-8\">\n            <AnimatePresence mode=\"wait\">\n              <motion.div\n                key={activeTab}\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -10 }}\n                transition={{ duration: 0.2 }}\n                className=\"w-full min-h-[460px] rounded-[24px] border border-white/10 bg-[#04060b] p-6 lg:p-8 flex flex-col justify-between shadow-2xl relative\"\n              >\n                <div>\n                  <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-white/5 pb-4\">\n                    <div>\n                      <span className=\"px-2 py-0.5 text-[9px] font-mono rounded bg-white/5 border border-white/10 text-white/60 uppercase\">\n                        {tools[activeTab].name} Simulator\n                      </span>\n                      <h2 className=\"mt-2 text-[20px] sm:text-[22px] font-bold text-white tracking-tight\">\n                        {activeTab === 0 && \"Autonomous Multi-Agent Chat Studio\"}\n                        {activeTab === 1 && \"Enterprise Blueprint Generator\"}\n                        {activeTab === 2 && \"Enterprise AI Readiness Evaluator\"}\n                        {activeTab === 3 && \"Productivity & Operational ROI Calculator\"}\n                        {activeTab === 4 && \"Enterprise Plug-In Registry\"}\n                        {activeTab === 5 && \"Foundry Workflow Studio\"}\n                      </h2>\n                    </div>\n                    <Link\n                      href={tools[activeTab].link}\n                      className=\"shrink-0 text-xs font-semibold px-4 py-2 rounded-[10px] text-white border border-white/10 bg-white/[0.05] hover:bg-white/[0.1] transition-all\"\n                    >\n                      Launch Tool →\n                    </Link>\n                  </div>\n\n                  <div className=\"mt-6\">\n                    {/* Tool 0: Talk to Agent */}\n                    {activeTab === 0 && (\n                      <div className=\"space-y-4\">\n                        <div className=\"h-[220px] rounded-[12px] border border-white/5 bg-black/60 p-4 overflow-y-auto font-mono text-[12px] leading-relaxed space-y-2.5\">\n                          {chatMessages.map((msg, i) => (\n                            <div key={i} className={`flex ${msg.sender === \"user\" ? \"justify-end\" : \"justify-start\"}`}>\n                              <div className={`max-w-[85%] rounded-[10px] px-3 py-1.5 ${msg.sender === \"user\" ? \"bg-[#009DFF]/15 text-white border border-[#009DFF]/30\" : \"bg-white/[0.03] text-white/90\"}`}>\n                                {msg.sender === \"user\" ? \"> \" : \"[Supervisor] \"}{msg.text}\n                              </div>\n                            </div>\n                          ))}\n                          {chatLoading && <div className=\"text-white/40 italic\">Supervisor thinking...</div>}\n                          <div ref={chatBottomRef} />\n                        </div>\n                        <div className=\"flex flex-wrap gap-2 text-xs\">\n                          <button type=\"button\" onClick={() => handleSendChat(\"Optimize Cloud Spend\")} className=\"px-3 py-1 bg-white/[0.02] border border-white/5 rounded-full hover:bg-white/5 text-white/70\">⚡ Cloud Spend</button>\n                          <button type=\"button\" onClick={() => handleSendChat(\"Audit Compliance\")} className=\"px-3 py-1 bg-white/[0.02] border border-white/5 rounded-full hover:bg-white/5 text-white/70\">🛡️ Compliance</button>\n                          <button type=\"button\" onClick={() => handleSendChat(\"Verify Supply Chain\")} className=\"px-3 py-1 bg-white/[0.02] border border-white/5 rounded-full hover:bg-white/5 text-white/70\">📦 Supply Chain</button>\n                        </div>\n                        <form onSubmit={(e) => { e.preventDefault(); handleSendChat(chatInput); }} className=\"flex gap-2\">\n                          <input type=\"text\" value={chatInput} onChange={(e) => setChatInput(e.target.value)} placeholder=\"Query the supervisor (e.g. Optimize cloud spend)...\" className=\"flex-grow h-[38px] rounded-[8px] border border-white/10 bg-[#010101]/60 px-3 text-xs text-white focus:outline-none\" />\n                          <button type=\"submit\" className=\"px-4 rounded-[8px] bg-[#009DFF] text-xs font-semibold text-white\">Send</button>\n                        </form>\n                      </div>\n                    )}\n\n                    {/* Tool 1: Blueprint Generator */}\n                    {activeTab === 1 && (\n                      <div className=\"space-y-4\">\n                        <p className=\"text-xs text-white/60\">Choose standard operational configurations to preview blueprint DAG mapping.</p>\n                        <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                          <div className=\"space-y-1.5\">\n                            <label className=\"text-[10px] font-bold text-white/40 uppercase\">Target VPC security</label>\n                            <select value={bpSec} onChange={(e) => { setBpSec(e.target.value); setBpGen(false); }} className=\"w-full h-[36px] rounded-[8px] border border-white/10 bg-white/[0.02] px-3 text-xs text-white\">\n                              <option value=\"vpc\">Private VPC Single-Tenant</option>\n                              <option value=\"sovereign\">Sovereign Air-Gapped Cluster</option>\n                            </select>\n                          </div>\n                          <div className=\"flex items-end\">\n                            <button type=\"button\" onClick={() => setBpGen(true)} className=\"w-full h-[36px] rounded-[8px] bg-[#E98828] text-xs font-semibold text-white\">Generate Blueprint Schema</button>\n                          </div>\n                        </div>\n                        {bpGen && (\n                          <div className=\"rounded-[12px] border border-white/5 bg-[#070c18] p-4 text-xs space-y-2\">\n                            <p className=\"font-semibold text-[#E98828]\">Blueprint Mapped successfully.</p>\n                            <p className=\"text-white/70\">Orchestrator Topology: Isolated secure tenant container operating on {bpSec === \"vpc\" ? \"Private VPC endpoints\" : \"Sovereign nodes\"}.</p>\n                            <button onClick={scrollSmoothToBlueprintSection} className=\"text-[#E98828] underline text-[11px]\">Scroll down to complete full Blueprint form below &darr;</button>\n                          </div>\n                        )}\n                      </div>\n                    )}\n\n                    {/* Tool 2: AI Readiness */}\n                    {activeTab === 2 && (\n                      <div className=\"space-y-5\">\n                        <div className=\"grid grid-cols-1 md:grid-cols-12 gap-4 items-center\">\n                          <div className=\"md:col-span-8 space-y-4\">\n                            <div className=\"space-y-1\">\n                              <div className=\"flex justify-between text-xs\">\n                                <span className=\"text-white/60\">Data Pipelines Integration</span>\n                                <span className=\"text-[#9D00FF] font-bold\">LVL {rdData}</span>\n                              </div>\n                              <input type=\"range\" min=\"1\" max=\"5\" value={rdData} onChange={(e) => setRdData(Number(e.target.value))} className=\"w-full accent-[#9D00FF]\" />\n                            </div>\n                            <div className=\"space-y-1\">\n                              <div className=\"flex justify-between text-xs\">\n                                <span className=\"text-white/60\">Compliance & Guardrails</span>\n                                <span className=\"text-[#9D00FF] font-bold\">LVL {rdComp}</span>\n                              </div>\n                              <input type=\"range\" min=\"1\" max=\"5\" value={rdComp} onChange={(e) => setRdComp(Number(e.target.value))} className=\"w-full accent-[#9D00FF]\" />\n                            </div>\n                          </div>\n                          <div className=\"md:col-span-4 p-4 rounded-[16px] bg-white/[0.02] border border-white/5 flex flex-col items-center\">\n                            <span className=\"text-[10px] text-white/40 uppercase\">Readiness</span>\n                            <span className=\"text-2xl font-bold text-[#9D00FF] mt-1\">{rdScore}%</span>\n                            <span className=\"text-[10px] text-white/60 text-center mt-2 font-semibold\">\n                              {rdScore >= 70 ? \"Enterprise Ready\" : \"Sandbox Recommended\"}\n                            </span>\n                          </div>\n                        </div>\n                      </div>\n                    )}\n\n                    {/* Tool 3: ROI Calculator */}\n                    {activeTab === 3 && (\n                      <div className=\"space-y-5\">\n                        <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-6\">\n                          <div className=\"space-y-4\">\n                            <div className=\"space-y-1\">\n                              <div className=\"flex justify-between text-xs\">\n                                <span className=\"text-white/60\">Team Size</span>\n                                <span className=\"text-[#E4000F] font-bold\">{roiSize} head</span>\n                              </div>\n                              <input type=\"range\" min=\"10\" max=\"1000\" step=\"10\" value={roiSize} onChange={(e) => setRoiSize(Number(e.target.value))} className=\"w-full accent-[#E4000F]\" />\n                            </div>\n                            <div className=\"space-y-1\">\n                              <div className=\"flex justify-between text-xs\">\n                                <span className=\"text-white/60\">Hours saved / employee / week</span>\n                                <span className=\"text-[#E4000F] font-bold\">{roiHours} hrs</span>\n                              </div>\n                              <input type=\"range\" min=\"2\" max=\"20\" step=\"1\" value={roiHours} onChange={(e) => setRoiHours(Number(e.target.value))} className=\"w-full accent-[#E4000F]\" />\n                            </div>\n                          </div>\n                          <div className=\"p-4 rounded-[16px] bg-[#050101] border border-white/5 flex flex-col justify-center items-center\">\n                            <span className=\"text-[10px] text-white/40 uppercase\">Est. Annual Productivity Saved</span>\n                            <span className=\"text-2xl font-bold text-[#00FF9D] mt-2\">${annualSavings.toLocaleString()}</span>\n                            <span className=\"text-[10px] text-white/40 mt-1\">Blended rate applied: $65/hr</span>\n                          </div>\n                        </div>\n                      </div>\n                    )}\n\n                    {/* Tool 4: Marketplace */}\n                    {activeTab === 4 && (\n                      <div className=\"space-y-4\">\n                        <p className=\"text-xs text-white/60\">Click to deploy mock multi-agent pipelines to your local secure sandbox cluster.</p>\n                        <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                          <div className=\"p-4 rounded-[12px] border border-white/5 bg-white/[0.02] flex flex-col justify-between\">\n                            <div>\n                              <h4 className=\"text-xs font-bold text-white\">Compliance Guardrail Plug-In</h4>\n                              <p className=\"mt-1 text-[11px] text-white/50 leading-relaxed\">Continuous audit scanning for AWS security policy drift.</p>\n                            </div>\n                            <button type=\"button\" onClick={() => setInstalled((p) => ({ ...p, c: true }))} className={`mt-3 w-full h-[28px] rounded text-[11px] font-semibold ${installed.c ? \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"bg-[#0186E4] text-white\"}`}>\n                              {installed.c ? \"✓ Sandbox Active\" : \"Deploy Sandbox\"}\n                            </button>\n                          </div>\n                          <div className=\"p-4 rounded-[12px] border border-white/5 bg-white/[0.02] flex flex-col justify-between\">\n                            <div>\n                              <h4 className=\"text-xs font-bold text-white\">ERP Freight Sync Agent</h4>\n                              <p className=\"mt-1 text-[11px] text-white/50 leading-relaxed\">Automatically re-routes supply chain exceptions in SAP systems.</p>\n                            </div>\n                            <button type=\"button\" onClick={() => setInstalled((p) => ({ ...p, e: true }))} className={`mt-3 w-full h-[28px] rounded text-[11px] font-semibold ${installed.e ? \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"bg-[#0186E4] text-white\"}`}>\n                              {installed.e ? \"✓ Sandbox Active\" : \"Deploy Sandbox\"}\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    )}\n\n                    {/* Tool 5: Foundry Studio */}\n                    {activeTab === 5 && (\n                      <div className=\"space-y-4\">\n                        <div className=\"grid grid-cols-1 sm:grid-cols-12 gap-4\">\n                          <div className=\"sm:col-span-8 h-[160px] rounded-[12px] border border-white/5 bg-black/60 relative flex items-center justify-around\">\n                            <svg className=\"absolute inset-0 w-full h-full pointer-events-none\">\n                              <path d=\"M 40 80 Q 120 40 180 80 Q 240 120 300 80\" fill=\"none\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth=\"1.5\" strokeDasharray=\"3 3\" />\n                            </svg>\n                            <button onClick={() => setSelectedNode(\"db\")} className={`z-10 w-12 h-12 rounded-lg border text-[10px] uppercase font-bold flex flex-col items-center justify-center ${selectedNode === \"db\" ? \"border-[#00FF9D] text-white bg-white/5\" : \"border-white/10 text-white/50\"}`}>\n                              <span>📥</span><span>DB</span>\n                            </button>\n                            <button onClick={() => setSelectedNode(\"core\")} className={`z-10 w-12 h-12 rounded-lg border text-[10px] uppercase font-bold flex flex-col items-center justify-center ${selectedNode === \"core\" ? \"border-[#00FF9D] text-white bg-white/5\" : \"border-white/10 text-white/50\"}`}>\n                              <span>🧠</span><span>Core</span>\n                            </button>\n                            <button onClick={() => setSelectedNode(\"alert\")} className={`z-10 w-12 h-12 rounded-lg border text-[10px] uppercase font-bold flex flex-col items-center justify-center ${selectedNode === \"alert\" ? \"border-[#00FF9D] text-white bg-white/5\" : \"border-white/10 text-white/50\"}`}>\n                              <span>📤</span><span>Sync</span>\n                            </button>\n                          </div>\n                          <div className=\"sm:col-span-4 p-4 rounded-[12px] bg-white/[0.02] border border-white/5 flex flex-col justify-between\">\n                            <div>\n                              <h4 className=\"text-[10px] uppercase font-bold text-[#00FF9D]\">DAG Flow Test</h4>\n                              <p className=\"mt-2 text-[11px] text-white/50\">Status: {flowLog}</p>\n                            </div>\n                            <button type=\"button\" onClick={runFlowTest} disabled={flowRunning} className=\"w-full h-[32px] rounded bg-white/5 border border-white/10 text-xs font-semibold text-white\">\n                              {flowRunning ? \"Executing...\" : \"Run Pipeline Test\"}\n                            </button>\n                          </div>\n                        </div>\n                      </div>\n                    )}\n                  </div>\n                </div>\n\n                <div className=\"mt-8 pt-4 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[11px] text-white/40\">\n                  <span>* Previews operate using client-side sandbox states. Secure enterprise cluster credentials are required for live runtime deployments.</span>\n                  <Link href={tools[activeTab].link} className=\"shrink-0 text-[#009DFF] font-bold hover:underline\">\n                    Access Dedicated Full-Screen Tool &rarr;\n                  </Link>\n                </div>\n              </motion.div>\n            </AnimatePresence>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"}}}
