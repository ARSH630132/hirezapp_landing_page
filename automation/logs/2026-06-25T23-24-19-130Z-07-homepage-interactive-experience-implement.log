{"ts":"2026-06-25T23:22:09.175Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"y7igiuos","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/InteractiveExperienceSection.tsx","old_text":"import SectionHeading from \"@/components/SectionHeading\";\n\nexport default function InteractiveExperienceSection() {\n  const items = ['Talk to Agent', 'Blueprint Generator', 'AI Readiness', 'ROI Calculator', 'Marketplace', 'Foundry Studio'];\n  return (\n    <section className=\"w-full bg-[#030303] px-6 lg:px-16 lg:py-20 py-12\">\n      <SectionHeading\n        title={\n          <h2 className=\"text-[24px] sm:text-[30px] leading-none font-medium text-center uppercase text-white\">\n            INTERACTIVE <span className=\"text-[#009DFF]\">EXPERIENCE</span>\n          </h2>\n        }\n        titleClassName=\"text-center\"\n        dividerWidthClassName=\"w-[260px]\"\n      />\n      <div className=\"mt-12 grid grid-cols-2 md:grid-cols-3 gap-6 max-w-[1795px] mx-auto\">\n        {items.map(c => (\n          <div key={c} className=\"group relative rounded-[20px] p-[1px] bg-white/5 hover:bg-gradient-to-r hover:from-[#E4000F] hover:to-[#009DFF] transition-all cursor-pointer\">\n            <div className=\"h-full rounded-[19px] bg-[#000102] p-8 flex flex-col justify-center min-h-[180px] text-center\">\n              <h3 className=\"text-xl font-bold text-white/90 group-hover:text-white transition-colors\">{c}</h3>\n            </div>\n          </div>\n        ))}\n      </div>\n    </section>\n  )\n}","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport SectionHeading from \"@/components/SectionHeading\";\nimport Link from \"next/link\";\n\nexport default function InteractiveExperienceSection() {\n  const [tab, setTab] = useState(0);\n  const [chat, setChat] = useState([{ s: \"agent\", t: \"Supervisor active. Ask about cloud spend, compliance, or shipping.\" }]);\n  const [inVal, setInVal] = useState(\"\");\n  const [bpGen, setBpGen] = useState(false);\n  const [rd, setRd] = useState(3);\n  const [roiSize, setRoiSize] = useState(250);\n  const [installed, setInstalled] = useState<Record<string, boolean>>({});\n  const [flowLog, setFlowLog] = useState(\"Status: Idle\");\n\n  const tools = [\n    { name: \"Talk to Agent\", link: \"/build/talk\" },\n    { name: \"Blueprint Generator\", link: \"/build/blueprint\" },\n    { name: \"AI Readiness\", link: \"/build/assessment\" },\n    { name: \"ROI Calculator\", link: \"/build/roi\" },\n    { name: \"Marketplace\", link: \"/platforms/marketplace\" },\n    { name: \"Foundry Studio\", link: \"/platforms/foundry\" },\n  ];\n\n  const handleSend = (text: string) => {\n    if (!text.trim()) return;\n    const ans = text.toLowerCase().includes(\"cloud\") ? \"Cloud Auditor: Identified $45k/yr idle instances.\" : text.toLowerCase().includes(\"comp\") ? \"Compliance Shield: SOC2 policy drift fixed.\" : \"Supervisor: Context mounted in local sandbox.\";\n    setChat((p) => [...p, { s: \"user\", t: text }, { s: \"agent\", t: ans }]);\n    setInVal(\"\");\n  };\n\n  return (\n    <section className=\"w-full bg-[#020202] px-6 lg:px-16 py-16 relative overflow-hidden\">\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        <SectionHeading\n          title={<h2 className=\"text-[26px] sm:text-[32px] leading-none font-semibold text-center uppercase text-white\">INTERACTIVE <span className=\"text-[#009DFF]\">EXPERIENCE</span></h2>}\n          titleClassName=\"text-center\"\n          dividerWidthClassName=\"w-[260px]\"\n        />\n        <p className=\"mt-4 text-center text-xs sm:text-sm text-white/40 max-w-2xl mx-auto uppercase tracking-[0.2em] mb-12\">\n          Hands-on simulation tools. Preview GFF capabilities in secure client-side sandboxes.\n        </p>\n\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8\">\n          {/* Tabs */}\n          <div className=\"lg:col-span-4 flex lg:flex-col gap-3 overflow-x-auto pb-4 lg:pb-0 scrollbar-none\">\n            {tools.map((t, idx) => (\n              <button\n                key={t.name}\n                type=\"button\"\n                onClick={() => setTab(idx)}\n                className={`flex-shrink-0 w-[200px] lg:w-full text-left rounded-xl border p-4 transition-all ${\n                  tab === idx ? \"bg-[#050B18] border-white/15\" : \"bg-[#010101]/60 border-white/5 hover:bg-white/[0.02]\"\n                }`}\n              >\n                <span className=\"text-[10px] font-mono text-white/30 uppercase\">0{idx + 1} / tool</span>\n                <h3 className=\"text-[15px] font-semibold text-white/90 mt-1\">{t.name}</h3>\n              </button>\n            ))}\n          </div>\n\n          {/* Panel */}\n          <div className=\"lg:col-span-8\">\n            <div className=\"w-full min-h-[380px] rounded-2xl border border-white/10 bg-[#04060b] p-6 sm:p-8 flex flex-col justify-between shadow-2xl\">\n              <div>\n                <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-white/5 pb-4\">\n                  <div>\n                    <span className=\"px-2 py-0.5 text-[9px] font-mono rounded bg-white/5 border border-white/10 text-white/60 uppercase\">{tools[tab].name} Simulator</span>\n                    <h2 className=\"mt-2 text-lg font-semibold text-white\">\n                      {tab === 0 && \"Autonomous Multi-Agent Chat Studio\"}\n                      {tab === 1 && \"Enterprise Infrastructure Blueprint Generator\"}\n                      {tab === 2 && \"Infrastructure AI Readiness Evaluator\"}\n                      {tab === 3 && \"Productivity & Operational ROI Calculator\"}\n                      {tab === 4 && \"Enterprise Secure Plug-In Registry\"}\n                      {tab === 5 && \"Foundry Workflow Visual Studio\"}\n                    </h2>\n                  </div>\n                  <Link href={tools[tab].link} className=\"shrink-0 text-xs font-semibold px-4 py-2 rounded-lg text-white border border-white/10 bg-white/5 hover:bg-white/10 transition-all text-center\">Launch Tool &rarr;</Link>\n                </div>\n\n                <div className=\"mt-6\">\n                  {tab === 0 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"h-[150px] rounded-lg border border-white/5 bg-black/50 p-4 overflow-y-auto font-mono text-[11px] leading-relaxed space-y-2\">\n                        {chat.map((m, i) => (\n                          <div key={i} className={`flex ${m.s === \"user\" ? \"justify-end\" : \"justify-start\"}`}>\n                            <span className={`rounded-md px-3 py-1 ${m.s === \"user\" ? \"bg-[#009DFF]/20 text-white\" : \"bg-white/[0.04] text-white/80\"}`}>{m.s === \"user\" ? \"> \" : \"\"}{m.t}</span>\n                          </div>\n                        ))}\n                      </div>\n                      <div className=\"flex flex-wrap gap-2 text-[10px]\">\n                        <button type=\"button\" onClick={() => handleSend(\"Optimize cloud spend\")} className=\"px-2.5 py-1 bg-white/5 rounded border border-white/5 text-white/70 hover:bg-white/10\">⚡ Cloud Spend</button>\n                        <button type=\"button\" onClick={() => handleSend(\"Check compliance\")} className=\"px-2.5 py-1 bg-white/5 rounded border border-white/5 text-white/70 hover:bg-white/10\">🛡️ Compliance</button>\n                      </div>\n                    </div>\n                  )}\n\n                  {tab === 1 && (\n                    <div className=\"space-y-4\">\n                      <p className=\"text-xs text-white/60\">Simulate structural DAG mapping. Choose a target VPC architecture.</p>\n                      <button type=\"button\" onClick={() => setBpGen(true)} className=\"h-[36px] px-4 rounded bg-[#E98828] text-xs font-semibold text-white\">Generate Preview</button>\n                      {bpGen && (\n                        <div className=\"rounded-lg border border-white/5 bg-[#070c18] p-4 text-xs space-y-1\">\n                          <p className=\"font-semibold text-[#E98828]\">Blueprint Generated Successfully</p>\n                          <button onClick={() => { document.getElementById(\"blueprint\")?.scrollIntoView({ behavior: \"smooth\" }) }} className=\"text-[#E98828] underline font-bold\">Scroll to Blueprint Generator below &darr;</button>\n                        </div>\n                      )}\n                    </div>\n                  )}\n\n                  {tab === 2 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"flex items-center justify-between text-xs mb-2\">\n                        <span className=\"text-white/60\">Data Infrastructure Integration Layer</span>\n                        <span className=\"text-[#9D00FF] font-bold\">LVL {rd} / 5</span>\n                      </div>\n                      <input type=\"range\" min=\"1\" max=\"5\" value={rd} onChange={(e) => setRd(Number(e.target.value))} className=\"w-full accent-[#9D00FF]\" />\n                      <div className=\"p-4 rounded-xl bg-white/[0.02] border border-white/5 text-center mt-4\">\n                        <p className=\"text-2xl font-bold text-[#9D00FF]\">{rd * 20}% Readiness</p>\n                      </div>\n                    </div>\n                  )}\n\n                  {tab === 3 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"flex justify-between text-xs mb-1\">\n                        <span className=\"text-white/60\">Automated Workgroup Size</span>\n                        <span className=\"text-[#E4000F] font-bold\">{roiSize} employees</span>\n                      </div>\n                      <input type=\"range\" min=\"10\" max=\"1000\" step=\"10\" value={roiSize} onChange={(e) => setRoiSize(Number(e.target.value))} className=\"w-full accent-[#E4000F]\" />\n                      <div className=\"p-4 rounded-xl bg-[#050101] border border-white/5 flex flex-col items-center\">\n                        <span className=\"text-xl font-bold text-[#00FF9D]\">${Math.round(roiSize * 8 * 52 * 65 * 0.85).toLocaleString()} / yr savings</span>\n                      </div>\n                    </div>\n                  )}\n\n                  {tab === 4 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex flex-col justify-between\">\n                          <h4 className=\"text-xs font-bold text-white\">Compliance Auditor Node</h4>\n                          <button type=\"button\" onClick={() => setInstalled(p => ({ ...p, c: true }))} className={`mt-3 w-full h-[28px] rounded text-xs font-semibold ${installed.c ? \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"bg-[#0186E4] text-white\"}`}>{installed.c ? \"✓ Live in Sandbox\" : \"Activate\"}</button>\n                        </div>\n                        <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex flex-col justify-between\">\n                          <h4 className=\"text-xs font-bold text-white\">Supply Chain Sync Agent</h4>\n                          <button type=\"button\" onClick={() => setInstalled(p => ({ ...p, s: true }))} className={`mt-3 w-full h-[28px] rounded text-xs font-semibold ${installed.s ? \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"bg-[#0186E4] text-white\"}`}>{installed.s ? \"✓ Live in Sandbox\" : \"Activate\"}</button>\n                        </div>\n                      </div>\n                    </div>\n                  )}\n\n                  {tab === 5 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"h-[100px] rounded-xl border border-white/5 bg-black/60 relative flex items-center justify-around overflow-hidden\">\n                        <div className=\"w-8 h-8 rounded border border-white/10 bg-white/[0.03] flex items-center justify-center text-xs\">📥</div>\n                        <div className=\"w-8 h-8 rounded border border-[#00FF9D] bg-[#00FF9D]/5 flex items-center justify-center text-xs\">🧠</div>\n                        <div className=\"w-8 h-8 rounded border border-white/10 bg-white/[0.03] flex items-center justify-center text-xs\">📤</div>\n                      </div>\n                      <div className=\"flex justify-between items-center bg-white/[0.02] p-3 rounded-lg border border-white/5\">\n                        <span className=\"text-xs text-white/50 font-mono\">{flowLog}</span>\n                        <button type=\"button\" onClick={() => { setFlowLog(\"Processing...\"); setTimeout(() => setFlowLog(\"Done (SLA: 420ms)\"), 800); }} className=\"px-3 py-1.5 bg-white/5 border border-white/10 rounded text-xs text-white hover:bg-white/10\">Run Test</button>\n                      </div>\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              <div className=\"mt-8 pt-4 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[11px] text-white/40\">\n                <span>* Simulated sandbox environments. Standalone routes contain high-fidelity execution panels.</span>\n                <Link href={tools[tab].link} className=\"shrink-0 text-[#009DFF] font-bold hover:underline\">Launch Full Sandbox &rarr;</Link>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"}}}
