 \"bg-[#00FF9D]/10 text-[#00FF9D]\" : \"bg-[#0186E4] text-white\"}`}>{installed.s ? \"✓ Live in Sandbox\" : \"Activate\"}</button>\n                        </div>\n                      </div>\n                    </div>\n                  )}\n\n                  {activeTab === 5 && (\n                    <div className=\"space-y-4\">\n                      <div className=\"h-[120px] rounded-xl border border-white/5 bg-black/60 relative flex items-center justify-around overflow-hidden\">\n                        <svg className=\"absolute inset-0 w-full h-full pointer-events-none\">\n                          <line x1=\"10%\" y1=\"50%\" x2=\"50%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" />\n                          <line x1=\"50%\" y1=\"50%\" x2=\"90%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" />\n                        </svg>\n                        <div className=\"w-10 h-10 rounded border border-white/10 bg-white/[0.03] flex items-center justify-center text-xs\">📥</div>\n                        <div className=\"w-10 h-10 rounded border border-[#00FF9D] bg-[#00FF9D]/5 flex items-center justify-center text-xs\">🧠</div>\n                        <div className=\"w-10 h-10 rounded border border-white/10 bg-white/[0.03] flex items-center justify-center text-xs\">📤</div>\n                      </div>\n                      <div className=\"flex justify-between items-center bg-white/[0.02] p-3 rounded-lg border border-white/5\">\n                        <span className=\"text-xs text-white/50 font-mono\">{flowLog}</span>\n                        <button type=\"button\" onClick={() => { setFlowLog(\"Processing...\"); setTimeout(() => setFlowLog(\"Done (SLA: 420ms)\"), 800); }} className=\"px-3 py-1.5 bg-white/5 border border-white/10 rounded text-xs text-white hover:bg-white/10\">Run Flow Test</button>\n                      </div>\n                    </div>\n                  )}\n                </div>\n              </div>\n\n              {/* Sandbox Footer */}\n              <div className=\"mt-8 pt-4 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-[11px] text-white/40\">\n                <span>* Simulated environments. Standalone sandbox routes contain high-fidelity execution panels.</span>\n                <Link href={tools[activeTab].link} className=\"shrink-0 text-[#009DFF] font-bold hover:underline\">Launch standalone sandbox &rarr;</Link>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}"}}}
