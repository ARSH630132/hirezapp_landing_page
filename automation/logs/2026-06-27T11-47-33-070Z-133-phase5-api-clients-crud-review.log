,\n 50 |         user_id=user_id,\n 51 |         role=role,\n 52 |         client_id=client_id,\n 53 |         email=email,\n 54 |         expires_delta=timedelta(minutes=15)\n 55 |     )\n 56 |     \n 57 |     # Check token structure\n 58 |     assert isinstance(token, str)\n 59 |     parts = token.split(\".\")\n 60 |     assert len(parts) == 3\n 61 |     \n 62 |     # Decode token\n 63 |     decoded_email = decode_access_token(token)\n 64 |     assert decoded_email == email\n 65 |     \n 66 |     # Retrieve full payload\n 67 |     payload = decode_access_token_payload(token)\n 68 |     assert payload is not None\n 69 |     assert payload[\"sub\"] == email\n 70 |     assert payload[\"user_id\"] == user_id\n 71 |     assert payload[\"role\"] == role\n 72 |     assert payload[\"client_id\"] == client_id\n 73 |     assert payload[\"email\"] == email\n 74 |     assert \"exp\" in payload\n 75 |     assert \"iat\" in payload\n 76 |     \n 77 |     # Test token expiry retrieval\n 78 |     expiry = get_token_expiry(token)\n 79 |     assert expiry is not None\n 80 |     assert isinstance(expiry, datetime)\n 81 |     \n 82 |     # Test nullable client_id\n 83 |     token_no_client = create_access_token(\n 84 |         subject=email,\n 85 |         user_id=user_id,\n 86 |         role=role,\n 87 |         client_id=None,\n 88 |         email=email\n 89 |     )\n 90 |     payload_no_client = decode_access_token_payload(token_no_client)\n 91 |     assert payload_no_client[\"client_id\"] is None\n 92 |     \n 93 |     # Test expired token\n 94 |     expired_token = create_access_token(\n 95 |         subject=email,\n 96 |         user_id=user_id,\n 97 |         role=role,\n 98 |         client_id=client_id,\n 99 |         email=email,\n100 |         expires_delta=timedelta(seconds=-10) # expired 10 seconds ago\n101 |     )\n102 |     assert decode_access_token(expired_token) is None\n103 |     assert decode_access_token_payload(expired_token) is None\n104 |     \n105 |     print(\"✓ test_jwt_utilities passed.\")\n106 | \n107 | from app.core.rbac import UserRole, PermissionGroup, ROLE_PERMISSIONS, RoleChecker\n108 | from app.api.deps import (\n109 |     require_roles,\n110 |     require_admin,\n111 |     require_client_access,\n112 |     require_same_client_or_admin,\n113 |     require_permission\n114 | )\n115 | from fastapi import HTTPException\n116 | \n117 | # Mock User class for testing dependencies\n118 | class MockUser:\n119 |     def __init__(self, role: str, client_id: int = None, is_active: bool = True):\n120 |         self.role = role\n121 |         self.client_id = client_id\n122 |         self.is_active = is_active\n123 | \n124 | # Mock Request class for testing client parameter extraction\n125 | class MockRequest:\n126 |     def __init__(self, path_params=None, query_params=None):\n127 |         self.path_params = path_params or {}\n128 |         self.query_params = query_params or {}\n129 | \n130 | def test_rbac_roles_and_permissions():\n131 |     print(\"Running test_rbac_roles_and_permissions...\")\n132 |     # Verify new roles exist\n133 |     assert UserRole.CLIENT_ADMIN == \"client_admin\"\n134 |     assert UserRole.CLIENT_MEMBER == \"client_member\"\n135 |     assert UserRole.GFF_ADMIN == \"gff_admin\"\n136 |     \n137 |     # Verify permission groups exist\n138 |     assert PermissionGroup.CLIENT_PORTAL_ACCESS == \"client_portal_access\"\n139 |     assert PermissionGroup.ADMIN_ACCESS == \"admin_access\"\n140 |     assert PermissionGroup.MANAGE_CLIENTS == \"manage_clients\"\n141 |     assert PermissionGroup.MANAGE_USERS == \"manage_users\"\n142 |     \n143 |     # Verify mapping assignments\n144 |     assert PermissionGroup.ADMIN_ACCESS in ROLE_PERMISSIONS[UserRole.GFF_ADMIN]\n145 |     assert PermissionGroup.ADMIN_ACCESS not in ROLE_PERMISSIONS[UserRole.CLIENT_ADMIN]\n146 |     assert PermissionGroup.ADMIN_ACCESS not in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n147 |     \n148 |     assert PermissionGroup.CLIENT_PORTAL_ACCESS in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n149 |     assert PermissionGroup.MANAGE_USERS in ROLE_PERMISSIONS[UserRole.CLIENT_ADMIN]\n150 |     assert PermissionGroup.MANAGE_USERS not in ROLE_PERMISSIONS[UserRole.CLIENT_MEMBER]\n151 |     \n152 |     print(\"✓ test_rbac_roles_and_permissions passed.\")\n153 | \n154 | def test_role_checker():\n155 |     print(\"Running test_role_checker...\")\n156 |     checker = RoleChecker([UserRole.GFF_ADMIN, UserRole.CLIENT_ADMIN])\n157 |     \n158 |     # Allowed\n159 |     assert checker(\"gff_admin\") is True\n160 |     assert checker(\"client_admin\") is True\n161 |     \n162 |     # Forbidden\n163 |     try:\n164 |         checker(\"client_member\")\n165 |         assert False, \"Should raise 403\"\n166 |     except HTTPException as e:\n167 |         assert e.status_code == 403\n168 |         assert \"Insufficient role\" in e.detail\n169 |         \n170 |     print(\"✓ test_role_checker passed.\")\n171 | \n172 | def test_require_roles_dependency():\n173 |     print(\"Running test_require_roles_dependency...\")\n174 |     dep = require_roles([UserRole.CLIENT_ADMIN, UserRole.CLIENT_MEMBER])\n175 |     \n176 |     member_user = MockUser(role=\"client_member\")\n177 |     admin_user = MockUser(role=\"client_admin\")\n178 |     gff_user = MockUser(role=\"gff_admin\")\n179 |     \n180 |     # Allowed\n181 |     assert dep(member_user) == member_user\n182 |     assert dep(admin_user) == admin_user\n183 |     \n184 |     # Forbidden\n185 |     try:\n186 |         dep(gff_user)\n187 |         assert False, \"Should raise 403\"\n188 |     except HTTPException as e:\n189 |         assert e.status_code == 403\n190 |         \n191 |     print(\"✓ test_require_roles_dependency passed.\")\n192 | \n193 | def test_require_admin_dependency():\n194 |     print(\"Running test_require_admin_dependency...\")\n195 |     \n196 |     gff_user = MockUser(role=\"gff_admin\")\n197 |     legacy_admin = MockUser(role=\"admin\")\n198 |     member_user = MockUser(role=\"client_member\")\n199 |     \n200 |     # Allowed\n201 |     assert require_admin(gff_user) == gff_user\n202 |     assert require_admin(legacy_admin) == legacy_admin\n203 |     \n204 |     # Forbidden\n205 |     try:\n206 |         require_admin(member_user)\n207 |         assert False, \"Should raise 403\"\n208 |     except HTTPException as e:\n209 |         assert e.status_code == 403\n210 |         \n211 |     print(\"✓ test_require_admin_dependency passed.\")\n212 | \n213 | def test_require_client_access_dependency():\n214 |     print(\"Running test_require_client_access_dependency...\")\n215 |     \n216 |     gff_user = MockUser(role=\"gff_admin\", client_id=None)\n217 |     client_admin_user = MockUser(role=\"client_admin\", client_id=42)\n218 |     client_member_user = MockUser(role=\"client_member\", client_id=42)\n219 |     other_client_user = MockUser(role=\"client_admin\", client_id=99)\n220 |     \n221 |     # Case 1: GFF Admin bypasses with client_id present\n222 |     req1 = MockRequest(path_params={\"client_id\": \"42\"})\n223 |     assert require_client_access(req1, gff_user) == gff_user\n224 |     \n225 |     # Case 2: Matching client_id allowed\n226 |     assert require_client_access(req1, client_admin_user) == client_admin_user\n227 |     assert require_client_access(req1, client_member_user) == client_member_user\n228 |     \n229 |     # Case 3: Mismatched client_id forbidden\n230 |     try:\n231 |         require_client_access(req1, other_client_user)\n232 |         assert False, \"Should raise 403\"\n233 |     except HTTPException as e:\n234 |         assert e.status_code == 403\n235 |         assert \"Access to this client's data is denied\" in e.detail\n236 |         \n237 |     # Case 4: client_id in query parameters\n238 |     req2 = MockRequest(query_params={\"client_id\": \"42\"})\n239 |     assert require_client_access(req2, client_admin_user) == client_admin_user\n240 |     \n241 |     # Case 5: Invalid client_id format\n242 |     req_invalid = MockRequest(path_params={\"client_id\": \"abc\"})\n243 |     try:\n244 |         require_client_access(req_invalid, client_admin_user)\n245 |         assert False, \"Should raise 400\"\n246 |     except HTTPException as e:\n247 |         assert e.status_code == 400\n248 |         assert \"Invalid client_id format\" in e.detail\n249 |         \n250 |     print(\"✓ test_require_client_access_dependency passed.\")\n251 | \n252 | def test_require_same_client_or_admin_dependency():\n253 |     print(\"Running test_require_same_client_or_admin_dependency...\")\n254 |     \n255 |     gff_user = MockUser(role=\"gff_admin\", client_id=None)\n256 |     client_admin_user = MockUser(role=\"client_admin\", client_id=42)\n257 |     other_client_user = MockUser(role=\"client_admin\", client_id=99)\n258 |     \n259 |     req1 = MockRequest(path_params={\"client_id\": \"42\"})\n260 |     \n261 |     # Admin is bypassed\n262 |     assert require_same_client_or_admin(req1, gff_user) == gff_user\n263 |     \n264 |     # Same client is allowed\n265 |     assert require_same_client_or_admin(req1, client_admin_user) == client_admin_user\n266 |     \n267 |     # Other client is rejected\n268 |     try:\n269 |         require_same_client_or_admin(req1, other_client_user)\n270 |         assert False, \"Should raise 403\"\n271 |     except HTTPException as e:\n272 |         assert e.status_code == 403\n273 |         assert \"You can only access data belonging to your own client account\" in e.detail\n274 |         \n275 |     # Missing parameter\n276 |     req_missing = MockRequest()\n277 |     try:\n278 |         require_same_client_or_admin(req_missing, other_client_user)\n279 |         assert False, \"Should raise 400\"\n280 |     except HTTPException as e:\n281 |         assert e.status_code == 400\n282 |         assert \"client_id parameter is required\" in e.detail\n283 |         \n284 |     print(\"✓ test_require_same_client_or_admin_dependency passed.\")\