 a reset filter option. I am starting to implement the active project cards now.\n\n```\n\n```\n\n"}}
{"ts":"2026-06-27T03:44:30.753Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"avgnvwa0","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/projects/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect } from \"react\";\nimport Link from \"next/link\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  Search, \n  SlidersHorizontal, \n  X, \n  Clock, \n  Cpu, \n  ShieldCheck, \n  Activity, \n  ArrowUpRight, \n  Calendar, \n  User, \n  Send, \n  CheckCircle2, \n  Terminal, \n  ChevronRight, \n  RefreshCw, \n  MessageSquare,\n  Sparkles,\n  HelpCircle,\n  FolderOpen,\n  ArrowRight\n} from \"lucide-react\";\n\nimport { \n  MetricTile, \n  WorkspaceCard, \n  StatusBadge, \n  PrivatePageHeader,\n  EmptyState\n} from \"@/components/private-app\";\n\n// ==========================================\n// CLIENT PROJECT TYPE DEFINITION\n// ==========================================\ninterface ClientProject {\n  id: string;\n  name: string;\n  phase: \"Garage\" | \"Foundry\" | \"Factory\" | \"Operate\";\n  owner: {\n    name: string;\n    role: string;\n    avatarInitials: string;\n  };\n  timeline: string;\n  progress: number;\n  nextMilestone: string;\n  healthStatus: \"On Track\" | \"Warning\" | \"Critical\";\n  description: string;\n  env: string;\n  platformCore: string;\n  specs: {\n    nodeId: string;\n    cores: string;\n    memory: string;\n    complianceScore: number;\n    securityLevel: string;\n  };\n}\n\n// ==========================================\n// REPRESENTATIVE PREVIEW DATA (6 projects)\n// ==========================================\nconst mockProjects: ClientProject[] = [\n  {\n    id: \"PROJ-701\",\n    name: \"Sovereign Audit & Compliance Ledger\",\n    phase: \"Garage\",\n    owner: {\n      name: \"Evelyn Chen\",\n      role: \"Principal AI Lead\",\n      avatarInitials: \"EC\"\n    },\n    timeline: \"June 2026 - Aug 2026\",\n    progress: 18,\n    nextMilestone: \"Phase Gate 1: Threat Model Sign-off\",\n    healthStatus: \"On Track\",\n    description: \"Deploying deep isolation sandboxes to verify cross-border financial audit capabilities using local fine-tuned LLMs.\",\n    env: \"Switzerland Enclave 01\",\n    platformCore: \"Foundry Studio\",\n    specs: {\n      nodeId: \"FF-701A-CH\",\n      cores: \"8 vCPU Cores\",\n      memory: \"16 GB Isolation RAM\",\n      complianceScore: 98.4,\n      securityLevel: \"EAL6+ Sandbox\"\n    }\n  },\n  {\n    id: \"PROJ-404\",\n    name: \"Apex RetailMesh Agent Lattice\",\n    phase: \"Foundry\",\n    owner: {\n      name: \"Marcus Aurelius\",\n      role: \"Orchestration Architect\",\n      avatarInitials: \"MA\"\n    },\n    timeline: \"May 2026 - Oct 2026\",\n    progress: 48,\n    nextMilestone: \"Agent Handshake Telemetry Benchmark\",\n    healthStatus: \"On Track\",\n    description: \"Integrating 1,200 autonomous edge agents to orchestrate inventory and demand forecasts across regional supply hubs.\",\n    env: \"Singapore West Grid\",\n    platformCore: \"RetailMesh Core\",\n    specs: {\n      nodeId: \"RM-404B-SG\",\n      cores: \"32 vCPU Cores\",\n      memory: \"64 GB isolation RAM\",\n      complianceScore: 99.2,\n      securityLevel: \"ISO-27001 Certified\"\n    }\n  },\n  {\n    id: \"PROJ-302\",\n    name: \"Sovereign Defense Risk Parser\",\n    phase: \"Factory\",\n    owner: {\n      name: \"Dr. Sarah Vance\",\n      role: \"Chief Governance Director\",\n      avatarInitials: \"SV\"\n    },\n    timeline: \"Mar 2026 - Nov 2026\",\n    progress: 74,\n    nextMilestone: \"Sovereign Air-Gap Decoupling Test\",\n    healthStatus: \"Warning\",\n    description: \"Parser compiling raw satellite telemetry and defense logs into continuous zero-trust threat reports.\",\n    env: \"US Federal Enclave\",\n    platformCore: \"Control Center Node\",\n    specs: {\n      nodeId: \"CC-302F-US\",\n      cores: \"64 vCPU Cores\",\n      memory: \"128 GB Isolation RAM\",\n      complianceScore: 97.1,\n      securityLevel: \"Sovereign Secret Enclave\"\n    }\n  },\n  {\n    id: \"PROJ-209\",\n    name: \"TelecomVerse Network Self-Healer\",\n    phase: \"Operate\",\n    owner: {\n      name: \"Devon Carter\",\n      role: \"Site Reliability Specialist\",\n      avatarInitials: \"DC\"\n    },\n    timeline: \"Jan 2026 - Ongoing\",\n    progress: 100,\n    nextMilestone: \"Automated Routine Guardrail Audit\",\n    healthStatus: \"On Track\",\n    description: \"Continuous autonomous network optimization layer, auto-triaging packet anomalies with sub-10ms response times.\",\n    env: \"London Central Core\",\n    platformCore: \"TelecomVerse Engine\",\n    specs: {\n      nodeId: \"TV-209O-UK\",\n      cores: \"128 vCPU Cores\",\n      memory: \"256 GB Isolation RAM\",\n      complianceScore: 99.9,\n      securityLevel: \"Autonomous Active Enclave\"\n    }\n  },\n  {\n    id: \"PROJ-105\",\n    name: \"OreMesh Sub-Surface Vision Grid\",\n    phase: \"Foundry\",\n    owner: {\n      name: \"Elena Rostova\",\n      role: \"Geological AI Director\",\n      avatarInitials: \"ER\"\n    },\n    timeline: \"April 2026 - Dec 2026\",\n    progress: 35,\n    nextMilestone: \"Model Weight Calibration for Quartz\",\n    healthStatus: \"Critical\",\n    description: \"Volumetric deep learning model mapping seismic density scans onto simulated autonomous drill paths.\",\n    env: \"Perth Enclave B\",\n    platformCore: \"OreMesh Vision Core\",\n    specs: {\n      nodeId: \"OM-105F-AU\",\n      cores: \"48 GPU-backed vCPU\",\n      memory: \"96 GB Isolation RAM\",\n      complianceScore: 94.1,\n      securityLevel: \"High-Performance Compute\"\n    }\n  },\n  {\n    id: \"PROJ-882\",\n    name: \"EnergyVerse Multi-Grid Balance Agent\",\n    phase: \"Garage\",\n    owner: {\n      name: \"Tariq Al-Mansoor\",\n      role: \"Senior Grid Integrator\",\n      avatarInitials: \"TA\"\n    },\n    timeline: \"June 2026 - Sept 2026\",\n    progress: 8,\n    nextMilestone: \"Grid Simulator Endpoint API Integration\",\n    healthStatus: \"On Track\",\n    description: \"Decentralized neural energy grid balancer modeling multi-phase distribution nodes to avoid peaking failures.\",\n    env: \"Munich Grid C\",\n    platformCore: \"Control Center Node\",\n    specs: {\n      nodeId: \"EV-882A-DE\",\n      cores: \"16 vCPU Cores\",\n      memory: \"32 GB Isolation RAM\",\n      complianceScore: 96.5,\n      securityLevel: \"EAL5 Sandbox\"\n    }\n  }\n];\n\n// Phase hierarchy representation for stepper\nconst LIFECYCLE_PHASES: Array<\"Garage\" | \"Foundry\" | \"Factory\" | \"Operate\"> = [\n  \"Garage\",\n  \"Foundry\",\n  \"Factory\",\n  \"Operate\"\n];\n\n// Telemetry log list for simulation\nconst TELEMETRY_LOG_TEMPLATES = [\n  \"Establishing transient eBPF socket listener on port 443...\",\n  \"Running cryptographic binary verification handshake...\",\n  \"Attesting sandbox kernel memory isolation boundaries...\",\n  \"Loading localized model weights into dedicated secure RAM...\",\n  \"Initializing active guardrail monitor policy v4.2...\",\n  \"Running Zero-Trust isolation check: SECURE (100% compliant)...\",\n  \"Telemetry stream synced at Swiss Node cluster state: NOMINAL.\",\n  \"Injecting validation queries through isolation boundary...\",\n  \"Epoch 1081 block hash consensus matching verified.\",\n  \"Continuous telemetry diagnostics active and stable.\"\n];\n\nexport default function ClientProjectsPage() {\n  const router = useRouter();\n\n  // Search & Filter state\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedPhase, setSelectedPhase] = useState<string>(\"\");\n  const [selectedHealth, setSelectedHealth] = useState<string>(\"\");\n  const [viewMode, setViewMode] = useState<\"grid\" | \"table\">(\"grid\");\n\n  // Selected project for details drawer\n  const [selectedProject, setSelectedProject] = useState<ClientProject | null>(null);\n  const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n\n  // Simulated Telemetry logs state\n  const [logs, setLogs] = useState<string[]>([]);\n  const [isLogSyncing, setIsLogSyncing] = useState(false);\n\n  // Simulated Dispatch update request states\n  const [isRequestingUpdate, setIsRequestingUpdate] = useState(false);\n  const [dispatchStep, setDispatchStep] = useState(0);\n  const [dispatchLogs, setDispatchLogs] = useState<string[]>([]);\n  const [dispatchSuccess, setDispatchSuccess] = useState(false);\n\n  // Dynamic visual notification banner\n  const [notification, setNotification] = useState<string | null>(null);\n\n  // Generate simulated log streams for selected project\n  useEffect(() => {\n    if (selectedProject) {\n      // Pick random logs initially\n      const initialLogs = [\n        `[${new Date().toLocaleTimeString()}] INITIATING TELMETRY SYNC FOR ${selectedProject.id}...`,\n        `[${new Date().toLocaleTimeString()}] Connected to active host node: ${selectedProject.specs.nodeId}`,\n        `[${new Date().toLocaleTimeString()}] Secure sandbox context state: ACTIVE`,\n        `[${new Date().toLocaleTimeString()}] Memory footprint: ${selectedProject.specs.memory}`,\n      ];\n      setLogs(initialLogs);\n    }\n  }, [selectedProject]);\n\n  // Handle live logs interval when drawer is open\n  useEffect(() => {\n    let interval: NodeJS.Timeout;\n    if (isDrawerOpen && selectedProject && !isRequestingUpdate) {\n      interval = setInterval(() => {\n        const randomTemplate = TELEMETRY_LOG_TEMPLATES[Math.floor(Math.random() * TELEMETRY_LOG_TEMPLATES.length)];\n        const logLine = `[${new Date().toLocaleTimeString()}] ${randomTemplate}`;\n        setLogs(prev => [...prev.slice(-8), logLine]); // keep last 10 lines\n      }, 4000);\n    }\n    return () => clearInterval(interval);\n  }, [isDrawerOpen, selectedProject, isRequestingUpdate]);\n\n  // Trigger telemetry sync manual action\n  const handleSyncTelemetry = () => {\n    setIsLogSyncing(true);\n    const syncLog = `[${new Date().toLocaleTimeString()}] SYSTEM DIAGNOSTIC TRACE REQUEST TRIGGERED BY CLIENT...`;\n    setLogs(prev => [...prev, syncLog]);\n\n    setTimeout(() => {\n      setIsLogSyncing(false);\n      const completeLog = `[${new Date().toLocaleTimeString()}] TELEMETRY HANDSHAKE RE-ESTABLISHED. ALL GUARDRAILS ACTIVE.`;\n      setLogs(prev => [...prev, completeLog]);\n    }, 1500);\n  };\n\n  // Run secure update request cycle\n  const triggerUpdateRequest = (projId: string) => {\n    setIsRequestingUpdate(true);\n    setDispatchStep(1);\n    setDispatchSuccess(false);\n    setDispatchLogs([\"Initializing sovereign socket handshake...\"]);\n\n    const steps = [\n      { log: \"Sealing current context layer into transit frame...\", delay: 600 },\n      { log: \"Locating secure delivery lead credentials...\", delay: 1200 },\n      { log: `Broadcasting PRIORITY LEVEL ALPHA dispatch to GFF Engineering Guild...`, delay: 1800 },\n      { log: \"Syncing updates ledger record signature...\", delay: 2400 },\n    ];\n\n    steps.forEach((step, idx) => {\n      setTimeout(() => {\n        setDispatchStep(idx + 2);\n        setDispatchLogs(prev => [...prev, step.log]);\n      }, step.delay);\n    });\n\n    setTimeout(() => {\n      setDispatchSuccess(true);\n      setNotification(`Emergency program status update requested for project ${projId}`);\n    }, 3200);\n  };\n\n  // Quick close and clean states\n  const closeDrawer = () => {\n    setIsDrawerOpen(false);\n    setIsRequestingUpdate(false);\n    setDispatchStep(0);\n    setDispatchLogs([]);\n    setDispatchSuccess(false);\n  };\n\n  const handleOpenProjectDetails = (proj: ClientProject) => {\n    setSelectedProject(proj);\n    setIsDrawerOpen(true);\n  };\n\n  // Clear global notifications\n  useEffect(() => {\n    if (notification) {\n      const timer = setTimeout(() => setNotification(null), 6000);\n      return () => clearTimeout(timer);\n    }\n  }, [notification]);\n\n  // Filter projects list\n  const filteredProjects = mockProjects.filter(p => {\n    const matchesSearch = \n      p.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      p.id.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      p.owner.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n      p.description.toLowerCase().includes(searchQuery.toLowerCase());\n    \n    const matchesPhase = selectedPhase ? p.phase === selectedPhase : true;\n    const matchesHealth = selectedHealth ? p.healthStatus === selectedHealth : true;\n\n    return matchesSearch && matchesPhase && matchesHealth;\n  });\n\n  // Calculate high-fidelity stats for visual metric tiles based on filtered set\n  const onTrackCount = mockProjects.filter(p => p.healthStatus === \"On Track\").length;\n  const warningCount = mockProjects.filter(p => p.healthStatus === \"Warning\").length;\n  const criticalCount = mockProjects.filter(p => p.healthStatus === \"Critical\").length;\n\n  return (\n    <div className=\"space-y-6 max-w-[1750px] mx-auto pb-16 select-none relative\">\n      \n      {/* ==========================================\n          0. NOTIFICATION BAR\n          ========================================== */}\n      {notification && (\n        <div className=\"fixed top-6 right-6 z-50 animate-in fade-in slide-in-from-top duration-300\">\n          <div className=\"border border-emerald-500/20 bg-emerald-950/70 backdrop-blur-md text-emerald-300 px-4 py-3 rounded-xl shadow-2xl flex items-center gap-3 font-mono text-[11.5px]\">\n            <CheckCircle2 className=\"w-4 h-4 text-emerald-400 shrink-0\" />\n            <span>{notification}</span>\n            <button onClick={() => setNotification(null)} className=\"ml-2 hover:text-white text-emerald-300/60\">\n              <X className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        </div>\n      )}\n\n      {/* ==========================================\n          1. SYSTEM SAFETY DISCLOSURE BANNER\n          ========================================== */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-3 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2.5 text-white/70\">\n          <Activity className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n          <span>\n            <strong className=\"text-white\">COCKPIT LEDGER SYNC:</strong> Active monitoring of your secure enclaves is online. Interactive parameters represent localized sandbox partitions.\n          </span>\n        </div>\n        <span className=\"text-[9.5px] text-[#009DFF]/80 font-bold bg-[#009DFF]/10 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase tracking-wider shrink-0\">\n          SECURE PROTOCOL ACTIVE\n        </span>\n      </div>\n\n      {/* ==========================================\n          2. HEADER BLOCK\n          ========================================== */}\n      <PrivatePageHeader\n        title=\"Delivery Program Control Deck\"\n        desc=\"Audit high-end sandbox developments, core model lifecycle phases, compliance checks, and secure multi-agent sandboxes.\"\n        badgeLabel=\"Multi-Enclave Ledger\"\n        actions={\n          <div className=\"flex flex-wrap gap-2 w-full md:w-auto\">\n            <button\n              onClick={() => {\n                triggerUpdateRequest(\"GLOBAL-COCKPIT\");\n                setIsDrawerOpen(true);\n              }}\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.02] px-4 text-[11px] font-mono font-bold text-white hover:bg-white/[0.06] hover:border-white/20 transition-all cursor-pointer\"\n            >\n              <Send className=\"w-3.5 h-3.5 text-white/60\" />\n              <span>REQUEST GLOBAL AUDIT</span>\n            </button>\n            <button\n              onClick={() => router.push(\"/portal/support\")}\n              className=\"flex-grow md:flex-grow-0 inline-flex h-9 items-center justify-center gap-1.5 rounded-lg bg-[#009DFF] px-4 text-[11px] font-mono font-bold text-white hover:bg-[#009DFF]/90 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.2)]\"\n            >\n              <MessageSquare className=\"w-3.5 h-3.5\" />\n              <span>SUPPORT WIRE</span>\n            </button>\n          </div>\n        }\n      />\n\n      {/* ==========================================\n          3. REAL-TIME PROGRAM HEALTH METRICS\n          ========================================== */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        <MetricTile\n          title=\"Active Engagements\"\n          value={`${mockProjects.length} Enclaves`}\n          delta=\"+1\"\n          direction=\"up\"\n          status=\"stable\"\n          sparkPoints={[4, 5, 5, 5, 5, 6, 6, 6, 6, 6]}\n        />\n        <MetricTile\n          title=\"Lifecycle Balance\"\n          value=\"2G | 2F | 1F | 1O\"\n          delta=\"NOMINAL\"\n          direction=\"neutral\"\n          status=\"normal\"\n          sparkPoints={[10, 15, 12, 18, 20, 24, 22, 28, 30, 32]}\n        />\n        <MetricTile\n          title=\"Program Health Ratio\"\n          value={`${onTrackCount} OK / ${warningCount} WRN / ${criticalCount} CRT`}\n          delta=\"STABLE\"\n          direction=\"neutral\"\n          status={criticalCount > 0 ? \"warning\" : \"normal\"}\n          sparkPoints={[90, 92, 88, 93, 91, 95, 94, 96, 96, 96]}\n        />\n        <MetricTile\n          title=\"Avg Compliance Guard\"\n          value=\"97.53%\"\n          delta=\"+0.82%\"\n          direction=\"up\"\n          status=\"stable\"\n          sparkPoints={[95.1, 95.8, 96.2, 96.0, 96.9, 97.2, 97.0, 97.4, 97.5, 97.53]}\n        />\n      </div>\n\n      {/* ==========================================\n          4. FILTER & VIEW CONTROL BAR\n          ========================================== */}\n      <WorkspaceCard className=\"p-4 space-y-4 md:space-y-0 md:flex md:items-center md:justify-between gap-4\">\n        {/* Search Input */}\n        <div className=\"relative flex-grow max-w-lg\">\n          <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n          <input \n            type=\"text\"\n            value={searchQuery}\n            onChange={(e) => setSearchQuery(e.target.value)}\n            placeholder=\"Search by ID, program name, owner, description...\"\n            className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n          />\n        </div>\n\n        {/* Filter Selectors */}\n        <div className=\"flex flex-wrap items-center gap-3\">\n          {/* Phase Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedPhase}\n              onChange={(e) => setSelectedPhase(e.target.value)}\n              className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL LIFECYCLE PHASES</option>\n              {LIFECYCLE_PHASES.map(ph => (\n                <option key={ph} value={ph} className=\"bg-[#0c0c0c] text-white\">{ph.toUpperCase()}</option>\n              ))}\n            </select>\n            <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n\n          {/* Health Status Filter */}\n          <div className=\"relative\">\n            <select\n              value={selectedHealth}\n              onChange={(e) => setSelectedHealth(e.target.value)}\n              className=\"h-9 rounded-lg border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none uppercase\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white\">ALL HEALTH STATUSES</option>\n              <option value=\"On Track\" className=\"bg-[#0c0c0c] text-white\">ON TRACK</option>\n              <option value=\"Warning\" className=\"bg-[#0c0c0c] text-white\">WARNING</option>\n              <option value=\"Critical\" className=\"bg-[#0c0c0c] text-white\">CRITICAL</option>\n            </select>\n            <SlidersHorizontal className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n          </div>\n\n          {/* Toggle View Mode Buttons */}\n          <div className=\"flex border border-white/5 rounded-lg overflow-hidden shrink-0\">\n            <button\n              onClick={() => setViewMode(\"grid\")}\n              className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n                viewMode === \"grid\" \n                  ? \"bg-white/5 text-white\" \n                  : \"bg-transparent text-white/40 hover:text-white/60\"\n              }`}\n            >\n              GRID\n            </button>\n            <button\n              onClick={() => setViewMode(\"table\")}\n              className={`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n                viewMode === \"table\" \n                  ? \"bg-white/5 text-white\" \n                  : \"bg-transparent text-white/40 hover:text-white/60\"\n              }`}\n            >\n              TABLE\n            </button>\n          </div>\n\n          {/* Reset Filters Option */}\n          {(searchQuery || selectedPhase || selectedHealth) && (\n            <button\n              onClick={() => {\n                setSearchQuery(\"\");\n                setSelectedPhase(\"\");\n                setSelectedHealth(\"\");\n              }}\n              className=\"text-[10px] font-mono text-red-400 hover:text-red-300 uppercase tracking-wider underline cursor-pointer\"\n            >\n              Clear Filters\n            </button>\n          )}\n        </div>\n      </WorkspaceCard>\n\n      {/* ==========================================\n          5. MAIN CONTENT SPACE (GRID / TABLE)\n          ========================================== */}\n      {filteredProjects.length === 0 ? (\n        <EmptyState\n          title=\"No Sandbox Program Records Match\"\n          description=\"We couldn't find any secure sandboxes matching your current search parameters. Clear filters to restore telemetry.\"\n          actionLabel=\"RESET ALL FILTERS\"\n          onAction={() => {\n            setSearchQuery(\"\");\n            setSelectedPhase(\"\");\n            setSelectedHealth(\"\");\n          }}\n          icon={FolderOpen}\n        />\n      ) : viewMode === \"grid\" ? (\n        /* PREMIUM CARDS GRID (Default View) */\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filteredProjects.map((project) => (\n            <WorkspaceCard \n              key={project.id} \n              className=\"flex flex-col h-full border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-all rounded-2xl p-6 relative overflow-hidden\"\n              spotlightColor={\n                project.healthStatus === \"On Track\" \n                  ? \"rgba(16,185,129,0.03)\" \n                  : project.healthStatus === \"Warning\" \n                    ? \"rgba(251,191,36,0.03)\" \n                    : \"rgba(228,0,15,0.03)\"\n              }\n            >\n              {/* Top Meta Line: ID, Health, Phase */}\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n                <div className=\"flex items-center gap-2\">\n                  <span className=\"text-[12px] font-mono font-bold text-[#009DFF]\">\n                    {project.id}\n                  </span>\n                  <span className=\"text-[9px] text-white/20 font-mono\">•</span>\n                  <span className=\"text-[10px] font-mono font-bold text-white/40 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded uppercase\">\n                    {project.env}\n                  </span>\n                </div>\n\n                <StatusBadge \n                  state={\n                    project.healthStatus === \"On Track\" \n                      ? \"stable\" \n                      : project.healthStatus === \"Warning\" \n                        ? \"warning\" \n                        : \"error\"\n                  } \n                  label={project.healthStatus} \n                />\n              </div>\n\n              {/* Title & Core Platform Description */}\n              <div className=\"mt-4 flex-grow space-y-2\">\n                <div className=\"flex items-center gap-1.5\">\n                  <h3 className=\"text-[14px] font-bold text-white font-mono tracking-tight uppercase group-hover:text-[#009DFF] transition-colors\">\n                    {project.name}\n                  </h3>\n                </div>\n                <p className=\"text-[11.5px] text-white/50 leading-relaxed font-mono font-light min-h-[50px]\">\n                  {project.description}\n                </p>\n              </div>\n\n              {/* Delivery Lead Block */}\n              <div className=\"mt-4 flex items-center gap-3 p-2.5 rounded-xl bg-white/[0.01] border border-white/5\">\n                <div className=\"h-7 w-7 rounded-lg bg-[#009DFF]/10 border border-[#009DFF]/20 flex items-center justify-center text-[10px] font-bold text-[#009DFF] font-mono select-none\">\n                  {project.owner.avatarInitials}\n                </div>\n                <div>\n                  <div className=\"text-[10px] font-mono text-white/30 uppercase tracking-widest leading-none\">Delivery Lead</div>\n                  <div className=\"text-[11px] font-mono font-bold text-white/80 mt-1\">{project.owner.name}</div>\n                </div>\n              </div>\n\n              {/* Premium Multi-Stage Stepper Component */}\n              <div className=\"mt-5 space-y-2.5 p-3 rounded-xl bg-white/[0.01] border border-white/5\">\n                <span className=\"text-[9px] font-mono tracking-widest text-white/30 uppercase block font-bold\">Lifecycle Stage</span>\n                <div className=\"relative flex items-center justify-between px-1\">\n                  {/* Connecting dashed line */}\n                  <div className=\"absolute left-4 right-4 top-1/2 -translate-y-1/2 h-0.5 border-t border-dashed border-white/10 z-0\" />\n                  \n                  {LIFECYCLE_PHASES.map((p, index) => {\n                    const isCurrent = project.phase === p;\n                    const isPast = LIFECYCLE_PHASES.indexOf(project.phase) > index;\n                    \n                    return (\n                      <div key={p} className=\"flex flex-col items-center relative z-10\">\n                        <div className={`h-4.5 w-4.5 rounded-full flex items-center justify-center border text-[8px] font-bold transition-all ${\n                          isCurrent \n                            ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF] shadow-[0_0_10px_rgba(0,157,255,0.4)]\" \n                            : isPast \n                              ? \"bg-emerald-500/10 border-emerald-500/40 text-emerald-400\" \n                              : \"bg-[#050505] border-white/5 text-white/20\"\n                        }`}>\n                          {isPast ? \"✓\" : index + 1}\n                        </div>\n                        <span className={`text-[8.5px] font-mono mt-1 ${\n                          isCurrent \n                            ? \"text-white font-bold\" \n                            : isPast \n                              ? \"text-white/50\" \n                              : \"text-white/20\"\n                        }`}>\n                          {p}\n                        </span>\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Progress Slider (Non-interactive) */}\n              <div className=\"mt-4 space-y-1\">\n                <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                  <span className=\"text-white/30 uppercase\">Deployment Progress</span>\n                  <span className=\"text-white/80 font-bold\">{project.progress}%</span>\n                </div>\n                <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\">\n                  <div \n                    className={`h-full rounded-full transition-all duration-500 ${\n                      project.healthStatus === \"On Track\" \n                        ? \"bg-gradient-to-r from-[#009DFF] to-emerald-400\" \n                        : project.healthStatus === \"Warning\" \n                          ? \"bg-gradient-to-r from-[#009DFF] to-amber-400\" \n                          : \"bg-gradient-to-r from-red-500 to-[#E4000F]\"\n                    }`}\n                    style={{ width: `${project.progress}%` }}\n                  />\n                </div>\n              </div>\n\n              {/* Next Milestone target */}\n              <div className=\"mt-5 pt-4 border-t border-white/5 flex items-start gap-2.5 text-[10.5px] font-mono text-white/45\">\n                <Calendar className=\"w-3.5 h-3.5 text-white/30 mt-0.5 shrink-0\" />\n                <div className=\"space-y-0.5\">\n                  <span className=\"text-white/20 uppercase text-[8.5px] block font-bold\">NEXT TARGET GATE</span>\n                  <span className=\"text-white/80 font-medium block leading-tight\">{project.nextMilestone}</span>\n                  <span className=\"text-white/40 text-[9px] block\">Target: {project.timeline}</span>\n                </div>\n              </div>\n\n              {/* Card CTA actions */}\n              <div className=\"mt-6 pt-4 border-t border-white/5 grid grid-cols-2 gap-2\">\n                <button\n                  onClick={() => triggerUpdateRequest(project.id)}\n                  className=\"h-8 rounded border border-white/5 hover:border-white/10 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] font-mono font-bold text-white/50 hover:text-white uppercase tracking-wider transition-all cursor-pointer\"\n                >\n                  Request Update\n                </button>\n                <button\n                  onClick={() => handleOpenProjectDetails(project)}\n                  className=\"h-8 rounded bg-[#009DFF]/10 hover:bg-[#009DFF]/20 border border-[#009DFF]/20 text-[9.5px] font-mono font-bold text-[#009DFF] hover:text-white uppercase tracking-wider flex items-center justify-center gap-1 transition-all cursor-pointer\"\n                >\n                  <span>Inspect Spec</span>\n                  <ArrowUpRight className=\"w-3 h-3\" />\n                </button>\n              </div>\n            </WorkspaceCard>\n          ))}\n        </div>\n      ) : (\n        /* ENTERPRISE LIST TABLE VIEW */\n        <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm overflow-hidden\">\n          <div className=\"bg-white/[0.02] border-b border-white/5 px-5 py-3.5 text-[10.5px] font-mono text-white/45 uppercase font-bold tracking-wider\">\n            Sovereign Project Registry Telemetry\n          </div>\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full min-w-[900px] text-left font-mono text-[11.5px] text-white/70\">\n              <thead>\n                <tr className=\"border-b border-white/5 text-white/30 text-[9px] uppercase tracking-wider\">\n                  <th className=\"p-4 pl-6\">ID</th>\n                  <th className=\"p-4\">Program / Project</th>\n                  <th className=\"p-4\">Lifecycle Phase</th>\n                  <th className=\"p-4\">Delivery Lead</th>\n                  <th className=\"p-4\">Next Target Milestone</th>\n                  <th className=\"p-4 text-center\">Progress</th>\n                  <th className=\"p-4\">Health</th>\n                  <th className=\"p-4 pr-6 text-right\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/5\">\n                {filteredProjects.map((project) => (\n                  <tr key={project.id} className=\"hover:bg-white/[0.01] transition-colors group\">\n                    <td className=\"p-4 pl-6 text-[#009DFF] font-bold\">{project.id}</td>\n                    <td className=\"p-4\">\n                      <div className=\"font-semibold text-white uppercase text-[12px]\">{project.name}</div>\n                      <div className=\"text-[10px] text-white/35 mt-0.5\">{project.env}</div>\n                    </td>\n                    <td className=\"p-4\">\n                      <span className=\"px-2 py-0.5 text-[9.5px] font-bold bg-[#009DFF]/10 text-[#009DFF] rounded border border-[#009DFF]/20 uppercase tracking-wide\">\n                        {project.phase}\n                      </span>\n                    </td>\n                    <td className=\"p-4\">\n                      <div className=\"text-white/80 font-medium\">{project.owner.name}</div>\n                      <div className=\"text-[9px] text-white/30\">{project.owner.role}</div>\n                    </td>\n                    <td className=\"p-4\">\n                      <div className=\"text-white/70 font-medium max-w-[200px] truncate\">{project.nextMilestone}</div>\n                      <div className=\"text-[9px] text-white/30\">Target: {project.timeline}</div>\n                    </td>\n                    <td className=\"p-4 text-center\">\n                      <div className=\"flex items-center justify-center gap-2\">\n                        <span className=\"font-bold text-white\">{project.progress}%</span>\n                        <div className=\"w-16 h-1 bg-white/5 rounded-full overflow-hidden shrink-0 hidden sm:block\">\n                          <div className=\"h-full bg-gradient-to-r from-[#009DFF] to-emerald-400\" style={{ width: `${project.progress}%` }} />\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"p-4\">\n                      <StatusBadge \n                        state={\n                          project.healthStatus === \"On Track\" \n                            ? \"stable\" \n                            : project.healthStatus === \"Warning\" \n                              ? \"warning\" \n                              : \"error\"\n                        } \n                        label={project.healthStatus} \n                      />\n                    </td>\n                    <td className=\"p-4 pr-6 text-right space-x-2\">\n                      <button\n                        onClick={() => triggerUpdateRequest(project.id)}\n                        className=\"inline-flex h-7 items-center justify-center px-2 text-[9px] font-bold text-white/40 hover:text-white bg-white/5 hover:bg-white/10 border border-white/5 rounded transition-all cursor-pointer uppercase\"\n                      >\n                        Update\n                      </button>\n                      <button\n                        onClick={() => handleOpenProjectDetails(project)}\n                        className=\"inline-flex h-7 items-center justify-center px-2.5 gap-1 text-[9px] font-bold text-[#009DFF] hover:text-white bg-[#009DFF]/5 hover:bg-[#009DFF]/20 border border-[#009DFF]/20 rounded transition-all cursor-pointer uppercase\"\n                      >\n                        <span>Inspect</span>\n                        <ArrowRight className=\"w-2.5 h-2.5\" />\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* ==========================================\n          6. THE SLIDE-OVER TELEMETRY & SPECS DRAWER\n          ========================================== */}\n      <div className={`fixed inset-0 z-50 overflow-hidden transition-all duration-300 ${isDrawerOpen ? \"visible\" : \"invisible pointer-events-none\"}`}>\n        {/* Backdrop overlay */}\n        <div \n          onClick={closeDrawer}\n          className={`absolute inset-0 bg-black/80 backdrop-blur-md transition-opacity duration-300 ${isDrawerOpen ? \"opacity-100\" : \"opacity-0\"}`} \n        />\n\n        {/* Sliding Panel */}\n        <div className={`absolute top-0 right-0 h-full w-full max-w-xl bg-gradient-to-b from-[#0a0a0a] to-[#040404] border-l border-white/10 shadow-2xl flex flex-col transition-transform duration-300 ease-out transform ${isDrawerOpen ? \"translate-x-0\" : \"translate-x-full\"}`}>\n          \n          {selectedProject ? (\n            <div className=\"flex flex-col h-full overflow-y-auto\">\n              {/* Drawer Header */}\n              <div className=\"p-6 border-b border-white/5 flex items-start justify-between bg-white/[0.01]\">\n                <div className=\"space-y-1\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded uppercase\">\n                      SECURE ENCLAVE ACTIVE\n                    </span>\n                    <span className=\"text-[10px] font-mono font-bold text-white/50 bg-white/5 border border-white/10 px-2 py-0.5 rounded uppercase\">\n                      {selectedProject.id}\n                    </span>\n                  </div>\n                  <h3 className=\"text-md font-bold text-white font-mono uppercase tracking-tight mt-2\">\n                    {selectedProject.name}\n                  </h3>\n                </div>\n                <button\n                  onClick={closeDrawer}\n                  className=\"p-1.5 rounded-lg border border-white/5 text-white/40 hover:text-white hover:bg-white/5 cursor-pointer transition-all\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              {/* Drawer Body content */}\n              <div className=\"p-6 flex-grow space-y-6\">\n\n                {/* Simulated Cryptographic Dispatch Progress overlay */}\n                {isRequestingUpdate ? (\n                  <div className=\"p-5 rounded-xl border border-[#009DFF]/20 bg-[#009DFF]/5 space-y-4 font-mono\">\n                    <div className=\"flex items-center gap-3\">\n                      <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin shrink-0\" />\n                      <div className=\"space-y-1\">\n                        <h4 className=\"text-[12px] font-bold text-white uppercase\">Cryptographic Update Dispatch active</h4>\n                        <p className=\"text-[10px] text-white/40\">Broadcasting through secure dual-layer gateways</p>\n                      </div>\n                    </div>\n\n                    <div className=\"space-y-2 text-[10px] text-[#009DFF]/80 p-3 bg-black/40 rounded border border-white/5 select-text\">\n                      {dispatchLogs.map((logLine, idx) => (\n                        <div key={idx} className=\"flex gap-2\">\n                          <span className=\"text-white/20 select-none\">[{idx+1}]</span>\n                          <span>{logLine}</span>\n                        </div>\n                      ))}\n                    </div>\n\n                    {dispatchSuccess ? (\n                      <div className=\"p-3 bg-emerald-500/10 border border-emerald-500/20 rounded-lg text-emerald-400 space-y-2\">\n                        <div className=\"flex items-center gap-2 text-[11px] font-bold uppercase\">\n                          <CheckCircle2 className=\"w-4 h-4\" />\n                          <span>Dispatch complete</span>\n                        </div>\n                        <div className=\"text-[10px] text-white/60 leading-relaxed\">\n                          A direct program update trigger signal has been signed and queued in the delivery lead enclaves. Live updates will compile inside this portal in under 15 minutes.\n                        </div>\n                        <div className=\"text-[8.5px] text-white/30 text-right select-all\">\n                          TX-SIG: SHA-256: 4e81cb8d9e2b100fa1b\n                        </div>\n                      </div>\n                    ) : (\n                      <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\">\n                        <div \n                          className=\"h-full bg-[#009DFF] transition-all duration-300\"\n                          style={{ width: `${(dispatchStep / 5) * 100}%` }}\n                        />\n                      </div>\n                    )}\n\n                    {dispatchSuccess && (\n                      <button\n                        onClick={() => setIsRequestingUpdate(false)}\n                        className=\"w-full h-8 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold text-white uppercase tracking-wider transition-all cursor-pointer\"\n                      >\n                        Return to Spec Deck\n                      </button>\n                    )}\n                  </div>\n                ) : null}\n\n                {/* 1. Core Sandbox Details */}\n                {!isRequestingUpdate && (\n                  <div className=\"space-y-4\">\n                    <h4 className=\"text-[11px] font-bold text-white/40 font-mono uppercase tracking-widest border-b border-white/5 pb-2\">\n                      Isolated Enclave Parameters\n                    </h4>\n                    <div className=\"grid grid-cols-2 gap-3 text-[11px] font-mono\">\n                      <div className=\"p-3 bg-black/40 border border-white/5 rounded-lg\">\n                        <span className=\"text-white/30 block uppercase text-[8.5px]\">Enclave Host Node</span>\n                        <span className=\"text-white font-bold block mt-1\">{selectedProject.specs.nodeId}</span>\n                      </div>\n                      <div className=\"p-3 bg-black/40 border border-white/5 rounded-lg\">\n                        <span className=\"text-white/30 block uppercase text-[8.5px]\">Dedicated Cores</span>\n                        <span className=\"text-white font-bold block mt-1\">{selectedProject.specs.cores}</span>\n                      </div>\n                      <div className=\"p-3 bg-black/40 border border-white/5 rounded-lg\">\n                        <span className=\"text-white/30 block uppercase text-[8.5px]\">Isolated RAM Bounds</span>\n                        <span className=\"text-white font-bold block mt-1\">{selectedProject.specs.memory}</span>\n                      </div>\n                      <div className=\"p-3 bg-black/40 border border-white/5 rounded-lg\">\n                        <span className=\"text-white/30 block uppercase text-[8.5px]\">Compliance Rating</span>\n                        <span className=\"text-emerald-400 font-bold block mt-1\">{selectedProject.specs.complianceScore}% Secure</span>\n                      </div>\n                    </div>\n                  </div>\n                )}\n\n                {/* 2. Interactive simulated terminal diagnostics */}\n                {!isRequestingUpdate && (\n                  <div className=\"space-y-3\">\n                    <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n                      <h4 className=\"text-[11px] font-bold text-white/40 font-mono uppercase tracking-widest\">\n                        Telemetry Diagnostics Terminal\n                      </h4>\n                      <button\n                        onClick={handleSyncTelemetry}\n                        disabled={isLogSyncing}\n                        className=\"inline-flex h-5 items-center gap-1 px-1.5 rounded border border-[#009DFF]/20 bg-[#009DFF]/5 text-[#009DFF] hover:bg-[#009DFF]/10 text-[8.5px] font-mono uppercase transition-all disabled:opacity-50 cursor-pointer\"\n                      >\n                        <RefreshCw className={`w-2.5 h-2.5 ${isLogSyncing ? \"animate-spin\" : \"\"}`} />\n                        <span>RE-SYNC</span>\n                      </button>\n                    </div>\n\n                    <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303] text-[10px] font-mono text-emerald-400/80 space-y-1.5 h-48 overflow-y-auto shadow-inner relative select-text\">\n                      <div className=\"absolute top-2 right-2 flex items-center gap-1.5 bg-black/40 px-2 py-0.5 rounded border border-white/5 select-none text-[8.5px] text-white/40 font-bold\">\n                        <span className=\"relative flex h-1.5 w-1.5\">\n                          <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n                          <span className=\"relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500\"></span>\n                        </span>\n                        <span>LIVE TELEMETRY STREAM</span>\n                      </div>\n\n                      {logs.map((log, idx) => (\n                        <div key={idx} className=\"leading-relaxed\">\n                          {log}\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n\n                {/* 3. Narrative timeline milestone checks */}\n                {!isRequestingUpdate && (\n                  <div className=\"space-y-4\">\n                    <h4 className=\"text-[11px] font-bold text-white/40 font-mono uppercase tracking-widest border-b border-white/5 pb-2\">\n                      GFF AI Lifecycle Path gates\n                    </h4>\n                    <div className=\"space-y-3 font-mono text-[11px]\">\n                      {LIFECYCLE_PHASES.map((p, index) => {\n                        const isCurrent = selectedProject.phase === p;\n                        const isPast = LIFECYCLE_PHASES.indexOf(selectedProject.phase) > index;\n                        \n                        return (\n                          <div key={p} className=\"flex items-start gap-3 p-2.5 rounded-lg border border-white/5 bg-white/[0.01]\">\n                            <div className={`mt-0.5 h-4 w-4 rounded-full flex items-center justify-center text-[8.5px] font-bold shrink-0 ${\n                              isCurrent \n                                ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF]\" \n                                : isPast \n                                  ? \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\" \n                                  : \"bg-transparent border-white/10 text-white/20\"\n                            }`}>\n                              {isPast ? \"✓\" : index + 1}\n                            </div>\n                            <div className=\"space-y-0.5 flex-grow\">\n                              <div className=\"flex justify-between items-center\">\n                                <span className={`font-bold ${isCurrent ? \"text-[#009DFF]\" : isPast ? \"text-white/70\" : \"text-white/20\"}`}>\n                                  {p.toUpperCase()} PHASE GATE\n                                </span>\n                                <span className={`text-[8.5px] px-1 py-0.2 rounded font-bold uppercase border ${\n                                  isCurrent \n                                    ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" \n                                    : isPast \n                                      ? \"bg-emerald-500/5 text-emerald-400 border-emerald-500/10\" \n                                      : \"bg-transparent text-white/10 border-white/5\"\n                                }`}>\n                                  {isCurrent ? \"ACTIVE OPERATOR\" : isPast ? \"COMPLIANCE OK\" : \"LOCKED\"}\n                                </span>\n                              </div>\n                              <p className={`text-[10px] leading-relaxed ${isCurrent || isPast ? \"text-white/50\" : \"text-white/10\"}`}>\n                                {p === \"Garage\" && \"Enclave sandbox design sign-off, core architecture mapping and secure key generation.\"}\n                                {p === \"Foundry\" && \"Localized parameter calibration, contextual neural fine-tuning and guardrail compliance locks.\"}\n                                {p === \"Factory\" && \"Scaled model packaging, multi-agent network mesh integrations, high-performance optimization.\"}\n                                {p === \"Operate\" && \"Sub-10ms telemetry auditing, continuous guardrail reinforcement, threat-vector defense parsing.\"}\n                              </p>\n                            </div>\n                          </div>\n                        );\n                      })}\n                    </div>\n                  </div>\n                )}\n\n              </div>\n\n              {/* Drawer Footer secure action deck */}\n              <div className=\"p-6 border-t border-white/5 bg-[#060606] flex items-center justify-between gap-3 shrink-0\">\n                <Link\n                  href={`/portal/projects/${selectedProject.id}`}\n                  className=\"flex-1 h-9 inline-flex items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.01] hover:bg-white/[0.04] text-[10.5px] font-mono font-bold text-white/70 hover:text-white uppercase tracking-wider transition-all\"\n                >\n                  <span>Open Sandbox Frame</span>\n                  <ArrowRight className=\"w-3.5 h-3.5\" />\n                </Link>\n\n                <button\n                  onClick={() => triggerUpdateRequest(selectedProject.id)}\n                  disabled={isRequestingUpdate}\n                  className=\"flex-1 h-9 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[10.5px] uppercase tracking-wider flex items-center justify-center gap-1.5 transition-all cursor-pointer hover:shadow-[0_0_15px_rgba(0,157,255,0.2)] disabled:opacity-50\"\n                >\n                  <Send className=\"w-3.5 h-3.5\" />\n                  <span>Request Live Update</span>\n                </button>\n              </div>\n\n            </div>\n          ) : (\n            /* Backup Empty State for global auditer */\n            <div className=\"flex flex-col h-full items-center justify-center p-8 text-center font-mono space-y-4\">\n              <Terminal className=\"w-12 h-12 text-[#009DFF]\" />\n              <div className=\"space-y-1\">\n                <h4 className=\"text-[13px] font-bold text-white uppercase\">GLOBAL COCKPIT AUDIT</h4>\n                <p className=\"text-[10.5px] text-white/50 max-w-sm\">No target project selected. Request global program audit over secure channel.</p>\n              </div>\n\n              <div className=\"w-full max-w-sm border border-white/5 rounded-xl p-4 bg-black/40 space-y-3\">\n                {isRequestingUpdate ? (\n                  <div className=\"space-y-3\">\n                    <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin mx-auto\" />\n                    <div className=\"text-[10px] text-white/70 space-y-1\">\n                      {dispatchLogs.map((logLine, idx) => (\n                        <div key={idx} className=\"text-left text-[#009DFF] opacity-80\">[{idx+1}] {logLine}</div>\n                      ))}\n                    </div>\n                  </div>\n                ) : (\n                  <button\n                    onClick={() => triggerUpdateRequest(\"GLOBAL-COCKPIT\")}\n                    className=\"w-full h-9 rounded bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[10.5px] uppercase tracking-wider transition-all cursor-pointer\"\n                  >\n                    TRIGGER BROADCAST AUDIT\n                  </button>\n                )}\n\n                {dispatchSuccess && (\n                  <div className=\"text-[10px] text-emerald-400 font-bold p-2 bg-emerald-500/5 border border-emerald-500/20 rounded\">\n                    Audit Dispatch Dispatched successfully. ID: GFF-GLOBAL-AUDIT-9922\n                  </div>\n                )}\n              </div>\n\n              <button\n                onClick={closeDrawer}\n                className=\"text-[11px] text-white/40 hover:text-white underline\"\n              >\n                CLOSE COCKPIT PANEL\n              </button>\n            </div>\n          )}\n\n        </div>\n      </div>\n\n      {/* ==========================================\n          7. PREMIUM COMPREHENSIVE SLA ACTION BANNER\n          ========================================== */}\n      <WorkspaceCard className=\"border border-[#009DFF]/30 bg-gradient-to-br from-[#040914] to-[#010307] p-6 rounded-2xl relative overflow-hidden\">\n        <div className=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none\">\n          <ShieldCheck className=\"w-44 h-44 text-[#009DFF]\" />\n        </div>\n        \n        <div className=\"relative z-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6\">\n          <div className=\"space-y-2 max-w-2xl\">\n            <div className=\"flex items-center gap-2 text-[#009DFF]\">\n              <Sparkles className=\"w-4 h-4 animate-pulse\" />\n              <span className=\"text-[10px] font-mono font-bold tracking-widest uppercase\">GFF AI Delivery Assurance</span>\n            </div>\n            \n            <h4 className=\"text-[15px] font-bold text-white font-mono uppercase\">\n              Need to accelerate development or adjust sandbox specifications?\n            </h4>\n            \n            <p className=\"text-[11.5px] text-white/60 leading-relaxed font-mono\">\n              All projects are backed by our enterprise Delivery Service Level Agreement (SLA). Request dedicated compute upgrades, adjust neural parameter scopes, or invoke priority secure support directly.\n            </p>\n          </div>\n\n          <div className=\"shrink-0 flex flex-col sm:flex-row gap-2.5 w-full md:w-auto\">\n            <button\n              onClick={() => {\n                triggerUpdateRequest(\"SLA-UPGRADE\");\n                setIsDrawerOpen(true);\n              }}\n              className=\"inline-flex h-9 px-5 items-center justify-center gap-2 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.02] hover:bg-white/[0.06] text-white font-mono font-bold text-[10.5px] uppercase tracking-wider transition-all cursor-pointer\"\n            >\n              Request Phase Scope Shift\n            </button>\n            <button\n              onClick={() => router.push(\"/portal/support\")}\n              className=\"inline-flex h-9 px-5 items-center justify-center gap-2 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[10.5px] uppercase tracking-wider transition-all cursor-pointer hover:shadow-[0_0_15px_rgba(0,157,255,0.3)]\"\n            >\n              <span>Contact Delivery Lead</span>\n              <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        </div>\n      </WorkspaceCard>\n\n    </div>\n  );\n}\n"}}}
