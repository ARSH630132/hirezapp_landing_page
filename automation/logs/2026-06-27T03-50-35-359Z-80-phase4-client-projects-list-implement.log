{"ts":"2026-06-27T03:46:24.382Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7391u756","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/projects/page.tsx","old_text":"      {/* Placeholder for Card List and Drawer */}\n      <div id=\"deck-list-placeholder\" className=\"border border-white/5 bg-black/20 p-6 rounded-xl text-center text-white/50 font-mono text-[11px]\">\n        Loading Project Registry Cards and table rows...\n      </div>","new_text":"      {/* 5. MAIN CONTENT SPACE (GRID / TABLE) */}\n      {filteredProjects.length === 0 ? (\n        <EmptyState\n          title=\"No Sandbox Program Records Match\"\n          description=\"We couldn't find any secure sandboxes matching your current search parameters. Clear filters to restore telemetry.\"\n          actionLabel=\"RESET ALL FILTERS\"\n          onAction={() => {\n            setSearchQuery(\"\");\n            setSelectedPhase(\"\");\n            setSelectedHealth(\"\");\n          }}\n          icon={FolderOpen}\n        />\n      ) : viewMode === \"grid\" ? (\n        /* PREMIUM CARDS GRID (Default View) */\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filteredProjects.map((project) => (\n            <WorkspaceCard \n              key={project.id} \n              className=\"flex flex-col h-full border border-white/5 bg-[#050505]/40 hover:border-white/10 transition-all rounded-2xl p-6 relative overflow-hidden\"\n              spotlightColor={\n                project.healthStatus === \"On Track\" \n                  ? \"rgba(16,185,129,0.03)\" \n                  : project.healthStatus === \"Warning\" \n                    ? \"rgba(251,191,36,0.03)\" \n                    : \"rgba(228,0,15,0.03)\"\n              }\n            >\n              {/* Top Meta Line: ID, Health, Phase */}\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n                <div className=\"flex items-center gap-2\">\n                  <span className=\"text-[12px] font-mono font-bold text-[#009DFF]\">\n                    {project.id}\n                  </span>\n                  <span className=\"text-[9px] text-white/20 font-mono\">•</span>\n                  <span className=\"text-[10px] font-mono font-bold text-white/40 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded uppercase\">\n                    {project.env}\n                  </span>\n                </div>\n\n                <StatusBadge \n                  state={\n                    project.healthStatus === \"On Track\" \n                      ? \"stable\" \n                      : project.healthStatus === \"Warning\" \n                        ? \"warning\" \n                        : \"error\"\n                  } \n                  label={project.healthStatus} \n                />\n              </div>\n\n              {/* Title & Core Platform Description */}\n              <div className=\"mt-4 flex-grow space-y-2\">\n                <h3 className=\"text-[14px] font-bold text-white font-mono tracking-tight uppercase group-hover:text-[#009DFF] transition-colors\">\n                  {project.name}\n                </h3>\n                <p className=\"text-[11.5px] text-white/50 leading-relaxed font-mono font-light min-h-[50px]\">\n                  {project.description}\n                </p>\n              </div>\n\n              {/* Delivery Lead Block */}\n              <div className=\"mt-4 flex items-center gap-3 p-2.5 rounded-xl bg-white/[0.01] border border-white/5\">\n                <div className=\"h-7 w-7 rounded-lg bg-[#009DFF]/10 border border-[#009DFF]/20 flex items-center justify-center text-[10px] font-bold text-[#009DFF] font-mono select-none\">\n                  {project.owner.avatarInitials}\n                </div>\n                <div>\n                  <div className=\"text-[10px] font-mono text-white/30 uppercase tracking-widest leading-none\">Delivery Lead</div>\n                  <div className=\"text-[11px] font-mono font-bold text-white/80 mt-1\">{project.owner.name}</div>\n                </div>\n              </div>\n\n              {/* Premium Multi-Stage Stepper Component */}\n              <div className=\"mt-5 space-y-2.5 p-3 rounded-xl bg-white/[0.01] border border-white/5\">\n                <span className=\"text-[9px] font-mono tracking-widest text-white/30 uppercase block font-bold\">Lifecycle Stage</span>\n                <div className=\"relative flex items-center justify-between px-1\">\n                  {/* Connecting dashed line */}\n                  <div className=\"absolute left-4 right-4 top-1/2 -translate-y-1/2 h-0.5 border-t border-dashed border-white/10 z-0\" />\n                  \n                  {LIFECYCLE_PHASES.map((p, index) => {\n                    const isCurrent = project.phase === p;\n                    const isPast = LIFECYCLE_PHASES.indexOf(project.phase) > index;\n                    \n                    return (\n                      <div key={p} className=\"flex flex-col items-center relative z-10\">\n                        <div className={`h-4.5 w-4.5 rounded-full flex items-center justify-center border text-[8px] font-bold transition-all ${\n                          isCurrent \n                            ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF] shadow-[0_0_10px_rgba(0,157,255,0.4)]\" \n                            : isPast \n                              ? \"bg-emerald-500/10 border-emerald-500/40 text-emerald-400\" \n                              : \"bg-[#050505] border-white/5 text-white/20\"\n                        }`}>\n                          {isPast ? \"✓\" : index + 1}\n                        </div>\n                        <span className={`text-[8.5px] font-mono mt-1 ${\n                          isCurrent \n                            ? \"text-white font-bold\" \n                            : isPast \n                              ? \"text-white/50\" \n                              : \"text-white/20\"\n                        }`}>\n                          {p}\n                        </span>\n                      </div>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Progress Slider (Non-interactive) */}\n              <div className=\"mt-4 space-y-1\">\n                <div className=\"flex justify-between items-center text-[10px] font-mono\">\n                  <span className=\"text-white/30 uppercase\">Deployment Progress</span>\n                  <span className=\"text-white/80 font-bold\">{project.progress}%</span>\n                </div>\n                <div className=\"h-1 w-full bg-white/5 rounded-full overflow-hidden\">\n                  <div \n                    className={`h-full rounded-full transition-all duration-500 ${\n                      project.healthStatus === \"On Track\" \n                        ? \"bg-[#009DFF]\" \n                        : project.healthStatus === \"Warning\" \n                          ? \"bg-amber-400\" \n                          : \"bg-red-500\"\n                    }`}\n                    style={{ width: `${project.progress}%` }}\n                  />\n                </div>\n              </div>\n\n              {/* Next Milestone target */}\n              <div className=\"mt-5 pt-4 border-t border-white/5 flex items-start gap-2.5 text-[10.5px] font-mono text-white/45\">\n                <Calendar className=\"w-3.5 h-3.5 text-white/30 mt-0.5 shrink-0\" />\n                <div className=\"space-y-0.5\">\n                  <span className=\"text-white/20 uppercase text-[8.5px] block font-bold\">NEXT TARGET GATE</span>\n                  <span className=\"text-white/80 font-medium block leading-tight\">{project.nextMilestone}</span>\n                  <span className=\"text-white/40 text-[9px] block\">Target: {project.timeline}</span>\n                </div>\n              </div>\n\n              {/* Card CTA actions */}\n              <div className=\"mt-6 pt-4 border-t border-white/5 grid grid-cols-2 gap-2\">\n                <button\n                  onClick={() => triggerUpdateRequest(project.id)}\n                  className=\"h-8 rounded border border-white/5 hover:border-white/10 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] font-mono font-bold text-white/50 hover:text-white uppercase tracking-wider transition-all cursor-pointer\"\n                >\n                  Request Update\n                </button>\n                <button\n                  onClick={() => handleOpenProjectDetails(project)}\n                  className=\"h-8 rounded bg-[#009DFF]/10 hover:bg-[#009DFF]/20 border border-[#009DFF]/20 text-[9.5px] font-mono font-bold text-[#009DFF] hover:text-white uppercase tracking-wider flex items-center justify-center gap-1 transition-all cursor-pointer\"\n                >\n                  <span>Inspect Spec</span>\n                  <ArrowUpRight className=\"w-3 h-3\" />\n                </button>\n              </div>\n            </WorkspaceCard>\n          ))}\n        </div>\n      ) : (\n        /* ENTERPRISE LIST TABLE VIEW */\n        <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm overflow-hidden\">\n          <div className=\"bg-white/[0.02] border-b border-white/5 px-5 py-3.5 text-[10.5px] font-mono text-white/45 uppercase font-bold tracking-wider\">\n            Sovereign Project Registry Telemetry\n          </div>\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full min-w-[900px] text-left font-mono text-[11.5px] text-white/70\">\n              <thead>\n                <tr className=\"border-b border-white/5 text-white/30 text-[9px] uppercase tracking-wider\">\n                  <th className=\"p-4 pl-6\">ID</th>\n                  <th className=\"p-4\">Program / Project</th>\n                  <th className=\"p-4\">Lifecycle Phase</th>\n                  <th className=\"p-4\">Delivery Lead</th>\n                  <th className=\"p-4\">Next Target Milestone</th>\n                  <th className=\"p-4 text-center\">Progress</th>\n                  <th className=\"p-4\">Health</th>\n                  <th className=\"p-4 pr-6 text-right\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/5\">\n                {filteredProjects.map((project) => (\n                  <tr key={project.id} className=\"hover:bg-white/[0.01] transition-colors group\">\n                    <td className=\"p-4 pl-6 text-[#009DFF] font-bold\">{project.id}</td>\n                    <td className=\"p-4\">\n                      <div className=\"font-semibold text-white uppercase text-[12px]\">{project.name}</div>\n                      <div className=\"text-[10px] text-white/35 mt-0.5\">{project.env}</div>\n                    </td>\n                    <td className=\"p-4\">\n                      <span className=\"px-2 py-0.5 text-[9.5px] font-bold bg-[#009DFF]/10 text-[#009DFF] rounded border border-[#009DFF]/20 uppercase tracking-wide\">\n                        {project.phase}\n                      </span>\n                    </td>\n                    <td className=\"p-4\">\n                      <div className=\"text-white/80 font-medium\">{project.owner.name}</div>\n                      <div className=\"text-[9px] text-white/30\">{project.owner.role}</div>\n                    </td>\n                    <td className=\"p-4\">\n                      <div className=\"text-white/70 font-medium max-w-[200px] truncate\">{project.nextMilestone}</div>\n                      <div className=\"text-[9px] text-white/30\">Target: {project.timeline}</div>\n                    </td>\n                    <td className=\"p-4 text-center\">\n                      <div className=\"flex items-center justify-center gap-2\">\n                        <span className=\"font-bold text-white\">{project.progress}%</span>\n                        <div className=\"w-16 h-1 bg-white/5 rounded-full overflow-hidden shrink-0 hidden sm:block\">\n                          <div className=\"h-full bg-gradient-to-r from-[#009DFF] to-emerald-400\" style={{ width: `${project.progress}%` }} />\n                        </div>\n                      </div>\n                    </td>\n                    <td className=\"p-4\">\n                      <StatusBadge \n                        state={\n                          project.healthStatus === \"On Track\" \n                            ? \"stable\" \n                            : project.healthStatus === \"Warning\" \n                              ? \"warning\" \n                              : \"error\"\n                        } \n                        label={project.healthStatus} \n                      />\n                    </td>\n                    <td className=\"p-4 pr-6 text-right space-x-2\">\n                      <button\n                        onClick={() => triggerUpdateRequest(project.id)}\n                        className=\"inline-flex h-7 items-center justify-center px-2 text-[9px] font-bold text-white/40 hover:text-white bg-white/5 hover:bg-white/10 border border-white/5 rounded transition-all cursor-pointer uppercase\"\n                      >\n                        Update\n                      </button>\n                      <button\n                        onClick={() => handleOpenProjectDetails(project)}\n                        className=\"inline-flex h-7 items-center justify-center px-2.5 gap-1 text-[9px] font-bold text-[#009DFF] hover:text-white bg-[#009DFF]/5 hover:bg-[#009DFF]/20 border border-[#009DFF]/20 rounded transition-all cursor-pointer uppercase\"\n                      >\n                        <span>Inspect</span>\n                        <ArrowRight className=\"w-2.5 h-2.5\" />\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* 6. SLIDE-OVER TELEMETRY & SPECS DRAWER PLACEHOLDER */}\n      <div id=\"drawer-placeholder\" />\n\n      {/* 7. PREMIUM COMPREHENSIVE SLA ACTION BANNER */}\n      <WorkspaceCard className=\"border border-[#009DFF]/30 bg-gradient-to-br from-[#040914] to-[#010307] p-6 rounded-2xl relative overflow-hidden\">\n        <div className=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none\">\n          <ShieldCheck className=\"w-44 h-44 text-[#009DFF]\" />\n        </div>\n        \n        <div className=\"relative z-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-6\">\n          <div className=\"space-y-2 max-w-2xl\">\n            <div className=\"flex items-center gap-2 text-[#009DFF]\">\n              <Sparkles className=\"w-4 h-4 animate-pulse\" />\n              <span className=\"text-[10px] font-mono font-bold tracking-widest uppercase\">GFF AI Delivery Assurance</span>\n            </div>\n            \n            <h4 className=\"text-[15px] font-bold text-white font-mono uppercase\">\n              Need to accelerate development or adjust sandbox specifications?\n            </h4>\n            \n            <p className=\"text-[11.5px] text-white/60 leading-relaxed font-mono\">\n              All projects are backed by our enterprise Delivery Service Level Agreement (SLA). Request dedicated compute upgrades, adjust neural parameter scopes, or invoke priority secure support directly.\n            </p>\n          </div>\n\n          <div className=\"shrink-0 flex flex-col sm:flex-row gap-2.5 w-full md:w-auto\">\n            <button\n              onClick={() => {\n                triggerUpdateRequest(\"SLA-UPGRADE\");\n                setIsDrawerOpen(true);\n              }}\n              className=\"inline-flex h-9 px-5 items-center justify-center gap-2 rounded-lg border border-white/10 hover:border-white/20 bg-white/[0.02] hover:bg-white/[0.06] text-white font-mono font-bold text-[10.5px] uppercase tracking-wider transition-all cursor-pointer\"\n            >\n              Request Phase Scope Shift\n            </button>\n            <button\n              onClick={() => router.push(\"/portal/support\")}\n              className=\"inline-flex h-9 px-5 items-center justify-center gap-2 rounded-lg bg-[#009DFF] hover:bg-[#009DFF]/90 text-white font-mono font-bold text-[10.5px] uppercase tracking-wider transition-all cursor-pointer hover:shadow-[0_0_15px_rgba(0,157,255,0.3)]\"\n            >\n              <span>Contact Delivery Lead</span>\n              <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        </div>\n      </WorkspaceCard>"}}}
