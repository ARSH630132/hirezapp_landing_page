{"ts":"2026-06-27T03:47:43.698Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"tqhbwzzj","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/projects/page.tsx","old_text":"        /* TABLE VIEW */\n        <div id=\"table-view-section\" />\n      )}\n\n      <div id=\"sla-drawer-placeholder\" />","new_text":"        /* TABLE VIEW */\n        <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm overflow-hidden\">\n          <div className=\"overflow-x-auto\">\n            <table className=\"w-full min-w-[800px] text-left font-mono text-[11.5px] text-white/70\">\n              <thead>\n                <tr className=\"border-b border-white/5 text-white/30 text-[9px] uppercase\">\n                  <th className=\"p-3 pl-5\">ID</th>\n                  <th className=\"p-3\">Program / Project</th>\n                  <th className=\"p-3\">Phase</th>\n                  <th className=\"p-3\">Delivery Lead</th>\n                  <th className=\"p-3 text-center\">Progress</th>\n                  <th className=\"p-3\">Health</th>\n                  <th className=\"p-3 text-right pr-5\">Actions</th>\n                </tr>\n              </thead>\n              <tbody className=\"divide-y divide-white/5\">\n                {filteredProjects.map((p) => (\n                  <tr key={p.id} className=\"hover:bg-white/[0.01]\">\n                    <td className=\"p-3 pl-5 text-[#009DFF] font-bold\">{p.id}</td>\n                    <td className=\"p-3\">\n                      <div className=\"font-semibold text-white uppercase text-[11px]\">{p.name}</div>\n                      <div className=\"text-[9px] text-white/30\">{p.env}</div>\n                    </td>\n                    <td className=\"p-3\">\n                      <span className=\"px-1.5 py-0.2 text-[8.5px] font-bold bg-[#009DFF]/10 text-[#009DFF] rounded border border-[#009DFF]/20 uppercase\">\n                        {p.phase}\n                      </span>\n                    </td>\n                    <td className=\"p-3\">\n                      <div className=\"text-white/80 font-bold text-[10px]\">{p.owner.name}</div>\n                    </td>\n                    <td className=\"p-3 text-center font-bold text-white\">{p.progress}%</td>\n                    <td className=\"p-3\">\n                      <StatusBadge state={p.healthStatus === \"On Track\" ? \"stable\" : p.healthStatus === \"Warning\" ? \"warning\" : \"error\"} label={p.healthStatus} />\n                    </td>\n                    <td className=\"p-3 text-right pr-5 space-x-1.5\">\n                      <button onClick={() => triggerUpdateRequest(p.id)} className=\"h-6 px-2 text-[9px] font-bold text-white/40 hover:text-white bg-white/5 border border-white/5 rounded cursor-pointer\">Update</button>\n                      <button onClick={() => handleOpenProjectDetails(p)} className=\"h-6 px-2 text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/10 rounded cursor-pointer\">Inspect</button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        </div>\n      )}\n\n      {/* 6. SLIDE-OVER TELEMETRY & SPECS DRAWER */}\n      <div className={`fixed inset-0 z-50 overflow-hidden transition-all duration-300 ${isDrawerOpen ? \"visible\" : \"invisible pointer-events-none\"}`}>\n        <div onClick={closeDrawer} className={`absolute inset-0 bg-black/80 backdrop-blur-md transition-opacity duration-300 ${isDrawerOpen ? \"opacity-100\" : \"opacity-0\"}`} />\n        <div className={`absolute top-0 right-0 h-full w-full max-w-xl bg-gradient-to-b from-[#0a0a0a] to-[#040404] border-l border-white/10 shadow-2xl flex flex-col transition-transform duration-300 ease-out transform ${isDrawerOpen ? \"translate-x-0\" : \"translate-x-full\"}`}>\n          {selectedProject ? (\n            <div className=\"flex flex-col h-full overflow-y-auto\">\n              <div className=\"p-5 border-b border-white/5 flex items-start justify-between bg-white/[0.01]\">\n                <div>\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1.5 py-0.5 rounded uppercase\">SECURE SANDBOX</span>\n                    <span className=\"text-[9px] font-mono font-bold text-white/50 bg-white/5 border border-white/10 px-1.5 py-0.5 rounded uppercase\">{selectedProject.id}</span>\n                  </div>\n                  <h3 className=\"text-sm font-bold text-white font-mono uppercase mt-2\">{selectedProject.name}</h3>\n                </div>\n                <button onClick={closeDrawer} className=\"p-1 rounded-lg border border-white/5 text-white/40 hover:text-white hover:bg-white/5 cursor-pointer\"><X className=\"w-3.5 h-3.5\" /></button>\n              </div>\n\n              <div className=\"p-5 flex-grow space-y-5\">\n                {isRequestingUpdate && (\n                  <div className=\"p-4 rounded-lg border border-[#009DFF]/20 bg-[#009DFF]/5 space-y-3 font-mono text-[10.5px]\">\n                    <div className=\"flex items-center gap-2\"><RefreshCw className=\"w-4 h-4 text-[#009DFF] animate-spin\" /><div><span className=\"text-white font-bold block uppercase\">Handshake Dispatch active</span></div></div>\n                    <div className=\"p-2.5 bg-black/40 rounded border border-white/5 text-[9.5px] text-[#009DFF]/80 space-y-1\">{dispatchLogs.map((logLine, idx) => ( <div key={idx} className=\"flex gap-1.5\"><span className=\"text-white/20\">[{idx+1}]</span><span>{logLine}</span></div> ))}</div>\n                    {dispatchSuccess && ( <div className=\"p-2.5 bg-emerald-500/10 border border-emerald-500/20 rounded text-emerald-400 space-y-1\"><div className=\"font-bold uppercase text-[10px]\">Dispatch complete</div><p className=\"text-[9.5px] text-white/60\">A secure delivery trigger has been queued with Delivery Leads. ETA &lt; 15 mins.</p></div> )}\n                  </div>\n                )}\n\n                <div className=\"space-y-3\">\n                  <h4 className=\"text-[10px] font-bold text-white/40 font-mono uppercase tracking-widest border-b border-white/5 pb-1\">Enclave Parameters</h4>\n                  <div className=\"grid grid-cols-2 gap-2 text-[10.5px] font-mono\">\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Host Node</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.nodeId}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Cores Threads</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.cores}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Memory Limit</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.memory}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Compliance</span><span className=\"text-emerald-400 font-bold block mt-0.5\">{selectedProject.specs.complianceScore}% Secure</span></div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <div className=\"flex justify-between items-center border-b border-white/5 pb-1\"><h4 className=\"text-[10px] font-bold text-white/40 font-mono uppercase tracking-widest\">Diagnostics Stream</h4><button onClick={handleSyncTelemetry} disabled={isLogSyncing} className=\"h-5 px-1.5 rounded border border-[#009DFF]/20 bg-[#009DFF]/5 text-[#009DFF] hover:bg-[#009DFF]/10 text-[8px] font-mono uppercase flex items-center gap-1 disabled:opacity-50 cursor-pointer\"><RefreshCw className={`w-2 h-2 ${isLogSyncing ? \"animate-spin\" : \"\"}`} />RE-SYNC</button></div>\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-[#030303] text-[9.5px] font-mono text-emerald-400/80 space-y-1 h-36 overflow-y-auto relative select-text\">\n                    <div className=\"absolute top-1.5 right-1.5 flex items-center gap-1 bg-black/40 px-1.5 py-0.2 rounded text-[7.5px] text-white/40 font-bold select-none\"><span className=\"relative flex h-1 w-1\"><span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span><span className=\"relative inline-flex rounded-full h-1 w-1 bg-emerald-500\"></span></span>LIVE</div>\n                    {logs.map((log, idx) => ( <div key={idx}>{log}</div> ))}\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <h4 className=\"text-[10px] font-bold text-white/40 font-mono uppercase tracking-widest border-b border-white/5 pb-1\">Lifecycle Gates</h4>\n                  <div className=\"space-y-2 font-mono text-[10px]\">\n                    {LIFECYCLE_PHASES.map((p, idx) => {\n                      const isCurrent = selectedProject.phase === p;\n                      const isPast = LIFECYCLE_PHASES.indexOf(selectedProject.phase) > idx;\n                      return (\n                        <div key={p} className=\"flex items-start gap-2 p-2 rounded border border-white/5 bg-white/[0.01]\">\n                          <div className={`h-3.5 w-3.5 rounded-full flex items-center justify-center text-[7.5px] font-bold shrink-0 ${isCurrent ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF]\" : isPast ? \"bg-emerald-500/10 border-emerald-500/30 text-emerald-400\" : \"bg-transparent border-white/10 text-white/20\"}`}>{isPast ? \"✓\" : idx+1}</div>\n                          <div className=\"flex-grow flex justify-between items-center\"><span className={`font-bold uppercase ${isCurrent ? \"text-[#009DFF]\" : isPast ? \"text-white/70\" : \"text-white/20\"}`}>{p} Phase Gate</span><span className={`text-[7.5px] px-1 py-0.2 rounded font-bold uppercase border ${isCurrent ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" : isPast ? \"bg-emerald-500/5 text-emerald-400 border-emerald-500/10\" : \"bg-transparent text-white/10 border-white/5\"}`}>{isCurrent ? \"ACTIVE\" : isPast ? \"COMPLIANT\" : \"LOCKED\"}</span></div>\n                        </div>\n                      );\n                    })}\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"p-4 border-t border-white/5 bg-[#060606] flex gap-3 shrink-0\">\n                <Link href={`/portal/projects/${selectedProject.id}`} className=\"flex-1 h-8.5 inline-flex items-center justify-center gap-1 rounded-lg border border-white/10 text-white font-mono font-bold text-[10px] uppercase hover:bg-white/5\"><span>Open Sandbox</span><ArrowRight className=\"w-3.5 h-3.5\" /></Link>\n                <button onClick={() => triggerUpdateRequest(selectedProject.id)} disabled={isRequestingUpdate} className=\"flex-1 h-8.5 rounded-lg bg-[#009DFF] text-white font-mono font-bold text-[10px] uppercase flex items-center justify-center gap-1.5 transition-all cursor-pointer hover:shadow-[0_0_15px_rgba(0,157,255,0.2)] disabled:opacity-50\"><Send className=\"w-3.5 h-3.5\" />Request Update</button>\n              </div>\n            </div>\n          ) : (\n            <div className=\"flex flex-col h-full items-center justify-center p-6 text-center font-mono space-y-3\">\n              <Terminal className=\"w-10 h-10 text-[#009DFF]\" />\n              <div className=\"space-y-1\"><h4 className=\"text-[12px] font-bold text-white uppercase\">GLOBAL AUDIT</h4><p className=\"text-[10px] text-white/50 max-w-sm\">No project selected. Run a global audit over secure wire.</p></div>\n              {isRequestingUpdate ? (\n                <div className=\"space-y-2 text-[#009DFF] text-[9.5px]\">{dispatchLogs.map((log, idx) => ( <div key={idx}>[{idx+1}] {log}</div> ))}</div>\n              ) : (\n                <button onClick={() => triggerUpdateRequest(\"GLOBAL\")} className=\"h-8 px-4 rounded bg-[#009DFF] text-white text-[10px] font-bold uppercase cursor-pointer\">Run Global Audit</button>\n              )}\n              {dispatchSuccess && <div className=\"text-[9px] text-emerald-400 uppercase font-bold\">Audit Dispatch Signed.</div>}\n              <button onClick={closeDrawer} className=\"text-[10px] text-white/40 hover:text-white underline cursor-pointer\">CLOSE</button>\n            </div>\n          )}\n        </div>\n      </div>\n\n      {/* 7. PREMIUM COMPREHENSIVE SLA ACTION BANNER */}\n      <WorkspaceCard className=\"border border-[#009DFF]/20 bg-gradient-to-br from-[#040914] to-[#010307] p-5 rounded-2xl relative overflow-hidden mt-6\">\n        <div className=\"absolute top-0 right-0 p-4 opacity-5 pointer-events-none\"><ShieldCheck className=\"w-40 h-40 text-[#009DFF]\" /></div>\n        <div className=\"relative z-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4\">\n          <div className=\"space-y-1 max-w-2xl\">\n            <div className=\"flex items-center gap-1.5 text-[#009DFF]\"><Sparkles className=\"w-3.5 h-3.5 animate-pulse\" /><span className=\"text-[9px] font-mono font-bold tracking-widest uppercase\">GFF AI Delivery Assurance</span></div>\n            <h4 className=\"text-[13.5px] font-bold text-white font-mono uppercase\">Need to accelerate development or adjust sandbox specifications?</h4>\n            <p className=\"text-[11px] text-white/60 font-mono\">All enclaves are backed by our enterprise Delivery Service Level Agreement (SLA). Request compute upgrades or invoke support over our secure wire.</p>\n          </div>\n          <div className=\"shrink-0 flex gap-2 w-full md:w-auto\">\n            <button onClick={() => { triggerUpdateRequest(\"SLA-UPGRADE\"); setIsDrawerOpen(true); }} className=\"h-8.5 px-4 rounded-lg border border-white/10 hover:bg-white/5 text-white font-mono font-bold text-[10px] uppercase cursor-pointer\">Request Scope Shift</button>\n            <button onClick={() => router.push(\"/portal/support\")} className=\"h-8.5 px-4 rounded-lg bg-[#009DFF] text-white font-mono font-bold text-[10px] uppercase cursor-pointer\">Contact Delivery Lead</button>\n          </div>\n        </div>\n      </WorkspaceCard>"}}}
