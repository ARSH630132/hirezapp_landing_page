{"ts":"2026-06-27T03:48:50.780Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"c7i82nr8","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/projects/page.tsx","old_text":"      <div id=\"sla-drawer-placeholder\" />","new_text":"      {/* 6. SLIDE-OVER TELEMETRY & SPECS DRAWER */}\n      <div className={`fixed inset-0 z-50 overflow-hidden transition-all duration-300 ${isDrawerOpen ? \"visible\" : \"invisible pointer-events-none\"}`}>\n        <div onClick={closeDrawer} className={`absolute inset-0 bg-black/80 backdrop-blur-md transition-opacity duration-300 ${isDrawerOpen ? \"opacity-100\" : \"opacity-0\"}`} />\n        <div className={`absolute top-0 right-0 h-full w-full max-w-xl bg-gradient-to-b from-[#0a0a0a] to-[#040404] border-l border-white/10 shadow-2xl flex flex-col transition-transform duration-300 ease-out transform ${isDrawerOpen ? \"translate-x-0\" : \"translate-x-full\"}`}>\n          {selectedProject ? (\n            <div className=\"flex flex-col h-full overflow-y-auto\">\n              <div className=\"p-4 border-b border-white/5 flex items-start justify-between bg-white/[0.01]\">\n                <div>\n                  <div className=\"flex items-center gap-1.5 text-[9px] font-mono font-bold text-[#009DFF]\">\n                    <span className=\"bg-[#009DFF]/5 border border-[#009DFF]/20 px-1 py-0.2 rounded\">SECURE SANDBOX</span>\n                    <span className=\"bg-white/5 border border-white/10 px-1 py-0.2 rounded text-white/50\">{selectedProject.id}</span>\n                  </div>\n                  <h3 className=\"text-sm font-bold text-white font-mono uppercase mt-1.5\">{selectedProject.name}</h3>\n                </div>\n                <button onClick={closeDrawer} className=\"p-1 rounded text-white/40 hover:text-white cursor-pointer\"><X className=\"w-4 h-4\" /></button>\n              </div>\n\n              <div className=\"p-4 flex-grow space-y-4\">\n                {isRequestingUpdate && (\n                  <div className=\"p-3 rounded border border-[#009DFF]/20 bg-[#009DFF]/5 space-y-2 font-mono text-[10px]\">\n                    <div className=\"flex items-center gap-2\"><RefreshCw className=\"w-3.5 h-3.5 text-[#009DFF] animate-spin\" /><span className=\"text-white font-bold uppercase\">Dispatch Active</span></div>\n                    <div className=\"p-2 bg-black/40 rounded border border-white/5 text-[9px] text-[#009DFF]/80 space-y-1\">{dispatchLogs.map((l, i) => ( <div key={i}>[{i+1}] {l}</div> ))}</div>\n                    {dispatchSuccess && ( <div className=\"p-2 bg-emerald-500/10 border border-emerald-500/20 rounded text-emerald-400 font-bold\">Dispatch complete. ETA &lt; 15 mins.</div> )}\n                  </div>\n                )}\n\n                <div className=\"space-y-2\">\n                  <h4 className=\"text-[9px] font-bold text-white/40 font-mono uppercase border-b border-white/5 pb-0.5\">Parameters</h4>\n                  <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono\">\n                    <div className=\"p-2 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 text-[8px] block uppercase\">Host Node</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.nodeId}</span></div>\n                    <div className=\"p-2 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 text-[8px] block uppercase\">Cores</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.cores}</span></div>\n                    <div className=\"p-2 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 text-[8px] block uppercase\">Memory Limit</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.memory}</span></div>\n                    <div className=\"p-2 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 text-[8px] block uppercase\">Compliance</span><span className=\"text-emerald-400 font-bold block mt-0.5\">{selectedProject.specs.complianceScore}% Safe</span></div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <div className=\"flex justify-between items-center border-b border-white/5 pb-0.5\"><h4 className=\"text-[9px] font-bold text-white/40 font-mono uppercase\">Diagnostics Stream</h4><button onClick={handleSyncTelemetry} disabled={isLogSyncing} className=\"h-4.5 px-1.5 rounded border border-[#009DFF]/20 bg-[#009DFF]/5 text-[#009DFF] text-[8px] font-mono flex items-center gap-1 cursor-pointer\"><RefreshCw className={`w-2.5 h-2.5 ${isLogSyncing ? \"animate-spin\" : \"\"}`} />RE-SYNC</button></div>\n                  <div className=\"p-2.5 rounded border border-white/5 bg-[#030303] text-[9px] font-mono text-emerald-400/80 space-y-1 h-32 overflow-y-auto relative select-text\">\n                    <div className=\"absolute top-1 right-1 flex items-center gap-1 bg-black/40 px-1 rounded text-[7px] text-white/40 font-bold select-none\"><span className=\"relative flex h-1 w-1\"><span className=\"animate-ping absolute inline-flex h-full w-full bg-emerald-400 rounded-full opacity-75\"></span><span className=\"relative inline-flex rounded-full h-1 w-1 bg-emerald-500\"></span></span>LIVE</div>\n                    {logs.map((log, idx) => ( <div key={idx}>{log}</div> ))}\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <h4 className=\"text-[9px] font-bold text-white/40 font-mono uppercase border-b border-white/5 pb-0.5\">Lifecycle Gates</h4>\n                  <div className=\"space-y-1.5 font-mono text-[9.5px]\">\n                    {LIFECYCLE_PHASES.map((p, idx) => {\n                      const isCurrent = selectedProject.phase === p;\n                      const isPast = LIFECYCLE_PHASES.indexOf(selectedProject.phase) > idx;\n                      return (\n                        <div key={p} className=\"flex items-center justify-between p-1.5 rounded border border-white/5 bg-white/[0.01]\">\n                          <div className=\"flex items-center gap-2\"><div className={`h-3 w-3 rounded-full flex items-center justify-center text-[7px] font-bold ${isCurrent ? \"bg-[#009DFF]/20 border-[#009DFF] text-[#009DFF]\" : isPast ? \"bg-emerald-500/10 text-emerald-400\" : \"text-white/20\"}`}>{isPast ? \"✓\" : idx+1}</div><span className={`font-bold ${isCurrent ? \"text-[#009DFF]\" : isPast ? \"text-white/70\" : \"text-white/20\"}`}>{p} Phase Gate</span></div>\n                          <span className={`text-[7.5px] px-1 py-0.2 rounded font-bold border ${isCurrent ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" : isPast ? \"bg-emerald-500/5 text-emerald-400\" : \"text-white/10\"}`}>{isCurrent ? \"ACTIVE\" : isPast ? \"COMPLIANT\" : \"LOCKED\"}</span>\n                        </div>\n                      );\n                    })}\n                  </div>\n                </div>\n              </div>\n\n              <div className=\"p-4 border-t border-white/5 bg-[#060606] flex gap-3 shrink-0\">\n                <Link href={`/portal/projects/${selectedProject.id}`} className=\"flex-1 h-8 inline-flex items-center justify-center gap-1 rounded border border-white/10 text-white font-mono font-bold text-[10px] uppercase hover:bg-white/5\"><span>Open Sandbox</span><ArrowRight className=\"w-3 h-3\" /></Link>\n                <button onClick={() => triggerUpdateRequest(selectedProject.id)} disabled={isRequestingUpdate} className=\"flex-1 h-8 rounded bg-[#009DFF] text-white font-mono font-bold text-[10px] uppercase flex items-center justify-center gap-1.5 transition-all cursor-pointer hover:shadow-[0_0_15px_rgba(0,157,255,0.2)] disabled:opacity-50\"><Send className=\"w-3.5 h-3.5\" />Request Update</button>\n              </div>\n            </div>\n          ) : (\n            <div className=\"flex flex-col h-full items-center justify-center p-6 text-center font-mono space-y-3\">\n              <Terminal className=\"w-8 h-8 text-[#009DFF]\" />\n              <div className=\"space-y-1\"><h4 className=\"text-[11px] font-bold text-white uppercase font-sans\">GLOBAL AUDIT</h4><p className=\"text-[9.5px] text-white/50 max-w-sm\">Run global program audit.</p></div>\n              {isRequestingUpdate ? (\n                <div className=\"space-y-1 text-[#009DFF] text-[9px]\">{dispatchLogs.map((l, idx) => ( <div key={idx}>[{idx+1}] {l}</div> ))}</div>\n              ) : (\n                <button onClick={() => triggerUpdateRequest(\"GLOBAL\")} className=\"h-8 px-3 rounded bg-[#009DFF] text-white text-[10px] font-bold uppercase cursor-pointer\">Run Global Audit</button>\n              )}\n              {dispatchSuccess && <div className=\"text-[9px] text-emerald-400 uppercase font-bold\">Audit Dispatched.</div>}\n              <button onClick={closeDrawer} className=\"text-[10px] text-white/40 hover:text-white underline cursor-pointer\">CLOSE</button>\n            </div>\n          )}\n        </div>\n      </div>\n\n      <div id=\"sla-banner-placeholder\" />"}}}
