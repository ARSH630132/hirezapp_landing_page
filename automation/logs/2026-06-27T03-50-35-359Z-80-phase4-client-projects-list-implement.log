{`h-9 px-3 text-[11px] font-mono font-bold uppercase transition-all ${\n                viewMode === \"table\" \n                  ? \"bg-white/5 text-white\" \n                  : \"bg-transparent text-white/40 hover:text-white/60\"\n              }`}\n            >\n              TABLE\n            </button>\n          </div>\n\n          {/* Reset Filters Option */}\n          {(searchQuery || selectedPhase || selectedHealth) && (\n            <button\n              onClick={() => {\n                setSearchQuery(\"\");\n                setSelectedPhase(\"\");\n                setSelectedHealth(\"\");\n              }}\n              className=\"text-[10px] font-mono text-red-400 hover:text-red-300 uppercase tracking-wider underline cursor-pointer\"\n            >\n              Clear Filters\n            </button>\n          )}\n        </div>\n      </WorkspaceCard>\n\n      {/* Placeholder for Card List and Drawer */}\n      <div id=\"deck-list-placeholder\" className=\"border border-white/5 bg-black/20 p-6 rounded-xl text-center text-white/50 font-mono text-[11px]\">\n        Loading Project Registry Cards and table rows...\n      </div>"}}}
