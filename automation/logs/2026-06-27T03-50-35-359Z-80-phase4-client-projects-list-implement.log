me=\"w-3.5 h-3.5\" /></button>\n              </div>\n\n              <div className=\"p-5 flex-grow space-y-5\">\n                {isRequestingUpdate && (\n                  <div className=\"p-4 rounded-lg border border-[#009DFF]/20 bg-[#009DFF]/5 space-y-3 font-mono text-[10.5px]\">\n                    <div className=\"flex items-center gap-2\"><RefreshCw className=\"w-4 h-4 text-[#009DFF] animate-spin\" /><div><span className=\"text-white font-bold block uppercase\">Handshake Dispatch active</span></div></div>\n                    <div className=\"p-2.5 bg-black/40 rounded border border-white/5 text-[9.5px] text-[#009DFF]/80 space-y-1\">{dispatchLogs.map((logLine, idx) => ( <div key={idx} className=\"flex gap-1.5\"><span className=\"text-white/20\">[{idx+1}]</span><span>{logLine}</span></div> ))}</div>\n                    {dispatchSuccess && ( <div className=\"p-2.5 bg-emerald-500/10 border border-emerald-500/20 rounded text-emerald-400 space-y-1\"><div className=\"font-bold uppercase text-[10px]\">Dispatch complete</div><p className=\"text-[9.5px] text-white/60\">A secure delivery trigger has been queued with Delivery Leads. ETA &lt; 15 mins.</p></div> )}\n                  </div>\n                )}\n\n                <div className=\"space-y-3\">\n                  <h4 className=\"text-[10px] font-bold text-white/40 font-mono uppercase tracking-widest border-b border-white/5 pb-1\">Enclave Parameters</h4>\n                  <div className=\"grid grid-cols-2 gap-2 text-[10.5px] font-mono\">\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Host Node</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.nodeId}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Cores Threads</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.cores}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Memory Limit</span><span className=\"text-white font-bold block mt-0.5\">{selectedProject.specs.memory}</span></div>\n                    <div className=\"p-2.5 bg-black/40 border border-white/5 rounded-lg\"><span className=\"text-white/30 block uppercase text-[8px]\">Compliance</span><span className=\"text-emerald-400 font-bold block mt-0.5\">{selectedProject.specs.complianceScore}% Secure</span></div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <div className=\"flex justify-between items-center border-b border-white/5 pb-1\"><h4 className=\"text-[10px] font-bold text-white/40 font-mono uppercase tracking-widest\">Diagnostics Stream</h4><button onClick={handleSyncTelemetry} disabled={isLogSyncing} className=\"h-5 px-1.5 rounded border border-[#009DFF]/20 bg-[#009DFF]/5 text-[#009DFF] hover:bg-[#009DFF]/10 text-[8px] font-mono uppercase flex items-center gap-1 disabled:opacity-50 cursor-pointer\"><RefreshCw className={`w-2 h-2 ${isLogSyncing ? \"animate-spin\" : \"\"}`} />RE-SYNC</button></div>\n                  <div className=\"p-3 rounded-lg border border-white/5 bg-[#030303] text-[9.5px] font-mono text-emerald-400/80 space-y-1 h-36 overflow-y-auto relative select-text\">\n                    <div className=\"absolute top-1.5 right-1.5 flex items-center gap-1 bg-black/40 px-1.5 py-0.2 rounded text-[7.5px] text-white/40 font-bold select-none\"><span className=\"relative flex h-1 w-1\"><span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span><span className=\"relative inline-flex rounded-full h-1 w-1 bg-emerald-500\"></span></span>LIVE</div>\n                    {logs.map((log, idx) => ( <div key={idx}>{log}</div> ))}\n           