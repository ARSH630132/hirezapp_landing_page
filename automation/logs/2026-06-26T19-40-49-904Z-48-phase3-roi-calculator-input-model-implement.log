sparent pointer-events-none\" />\n190 |             \n191 |             <div className=\"border-b border-white/5 pb-3\">\n192 |               <span className=\"text-[10px] font-mono text-white/40 block uppercase tracking-wider\">VARIABLE CONTEXT PANEL</span>\n193 |               <h2 className=\"text-sm font-bold text-white mt-1\">Configure Local Inputs</h2>\n194 |             </div>\n195 | \n196 |             {/* Variable 1: Team Size */}\n197 |             <div className=\"space-y-2\">\n198 |               <div className=\"flex justify-between items-center text-xs\">\n199 |                 <label htmlFor=\"teamSize-input\" className=\"text-white/60 font-mono text-[10px] uppercase cursor-pointer\">\n200 |                   Workforce Size\n201 |                 </label>\n202 |                 <div className=\"flex items-center gap-2\">\n203 |                   <input\n204 |                     id=\"teamSize-input\"\n205 |                     type=\"number\"\n206 |                     value={teamSize}\n207 |                     onChange={(e) => setTeamSize(Math.max(1, parseInt(e.target.value) || 0))}\n208 |                     className=\"w-16 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n209 |                   />\n210 |                   <span className=\"text-white/40 font-mono text-[9px]\">FTE</span>\n211 |                 </div>\n212 |               </div>\n213 |               <p className=\"text-[10px] text-white/40 font-light leading-relaxed\">\n214 |                 The number of analysts, operations agents, or specialists engaged in manual workflows.\n215 |               </p>\n216 |               <input\n217 |                 id=\"teamSize-slider\"\n218 |                 aria-label=\"Workforce Size range slider\"\n219 |                 type=\"range\"\n220 |                 min=\"5\"\n221 |                 max=\"5000\"\n222 |                 step=\"5\"\n223 |                 value={teamSize}\n224 |                 onChange={(e) => setTeamSize(parseInt(e.target.value))}\n225 |                 className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n226 |               />\n227 |             </div>\n228 | \n229 |             {/* Variable 2: Hourly Rate */}\n230 |             <div className=\"space-y-2\">\n231 |               <div className=\"flex justify-between items-center text-xs\">\n232 |                 <label htmlFor=\"avgHourlyRate-input\" className=\"text-white/60 font-mono text-[10px] uppercase cursor-pointer\">\n233 |                   Avg Hourly Labor Rate\n234 |                 </label>\n235 |                 <div className=\"flex items-center gap-1\">\n236 |                   <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n237 |                   <input\n238 |                     id=\"avgHourlyRate-input\"\n239 |                     type=\"number\"\n240 |                     value={avgHourlyRate}\n241 |                     onChange={(e) => setAvgHourlyRate(Math.max(1, parseInt(e.target.value) || 0))}\n242 |                     className=\"w-16 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n243 |                   />\n244 |                   <span className=\"text-white/40 font-mono text-[9px]\">/ HR</span>\n245 |                 </div>\n246 |               </div>\n247 |               <p className=\"text-[10px] text-white/40 font-light leading-relaxed\">\n248 |                 Fully loaded wage of targeted workforce, including operations, benefits, and tools.\n249 |               </p>\n250 |               <input\n251 |                 id=\"avgHourlyRate-slider\"\n252 |                 aria-label=\"Avg Hourly Labor Rate range slider\"\n253 |                 type=\"range\"\n254 |                 min=\"15\"\n255 |                 max=\"350\"\n256 |                 step=\"5\"\n257 |                 value={avgHourlyRate}\n258 |                 onChange={(e) => setAvgHourlyRate(parseInt(e.target.value))}\n259 |                 className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n260 |               />\n261 |             </div>\n262 | \n263 |             {/* Variable 3: Inefficient Hours */}\n264 |             <div className=\"space-y-2\">\n265 |               <div className=\"flex justify-between items-center text-xs\">\n266 |                 <label htmlFor=\"inefficientHours-input\" className=\"text-white/60 font-mono text-[10px] uppercase cursor-pointer\">\n267 |                   Wasted Hours per FTE / Wk\n268 |                 </label>\n269 |                 <div className=\"flex items-center gap-1\">\n270 |                   <input\n271 |                     id=\"inefficientHours-input\"\n272 |                     type=\"number\"\n273 |                     value={inefficientHoursPerWeek}\n274 |                     onChange={(e) => setInefficientHoursPerWeek(Math.max(0, parseInt(e.target.value) || 0))}\n275 |                     className=\"w-16 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n276 |                   />\n277 |                   <span className=\"text-white/40 font-mono text-[9px]\">HRS</span>\n278 |                 </div>\n279 |               </div>\n280 |               <p className=\"text-[10px] text-white/40 font-light leading-relaxed\">\n281 |                 Average hours wasted per week per analyst on compliance paperwork, manual audit, or waiting.\n282 |               </p>\n283 |               <input\n284 |                 id=\"inefficientHours-slider\"\n285 |                 aria-label=\"Wasted Hours per FTE / Wk range slider\"\n286 |                 type=\"range\"\n287 |                 min=\"1\"\n288 |                 max=\"40\"\n289 |                 step=\"1\"\n290 |                 value={inefficientHoursPerWeek}\n291 |                 onChange={(e) => setInefficientHoursPerWeek(parseInt(e.target.value))}\n292 |                 className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n293 |               />\n294 |             </div>\n295 | \n296 |             {/* Variable 4: Initial CapEx */}\n297 |             <div className=\"space-y-2\">\n298 |               <div className=\"flex justify-between items-center text-xs\">\n299 |                 <label htmlFor=\"initialInvestment-input\" className=\"text-white/60 font-mono text-[10px] uppercase cursor-pointer\">\n300 |                   Initial CapEx Allocation\n301 |                 </label>\n302 |                 <div className=\"flex items-center gap-1\">\n303 |                   <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n304 |                   <input\n305 |                     id=\"initialInvestment-input\"\n306 |                     type=\"number\"\n307 |                     value={initialInvestment}\n308 |                     onChange={(e) => setInitialInvestment(Math.max(0, parseInt(e.target.value) || 0))}\n309 |                     className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n310 |                   />\n311 |                 </div>\n312 |               </div>\n313 |               <p className=\"text-[10px] text-white/40 font-light leading-relaxed\">\n314 |                 Anticipated infrastructure setup cost, licensing fee, and engineering resource alignment for GFF enclaves.\n315 |               </p>\n316 |               <input\n317 |                 id=\"initialInvestment-slider\"\n318 |                 aria-label=\"Initial CapEx Allocation range slider\"\n319 |                 type=\"range\"\n320 |                 min=\"5000\"\n321 |                 max=\"1500000\"\n322 |                 step=\"5000\"\n323 |                 value={initialInvestment}\n324 |                 onChange={(e) => setInitialInvestment(parseInt(e.target.value))}\n325 |                 className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n326 |               />\n327 |             </div>\n328 | \n329 |             {/* Strategic Priorities Selection Grid */}\n330 |             <div className=\"space-y-3 pt-2\">\n331 |               <span className=\"text-white/60 font-mono text-[10px] uppercase block\">Strategic Core Objective</span>\n332 |               <div className=\"grid grid-cols-1 gap-2\">\n333 |                 {priorities.map((item) => {\n334 |                   const isActive = item.id === priority;\n335 |                   return (\n336 |                     <button\n337 |                       key={item.id}\n338 |                       onClick={() => setPriority(item.id)}\n339 |                       type=\"button\"\n340 |                       className={`relative text-left p-2.5 rounded-lg border transition-all text-xs flex items-start gap-3 overflow-hidden ${\n341 |                         isActive\n342 |                           ? \"border-white/20 text-white\"\n343 |                           : \"border-white/5 bg-transparent text-white/70 hover:border-white/10 hover:bg-white/[0.01]\"\n344 |                       }`}\n345 |                     >\n346 |                       {isActive && (\n347 |                         <motion.div\n348 |                           layoutId=\"activePriorityBg\"\n349 |                           className=\"absolute inset-0 bg-white/[0.03] -z-10\"\n350 |                           transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n351 |                         />\n352 |                       )}\n353 |                       <div\n354 |                         className=\"w-2 h-2 rounded-full shrink-0 mt-1\"\n355 |                         style={{ backgroundColor: item.color }}\n356 |                       />\n357 |                       <div className=\"relative z-10\">\n358 |                         <span className={`font-semibold block text-[11px] ${isActive ? \"text-white\" : \"text-white/70\"}`}>\n359 |                           {item.title}\n360 |                         </span>\n361 |                         <span className=\"text-[9px] text-white/40 block leading-tight font-light mt-0.5\">\n362 |                           {item.desc}\n363 |                         </span>\n364 |                       </div>\n365 |                     </button>\n366 |                   );\n367 |                 })}\n368 |               </div>\n369 |             </div>\n370 |           </div>\n371 | \n372 |           {/* Footnote Compliance Panel */}\n373 |           <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/40 text-[10px] text-white/30 space-y-2 leading-relaxed\">\n374 |             <span className=\"font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">SECURE SHIELD COMPLIANCE</span>\n375 |             <p>\n376 |               This simulator processes data points purely inside local volatile browser memory. It adheres to the GFF AI zero-retention mandate. No telemetry is logged outside your sandboxed session.\n377 |             </p>\n378 |           </div>\n379 |         </div>\n380 | \n381 |         {/* RIGHT COLUMN: Results Console */}\n382 |         <div className=\"lg:col-span-8 space-y-8 text-white\">\n383 |           {/* Section A: Main Telemetry Summary Cards */}\n384 |           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n385 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n386 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#00FF9D]/30 to-transparent\" />\n387 |               <div>\n388 |                 <div className=\"flex items-center gap-1.5\">\n389 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">ANNUAL EFFICIENCY GAP</span>\n390 |                   <span className=\"text-[8px] font-mono font-bold bg-[#00FF9D]/10 text-[#00FF9D] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n391 |                 </div>\n392 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#00FF9D] block mt-2 font-mono tracking-tight\">\n393 |                   {formatCompactCurrency(expectedGrossSavings)}\n394 |                 </span>\n395 |               </div>\n396 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n397 |                 Illustrative recouped cost based on expected 85% workforce velocity optimization.\n398 |               </p>\n399 |             </div>\n400 | \n401 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n402 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/30 to-transparent\" />\n403 |               <div>\n404 |                 <div className=\"flex items-center gap-1.5\">\n405 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">RECLAIMED ANNUAL CAPACITY</span>\n406 |                   <span className=\"text-[8px] font-mono font-bold bg-[#009DFF]/10 text-[#009DFF] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n407 |                 </div>\n408 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#009DFF] block mt-2 font-mono tracking-tight\">\n409 |                   {expectedHoursSaved.toLocaleString()} Hrs\n410 |                 </span>\n411 |               </div>\n412 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n413 |                 Equivalent full-time hours returned to strategic initiatives rather than administrative friction.\n414 |               </p>\n415 |             </div>\n416 | \n417 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n418 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-amber-500/25 to-transparent\" />\n419 |               <div>\n420 |                 <div className=\"flex items-center gap-1.5\">\n421 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">CAPITAL AMORTIZATION</span>\n422 |                   <span className=\"text-[8px] font-mono font-bold bg-amber-500/10 text-amber-500 px-1 rounded uppercase tracking-widest\">MODELLED</span>\n423 |                 </div>\n424 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-amber-400 block mt-2 font-mono tracking-tight\">\n425 |                   {formatPayback(expectedPaybackMonths)}\n426 |                 </span>\n427 |               </div>\n428 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n429 |                 The computed timeframe before recouped hours balance the initial CapEx allocation.\n430 |               </p>\n431 |             </div>\n432 |           </div>\n433 | \n434 |           {/* Section B: Payback-Style Strategic Narrative */}\n435 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/80 backdrop-blur-sm space-y-4\">\n436 |             <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">EXECUTIVE EVALUATION SUMMARY // {currentPriorityObj.title.toUpperCase()} TARGET</span>\n437 |             <div className=\"space-y-3\">\n438 |               <p className=\"text-sm lg:text-base text-white/80 font-light leading-relaxed\">\n439 |                 By deploying the GFF sovereign agent network across your <span className=\"font-semibold text-white\">{teamSize} FTE</span> workforce footprint, the organization is projected to achieve an illustrative Net Sovereign Return of <span className=\"text-[#00FF9D] font-mono font-bold\">{expectedRoi}%</span>. The model indicates full amortization completes <span className=\"text-white font-semibold\">{formatPayback(expectedPaybackMonths).toLowerCase()}</span>, establishing an air-gapped margin optimization boundary.\n440 |               </p>\n441 |               <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n442 |                 Under the strategic lens of <span className=\"font-semibold text-[#009DFF]\">{currentPriorityObj.title}</span>, GFF's multi-agent hierarchies eliminate repetitive operational loops to reclaim <span className=\"text-white font-semibold font-mono\">{expectedHoursSaved.toLocaleString()} hours</span> of analytical runway per year. Telemetry is securely validated on single-tenant enclaves, reducing audit and speed friction to zero.\n443 |               </p>\n444 |             </div>\n445 |           </div>\n446 | \n447 |           {/* Section C: Pure CSS/SVG Waterfall Chart */}\n448 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 relative\">\n449 |             <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/20 to-transparent\" />\n450 |             <div className=\"flex justify-between items-baseline border-b border-white/5 pb-4 mb-4\">\n451 |               <div>\n452 |                 <span className=\"text-[9px] font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">VALUE CONSTRUCT MATRIX</span>\n453 |                 <h3 className=\"text-sm font-bold text-white mt-1\">Sovereign Financial Value Waterfall Chart</h3>\n454 |               </div>\n455 |               <span className=\"text-[9px] font-mono text-white/30 hidden md:inline\">UNIT: USD ($) // ANNUALIZED MODEL</span>\n456 |             </div>\n457 |             <div className=\"w-full\">\n458 |               <svg viewBox=\"0 0 720 230\" className=\"w-full h-auto overflow-visible select-none\" fill=\"none\">\n459 |                 <line x1=\"30\" y1=\"20\" x2=\"690\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n460 |                 <line x1=\"30\" y1=\"70\" x2=\"690\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n461 |                 <line x1=\"30\" y1=\"120\" x2=\"690\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n462 |                 <line x1=\"30\" y1=\"170\" x2=\"690\" y2=\"170\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n463 |                 <line x1=\"30\" y1=\"200\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n464 |                 {(() => {\n465 |                   const maxAmt = Math.max(totalWastedCostPerYear, expectedGrossSavings, initialInvestment, expectedNetSavings, 1);\n466 |                   const getY = (v: number) => 200 - (v / maxAmt) * 160;\n467 |                   const getH = (v: number) => (v / maxAmt) * 160;\n468 |                   const b1Y = getY(totalWastedCostPerYear), b1H = getH(totalWastedCostPerYear);\n469 |                   const b2H = getH(expectedGrossSavings), b2Y = b1Y;\n470 |                   const b3H = getH(initialInvestment), b3Y = b2Y + b2H - b3H;\n471 |                   const b4Y = getY(expectedNetSavings), b4H = getH(expectedNetSavings);\n472 |                   return (\n473 |                     <>\n474 |                       <line x1=\"120\" y1={b1Y} x2=\"210\" y2={b2Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n475 |                       <line x1=\"290\" y1={b2Y+b2H} x2=\"380\" y2={b3Y+b3H} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n476 |                       <line x1=\"460\" y1={b3Y} x2=\"550\" y2={b4Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n477 |                       <g>\n478 |                         <rect x=\"50\" y={b1Y} width=\"70\" height={b1H} rx=\"3\" fill=\"url(#fG)\" stroke=\"rgba(255,255,255,0.05)\" />\n479 |                         <text x=\"85\" y={Math.max(b1Y-8,15)} textAnchor=\"middle\" className=\"fill-white/80 font-mono text-[10px] font-bold\">{formatCompactCurrency(totalWastedCostPerYear)}</text>\n480 |                       </g>\n481 |                       <g>\n482 |                         <rect x=\"220\" y={b2Y} width=\"70\" height={b2H} rx=\"3\" fill=\"url(#rG)\" stroke=\"rgba(0,255,157,0.15)\" />\n483 |                         <text x=\"255\" y={Math.max(b2Y-8,15)} textAnchor=\"middle\" className=\"fill-[#00FF9D] font-mono text-[10px] font-bold\">-{formatCompactCurrency(expectedGrossSavings)}</text>\n484 |                       </g>\n485 |                       <g>\n486 |                         <rect x=\"390\" y={b3Y} width=\"70\" height={b3H} rx=\"3\" fill=\"url(#cG)\" stroke=\"rgba(228,0,15,0.15)\" />\n487 |                         <text x=\"425\" y={Math.max(b3Y-8,15)} textAnchor=\"middle\" className=\"fill-[#E4000F] font-mono text-[10px] font-bold\">+{formatCompactCurrency(initialInvestment)}</text>\n488 |                       </g>\n489 |                       <g>\n490 |                         <rect x=\"560\" y={b4Y} width=\"70\" height={b4H} rx=\"3\" fill=\"url(#nG)\" stroke=\"rgba(0,255,157,0.3)\" />\n491 |                         <text x=\"595\" y={Math.max(b4Y-8,15)} textAnchor=\"middle\" className=\"fill-white font-mono text-[11px] font-extrabold\">{formatCompactCurrency(expectedNetSavings)}</text>\n492 |                       </g>\n493 |                     </>\n494 |                   );\n495 |                 })()}\n496 |                 <defs>\n497 |                   <linearGradient id=\"fG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#fff\" stopOpacity=\"0.2\"/><stop offset=\"100%\" stopColor=\"#fff\" stopOpacity=\"0.03\"/></linearGradient>\n498 |                   <linearGradient id=\"rG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#00FF9D\" stopOpacity=\"0.05\"/></linearGradient>\n499 |                   <linearGradient id=\"cG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#E4000F\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#E4000F\" stopOpacity=\"0.05\"/></linearGradient>\n500 |                   <linearGradient id=\"nG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.55\"/><stop offset=\"50%\" stopColor=\"#009DFF\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#000\" stopOpacity=\"0\"/></linearGradient>\n501 |                 </defs>\n502 |               </svg>\n503 |               <div className=\"grid grid-cols-4 gap-2 pt-3 font-mono text-[9px] uppercase tracking-wider text-white/50 text-center border-t border-white/[0.03] mt-2\">\n504 |                 <div>01. Operational Friction</div>\n505 |                 <div>02. GFF Reclaim</div>\n506 |                 <div>03. Setup Expense</div>\n507 |                 <div className=\"text-white font-bold\">04. Sovereign Dividend</div>\n508 |               </div>\n509 |             </div>\n510 |             <p className=\"text-[9px] text-white/30 font-light italic mt-3 text-center\">* All metrics are illustrative based on mathematical models and not performance guarantees.</p>\n511 |           </div>\n512 | \n513 |           {/* Section D: Three Scenario Comparisons (Conservative, Expected, Aggressive) */}\n514 |           <div className=\"space-y-4\">\n515 |             <span className=