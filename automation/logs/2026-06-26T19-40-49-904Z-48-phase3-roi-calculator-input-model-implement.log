|   \n 35 |   const expectedMonthlySavings = expectedGrossSavings / 12;\n 36 |   const expectedPaybackMonths = expectedMonthlySavings > 0 \n 37 |     ? Math.max(0.1, Math.round((initialInvestment / expectedMonthlySavings) * 10) / 10) \n 38 |     : 0;\n 39 | \n 40 |   // Conservative Case (50% efficiency recovery)\n 41 |   const conservativeAdoptionFactor = 0.50;\n 42 |   const conservativeHoursSaved = Math.round(totalWastedHoursPerYear * conservativeAdoptionFactor);\n 43 |   const conservativeGrossSavings = conservativeHoursSaved * avgHourlyRate;\n 44 |   const conservativeNetSavings = Math.max(0, conservativeGrossSavings - initialInvestment);\n 45 |   const conservativeRoi = initialInvestment > 0 ? Math.round((conservativeNetSavings / initialInvestment) * 100) : 0;\n 46 |   \n 47 |   const conservativeMonthlySavings = conservativeGrossSavings / 12;\n 48 |   const conservativePaybackMonths = conservativeMonthlySavings > 0 \n 49 |     ? Math.max(0.1, Math.round((initialInvestment / conservativeMonthlySavings) * 10) / 10) \n 50 |     : 0;\n 51 | \n 52 |   // Aggressive Case (120% efficiency recovery due to synergistic agent multipliers)\n 53 |   const aggressiveAdoptionFactor = 1.20;\n 54 |   const aggressiveHoursSaved = Math.round(totalWastedHoursPerYear * aggressiveAdoptionFactor);\n 55 |   const aggressiveGrossSavings = aggressiveHoursSaved * avgHourlyRate;\n 56 |   const aggressiveNetSavings = Math.max(0, aggressiveGrossSavings - initialInvestment);\n 57 |   const aggressiveRoi = initialInvestment > 0 ? Math.round((aggressiveNetSavings / initialInvestment) * 100) : 0;\n 58 |   \n 59 |   const aggressiveMonthlySavings = aggressiveGrossSavings / 12;\n 60 |   const aggressivePaybackMonths = aggressiveMonthlySavings > 0 \n 61 |     ? Math.max(0.1, Math.round((initialInvestment / aggressiveMonthlySavings) * 10) / 10) \n 62 |     : 0;\n 63 | \n 64 |   // 3. PRIORITIES METADATA\n 65 |   const priorities = [\n 66 |     {\n 67 |       id: \"cost_reduction\" as Priority,\n 