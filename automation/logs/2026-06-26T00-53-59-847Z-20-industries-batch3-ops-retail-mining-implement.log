erations.\"\n 60 |         breadcrumbs={[{ label: \"Industries\", href: \"/industries\" }, { label: \"Healthcare\" }]}\n 61 |       />\n 62 | \n 63 |       {/* Challenge Landscape */}\n 64 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n 65 |         <h2 className=\"text-2xl font-bold text-white mb-6\">Challenge Landscape</h2>\n 66 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4\">\n 67 |           {CHALLENGES.map((c, i) => (\n 68 |             <div key={i} className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60\">\n 69 |               <span className=\"text-[#009DFF] font-mono text-xs block mb-2\">0{i+1} {\"//\"} {c.title}</span>\n 70 |               <p className=\"text-xs text-white/60 leading-relaxed font-light\">{c.desc}</p>\n 71 |             </div>\n 72 |           ))}\n 73 |         </div>\n 74 |       </div>\n 75 | \n 76 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n 77 |         <div className=\"lg:col-span-5 flex flex-col justify-center\">\n 78 |           <h2 className=\"text-2xl font-bold text-white mb-4\">Reference Solution</h2>\n 79 |           <p className=\"text-xs text-white/70 leading-relaxed font-light mb-6\">\n 80 |             Connecting medical systems of record with natural language orchestrators requires secure, airgapped boundaries. Our reference solution routes non-clinical inquiries through isolated cognitive layers, ensuring patient records are scrubbed of PHI before any agent processing.\n 81 |           </p>\n 82 |           <div className=\"space-y-2\">\n 83 |             {[\n 84 |               { id: \"gateway\", name: \"PHI Scrubbing Gateway\", desc: \"Zero-retention proxy cleans data of HIPAA identifiers.\" },\n 85 |               { id: \"orchestrator\", name: \"Cognitive Care Orchestrator\", desc: \"Semantic routing engine directs operational intents.\" },\n 86 |               { id: \"audit\", name: \"Immutable Care Logs\", desc: \"Every search is recorded in high-security, tamper-evident audit logs.\" }\n 87 |             ].map((tab) => (\n 88 |               <button\n 89 |                 key={tab.id}\n 90 |                 onClick={() => setActiveTab(tab.id)}\n 91 |                 className={`w-full p-3 rounded-xl text-left border text-xs transition-all ${\n 92 |                   activeTab === tab.id ? \"bg-white/5 border-white/10 text-white\" : \"border-transparent text-white/50 hover:text-white\"\n 93 |                 }`}\n 94 |               >\n 95 |                 <span className=\"font-bold uppercase tracking-wider\">{tab.name}</span>\n 96 |                 {activeTab === tab.id && <p className=\"text-[11px] text-white/60 leading-normal font-light mt-1\">{tab.desc}</p>}\n 97 |               </button>\n 98 |             ))}\n 99 |           </div>\n100 |         </div>\n101 | \n102 |         <div className=\"lg:col-span-7 p-6 rounded-2xl border border-white/5 bg-[#050507]/40 backdrop-blur-[12px] flex flex-col items-center\">\n103 |           <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest mb-4\">Interactive Healthcare Architecture Blueprint</span>\n104 |           <div className=\"w-full max-w-[420px] h-[280px] relative\">\n105 |             <svg className=\"w-full h-full\" viewBox=\"0 0 500 340\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n106 |               <path d=\"M250 40 L250 110 M250 150 L250 200 M250 240 L250 290\" stroke=\"url(#pipeGlow)\" strokeWidth=\"1.5\" strokeDasharray=\"6 4\" />\n107 |               <g onClick={() => setActiveTab(\"gateway\")} className=\"cursor-pointer\">\n108 |                 <rect x=\"100\" y=\"20\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"gateway\" ? \"#009DFF\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n109 |                 <text x=\"250\" y=\"44\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">1. SECURE EHR GATEWAY (HIPAA-ALIGNMENT)</text>\n110 |               </g>\n111 |               <g onClick={() => setActiveTab(\"orchestrator\")} className=\"cursor-pointer\">\n112 |                 <rect x=\"80\" y=\"110\" width=\"340\" height=\"40\" rx=\"8\" fill={activeTab === \"orchestrator\" ? \"url(#brandG)\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n113 |                 <text x=\"250\" y=\"134\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">2. COGNITIVE CARE ORCHESTRATOR</text>\n114 |               </g>\n115 |               <g className=\"opacity-70\">\n116 |                 <rect x=\"50\" y=\"190\" width=\"400\" height=\"50\" rx=\"8\" fill=\"#050507\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n117 |                 <text x=\"250\" y=\"210\" fill=\"#009DFF\" fontSize=\"9\" fontWeight=\"bold\" textAnchor=\"middle\">Care Copilots // Knowledge Search // Document Intelligence</text>\n118 |                 <text x=\"250\" y=\"228\" fill=\"white\" fontSize=\"8\" textAnchor=\"middle\" className=\"opacity-60\">Executing administrative tasks inside secured runtime environments</text>\n119 |               </g>\n120 |               <g onClick={() => setActiveTab(\"audit\")} className=\"cursor-pointer\">\n121 |                 <rect x=\"100\" y=\"280\" width=\"300\" height=\"40\" rx=\"8\" fill={activeTab === \"audit\" ? \"#E4000F\" : \"#0A0A0C\"} stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n122 |                 <text x=\"250\" y=\"304\" fill=\"white\" fontSize=\"10\" fontWeight=\"bold\" textAnchor=\"middle\">3. IMMUTABLE CARE AUDIT TRAIL</text>\n123 |               </g>\n124 |               <defs>\n125 |                 <linearGradient id=\"brandG\" x1=\"0\" y1=\"0\" x2=\"340\" y2=\"0\" gradientUnits=\"userSpaceOnUse\">\n126 |                   <stop stopColor=\"#E4000F\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n127 |                 </linearGradient>\n128 |                 <linearGradient id=\"pipeGlow\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"340\" gradientUnits=\"userSpaceOnUse\">\n129 |                   <stop stopColor=\"#E4000F\" /><stop offset=\"0.5\" stopColor=\"#FFFFFF\" /><stop offset=\"1\" stopColor=\"#009DFF\" />\n130 |                 </linearGradient>\n131 |               </defs>\n132 |             </svg>\n133 |           </div>\n134 |         </div>\n135 |       </div>\n136 | \n137 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n138 |         <h2 className=\"text-2xl font-bold text-white mb-6\">The Healthcare Agent Map</h2>\n139 |         <Carousel\n140 |           items={AGENTS.map((a) => ({\n141 |             title: a.name,\n142 |             tag: \"Healthcare Agent\",\n143 |             desc: a.role,\n144 |             metric: \"Latency: <150ms\"\n145 |           }))}\n146 |         />\n147 |       </div>\n148 | \n149 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\">\n150 |         <div className=\"lg:col-span-5 flex flex-col justify-center\">\n151 |           <h2 className=\"text-2xl font-bold text-white mb-4\">Interactive Care Operations Simulator</h2>\n152 |           <p className=\"text-xs text-white/70 leading-relaxed font-light mb-6\">\n153 |             Test our Document Intelligence and Knowledge Search engines. Simulate real-time parsing of pre-authorization requests and guideline queries safely.\n154 |           </p>\n155 |           <div className=\"flex flex-wrap gap-3\">\n156 |             <button\n157 |               onClick={() => runDemo(\"preauth\")}\n158 |               disabled={running}\n159 |               className=\"px-4 py-2 rounded-full text-xs font-semibold bg-white text-black hover:bg-white/90 disabled:opacity-50 transition-all\"\n160 |             >\n161 |               {running ? \"Executing...\" : \"Pre-auth Document Check\"}\n162 |             </button>\n163 |             <button\n164 |               onClick={() => runDemo(\"knowledge\")}\n165 |               disabled={running}\n166 |               className=\"px-4 py-2 rounded-full text-xs font-semibold bg-white/5 border border-white/10 hover:bg-white/10 text-white disabled:opacity-50 transition-all\"\n167 |             >\n168 |               {running ? \"Searching...\" : \"Hospital Guidelines Search\"}\n169 |             </button>\n170 |           </div>\n171 |         </div>\n172 | \n173 |         <div className=\"lg:col-span-7 p-5 rounded-xl border border-white/5 bg-black/40 min-h-[160px] flex flex-col justify-between font-mono relative overflow-hidden\">\n174 |           <span className=\"text-[10px] text-[#009DFF] block border-b border-white/5 pb-2 uppercase tracking-wider font-bold\">KNOWLEDGE RETRIEVAL LOG</span>\n175 |           <p className=\"text-xs text-green-400 mt-3 leading-relaxed font-mono\">{demoOutput}</p>\n176 |           <span className=\"text-[9px] text-white/30 text-right block pt-3\">GFF HEALTHCARE PORTAL</span>\n177 |         </div>\n178 |       </div>\n179 | \n180 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16\">\n181 |         <h2 className=\"text-2xl font-bold text-white mb-6\">Structural ROI & Outcome Levers</h2>\n182 |         <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n183 |           {OUTCOMES.map((o, i) => (\n184 |             <div key={i} className=\"p-5 rounded-xl border border-white/5 bg-[#050507]/60 hover:border-white/10 transition-all\">\n185 |               <h3 className=\"text-xs font-mono font-bold text-white uppercase mb-2 tracking-wider\">{o.title}</h3>\n186 |               <p className=\"text-xs text-white/60 leading-relaxed font-light\">{o.desc}</p>\n187 |             </div>\n188 |           ))}\n189 |         </div>\n190 |       </div>\n191 | \n192 |       <div className=\"max-w-[1795px] mx-auto px-6 pb-16 border-t border-white/5 pt-12\">\n193 |         <h3 className=\"text-xs font-mono text-white/40 uppercase tracking-widest mb-4\">Related Capabilities & Platforms</h