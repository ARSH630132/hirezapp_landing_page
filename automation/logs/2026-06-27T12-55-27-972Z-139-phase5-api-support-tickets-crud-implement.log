ets.filter(t => t.client_id === cid);\n      if (cliF && cliF !== cid) return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Denied\" }, { status: 403 });\n    } else if (cliF) {\n      tickets = tickets.filter(t => t.client_id === cliF);\n    }\n\n    if (statF) tickets = tickets.filter(t => t.status.toLowerCase() === statF.toLowerCase().trim());\n    if (priF) tickets = tickets.filter(t => t.priority.toLowerCase() === priF.toLowerCase().trim());\n    if (catF) tickets = tickets.filter(t => t.category.toLowerCase().includes(catF.toLowerCase().trim()));\n    if (projF) tickets = tickets.filter(t => t.project_id === projF || (projF === \"null\" && !t.project_id));\n    if (assF) tickets = tickets.filter(t => t.assigned_to === assF || (assF === \"null\" && !t.assigned_to));\n    if (q) {\n      const searchQ = q.toLowerCase().trim();\n      tickets = tickets.filter(t => t.title.toLowerCase().includes(searchQ) || t.description.toLowerCase().includes(searchQ) || t.id.toLowerCase().includes(searchQ) || t.category.toLowerCase().includes(searchQ));\n    }\n\n    return NextResponse.json({ success: true, tickets });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Error\" }, { status: 500 });\n  }\n}\n\nexport async function POST(req: Request) {\n  try {\n    const auth = getAuthCaller(req);\n    if (\"status\" in auth) return NextResponse.json({ success: false, error: auth.error, message: auth.msg }, { status: auth.status });\n    const { caller } = auth;\n\n    const b = await req.json().catch(() => null);\n    if (!b) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid JSON\" }, { status: 400 });\n\n    const { title, description, category, priority, status, client_id, project_id, assigned_to } = b;\n    if (!title || typeof title !== \"string\" || !title.trim()) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid title\" }, { status: 400 });\n    if (!description || typeof description !== \"string\" || !description.trim()) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid description\" }, { status: 400 });\n    if (!category || typeof category !== \"string\" || !category.trim()) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid category\" }, { status: 400 });\n\n    const valP = [\"low\", \"medium\", \"high\", \"critical\"];\n    if (!priority || !valP.includes(priority.toLowerCase().trim())) return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid priority\" }, { status: 400 });\n\n    let cid = client_id;\n    if (caller.role !== \"gff_admin\") {\n      const callerCid = getClientIdFromAssociation(caller.clientAssociation);\n      if (client_id && client_id !== callerCid) return NextResponse.json({ success: false, error: \"Forbidden\", message: \"Boundary violation\" }, { status: 403 });\n      cid = callerCid;\n    } else if (!cid || ![\"client-001\", \"client-002\", \"client-003\", \"client-004\"].includes(cid)) {\n      return NextResponse.json({ success: false, error: \"Bad Request\", message: \"Invalid client_id\" }, { status: 400 });\n    }\n\n    const tid = getNextSupportTicketId();\n    const now = new Date().toISOString();\n    const newTkt: ApiSupportTicket = {\n      id: tid,\n      title: title.trim(),\n      description: description.trim(),\n      category: category.trim(),\n      priority: priority.toLowerCase().trim() as ApiSupportTicket[\"priority\"],\n      status: (status?.toLowerCase().trim() || \"open\") as ApiSupportTicket[\"status\"],\n      client_id: cid,\n      project_id: project_id || null,\n      assigned_to: assigned_to || null,\n      created_by: caller.email,\n      createdAt: now,\n      lastUpdated: now,\n      replies: []\n    };\n\n    (API_MOCK_SUPPORT_TICKETS as Record<string, ApiSupportTicket>)[tid] = newTkt;\n    return NextResponse.json({ success: true, ticket: newTkt }, { status: 201 });\n  } catch (err) {\n    return NextResponse.json({ success: false, error: \"Internal Error\" }, { status: 500 });\n  }\n}\n"}}}
