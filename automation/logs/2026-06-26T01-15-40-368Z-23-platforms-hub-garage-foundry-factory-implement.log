{"ts":"2026-06-26T01:10:35.151Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"vbjell3d","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport Link from \"next/link\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport EnterpriseFlowDiagram from \"@/components/inner-pages/EnterpriseFlowDiagram\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function PlatformsHubPage() {\n  const stackLayers = [\n    {\n      id: \"factory\",\n      title: \"FACTORY LAYER\",\n      subtitle: \"Industrialisation, Scaling & Monetisation\",\n      desc: \"Deploy, manage, and audit cognitive agent pipelines at global scale. Factory governs live telemetry logs, runs Human-in-the-Loop verification gates, and tracks real-time cost-attribution.\",\n      href: \"/platforms/factory\",\n      color: \"border-[#FF3B30]/30 hover:border-[#FF3B30]/60 hover:bg-[#FF3B30]/5 text-[#FF3B30]\",\n      badge: \"Scale & Operate\",\n    },\n    {\n      id: \"foundry\",\n      title: \"FOUNDRY LAYER\",\n      subtitle: \"Co-creation, Visual DAGs & Runtime Node\",\n      desc: \"Connect data structures, prompt compiler chains, and compliance guardrails. Foundry compiles your logic into deterministic agent architectures executing within a secure containerized runtime.\",\n      href: \"/platforms/foundry\",\n      color: \"border-[#009DFF]/30 hover:border-[#009DFF]/60 hover:bg-[#009DFF]/5 text-[#009DFF]\",\n      badge: \"Build & Orchestrate\",\n    },\n    {\n      id: \"garage\",\n      title: \"GARAGE LAYER\",\n      subtitle: \"Strategic Discovery & AI Engineering Labs\",\n      desc: \"Shape raw opportunities into executable technical blueprints. Garage hosts high-velocity sandboxed workshops, executive framing platforms, and live experimentation zones.\",\n      href: \"/platforms/garage\",\n      color: \"border-[#00FF9D]/30 hover:border-[#00FF9D]/60 hover:bg-[#00FF9D]/5 text-[#00FF9D]\",\n      badge: \"Discover & Frame\",\n    }\n  ];\n\n  const gridPlatforms = [\n    {\n      title: \"Garage Innovation Suite\",\n      category: \"Innovation Layer\",\n      href: \"/platforms/garage\",\n      desc: \"Collaborative portal for executive framing, architectural design workshops, and secure rapid-prototyping sandbox environments.\",\n      features: [\"Strategic Discovery\", \"Joint Architecture Workshops\", \"High-velocity AI Labs\", \"Experiment Zone Playground\"],\n      themeColor: \"#00FF9D\",\n      buttonText: \"Explore Garage\",\n    },\n    {\n      title: \"Foundry Visual Studio\",\n      category: \"Co-creation Layer\",\n      href: \"/platforms/foundry\",\n      desc: \"Our signature professional IDE to build multi-agent systems. Manage relational database fabric ingest and configure cognitive core supervisors.\",\n      features: [\"Visual Flow (DAG) Canvas\", \"Secure Local Runtime\", \"Dynamic Data Fabric\", \"Enterprise AI Engineering\"],\n      themeColor: \"#009DFF\",\n      buttonText: \"Launch Foundry Preview\",\n    },\n    {\n      title: \"Factory Scaling Portal\",\n      category: \"Industrialisation Layer\",\n      href: \"/platforms/factory\",\n      desc: \"The mission-critical operations control tower. Manage security guardrail policies, horizontal clustering, and cost tracking logs.\",\n      features: [\"Horizontal Agent Clustering\", \"Observability Monitor Dashboard\", \"Human-in-the-Loop Audit Gates\", \"Tenant Cost Attribution\"],\n      themeColor: \"#FF3B30\",\n      buttonText: \"Review Factory Portal\",\n    },\n    {\n      title: \"GFF AI Marketplace\",\n      category: \"Sovereign Asset Directory\",\n      href: \"/platforms/marketplace\",\n      desc: \"An enterprise directory of pre-packaged autonomous agents, specialized compliance templates, and secure API connector recipes.\",\n      features: [\"Pre-built Agent Clusters\", \"Certified Local Connectors\", \"One-Click Sandbox Deploy\", \"Audit-Ready Configurations\"],\n      themeColor: \"#E4000F\",\n      buttonText: \"Browse Marketplace\",\n    }\n  ];\n\n  const industryMeshes = [\n    {\n      title: \"Financial Sovereign Mesh\",\n      specs: [\"SEC & FINRA Compliance\", \"Real-Time Audit Attribution\", \"Isolated Memory Pools\"],\n      desc: \"Hardened transactional intelligence layer designed for global banking, asset management, and complex quantitative compliance.\"\n    },\n    {\n      title: \"Healthcare Secure Mesh\",\n      specs: [\"HIPAA-Hardened Data Pipelines\", \"Clinical Concept Ontologies\", \"Zero-PII Token Leakage\"],\n      desc: \"Strictly isolated clinical-grade agent pipelines mapping patient pathways, medical records research, and staff scheduling optimization.\"\n    },\n    {\n      title: \"Government Sovereign Mesh\",\n      specs: [\"FedRAMP-Ready Framework\", \"Air-Gapped Node Deployment\", \"Zero External Exfiltration\"],\n      desc: \"Sovereign intelligence grids serving public administrations, defense operations, tax authorities, and secure cross-agency workflows.\"\n    },\n    {\n      title: \"Energy & Utilities Mesh\",\n      specs: [\"Critical Infrastructure Shield\", \"SCADA Telemetry Parsing\", \"Asset Failure Prediction\"],\n      desc: \"Robust agent grids for utility optimization, predictive grid balancing, real-time field operations logging, and plant safety auditing.\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Productized Assets\"\n        title=\"Enterprise Platforms\"\n        highlightedWord=\"Platforms\"\n        description=\"Transform enterprise operations with GFF AI's suite of secure sovereign software platforms. Build, audit, and run multi-agent cognitive systems with total control.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n        \n        {/* SECTION 1: Product Stack (The Core Architecture) */}\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">ARCHITECTURE LAYER</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white tracking-tight mt-2\">\n              The GFF Operating Stack\n            </h2>\n            <p className=\"mt-4 text-[15px] text-white/60 font-light\">\n              Our unique three-tier framework ensures your enterprise AI goes from zero-friction strategic design to high-throughput secure operations.\n            </p>\n          </div>\n\n          {/* Layered Interactive CSS Stack Graphic */}\n          <div className=\"max-w-[1000px] mx-auto space-y-4\">\n            {stackLayers.map((layer, index) => (\n              <div\n                key={layer.id}\n                className={`p-8 rounded-[20px] border bg-[#050505]/80 backdrop-blur-[12px] flex flex-col md:flex-row md:items-center justify-between transition-all duration-300 group ${layer.color}`}\n              >\n                <div className=\"space-y-2 md:max-w-[70%]\">\n                  <div className=\"flex items-center gap-3\">\n                    <span className=\"text-[10px] font-mono font-bold tracking-widest uppercase py-0.5 px-2.5 bg-white/5 rounded-full border border-white/5\">\n                      {layer.badge}\n                    </span>\n                    <span className=\"text-xs font-mono opacity-40\">Tier 0{3 - index}</span>\n                  </div>\n                  <h3 className=\"text-[20px] font-bold text-white tracking-tight\">{layer.title}</h3>\n                  <p className=\"text-[13.5px] leading-[1.5] text-white/60 font-light group-hover:text-white/80 transition-colors\">\n                    {layer.desc}\n                  </p>\n                </div>\n                <div className=\"mt-6 md:mt-0 pt-4 md:pt-0 border-t md:border-0 border-white/5 flex flex-col items-start md:items-end justify-center shrink-0\">\n                  <span className=\"text-[12px] font-mono opacity-50 mb-3 block md:hidden lg:block text-white\">\n                    {layer.subtitle}\n                  </span>\n                  <Link\n                    href={layer.href}\n                    className=\"inline-flex h-[42px] px-6 items-center justify-center rounded-xl bg-white/5 border border-white/10 text-white text-[13px] font-semibold hover:bg-white/10 hover:border-white/20 transition-all\"\n                  >\n                    Launch Layer Specs →\n                  </Link>\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 2: Platform Grid */}\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">MODULAR SYSTEM SOFTWARE</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white tracking-tight mt-2\">\n              System Components\n            </h2>\n            <p className=\"mt-4 text-[15px] text-white/60 font-light\">\n              Select standalone core modules or roll out the complete vertical suite to integrate secure decision pipelines into legacy workflows.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8\">\n            {gridPlatforms.map((plat) => (\n              <div\n                key={plat.title}\n                className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] flex flex-col justify-between hover:border-white/10 transition-all duration-300 hover:shadow-[0_0_30px_rgba(0,0,0,0.4)] group relative\"\n              >\n                {/* Visual hover spotlight outline */}\n                <div className=\"absolute top-0 left-0 w-8 h-8 border-t border-l border-white/10 rounded-tl-[24px]\" />\n                <div className=\"absolute bottom-0 right-0 w-8 h-8 border-b border-r border-white/10 rounded-br-[24px]\" />\n\n                <div>\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[10px] uppercase font-mono text-white/40 tracking-wider\">\n                      {plat.category}\n                    </span>\n                    <span\n                      className=\"w-2.5 h-2.5 rounded-full\"\n                      style={{ backgroundColor: plat.themeColor }}\n                    />\n                  </div>\n                  <h3 className=\"text-[22px] font-bold text-white tracking-tight mt-3\">{plat.title}</h3>\n                  <p className=\"mt-4 text-[14px] leading-[1.6] text-white/60 font-light\">{plat.desc}</p>\n                  \n                  <ul className=\"mt-6 space-y-3\">\n                    {plat.features.map((feat) => (\n                      <li key={feat} className=\"flex items-center gap-2.5 text-[13px] text-white/80\">\n                        <svg className=\"w-4 h-4 shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" style={{ color: plat.themeColor }}>\n                          <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                        </svg>\n                        <span className=\"font-light\">{feat}</span>\n                      </li>\n                    ))}\n                  </ul>\n                </div>\n\n                <div className=\"mt-8 pt-6 border-t border-white/5\">\n                  <Link\n                    href={plat.href}\n                    className=\"inline-flex w-full h-[46px] items-center justify-center rounded-xl bg-white/5 border border-white/10 text-white text-[13.5px] font-semibold hover:bg-white/10 hover:border-white/15 transition-all\"\n                  >\n                    {plat.buttonText}\n                  </Link>\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 3: Industry Mesh Platforms */}\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">COMPLIANCE EDGE</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white tracking-tight mt-2\">\n              Industry Mesh Layers\n            </h2>\n            <p className=\"mt-4 text-[15px] text-white/60 font-light\">\n              Secure sector-specific ontologies loaded on top of GFF core components. Every mesh implements industry-mandated security and audit guidelines.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {industryMeshes.map((mesh) => (\n              <div\n                key={mesh.title}\n                className=\"p-6 lg:p-8 rounded-[20px] border border-white/5 bg-[#030304]/80 flex flex-col justify-between\"\n              >\n                <div>\n                  <h3 className=\"text-[18px] font-bold text-white tracking-tight\">{mesh.title}</h3>\n                  <p className=\"mt-2.5 text-[13.5px] leading-[1.5] text-white/50 font-light\">{mesh.desc}</p>\n                </div>\n\n                <div className=\"mt-6 pt-5 border-t border-white/5\">\n                  <div className=\"flex flex-wrap gap-2\">\n                    {mesh.specs.map((spec) => (\n                      <span\n                        key={spec}\n                        className=\"px-2.5 py-1 rounded-md text-[10px] font-mono bg-white/[0.02] border border-white/5 text-white/70\"\n                      >\n                        {spec}\n                      </span>\n                    ))}\n                  </div>\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 4: Control & Governance Layer */}\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">SOVEREIGN TRUST</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white tracking-tight mt-2\">\n              Active Control & Governance\n            </h2>\n            <p className=\"mt-4 text-[15px] text-white/60 font-light\">\n              Our systems integrate live compliance firewalls, data leakage prevention models, and sovereign container tracking. Here is how a standard cognitive request routes securely.\n            </p>\n          </div>\n\n          <div className=\"max-w-[1100px] mx-auto\">\n            <EnterpriseFlowDiagram />\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 5: CTA */}\n        <MotionReveal direction=\"up\">\n          <PremiumCTA\n            title=\"Design Your Multi-Agent Topology\"\n            description=\"Consult with a GFF systems architect to build, scope, and prototype a private sovereign cluster suited for your legal frameworks.\"\n            primaryLabel=\"Book Architectural Consultation\"\n            primaryHref=\"/contact\"\n            secondaryLabel=\"Explore Core Philosophy\"\n            secondaryHref=\"/why-gff-ai/technology-philosophy\"\n          />\n        </MotionReveal>\n\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
