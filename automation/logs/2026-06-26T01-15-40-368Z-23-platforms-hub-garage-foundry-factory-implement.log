{"ts":"2026-06-26T01:13:56.244Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"lpbbou0s","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/foundry/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function FoundryPage() {\n  const [selected, setSelected] = useState(\"core\");\n  const [log, setLog] = useState(\"Status: Ready to execute flow.\");\n  const [running, setRunning] = useState(false);\n\n  const triggerFlow = () => {\n    setRunning(true);\n    setLog(\"Compiling multi-agent DAG structure...\");\n    setTimeout(() => {\n      setLog(\"[Node 1] Ingesting database streams...\\n[Node 2] Cognitive core processing feedback loop...\\n[Node 3] Executed flow successfully. Latency: 120ms.\");\n      setRunning(false);\n    }, 800);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Co-Creation Layer\"\n        title=\"Foundry Visual Studio\"\n        highlightedWord=\"Foundry\"\n        description=\"Design and engineer deterministic multi-agent architectures with visual DAG orchestration.\"\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        \n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center py-10 border-y border-white/5\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Systems Co-Creation</span>\n            <h2 className=\"text-3xl font-bold text-white mt-2\">The Co-Creation Layer</h2>\n          </div>\n          <div className=\"l