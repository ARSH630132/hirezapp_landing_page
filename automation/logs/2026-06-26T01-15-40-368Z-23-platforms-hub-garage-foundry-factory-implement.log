            specs: [\"FedRAMP-Ready Pipeline\", \"Air-Gapped Deployment\"]\n              },\n              {\n                title: \"Energy & Utilities Mesh\",\n                desc: \"Robust agent grids for utility optimization, predictive grid balancing, real-time SCADA telemetry parsing, and safety auditing.\",\n                specs: [\"SCADA Telemetry Core\", \"Grid-Attributed Safeguards\"]\n              }\n            ].map((mesh) => (\n              <div key={mesh.title} className=\"p-6 rounded-[20px] border border-white/5 bg-[#030304]/80 flex flex-col justify-between\">\n                <div>\n                  <h3 className=\"text-[16px] font-bold text-white\">{mesh.title}</h3>\n                  <p className=\"mt-2 text-[13px] leading-[1.45] text-white/50 font-light\">{mesh.desc}</p>\n                </div>\n                <div className=\"mt-4 pt-4 border-t border-white/5 flex gap-2\">\n                  {mesh.specs.map((spec) => (\n                    <span key={spec} className=\"px-2 py-0.5 rounded text-[9px] font-mono bg-white/[0.02] border border-white/5 text-white/60\">{spec}</span>\n                  ))}\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 4: Control & Governance Layer */}\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">SOVEREIGN TRUST</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white mt-2\">Active Control & Governance</h2>\n          </div>\n          <div className=\"max-w-[1100px] mx-auto\">\n            <EnterpriseFlowDiagram />\n          </div>\n        </MotionReveal>\n\n        {/* SECTION 5: CTA */}\n        <MotionReveal direction=\"up\">\n          <PremiumCTA\n            title=\"Design Your Multi-Agent Topology\"\n       