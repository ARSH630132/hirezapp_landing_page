ext-white/60\"}`}>\n                <span className=\"text-xl\">🧠</span>\n                <span className=\"text-[9px] font-bold mt-1\">COGNITIVE</span>\n              </button>\n              <button onClick={() => setSelected(\"out\")} className={`z-10 w-20 h-20 rounded-xl border flex flex-col items-center justify-center transition-all ${selected === \"out\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-[#009DFF]\" : \"border-white/10 bg-white/[0.02] text-white/60\"}`}>\n                <span className=\"text-xl\">📤</span>\n                <span className=\"text-[9px] font-bold mt-1\">DISPATCH</span>\n              </button>\n            </div>\n\n            <div className=\"lg:col-span-5 flex flex-col justify-between p-6 rounded-2xl border border-white/10 bg-[#04060b] min-h-[300px]\">\n              <div>\n                <h3 className=\"text-xs font-bold text-[#009DFF] uppercase tracking-wider mb-2\">Node Configurator</h3>\n                {selected === \"db\" && <p className=\"text-xs text-white/70\">Source: Relational Database Fabric. Configured for delta-stream indexing.</p>}\n                {selected === \"core\" && <p className=\"text-xs text-white/70\">Engine: GFF Cognitive Supervisor. Orchestrating reasoning feedback loop.</p>}\n                {selected === \"out\" && <p className=\"text-xs text-white/70\">Dispatcher: Webhook Secure Relay. Sends certified ledger transactions.</p>}\n              </div>\n              <div className=\"space-y-4\">\n                <div className=\"p-3 rounded-lg border border-white/5 bg-black/40 text-[11px] font-mono text-white/60 min-h-[70px] whitespace-pre-wrap\">\n                  {log}\n                </div>\n                <button onClick={triggerFlow} disabled={running} className=\"w-full h-[40px] rounded-lg bg-[#009DFF]/15 border border-[#009DFF]/30 text-xs font-bold text-[#009DFF] hover:bg-[#009DFF]/25 transition-all\">\n                  {running ? \"Compiling...\" : \"Compile & Run DAG Flow\"}\n                <