{"ts":"2026-06-26T01:14:34.232Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"27ubqj91","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/foundry/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function FoundryPage() {\n  const [selected, setSelected] = useState(\"core\");\n  const [log, setLog] = useState(\"Status: Ready to execute flow.\");\n  const [running, setRunning] = useState(false);\n\n  const triggerFlow = () => {\n    setRunning(true);\n    setLog(\"Compiling multi-agent DAG structure...\");\n    setTimeout(() => {\n      setLog(\"[Node] Ingesting database streams...\\n[Engine] Cognitive loops...\\n[Status] Completed in 120ms.\");\n      setRunning(false);\n    }, 400);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Co-Creation Layer\"\n        title=\"Foundry Studio\"\n        highlightedWord=\"Foundry\"\n        description=\"Design and engineer deterministic multi-agent architectures with visual DAG orchestration.\"\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-10 border-y border-white/5\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Systems Co-Creation</span>\n            <h2 className=\"text-3xl font-bold text-white mt-2\">The Co-Creation Layer</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light leading-relaxed text-sm\">\n              The Foundry serves as Tier 2 of GFF's Operating Model. Developers build real-world cognitive agents using visual DAG pipelines, connect enterprise datasets securely, and run local compilations on secure runtime nodes.\n            </p>\n          </div>\n        </MotionReveal>\n\n        <MotionReveal className=\"space-y-6\">\n          <h2 className=\"text-2xl font-bold text-white text-center\">Interactive Workspace</h2>\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 max-w-5xl mx-auto items-stretch\">\n            <div className=\"lg:col-span-7 h-[240px] rounded-2xl border border-white/10 bg-black/60 relative flex items-center justify-around overflow-hidden p-4\">\n              <svg className=\"absolute inset-0 w-full h-full pointer-events-none\">\n                <line x1=\"15%\" y1=\"50%\" x2=\"50%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth=\"2\" strokeDasharray=\"4 4\" />\n                <line x1=\"50%\" y1=\"50%\" x2=\"85%\" y2=\"50%\" stroke=\"rgba(255,255,255,0.15)\" strokeWidth=\"2\" strokeDasharray=\"4 4\" />\n              </svg>\n              {[\"db\", \"core\", \"out\"].map((node) => (\n                <button key={node} onClick={() => setSelected(node)} className={`z-10 w-20 h-20 rounded-xl border flex flex-col items-center justify-center capitalize transition-all ${selected === node ? \"border-[#009DFF] bg-[#009DFF]/5 text-[#009DFF]\" : \"border-white/10 bg-white/[0.02] text-white/60\"}`}>\n                  <span className=\"text-xl\">{node === \"db\" ? \"📥\" : node === \"core\" ? \"🧠\" : \"📤\"}</span>\n                  <span className=\"text-[9px] font-bold mt-1\">{node === \"db\" ? \"DB INGEST\" : node === \"core\" ? \"COGNITIVE\" : \"DISPATCH\"}</span>\n                </button>\n              ))}\n            </div>\n\n            <div className=\"lg:col-span-5 flex flex-col justify-between p-6 rounded-2xl border border-white/10 bg-[#04060b] min-h-[240px]\">\n              <div>\n                <h3 className=\"text-xs font-bold text-[#009DFF] uppercase tracking-wider mb-2\">Node Configurator</h3>\n                <p className=\"text-xs text-white/70\">\n                  {selected === \"db\" && \"Source: Relational Database Fabric. Configured for delta-stream indexing.\"}\n                  {selected === \"core\" && \"Engine: GFF Cognitive Supervisor. Orchestrating reasoning feedback loop.\"}\n                  {selected === \"out\" && \"Dispatcher: Webhook Secure Relay. Sends certified ledger transactions.\"}\n                </p>\n              </div>\n              <div className=\"space-y-4\">\n                <pre className=\"p-3 rounded-lg border border-white/5 bg-black/40 text-[11px] font-mono text-white/60 min-h-[60px] whitespace-pre-wrap\">{log}</pre>\n                <button onClick={triggerFlow} disabled={running} className=\"w-full py-2 rounded bg-[#009DFF]/15 border border-[#009DFF]/30 text-xs font-bold text-[#009DFF] hover:bg-[#009DFF]/25 transition-all\">\n                  {running ? \"Compiling...\" : \"Compile & Run DAG Flow\"}\n                </button>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        <MotionReveal className=\"space-y-6\">\n          <h2 className=\"text-2xl font-bold text-white text-center\">Foundry Capabilities</h2>\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n            {[\n              { title: \"Build Agents\", desc: \"Build rich cognitive supervisors with deterministic branching policies.\" },\n              { title: \"Secure Runtime\", desc: \"Run high-throughput agent nodes inside locally sandboxed container environments.\" },\n              { title: \"Data Fabric\", desc: \"Ingest structured relational streams and orchestrate vector index updates.\" },\n              { title: \"AI Engineering\", desc: \"Enterprise evaluation loops, regression checks, and performance metrics.\" }\n            ].map((c) => (\n              <div key={c.title} className=\"p-6 rounded-xl border border-white/5 bg-black/40 hover:border-[#009DFF]/20 transition-all\">\n                <h3 className=\"font-bold text-white text-sm mb-2\">{c.title}</h3>\n                <p className=\"text-xs text-white/50 leading-relaxed font-light\">{c.desc}</p>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        <PremiumCTA\n          title=\"Scale Your Engineered DAG to Production\"\n          description=\"Ready to elevate your validated agent pipelines? Transition seamlessly to the industrialization layer with Factory.\"\n          primaryLabel=\"Explore Scaling Factory\"\n          primaryHref=\"/platforms/factory\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
