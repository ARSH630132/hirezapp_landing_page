{"ts":"2026-06-26T01:12:59.329Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"nwblr1n8","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/garage/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function GaragePage() {\n  const [activeZone, setActiveZone] = useState(\"audit\");\n  const [simLog, setSimLog] = useState(\"Status: Idle. Select target agent...\");\n  const [simulating, setSimulating] = useState(false);\n\n  const runSimulation = (agentType: string) => {\n    setSimulating(true);\n    setSimLog(\"Connecting to sandboxed security kernel...\");\n    setTimeout(() => {\n      if (agentType === \"audit\") {\n        setSimLog(\"[Agent-Core-1] Active. Ingested data trace.\\n[Compliance-Gate] Scanning for PII leaks...\\n[Trace] Redacted 2 instances of sensitive data.\\n[Status] Secure token dispatch complete.\");\n      } else if (agentType === \"scada\") {\n        setSimLog(\"[Sensor-Core] Polling telemetry streams...\\n[Telemetry-Check] Values within threshold (+0.042)\\n[Log] State locked in local memory space.\\n[Status] Dispatch complete.\");\n      } else {\n        setSimLog(\"[Parser-Core] Scanning transaction ledger...\\n[Audit-Lock] Match found: verified block signature.\\n[Compliance] Passed SOC2 dynamic rules.\\n[Status] Dispatch complete.\");\n      }\n      setSimulating(false);\n    }, 800);\n  };\n\n  const pillars = [\n    {\n      title: \"Discover AI Portal\",\n      tagline: \"Strategic Scoping & Priorities\",\n      desc: \"An intuitive collaborative platform to map business objectives directly into formal multi-agent capabilities, compliance requirements, and computational blueprints.\"\n    },\n    {\n      title: \"Architectural Workshops\",\n      tagline: \"Alignment & Design\",\n      desc: \"Collaborative deep-dive sessions where systems architects, compliance managers, and line-of-business owners outline specific safety bounds and sovereign boundaries.\"\n    },\n    {\n      title: \"AI Prototyping Labs\",\n      tagline: \"High-Velocity Sandboxing\",\n      desc: \"Secure, isolated engineering spaces where GFF developers co-build initially scoped pipeline designs to test throughput and agent-to-agent logic loops.\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Innovation Layer\"\n        title=\"GFF AI Garage\"\n        highlightedWord=\"Garage\"\n        description=\"Transform complex business objectives into production-ready software blueprints in our strategic co-design space.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-20\">\n        \n        {/* Innovation Layer description */}\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center py-10 border-y border-white/5\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#00FF9D] uppercase tracking-widest\">Innovation Framework</span>\n            <h2 className=\"text-3xl font-bold text-white mt-2\">The Innovation Layer</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light leading-relaxed text-base\">\n              The Garage represents Tier 1 of GFF AI's deployment framework. It acts as the initial translation bridge. Rather than jumping straight to complex coding, we scope governance boundaries, design cognitive topologies, and validate data compliance parameters. This methodical approach ensures zero waste, tight alignment, and robust safety protocols.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Discovery, Workshops, AI Labs Section */}\n        <MotionReveal className=\"space-y-8\">\n          <h2 className=\"text-2xl font-bold text-white text-center\">Co-Design Capabilities</h2>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n            {pillars.map((p) => (\n              <div key={p.title} className=\"p-8 rounded-2xl border border-white/5 bg-black/40 hover:border-[#00FF9D]/20 transition-all duration-300\">\n                <span className=\"text-[10px] font-mono text-[#00FF9D] uppercase tracking-wider\">{p.tagline}</span>\n                <h3 className=\"text-xl font-bold text-white mt-2 mb-4\">{p.title}</h3>\n                <p className=\"text-sm text-white/60 leading-relaxed font-light\">{p.desc}</p>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* Experiment Zone */}\n        <MotionReveal className=\"space-y-6\">\n          <div className=\"text-center\">\n            <span className=\"text-xs font-mono text-[#00FF9D] uppercase tracking-widest\">Playground Environment</span>\n            <h2 className=\"text-2xl font-bold text-white mt-1\">Experiment Zone Sandbox</h2>\n            <p className=\"text-sm text-white/50 max-w-xl mx-auto mt-2\">\n              Select an experimental agent target to simulate a sandboxed sovereign run trace. See compliance rules execute in real-time.\n            </p>\n          </div>\n\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-5xl mx-auto items-stretch\">\n            <div className=\"lg:col-span-5 bg-black/40 p-6 rounded-2xl border border-white/5 flex flex-col gap-3 justify-center\">\n              <span className=\"text-[10px] font-mono text-white/40 uppercase\">Select Simulator Model</span>\n              <button\n                onClick={() => { setActiveZone(\"audit\"); runSimulation(\"audit\"); }}\n                className={`p-4 rounded-xl border text-left transition-all ${activeZone === \"audit\" ? \"border-[#00FF9D] bg-[#00FF9D]/5\" : \"border-white/5 bg-white/[0.02]\"}`}\n              >\n                <div className=\"font-bold text-sm text-white\">PII Redactor Core</div>\n                <div className=\"text-[11px] text-white/40\">Scans memory frames for HIPAA parameters</div>\n              </button>\n\n              <button\n                onClick={() => { setActiveZone(\"scada\"); runSimulation(\"scada\"); }}\n                className={`p-4 rounded-xl border text-left transition-all ${activeZone === \"scada\" ? \"border-[#00FF9D] bg-[#00FF9D]/5\" : \"border-white/5 bg-white/[0.02]\"}`}\n              >\n                <div className=\"font-bold text-sm text-white\">SCADA Telemetry Parser</div>\n                <div className=\"text-[11px] text-white/40\">Processes localized utility sensors</div>\n              </button>\n\n              <button\n                onClick={() => { setActiveZone(\"sec\"); runSimulation(\"sec\"); }}\n                className={`p-4 rounded-xl border text-left transition-all ${activeZone === \"sec\" ? \"border-[#00FF9D] bg-[#00FF9D]/5\" : \"border-white/5 bg-white/[0.02]\"}`}\n              >\n                <div className=\"font-bold text-sm text-white\">SEC Audit Agent</div>\n                <div className=\"text-[11px] text-white/40\">Validates compliance metadata chains</div>\n              </button>\n            </div>\n\n            <div className=\"lg:col-span-7 bg-[#04060b] rounded-2xl border border-white/10 p-6 flex flex-col justify-between min-h-[240px]\">\n              <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n                <span className=\"text-xs font-mono text-white/40\">Terminal Trace Output</span>\n                <span className=\"w-2.5 h-2.5 rounded-full bg-[#00FF9D] animate-ping\" />\n              </div>\n              <pre className=\"font-mono text-xs text-white/70 leading-relaxed whitespace-pre-wrap flex-grow my-4 font-light\">\n                {simLog}\n              </pre>\n              <button\n                disabled={simulating}\n                onClick={() => runSimulation(activeZone)}\n                className=\"w-full py-2.5 rounded-lg bg-[#00FF9D]/10 border border-[#00FF9D]/30 text-xs font-bold text-[#00FF9D] hover:bg-[#00FF9D]/20 transition-all text-center\"\n              >\n                {simulating ? \"Executing sandbox run...\" : \"Re-Run Sandbox Trace\"}\n              </button>\n            </div>\n          </div>\n        </MotionReveal>\n\n        <PremiumCTA\n          title=\"Start Your Joint Discovery in the Garage\"\n          description=\"Ready to frame your enterprise AI challenge? Contact us to map security guardrails, design cognitive topologies, and test in our labs.\"\n          primaryLabel=\"Schedule Scoping Call\"\n          primaryHref=\"/contact\"\n        />\n\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
