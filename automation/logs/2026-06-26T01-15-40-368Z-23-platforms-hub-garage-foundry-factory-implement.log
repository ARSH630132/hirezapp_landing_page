{"ts":"2026-06-26T01:11:37.089Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"pzjekxmi","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/page.tsx","old_text":"\"use client\";\n\nimport Link from \"next/link\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\n\nexport default function PlatformsHubPage() {\n  const platforms = [\n    {\n      title: \"Foundry Studio\",\n      href: \"/platforms/foundry\",\n      desc: \"Our premium visual DAG workspace where you connect cognitive reasoning cores, relational database ingest hubs, and real-time security guardrails.\",\n      features: [\"Visual Flow Builder\", \"Hot-swap Models\", \"Active Telemetry Logs\", \"SOC2 Secured\"],\n      buttonText: \"Launch Studio View\"\n    },\n    {\n      title: \"GFF Marketplace\",\n      href: \"/platforms/marketplace\",\n      desc: \"An enterprise directory of pre-packaged autonomous agents, specialized compliance guardrails, and dynamic API connector recipes.\",\n      features: [\"Pre-built Agent Clusters\", \"Certified Connectors\", \"One-Click Sandbox Deploy\", \"Audit-Ready Logs\"],\n      buttonText: \"Browse Marketplace\"\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Productized Assets\"\n        title=\"Platforms and Products\"\n        highlightedWord=\"Platforms\"\n        description=\"Access GFF AI's signature developer platforms, visual orchestrators, and pre-packaged agent marketplaces.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n          {platforms.map((plat) => (\n            <div key={plat.title} className=\"p-8 rounded-[24px] border border-white/5 bg-[#050505]/60 backdrop-blur-[12px] flex flex-col justify-between hover:border-[#009DFF]/20 transition-all group\">\n              <div>\n                <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-wider font-bold\">ENTERPRISE PLATFORM</span>\n                <h2 className=\"text-[24px] font-bold text-white tracking-tight mt-2\">{plat.title}</h2>\n                <p className=\"mt-4 text-[14px] leading-[1.6] text-white/70 font-light\">{plat.desc}</p>\n                \n                <ul className=\"mt-6 space-y-2.5\">\n                  {plat.features.map((feat) => (\n                    <li key={feat} className=\"flex items-center gap-2.5 text-[13.5px] text-white/80\">\n                      <svg className=\"w-4 h-4 text-[#009DFF] shrink-0\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n                        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M5 13l4 4L19 7\" />\n                      </svg>\n                      <span className=\"font-light\">{feat}</span>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n\n              <div className=\"mt-8 pt-6 border-t border-white/5\">\n                <Link href={plat.href} className=\"inline-flex w-full h-[48px] items-center justify-center rounded-xl bg-gradient-to-r from-[#E4000F] to-[#009DFF] text-white text-[14.5px] font-semibold hover:opacity-95 transition-opacity\">\n                  {plat.buttonText}\n                </Link>\n              </div>\n            </div>\n          ))}\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"\"use client\";\n\nimport Link from \"next/link\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport EnterpriseFlowDiagram from \"@/components/inner-pages/EnterpriseFlowDiagram\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nexport default function PlatformsHubPage() {\n  const stack = [\n    {\n      title: \"FACTORY LAYER (Tier 3)\",\n      subtitle: \"Scale, Monitor, Operate, Monetize\",\n      desc: \"Governance & Industrialisation. Deploy agent clusters, track costs, and audit compliance.\",\n      href: \"/platforms/factory\",\n      color: \"border-[#FF3B30]/20 hover:bg-[#FF3B30]/5\",\n      badge: \"Industrialisation\",\n    },\n    {\n      title: \"FOUNDRY LAYER (Tier 2)\",\n      subtitle: \"Build Agents, Runtime, Data Fabric, AI Engineering\",\n      desc: \"Co-creation & Orchestration. Build agent DAGs, stream database pipelines, and execute inside secure runtime.\",\n      href: \"/platforms/foundry\",\n      color: \"border-[#009DFF]/20 hover:bg-[#009DFF]/5\",\n      badge: \"Co-Creation\",\n    },\n    {\n      title: \"GARAGE LAYER (Tier 1)\",\n      subtitle: \"Discover AI, Workshops, AI Labs, Experiment Zone\",\n      desc: \"Innovation & Framing. Transform enterprise objectives into executable technical blueprints and test in our experiment sandbox.\",\n      href: \"/platforms/garage\",\n      color: \"border-[#00FF9D]/20 hover:bg-[#00FF9D]/5\",\n      badge: \"Innovation\",\n    }\n  ];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Productized Assets\"\n        title=\"Enterprise Platforms\"\n        highlightedWord=\"Platforms\"\n        description=\"GFF AI delivers secure sovereign software platforms to build, audit, and run multi-agent cognitive systems.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">ARCHITECTURE</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white mt-2\">The GFF Operating Stack</h2>\n          </div>\n\n          <div className=\"max-w-[900px] mx-auto space-y-4\">\n            {stack.map((layer) => (\n              <div key={layer.title} className={`p-6 rounded-[20px] border bg-[#050505]/80 backdrop-blur-[12px] flex flex-col md:flex-row md:items-center justify-between transition-all duration-300 group ${layer.color}`}>\n                <div className=\"space-y-2 md:max-w-[70%]\">\n                  <span className=\"text-[9px] font-mono font-bold uppercase py-0.5 px-2 bg-white/5 rounded-full border border-white/5 text-white/60\">{layer.badge}</span>\n                  <h3 className=\"text-[18px] font-bold text-white\">{layer.title}</h3>\n                  <p className=\"text-[13px] leading-[1.5] text-white/60 font-light\">{layer.desc}</p>\n                </div>\n                <div className=\"mt-4 md:mt-0 flex flex-col items-start md:items-end shrink-0 gap-2\">\n                  <span className=\"text-[11px] font-mono text-white/40\">{layer.subtitle}</span>\n                  <Link href={layer.href} className=\"inline-flex h-[36px] px-4 items-center justify-center rounded-lg bg-white/5 border border-white/10 text-white text-[12px] font-semibold hover:bg-white/10 transition-all\">Launch Specs →</Link>\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">COMPLIANCE EDGE</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white mt-2\">Industry Mesh Layers</h2>\n          </div>\n          <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            {[\n              { title: \"Financial Sovereign Mesh\", desc: \"Hardened transactional intelligence designed for international banking and risk controls.\", specs: [\"SEC & FINRA Compliant\", \"Audit Logs\"] },\n              { title: \"Healthcare Secure Mesh\", desc: \"Strictly isolated clinical-grade agent pipelines mapping patient pathways with zero-PII leakage.\", specs: [\"HIPAA-Hardened\", \"PII-Scrubbed\"] },\n              { title: \"Government Sovereign Mesh\", desc: \"Sovereign intelligence grids serving public administrations, defense operations, and air-gapped nodes.\", specs: [\"FedRAMP-Ready\", \"Air-Gapped\"] },\n              { title: \"Energy & Utilities Mesh\", desc: \"Robust agent grids for utility optimization, SCADA telemetry parsing, and predictive safety.\", specs: [\"SCADA Integration\", \"Grid Safeguards\"] }\n            ].map((mesh) => (\n              <div key={mesh.title} className=\"p-6 rounded-[20px] border border-white/5 bg-[#030304]/80 flex flex-col justify-between\">\n                <div>\n                  <h3 className=\"text-[16px] font-bold text-white\">{mesh.title}</h3>\n                  <p className=\"mt-2 text-[13px] leading-[1.45] text-white/50 font-light\">{mesh.desc}</p>\n                </div>\n                <div className=\"mt-4 pt-4 border-t border-white/5 flex gap-2\">\n                  {mesh.specs.map((spec) => (\n                    <span key={spec} className=\"px-2 py-0.5 rounded text-[9px] font-mono bg-white/[0.02] border border-white/5 text-white/60\">{spec}</span>\n                  ))}\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        <MotionReveal direction=\"up\" className=\"space-y-8\">\n          <div className=\"text-center max-w-[800px] mx-auto\">\n            <span className=\"text-[10px] uppercase font-mono text-[#009DFF] tracking-[0.2em] font-bold\">SOVEREIGN TRUST</span>\n            <h2 className=\"text-[28px] sm:text-[36px] font-bold text-white mt-2\">Active Control & Governance</h2>\n          </div>\n          <div className=\"max-w-[1100px] mx-auto\">\n            <EnterpriseFlowDiagram />\n          </div>\n        </MotionReveal>\n\n        <MotionReveal direction=\"up\">\n          <PremiumCTA\n            title=\"Design Your Multi-Agent Topology\"\n            description=\"Consult with a GFF systems architect to build, scope, and prototype a private sovereign cluster suited for your legal frameworks.\"\n            primaryLabel=\"Book Architectural Session\"\n            primaryHref=\"/contact\"\n            secondaryLabel=\"Explore Technology Philosophy\"\n            secondaryHref=\"/why-gff-ai/technology-philosophy\"\n          />\n        </MotionReveal>\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
