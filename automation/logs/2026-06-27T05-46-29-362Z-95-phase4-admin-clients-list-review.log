{"ts":"2026-06-27T05:42:02.417Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"4yu88vhe","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/clients/[id]/page.tsx","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { \n  ArrowLeft, Shield, ShieldCheck, Cpu, Clock, Layers, \n  Bot, Terminal, RefreshCw, AlertTriangle, Users, BadgeCheck\n} from \"lucide-react\";\nimport { previewClientAccounts, previewProjects } from \"@/lib/mock-data-model\";\n\nexport default function AdminClientDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const clientId = typeof id === \"string\" ? id : \"client-001\";\n  const client = previewClientAccounts.find(c => c.id === clientId) || previewClientAccounts[0];\n  const clientProjects = previewProjects.filter(p => p.clientAccountId === client.id);\n\n  const [activeTab, setActiveTab] = useState<\"telemetry\" | \"compliance\">(\"telemetry\");\n  const [isRotating, setIsRotating] = useState(false);\n  const [isScanning, setIsScanning] = useState(false);\n  const [logs, setLogs] = useState<string[]>([\n    `[${new Date().toLocaleTimeString()}] ADMIN_INIT: Oversight session opened for ${client.id.toUpperCase()}`,\n    `[${new Date().toLocaleTimeString()}] SECURE_LINK: TLS 1.3 bound to: ${client.domain}`,\n    `[${new Date().toLocaleTimeString()}] ATTESTATION: Root HSM status verified.`\n  ]);\n\n  const addLog = (msg: string) => {\n    setLogs(p => [...p, `[${new Date().toLocaleTimeString()}] ${msg}`]);\n  };\n\n  const handleRotate = () => {\n    if (isRotating || isScanning) return;\n    setIsRotating(true);\n    addLog(\"HSM_KEY_ROLLOVER: Initiating ephemeral key rotation...\");\n    setTimeout(() => {\n      addLog(\"HSM_KEY_ROLLOVER: Generated 4096-bit NTRU params.\");\n      setTimeout(() => {\n        addLog(\"HSM_KEY_ROLLOVER: SUCCESS - New root seal: SHA-0x8A12FF\");\n        setIsRotating(false);\n      }, 500);\n    }, 500);\n  };\n\n  const handleScan = () => {\n    if (isRotating || isScanning) return;\n    setIsScanning(true);\n    addLog(\"COMPLIANCE_SCAN: Triggered kernel boundary audit...\");\n    setTimeout(() => {\n      addLog(\"COMPLIANCE_SCAN: Checked AMD SEV-SNP register integrity.\");\n      setTimeout(() => {\n        addLog(`COMPLIANCE_SCAN: COMPLETED - Certified: ${client.complianceLevel}`);\n        setIsScanning(false);\n      }, 500);\n    }, 500);\n  };\n\n  return (\n    <div className=\"space-y-6 font-mono text-xs\">\n      \n      {/* HEADER */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-white/5 pb-4\">\n        <div className=\"flex items-center gap-3\">\n          <button\n            onClick={() => router.push(\"/admin/clients\")}\n            className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded uppercase\">\n              Oversight: {client.id.toUpperCase()}\n            </span>\n            <h2 className=\"text-lg font-bold text-white uppercase mt-1 flex items-center gap-2\">\n              <span>{client.name.replace(\" [Preview Client]\", \"\")}</span>\n              {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400\" />}\n            </h2>\n          </div>\n        </div>\n\n        <button\n          onClick={() => {\n            const sess = {\n              name: client.contactName,\n              email: client.contactEmail,\n              role: \"client_admin\",\n              clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\",\n              isMock: true,\n              label: `PORTAL PREVIEW - ${client.name.toUpperCase()}`\n            };\n            localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify(sess));\n            window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n            router.push(\"/portal/dashboard\");\n          }}\n          className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] font-bold uppercase text-white flex items-center gap-1.5 transition-all cursor-pointer border-none\"\n        >\n          <span>Mirror Portal</span>\n        </button>\n      </div>\n\n      {/* BODY */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* LEFT COLUMN */}\n        <div className=\"lg:col-span-2 space-y-6\">\n          <div className=\"flex bg-black/20 p-1 rounded-lg border border-white/5\">\n            <button\n              onClick={() => setActiveTab(\"telemetry\")}\n              className={`flex-1 py-1.5 rounded font-bold uppercase transition-all text-center cursor-pointer border-none ${\n                activeTab === \"telemetry\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"\n              }`}\n            >\n              Partition Telemetry\n            </button>\n            <button\n              onClick={() => setActiveTab(\"compliance\")}\n              className={`flex-1 py-1.5 rounded font-bold uppercase transition-all text-center cursor-pointer border-none ${\n                activeTab === \"compliance\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"\n              }`}\n            >\n              Boundary Compliance\n            </button>\n          </div>\n\n          {activeTab === \"telemetry\" ? (\n            <div className=\"space-y-6\">\n              {/* BENTO */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-1.5\">\n                  <div className=\"flex justify-between border-b border-white/5 pb-1 font-bold text-white/40 uppercase text-[9px]\">\n                    <span>Scope bounds</span>\n                    <Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  </div>\n                  <div>Tier: <span className=\"text-amber-300 font-bold uppercase\">{client.tier}</span></div>\n                  <div>Region: <span className=\"text-white font-semibold\">{client.region}</span></div>\n                  <div className=\"truncate\">Domain: <span className=\"text-[#009DFF]\">{client.domain}</span></div>\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-1.5\">\n                  <div className=\"flex justify-between border-b border-white/5 pb-1 font-bold text-white/40 uppercase text-[9px]\">\n                    <span>Hardware bounds</span>\n                    <Lock className=\"w-3.5 h-3.5 text-emerald-400\" />\n                  </div>\n                  <div>CPU cores: <span className=\"text-[#00FFC2] font-bold\">128 Cores</span></div>\n                  <div>Enclave isolation: <span className=\"text-white\">AMD SEV-SNP</span></div>\n                  <div>eBPF filtering: <span className=\"text-white\">Active</span></div>\n                </div>\n              </div>\n\n              {/* PROJECTS LIST */}\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2 text-white/40\">\n                  <Layers className=\"w-4 h-4 text-[#009DFF]\" />\n                  <span className=\"font-bold uppercase\">Associated projects ({clientProjects.length})</span>\n                </div>\n                {clientProjects.length === 0 ? (\n                  <div className=\"text-center py-2 text-white/30\">No active projects allocated.</div>\n                ) : (\n                  <div className=\"space-y-2\">\n                    {clientProjects.map(p => (\n                      <div key={p.id} className=\"flex justify-between items-center p-2 rounded bg-white/[0.01] border border-white/5\">\n                        <div>\n                          <div className=\"font-bold text-white uppercase\">{p.name}</div>\n                          <span className=\"text-[#009DFF] text-[10px]\">{p.id.toUpperCase()}</span>\n                        </div>\n                        <span className=\"rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1.5 py-0.5 font-bold uppercase text-[9px]\">{p.status}</span>\n                      </div>\n                    ))}\n                  </div>\n                )}\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-6\">\n              {/* SVG DIAGRAM */}\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px]\">HSM Boundary Airgap mapping</span>\n                <div className=\"relative h-[150px] bg-black/60 rounded-lg border border-white/5 flex items-center justify-center overflow-hidden\">\n                  <svg className=\"w-full h-full max-w-[320px]\" viewBox=\"0 0 300 150\">\n                    <path d=\"M 50 75 C 100 20, 200 20, 250 75\" fill=\"none\" stroke=\"#00FFC2\" strokeWidth=\"2\" strokeDasharray=\"10 30\" className=\"animate-[dash_3s_linear_infinite]\" />\n                    <path d=\"M 50 75 C 100 130, 200 130, 250 75\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n                    <g transform=\"translate(150, 75)\"><circle r=\"20\" fill=\"#030303\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-pulse\" /><text y=\"3\" textAnchor=\"middle\" fill=\"#00FFC2\" fontSize=\"7\" fontWeight=\"bold\">HSM_CORE</text></g>\n                    <g transform=\"translate(50, 75)\"><circle r=\"10\" fill=\"#050505\" stroke=\"#009DFF\" strokeWidth=\"1\" /><text y=\"2.5\" textAnchor=\"middle\" fill=\"#009DFF\" fontSize=\"5\" fontWeight=\"bold\">SOCKET</text></g>\n                    <g transform=\"translate(250, 75)\"><circle r=\"10\" fill=\"#050505\" stroke=\"#a855f7\" strokeWidth=\"1\" /><text y=\"2.5\" textAnchor=\"middle\" fill=\"#a855f7\" fontSize=\"5\" fontWeight=\"bold\">LATTICE</text></g>\n                  </svg>\n                </div>\n              </div>\n\n              {/* COMPLIANCE CHECKLIST */}\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1.5\">Continuous Compliance Checklist</span>\n                <div className=\"space-y-2 text-[10.5px]\">\n                  <div className=\"flex items-center gap-2 text-emerald-400 font-bold\"><ShieldCheck className=\"w-4 h-4 shrink-0\" /> [01] HSM KEY VERIFICATION SUCCESSFUL</div>\n                  <div className=\"flex items-center gap-2 text-emerald-400 font-bold\"><ShieldCheck className=\"w-4 h-4 shrink-0\" /> [02] eBPF KERNEL BOUNDARY ENFORCED</div>\n                  <div className=\"flex items-center gap-2 text-blue-400 font-bold animate-pulse\"><Clock className=\"w-4 h-4 shrink-0\" /> [03] ATTESTATION LEDGER SEAL LIVE RUNNING</div>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        {/* RIGHT COLUMN */}\n        <div className=\"space-y-6\">\n          {/* ACTIONS */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n            <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1\">Administrative Actions</span>\n            <div className=\"space-y-2\">\n              <button\n                onClick={handleRotate}\n                disabled={isRotating || isScanning}\n                className={`w-full h-9 rounded border text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1.5 cursor-pointer transition-all ${\n                  isRotating ? \"bg-[#00FFC2]/10 text-[#00FFC2] border-[#00FFC2]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"\n                }`}\n              >\n                <RefreshCw className={`w-3 h-3 text-[#00FFC2] ${isRotating ? \"animate-spin\" : \"\"}`} />\n                <span>{isRotating ? \"Rotating key...\" : \"Rotate HSM Keys\"}</span>\n              </button>\n\n              <button\n                onClick={handleScan}\n                disabled={isRotating || isScanning}\n                className={`w-full h-9 rounded border text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1.5 cursor-pointer transition-all ${\n                  isScanning ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"\n                }`}\n              >\n                <Shield className={`w-3 h-3 text-[#009DFF] ${isScanning ? \"animate-pulse\" : \"\"}`} />\n                <span>{isScanning ? \"Auditing...\" : \"Execute Boundary Scan\"}</span>\n              </button>\n            </div>\n            <div className=\"flex items-start gap-1.5 text-[9px] text-white/30 p-2.5 rounded bg-white/[0.01] border border-white/5 leading-relaxed\">\n              <AlertTriangle className=\"w-3.5 h-3.5 text-amber-500 shrink-0 mt-0.5\" />\n              <span>Oversight actions operate at root hypervisor levels and bypass standard customer locks.</span>\n            </div>\n          </div>\n\n          {/* TELEMETRY HUD */}\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-2.5 flex flex-col h-[180px]\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n              <span className=\"font-bold text-white/40 uppercase text-[9px] flex items-center gap-1\