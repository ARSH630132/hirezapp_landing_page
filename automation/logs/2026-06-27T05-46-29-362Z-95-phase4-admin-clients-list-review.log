me=\"w-4 h-4\" /></button>\n          <div>\n            <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded uppercase\">Oversight: {client.id.toUpperCase()}</span>\n            <h2 className=\"text-lg font-bold text-white uppercase mt-1\">{client.name.replace(\" [Preview Client]\", \"\")}</h2>\n          </div>\n        </div>\n        <button onClick={() => {\n          localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify({\n            name: client.contactName, email: client.contactEmail, role: \"client_admin\", clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\", isMock: true, label: `PORTAL PREVIEW - ${client.name.toUpperCase()}`\n          }));\n          window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n          router.push(\"/portal/dashboard\");\n        }} className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] font-bold uppercase text-white cursor-pointer border-none\">Mirror Portal</button>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 space-y-6\">\n          <div className=\"flex bg-black/20 p-1 rounded-lg border border-white/5\">\n            <button onClick={() => setTab(\"data\")} className={`flex-1 py-1.5 rounded font-bold uppercase cursor-pointer border-none ${tab === \"data\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"}`}>Telemetry</button>\n            <button onClick={() => setTab(\"map\")} className={`flex-1 py-1.5 rounded font-bold uppercase cursor-pointer border-none ${tab === \"map\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"}`}>Boundary Map</button>\n          </div>\n\n          {tab === \"data\" ? (\n            <div className=\"space-y-6\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-1.5\">\n 