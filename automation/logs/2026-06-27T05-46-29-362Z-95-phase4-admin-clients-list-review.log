>\n              </div>\n            </div>\n          )}\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n            <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1\">Administrative Actions</span>\n            <div className=\"space-y-2\">\n              <button onClick={handleRotate} disabled={isRotating || isScanning} className={`w-full h-9 rounded border text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1.5 cursor-pointer transition-all ${isRotating ? \"bg-[#00FFC2]/10 text-[#00FFC2] border-[#00FFC2]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"}`}>\n                <RefreshCw className={`w-3 h-3 text-[#00FFC2] ${isRotating ? \"animate-spin\" : \"\"}`} />\n                <span>{isRotating ? \"Rotating key...\" : \"Rotate HSM Keys\"}</span>\n              </button>\n              <button onClick={handleScan} disabled={isRotating || isScanning} className={`w-full h-9 rounded border text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1.5 cursor-pointer transition-all ${isScanning ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"}`}>\n                <Shield className={`w-3 h-3 text-[#009DFF] ${isScanning ? \"animate-pulse\" : \"\"}`} />\n                <span>{isScanning ? \"Auditing...\" : \"Execute Boundary Scan\"}</span>\n              </button>\n            </div>\n            <div className=\"flex items-start gap-1.5 text-[9px] text-white/30 p-2.5 rounded bg-white/[0.01] border border-white/5 leading-relaxed\">\n              <AlertTriangle className=\"w-3.5 h-3.5 text-amber-500 shrink-0 mt-0.5\" />\n              <span>Oversight actions operate at root levels and bypass standard customer seals.</span>\n            </div>\n          </div>\n\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-2.5 flex flex-col h-[180px]\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n              <span className=\"font-bold text-white/40 uppercase text-[9px] flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5 text-emerald-400\" /> Oversight Console</span>\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n            </div>\n            <div className=\"flex-1 bg-black/50 border border-white/5 rounded p-2 text-[9px] text-emerald-400/80 space-y-1 overflow-y-auto font-mono text-left select-text\">\n              {logs.map((l, i) => <div key={i} className=\"truncate\">&gt; {l}</div>)}\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
