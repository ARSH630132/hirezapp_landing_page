D</span>\n              </div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">\n                Hardware modules are completely verified, running real-time TLS 1.3 decapsulated loops under dual-layer HSM protocols.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { ArrowLeft, Shield, ShieldCheck, Cpu, Clock, Layers, Terminal, RefreshCw } from \"lucide-react\";\nimport { previewClientAccounts, previewProjects } from \"@/lib/mock-data-model\";\n\nexport default function AdminClientDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const client = previewClientAccounts.find(c => c.id === id) || previewClientAccounts[0];\n  const clientProjects = previewProjects.filter(p => p.clientAccountId === client.id);\n\n  const [tab, setTab] = useState<\"data\" | \"map\">(\"data\");\n  const [rotating, setRotating] = useState(false);\n  const [logs, setLogs] = useState<string[]>([`Secure link bound.`, `HSM state verified.`]);\n\n  return (\n    <div className=\"space-y-6 font-mono text-xs\">\n      <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n        <div className=\"flex items-center gap-3\">\n          <button onClick={() => router.push(\"/admin/clients\")} className=\"p-1 rounded border border-white/5 text-white/50 hover:text-white cursor-pointer\"><ArrowLeft className=\"w-4 h-4\" /></button>\n          <div>\n            <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20 uppercase\">Oversight: {client.id.toUpperCase()}</span>\n            <h2 className=\"text-base font-bold text-white uppercase mt-1\">{client.name.replace(\" [Preview Client]\", \"\")}</h2>\n          </div>\n        </div>\n        <button onClick={() => {\n          localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify({\n            name: client.contactName, email: client.contactEmail, role: \"client_admin\", clearance: \"CLEARANCE LEVEL III\", isMock: true, label: `PREVIEW - ${client.name.toUpperCase()}`\n          }));\n          window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n          router.push(\"/portal/dashboard\");\n        }} className=\"h-7 px-2.5 rounded bg-[#009DFF] text-white cursor-pointer font-bold border-none text-[10px] uppercase\">Mirror Portal</button>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 space-y-6\">\n          <div className=\"flex bg-black/20 p-1 rounded border border-white/5\">\n            <button onClick={() => setTab(\"data\")} className={`flex-1 py-1 rounded cursor-pointer border-none font-bold uppercase ${tab === \"data\" ? \"bg-[#009DFF]/10 text-white\" : \"text-white/40 bg-transparent\"}`}>Telemetry</button>\n            <button onClick={() => setTab(\"map\")} className={`flex-1 py-1 rounded cursor-pointer border-none font-bold uppercase ${tab === \"map\" ? \"bg-[#009DFF]/10 text-white\" : \"text-white/40 bg-transparent\"}`}>Enclave Map</button>\n          </div>\n\n          {tab === \"data\" ? (\n            <div className=\"space-y-4\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-1\">\n                  <div className=\"border-b border-white/5 pb-1 font-bold text-white/40 text-[9px] uppercase\">Scope</div>\n                  <div>Tier: <span className=\"text-amber-300 font-bold uppercase\">{client.tier}</span></div>\n                  <div>Region: <span className=\"text-white\">{client.region}</span></div>\n                  <div className=\"truncate\">Domain: <span className=\"text-[#009DFF]\">{client.domain}</span></div>\n                </div>\n                <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-1\">\n                  <div className=\"border-b border-white/5 pb-1 font-bold text-white/40 text-[9px] uppercase\">Hardware</div>\n                  <div>Cores: <span className=\"text-[#00FFC2] font-bold\">128 Cores</span></div>\n                  <div>Enclave: <span className=\"text-white\">AMD SEV-SNP</span></div>\n                  <div>Compliance: <span className=\"text-white truncate\">{client.complianceLevel}</span></div>\n                </div>\n              </div>\n\n              <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-2\">\n                <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-1.5 text-white/40 font-bold uppercase\"><Layers className=\"w-3.5 h-3.5\" /> Associated Projects ({clientProjects.length})</div>\n                {clientProjects.length === 0 ? <div className=\"text-white/30 text-center\">No active projects.</div> : (\n                  <div className=\"space-y-1.5\">{clientProjects.map(p => (\n                    <div key={p.id} className=\"flex justify-between items-center p-2 rounded bg-white/[0.01] border border-white/5\">\n                      <div><div className=\"font-bold text-white uppercase\">{p.name}</div><span className=\"text-[#009DFF] text-[10px]\">{p.id.toUpperCase()}</span></div>\n                      <span className=\"rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1 py-0.5 font-bold uppercase text-[9px]\">{p.status}</span>\n                    </div>\n                  ))}</div>\n                )}\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-4\">\n              <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-2\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px]\">HSM Boundary Airgap mapping</span>\n                <div className=\"relative h-[110px] bg-black/60 rounded border border-white/5 flex items-center justify-center\">\n                  <svg className=\"w-full h-full max-w-[260px]\" viewBox=\"0 0 300 150\">\n                    <path d=\"M 50 75 C 100 20, 200 20, 250 75\" fill=\"none\" stroke=\"#00FFC2\" strokeWidth=\"2\" strokeDasharray=\"10 30\" className=\"animate-[dash_3s_linear_infinite]\" />\n                    <g transform=\"translate(150, 75)\"><circle r=\"16\" fill=\"#030303\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" /><text y=\"2\" textAnchor=\"middle\" fill=\"#00FFC2\" fontSize=\"6\" fontWeight=\"bold\">HSM_CORE</text></g>\n                    <g transform=\"translate(50, 75)\"><circle r=\"8\" fill=\"#050505\" stroke=\"#009DFF\" strokeWidth=\"1\" /></g>\n                    <g transform=\"translate(250, 75)\"><circle r=\"8\" fill=\"#050505\" stroke=\"#a855f7\" strokeWidth=\"1\" /></g>\n                  </svg>\n                </div>\n              </div>\n              <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-2\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1\">Continuous Compliance</span>\n                <div className=\"space-y-1.5 text-[10px]\">\n                  <div className=\"flex items-center gap-1.5 text-emerald-400 font-bold\"><ShieldCheck className=\"w-3.5 h-3.5\" /> [01] HSM KEY VERIFICATION PASSED</div>\n                  <div className=\"flex items-center gap-1.5 text-emerald-400 font-bold\"><ShieldCheck className=\"w-3.5 h-3.5\" /> [02] eBPF KERNEL ENFORCED</div>\n                  <div className=\"flex items-center gap-1.5 text-blue-400 font-bold animate-pulse\"><Clock className=\"w-3.5 h-3.5\" /> [03] ATTESTATION LEDGER SEAL ACTIVE</div>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-3\">\n            <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1\">Controls</span>\n            <button onClick={() => {\n              if (rotating) return;\n              setRotating(true);\n              setLogs(p => [...p, `HSM_KEY_ROLLOVER: Initiated...`]);\n              setTimeout(() => {\n                setLogs(p => [...p, `SUCCESS - New key SHA-0x8A12FF`]);\n                setRotating(false);\n              }, 800);\n            }} disabled={rotating} className=\"w-full h-8 rounded border border-white/10 hover:border-white/20 text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1 cursor-pointer transition-all bg-white/[0.01]\">\n              <RefreshCw className={`w-3 h-3 text-[#00FFC2] ${rotating ? \"animate-spin\" : \"\"}`} />\n              <span>{rotating ? \"Rotating...\" : \"Rotate HSM Keys\"}</span>\n            </button>\n          </div>\n\n          <div className=\"p-4 rounded border border-white/5 bg-[#050505]/40 space-y-2 flex flex-col h-[150px]\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n              <span className=\"font-bold text-white/40 uppercase text-[9px] flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5 text-emerald-400\" /> Oversight Console</span>\n            </div>\n            <div className=\"flex-1 bg-black/50 border border-white/5 rounded p-2 text-[9px] text-emerald-400/80 space-y-1 overflow-y-auto select-text text-left\">\n              {logs.map((l, i) => <div key={i} className=\"truncate\">&gt; {l}</div>)}\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
