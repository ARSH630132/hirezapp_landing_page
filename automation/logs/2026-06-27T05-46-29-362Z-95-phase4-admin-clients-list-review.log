-4 text-[12px] font-mono text-white/70\">\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Secure Enclave Plan:</span>\n                <span className=\"text-white font-bold\">Enterprise Infinite</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Active CPU Threads:</span>\n                <span className=\"text-[#00FFC2] font-bold\">128 Live Loops</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Sovereign Domain Namespace:</span>\n                <span className=\"text-white\">sovereign-retail.gff.ai</span>\n              </div>\n              <div className=\"p-3 bg-black/30 border border-white/5 rounded-lg flex justify-between\">\n                <span className=\"text-white/40\">Data Boundary Isolation:</span>\n                <span className=\"text-white\">eBPF Kernel Enforced</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n              <ShieldCheck className=\"w-4.5 h-4.5 text-green-400\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">HSM Security State</h3>\n            </div>\n            <div className=\"space-y-3 font-mono text-[11px]\">\n              <div className=\"p-3 bg-green-500/5 border border-green-500/20 text-green-400 font-bold rounded flex items-center justify-between\">\n                <span>SOC2 CERTIFICATION:</span>\n                <span>VERIFIED</span>\n              </div>\n              <p className=\"text-[10px] text-white/40 leading-relaxed\">\n                Hardware modules are completely verified, running real-time TLS 1.3 decapsulated loops under dual-layer HSM protocols.\n              </p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}","new_text":"\"use client\";\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { ArrowLeft, Shield, ShieldCheck, Cpu, Clock, Layers, Terminal, RefreshCw, AlertTriangle, BadgeCheck } from \"lucide-react\";\nimport { previewClientAccounts, previewProjects } from \"@/lib/mock-data-model\";\n\nexport default function AdminClientDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const clientId = typeof id === \"string\" ? id : \"client-001\";\n  const client = previewClientAccounts.find(c => c.id === clientId) || previewClientAccounts[0];\n  const clientProjects = previewProjects.filter(p => p.clientAccountId === client.id);\n\n  const [tab, setTab] = useState<\"telemetry\" | \"compliance\">(\"telemetry\");\n  const [rotating, setRotating] = useState(false);\n  const [logs, setLogs] = useState<string[]>([\n    `[${new Date().toLocaleTimeString()}] Secure link bound to: ${client.domain}`,\n    `[${new Date().toLocaleTimeString()}] Root HSM state verified.`\n  ]);\n\n  const runRotate = () => {\n    if (rotating) return;\n    setRotating(true);\n    setLogs(p => [...p, `[${new Date().toLocaleTimeString()}] HSM_KEY_ROLLOVER: Initiated...`]);\n    setTimeout(() => {\n      setLogs(p => [...p, `[${new Date().toLocaleTimeString()}] SUCCESS - New root seal: SHA-0x8A12FF`]);\n      setRotating(false);\n    }, 800);\n  };\n\n  return (\n    <div className=\"space-y-6 font-mono text-xs\">\n      <div className=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-white/5 pb-4\">\n        <div className=\"flex items-center gap-3\">\n          <button onClick={() => router.push(\"/admin/clients\")} className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer\"><ArrowLeft className=\"w-4 h-4\" /></button>\n          <div>\n            <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded uppercase\">Oversight: {client.id.toUpperCase()}</span>\n            <h2 className=\"text-lg font-bold text-white uppercase mt-1 flex items-center gap-1.5\">\n              <span>{client.name.replace(\" [Preview Client]\", \"\")}</span>\n              {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400\" />}\n            </h2>\n          </div>\n        </div>\n        <button onClick={() => {\n          localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify({\n            name: client.contactName, email: client.contactEmail, role: \"client_admin\", clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\", isMock: true, label: `PORTAL PREVIEW - ${client.name.toUpperCase()}`\n          }));\n          window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n          router.push(\"/portal/dashboard\");\n        }} className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] font-bold uppercase text-white cursor-pointer border-none\">Mirror Portal</button>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 space-y-6\">\n          <div className=\"flex bg-black/20 p-1 rounded-lg border border-white/5\">\n            <button onClick={() => setTab(\"data\")} className={`flex-1 py-1.5 rounded font-bold uppercase cursor-pointer border-none ${tab === \"data\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"}`}>Telemetry</button>\n            <button onClick={() => setTab(\"map\")} className={`flex-1 py-1.5 rounded font-bold uppercase cursor-pointer border-none ${tab === \"map\" ? \"bg-[#009DFF]/10 text-white\" : \"bg-transparent text-white/40\"}`}>Boundary Map</button>\n          </div>\n\n          {tab === \"data\" ? (\n            <div className=\"space-y-6\">\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-1.5\">\n                  <div className=\"flex justify-between border-b border-white/5 pb-1 font-bold text-white/40 uppercase text-[9px]\"><span>Scope</span><Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" /></div>\n                  <div>Tier: <span className=\"text-amber-300 font-bold uppercase\">{client.tier}</span></div>\n                  <div>Region: <span className=\"text-white\">{client.region}</span></div>\n                  <div className=\"truncate\">Domain: <span className=\"text-[#009DFF]\">{client.domain}</span></div>\n                </div>\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-1.5\">\n                  <div className=\"flex justify-between border-b border-white/5 pb-1 font-bold text-white/40 uppercase text-[9px]\"><span>Hardware</span><ShieldCheck className=\"w-3.5 h-3.5 text-emerald-400\" /></div>\n                  <div>Cores: <span className=\"text-[#00FFC2] font-bold\">128 Threads</span></div>\n                  <div>Isolation: <span className=\"text-white\">AMD SEV-SNP</span></div>\n                  <div>Compliance: <span className=\"text-white\">{client.complianceLevel}</span></div>\n                </div>\n              </div>\n\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2 text-white/40\"><Layers className=\"w-4 h-4 text-[#009DFF]\" /><span className=\"font-bold uppercase\">Associated Projects ({clientProjects.length})</span></div>\n                {clientProjects.length === 0 ? <div className=\"text-center py-2 text-white/30\">No active projects allocated.</div> : (\n                  <div className=\"space-y-2\">{clientProjects.map(p => (\n                    <div key={p.id} className=\"flex justify-between items-center p-2 rounded bg-white/[0.01] border border-white/5\">\n                      <div><div className=\"font-bold text-white uppercase\">{p.name}</div><span className=\"text-[#009DFF] text-[10px]\">{p.id.toUpperCase()}</span></div>\n                      <span className=\"rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1.5 py-0.5 font-bold uppercase text-[9px]\">{p.status}</span>\n                    </div>\n                  ))}</div>\n                )}\n              </div>\n            </div>\n          ) : (\n            <div className=\"space-y-6\">\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px]\">HSM Boundary Airgap mapping</span>\n                <div className=\"relative h-[120px] bg-black/60 rounded-lg border border-white/5 flex items-center justify-center overflow-hidden\">\n                  <svg className=\"w-full h-full max-w-[280px]\" viewBox=\"0 0 300 150\">\n                    <path d=\"M 50 75 C 100 20, 200 20, 250 75\" fill=\"none\" stroke=\"#00FFC2\" strokeWidth=\"2\" strokeDasharray=\"10 30\" className=\"animate-[dash_3s_linear_infinite]\" />\n                    <path d=\"M 50 75 C 100 130, 200 130, 250 75\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1\" strokeDasharray=\"4 4\" />\n                    <g transform=\"translate(150, 75)\"><circle r=\"18\" fill=\"#030303\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-pulse\" /><text y=\"2.5\" textAnchor=\"middle\" fill=\"#00FFC2\" fontSize=\"6\" fontWeight=\"bold\">HSM_CORE</text></g>\n                    <g transform=\"translate(50, 75)\"><circle r=\"8\" fill=\"#050505\" stroke=\"#009DFF\" strokeWidth=\"1\" /><text y=\"2\" textAnchor=\"middle\" fill=\"#009DFF\" fontSize=\"4\" fontWeight=\"bold\">SOCKET</text></g>\n                    <g transform=\"translate(250, 75)\"><circle r=\"8\" fill=\"#050505\" stroke=\"#a855f7\" strokeWidth=\"1\" /><text y=\"2\" textAnchor=\"middle\" fill=\"#a855f7\" fontSize=\"4\" fontWeight=\"bold\">LATTICE</text></g>\n                  </svg>\n                </div>\n              </div>\n\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1.5\">Continuous Compliance Checklist</span>\n                <div className=\"space-y-2 text-[10.5px]\">\n                  <div className=\"flex items-center gap-2 text-emerald-400 font-bold\"><ShieldCheck className=\"w-4 h-4 shrink-0\" /> [01] HSM KEY VERIFICATION SUCCESSFUL</div>\n                  <div className=\"flex items-center gap-2 text-emerald-400 font-bold\"><ShieldCheck className=\"w-4 h-4 shrink-0\" /> [02] eBPF KERNEL BOUNDARY ENFORCED</div>\n                  <div className=\"flex items-center gap-2 text-blue-400 font-bold animate-pulse\"><Clock className=\"w-4 h-4 shrink-0\" /> [03] ATTESTATION LEDGER SEAL LIVE RUNNING</div>\n                </div>\n              </div>\n            </div>\n          )}\n        </div>\n\n        <div className=\"space-y-6\">\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n            <span className=\"font-bold text-white/40 uppercase text-[9px] block border-b border-white/5 pb-1\">Administrative Controls</span>\n            <button onClick={runRotate} disabled={rotating} className={`w-full h-9 rounded border text-[9px] font-bold uppercase text-white flex items-center justify-center gap-1.5 cursor-pointer transition-all ${rotating ? \"bg-[#00FFC2]/10 text-[#00FFC2] border-[#00FFC2]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"}`}>\n              <RefreshCw className={`w-3 h-3 text-[#00FFC2] ${rotating ? \"animate-spin\" : \"\"}`} />\n              <span>{rotating ? \"Rotating...\" : \"Rotate HSM Keys\"}</span>\n            </button>\n            <div className=\"flex items-start gap-1.5 text-[9px] text-white/30 p-2.5 rounded bg-white/[0.01] border border-white/5 leading-relaxed\">\n              <Shield className=\"w-3.5 h-3.5 text-amber-500 shrink-0\" />\n              <span>Oversight actions operate at root hypervisor levels and bypass standard customer seals.</span>\n            </div>\n          </div>\n\n          <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-2.5 flex flex-col h-[180px]\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n              <span className=\"font-bold text-white/40 uppercase text-[9px] flex items-center gap-1\"><Terminal className=\"w-3.5 h-3.5 text-emerald-400\" /> Oversight Console</span>\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n            </div>\n            <div className=\"flex-1 bg-black/50 border border-white/5 rounded p-2 text-[9px] text-emerald-400/80 space-y-1 overflow-y-auto font-mono text-left select-text\">\n              {logs.map((l, i) => <div key={i} className=\"truncate\">&gt; {l}</div>)}\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
