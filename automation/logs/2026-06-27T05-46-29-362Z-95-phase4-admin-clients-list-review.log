-1\">\n615 |               <Shield className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n616 |               <span>Attestation registry locked with administrative cryptographic keys</span>\n617 |             </div>\n618 |           </div>\n619 |         </div>\n620 |       )}\n621 | \n622 |       {/* -----------------------------------------------------------------------\n623 |           5. DETAILS SIDE-DRAWER\n624 |           ----------------------------------------------------------------------- */}\n625 |       {selectedClient && (\n626 |         <div className=\"fixed inset-0 z-50 flex justify-end\">\n627 |           \n628 |           {/* Backdrop */}\n629 |           <div \n630 |             onClick={() => setSelectedClient(null)}\n631 |             className=\"absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity duration-300\"\n632 |           />\n633 | \n634 |           {/* Drawer Panel */}\n635 |           <div className=\"relative z-10 w-full sm:w-[500px] border-l border-white/10 bg-[#060606]/95 backdrop-blur-md shadow-2xl flex flex-col h-full overflow-hidden\">\n636 |             \n637 |             {/* Drawer Header */}\n638 |             <div className=\"p-5 border-b border-white/5 bg-[#090909]\">\n639 |               <div className=\"flex items-start justify-between gap-4\">\n640 |                 <div className=\"space-y-1.5 text-left\">\n641 |                   <div className=\"flex items-center gap-2\">\n642 |                     <span className=\"text-[9px] font-mono font-bold text-[#009DFF] uppercase tracking-widest px-1.5 py-0.5 bg-[#009DFF]/10 rounded border border-[#009DFF]/20\">Sovereign Partition</span>\n643 |                     <span className=\"text-[10px] font-mono text-white/40\">{selectedClient.id.toUpperCase()}</span>\n644 |                   </div>\n645 |                   <h3 className=\"text-base font-bold text-white font-mono\">{selectedClient.name}</h3>\n646 |                   <div className=\"text-[11px] text-[#009DFF] font-mo