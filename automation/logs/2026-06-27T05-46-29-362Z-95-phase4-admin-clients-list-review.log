{"ts":"2026-06-27T05:41:38.960Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"bd0qek4r","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/clients/[id]/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { useParams, useRouter } from \"next/navigation\";\nimport { \n  ArrowLeft, Shield, ShieldCheck, Cpu, Clock, Layers, \n  Bot, Terminal, RefreshCw, AlertTriangle, CheckCircle2, Lock, \n  Settings2, ExternalLink, Users, BadgeCheck\n} from \"lucide-react\";\nimport { \n  previewClientAccounts, \n  previewProjects, \n  previewAgentOperations,\n  ClientAccount\n} from \"@/lib/mock-data-model\";\n\ninterface EnrichedClient extends ClientAccount {\n  industry: string;\n  accountOwner: string;\n  billingStatus: \"Paid\" | \"Unpaid\" | \"Processing\" | \"Overdue\";\n  healthStatus: \"Healthy\" | \"Warning\" | \"Critical\" | \"Offline\";\n}\n\nexport default function AdminClientDetailPage() {\n  const router = useRouter();\n  const { id } = useParams();\n  const clientId = typeof id === \"string\" ? id : \"client-001\";\n\n  // ---------------------------------------------------------------------------\n  // 1. DATA LOOKUP & ENRICHMENT\n  // ---------------------------------------------------------------------------\n  const rawClient = previewClientAccounts.find(c => c.id === clientId) || previewClientAccounts[0];\n\n  const client: EnrichedClient = {\n    ...rawClient,\n    industry: rawClient.id === \"client-001\" ? \"Cybersecurity & Defense\" :\n              rawClient.id === \"client-002\" ? \"E-Commerce & Retail\" :\n              rawClient.id === \"client-003\" ? \"Supply Chain & Logistics\" : \"FinTech & Treasury\",\n    accountOwner: rawClient.id === \"client-002\" ? \"Alexander Mercer\" :\n                  rawClient.id === \"client-003\" ? \"Sarah Jenkins\" :\n                  rawClient.id === \"client-004\" ? \"Marcus Vance\" : \"Dr. Sarah Vance\",\n    billingStatus: rawClient.id === \"client-002\" ? \"Overdue\" :\n                   rawClient.id === \"client-003\" ? \"Unpaid\" : \"Paid\",\n    healthStatus: rawClient.id === \"client-002\" ? \"Warning\" :\n                  rawClient.id === \"client-003\" ? \"Offline\" : \"Healthy\"\n  };\n\n  const clientProjects = previewProjects.filter(p => p.clientAccountId === client.id);\n  const projectIds = clientProjects.map(p => p.id);\n  const clientAgents = previewAgentOperations.filter(op => projectIds.includes(op.projectId));\n\n  // State Hooks\n  const [activeTab, setActiveTab] = useState<\"telemetry\" | \"architecture\" | \"compliance\" | \"workloads\">(\"telemetry\");\n  const [isRotatingKey, setIsRotatingKey] = useState(false);\n  const [isScanning, setIsScanning] = useState(false);\n  const [consoleLogs, setConsoleLogs] = useState<string[]>([\n    `[${new Date().toISOString().split(\"T\")[1].slice(0, 8)}] ADMIN_INIT: Oversight session opened for ${client.id.toUpperCase()}`,\n    `[${new Date().toISOString().split(\"T\")[1].slice(0, 8)}] SECURE_LINK: TLS 1.3 socket bound to enclave: ${client.domain}`,\n    `[${new Date().toISOString().split(\"T\")[1].slice(0, 8)}] ATTESTATION: Root HSM state verified. Seal: SHA-0x${client.id.toUpperCase()}`\n  ]);\n\n  const addConsoleLog = (text: string) => {\n    const timestamp = new Date().toISOString().split(\"T\")[1].slice(0, 8);\n    setConsoleLogs(prev => [...prev, `[${timestamp}] ${text}`]);\n  };\n\n  const handleRotateHSMSeal = () => {\n    if (isRotatingKey || isScanning) return;\n    setIsRotatingKey(true);\n    addConsoleLog(\"HSM_KEY_ROLLOVER: Initiating ephemeral root key rotation...\");\n    setTimeout(() => {\n      addConsoleLog(\"HSM_KEY_ROLLOVER: NTPU cryptographic parameters generated.\");\n      setTimeout(() => {\n        addConsoleLog(\"HSM_KEY_ROLLOVER: Sealed new certificate on airgapped master vault.\");\n        setTimeout(() => {\n          addConsoleLog(\"HSM_KEY_ROLLOVER: SUCCESS - Partition rotated. New Seal: SHA-0x8A12FFCE\");\n          setIsRotatingKey(false);\n        }, 600);\n      }, 600);\n    }, 600);\n  };\n\n  const handleRunSecurityScan = () => {\n    if (isRotatingKey || isScanning) return;\n    setIsScanning(true);\n    addConsoleLog(\"COMPLIANCE_SCAN: Initiated continuous eBPF kernel isolation verify...\");\n    setTimeout(() => {\n      addConsoleLog(\"COMPLIANCE_SCAN: Checked AMD SEV-SNP secure hardware registers.\");\n      setTimeout(() => {\n        addConsoleLog(\"COMPLIANCE_SCAN: Audited multi-agent boundary rules and flow alignment.\");\n        setTimeout(() => {\n          addConsoleLog(`COMPLIANCE_SCAN: SUCCESS - No leakage found. ISO certified: ${client.complianceLevel}`);\n          setIsScanning(false);\n        }, 600);\n      }, 600);\n    }, 600);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* HEADER BAR */}\n      <div className=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4 border-b border-white/5 pb-5\">\n        <div className=\"flex items-center gap-3\">\n          <button\n            onClick={() => router.push(\"/admin/clients\")}\n            className=\"p-1.5 rounded border border-white/5 bg-white/[0.01] text-white/50 hover:text-white cursor-pointer transition-colors\"\n            aria-label=\"Back to tenant registry\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n          </button>\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/10 border border-[#009DFF]/20 px-1.5 py-0.5 rounded uppercase tracking-wider\">\n                Administrative Oversight\n              </span>\n              <span className=\"text-[9px] font-mono font-bold text-white/30\">\n                {client.id.toUpperCase()}\n              </span>\n            </div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase mt-1 flex items-center gap-1.5\">\n              <span>{client.name.replace(\" [Preview Client]\", \"\")}</span>\n              {client.tier === \"Sovereign\" && <BadgeCheck className=\"w-4 h-4 text-amber-400 animate-pulse\" />}\n            </h2>\n          </div>\n        </div>\n\n        <div className=\"flex items-center gap-3 font-mono text-xs\">\n          <div className=\"p-2 rounded bg-white/[0.01] border border-white/5 flex items-center gap-2\">\n            <span className=\"text-white/40 uppercase text-[9px]\">SLA Health:</span>\n            <span className={`inline-flex items-center gap-1 font-bold ${\n              client.healthStatus === \"Healthy\" ? \"text-emerald-400\" :\n              client.healthStatus === \"Warning\" ? \"text-amber-400\" : \"text-red-400\"\n            }`}>\n              <span className={`h-1.5 w-1.5 rounded-full bg-current ${client.healthStatus === \"Healthy\" ? \"animate-pulse\" : \"\"}`} />\n              {client.healthStatus.toUpperCase()}\n            </span>\n          </div>\n\n          <button\n            onClick={() => {\n              const customSession = {\n                name: client.contactName,\n                email: client.contactEmail,\n                role: \"client_admin\",\n                clearance: \"CLEARANCE LEVEL III (SANDBOX ADMIN)\",\n                isMock: true,\n                label: `PORTAL PREVIEW - ${client.name.toUpperCase()}`\n              };\n              localStorage.setItem(\"gff_ai_preview_session_v1\", JSON.stringify(customSession));\n              window.dispatchEvent(new Event(\"gff_preview_session_changed\"));\n              router.push(\"/portal/dashboard\");\n            }}\n            className=\"h-8 px-3 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10.5px] font-bold uppercase text-white flex items-center gap-1.5 transition-all cursor-pointer border-none\"\n          >\n            <ExternalLink className=\"w-3.5 h-3.5\" />\n            <span>Mirror Portal</span>\n          </button>\n        </div>\n      </div>\n\n      {/* CORE GRID */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* LEFT COMPONENT */}\n        <div className=\"lg:col-span-2 space-y-6\">\n          \n          {/* TABS SELECTOR */}\n          <div className=\"flex border-b border-white/5 font-mono text-[10.5px] gap-1 bg-black/20 p-1 rounded-lg\">\n            {([\"telemetry\", \"architecture\", \"compliance\", \"workloads\"] as const).map((tab) => (\n              <button\n                key={tab}\n                onClick={() => setActiveTab(tab)}\n                className={`flex-1 py-2 rounded font-bold uppercase transition-all text-center cursor-pointer border-none ${\n                  activeTab === tab \n                    ? \"bg-[#009DFF]/10 text-white border border-[#009DFF]/20\" \n                    : \"bg-transparent text-white/40 hover:text-white/70\"\n                }`}\n              >\n                {tab}\n              </button>\n            ))}\n          </div>\n\n          {/* TELEMETRY VIEW */}\n          {activeTab === \"telemetry\" && (\n            <div className=\"space-y-6\">\n              \n              {/* BENTO GRID */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 font-mono\">\n                  <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n                    <span className=\"text-[9px] uppercase font-bold text-white/40\">Partition Scope</span>\n                    <Cpu className=\"w-4 h-4 text-[#009DFF]\" />\n                  </div>\n                  <div className=\"space-y-1.5 text-xs text-white/70\">\n                    <div className=\"flex justify-between\"><span>Subscription Tier:</span><span className=\"text-amber-300 font-bold uppercase\">{client.tier}</span></div>\n                    <div className=\"flex justify-between\"><span>Compute Region:</span><span className=\"text-white\">{client.region}</span></div>\n                    <div className=\"flex justify-between\"><span>Isolated Namespace:</span><span className=\"text-[#009DFF]\">{client.domain}</span></div>\n                  </div>\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 font-mono\">\n                  <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n                    <span className=\"text-[9px] uppercase font-bold text-white/40\">Hardware Allocation</span>\n                    <Lock className=\"w-4 h-4 text-emerald-400\" />\n                  </div>\n                  <div className=\"space-y-1.5 text-xs text-white/70\">\n                    <div className=\"flex justify-between\"><span>Secure CPU Cores:</span><span className=\"text-[#00FFC2] font-bold\">128 Threads</span></div>\n                    <div className=\"flex justify-between\"><span>Enclave Sandbox:</span><span className=\"text-white\">AMD SEV-SNP (Hardware)</span></div>\n                    <div className=\"flex justify-between\"><span>eBPF Filter Mode:</span><span className=\"text-white\">Kernel Locked</span></div>\n                  </div>\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 font-mono\">\n                  <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n                    <span className=\"text-[9px] uppercase font-bold text-white/40\">Assurance Ledger</span>\n                    <Clock className=\"w-4 h-4 text-amber-500\" />\n                  </div>\n                  <div className=\"space-y-1.5 text-xs text-white/70\">\n                    <div className=\"flex justify-between\"><span>ISO-27001 State:</span><span className=\"text-emerald-400 font-bold\">CERTIFIED</span></div>\n                    <div className=\"flex justify-between\"><span>Attestation Epochs:</span><span className=\"text-white\">812K Cycles Sealed</span></div>\n                    <div className=\"flex justify-between\"><span>SLA SLA Response:</span><span className=\"text-white\">Dedicated Wire</span></div>\n                  </div>\n                </div>\n\n                <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-2 font-mono\">\n                  <div className=\"flex items-center justify-between border-b border-white/5 pb-1\">\n                    <span className=\"text-[9px] uppercase font-bold text-white/40\">Custodian Bounds</span>\n                    <Users className=\"w-4 h-4 text-purple-400\" />\n                  </div>\n                  <div className=\"space-y-1.5 text-xs text-white/70\">\n                    <div className=\"flex justify-between\"><span>Account Custodian:</span><span className=\"text-white font-bold\">{client.accountOwner}</span></div>\n                    <div className=\"flex justify-between\"><span>Primary Operator:</span><span className=\"text-white\">{client.contactName}</span></div>\n                    <div className=\"flex justify-between\"><span>Secure Mailbox:</span><span className=\"text-[#009DFF] text-[10px] truncate max-w-[130px]\">{client.contactEmail}</span></div>\n                  </div>\n                </div>\n              </div>\n\n              {/* ACTIVE PROJECTS LIST */}\n              <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n                <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <Layers className=\"w-4 h-4 text-[#009DFF]\" />\n                    <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Associated Projects ({clientProjects.length})</h3>\n                  </div>\n                  <span className=\"text-[10px] text-white/40 font-mono\">Continuous auditing active</span>\n                </div>\n\n                {clientProjects.length === 0 ? (\n                  <div className=\"text-center py-4 text-white/30 text-xs font-mono\">\n                    No active projects allocated to this partition.\n                  </div>\n                ) : (\n                  <div className=\"overflow-x-auto font-mono text-[11px]\">\n                    <table className=\"w-full text-left\">\n                      <thead>\n                        <tr className=\"border-b border-white/5 text-white/40\">\n                          <th className=\"pb-2\">Grid ID / Name</th>\n                          <th className=\"pb-2\">Enclave Isolation</th>\n                          <th className=\"pb-2 text-right\">Status</th>\n                        </tr>\n                      </thead>\n                      <tbody className=\"divide-y divide-white/[0.03]\">\n                        {clientProjects.map((p) => (\n                          <tr key={p.id}>\n                            <td className=\"py-2.5\">\n                              <div className=\"font-bold text-white uppercase\">{p.name}</div>\n                              <span className=\"text-[#009DFF] text-[9px]\">{p.id.toUpperCase()}</span>\n                            </td>\n                            <td className=\"py-2.5 text-white/60\">{p.enclaveType} ({p.nodesCount} Nodes)</td>\n                            <td className=\"py-2.5 text-right\">\n                              <span className=\"rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1.5 py-0.5 text-[9px] font-bold uppercase\">\n                                {p.status}\n                              </span>\n                            </td>\n                          </tr>\n                        ))}\n                      </tbody>\n                    </table>\n                  </div>\n                )}\n              </div>\n\n            </div>\n          )}\n\n          {/* SVG ARCHITECTURE DIAGRAM */}\n          {activeTab === \"architecture\" && (\n            <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"space-y-1\">\n                <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">HSM Airgap & Cryptographic Path Mapping</h3>\n                <p className=\"text-[10px] text-white/40\">\n                  Deterministic view of hardware-isolated enclave loops and continuous decapsulation telemetry.\n                </p>\n              </div>\n\n              <div className=\"relative w-full h-[200px] bg-black/60 rounded-xl border border-white/5 flex items-center justify-center overflow-hidden\">\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:16px_16px]\" />\n                <div className=\"absolute w-[160px] h-[160px] rounded-full bg-[#009DFF]/5 blur-[40px]\" />\n\n                <svg className=\"relative w-full h-full max-w-[420px]\" viewBox=\"0 0 400 200\">\n                  <path d=\"M 80 100 C 150 40, 250 40, 320 100\" fill=\"none\" stroke=\"#00FFC2\" strokeWidth=\"2\" strokeDasharray=\"10 40\" className=\"animate-[dash_3s_linear_infinite]\" />\n                  <path d=\"M 80 100 C 150 160, 250 160, 320 100\" fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"1.5\" strokeOpacity=\"0.4\" strokeDasharray=\"5 5\" />\n                  \n                  {/* Central Node */}\n                  <g transform=\"translate(200, 100)\">\n                    <circle r=\"26\" fill=\"#030303\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-pulse\" />\n                    <text y=\"3\" textAnchor=\"middle\" fill=\"#00FFC2\" fontSize=\"8\" fontWeight=\"bold\">HSM_CORE</text>\n                  </g>\n                  {/* Left Node */}\n                  <g transform=\"translate(80, 100)\">\n                    <circle r=\"15\" fill=\"#050505\" stroke=\"#009DFF\" strokeWidth=\"1.5\" />\n                    <text y=\"3\" textAnchor=\"middle\" fill=\"#009DFF\" fontSize=\"7\" fontWeight=\"bold\">SOCKET</text>\n                  </g>\n                  {/* Right Node */}\n                  <g transform=\"translate(320, 100)\">\n                    <circle r=\"15\" fill=\"#050505\" stroke=\"#a855f7\" strokeWidth=\"1.5\" />\n                    <text y=\"3\" textAnchor=\"middle\" fill=\"#a855f7\" fontSize=\"7\" fontWeight=\"bold\">LATTICE</text>\n                  </g>\n                </svg>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3 text-[9.5px] text-white/40 pt-1\">\n                <div className=\"flex items-start gap-1.5 p-2 rounded bg-black/20 border border-white/5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FFC2] mt-1 shrink-0 animate-pulse\" />\n                  <div><strong className=\"text-white/70\">HSM Core Shield:</strong> Physical hardware key signature verification loop.</div>\n                </div>\n                <div className=\"flex items-start gap-1.5 p-2 rounded bg-black/20 border border-white/5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF] mt-1 shrink-0\" />\n                  <div><strong className=\"text-white/70\">eBPF Port Bounds:</strong> Network boundary mapping isolated sockets.</div>\n                </div>\n                <div className=\"flex items-start gap-1.5 p-2 rounded bg-black/20 border border-white/5\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-[#a855f7] mt-1 shrink-0\" />\n                  <div><strong className=\"text-white/70\">Agent Sandbox:</strong> Decapsulated Ring-3 LLM isolated worker pools.</div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* COMPLIANCE CHRONOLOGY */}\n          {activeTab === \"compliance\" && (\n            <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono text-xs\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n                <span className=\"font-bold text-white uppercase flex items-center gap-1.5\">\n                  <ShieldCheck className=\"w-4 h-4 text-emerald-400\" />\n                  <span>Continuous Certification Trails</span>\n                </span>\n                <span className=\"text-[9px] text-emerald-400 font-bold bg-emerald-500/10 px-1.5 py-0.5 rounded uppercase\">ISO ACTIVE</span>\n              </div>\n\n              <div className=\"space-y-4 text-[11px]\">\n                <div className=\"flex gap-3\">\n                  <div className=\"w-5 h-5 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 text-[9px] font-bold shrink-0\">01</div>\n                  <div>\n                    <span className=\"font-bold text-white uppercase flex items-center gap-1\">HSM Key Verification <CheckCircle2 className=\"w-3 h-3 text-emerald-400\" /></span>\n                    <p className=\"text-white/40 text-[10px]\">Administrative root signature checked against hardware boundaries.</p>\n                  </div>\n                </div>\n                <div className=\"flex gap-3\">\n                  <div className=\"w-5 h-5 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 text-[9px] font-bold shrink-0\">02</div>\n                  <div>\n                    <span className=\"font-bold text-white uppercase flex items-center gap-1\">Kernel Boundaries Audit <CheckCircle2 className=\"w-3 h-3 text-emerald-400\" /></span>\n                    <p className=\"text-white/40 text-[10px]\">eBPF runtime profiles verify 100% namespace separation from host system.</p>\n                  </div>\n                </div>\n                <div className=\"flex gap-3\">\n                  <div className=\"w-5 h-5 rounded-full bg-blue-500/10 border border-blue-500/30 flex items-center justify-center text-blue-400 text-[9px] font-bold shrink-0 animate-pulse\">03</div>\n                  <div>\n                    <span className=\"font-bold text-white uppercase flex items-center gap-1.5\">Telemetry Ledger Seals <span className=\"text-[8px] bg-blue-500/15 text-blue-400 border border-blue-500/20 px-1 rounded animate-pulse font-bold\">POLLING</span></span>\n                    <p className=\"text-white/40 text-[10px]\">Real-time attestation metrics securely written to epoch blockchain register.</p>\n                  </div>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* ACTIVE WORKLOADS */}\n          {activeTab === \"workloads\" && (\n            <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n                <Bot className=\"w-4 h-4 text-[#a855f7]\" />\n                <h3 className=\"text-xs font-bold text-white uppercase\">Decapsulated Multi-Agent Sandboxes</h3>\n              </div>\n\n              {clientAgents.length === 0 ? (\n                <div className=\"text-center py-6 text-white/30 text-xs\">No active autonomous models executing in this boundary.</div>\n              ) : (\n                <div className=\"space-y-3 text-xs\">\n                  {clientAgents.map((agent) => (\n                    <div key={agent.id} className=\"p-3.5 rounded-lg border border-white/5 bg-black/40 space-y-2\">\n                      <div className=\"flex justify-between\">\n                        <div>\n                          <strong className=\"text-white uppercase\">{agent.name}</strong>\n                          <span className=\"text-white/30 text-[9px] ml-1.5\">({agent.id.toUpperCase()})</span>\n                        </div>\n                        <span className=\"rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1 py-0.2 text-[8px] font-bold uppercase\">{agent.status}</span>\n                      </div>\n                      <div className=\"text-[10px] text-white/50 flex gap-4\">\n                        <div>Compute: <span className=\"text-white font-bold\">{agent.threads} Cores</span></div>\n                        <div>Enclave RAM: <span className=\"text-white font-bold\">{agent.memory}</span></div>\n                      </div>\n                      <div className=\"p-2 rounded bg-black/60 border border-white/5 text-[9px] text-emerald-400/80 space-y-0.5 font-mono max-h-[80px] overflow-y-auto\">\n                        {agent.logs.map((log, lIdx) => <div key={lIdx} className=\"truncate\">&gt; {log}</div>)}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n\n        </div>\n\n        {/* RIGHT COLUMN */}\n        <div className=\"space-y-6\">\n          \n          {/* ADMINISTRATIVE ACTIONS */}\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n            <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2.5\">\n              <Settings2 className=\"w-4 h-4 text-[#009DFF]\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Administrative Controls</h3>\n            </div>\n\n            <div className=\"space-y-2 font-mono text-xs\">\n              <button\n                onClick={handleRotateHSMSeal}\n                disabled={isRotatingKey || isScanning}\n                className={`w-full h-9 rounded border text-[10px] font-bold uppercase text-white flex items-center justify-center gap-2 cursor-pointer transition-all ${\n                  isRotatingKey ? \"bg-[#00FFC2]/10 text-[#00FFC2] border-[#00FFC2]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"\n                }`}\n              >\n                <RefreshCw className={`w-3.5 h-3.5 text-[#00FFC2] ${isRotatingKey ? \"animate-spin\" : \"\"}`} />\n                <span>{isRotatingKey ? \"Rotating Keys...\" : \"Rotate HSM Seal Key\"}</span>\n              </button>\n\n              <button\n                onClick={handleRunSecurityScan}\n                disabled={isRotatingKey || isScanning}\n                className={`w-full h-9 rounded border text-[10px] font-bold uppercase text-white flex items-center justify-center gap-2 cursor-pointer transition-all ${\n                  isScanning ? \"bg-[#009DFF]/10 text-[#009DFF] border-[#009DFF]/20\" : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/10\"\n                }`}\n              >\n                <Shield className={`w-3.5 h-3.5 text-[#009DFF] ${isScanning ? \"animate-pulse\" : \"\"}`} />\n                <span>{isScanning ? \"Scanning...\" : \"Execute Boundary Scan\"}</span>\n              </button>\n            </div>\n\n            <div className=\"flex items-start gap-2 text-[9px] text-white/30 bg-white/[0.01] p-3 rounded border border-white/5 font-mono\">\n              <AlertTriangle className=\"w-3.5 h-3.5 text-amber-500 shrink-0\" />\n              <span>Oversight actions operate at root hypervisor levels and bypass tenant-side key controls.</span>\n            </div>\n          </div>\n\n          {/* TELEMETRY CONSOLE HUD */}\n          <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-3 flex flex-col h-[220px]\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n              <div className=\"flex items-center gap-1.5\">\n                <Terminal className=\"w-4 h-4 text-emerald-400\" />\n                <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Telemetry Console</h3>\n              </div>\n              <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n            </div>\n\n            <div className=\"flex-1 bg-black/50 border border-white/5 rounded-lg p-2.5 font-mono text-[9px] text-emerald-400/80 space-y-1.5 overflow-y-auto select-text text-left\">\n              {consoleLogs.map((log, index) => (\n                <div key={index} className=\"leading-relaxed truncate\">\n                  {log}\n                </div>\n              ))}\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n\n    </div>\n  );\n}"}}}
