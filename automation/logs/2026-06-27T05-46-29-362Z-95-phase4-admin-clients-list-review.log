ver:text-white text-[11px] font-mono font-bold uppercase transition-all cursor-pointer bg-transparent\"\n1088 |                 >\n1089 |                   Cancel\n1090 |                 </button>\n1091 |                 <button \n1092 |                   type=\"submit\"\n1093 |                   className=\"h-9 px-4 rounded bg-[#10b981] hover:bg-[#059669] text-white text-[11px] font-mono font-bold uppercase transition-all shadow-[0_0_15px_rgba(16,185,129,0.2)] cursor-pointer border-none\"\n1094 |                 >\n1095 |                   Confirm Provisioning\n1096 |                 </button>\n1097 |               </div>\n1098 | \n1099 |             </form>\n1100 |           </div>\n1101 |         </div>\n1102 |       )}\n1103 | \n1104 |       {/* -----------------------------------------------------------------------\n1105 |           7. ASSIGN ACCOUNT OWNER MODAL\n1106 |           ----------------------------------------------------------------------- */}\n1107 |       {isAssignModalOpen && assigningClient && (\n1108 |         <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n1109 |           <div onClick={() => setIsAssignModalOpen(false)} className=\"absolute inset-0 bg-black/70 backdrop-blur-sm\" />\n1110 |           <div className=\"relative z-10 w-full max-w-sm border border-white/10 bg-[#060606] rounded-xl overflow-hidden shadow-2xl flex flex-col font-mono text-[11.5px]\">\n1111 |             \n1112 |             <div className=\"p-4 border-b border-white/5 bg-[#090909] flex items-center justify-between\">\n1113 |               <div className=\"flex items-center gap-2\">\n1114 |                 <User className=\"w-4 h-4 text-[#009DFF]\" />\n1115 |                 <h3 className=\"text-xs font-bold uppercase tracking-wider text-white font-mono\">RE-ASSIGN CUSTODIAN</h3>\n1116 |               </div>\n1117 |               <button onClick={() => setIsAssignModalOpen(false)} className=\"text-white/40 hover:text-white cursor-pointer bg-transparent border-none\">\n1118 |                 <X className=\"w-4 h-4\" />\n1119 |               </button>\n1120 |             </div>\n1121 | \n1122 |             <form onSubmit={handleSaveOwner} className=\"p-5 space-y-4 text-left\">\n1123 |               \n1124 |               <div className=\"space-y-1 bg-[#101010]/50 p-3 rounded border border-white/5\">\n1125 |                 <span className=\"text-[10px] text-white/40 uppercase block font-bold\">Selected Tenant</span>\n1126 |                 <p className=\"text-white font-bold\">{assigningClient.name}</p>\n1127 |                 <p className=\"text-[10px] text-[#009DFF]\">{assigningClient.domain}</p>\n1128 |               </div>\n1129 | \n1130 |               <div className=\"space-y-1.5\">\n1131 |                 <label className=\"text-[10px] uppercase font-bold text-white/40 block\">Account Custodian Assigned</label>\n1132 |                 <select \n1133 |                   value={assignedOwner}\n1134 |                   onChange={(e) => setAssignedOwner(e.target.value)}\n1135 |                   className=\"w-full h-9 rounded bg-[#101010] border border-white/5 px-2 text-white outline-none focus:border-[#009DFF]/40 transition-all cursor-pointer font-mono text-[11px]\"\n1136 |                 >\n1137 |                   <option value=\"Dr. Sarah Vance\">Dr. Sarah Vance (Lead Oversight)</option>\n1138 |                   <option value=\"Alexander Mercer\">Alexander Mercer (Sandbox Lead)</option>\n1139 |                   <option value=\"Sarah Jenkins\">Sarah Jenkins (GovWest Auditor)</option>\n1140 |                   <option value=\"Marcus Vance\">Marcus Vance (APAC Lead)</option>\n1141 |                   <option value=\"Dr. Robert Chen\">Dr. Robert Chen (SLA Architect)</option>\n1142 |                   <option value=\"Director Ava Thorne\">Director Ava Thorne (Operations Custodian)</option>\n1143 |                 </select>\n1144 |               </div>\n1145 | \n1146 |               <div className=\"pt-4 border-t border-white/5 flex justify-end gap-3\">\n1147 |                 <button \n1148 |                   type=\"button\"\n1149 |                   onClick={() => setIsAssignModalOpen(false)}\n1150 |                   className=\"h-9 px-4 rounded border border-white/10 hover:bg-white/5 text-white/70 hover:text-white text-[11px] font-mono font-bold uppercase transition-all cursor-pointer bg-transparent\"\n1151 |                 >\n1152 |                   Cancel\n1153 |                 </button>\n1154 |                 <button \n1155 |                   type=\"submit\"\n1156 |                   className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-white text-[11px] font-mono font-bold uppercase transition-all shadow-[0_0_15px_rgba(0,157,255,0.2)] cursor-pointer border-none\"\n1157 |                 >\n1158 |                   Confirm Custodian\n1159 |                 </button>\n1160 |               </div>\n1161 | \n1162 |             </form>\n1163 |           </div>\n1164 |         </div>\n1165 |       )}\n1166 | \n1167 |       {/* -----------------------------------------------------------------------\n1168 |           8. SECURE PORTAL MIRROR CONNECTION LAYER (HANDSHAKE OVERLAY)\n1169 |           ----------------------------------------------------------------------- */}\n1170 |       {handshakeClient && handshakeStep > 0 && (\n1171 |         <div className=\"fixed inset-0 z-50 bg-black/90 backdrop-blur-md flex items-center justify-center p-4\">\n1172 |           <div className=\"max-w-md w-full border border-white/10 bg-[#040404] p-8 rounded-2xl shadow-2xl text-center space-y-6 font-mono\">\n1173 |             \n1174 |             {/* Hologram loading ring */}\n1175 |             <div className=\"relative w-16 h-16 mx-auto flex items-center justify-center\">\n1176 |               <div className=\"absolute inset-0 rounded-full border-2 border-white/5 border-t-2 border-t-[#009DFF] animate-spin\" />\n1177 |               <Shield className=\"w-7 h-7 text-[#009DFF]\" />\n1178 |             </div>\n1179 | \n1180 |             <div className=\"space-y-2\">\n1181 |               <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">Establishing Private Mirror Link</h3>\n1182 |               <p className=\"text-[11px] text-white/50\">\n1183 |                 Impersonating administrator context under ISO-27001 auditing guidelines.\n1184 |               </p>\n1185 |             </div>\n1186 | \n1187 |             {/* Simulated Handshake Flow */}\n1188 |             <div className=\"bg-black/60 border border-white/5 p-4 rounded-xl text-left space-y-3 font-mono text-[10px]\">\n1189 |               <div className=\"flex items-center gap-2\">\n1190 |                 <span className={`w-1.5 h-1.5 rounded-full ${handshakeStep >= 1 ? \"bg-emerald-400\" : \"bg-white/10\"}`} />\n1191 |                 <span className={handshakeStep >= 1 ? \"text-white\" : \"text-white/30\"}>[01] Mapping clearance credentials (Clearance V)</span>\n1192 |                 {handshakeStep >= 1 && <Check className=\"w-3.5 h-3.5 text-emerald-400 ml-auto shrink-0\" />}\n1193 |               </div>\n1194 |               <div className=\"flex items-center gap-2\">\n1195 |                 <span className={`w-1.5 h-1.5 rounded-full ${handshakeStep >= 2 ? \"bg-emerald-400 animate-pulse\" : \"bg-white/10\"}`} />\n1196 |                 <span className={handshakeStep >= 2 ? \"text-white\" : \"text-white/30\"}>[02] Binding TLS 1.3 socket to client HSM certificate</span>\n1197 |                 {handshakeStep >= 2 && <Check className=\"w-3.5 h-3.5 text-emerald-400 ml-auto shrink-0\" />}\n1198 |               </div>\n1199 |               <div className=\"flex items-center gap-2\">\n1200 |                 <span className={`w-1.5 h-1.5 rounded-full ${handshakeStep >= 3 ? \"bg-emerald-400 animate-pulse\" : \"bg-white/10\"}`} />\n1201 |                 <span className={handshakeStep >= 3 ? \"text-white\" : \"text-white/30\"}>[03] Redirecting mirror stream to telemetry workspace</span>\n1202 |                 {handshakeStep >= 3 && <RefreshCw className=\"w-3.5 h-3.5 text-emerald-400 animate-spin ml-auto shrink-0\" />}\n1203 |               </div>\n1204 |             </div>\n1205 | \n1206 |             {/* Disclaimer */}\n1207 |             <div className=\"flex items-start gap-2.5 text-[9.5px] text-white/30 leading-relaxed text-left bg-white/[0.01] p-3 rounded border border-white/5\">\n1208 |               <Info className=\"w-4 h-4 text-amber-400 shrink-0 mt-0.5\" />\n1209 |               <span>\n1210 |                 All administrative access mimics real-world single sign-on (SSO) handshakes. Action logs are automatically sealed in the system activity log.\n1211 |               </span>\n1212 |             </div>\n1213 | \n1214 |           </div>\n1215 |         </div>\n1216 |       )}\n1217 | \n1218 |     </div>\n1219 |   );\n1220 | }","success":true}],"durationMs":8}}
