leCopyId = (id: string, e: React.MouseEvent) => {\n120 |     e.stopPropagation();\n121 |     navigator.clipboard.writeText(id);\n122 |     setCopiedId(id);\n123 |     setTimeout(() => setCopiedId(null), 1500);\n124 |   };\n125 | \n126 |   // Unique lists for filters\n127 |   const uniqueRegions = Array.from(new Set(clients.map(c => c.region)));\n128 |   const uniqueIndustries = Array.from(new Set(clients.map(c => c.industry)));\n129 | \n130 |   // ---------------------------------------------------------------------------\n131 |   // 3. FRONTEND-ONLY ACTIONS\n132 |   // ---------------------------------------------------------------------------\n133 |   const handleAddClient = (e: React.FormEvent) => {\n134 |     e.preventDefault();\n135 |     if (!newName || !newDomain) return;\n136 | \n137 |     const nextId = `client-00${clients.length + 1}`;\n138 |     const newClientObj: AdminClient = {\n139 |       id: nextId,\n140 |       name: `${newName} [Preview Client]`,\n141 |       domain: newDomain,\n142 |       status: \"active\",\n143 |       tier: newTier,\n144 |       createdAt: new Date().toISOString(),\n145 |       region: newRegion,\n146 |       complianceLevel: newTier === \"Sovereign\" ? \"ISO-27001 Fully Certified\" : \"SOC2 Type II Assured\",\n147 |       contactName: \"Sovereign Operator\",\n148 |       contactEmail: `operator@${newDomain}`,\n149 |       industry: newIndustry,\n150 |       accountOwner: newOwner,\n151 |       healthStatus: newHealth,\n152 |       billingStatus: newBilling\n153 |     };\n154 | \n155 |     setClients([...clients, newClientObj]);\n156 |     setIsAddModalOpen(false);\n157 | \n158 |     // Reset Form\n159 |     setNewName(\"\");\n160 |     setNewDomain(\"\");\n161 |     setNewIndustry(\"Cybersecurity & Defense\");\n162 |     setNewTier(\"Sovereign\");\n163 |     setNewRegion(\"EU-West (Isolated)\");\n164 |     setNewOwner(\"Dr. Sarah Vance\");\n165 |     setNewHealth(\"Healthy\");\n166 |     setNewBilling(\"Paid\");\n167 |   };\