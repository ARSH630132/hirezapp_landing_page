ustomer_experience\"\n 16 |   | \"decision_automation\";\n 17 | \n 18 | export default function ROICalculatorPage() {\n 19 |   // 1. STATE & PARAMETERS\n 20 |   const [industry, setIndustry] = useState<string>(\"financial_services\");\n 21 |   const [companySize, setCompanySize] = useState<string>(\"enterprise\");\n 22 |   const [opFunction, setOpFunction] = useState<string>(\"customer_operations\");\n 23 |   const [annualCostBaseline, setAnnualCostBaseline] = useState<number>(1500000);\n 24 |   const [processVolume, setProcessVolume] = useState<number>(250000);\n 25 |   const [avgHandlingTime, setAvgHandlingTime] = useState<number | \"\">(15);\n 26 |   const [automationTarget, setAutomationTarget] = useState<number>(65);\n 27 |   const [manualEffort, setManualEffort] = useState<string>(\"high\");\n 28 |   const [productivityImprovement, setProductivityImprovement] = useState<number>(50);\n 29 |   const [implementationHorizon, setImplementationHorizon] = useState<string>(\"6_months\");\n 30 |   const [initialInvestment, setInitialInvestment] = useState<number>(350000);\n 31 |   const [priority, setPriority] = useState<Priority>(\"cost_reduction\");\n 32 |   const [copied, setCopied] = useState(false);\n 33 |   const [isHydrated, setIsHydrated] = useState(false);\n 34 | \n 35 |   // Load from Local Workspace on mount\n 36 |   useEffect(() => {\n 37 |     const saved = getToolState(\"roi\");\n 38 |     if (saved) {\n 39 |       if (saved.industry) setIndustry(saved.industry);\n 40 |       if (saved.companySize) setCompanySize(saved.companySize);\n 41 |       if (saved.opFunction) setOpFunction(saved.opFunction);\n 42 |       if (typeof saved.annualCostBaseline === \"number\") setAnnualCostBaseline(saved.annualCostBaseline);\n 43 |       if (typeof saved.processVolume === \"number\") setProcessVolume(saved.processVolume);\n 44 |       if (typeof saved.avgHandlingTime === \"number\" || saved.avgHandlingTime === \"\") setAvgHandlingTime(saved.avgHandlingTime);\n 45 |       if (typeof saved.automationTarget === \"number\") setAutomationTarget(saved.automationTarget);\n 46 |       if (saved.manualEffort) setManualEffort(saved.manualEffort);\n 47 |       if (typeof saved.productivityImprovement === \"number\") setProductivityImprovement(saved.productivityImprovement);\n 48 |       if (saved.implementationHorizon) setImplementationHorizon(saved.implementationHorizon);\n 49 |       if (typeof saved.initialInvestment === \"number\") setInitialInvestment(saved.initialInvestment);\n 50 |       if (saved.priority) setPriority(saved.priority as Priority);\n 51 |     }\n 52 |     setIsHydrated(true);\n 53 |   }, []);\n 54 | \n 55 |   // Save to Local Workspace on changes\n 56 |   useEffect(() => {\n 57 |     if (isHydrated) {\n 58 |       saveToolState(\"roi\", {\n 59 |         industry,\n 60 |         companySize,\n 61 |         opFunction,\n 62 |         annualCostBaseline,\n 63 |         processVolume,\n 64 |         avgHandlingTime,\n 65 |         automationTarget,\n 66 |         manualEffort,\n 67 |         productivityImprovement,\n 68 |         implementationHorizon,\n 69 |         initialInvestment,\n 70 |         priority\n 71 |       });\n 72 |     }\n 73 |   }, [\n 74 |     isHydrated,\n 75 |     industry,\n 76 |     companySize,\n 77 |     opFunction,\n 78 |     annualCostBaseline,\n 79 |     processVolume,\n 80 |     avgHandlingTime,\n 81 |     automationTarget,\n 82 |     manualEffort,\n 83 |     productivityImprovement,\n 84 |     implementationHorizon,\n 85 |     initialInvestment,\n 86 |     priority\n 87 |   ]);\n 88 | \n 89 |   // Synchronize derived platform setup CapEx whenever scale or horizon shifts\n 90 |   useEffect(() => {\n 91 |     let base = 350000;\n 92 |     if (companySize === \"smb\") base = 75000;\n 93 |     else if (companySize === \"mid\") base = 150000;\n 94 |     else if (companySize === \"enterprise\") base = 350000;\n 95 |     else if (companySize === \"large_enterprise\") base = 750000;\n 96 |     else if (companySize === \"global_corp\") base = 1500000;\n 97 | \n 98 |     let multiplier = 1.0;\n 99 |     if (implementationHorizon === \"3_months\") multiplier = 1.1;\n100 |     else if (implementationHorizon === \"6_months\") multiplier = 1.0;\n101 |     else if (implementationHorizon === \"12_months\") multiplier = 0.9;\n102 |     else if (implementationHorizon === \"18_months\") multiplier = 0.8;\n103 | \n104 |     setInitialInvestment(Math.round(base * multiplier));\n105 |   }, [companySize, implementationHorizon]);\n106 | \n107 |   // 2. MATHEMATICAL MODEL FOR SOVEREIGN ROI CALCULATION\n108 |   const industryBaseRate: Record<string, number> = {\n109 |     financial_services: 95,\n110 |     healthcare: 90,\n111 |     energy_utilities: 85,\n112 |     telecommunications: 75,\n113 |     public_sector: 65,\n114 |     retail_logistics: 55,\n115 |     technology_media: 100\n116 |   };\n117 | \n118 |   const functionMultiplier: Record<string, number> = {\n119 |     customer_operations: 0.7,\n120 |     legal_compliance: 1.4,\n121 |     supply_chain: 0.9,\n122 |     finance_accounting: 1.2,\n123 |     it_engineering: 1.3,\n124 |     hr_admin: 0.8\n125 |   };\n126 | \n127 |   const loadedHourlyRate = Math.round(\n128 |     (industryBaseRate[industry] || 80) * (functionMultiplier[opFunction] || 1.0)\n129 |   );\n130 | \n131 |   const manualEffortFactor = {\n132 |     low: 0.20,\n133 |     medium: 0.40,\n134 |     high: 0.65,\n135 |     critical: 0.85\n136 |   }[manualEffort] || 0.65;\n137 | \n138 |   const addressableCostBaseline = Math.round(annualCostBaseline * manualEffortFactor);\n139 | \n140 |   const manualHoursSpent = avgHandlingTime !== \"\" && avgHandlingTime > 0\n141 |     ? Math.round(processVolume * (avgHandlingTime / 60))\n142 |     : Math.round(addressableCostBaseline / loadedHourlyRate);\n143 | \n144 |   // EXPECTED GFF STANDARD CASE\n145 |   const expectedAdoptionFactor = automationTarget / 100;\n146 |   const expectedProductivityFactor = productivityImprovement / 100;\n147 |   const expectedSavingsFactor = expectedAdoptionFactor * expectedProductivityFactor;\n148 | \n149 |   const expectedGrossSavings = Math.round(addressableCostBaseline * expectedSavingsFactor);\n150 |   const expectedHoursSaved = Math.round(manualHoursSpent * expectedSavingsFactor);\n151 |   const expectedNetSavings = Math.max(0, expectedGrossSavings - initialInvestment);\n152 |   const expectedRoi = initialInvestment > 0 ? Math.round((expectedNetSavings / initialInvestment) * 100) : 0;\n153 | \n154 |   const expectedMonthlySavings = expectedGrossSavings / 12;\n155 |   const expectedPaybackMonths = expectedMonthlySavings > 0\n156 |     ? Math.max(0.1, Math.round((initialInvestment / expectedMonthlySavings) * 10) / 10)\n157 |     : 0;\n158 | \n159 |   // CONSERVATIVE GFF CASE (Risk-Adjusted Setup)\n160 |   const conservativeAdoptionFactor = (automationTarget * 0.75) / 100;\n161 |   const conservativeProductivityFactor = Math.max(10, productivityImprovement - 15) / 100;\n162 |   const conservativeSavingsFactor = conservativeAdoptionFactor * conservativeProductivityFactor;\n163 | \n164 |   const conservativeGrossSavings = Math.round(addressableCostBaseline * conservativeSavingsFactor);\n165 |   const conservativeHoursSaved = Math.round(manualHoursSpent * conservativeSavingsFactor);\n166 |   const conservativeNetSavings = Math.max(0, conservativeGrossSavings - initialInvestment);\n167 |   const conservativeRoi = initialInvestment > 0 ? Math.round((conservativeNetSavings / initialInvestment) * 100) : 0;\n168 | \n169 |   const conservativeMonthlySavings = conservativeGrossSavings / 12;\n170 |   const conservativePaybackMonths = conservativeMonthlySavings > 0\n171 |     ? Math.max(0.1, Math.round((initialInvestment / conservativeMonthlySavings) * 10) / 10)\n172 |     : 0;\n173 | \n174 |   // AGGRESSIVE GFF CASE (Synergy & Cognitive Multipliers)\n175 |   const aggressiveAdoptionFactor = Math.min(98, automationTarget * 1.15) / 100;\n176 |   const aggressiveProductivityFactor = Math.min(95, productivityImprovement + 15) / 100;\n177 |   const aggressiveSavingsFactor = aggressiveAdoptionFactor * aggressiveProductivityFactor;\n178 | \n179 |   const aggressiveGrossSavings = Math.round(addressableCostBaseline * aggressiveSavingsFactor);\n180 |   const aggressiveHoursSaved = Math.round(manualHoursSpent * aggressiveSavingsFactor);\n181 |   const aggressiveNetSavings = Math.max(0, aggressiveGrossSavings - initialInvestment);\n182 |   const aggressiveRoi = initialInvestment > 0 ? Math.round((aggressiveNetSavings / initialInvestment) * 100) : 0;\n183 | \n184 |   const aggressiveMonthlySavings = aggressiveGrossSavings / 12;\n185 |   const aggressivePaybackMonths = aggressiveMonthlySavings > 0\n186 |     ? Math.max(0.1, Math.round((initialInvestment / aggressiveMonthlySavings) * 10) / 10)\n187 |     : 0;\n188 | \n189 |   // 3. PRIORITIES METADATA\n190 |   const priorities = [\n191 |     {\n192 |       id: \"cost_reduction\" as Priority,\n193 |       title: \"Cost Elimination\",\n194 |       desc: \"Remove manual operational overhead & SaaS redundancies.\",\n195 |       color: \"#E4000F\",\n196 |       bgHex: \"rgba(228, 0, 15, 0.08)\"\n197 |     },\n198 |     {\n199 |       id: \"compliance_security\" as Priority,\n200 |       title: \"Sovereign Compliance\",\n201 |       desc: \"Deploy zero-retention private enclaves to remove legal friction.\",\n202 |       color: \"#9D00FF\",\n203 |       bgHex: \"rgba(157, 0, 255, 0.08)\"\n204 |     },\n205 |     {\n206 |       id: \"operational_speed\" as Priority,\n207 |       title: \"Latency Optimization\",\n208 |       desc: \"Accelerate task completion times from days to milliseconds.\",\n209 |       color: \"#009DFF\",\n210 |       bgHex: \"rgba(0, 157, 255, 0.08)\"\n211 |     },\n212 |     {\n213 |       id: \"customer_experience\" as Priority,\n214 |       title: \"Experience Transformation\",\n215 |       desc: \"Establish instantaneous, context-aware customer resolution pipelines.\",\n216 |       color: \"#00FF9D\",\n217 |       bgHex: \"rgba(0, 255, 157, 0.08)\"\n218 |     },\n219 |     {\n220 |       id: \"decision_automation\" as Priority,\n221 |       title: \"Cognitive Multiplier\",\n222 |       desc: \"Delegate complex analytical operations directly to secure agent networks.\",\n223 |       color: \"#FFBD00\",\n224 |       bgHex: \"rgba(255, 189, 0, 0.08)\"\n225 |     }\n226 |   ];\n227 | \n228 |   const currentPriorityObj = priorities.find(p => p.id === priority) || priorities[0];\n229 | \n230 |   // 4. HELPERS FOR INPUT SAFE VALIDATION & FORMATTING\n231 |   const handleBaselineChange = (val: string) => {\n232 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n233 |     const parsed = parseInt(cleaned) || 0;\n234 |     setAnnualCostBaseline(parsed);\n235 |   };\n236 | \n237 |   const handleVolumeChange = (val: string) => {\n238 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n239 |     const parsed = parseInt(cleaned) || 0;\n240 |     setProcessVolume(parsed);\n241 |   };\n242 | \n243 |   const handleHandlingTimeChange = (val: string) => {\n244 |     if (val === \"\") {\n245 |       setAvgHandlingTime(\"\");\n246 |       return;\n247 |     }\n248 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n249 |     const parsed = parseInt(cleaned) || 0;\n250 |     setAvgHandlingTime(parsed);\n251 |   };\n252 | \n253 |   const handleInvestmentChange = (val: string) => {\n254 |     const cleaned = val.replace(/[^0-9]/g, \"\");\n255 |     const parsed = parseInt(cleaned) || 0;\n256 |     setInitialInvestment(parsed);\n257 |   };\n258 | \n259 |   const formatCompactCurrency = (num: number) => {\n260 |     if (num >= 1000000) return `$${(num / 1000000).toFixed(2)}M`;\n261 |     if (num >= 1000) return `$${(num / 1000).toFixed(0)}K`;\n262 |     return `$${num}`;\n263 |   };\n264 | \n265 |   const formatPayback = (months: number) => {\n266 |     if (months <= 0) return \"Instant Amortization\";\n267 |     if (months < 1) return \"Within 1 Month\";\n268 |     return `${months} Months`;\n269 |   };\n270 | \n271 |   // 5. COPY TO CLIPBOARD ACTION\n272 |   const handleCopyReport = () => {\n273 |     const indName = {\n274 |       financial_services: \"Financial Services\",\n275 |       healthcare: \"Healthcare & Life Sciences\",\n276 |       energy_utilities: \"Energy & Utilities\",\n277 |       telecommunications: \"Telecommunications\",\n278 |       public_sector: \"Public Sector & Government\",\n279 |       retail_logistics: \"Retail & Logistics\",\n280 |       technology_media: \"Technology & Media\"\n281 |     }[industry] || \"Enterprise\";\n282 | \n283 |     const sizeName = {\n284 |       smb: \"< 100 FTE\",\n285 |       mid: \"100 - 500 FTE\",\n286 |       enterprise: \"500 - 2,000 FTE\",\n287 |       large_enterprise: \"2,000 - 10,000 FTE\",\n288 |       global_corp: \"10,000+ FTE\"\n289 |     }[companySize] || \"Enterprise Scale\";\n290 | \n291 |     const funcName = {\n292 |       customer_operations: \"Customer Support & Operations\",\n293 |       legal_compliance: \"Legal, Risk & Compliance\",\n294 |       supply_chain: \"Supply Chain & Logistics\",\n295 |       finance_accounting: \"Finance, Audit & Accounting\",\n296 |       it_engineering: \"IT Service & Infrastructure\",\n297 |       hr_admin: \"People & Administrative Services\"\n298 |     }[opFunction] || \"Operations\";\n299 | \n300 |     const reportMd = `# GFF AI // ENTERPRISE SOVEREIGN ROI SIMULATION REPORT\n301 | Generated: ${new Date().toLocaleDateString()}\n302 | Status: MODELLED - ILLUSTRATIVE ONLY\n303 | \n304 | ## I. ORGANIZATIONAL CONTEXT & PROFILE\n305 | - Industry Sector: ${indName}\n306 | - Enterprise Scale: ${sizeName}\n307 | - Operational Function: ${funcName}\n308 | - Implementation Horizon: ${implementationHorizon.replace(\"_\", \" \")}\n309 | \n310 | ## II. FINANCIAL & OPERATIONAL BASELINE (INPUTS)\n311 | - Annual Operational Cost Baseline: $${annualCostBaseline.toLocaleString()}\n312 | - Current Manual Friction Index: ${manualEffort.toUpperCase()}\n313 | - Modelled Addressable Manual Overhead: $${addressableCostBaseline.toLocaleString()}\n314 | - Annual Process Volume: ${processVolume.toLocaleString()} units\n315 | - Average Handling Time: ${avgHandlingTime ? avgHandlingTime + \" Minutes\" : \"Not Specified (estimated based on sector average)\"}\n316 | - Estimated Loaded Hourly Rate: $${loadedHourlyRate}/hr\n317 | - Estimated Current Manual Effort: ${manualHoursSpent.toLocaleString()} hours/year\n318 | \n319 | ## III. TARGET SOVEREIGN PARAMETERS\n320 | - Automation Target Rate: ${automationTarget}%\n321 | - Expected Productivity Boost: ${productivityImprovement}%\n322 | - Enclave Platform Investment CapEx: $${initialInvestment.toLocaleString()}\n323 | - Strategic Priority Lens: ${currentPriorityObj.title} (${priority.toUpperCase()})\n324 | \n325 | ## IV. KEY RECOVERY METRICS (EXPECTED CASE)\n326 | - Illustrative Annual Reclaimed Value: $${expectedGrossSavings.toLocaleString()}\n327 | - Estimated Annual Productive Hours Saved: ${expectedHoursSaved.toLocaleString()} hours\n328 | - Amortization / Payback Period: ${formatPayback(expectedPaybackMonths)}\n329 | - Net Sovereign Return on Investment (ROI): ${expectedRoi}%\n330 | \n331 | ## V. SCENARIO COMPARISON MATRIX\n332 | - CONSERVATIVE CASE (Risk-Adjusted Execution):\n333 |   * Annual Saved Hours: ${conservativeHoursSaved.toLocaleString()} hrs\n334 |   * Annual Recouped Value: $${conservativeGrossSavings.toLocaleString()}\n335 |   * Amortization Payback: ${formatPayback(conservativePaybackMonths)}\n336 |   * Sovereign ROI: ${conservativeRoi}%\n337 | - EXPECTED CASE (Standard GFF Execution):\n338 |   * Annual Saved Hours: ${expectedHoursSaved.toLocaleString()} hrs\n339 |   * Annual Recouped Value: $${expectedGrossSavings.toLocaleString()}\n340 |   * Amortization Payback: ${formatPayback(expectedPaybackMonths)}\n341 |   * Sovereign ROI: ${expectedRoi}%\n342 | - AGGRESSIVE CASE (Synergistic Multiplier Execution):\n343 |   * Annual Saved Hours: ${aggressiveHoursSaved.toLocaleString()} hrs\n344 |   * Annual Recouped Value: $${aggressiveGrossSavings.toLocaleString()}\n345 |   * Amortization Payback: ${formatPayback(aggressivePaybackMonths)}\n346 |   * Sovereign ROI: ${aggressiveRoi}%\n347 | \n348 | ## VI. FINANCIAL WATERFALL SUMMARY\n349 | - Addressable Manual Friction Loss: $${addressableCostBaseline.toLocaleString()}/yr\n350 | - GFF Sovereign Reclaimed Value (Expected): -$${expectedGrossSavings.toLocaleString()}/yr\n351 | - Enclave CapEx Investment Allocation: +$${initialInvestment.toLocaleString()}\n352 | - Net Annual Sovereign Dividend: $${expectedNetSavings.toLocaleString()}/yr\n353 | \n354 | * DISCLAIMER: All figures are generated for strategic modeling and simulation purposes based on mathematical formulas and illustrative enterprise assumptions. They do not constitute binding financial, commercial, or operational guarantees.`;\n355 | \n356 |     navigator.clipboard.writeText(reportMd);\n357 |     setCopied(true);\n358 |     setTimeout(() => setCopied(false), 2000);\n359 |   };\n360 | \n361 |   // 6. RESET ACTION\n362 |   const handleReset = () => {\n363 |     setIndustry(\"financial_services\");\n364 |     setCompanySize(\"enterprise\");\n365 |     setOpFunction(\"customer_operations\");\n366 |     setAnnualCostBaseline(1500000);\n367 |     setProcessVolume(250000);\n368 |     setAvgHandlingTime(15);\n369 |     setAutomationTarget(65);\n370 |     setManualEffort(\"high\");\n371 |     setProductivityImprovement(50);\n372 |     setImplementationHorizon(\"6_months\");\n373 |     setPriority(\"cost_reduction\");\n374 |   };\n375 | \n376 |   // 7. GET STRATEGIC NARRATIVE\n377 |   const indName = {\n378 |     financial_services: \"Financial Services\",\n379 |     healthcare: \"Healthcare & Life Sciences\",\n380 |     energy_utilities: \"Energy & Utilities\",\n381 |     telecommunications: \"Telecommunications\",\n382 |     public_sector: \"Public Sector & Government\",\n383 |     retail_logistics: \"Retail & Logistics\",\n384 |     technology_media: \"Technology & Media\"\n385 |   }[industry] || \"Enterprise\";\n386 | \n387 |   const funcName = {\n388 |     customer_operations: \"Customer Support & Operations\",\n389 |     legal_compliance: \"Legal, Risk & Compliance\",\n390 |     supply_chain: \"Supply Chain & Logistics\",\n391 |     finance_accounting: \"Finance, Audit & Accounting\",\n392 |     it_engineering: \"IT Service & Infrastructure\",\n393 |     hr_admin: \"People & Administrative Services\"\n394 |   }[opFunction] || \"Operations\";\n395 | \n396 |   return (\n397 |     <ToolPageShell showContact={true}>\n398 |       <ToolHero\n399 |         category=\"FINANCIAL ENGINEERING CORE\"\n400 |         title=\"Sovereign ROI Calculator\"\n401 |         highlightedWord=\"ROI\"\n402 |         description=\"Quantify the fiscal impact, cognitive hours reclaimed, and capital amortization curves achieved by shifting legacy operational friction to GFF secure multi-agent systems.\"\n403 |         metricLabel=\"MODEL VERSION\"\n404 |         metricValue=\"V2.8-SOVEREIGN\"\n405 |       />\n406 | \n407 |       <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n408 |         {/* LEFT COLUMN: Input Control Panel */}\n409 |         <div className=\"lg:col-span-5 space-y-6\">\n410 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 backdrop-blur-md space-y-6 relative group overflow-hidden\">\n411 |             {/* Top accent line */}\n412 |             <div className=\"absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-[#009DFF]/40 to-transparent pointer-events-none\" />\n413 |             \n414 |             <div className=\"border-b border-white/5 pb-3\">\n415 |               <span className=\"text-[10px] font-mono text-white/40 block uppercase tracking-wider\">VARIABLE CONTEXT PANEL</span>\n416 |               <h2 className=\"text-sm font-bold text-white mt-1\">Configure Model Inputs</h2>\n417 |      