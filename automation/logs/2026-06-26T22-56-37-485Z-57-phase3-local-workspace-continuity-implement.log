2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n171 |       </svg>\n172 |     )\n173 |   },\n174 |   {\n175 |     title: \"Marketplace\",\n176 |     href: \"/build/marketplace\",\n177 |     desc: \"Browse and acquire pre-configured sovereign node recipes, certified third-party platform connectors, and core cognitive packages.\",\n178 |     cat: \"DEPLOYABLE REGISTRY\",\n179 |     accent: \"#EC4899\",\n180 |     output: \"Integration YAML Specs\",\n181 |     status: \"RELEASED\",\n182 |     icon: (\n183 |       <svg className=\"w-8 h-8 text-[#EC4899]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n184 |         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10\" />\n185 |       </svg>\n186 |     )\n187 |   },\n188 |   {\n189 |     title: \"Foundry Studio\",\n190 |     href: \"/build/foundry-studio\",\n191 |     desc: \"Visually assemble and edit production-grade multi-agent DAG execution layouts in our interactive workshop.\",\n192 |     cat: \"TOPOLOGY WORKSPACE\",\n193 |     accent: \"#10B981\",\n194 |     output: \"DAG Runtime Layout\",\n195 |     status: \"SIMULATOR ACTIVE\",\n196 |     icon: (\n197 |       <svg className=\"w-8 h-8 text-[#10B981]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n198 |         <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m2-1v2.5M6 18l-2-1v2.5M18 18l2-1v2.5\" />\n199 |       </svg>\n200 |     )\n201 |   }\n202 | ];\n203 | \n204 | \n205 | \n206 | \n207 | export default function BuildHubPage() {\n208 |   const [activeStage, setActiveStage] = useState<Stage>(JOURNEY[1]); // Focus on AI Assessment initially\n209 |   const [activeScenarioIdx, setActiveScenarioIdx] = useState<number>(0);\n210 | \n211 |   // Local storage state checking\n212 |   const [hasProposalDraft, setHasProposalDraft] = useState(false);\n213 |   const [blueprintCount, setBlueprintCount] = useState(0);\n214 |   const [latestBlueprint, setLatestBlueprint] = useState<any>(null);\n215 |   const [latestProposal, setLatestProposal] = useState<any>(null);\n216 |   const [isClient, setIsClient] = useState(false);\n217 | \n218 |   const refreshLocalSessionStates = () => {\n219 |     if (typeof window !== \"undefined\") {\n220 |       try {\n221 |         const propDraft = localStorage.getItem(\"gff_proposal_draft_intake\");\n222 |         if (propDraft) {\n223 |           const parsed = JSON.parse(propDraft);\n224 |           setHasProposalDraft(true);\n225 |           setLatestProposal(parsed);\n226 |         } else {\n227 |           setHasProposalDraft(false);\n228 |           setLatestProposal(null);\n229 |         }\n230 | \n231 |         const blueHistory = localStorage.getItem(\"gff_blueprint_history\");\n232 |         if (blueHistory) {\n233 |           const parsed = JSON.parse(blueHistory);\n234 |           if (Array.isArray(parsed) && parsed.length > 0) {\n235 |             setBlueprintCount(parsed.length);\n236 |             setLatestBlueprint(parsed[0]);\n237 |           } else {\n238 |             setBlueprintCount(0);\n239 |             setLatestBlueprint(null);\n240 |           }\n241 |         } else {\n242 |           setBlueprintCount(0);\n243 |           setLatestBlueprint(null);\n244 |         }\n245 |       } catch (e) {\n246 |         console.error(\"Error reading localStorage keys\", e);\n247 |       }\n248 |     }\n249 |   };\n250 | \n251 |   useEffect(() => {\n252 |     setIsClient(true);\n253 |     refreshLocalSessionStates();\n254 |   }, []);\n255 | \n256 |   const handleCreateMockSession = () => {\n257 |     if (typeof window !== \"undefined\") {\n258 |       const mockProposal = {\n259 |         clientName: \"Enterprise Vanguard Corp\",\n260 |         industry: \"financial-services\",\n261 |         challenge: \"Legacy core banking orchestration with autonomous risk compliance nodes\",\n262 |         budget: \"Tier-3 Enterprise Sovereign Dedicated Enclave\",\n263 |         timeline: \"Immediate 60-day strategic sprint\",\n264 |         step: 2,\n265 |         updatedAt: new Date().toISOString()\n266 |       };\n267 |       localStorage.setItem(\"gff_proposal_draft_intake\", JSON.stringify(mockProposal));\n268 | \n269 |       const mockBlueprint = [\n270 |         {\n271 |           id: \"bp-mock-2026\",\n272 |           score: 84,\n273 |           timestamp: new Date().toISOString(),\n274 |           data: {\n275 |             email: \"architect@vanguard.io\",\n276 |             company: \"Enterprise Vanguard Corp\",\n277 |             cloud: \"hybrid\",\n278 |             agentsCount: \"50-100 Autonomous Agents\",\n279 |             urgency: \"immediate\"\n280 |           }\n281 |         }\n282 |       ];\n283 |       localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(mockBlueprint));\n284 | \n285 |       refreshLocalSessionStates();\n286 |     }\n287 |   };\n288 | \n289 |   const handleClearSessions = () => {\n290 |     if (typeof window !== \"undefined\") {\n291 |       localStorage.removeItem(\"gff_proposal_draft_intake\");\n292 |       localStorage.removeItem(\"gff_blueprint_history\");\n293 |       refreshLocalSessionStates();\n294 |     }\n295 |   };\n296 | \n297 | \n298 |   return (\n299 |     <InnerPageShell>\n300 |       {/* Premium Hero Area */}\n301 |       <InnerPageHero\n302 |         category=\"Build With GFF Hub\"\n303 |         title=\"Sovereign Co-Engineering Workshop\"\n304 |         highlightedWord=\"Sovereign\"\n305 |         description=\"Construct, simulate, validate, and launch custom multi-agent execution systems using our self-service diagnostic suite, roadmap engines, and commercial scoping nodes.\"\n306 |       />\n307 | \n308 |       <div clas