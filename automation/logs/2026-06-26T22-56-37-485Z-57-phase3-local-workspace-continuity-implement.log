andleCreateMockSession}\n336 |                       className=\"px-4 py-2 text-xs font-semibold text-white bg-gradient-to-r from-[#009DFF]/20 to-[#E4000F]/20 hover:from-[#009DFF]/35 hover:to-[#E4000F]/35 border border-white/10 rounded-lg transition-all shadow-[0_0_15px_rgba(0,157,255,0.1)] active:scale-95\"\n337 |                     >\n338 |                       Initialize Mock Draft Workspace\n339 |                     </button>\n340 |                   </div>\n341 |                 ) : (\n342 |                   <div className=\"flex flex-col sm:flex-row items-stretch sm:items-center gap-3\">\n343 |                     {hasProposalDraft && (\n344 |                       <Link\n345 |                         href=\"/build/proposal\"\n346 |                         className=\"p-3.5 rounded-xl border border-[#3B82F6]/30 bg-[#3B82F6]/5 hover:bg-[#3B82F6]/10 transition group text-left max-w-[280px]\"\n347 |                       >\n348 |                         <div className=\"text-[10px] font-mono text-[#3B82F6] font-bold\">PROPOSAL DRAFT DETECTED</div>\n349 |                         <div className=\"text-xs text-white/90 font-medium truncate mt-1\">\n350 |                           {latestProposal?.clientName || \"Proposal Intake\"}\n351 |                         </div>\n352 |                         <div className=\"text-[9px] font-mono text-white/40 mt-1 flex items-center gap-1\">\n353 |                           <span>Resume Draft</span>\n354 |                           <span className=\"group-hover:translate-x-1 transition-transform\">→</span>\n355 |                         </div>\n356 |                       </Link>\n357 |                     )}\n358 | \n359 |                     {blueprintCount > 0 && (\n360 |                       <Link\n361 |                         href=\"/build/blueprint\"\n362 |                         className=\"p-3.5 rounded-xl border border-[#9D00FF]/30 bg-[#9D00FF]/5 hover:bg-[#9D00FF]/10 transition group text-left max-w-[280px]\"\n363 |                       >\n364 |                         <div className=\"text-[10px] font-mono text-[#9D00FF] font-bold\">BLUEPRINT DETECTED</div>\n365 |                         <div className=\"text-xs text-white/90 font-medium truncate mt-1\">\n366 |                           {latestBlueprint?.data?.company || \"Blueprint State\"} ({latestBlueprint?.score || 0}%)\n367 |                         </div>\n368 |                         <div className=\"text-[9px] font-mono text-white/40 mt-1 flex items-center gap-1\">\n369 |                           <span>Resume Architect</span>\n370 |                           <span className=\"group-hover:translate-x-1 transition-transform\">→</span>\n371 |                         </div>\n372 |                       </Link>\n373 |                     )}\n374 | \n375 |                     <button\n376 |                       onClick={handleClearSessions}\n377 |                       className=\"px-3.5 py-3 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-red-500/30 text-white/60 hover:text-red-400 text-xs font-mono transition\"\n378 |                       title=\"Clear session variables\"\n379 |                     >\n380 |                       Clear State\n381 |                     </button>\n382 |                   </div>\n383 |                 )}\n384 |               </div>\n385 |             </div>\n386 |           </section>\n387 |         )}\n388 | \n389 |         {/* SECTION 1: Sovereign Journey Timeline */}\n390 |         <section className=\"p-6 lg:p-10 rounded-[24px] border border-white/5 bg-[#04060b] relative overflow-hidden\">\n391 |           <div className=\"absolute top-0 right-0 w-[30%] h-[30%] bg-[#E4000F]/5 blur-3xl pointer-events-none\" />\n392 |           \n393 |           <div className=\"relative z-10 max-w-[1400px] mx-auto space-y-8\">\n394 |             <div className=\"flex flex-col lg:flex-row justify-between lg:items-end gap-4\">\n395 |               <div>\n396 |                 <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block mb-1\">\n397 |                   ENTERPRISE PROTOCOL PIPELINE\n398 |                 </span>\n399 |                 <h2 className=\"text-2xl lg:text-3xl font-bold text-white tracking-tight\">\n400 |                   The 9-Stage Sovereign Flow\n401 |                 </h2>\n402 |                 <p className=\"text-white/60 text-xs mt-1 max-w-[600px] font-light\">\n403 |                   Inspect the structured deployment milestones GFF AI utilizes to scope, configure, and operate air-gapped cognitive fleets.\n404 |                 </p>\n405 |               </div>\n406 |               <div className=\"text-xs font-mono text-[#009DFF] bg-[#009DFF]/10 px-3 py-1.5 rounded-full border border-[#009DFF]/20 self-start font-semibold\">\n407 |                 PHASE 0{activeStage.n}: {activeStage.name.toUpperCase()}\n408 |               </div>\n409 |             </div>\n410 | \n411 |             {/* Scrollable Timeline Row */}\n412 |             <div className=\"relative overflow-x-auto pb-4 scrollbar-none border-b border-white/5\">\n413 |               <div className=\"min-w-[940px] flex items-center justify-between relative px-2 py-4\">\n414 |                 <div className=\"absolute top-[38px] left-8 right-8 h-[2px] bg-white/5 z-0\" />\n415 |                 <div \n416 |                   className=\"absolute top-[38px] left-8 h-[2px] bg-gradient-to-r from-[#E4000F] to-[#009DFF] z-0 transition-all duration-500\" \n417 |                   style={{ width: `${((activeStage.n - 1) / 8) * 100}%` }} \n418 |                 />\n419 |                 \n420 |                 {JOURNEY.map((stg) => {\n421 |                   const act = activeStage.n === stg.n;\n422 |                   return (\n423 |                     <button \n424 |                       key={stg.n} \n425 |                       onClick={() => setActiveStage(stg)} \n426 |                       className=\"flex f