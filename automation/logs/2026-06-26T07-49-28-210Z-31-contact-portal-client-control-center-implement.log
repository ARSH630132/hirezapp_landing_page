{"ts":"2026-06-26T07:44:05.325Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"6ns1wlps","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/company/contact/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, type FormEvent } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport CompanyNavigation from \"@/components/inner-pages/CompanyNavigation\";\nimport { \n  MessageSquare, Calendar, Shield, HelpCircle, Users, FileText, \n  Globe, Award, Briefcase, Lock, CheckCircle, RefreshCw, Send, Sparkles, Building, ShieldAlert \n} from \"lucide-react\";\n\nconst PATHWAYS = [\n  { id: \"talk-sales\", title: \"Talk To Sales\", tag: \"Agent subscriptions\", icon: MessageSquare, color: \"gradient\", desc: \"Discuss licensing, volume brackets, and custom service boundaries.\" },\n  { id: \"workshop\", title: \"Book Workshop\", tag: \"Engineering sessions\", icon: Calendar, color: \"blue\", desc: \"Schedule a collaborative architectural design workshop.\" },\n  { id: \"consultation\", title: \"Book Consultation\", tag: \"Enterprise strategy\", icon: Sparkles, color: \"red\", desc: \"Arrange a dedicated session with our senior AI strategy team.\" },\n  { id: \"sales\", title: \"Sales\", tag: \"Commercial procurement\", icon: Building, color: \"gradient\", desc: \"Inquire about strategic pricing and volume discounts.\" },\n  { id: \"support\", title: \"Support\", tag: \"Sandbox solutions\", icon: ShieldAlert, color: \"red\", desc: \"Access technical assistance for active sandboxes or API issues.\" },\n  { id: \"partnership\", title: \"Partnership\", tag: \"Lattice ecosystem\", icon: Globe, color: \"blue\", desc: \"Propose technology integrations and strategic alliances.\" },\n  { id: \"media\", title: \"Media\", tag: \"Press & institutional\", icon: FileText, color: \"gradient\", desc: \"Request interviews or research commentary.\" },\n  { id: \"university\", title: \"University\", tag: \"Academic alliances\", icon: Award, color: \"blue\", desc: \"Engage in partnerships regarding decoupled multi-agent engineering.\" },\n  { id: \"investors\", title: \"Investors\", tag: \"Institutional updates\", icon: Shield, color: \"gradient\", desc: \"Direct communications for investors and capital allocators.\" },\n  { id: \"become-partner\", title: \"Become Partner\", tag: \"Join global alliance\", icon: Users, color: \"blue\", desc: \"Register as a certified delivery partner in our global lattice.\" },\n  { id: \"careers\", title: \"Careers\", tag: \"Build decoupled future\", icon: Briefcase, color: \"red\", desc: \"Apply for research, systems engineering, or core infrastructure roles.\" }\n];\n\nexport default function CompanyContactPage() {\n  const [activeId, setActiveId] = useState(\"talk-sales\");\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [success, setSuccess] = useState(false);\n  const [txHash, setTxHash] = useState(\"\");\n  const [formData, setFormData] = useState({ name: \"\", email: \"\", org: \"\", details: \"\", param1: \"\", param2: \"\" });\n\n  const activePath = PATHWAYS.find(p => p.id === activeId) || PATHWAYS[0];\n\n  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>) => {\n    setFormData(prev => ({ ...prev, [e.target.name]: e.target.value }));\n  };\n\n  const handleFormSubmit = async (e: FormEvent<HTMLFormElement>) => {\n    e.preventDefault();\n    setIsSubmitting(true);\n    await new Promise(r => setTimeout(r, 1200));\n    setTxHash(\"GFF-ENCLAVE-\" + Math.random().toString(36).substring(2, 10).toUpperCase());\n    setIsSubmitting(false);\n    setSuccess(true);\n  };\n\n  const resetForm = () => {\n    setFormData({ name: \"\", email: \"\", org: \"\", details: \"\", param1: \"\", param2: \"\" });\n    setSuccess(false);\n  };\n\n  return (\n    <InnerPageShell showContact={false}>\n      <CompanyNavigation />\n      <InnerPageHero\n        category=\"Secure Gateway\"\n        title=\"Decoupled Engagement Hub\"\n        highlightedWord=\"Hub\"\n        description=\"Initiate validation sandbox sessions, structure enterprise pilot programs, or connect with specific functional representatives across GFF AI's zero-trust gateway.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-32\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-start\">\n          {/* Left Column: 11 Pathways selector */}\n          <div className=\"lg:col-span-5 space-y-4\">\n            <div>\n              <span className=\"text-[10px] font-mono tracking-[0.2em] text-[#009DFF] uppercase font-semibold\">Active Routing Matrix</span>\n              <h2 className=\"text-[20px] font-bold text-white tracking-tight mt-1\">Select Objective Gateway</h2>\n            </div>\n\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-2.5 max-h-[580px] overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-white/15\">\n              {PATHWAYS.map(p => {\n                const Icon = p.icon;\n                const active = p.id === activeId;\n                return (\n                  <button\n                    key={p.id}\n                    onClick={() => { setActiveId(p.id); resetForm(); }}\n                    className={`w-full text-left p-3.5 rounded-[16px] border transition-all duration-200 relative group cursor-pointer ${\n                      active ? \"bg-gradient-to-br from-[#0a0a0c] to-[#030304] border-white/15 shadow-lg\" : \"bg-[#020202]/30 border-white/5 hover:border-white/10 hover:bg-white/[0.01]\"\n                    }`}\n                  >\n                    {active && <div className={`absolute top-0 bottom-0 left-0 w-[3px] ${p.color === \"red\" ? \"bg-[#E4000F]\" : p.color === \"blue\" ? \"bg-[#009DFF]\" : \"bg-gradient-to-b from-[#E4000F] to-[#009DFF]\"}`} />}\n                    <div className=\"flex gap-3.5 items-center\">\n                      <div className={`p-2 rounded-[10px] border ${active ? \"border-white/10 bg-white/[0.03] text-white\" : \"border-white/5 bg-white/[0.01] text-white/40 group-hover:text-white/60\"} transition-colors`}>\n                        <Icon className=\"w-4.5 h-4.5\" />\n                      </div>\n                      <div className=\"min-w-0 flex-grow\">\n                        <div className=\"flex items-center justify-between\">\n                          <span className={`text-[14px] font-semibold tracking-tight transition-colors ${active ? \"text-white\" : \"text-white/70 group-hover:text-white\"}`}>{p.title}</span>\n                          <span className={`w-1.5 h-1.5 rounded-full ${active ? p.color === \"red\" ? \"bg-[#E4000F] shadow-[0_0_8px_#E4000F]\" : \"bg-[#009DFF] shadow-[0_0_8px_#009DFF]\" : \"bg-white/10\"}`} />\n                        </div>\n                        <span className=\"text-[11px] text-white/40 block mt-0.5 truncate\">{p.tag}</span>\n                      </div>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* Right Column: Portal Form */}\n          <div className=\"lg:col-span-7\">\n            <div className=\"rounded-[22px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] p-6 lg:p-8 relative overflow-hidden\">\n              <div className=\"flex items-start gap-3 mb-6 border-b border-white/5 pb-4\">\n                <span className=\"p-1.5 rounded-[8px] bg-white/5 border border-white/10 text-white/70\">\n                  {React.createElement(activePath.icon, { className: \"w-4.5 h-4.5\" })}\n                </span>\n                <div>\n                  <h3 className=\"text-[16px] font-bold text-white tracking-tight\">{activePath.title} Gateway</h3>\n                  <p className=\"text-[12px] text-white/50\">{activePath.desc}</p>\n                </div>\n              </div>\n\n              {!success ? (\n                <form onSubmit={handleFormSubmit} className=\"space-y-5\">\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                    <div>\n                      <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Contact Principal</label>\n                      <input name=\"name\" type=\"text\" required placeholder=\"Full Name\" value={formData.name} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                    </div>\n                    <div>\n                      <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Business Email</label>\n                      <input name=\"email\" type=\"email\" required placeholder=\"principal@firm.com\" value={formData.email} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Organization / Institution</label>\n                    <input name=\"org\" type=\"text\" required placeholder=\"Legal enterprise name\" value={formData.org} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                  </div>\n\n                  {/* Pathway-specific Fields */}\n                  {[\"talk-sales\", \"sales\"].includes(activeId) && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Operational Scale</label>\n                        <select name=\"param1\" required value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Scale</option>\n                          <option value=\"1-10\">1-10 Sovereign Agents</option>\n                          <option value=\"10-100\">10-100 Integrated Nodes</option>\n                          <option value=\"100+\">100+ Enterprise Enclaves</option>\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Target Platform Core</label>\n                        <select name=\"param2\" required value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Platform</option>\n                          <option value=\"RetailMesh\">RetailMesh Mesh</option>\n                          <option value=\"Oremesh\">Oremesh Industrial</option>\n                          <option value=\"Foundry\">Foundry Orchestration</option>\n                          <option value=\"Runtime\">Runtime Governance</option>\n                        </select>\n                      </div>\n                    </div>\n                  )}\n\n                  {[\"workshop\", \"consultation\"].includes(activeId) && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Format</label>\n                        <select name=\"param1\" required value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Format</option>\n                          <option value=\"virtual\">Virtual Sandbox</option>\n                          <option value=\"onsite\">On-site Session</option>\n                          <option value=\"decoupled\">Decoupled Design Lab</option>\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Technical Depth</label>\n                        <select name=\"param2\" required value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Depth</option>\n                          <option value=\"executive\">Executive Narrative</option>\n                          <option value=\"architect\">Systems Deep-Dive</option>\n                        </select>\n                      </div>\n                    </div>\n                  )}\n\n                  {activeId === \"support\" && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Severity Priority</label>\n                        <select name=\"param1\" required value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Severity</option>\n                          <option value=\"sev1\">Sev 1 - Outage</option>\n                          <option value=\"sev2\">Sev 2 - Impairment</option>\n                          <option value=\"sev3\">Sev 3 - General Assistance</option>\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Sandbox Environment ID</label>\n                        <input name=\"param2\" required placeholder=\"e.g. GFF-CORE-102\" value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                      </div>\n                    </div>\n                  )}\n\n                  {[\"partnership\", \"become-partner\"].includes(activeId) && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Alignment Model</label>\n                        <select name=\"param1\" required value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Model</option>\n                          <option value=\"gsi\">Global Integrator (GSI)</option>\n                          <option value=\"api\">API Alliance</option>\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Geographic Focus</label>\n                        <select name=\"param2\" required value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Region</option>\n                          <option value=\"apac\">APAC (Singapore Core)</option>\n                          <option value=\"emea\">EMEA (London Core)</option>\n                        </select>\n                      </div>\n                    </div>\n                  )}\n\n                  {activeId === \"careers\" && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Engineering Specialty</label>\n                        <select name=\"param1\" required value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Specialty</option>\n                          <option value=\"multi-agent\">Multi-Agent Systems</option>\n                          <option value=\"ebpf\">eBPF Security / Kernel</option>\n                        </select>\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Profile / LinkedIn URL</label>\n                        <input name=\"param2\" type=\"url\" required placeholder=\"https://linkedin.com/...\" value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                      </div>\n                    </div>\n                  )}\n\n                  {/* Fallback parameters for others */}\n                  {![\"talk-sales\", \"sales\", \"workshop\", \"consultation\", \"support\", \"partnership\", \"become-partner\", \"careers\"].includes(activeId) && (\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-5\">\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Primary Theme</label>\n                        <input name=\"param1\" required placeholder=\"Academic research / Press\" value={formData.param1} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-white/[0.01] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\" />\n                      </div>\n                      <div>\n                        <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Response Timeline</label>\n                        <select name=\"param2\" required value={formData.param2} onChange={handleInputChange} className=\"w-full h-[46px] rounded-[12px] border border-white/10 bg-[#050505] px-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all\">\n                          <option value=\"\">Select Timeline</option>\n                          <option value=\"asap\">Immediate (24h)</option>\n                          <option value=\"standard\">Standard Protocol</option>\n                        </select>\n                      </div>\n                    </div>\n                  )}\n\n                  <div>\n                    <label className=\"block text-[10.5px] uppercase tracking-widest text-white/50 mb-1.5 font-mono\">Operational Parameters & Context</label>\n                    <textarea name=\"details\" required rows={3} placeholder=\"Describe specific integration requirements, scaling boundaries, or collaboration priorities...\" value={formData.details} onChange={handleInputChange} className=\"w-full rounded-[12px] border border-white/10 bg-white/[0.01] p-4 text-white text-[13px] outline-none font-mono focus:border-white/20 transition-all resize-none\" />\n                  </div>\n\n                  <button type=\"submit\" disabled={isSubmitting} className=\"w-full h-[48px] rounded-[12px] bg-white text-black font-semibold text-[12.5px] tracking-wider uppercase hover:bg-white/90 transition-all cursor-pointer flex items-center justify-center gap-2 disabled:opacity-50\">\n                    {isSubmitting ? (\n                      <>\n                        <RefreshCw className=\"w-4.5 h-4.5 animate-spin\" />\n                        <span>Transmitting over secure enclave...</span>\n                      </>\n                    ) : (\n                      <>\n                        <span>Transmit Request Protocol</span>\n                        <Send className=\"w-3.5 h-3.5\" />\n                      </>\n                    )}\n                  </button>\n\n                  <div className=\"flex gap-3 p-3.5 rounded-[12px] bg-white/[0.01] border border-white/5\">\n                    <Lock className=\"w-4 h-4 text-white/30 shrink-0 mt-0.5\" />\n                    <p className=\"text-[11px] text-white/40 leading-relaxed font-mono\">\n                      SECURE BOUNDARY: This contact portal is a premium frontend-only simulation. Data is processed locally in browser sandbox memory and never persisted or sent to remote servers.\n                    </p>\n                  </div>\n                </form>\n              ) : (\n                <div className=\"py-12 text-center flex flex-col items-center justify-center\">\n                  <div className=\"w-14 h-14 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 flex items-center justify-center mb-5\">\n                    <CheckCircle className=\"w-7 h-7\" />\n                  </div>\n                  <span className=\"px-2.5 py-0.5 text-[9px] font-mono font-bold text-green-400 bg-green-500/5 border border-green-500/20 rounded-full uppercase tracking-widest mb-3\">Transmission Signed</span>\n                  <h3 className=\"text-[20px] font-bold text-white tracking-tight\">Decapsulation Succeeded</h3>\n                  <p className=\"text-[13px] leading-relaxed text-white/60 max-w-[440px] mt-2\">\n                    Your request was processed inside our simulated secure environment. No actual data was transmitted or retained.\n                  </p>\n                  <div className=\"mt-5 p-3.5 rounded-[12px] bg-white/[0.02] border border-white/5 max-w-[420px] w-full text-left font-mono text-[11px] space-y-1.5\">\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\"><span className=\"text-white/30\">RECEIPT HASH</span><span className=\"text-white/80\">{txHash}</span></div>\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\"><span className=\"text-white/30\">DESTINATION</span><span className=\"text-[#009DFF] uppercase\">{activePath.id}-enclave</span></div>\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\"><span className=\"text-white/30\">INTEGRITY</span><span className=\"text-white/80\">SHA-256 SIGNED</span></div>\n                    <div className=\"flex justify-between\"><span className=\"text-white/30\">SIM STATUS</span><span className=\"text-green-400 font-bold\">FRONTEND_ONLY_SUCCESS</span></div>\n                  </div>\n                  <button onClick={resetForm} className=\"mt-6 text-[11.5px] font-mono tracking-widest uppercase text-white/50 hover:text-white flex items-center gap-2 border border-white/10 hover:border-white/20 bg-white/[0.01] px-5 py-2 rounded-full transition-all cursor-pointer\">\n                    <RefreshCw className=\"w-3.5 h-3.5\" />\n                    <span>Reset Gateway</span>\n                  </button>\n                </div>\n              )}\n            </div>\n          </div>\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
