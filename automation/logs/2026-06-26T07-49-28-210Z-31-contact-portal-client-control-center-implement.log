{"ts":"2026-06-26T07:43:29.256Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"1ykp49sc","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/company/contact/page.tsx","new_text":"\"use client\";\n\nimport React, { useState, type FormEvent } from \"react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport CompanyNavigation from \"@/components/inner-pages/CompanyNavigation\";\nimport { \n  MessageSquare, Calendar, Shield, HelpCircle, Users, FileText, \n  Globe, Award, Briefcase, ChevronRight, Lock, Key, CheckCircle, \n  RefreshCw, Send, AlertTriangle, Sparkles, Building, Mail, \n  ArrowRight, ShieldAlert \n} from \"lucide-react\";\n\n// Types for the pathway\ninterface Pathway {\n  id: string;\n  title: string;\n  tagline: string;\n  icon: React.ComponentType<{ className?: string }>;\n  description: string;\n  primaryColor: \"red\" | \"blue\" | \"gradient\";\n}\n\nexport default function CompanyContactPage() {\n  // 11 requested pathways\n  const pathways: Pathway[] = [\n    {\n      id: \"talk-sales\",\n      title: \"Talk To Sales\",\n      tagline: \"Configure agent subscriptions\",\n      icon: MessageSquare,\n      description: \"Discuss licensing, custom volume deployments, and enterprise service-level boundaries.\",\n      primaryColor: \"gradient\",\n    },\n    {\n      id: \"workshop\",\n      title: \"Book Workshop\",\n      tagline: \"Hands-on engineering sessions\",\n      icon: Calendar,\n      description: \"Schedule a collaborative architectural design workshop with GFF AI lead system design team.\",\n      primaryColor: \"blue\",\n    },\n    {\n      id: \"consultation\",\n      title: \"Book Consultation\",\n      tagline: \"Enterprise strategy mapping\",\n      icon: Sparkles,\n      description: \"Arrange a dedicated consultative session with our senior AI strategy architects.\",\n      primaryColor: \"red\",\n    },\n    {\n      id: \"sales\",\n      title: \"Sales\",\n      tagline: \"Direct commercial procurement\",\n      icon: Building,\n      description: \"Inquire about strategic agency pricing, volume discount brackets, and customized terms.\",\n      primaryColor: \"gradient\",\n    },\n    {\n      id: \"support\",\n      title: \"Support\",\n      tagline: \"Sovereign sandbox troubleshooting\",\n      icon: ShieldAlert,\n      description: \"Access technical assistance for active multi-agent sandbox boundaries or API integration issues.\",\n      primaryColor: \"red\",\n    },\n    {\n      id: \"partnership\",\n      title: \"Partnership\",\n      tagline: \"Lattice ecosystem integration\",\n      icon: Globe,\n      description: \"Propose technology integrations, distribution agreements, or ecosystem synergies.\",\n      primaryColor: \"blue\",\n    },\n    {\n      id: \"media\",\n      title: \"Media\",\n      tagline: \"Press and institutional inquiries\",\n      icon: FileText,\n      description: \"Request interviews, authorized brand assets, or expert commentary from the GFF research team.\",\n      primaryColor: \"gradient\",\n    },\n    {\n      id: \"university\",\n      title: \"University\",\n      tagline: \"Academic research alliances\",\n      icon: Award,\n      description: \"Engage in research partnerships regarding decoupled sovereign state multi-agent engineering.\",\n      primaryColor: \"blue\",\n    },\n    {\n      id: \"investors\",\n      title: \"Investors\",\n      tagline: \"Sovereign transformation updates\",\n      icon: Shield,\n      description: \"Direct communications for institutional investors, capital allocators, and strategic partners.\",\n      primaryColor: \"gradient\",\n    },\n    {\n      id: \"become-partner\",\n      title: \"Become Partner\",\n      tagline: \"Join our global alliance\",\n      icon: Users,\n      description: \"Register as a certified delivery partner or systems integrator in our global lattice.\",\n      primaryColor: \"blue\",\n    },\n    {\n      id: \"careers\",\n      title: \"Careers\",\n      tagline: \"Build the decoupled future\",\n      icon: Briefcase,\n      description: \"Apply for research, systems engineering, or core infrastructure roles at our global cores.\",\n      primaryColor: \"red\",\n    },\n  ];\n\n  const [activePathway, setActivePathway] = useState<string>(\"talk-sales\");\n  const [isSubmitting, setIsSubmitting] = useState(false);\n  const [submissionSuccess, setSubmissionSuccess] = useState(false);\n  const [txHash, setTxHash] = useState(\"\");\n\n  // Form states\n  const [formData, setFormData] = useState({\n    fullName: \"\",\n    businessEmail: \"\",\n    organization: \"\",\n    details: \"\",\n    param1: \"\", // Pathway specific parameter 1\n    param2: \"\", // Pathway specific parameter 2\n  });\n\n  const selectedPathway = pathways.find((p) => p.id === activePathway) || pathways[0];\n\n  const handleInputChange = (e: React.ChangeEvent<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>) => {\n    const { name, value } = e.target;\n    setFormData((prev) => ({ ...prev, [name]: value }));\n  };\n\n  const handleFormSubmit = async (e: FormEvent<HTMLFormElement>) => {\n    e.preventDefault();\n    setIsSubmitting(true);\n\n    // Simulate cryptographic processing delay\n    await new Promise((resolve) => setTimeout(resolve, 1500));\n\n    // Generate simulated routing hash\n    const hash = \"GFF-ENCLAVE-\" + Math.random().toString(36).substring(2, 10).toUpperCase() + \"-\" + Math.random().toString(36).substring(2, 6).toUpperCase();\n    \n    setTxHash(hash);\n    setIsSubmitting(false);\n    setSubmissionSuccess(true);\n  };\n\n  const resetForm = () => {\n    setFormData({\n      fullName: \"\",\n      businessEmail: \"\",\n      organization: \"\",\n      details: \"\",\n      param1: \"\",\n      param2: \"\",\n    });\n    setSubmissionSuccess(false);\n    setTxHash(\"\");\n  };\n\n  // Helper to render pathway-specific form fields\n  const renderPathwayFields = () => {\n    switch (activePathway) {\n      case \"talk-sales\":\n      case \"sales\":\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Operational Node Scale\n                </label>\n                <select\n                  name=\"param1\"\n                  required\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select deployment scale</option>\n                  <option value=\"1-10\" className=\"bg-[#050505]\">1 - 10 Sovereign Agents</option>\n                  <option value=\"10-100\" className=\"bg-[#050505]\">10 - 100 Integrated Nodes</option>\n                  <option value=\"100+\" className=\"bg-[#050505]\">100+ Enterprise Enclaves</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Target Platform Core\n                </label>\n                <select\n                  name=\"param2\"\n                  required\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select primary core</option>\n                  <option value=\"RetailMesh\" className=\"bg-[#050505]\">RetailMesh Sovereign Mesh</option>\n                  <option value=\"Oremesh\" className=\"bg-[#050505]\">Oremesh Industrial Core</option>\n                  <option value=\"Foundry\" className=\"bg-[#050505]\">Foundry Orchestration Sandbox</option>\n                  <option value=\"RuntimeGovernance\" className=\"bg-[#050505]\">Runtime Governance Platform</option>\n                  <option value=\"Other\" className=\"bg-[#050505]\">Custom Core / Not Sure</option>\n                </select>\n              </div>\n            </div>\n          </>\n        );\n      case \"workshop\":\n      case \"consultation\":\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Preferred Workshop Format\n                </label>\n                <select\n                  name=\"param1\"\n                  required\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select execution format</option>\n                  <option value=\"virtual\" className=\"bg-[#050505]\">Virtual Sandbox Simulation</option>\n                  <option value=\"onsite\" className=\"bg-[#050505]\">On-site Core Architecture Session</option>\n                  <option value=\"decoupled\" className=\"bg-[#050505]\">Decoupled Enclave Design Lab</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Technical Depth Required\n                </label>\n                <select\n                  name=\"param2\"\n                  required\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select architectural level</option>\n                  <option value=\"executive\" className=\"bg-[#050505]\">Executive Transformation Narrative</option>\n                  <option value=\"lead-architect\" className=\"bg-[#050505]\">Systems & Core Engineering Deep Dive</option>\n                  <option value=\"developer-practical\" className=\"bg-[#050505]\">Developer Sandbox Workshop</option>\n                </select>\n              </div>\n            </div>\n          </>\n        );\n      case \"support\":\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Priority Tier Threshold\n                </label>\n                <select\n                  name=\"param1\"\n                  required\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#E4000F] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select priority severity</option>\n                  <option value=\"sev1\" className=\"bg-[#050505]\">Severity 1 - Mission Critical Outage</option>\n                  <option value=\"sev2\" className=\"bg-[#050505]\">Severity 2 - Operational Impairment</option>\n                  <option value=\"sev3\" className=\"bg-[#050505]\">Severity 3 - Sandbox Assistance</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Enclave Environment ID\n                </label>\n                <input\n                  name=\"param2\"\n                  type=\"text\"\n                  required\n                  placeholder=\"e.g. GFF-CORE-8821\"\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-[#E4000F] focus:bg-white/[0.04] transition-all\"\n                />\n              </div>\n            </div>\n          </>\n        );\n      case \"partnership\":\n      case \"become-partner\":\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Partnership Alignment\n                </label>\n                <select\n                  name=\"param1\"\n                  required\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select alignment model</option>\n                  <option value=\"systems-integrator\" className=\"bg-[#050505]\">Global Systems Integrator (GSI)</option>\n                  <option value=\"tech-alliance\" className=\"bg-[#050505]\">Technology & API Core Alliance</option>\n                  <option value=\"academic-co-developer\" className=\"bg-[#050505]\">Sovereign Research Co-developer</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Geographical Focus Core\n                </label>\n                <select\n                  name=\"param2\"\n                  required\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select target region</option>\n                  <option value=\"apac\" className=\"bg-[#050505]\">Asia-Pacific (Singapore Core)</option>\n                  <option value=\"emea\" className=\"bg-[#050505]\">Europe / Middle East (London Core)</option>\n                  <option value=\"americas\" className=\"bg-[#050505]\">Americas Enclave</option>\n                  <option value=\"global\" className=\"bg-[#050505]\">Global Unified Lattice</option>\n                </select>\n              </div>\n            </div>\n          </>\n        );\n      case \"careers\":\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Engineering / Domain Specialty\n                </label>\n                <select\n                  name=\"param1\"\n                  required\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#E4000F] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select domain focus</option>\n                  <option value=\"multi-agent\" className=\"bg-[#050505]\">Multi-Agent Systems Architect</option>\n                  <option value=\"ebpf\" className=\"bg-[#050505]\">eBPF Security & Kernel Engineer</option>\n                  <option value=\"compiler\" className=\"bg-[#050505]\">Decoupled Compiler/LLVM Specialist</option>\n                  <option value=\"systems-general\" className=\"bg-[#050505]\">Core Infrastructure Engineer</option>\n                </select>\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Professional Profile Link\n                </label>\n                <input\n                  name=\"param2\"\n                  type=\"url\"\n                  required\n                  placeholder=\"https://linkedin.com/in/yourprofile\"\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-[#E4000F] focus:bg-white/[0.04] transition-all\"\n                />\n              </div>\n            </div>\n          </>\n        );\n      default: // university, investors, media\n        return (\n          <>\n            <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Primary Theme of Inquiry\n                </label>\n                <input\n                  name=\"param1\"\n                  type=\"text\"\n                  required\n                  placeholder=\"e.g. Collaborative research / Press briefing\"\n                  value={formData.param1}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                />\n              </div>\n              <div>\n                <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                  Estimated Response Timeline\n                </label>\n                <select\n                  name=\"param2\"\n                  required\n                  value={formData.param2}\n                  onChange={handleInputChange}\n                  className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white outline-none font-mono text-[13px] focus:border-[#009DFF] focus:bg-white/[0.04] transition-all\"\n                >\n                  <option value=\"\" disabled className=\"bg-[#050505]\">Select timeline urgency</option>\n                  <option value=\"asap\" className=\"bg-[#050505]\">Immediate (24-48 hours)</option>\n                  <option value=\"standard\" className=\"bg-[#050505]\">Standard Corporate Protocol</option>\n                  <option value=\"flexible\" className=\"bg-[#050505]\">Flexible Co-development Schedule</option>\n                </select>\n              </div>\n            </div>\n          </>\n        );\n    }\n  };\n\n  return (\n    <InnerPageShell showContact={false}>\n      <CompanyNavigation />\n      \n      <InnerPageHero\n        category=\"Secure Corporate Access\"\n        title=\"Decoupled Engagement Hub\"\n        highlightedWord=\"Hub\"\n        description=\"Initiate validation sandbox sessions, structure enterprise pilot programs, or connect with specific functional representatives across GFF AI's zero-trust gateway.\"\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-32\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\">\n          \n          {/* Left Column: 11 Pathways List */}\n          <div className=\"lg:col-span-5 flex flex-col gap-4\">\n            <div className=\"mb-2\">\n              <span className=\"text-[10px] font-mono tracking-[0.2em] uppercase text-[#009DFF]\">\n                Active Routing Matrix\n              </span>\n              <h2 className=\"text-[20px] font-bold text-white tracking-tight mt-1\">\n                Select Your Objective Gateway\n              </h2>\n              <p className=\"text-[13px] text-white/55 font-light mt-1\">\n                Requests are decapsulated and handled inside isolated regional operational cores.\n              </p>\n            </div>\n\n            {/* Pathway Cards Container */}\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3 max-h-[640px] overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-white/10\">\n              {pathways.map((path) => {\n                const IconComponent = path.icon;\n                const isActive = path.id === activePathway;\n                return (\n                  <button\n                    key={path.id}\n                    onClick={() => {\n                      setActivePathway(path.id);\n                      resetForm();\n                    }}\n                    className={`w-full text-left p-4 rounded-[18px] border transition-all duration-300 relative group overflow-hidden cursor-pointer ${\n                      isActive\n                        ? \"bg-gradient-to-br from-[#0c0c0e] to-[#040405] border-white/15 shadow-xl\"\n                        : \"bg-[#020202]/30 border-white/5 hover:border-white/10 hover:bg-white/[0.01]\"\n                    }`}\n                  >\n                    {/* Active accent border glow */}\n                    {isActive && (\n                      <div className={`absolute top-0 bottom-0 left-0 w-[4px] ${\n                        path.primaryColor === \"red\" \n                          ? \"bg-[#E4000F]\" \n                          : path.primaryColor === \"blue\" \n                            ? \"bg-[#009DFF]\" \n                            : \"bg-gradient-to-b from-[#E4000F] to-[#009DFF]\"\n                      }`} />\n                    )}\n\n                    <div className=\"flex gap-4 items-start relative z-10\">\n                      <div className={`p-2.5 rounded-[12px] border ${\n                        isActive\n                          ? \"border-white/10 bg-white/[0.03] text-white\"\n                          : \"border-white/5 bg-white/[0.01] text-white/40 group-hover:text-white/60 group-hover:border-white/10\"\n                      } transition-colors`}>\n                        <IconComponent className=\"w-5 h-5\" />\n                      </div>\n                      <div className=\"flex-grow min-w-0\">\n                        <div className=\"flex items-center justify-between\">\n                          <span className={`text-[14.5px] font-semibold tracking-tight transition-colors ${\n                            isActive ? \"text-white\" : \"text-white/70 group-hover:text-white\"\n                          }`}>\n                            {path.title}\n                          </span>\n                          <span className={`w-1.5 h-1.5 rounded-full ${\n                            isActive \n                              ? path.primaryColor === \"red\" \n                                ? \"bg-[#E4000F] shadow-[0_0_8px_#E4000F]\" \n                                : \"bg-[#009DFF] shadow-[0_0_8px_#009DFF]\"\n                              : \"bg-white/10\"\n                          }`} />\n                        </div>\n                        <span className=\"text-[11.5px] text-white/40 block mt-0.5 truncate group-hover:text-white/55 transition-colors\">\n                          {path.tagline}\n                        </span>\n                      </div>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* Right Column: Interactive Form Enclave */}\n          <div className=\"lg:col-span-7\">\n            <div className=\"rounded-[24px] border border-white/5 bg-[#050505]/40 backdrop-blur-[12px] p-6 lg:p-8 relative overflow-hidden\">\n              {/* Subtle ambient lighting inside card */}\n              <div className={`absolute -top-32 -right-32 w-64 h-64 rounded-full blur-[90px] opacity-10 transition-colors duration-500 ${\n                selectedPathway.primaryColor === \"red\" \n                  ? \"bg-[#E4000F]\" \n                  : selectedPathway.primaryColor === \"blue\" \n                    ? \"bg-[#009DFF]\" \n                    : \"bg-gradient-to-tr from-[#E4000F] to-[#009DFF]\"\n              }`} />\n\n              <div className=\"flex items-center gap-2 mb-6 border-b border-white/5 pb-4 relative z-10\">\n                <span className=\"p-1.5 rounded-[8px] bg-white/5 border border-white/10 text-white/70\">\n                  {React.createElement(selectedPathway.icon, { className: \"w-4 h-4\" })}\n                </span>\n                <div>\n                  <h3 className=\"text-[17px] font-bold text-white tracking-tight\">\n                    {selectedPathway.title} Gateway\n                  </h3>\n                  <p className=\"text-[12px] text-white/50\">\n                    {selectedPathway.description}\n                  </p>\n                </div>\n              </div>\n\n              {!submissionSuccess ? (\n                <form onSubmit={handleFormSubmit} className=\"space-y-6 relative z-10\">\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                    <div>\n                      <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                        Contact Principal Name\n                      </label>\n                      <input\n                        name=\"fullName\"\n                        type=\"text\"\n                        required\n                        placeholder=\"Enter full name\"\n                        value={formData.fullName}\n                        onChange={handleInputChange}\n                        className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-white/20 focus:bg-white/[0.04] transition-all\"\n                      />\n                    </div>\n                    <div>\n                      <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                        Business Email Address\n                      </label>\n                      <input\n                        name=\"businessEmail\"\n                        type=\"email\"\n                        required\n                        placeholder=\"e.g. principal@firm.com\"\n                        value={formData.businessEmail}\n                        onChange={handleInputChange}\n                        className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-white/20 focus:bg-white/[0.04] transition-all\"\n                      />\n                    </div>\n                  </div>\n\n                  <div>\n                    <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                      Organization / Institution\n                    </label>\n                    <input\n                      name=\"organization\"\n                      type=\"text\"\n                      required\n                      placeholder=\"Enter legal organizational name\"\n                      value={formData.organization}\n                      onChange={handleInputChange}\n                      className=\"w-full h-[50px] rounded-[14px] border border-white/10 bg-white/[0.02] px-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-white/20 focus:bg-white/[0.04] transition-all\"\n                    />\n                  </div>\n\n                  {/* Render dynamic pathway specific fields */}\n                  {renderPathwayFields()}\n\n                  <div>\n                    <label className=\"block text-[11px] uppercase tracking-widest text-white/50 mb-2 font-mono\">\n                      Operational Parameters & Scope Details\n                    </label>\n                    <textarea\n                      name=\"details\"\n                      required\n                      rows={4}\n                      placeholder=\"Describe target integration requirements, scaling boundaries, or collaboration priorities...\"\n                      value={formData.details}\n                      onChange={handleInputChange}\n                      className=\"w-full rounded-[14px] border border-white/10 bg-white/[0.02] p-4 text-white placeholder-white/20 outline-none font-mono text-[13px] focus:border-white/20 focus:bg-white/[0.04] transition-all resize-none\"\n                    />\n                  </div>\n\n                  {/* Submission Trigger */}\n                  <div className=\"pt-2\">\n                    <button\n                      type=\"submit\"\n                      disabled={isSubmitting}\n                      className=\"w-full h-[52px] rounded-[14px] bg-white text-black font-semibold text-[13px] tracking-wider uppercase hover:bg-white/90 focus:ring-2 focus:ring-white/20 transition-all cursor-pointer flex items-center justify-center gap-2 relative overflow-hidden disabled:opacity-50\"\n                    >\n                      {isSubmitting ? (\n                        <>\n                          <RefreshCw className=\"w-4 h-4 animate-spin\" />\n                          <span>Routing Gateway Secure Message...</span>\n                        </>\n                      ) : (\n                        <>\n                          <span>Transmit Request Protocol</span>\n                          <Send className=\"w-3.5 h-3.5\" />\n                        </>\n                      )}\n                    </button>\n                  </div>\n\n                  {/* Frontend Only Security Safe Notice */}\n                  <div className=\"flex gap-3 p-4 rounded-[14px] bg-white/[0.01] border border-white/5\">\n                    <Lock className=\"w-4.5 h-4.5 text-white/30 shrink-0 mt-0.5\" />\n                    <p className=\"text-[11.5px] text-white/40 leading-relaxed font-mono\">\n                      SECURE DESIGNATION: This form is a premium frontend-only simulation. Submitted data is verified inside the browser sandbox and never reaches remote database servers. No real email, credentials, or telemetry will be harvested.\n                    </p>\n                  </div>\n                </form>\n              ) : (\n                /* Dynamic Verification Overlay on Success */\n                <div className=\"py-12 px-4 text-center flex flex-col items-center justify-center relative z-10\">\n                  <div className=\"w-16 h-16 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 flex items-center justify-center mb-6\">\n                    <CheckCircle className=\"w-8 h-8\" />\n                  </div>\n\n                  <span className=\"px-2.5 py-1 text-[9px] font-mono font-bold text-green-400 bg-green-500/5 border border-green-500/25 rounded-full uppercase tracking-widest mb-4\">\n                    Routing Hash Certified\n                  </span>\n\n                  <h3 className=\"text-[22px] font-bold text-white tracking-tight\">\n                    Secure Decapsulation Completed\n                  </h3>\n\n                  <p className=\"text-[13.5px] leading-relaxed text-white/60 font-light max-w-[480px] mt-3\">\n                    Your transmission was successfully routed inside our premium sandbox interface. The isolated regional gateway issued a certified routing receipt.\n                  </p>\n\n                  <div className=\"mt-6 p-4 rounded-[14px] bg-white/[0.02] border border-white/5 max-w-[460px] w-full text-left font-mono text-[11px] space-y-2\">\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                      <span className=\"text-white/30\">TRANSMISSION ID</span>\n                      <span className=\"text-white/80\">{txHash}</span>\n                    </div>\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                      <span className=\"text-white/30\">DESTINATION GATEWAY</span>\n                      <span className=\"text-[#009DFF] uppercase\">{selectedPathway.id}-enclave</span>\n                    </div>\n                    <div className=\"flex justify-between border-b border-white/5 pb-1\">\n                      <span className=\"text-white/30\">CRYPTO PARAMS</span>\n                      <span className=\"text-white/80\">AES-256 / SHA-256-SIGNED</span>\n                    </div>\n                    <div className=\"flex justify-between pt-1\">\n                      <span className=\"text-white/30\">SANDBOX STATUS</span>\n                      <span className=\"text-green-400 font-bold\">FRONTEND_SIM_OK</span>\n                    </div>\n                  </div>\n\n                  <button\n                    onClick={resetForm}\n                    className=\"mt-8 text-[12px] font-mono tracking-widest uppercase text-white/50 hover:text-white flex items-center gap-2 border border-white/10 hover:border-white/20 bg-white/[0.01] hover:bg-white/[0.03] px-6 py-2.5 rounded-full transition-all cursor-pointer\"\n                  >\n                    <RefreshCw className=\"w-3.5 h-3.5\" />\n                    <span>Reset Gateway Form</span>\n                  </button>\n                </div>\n              )}\n            </div>\n          </div>\n\n        </div>\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
