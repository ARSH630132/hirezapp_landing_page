e)\n 93 |     login_res = client.post(\n 94 |         \"/api/v1/auth/login\",\n 95 |         data={\"username\": \"client_member@apex.com\", \"password\": \"password123\"}\n 96 |     )\n 97 |     token = login_res.json()[\"access_token\"]\n 98 |     headers = {\"Authorization\": f\"Bearer {token}\"}\n 99 | \n100 |     # /api/v1/clients is an admin-only route that requires 'require_admin'\n101 |     response = client.get(\"/api/v1/clients\", headers=headers)\n102 |     assert response.status_code == 403\n103 |     assert \"Operation not permitted\" in response.json()[\"detail\"]\n104 | \n105 | \n106 | def test_5_client_dashboard_data_scoping():\n107 |     \"\"\"\n108 |     5. Verify client dashboard data scoping and multi-tenant isolation.\n109 |     \"\"\"\n110 |     # Get token for client_admin at Apex Global\n111 |     login_res = client.post(\n112 |         \"/api/v1/auth/login\",\n113 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n114 |     )\n115 |     apex_token = login_res.json()[\"access_token\"]\n116 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n117 | \n118 |     # Get apex user details to find client_id\n119 |     me_res = client.get(\"/api/v1/auth/me\", headers=apex_headers)\n120 |     apex_client_id = me_res.json()[\"client_id\"]\n121 | \n122 |     # Verify client user can access their own dashboard\n123 |     res_own = client.get(f\"/api/v1/dashboard/client?client_id={apex_client_id}\", headers=apex_headers)\n124 |     assert res_own.status_code == 200\n125 |     assert res_own.json()[\"success\"] is True\n126 |     assert res_own.json()[\"client_id\"] == apex_client_id\n127 | \n128 |     # Verify client user is BLOCKED from accessing another client's dashboard (e.g. client_id + 1)\n129 |     other_client_id = apex_client_id + 1\n130 |     res_other = client.get(f\"/api/v1/dashboard/client?client_id={other_client_id}\", headers=apex_headers)\n131 |     assert res_other.status_code == 403\n132 |     assert \"Access denied\" in res_other.json()[\"detail\"]\n133 | \n134 | def test_6_projects_list_data_scoping():\n135 |     \"\"\"\n136 |     6. Verify project listing is scoped to the user's client account.\n137 |     \"\"\"\n138 |     # Get token for client_admin at Apex Global\n139 |     login_res = client.post(\n140 |         \"/api/v1/auth/login\",\n141 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n142 |     )\n143 |     apex_token = login_res.json()[\"access_token\"]\n144 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n145 | \n146 |     # Retrieve projects list for Apex Global\n147 |     response = client.get(\"/api/v1/projects\", headers=apex_headers)\n148 |     assert response.status_code == 200\n149 |     projects = response.json()\n150 |     \n151 |     # Check that all retrieved projects belong to the same client_id\n152 |     db = SessionLocal()\n153 |     apex_user = db.query(User).filter(User.email == \"client_admin@apex.com\").first()\n154 |     assert apex_user is not None\n155 |     \n156 |     for proj in projects:\n157 |         assert proj[\"client_id\"] == apex_user.client_id\n158 |     db.close()\n159 | \n160 | def test_7_support_ticket_create_isolation():\n161 |     \"\"\"\n162 |     7. Verify support ticket creation successfully saves data and prevents cross-tenant submissions.\n163 |     \"\"\"\n164 |     # Get token for client_admin at Apex Global\n165 |     login_res = client.post(\n166 |         \"/api/v1/auth/login\",\n167 |         data={\"username\": \"client_admin@apex.com\", \"password\": \"password123\"}\n168 |     )\n169 |     apex_token = login_res.json()[\"access_token\"]\n170 |     apex_headers = {\"Authorization\": f\"Bearer {apex_token}\"}\n171 | \n172 |     db = SessionLocal()\n173 |     apex_user = db.query(User).filter(User.email == \"client_admin@apex.com\").first()\n174 |     apex_client_id = apex_user.client_id\n175 |     other_client = db.query(ClientAccount).filter(ClientAccount.id != apex_client_id).first()\n176 |     other_client_id = other_client.id\n177 |     db.close()\n178 | \n179 |     # Create a valid ticket under own client account\n180 |     ticket_payload = {\n181 |         \"client_id\": apex_client_id,\n182 |         \"title\": \"Smoke Test Ticket\",\n183 |         \"category\": \"Technical\",\n184 |         \"priority\": \"low\",\n185 |         \"status\": \"open\",\n186 |         \"description\": \"This is a backend smoke test ticket description.\"\n187 |     }\n188 |     response_create = client.post(\"/api/v1/support-tickets\", json=ticket_payload, headers=apex_headers)\n189 |     assert response_create.status_code == 201\n190 |     created_ticket = response_create.json()\n191 |     assert created_ticket[\"title\"] == \"Smoke Test Ticket\"\n192 |     assert created_ticket[\"client_id\"] == apex_client_id\n193 | \n194 |     # Try to create a ticket for another client account and verify 403 Forbidden\n195 |     invalid_ticket_payload = {\n196 |         \"client_id\": other_client_id,\n197 |         \"title\": \"Malicious Cross-Tenant Ticket\",\n198 |         \"category\": \"Security\",\n199 |         \"priority\": \"critical\",\n200 |         \"status\": \"open\",\n201 |         \"description\": \"Attempting to insert a ticket into another client account.\"\n202 |     }\n203 |     response_invalid = client.post(\"/api/v1/support-tickets\", json=invalid_ticket_payload, headers=apex_headers)\n204 |     assert response_invalid.status_code == 403\n205 |     assert \"You can only create tickets for your own client account\" in response_invalid.json()[\"detail\"]\n206 | ","success":true}],"durationMs":3}}
