   clients = [c for c in clients if c.status == status]\n 35 |     if industry:\n 36 |         clients = [c for c in clients if industry.lower() in c.industry.lower()]\n 37 |     if region:\n 38 |         clients = [c for c in clients if region.lower() in c.region.lower()]\n 39 |     final_offset = offset if offset is not None else skip\n 40 |     return clients[final_offset:final_offset + limit]\n 41 | \n 42 | @router.get(\"/{client_id}\", response_model=ClientAccountResponse)\n 43 | def get_client(\n 44 |     client_id: int,\n 45 |     db = Depends(get_db),\n 46 |     current_user: User = Depends(require_admin)\n 47 | ):\n 48 |     client = clients_repo.get_by_id(str(client_id))\n 49 |     if not client:\n 50 |         raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=\"Client account not found\")\n 51 |     return client\n 52 | \n 53 | @router.post(\"\", response_model=ClientAccountResponse, status_code=201)\n 54 | def create_client(\n 55 |     client_in: ClientAccountCreate,\n 56 |     db = Depends(get_db),\n 57 |     current_user: User = Depends(require_admin)\n 58 | ):\n 59 |     existing = clients_repo.get_by_name(client_in.name)\n 60 |     if existing:\n 61 |         raise HTTPException(\n 62 |             status_code=status.HTTP_400_BAD_REQUEST,\n 63 |             detail=f\"A client account with name '{client_in.name}' already exists.\"\n 64 |         )\n 65 |     db_client = clients_repo.create(client_in.model_dump())\n 66 |     SystemLoggerService.create_log(\n 67 |         db,\n 68 |         SystemLogCreate(\n 69 |             level=\"INFO\",\n 70 |             message=f\"ClientAccount '{db_client.name}' (ID: {db_client.id}) created by Admin {current_user.email}.\",\n 71 |             module=\"client_management\"\n 72 |         )\n 73 |     )\n 74 |     return db_client\n 75 | \n 76 | @router.patch(\"/{client_id}\", response_model=ClientAccountResponse)\n 77 | def update_client(\n 78 |     client_id: int,\n 79 |     client_in: ClientAccountUpdate,\n 80 |     db = Depends(get_db),\n 81 |     current_user: User = Depends(require_admin)\n 82 | ):\n 83 |     client = clients_repo.get_by_id(str(client_id))\n 84 |     if not client:\n 85 |         raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=\"Client account not found\")\n 86 |     db_client = clients_repo.update(str(client_id), client_in.model_dump(exclude_unset=True))\n 87 |     SystemLoggerService.create_log(\n 88 |         db,\n 89 |         SystemLogCreate(\n 90 |             level=\"INFO\",\n 91 |             message=f\"ClientAccount '{db_client.name}' (ID: {db_client.id}) updated by Admin {current_user.email}.\",\n 92 |             module=\"client_management\"\n 93 |         )\n 94 |     )\n 95 |     return db_client\n 96 | \n 97 | @router.delete(\"/{client_id}\", response_model=ClientAccountResponse)\n 98 | def delete_client(\n 99 |     client_id: int,\n100 |     hard_delete: bool = Query(False),\n101 |     db = Depends(get_db),\n102 |     current_user: User = Depends(require_admin)\n103 | ):\n104 |     client = clients_repo.get_by_id(str(client_id))\n105 |     if not client:\n106 |         raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=\"Client account not found\")\n107 |     if hard_delete:\n108 |         clients_repo.delete(str(client_id))\n109 |         client.status = \"deleted\"\n110 |         SystemLoggerService.create_log(\n111 |             db,\n112 |             SystemLogCreate(\n113 |                 level=\"WARNING\",\n114 |                 message=f\"ClientAccount '{client.name}' (ID: {client_id}) deleted by Admin {current_user.email}.\",\n115 |                 module=\"client_management\"\n116 |             )\n117 |         )\n118 |         return client\n119 |     else:\n120 |         db_client = clients_repo.update(str(client_id), {\"status\": \"archived\"})\n121 |         SystemLoggerService.create_log(\n122 |             db,\n123 |             SystemLogCreate(\n124 |                 level=\