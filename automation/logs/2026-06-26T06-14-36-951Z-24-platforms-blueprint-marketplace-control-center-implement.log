{"ts":"2026-06-26T06:11:31.554Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"14gdv37n","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/blueprint/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport Link from \"next/link\";\nimport { ShieldCheck, Database, Cpu, Network, ArrowRight, AlertCircle, CheckCircle2 } from \"lucide-react\";\nimport InnerPageShell from \"@/components/inner-pages/InnerPageShell\";\nimport InnerPageHero from \"@/components/inner-pages/InnerPageHero\";\nimport MotionReveal from \"@/components/inner-pages/MotionReveal\";\nimport { BentoGrid, BentoCard } from \"@/components/inner-pages/BentoGrid\";\nimport PremiumCTA from \"@/components/inner-pages/PremiumCTA\";\n\nconst DIMENSIONS = [\n  {\n    id: \"gov\",\n    title: \"Governance & Security\",\n    score: 84,\n    icon: ShieldCheck,\n    gap: \"Fragmented security checks without automated kernel logs. Token policies applied at proxy rather than container-level sandboxing.\",\n    target: \"Deploy custom Sovereign Guardrail policies with zero-trust eBPF telemetry and real-time PII masking before agent routing.\",\n    tech: [\"eBPF Shield\", \"Guardrail Engine\"]\n  },\n  {\n    id: \"data\",\n    title: \"Data Surface Density\",\n    score: 42,\n    icon: Database,\n    gap: \"Corporate intellectual property locked across legacy CSVs, internal wikis, and silos with no unified vector-graph mesh.\",\n    target: \"Orchestrate a sovereign hybrid vector-graph index using Neo4j and pgvector to offer low-latency secure search.\",\n    tech: [\"GFF Data Fabric\", \"Graph-Vector\"]\n  },\n  {\n    id: \"compute\",\n    title: \"Compute Scalability\",\n    score: 65,\n    icon: Cpu,\n    gap: \"Compute workloads are statically provisioned on general nodes, leading to excessive token overhead and idle cluster costs.\",\n    target: \"Implement dynamic SLA-based compute scaling that shifts resources dynamically between non-production containers.\",\n    tech: [\"K8s Auto-scalers\", \"vLLM Runtime\"]\n  }\n];\n\nexport default function BlueprintPage() {\n  const [activeId, setActiveId] = useState(\"data\");\n  const activeDim = DIMENSIONS.find((d) => d.id === activeId) || DIMENSIONS[0];\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Tier 0 • Diagnostics\"\n        title=\"Enterprise AI Blueprints\"\n        highlightedWord=\"Blueprints\"\n        description=\"Audit existing data structures, analyze regulatory boundaries, and design mathematically structured multi-agent topologies before writing code.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"Blueprint\" }]}\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-20\">\n        {/* Narrative Banner */}\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-10 border-y border-white/5 items-center\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Strategic Framework</span>\n            <h2 className=\"text-2xl font-bold text-white mt-2\">The Diagnostic Foundation</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light leading-relaxed text-sm\">\n              We believe successful enterprise AI is an architectural discipline, not a series of prompt experiments. Before GFF deploys an agent, we model your entire system topology, audit your data surfaces, and design a deterministic roadmap to convert objectives into secure sovereign software blueprints.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Interactive Scoring Engine */}\n        <MotionReveal className=\"space-y-8\">\n          <h2 className=\"text-xl sm:text-2xl font-bold text-center text-white\">Interactive Readiness Assessor</h2>\n          <div className=\"grid grid-cols-1 md:grid-cols-12 gap-8 max-w-4xl mx-auto items-stretch\">\n            <div className=\"md:col-span-5 flex flex-col gap-3\">\n              {DIMENSIONS.map((dim) => {\n                const Icon = dim.icon;\n                const isSel = dim.id === activeId;\n                return (\n                  <button\n                    key={dim.id}\n                    onClick={() => setActiveId(dim.id)}\n                    className={`p-4 rounded-xl border text-left transition-all flex items-center justify-between ${\n                      isSel ? \"text-[#009DFF] border-[#009DFF]/30 bg-[#009DFF]/5\" : \"border-white/5 bg-black/40 hover:bg-black/60\"\n                    }`}\n                  >\n                    <div className=\"flex items-center gap-3\">\n                      <Icon className={`w-5 h-5 ${isSel ? \"text-[#009DFF]\" : \"text-white/40\"}`} />\n                      <span className=\"text-xs font-bold text-white\">{dim.title}</span>\n                    </div>\n                    <span className=\"text-xs font-mono font-bold text-white/80\">{dim.score}%</span>\n                  </button>\n                );\n              })}\n            </div>\n\n            <div className=\"md:col-span-7 bg-[#04060b] rounded-xl border border-white/10 p-6 flex flex-col justify-between\">\n              <div>\n                <span className=\"text-[9px] uppercase tracking-wider font-mono text-white/40\">Readiness Gap Inspector</span>\n                <h3 className=\"text-base font-bold text-white mt-1\">{activeDim.title} Analysis</h3>\n                <div className=\"mt-4 space-y-3\">\n                  <div>\n                    <span className=\"flex items-center gap-1.5 text-red-400 font-mono text-[9px] uppercase\"><AlertCircle className=\"w-3.5 h-3.5\" /> Identified Gap</span>\n                    <p className=\"text-xs text-white/60 leading-relaxed font-light mt-1\">{activeDim.gap}</p>\n                  </div>\n                  <div>\n                    <span className=\"flex items-center gap-1.5 text-green-400 font-mono text-[9px] uppercase\"><CheckCircle2 className=\"w-3.5 h-3.5\" /> GFF Recommendation</span>\n                    <p className=\"text-xs text-white/80 leading-relaxed font-light mt-1\">{activeDim.target}</p>\n                  </div>\n                </div>\n              </div>\n              <div className=\"mt-6 pt-4 border-t border-white/5 flex items-center justify-between flex-wrap gap-2\">\n                <div className=\"flex gap-1\">\n                  {activeDim.tech.map((t) => (\n                    <span key={t} className=\"px-1.5 py-0.5 rounded bg-white/5 border border-white/10 text-[9px] font-mono text-white/60\">{t}</span>\n                  ))}\n                </div>\n                <Link href=\"/build/blueprint\" className=\"text-xs text-[#009DFF] hover:underline flex items-center gap-1\">Configure Simulator →</Link>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        {/* Expected Impact Bento Grid */}\n        <MotionReveal className=\"space-y-8\">\n          <h2 className=\"text-xl sm:text-2xl font-bold text-center text-white\">Solution Topologies & Expected Impact</h2>\n          <BentoGrid>\n            <BentoCard\n              title=\"Autonomous Compliance Core\"\n              description=\"Continuous eBPF kernel monitors scanning live database transactions, auto-redacting PII leaks and validating regulatory schemas.\"\n              badge=\"Security Mesh\"\n              glowColor=\"red\"\n              metric={{ value: \"-98%\", label: \"PII Leakage Risk\" }}\n            />\n            <BentoCard\n              title=\"Cognitive Pipeline Mesh\"\n              description=\"Sovereign multi-agent router connecting multi-modal models to parse complex regulatory compliance requests and compile departmental assets.\"\n              badge=\"Reasoning Loop\"\n              glowColor=\"blue\"\n              metric={{ value: \"10x\", label: \"Workload Throughput\" }}\n            />\n            <BentoCard\n              title=\"Action Gateway Network\"\n              description=\"Cryptographically signed outbound brokers executing idempotent operations in legacy SAP systems with human-approval gates.\"\n              badge=\"Deterministic Execution\"\n              glowColor=\"purple\"\n              metric={{ value: \"Zero-Risk\", label: \"State Recoverability\" }}\n            />\n          </BentoGrid>\n        </MotionReveal>\n\n        {/* 90-Day Roadmap */}\n        <MotionReveal className=\"space-y-8\">\n          <h2 className=\"text-xl sm:text-2xl font-bold text-center text-white\">90-Day Enterprise Roadmap</h2>\n          <div className=\"max-w-3xl mx-auto space-y-4\">\n            {[\n              { phase: \"Phase 1: Days 1-30\", title: \"Diagnostics & Topology Design\", desc: \"Conduct stakeholder workshops, execute GFF Readiness assessments, and map target security boundaries.\" },\n              { phase: \"Phase 2: Days 31-60\", title: \"Sandbox Prototype & DAG Coding\", desc: \"Establish local sandbox clusters inside the GFF Garage, model agent graphs inside Foundry, and load knowledge bases.\" },\n              { phase: \"Phase 3: Days 61-90\", title: \"Cluster Scaling & Production Delivery\", desc: \"Promote validated agents into elastic clusters in GFF Factory, connect production SAP/SQL streams, and launch operations.\" }\n            ].map((p, idx) => (\n              <div key={idx} className=\"p-5 rounded-xl border border-white/5 bg-black/40 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 hover:border-[#009DFF]/20 transition-all\">\n                <div>\n                  <span className=\"text-[9px] font-mono font-bold text-[#009DFF] uppercase tracking-wider\">{p.phase}</span>\n                  <h3 className=\"font-bold text-white text-base mt-0.5\">{p.title}</h3>\n                  <p className=\"text-xs text-white/50 leading-relaxed font-light mt-1\">{p.desc}</p>\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        <PremiumCTA\n          title=\"Scale Your Enterprise Topology Design\"\n          description=\"Ready to design your custom sovereign system? Launch our interactive, frontend-only simulator to instantly model execution boundaries and download a pre-formatted structure.\"\n          primaryLabel=\"Launch Blueprint Generator\"\n          primaryHref=\"/build/blueprint\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}\n"}}}
