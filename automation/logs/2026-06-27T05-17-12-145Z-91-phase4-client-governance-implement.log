{"ts":"2026-06-27T05:12:02.103Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"qj0f41b4","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/governance/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { \n  ShieldCheck, ShieldAlert, CheckCircle, AlertCircle, FileText, Copy, Search, \n  X, ChevronRight, ChevronDown, Download, Lock, RefreshCw, UserCheck, \n  ThumbsUp, ThumbsDown, Info, Layers, Cpu, SlidersHorizontal, ExternalLink, RotateCcw\n} from \"lucide-react\";\nimport { WorkspaceCard, StatusBadge } from \"@/components/private-app\";\n\ninterface PolicyItem {\n  id: string;\n  name: string;\n  standard: \"ISO-27001\" | \"SOC2 Type II\" | \"HIPAA\" | \"GDPR Enclave\" | \"NIST AI RMF\";\n  status: \"compliant\" | \"warning\" | \"critical\";\n  severity: \"high\" | \"medium\" | \"low\";\n  projectId: string;\n  projectName: string;\n  agentId: string;\n  agentName: string;\n  desc: string;\n  lastChecked: string;\n  logs: string[];\n}\n\ninterface OversightItem {\n  id: string;\n  title: string;\n  project: string;\n  projectId: string;\n  agent: string;\n  agentId: string;\n  requester: string;\n  status: \"pending\" | \"approved\" | \"rejected\";\n  severity: \"high\" | \"medium\" | \"low\";\n  requestDate: string;\n  category: \"Access Elevation\" | \"Model Boundary Shift\" | \"HSM Seal Rollover\";\n  desc: string;\n}\n\ninterface DocItem {\n  id: string;\n  name: string;\n  size: string;\n  format: \"PDF\" | \"YAML\" | \"CSV\";\n  projectId: string;\n  projectName: string;\n  agentId: string;\n  agentName: string;\n  status: \"compliant\" | \"warning\";\n  hash: string;\n  uploadedAt: string;\n  category: \"audit\" | \"governance\";\n  clearanceLevel: string;\n}\n\nexport default function ClientGovernancePage() {\n  // -----------------------------------------------------------------------------\n  // MOCK DATASETS (Enriched with project, agent, status, and severity)\n  // -----------------------------------------------------------------------------\n  const [policies, setPolicies] = useState<PolicyItem[]>([\n    {\n      id: \"GOV-27001-A\",\n      name: \"ISO-27001 Cryptographic Key Hygiene\",\n      standard: \"ISO-27001\",\n      status: \"compliant\",\n      severity: \"high\",\n      projectId: \"proj-001\",\n      projectName: \"Sovereign Core Sandbox 02\",\n      agentId: \"agent-001\",\n      agentName: \"RETAIL-CORE-A1\",\n      desc: \"Enforces 30-day automatic key rotation inside HSM pools to ensure credential isolation.\",\n      lastChecked: \"2026-06-27T11:00:00Z\",\n      logs: [\n        \"Initializing key rotation handshake with hardware module...\",\n        \"Cryptographic root keys verified via zero-knowledge proof.\",\n        \"Rotation completed successfully. Signature logged.\"\n      ]\n    },\n    {\n      id: \"GOV-SOC2-B\",\n      name: \"eBPF Sandboxed Host Execution Boundaries\",\n      standard: \"SOC2 Type II\",\n      status: \"compliant\",\n      severity: \"high\",\n      projectId: \"proj-001\",\n      projectName: \"Sovereign Core Sandbox 02\",\n      agentId: \"agent-001\",\n      agentName: \"RETAIL-CORE-A1\",\n      desc: \"Active kernel monitoring ensuring sandbox containers cannot inspect host memory.\",\n      lastChecked: \"2026-06-27T11:30:00Z\",\n      logs: [\n        \"Streaming eBPF ring buffer events...\",\n        \"Verifying isolation: Host syscall table locked.\",\n        \"Zero boundary violations detected in current epoch.\"\n      ]\n    },\n    {\n      id: \"GOV-NIST-C\",\n      name: \"Sovereign Compliance Model Audit Range\",\n      standard: \"NIST AI RMF\",\n      status: \"warning\",\n      severity: \"medium\",\n      projectId: \"proj-002\",\n      projectName: \"Model Guardrail Sandbox 04\",\n      agentId: \"agent-002\",\n      agentName: \"ALIGN-GUARD-A2\",\n      desc: \"Continuous filtering log stream audits. Warning: Log storage approach threshold.\",\n      lastChecked: \"2026-06-27T10:15:00Z\",\n      logs: [\n        \"Analyzing prompt distribution...\",\n        \"Telemetry logs approaching local warning threshold (88%).\",\n        \"Action: Trigger compression / archival routines.\"\n      ]\n    },\n    {\n      id: \"GOV-HIPAA-D\",\n      name: \"Patient Identity Isolation Enclave\",\n      standard: \"HIPAA\",\n      status: \"compliant\",\n      severity: \"high\",\n      projectId: \"proj-001\",\n      projectName: \"Sovereign Core Sandbox 02\",\n      agentId: \"agent-004\",\n      agentName: \"MED-CLINIC-H9\",\n      desc: \"Cryptographically redacts high-risk patient fields inside the enclave memory partition.\",\n      lastChecked: \"2026-06-27T09:00:00Z\",\n      logs: [\n        \"Intercepted clinical inference payload...\",\n        \"PII scrubbed via local tokenization. Redaction: COMPLETE.\"\n      ]\n    },\n    {\n      id: \"GOV-EXEC-F\",\n      name: \"Thread Allocation Leak-Gate Check\",\n      standard: \"NIST AI RMF\",\n      status: \"critical\",\n      severity: \"high\",\n      projectId: \"proj-001\",\n      projectName: \"Sovereign Core Sandbox 02\",\n      agentId: \"agent-004\",\n      agentName: \"MED-CLINIC-H9\",\n      desc: \"Monitors context leaks. Warning: Thread utilization is above safe thresholds (94.5%).\",\n      lastChecked: \"2026-06-27T11:58:11Z\",\n      logs: [\n        \"Anomaly detected: Sustained high thread utilization.\",\n        \"Recommendation: Scale execution partition into adjacent SGX nodes.\"\n      ]\n    }\n  ]);\n\n  const [approvals, setApprovals] = useState<OversightItem[]>([\n    {\n      id: \"OVS-001\",\n      title: \"Elevate Alexander Mercer to Level IV Clearance\",\n      project: \"Sovereign Core Sandbox 02\",\n      projectId: \"proj-001\",\n      agent: \"RETAIL-CORE-A1\",\n      agentId: \"agent-001\",\n      requester: \"Apex Sovereign Group\",\n      status: \"pending\",\n      severity: \"high\",\n      requestDate: \"2026-06-27T11:15:00Z\",\n      category: \"Access Elevation\",\n      desc: \"Temporary elevation request to inspect active HSM enclave raw decryption socket.\"\n    },\n    {\n      id: \"OVS-002\",\n      title: \"Shift Model Boundary Execution Parameters\",\n      project: \"Model Guardrail Sandbox 04\",\n      projectId: \"proj-002\",\n      agent: \"ALIGN-GUARD-A2\",\n      agentId: \"agent-002\",\n      requester: \"Alexander Mercer\",\n      status: \"pending\",\n      severity: \"medium\",\n      requestDate: \"2026-06-27T10:45:00Z\",\n      category: \"Model Boundary Shift\",\n      desc: \"Adjust semantic boundary threshold to 0.75 for geological taxonomy analysis.\"\n    },\n    {\n      id: \"OVS-003\",\n      title: \"Force HSM Cryptographic Manual Key Rollover\",\n      project: \"Sovereign Core Sandbox 02\",\n      projectId: \"proj-001\",\n      agent: \"RETAIL-CORE-A1\",\n      agentId: \"agent-001\",\n      requester: \"Dr. Sarah Vance\",\n      status: \"approved\",\n      severity: \"high\",\n      requestDate: \"2026-06-25T09:00:00Z\",\n      category: \"HSM Seal Rollover\",\n      desc: \"Manual signature to roll cryptographically sealed root keys and bypass interlock timers.\"\n    }\n  ]);\n\n  const [documents, setDocuments] = useState<DocItem[]>([\n    {\n      id: \"DOC-GOV-01\",\n      name: \"ISO27001_Sovereign_Sandbox_Audit_2026.pdf\",\n      size: \"4.8 MB\",\n      format: \"PDF\",\n      projectId: \"proj-001\",\n      projectName: \"Sovereign Core Sandbox 02\",\n      agentId: \"agent-001\",\n      agentName: \"RETAIL-CORE-A1\",\n      status: \"compliant\",\n      hash: \"0x8FDE3102C130D7B2D26788AB0E8A850CE3207FFCDE10B74E824A45B12A4F23AA\",\n      uploadedAt: \"2026-05-12T10:30:00Z\",\n      category: \"audit\",\n      clearanceLevel: \"LEVEL_III\"\n    },\n    {\n      id: \"DOC-GOV-02\",\n      name: \"Guardrail_Ruleset_SOC2_Compliance_Signed.yaml\",\n      size: \"24 KB\",\n      format: \"YAML\",\n      projectId: \"proj-002\",\n      projectName: \"Model Guardrail Sandbox 04\",\n      agentId: \"agent-002\",\n      agentName: \"ALIGN-GUARD-A2\",\n      status: \"compliant\",\n      hash: \"0x3FBC128EE809FF9CC9810A88AA11B8FFFA02CE8274A08B0192A45C89FBC10492\",\n      uploadedAt: \"2026-06-01T15:45:00Z\",\n      category: \"governance\",\n      clearanceLevel: \"LEVEL_IV\"\n    }\n  ]);\n\n  // -----------------------------------------------------------------------------\n  // SELECTION & FILTER STATES\n  // -----------------------------------------------------------------------------\n  const [selectedProject, setSelectedProject] = useState(\"\");\n  const [selectedAgent, setSelectedAgent] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedSeverity, setSelectedSeverity] = useState(\"\");\n  const [searchTerm, setSearchTerm] = useState(\"\");\n\n  const [activeTab, setActiveTab] = useState<\"policies\" | \"oversight\" | \"documents\">(\"policies\");\n  const [expandedPolicyId, setExpandedPolicyId] = useState<string | null>(\"GOV-27001-A\");\n  const [activeStep, setActiveStep] = useState(\"step-4\");\n\n  // Interaction Toast State\n  const [toasts, setToasts] = useState<{ id: string; message: string; type: \"success\" | \"info\" | \"warning\" }[]>([]);\n  const [verifyingId, setVerifyingId] = useState<string | null>(null);\n  const [exportingId, setExportingId] = useState<string | null>(null);\n\n  const addToast = (message: string, type: \"success\" | \"info\" | \"warning\" = \"success\") => {\n    const id = Math.random().toString(36).substring(2, 9);\n    setToasts(prev => [...prev, { id, message, type }]);\n    setTimeout(() => setToasts(prev => prev.filter(t => t.id !== id)), 4000);\n  };\n\n  // -----------------------------------------------------------------------------\n  // DYNAMIC FILTERS (Applied across all tabs)\n  // -----------------------------------------------------------------------------\n  const filteredPolicies = policies.filter(p => {\n    if (selectedProject && p.projectId !== selectedProject) return false;\n    if (selectedAgent && p.agentId !== selectedAgent) return false;\n    if (selectedStatus && p.status !== selectedStatus) return false;\n    if (selectedSeverity && p.severity !== selectedSeverity) return false;\n    if (searchTerm) {\n      const s = searchTerm.toLowerCase();\n      return p.name.toLowerCase().includes(s) || p.desc.toLowerCase().includes(s) || p.id.toLowerCase().includes(s);\n    }\n    return true;\n  });\n\n  const filteredApprovals = approvals.filter(a => {\n    if (selectedProject && a.projectId !== selectedProject) return false;\n    if (selectedAgent && a.agentId !== selectedAgent) return false;\n    if (selectedStatus && a.status !== selectedStatus) return false;\n    if (selectedSeverity && a.severity !== selectedSeverity) return false;\n    if (searchTerm) {\n      const s = searchTerm.toLowerCase();\n      return a.title.toLowerCase().includes(s) || a.desc.toLowerCase().includes(s) || a.id.toLowerCase().includes(s);\n    }\n    return true;\n  });\n\n  const filteredDocuments = documents.filter(d => {\n    if (selectedProject && d.projectId !== selectedProject) return false;\n    if (selectedAgent && d.agentId !== selectedAgent) return false;\n    if (selectedStatus && d.status !== selectedStatus) return false;\n    if (selectedSeverity && d.severity !== selectedSeverity) return false;\n    if (searchTerm) {\n      return d.name.toLowerCase().includes(searchTerm.toLowerCase()) || d.id.toLowerCase().includes(searchTerm.toLowerCase());\n    }\n    return true;\n  });\n\n  // Extract select options dynamically\n  const projectOptions = Array.from(new Set([\n    ...policies.map(p => JSON.stringify({ id: p.projectId, name: p.projectName })),\n    ...approvals.map(a => JSON.stringify({ id: a.projectId, name: a.project })),\n    ...documents.map(d => JSON.stringify({ id: d.projectId, name: d.projectName }))\n  ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n\n  const agentOptions = Array.from(new Set([\n    ...policies.map(p => JSON.stringify({ id: p.agentId, name: p.agentName })),\n    ...approvals.map(a => JSON.stringify({ id: a.agentId, name: a.agent })),\n    ...documents.map(d => JSON.stringify({ id: d.agentId, name: d.agentName }))\n  ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n\n  // Real-time calculation of dynamic trust score based on interactive page state\n  const criticalCount = policies.filter(p => p.status === \"critical\").length;\n  const warningCount = policies.filter(p => p.status === \"warning\").length;\n  const pendingCount = approvals.filter(a => a.status === \"pending\").length;\n  const approvedCount = approvals.filter(a => a.status === \"approved\").length;\n\n  const trustScore = Math.min(100, Math.max(0, \n    99.5 - (criticalCount * 7.5) - (warningCount * 3.5) - (pendingCount * 1.5) + (approvedCount * 0.8)\n  )).toFixed(1);\n\n  const handleResetFilters = () => {\n    setSelectedProject(\"\");\n    setSelectedAgent(\"\");\n    setSelectedStatus(\"\");\n    setSelectedSeverity(\"\");\n    setSearchTerm(\"\");\n    addToast(\"All governance filters reset\", \"info\");\n  };\n\n  // -----------------------------------------------------------------------------\n  // ACTIONS\n  // -----------------------------------------------------------------------------\n  const handleVerifyPolicy = (id: string) => {\n    if (verifyingId) return;\n    setVerifyingId(id);\n    addToast(`Initiating cryptographic verify handshake for ${id}...`, \"info\");\n    setTimeout(() => {\n      setPolicies(prev => prev.map(p => {\n        if (p.id === id) {\n          return {\n            ...p,\n            status: \"compliant\",\n            lastChecked: new Date().toISOString(),\n            logs: [\n              `[${new Date().toLocaleTimeString()}] MANUAL-RECHECK: Handshake established.`,\n              `[${new Date().toLocaleTimeString()}] ENCLAVE: Hardware-attested standard verified.`,\n              ...p.logs\n            ]\n          };\n        }\n        return p;\n      }));\n      setVerifyingId(null);\n      addToast(`Policy ${id} verified and confirmed compliant.`, \"success\");\n    }, 1200);\n  };\n\n  const handleResolveApproval = (id: string, state: \"approved\" | \"rejected\") => {\n    setApprovals(prev => prev.map(a => a.id === id ? { ...a, status: state } : a));\n    if (state === \"approved\") {\n      addToast(`Human interlock signature committed for ${id}`, \"success\");\n    } else {\n      addToast(`Access interlock request rejected for ${id}`, \"warning\");\n    }\n  };\n\n  const handleExportDocument = (id: string) => {\n    if (exportingId) return;\n    setExportingId(id);\n    addToast(`Compiling attestation certificate package for ${id}...`, \"info\");\n    setTimeout(() => {\n      setExportingId(null);\n      addToast(`Attestation Certificate ${id} compiled and exported.`, \"success\");\n    }, 1500);\n  };\n\n  // -----------------------------------------------------------------------------\n  // INTERACTIVE TOPOLOGY STEPS\n  // -----------------------------------------------------------------------------\n  const diagramSteps = [\n    { id: \"step-1\", title: \"1. Prompt Ingress Node\", metric: \"0.4ms latency\", desc: \"Client-facing transaction streams are ingested and parsed inside localized process loops.\" },\n    { id: \"step-2\", title: \"2. Guardrail Interception\", metric: \"Active (99.8% pass)\", desc: \"Analyzes inputs against configured semantic compliance rules and redacts sensitive data.\" },\n    { id: \"step-3\", title: \"3. Secure Enclave Isolation\", metric: \"SGX-SNP Locked\", desc: \"Performs model execution in high-security physically decoupled memory partitions.\" },\n    { id: \"step-4\", title: \"4. Human Oversight Interlock\", metric: `${pendingCount} Handshakes Pending`, desc: \"Sensitive boundary alterations block at hardware level awaiting explicit user signatures.\" },\n    { id: \"step-5\", title: \"5. Sealed State Ledger\", metric: \"SHA-256 Committed\", desc: \"Transactions are cryptographically stamped and registered into immutable client auditing logs.\" }\n  ];\n\n  return (\n    <div className=\"space-y-6 max-w-[1700px] mx-auto pb-16 animate-slide-up\">\n      \n      {/* A. WORKFLOW NOTICE DISCLAIMER (NO LEGAL GUARANTEES) */}\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl p-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 font-mono text-[11px] leading-relaxed relative overflow-hidden\">\n        <div className=\"flex items-start gap-2.5 text-white/80 max-w-4xl\">\n          <ShieldAlert className=\"w-5 h-5 text-[#009DFF] shrink-0 mt-0.5\" />\n          <span>\n            <strong className=\"text-white\">SOVEREIGN WORKFLOW ASSISTANCE:</strong> This interface is <strong className=\"text-[#009DFF]\">designed to support governance workflows</strong>. \n            All checks, state indications, and audit certificates represent simulated sandbox parameters tailored for governance assistance, and do not constitute formal legal or regulatory compliance guarantees.\n          </span>\n        </div>\n        <span className=\"text-[9px] text-[#009DFF]/90 font-bold bg-[#009DFF]/15 border border-[#009DFF]/30 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 select-none\">\n          AUDIT ASSISTANT ACTIVE\n        </span>\n      </div>\n\n      {/* B. PAGE HEADER */}\n      <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 border-b border-white/5 pb-5 select-none font-mono\">\n        <div>\n          <div className=\"flex items-center gap-2\">\n            <h1 className=\"text-xl md:text-2xl font-bold tracking-tight text-white uppercase\">Sovereign Governance</h1>\n            <span className=\"inline-flex rounded bg-[#00FFC2]/10 border border-[#00FFC2]/20 px-1.5 py-0.5 text-[9px] font-bold uppercase text-[#00FFC2]\">\n              SECURE BOUNDARY LOCK\n            </span>\n          </div>\n          <p className=\"text-[12px] text-white/50 mt-1 leading-relaxed max-w-2xl\">\n            Real-time telemetry, automated guardrail verification blocks, human interlock points, and cryptographically hashed document audit records.\n          </p>\n        </div>\n        <div className=\"text-[10px] text-white/40 bg-white/[0.01] border border-white/5 px-2.5 py-1.5 rounded-lg shrink-0\">\n          Enclave Epoch: <span className=\"text-white font-bold\">2026.E3</span>\n        </div>\n      </div>\n\n      {/* C. BENTO GRID: METRICS & DIAGRAM */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Left column - Metrics */}\n        <div className=\"flex flex-col gap-4\">\n          <WorkspaceCard className=\"flex flex-col justify-between h-[105px] border-[#00FFC2]/10\">\n            <div className=\"flex justify-between items-start\">\n              <span className=\"text-[10px] font-mono tracking-wider text-white/40 uppercase\">Dynamic Trust Index</span>\n              <StatusBadge state=\"active\" label=\"continuous check\" />\n            </div>\n            <div className=\"flex items-end justify-between mt-1\">\n              <div className=\"text-3xl font-bold font-mono tracking-tight text-white\">{trustScore}%</div>\n              <span className=\"text-[9.5px] font-mono text-emerald-400 flex items-center gap-1\">\n                Optimized <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n              </span>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className=\"flex flex-col justify-between h-[105px]\">\n            <div className=\"flex justify-between items-start\">\n              <span className=\"text-[10px] font-mono tracking-wider text-white/40 uppercase\">AI Rulesets & Policies</span>\n              <span className=\"text-[9px] font-mono text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20\">MONITORED</span>\n            </div>\n            <div className=\"flex items-end justify-between mt-1\">\n              <div className=\"text-3xl font-bold font-mono tracking-tight text-white\">{policies.length}</div>\n              <span className=\"text-[9.5px] font-mono text-white/50\">\n                {policies.filter(p => p.status === \"compliant\").length} Locked • {policies.filter(p => p.status !== \"compliant\").length} Alerts\n              </span>\n            </div>\n          </WorkspaceCard>\n\n          <WorkspaceCard className={`flex flex-col justify-between h-[105px] transition-all ${\n            pendingCount > 0 ? \"border-amber-500/20 bg-amber-500/[0.01]\" : \"\"\n          }`}>\n            <div className=\"flex justify-between items-start\">\n              <span className=\"text-[10px] font-mono tracking-wider text-white/40 uppercase\">Pending Interlocks</span>\n              {pendingCount > 0 ? (\n                <span className=\"text-[9px] font-mono text-amber-400 bg-amber-400/10 px-1.5 py-0.5 rounded border border-amber-400/20 animate-pulse\">SIGNATURE NEEDED</span>\n              ) : (\n                <span className=\"text-[9px] font-mono text-white/30\">ALL SIGNED</span>\n              )}\n            </div>\n            <div className=\"flex items-end justify-between mt-1\">\n              <div className=\"text-3xl font-bold font-mono tracking-tight text-white\">{pendingCount}</div>\n              <span className=\"text-[9.5px] font-mono text-white/40\">\n                Awaiting client administrator keys\n              </span>\n            </div>\n          </WorkspaceCard>\n        </div>\n\n        {/* Right column - Interactive Flow Diagram */}\n        <div className=\"lg:col-span-2\">\n          <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n            \n            {/* Inline CSS Keyframe */}\n            <style dangerouslySetInnerHTML={{ __html: `\n              @keyframes flow { to { stroke-dashoffset: -20; } }\n              .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n            `}} />\n\n            {/* Left side: Flow Nodes */}\n            <div className=\"flex-grow flex flex-col justify-between gap-4\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n                <div className=\"flex items-center gap-1.5\">\n                  <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                  <span className=\"font-mono text-[11px] font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n                </div>\n                <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology Map</span>\n              </div>\n\n              <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n                {/* Connector line */}\n                <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n                  <svg className=\"w-full h-[2px] overflow-visible\">\n                    <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n                    <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n                  </svg>\n                </div>\n\n                {diagramSteps.map((step, idx) => {\n                  const isActive = activeStep === step.id;\n                  const colors = \n                    step.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n                    step.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n                    step.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n                    step.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" :\n                    \"border-emerald-500/10 text-emerald-400\";\n                  \n                  const glow = isActive \n                    ? `shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102` \n                    : \"bg-black/45 hover:border-white/10\";\n\n                  return (\n                    <button \n                      key={step.id}\n                      onClick={() => setActiveStep(step.id)}\n                      className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${colors} ${glow}`}\n                    >\n                      <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${\n                        isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"\n                      }`}>\n                        {step.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n                        {step.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n                        {step.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n                        {step.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n                        {step.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n                      </div>\n                      <div className=\"text-center font-mono select-none\">\n                        <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n                        <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">\n                          {step.id === \"step-1\" ? \"Ingress\" : step.id === \"step-2\" ? \"Guardrail\" : step.id === \"step-3\" ? \"Enclave\" : step.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}\n                        </span>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n            </div>\n\n            {/* Right side: Node Telemetry Panel */}\n            <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n              {(() => {\n                const activeInfo = diagramSteps.find(s => s.id === activeStep) || diagramSteps[0];\n                return (\n                  <div className=\"space-y-3 h-full flex flex-col justify-between\">\n                    <div className=\"space-y-1.5\">\n                      <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">NODE METRICS</span>\n                      <p className=\"text-white font-bold text-[11.5px]\">{activeInfo.title}</p>\n                      \n                      <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n                        <span className={`w-1 h-1 rounded-full ${activeStep === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n                        <span className=\"text-white/40\">Status:</span>\n                        <span className={`font-bold ${activeStep === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>\n                          {activeInfo.metric}\n                        </span>\n                      </div>\n                      \n                      <p className=\"text-[10px] text-white/50 leading-normal pt-1\">\n                        {activeInfo.desc}\n                      </p>\n                    </div>\n                    \n                    <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 select-none\">\n                      <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n                      <span>Mathematical boundary verified</span>\n                    </div>\n                  </div>\n                );\n              })()}\n            </div>\n\n          </div>\n        </div>\n\n      </div>\n\n      {/* D. GOVERNANCE INTERACTIVE FILTERS */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#070707]/60 backdrop-blur-sm space-y-3 font-mono\">\n        <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n          <div className=\"flex items-center gap-1.5\">\n            <SlidersHorizontal className=\"w-3.5 h-3.5 text-white/50\" />\n            <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Dynamic Workspace Filters</h3>\n          </div>\n          {(selectedProject || selectedAgent || selectedStatus || selectedSeverity || searchTerm) && (\n            <button \n              onClick={handleResetFilters}\n              className=\"flex items-center gap-1 text-[10px] text-amber-500 hover:text-amber-400 cursor-pointer\"\n            >\n              <RotateCcw className=\"w-3 h-3\" /> Reset Filters\n            </button>\n          )}\n        </div>\n\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n          \n          <div>\n            <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Project Context</label>\n            <select \n              value={selectedProject} \n              onChange={(e) => { setSelectedProject(e.target.value); addToast(\"Filter: Project target updated\", \"info\"); }}\n              className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL PROJECTS</option>\n              {projectOptions.map(p => (\n                <option key={p.id} value={p.id} className=\"bg-[#0c0c0c] text-white\">{p.name.toUpperCase()}</option>\n              ))}\n            </select>\n          </div>\n\n          <div>\n            <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Agent Enclave</label>\n            <select \n              value={selectedAgent} \n              onChange={(e) => { setSelectedAgent(e.target.value); addToast(\"Filter: Agent target updated\", \"info\"); }}\n              className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL AGENTS</option>\n              {agentOptions.map(a => (\n                <option key={a.id} value={a.id} className=\"bg-[#0c0c0c] text-white\">{a.name}</option>\n              ))}\n            </select>\n          </div>\n\n          <div>\n            <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Compliance State</label>\n            <select \n              value={selectedStatus} \n              onChange={(e) => { setSelectedStatus(e.target.value); addToast(\"Filter: Compliance state updated\", \"info\"); }}\n              className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL STATES</option>\n              <option value=\"compliant\" className=\"bg-[#0c0c0c] text-green-400\">COMPLIANT</option>\n              <option value=\"warning\" className=\"bg-[#0c0c0c] text-amber-400\">WARNING ALERT</option>\n              <option value=\"critical\" className=\"bg-[#0c0c0c] text-red-400\">CRITICAL FAULT</option>\n            </select>\n          </div>\n\n          <div>\n            <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Risk Severity</label>\n            <select \n              value={selectedSeverity} \n              onChange={(e) => { setSelectedSeverity(e.target.value); addToast(\"Filter: Severity updated\", \"info\"); }}\n              className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] px-2.5 text-[10.5px] text-white/80 focus:text-white outline-none cursor-pointer appearance-none\"\n            >\n              <option value=\"\" className=\"bg-[#0c0c0c] text-white/40\">ALL SEVERITIES</option>\n              <option value=\"high\" className=\"bg-[#0c0c0c] text-red-400\">HIGH RISK</option>\n              <option value=\"medium\" className=\"bg-[#0c0c0c] text-amber-400\">MEDIUM RISK</option>\n              <option value=\"low\" className=\"bg-[#0c0c0c] text-blue-400\">LOW RISK</option>\n            </select>\n          </div>\n\n          <div>\n            <label className=\"block text-[8px] text-white/40 uppercase mb-0.5\">Search Keywords</label>\n            <div className=\"relative\">\n              <Search className=\"absolute left-2 top-2.5 w-3.5 h-3.5 text-white/35\" />\n              <input \n                type=\"text\" \n                value={searchTerm} \n                onChange={(e) => setSearchTerm(e.target.value)}\n                placeholder=\"Search rule title or standard...\"\n                className=\"w-full h-8.5 rounded-lg border border-white/5 bg-white/[0.02] pl-7.5 pr-7 text-[10.5px] text-white outline-none focus:border-white/10\"\n              />\n              {searchTerm && <X className=\"absolute right-2 top-2.5 w-3.5 h-3.5 text-white/40 cursor-pointer\" onClick={() => setSearchTerm(\"\")} />}\n            </div>\n          </div>\n\n        </div>\n      </div>\n\n      {/* E. WORKSPACE MODULE TABS */}\n      <div className=\"space-y-4\">\n        <div className=\"flex border-b border-white/5 gap-6 select-none font-mono\">\n          \n          <button \n            onClick={() => setActiveTab(\"policies\")}\n            className={`py-2 text-[11.5px] font-bold uppercase transition-all relative flex items-center gap-2 cursor-pointer ${\n              activeTab === \"policies\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"\n            }`}\n          >\n            <span>AI Checks & Policies</span>\n            <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredPolicies.length}</span>\n            {activeTab === \"policies\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n          </button>\n\n          <button \n            onClick={() => setActiveTab(\"oversight\")}\n            className={`py-2 text-[11.5px] font-bold uppercase transition-all relative flex items-center gap-2 cursor-pointer ${\n              activeTab === \"oversight\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"\n            }`}\n          >\n            <span>Human Oversight Interlocks</span>\n            <span className={`px-1 rounded text-[9px] ${pendingCount > 0 ? \"bg-amber-400/10 text-amber-500\" : \"bg-white/5 text-white/50\"}`}>{filteredApprovals.length}</span>\n            {activeTab === \"oversight\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n          </button>\n\n          <button \n            onClick={() => setActiveTab(\"documents\")}\n            className={`py-2 text-[11.5px] font-bold uppercase transition-all relative flex items-center gap-2 cursor-pointer ${\n              activeTab === \"documents\" ? \"text-white\" : \"text-white/40 hover:text-white/70\"\n            }`}\n          >\n            <span>Document Ledger</span>\n            <span className=\"px-1 rounded text-[9px] bg-white/5 text-white/50\">{filteredDocuments.length}</span>\n            {activeTab === \"documents\" && <span className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00FFC2]\" />}\n          </button>\n\n        </div>\n\n        {/* TAB INTERIORS */}\n        <div className=\"space-y-3\">\n          \n          {/* TAB 1: POLICIES */}\n          {activeTab === \"policies\" && (\n            <div className=\"space-y-3\">\n              {filteredPolicies.length === 0 ? (\n                <div className=\"p-10 border border-dashed border-white/5 rounded-2xl text-center font-mono max-w-md mx-auto space-y-2\">\n                  <ShieldAlert className=\"w-6 h-6 text-white/20 mx-auto\" />\n                  <p className=\"text-white font-bold text-xs\">NO POLICIES MATCH FILTERS</p>\n                  <p className=\"text-white/40 text-[10px]\">Try adjusting your active workspace target parameters.</p>\n                </div>\n              ) : (\n                filteredPolicies.map(policy => {\n                  const isExpanded = expandedPolicyId === policy.id;\n                  return (\n                    <div \n                      key={policy.id} \n                      className={`rounded-xl border transition-all ${isExpanded ? \"border-white/10 bg-white/[0.02]\" : \"border-white/5 bg-[#050505]/20\"}`}\n                    >\n                      <div \n                        onClick={() => setExpandedPolicyId(isExpanded ? null : policy.id)}\n                        className=\"p-3.5 flex items-center justify-between gap-3 cursor-pointer font-mono text-xs select-none\"\n                      >\n                        <div className=\"flex items-center gap-2.5 min-w-0\">\n                          {policy.status === \"compliant\" ? <CheckCircle className=\"w-4 h-4 text-[#00FFC2] shrink-0\" /> : policy.status === \"warning\" ? <AlertCircle className=\"w-4 h-4 text-amber-400 shrink-0\" /> : <ShieldAlert className=\"w-4 h-4 text-red-400 shrink-0\" />}\n                          <div className=\"min-w-0\">\n                            <div className=\"flex items-center gap-1.5 flex-wrap\">\n                              <span className=\"text-[10px] text-white/40 font-bold shrink-0\">{policy.id}</span>\n                              <span className=\"text-white font-bold truncate\">{policy.name}</span>\n                              <span className={`text-[8.5px] px-1 border rounded shrink-0 ${policy.severity === \"high\" ? \"text-red-400 border-red-500/10 bg-red-500/5\" : \"text-amber-400 border-amber-500/10 bg-amber-500/5\"}`}>{policy.severity.toUpperCase()}</span>\n                            </div>\n                            <div className=\"flex items-center gap-2 mt-0.5 text-[9.5px] text-white/45 flex-wrap\">\n                              <span>Std: <strong className=\"text-white/70\">{policy.standard}</strong></span>\n                              <span>•</span>\n                              <span>Project: <strong className=\"text-white/70\">{policy.projectName}</strong></span>\n                            </div>\n                          </div>\n                        </div>\n                        <div className=\"flex items-center gap-3 shrink-0\">\n                          <span className={`text-[9px] font-bold uppercase ${policy.status === \"compliant\" ? \"text-[#00FFC2]\" : \"text-amber-400\"}`}>{policy.status.toUpperCase()}</span>\n                          {isExpanded ? <ChevronDown className=\"w-4 h-4 text-white/40\" /> : <ChevronRight className=\"w-4 h-4 text-white/40\" />}\n                        </div>\n                      </div>\n\n                      {isExpanded && (\n                        <div className=\"px-3.5 pb-4.5 border-t border-white/5 pt-3.5 font-mono text-xs text-white/80 space-y-3 select-text\">\n                          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n                            <div className=\"md:col-span-2 p-3 rounded-lg border border-white/5 bg-[#020202]/60\">\n                              <span className=\"text-[8.5px] text-[#009DFF] font-bold uppercase block mb-1\">Enforcement Boundary Spec</span>\n                              <p className=\"text-[11px] leading-relaxed text-white/70\">{policy.desc}</p>\n                            </div>\n                            <div className=\"p-3 rounded-lg border border-white/5 bg-[#020202]/60 flex flex-col justify-between\">\n                              <div className=\"text-[10px] space-y-0.5 text-white/60 mb-2\">\n                                <div className=\"flex justify-between\"><span>Audit Target:</span> <span className=\"text-white\">{policy.agentName}</span></div>\n                                <div className=\"flex justify-between\"><span>Verified At:</span> <span className=\"text-white\">{new Date(policy.lastChecked).toLocaleTimeString()}</span></div>\n                              </div>\n                              <button \n                                onClick={() => handleVerifyPolicy(policy.id)} \n                                disabled={verifyingId !== null}\n                                className=\"w-full h-7.5 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 flex items-center justify-center gap-1 cursor-pointer disabled:opacity-40\"\n                              >\n                                {verifyingId === policy.id ? <RefreshCw className=\"w-3 h-3 animate-spin text-[#00FFC2]\" /> : <ShieldCheck className=\"w-3.5 h-3.5 text-[#00FFC2]\" />}\n                                {verifyingId === policy.id ? \"Checking...\" : \"Recheck Boundary\"}\n                              </button>\n                            </div>\n                          </div>\n\n                          <div className=\"space-y-1 bg-[#020202] p-3 rounded-lg border border-white/5\">\n                            <div className=\"flex justify-between text-[8px] text-white/35 font-bold uppercase pb-1 border-b border-white/5\">\n                              <span>Secure Telemetry Log Stream</span>\n                              <span>Sandbox Enclave Assertions</span>\n                            </div>\n                            <div className=\"space-y-1 max-h-[100px] overflow-y-auto text-[10px] text-white/60 pt-1.5 font-mono select-text\">\n                              {policy.logs.map((log, idx) => (\n                                <div key={idx} className=\"truncate\"><span className=\"text-[#009DFF]\">&gt;</span> {log}</div>\n                              ))}\n                            </div>\n                          </div>\n                        </div>\n                      )}\n                    </div>\n                  );\n                })\n              )}\n            </div>\n          )}\n\n          {/* TAB 2: HUMAN OVERSIGHT */}\n          {activeTab === \"oversight\" && (\n            <div className=\"space-y-3\">\n              {filteredApprovals.length === 0 ? (\n                <div className=\"p-10 border border-dashed border-white/5 rounded-2xl text-center font-mono max-w-md mx-auto space-y-2\">\n                  <UserCheck className=\"w-6 h-6 text-white/20 mx-auto\" />\n                  <p className=\"text-white font-bold text-xs\">NO INTERLOCKS REQUIRING ATTENTION</p>\n                  <p className=\"text-white/40 text-[10px]\">All human oversight points are verified and signed off.</p>\n                </div>\n              ) : (\n                <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                  {filteredApprovals.map(item => (\n                    <div \n                      key={item.id} \n                      className={`p-4 rounded-xl border font-mono text-xs flex flex-col justify-between gap-3 bg-[#050505]/40 transition-all ${\n                        item.status === \"pending\" ? \"border-amber-500/25 bg-amber-500/[0.01]\" : \"border-white/5 opacity-70\"\n                      }`}\n                    >\n                      <div className=\"space-y-2\">\n                        <div className=\"flex justify-between items-start gap-2\">\n                          <div>\n                            <span className=\"text-[8px] text-[#009DFF] font-bold uppercase block\">{item.category.toUpperCase()} • {item.id}</span>\n                            <h4 className=\"text-[12px] font-bold text-white select-text\">{item.title}</h4>\n                          </div>\n                          <span className={`text-[8px] font-bold px-1.5 py-0.5 rounded border uppercase ${\n                            item.status === \"pending\" ? \"text-amber-400 border-amber-400/20 bg-amber-400/5 animate-pulse\" : \"text-green-400 border-green-500/20 bg-green-500/5\"\n                          }`}>{item.status}</span>\n                        </div>\n\n                        <p className=\"text-[10px] text-white/50 leading-relaxed border-t border-white/5 pt-2 select-text\">{item.desc}</p>\n                        \n                        <div className=\"text-[9.5px] text-white/40 space-y-0.5 bg-black/40 p-2 rounded border border-white/5 select-text\">\n                          <div>Scope: <strong className=\"text-white/70\">{item.project}</strong></div>\n                          <div>Requester: <strong className=\"text-white/70\">{item.requester}</strong></div>\n                        </div>\n                      </div>\n\n                      {item.status === \"pending\" ? (\n                        <div className=\"grid grid-cols-2 gap-2 pt-1 select-none\">\n                          <button \n                            onClick={() => handleResolveApproval(item.id, \"rejected\")}\n                            className=\"h-7.5 rounded border border-red-500/20 hover:border-red-500/30 text-[9.5px] font-bold uppercase text-red-400 flex items-center justify-center gap-1 cursor-pointer\"\n                          >\n                            <ThumbsDown className=\"w-3 h-3\" /> Decline\n                          </button>\n                          <button \n                            onClick={() => handleResolveApproval(item.id, \"approved\")}\n                            className=\"h-7.5 rounded bg-[#00FFC2] hover:bg-[#00e0aa] text-[#020202] text-[9.5px] font-bold uppercase flex items-center justify-center gap-1 cursor-pointer\"\n                          >\n                            <ThumbsUp className=\"w-3 h-3\" /> Sign & Approve\n                          </button>\n                        </div>\n                      ) : (\n                        <div className=\"text-[9px] text-white/35 pt-1 flex items-center gap-1.5 select-none\">\n                          <UserCheck className=\"w-3.5 h-3.5\" />\n                          <span>Approved. Handshake sealed with HSM token.</span>\n                        </div>\n                      )}\n                    </div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n\n          {/* TAB 3: DOCUMENTS */}\n          {activeTab === \"documents\" && (\n            <div className=\"space-y-2\">\n              {filteredDocuments.length === 0 ? (\n                <div className=\"p-10 border border-dashed border-white/5 rounded-2xl text-center font-mono max-w-md mx-auto space-y-2\">\n                  <FileText className=\"w-6 h-6 text-white/20 mx-auto\" />\n                  <p className=\"text-white font-bold text-xs\">NO DOCUMENTS MATCH FILTERS</p>\n                  <p className=\"text-white/40 text-[10px]\">No active governance documents match your selection target.</p>\n                </div>\n              ) : (\n                filteredDocuments.map(doc => (\n                  <div \n                    key={doc.id} \n                    className=\"p-3.5 rounded-xl border border-white/5 bg-[#050505]/20 flex flex-col sm:flex-row sm:items-center justify-between gap-3 font-mono text-xs\"\n                  >\n                    <div className=\"flex items-start gap-3 min-w-0\">\n                      <div className=\"w-8 h-8 rounded bg-white/[0.02] border border-white/5 flex items-center justify-center shrink-0\">\n                        <FileText className=\"w-4 h-4 text-white/50\" />\n                      </div>\n                      <div className=\"min-w-0\">\n                        <div className=\"flex items-center gap-2 flex-wrap\">\n                          <span className=\"font-bold text-white text-[12px] truncate select-text\">{doc.name}</span>\n                          <span className=\"text-[8.5px] px-1.5 py-0.2 rounded bg-white/5 border border-white/10 text-white/50\">{doc.format}</span>\n                          <span className=\"text-[8px] px-1.5 py-0.2 rounded bg-[#009DFF]/10 border border-[#009DFF]/20 text-[#009DFF]\">{doc.clearanceLevel}</span>\n                        </div>\n                        <div className=\"text-[9.5px] text-white/40 mt-0.5\">\n                          Size: {doc.size} • Category: {doc.category.toUpperCase()} • Project: {doc.projectName}\n                        </div>\n                      </div>\n                    </div>\n\n                    <div className=\"flex items-center gap-2 flex-wrap sm:flex-nowrap shrink-0\">\n                      <button \n                        onClick={() => { navigator.clipboard.writeText(doc.hash); addToast(\"Cryptographic hash seal copied\", \"success\"); }}\n                        className=\"h-7.5 rounded bg-black border border-white/5 hover:border-white/10 px-2 text-[9.5px] text-white/50 hover:text-white flex items-center gap-1 max-w-[150px] cursor-pointer\"\n                        title=\"Copy cryptographic seal\"\n                      >\n                        <Lock className=\"w-3 h-3 text-[#00FFC2]\" />\n                        <span className=\"truncate\">{doc.hash.substring(0, 8)}...</span>\n                        <Copy className=\"w-3 h-3 text-white/30\" />\n                      </button>\n\n                      <button \n                        onClick={() => handleExportDocument(doc.id)} \n                        disabled={exportingId !== null}\n                        className=\"h-7.5 px-3 rounded bg-white/5 hover:bg-white/10 text-[9.5px] font-bold uppercase text-white border border-white/10 flex items-center justify-center gap-1 cursor-pointer disabled:opacity-40\"\n                      >\n                        {exportingId === doc.id ? <RefreshCw className=\"w-3 h-3 animate-spin text-[#00FFC2]\" /> : <Download className=\"w-3 h-3\" />}\n                        {exportingId === doc.id ? \"Compiling...\" : \"Export Certificate\"}\n                      </button>\n                    </div>\n                  </div>\n                ))\n              )}\n            </div>\n          )}\n\n        </div>\n      </div>\n\n      {/* F. PREMIUM CALL-TO-ACTION */}\n      <WorkspaceCard className=\"mt-6 border-[#009DFF]/10 text-center font-mono\">\n        <div className=\"max-w-xl mx-auto space-y-3 p-2 select-none\">\n          <ShieldCheck className=\"w-6 h-6 text-[#00FFC2] mx-auto animate-pulse-glow\" />\n          <div className=\"space-y-1\">\n            <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Custom Enclave Architecture</h3>\n            <p className=\"text-[11px] text-white/50 leading-relaxed\">\n              Do your operations require hardware interlock integrations, custom security rulebooks, or localized GDPR residency boundaries?\n              Our sovereign systems are built to support enterprise-grade security structures.\n            </p>\n          </div>\n          <div className=\"pt-1.5\">\n            <a href=\"/portal/support\" className=\"inline-flex h-8.5 items-center gap-1.5 px-3.5 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 transition-all cursor-pointer\">\n              <span>Consult Sovereign Architects</span>\n              <ExternalLink className=\"w-3 h-3 text-white/50\" />\n            </a>\n          </div>\n        </div>\n      </WorkspaceCard>\n\n      {/* G. TOAST NOTIFICATION CONTAINER */}\n      <div className=\"fixed bottom-6 right-6 z-50 flex flex-col gap-2 pointer-events-none select-none\">\n        {toasts.map(t => (\n          <div \n            key={t.id} \n            className={`p-3 rounded-xl shadow-2xl border text-[10.5px] font-mono font-bold flex items-center gap-2.5 pointer-events-auto max-w-xs animate-slide-up ${\n              t.type === \"success\" ? \"bg-black border-[#00FFC2]/30 text-[#00FFC2] shadow-[0_4px_15px_rgba(0,255,194,0.1)]\" :\n              t.type === \"warning\" ? \"bg-black border-amber-500/30 text-amber-500 shadow-[0_4px_15px_rgba(245,158,11,0.1)]\" :\n              \"bg-black border-[#009DFF]/30 text-[#009DFF] shadow-[0_4px_15px_rgba(0,157,255,0.1)]\"\n            }`}\n          >\n            {t.type === \"success\" && <CheckCircle className=\"w-3.5 h-3.5 shrink-0\" />}\n            {t.type === \"warning\" && <AlertCircle className=\"w-3.5 h-3.5 shrink-0\" />}\n            {t.type === \"info\" && <Info className=\"w-3.5 h-3.5 shrink-0\" />}\n            <span className=\"leading-tight\">{t.message}</span>\n          </div>\n        ))}\n      </div>\n\n      {/* Styled Animations CSS block */}\n      <style dangerouslySetInnerHTML={{ __html: `\n        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }\n        .animate-slide-up { animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards; }\n        @keyframes glow { 0%, 100% { filter: drop-shadow(0 0 4px rgba(0,255,194,0.2)); } 50% { filter: drop-shadow(0 0 10px rgba(0,255,194,0.4)); } }\n        .animate-pulse-glow { animation: glow 2.5s infinite ease-in-out; }\n      `}} />\n\n    </div>\n  );\n}"}}}
