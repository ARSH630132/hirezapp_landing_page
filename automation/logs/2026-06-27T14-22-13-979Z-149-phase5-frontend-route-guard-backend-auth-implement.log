an access admin panel\n158 |   if (role === \"gff_admin\") return true;\n159 |   \n160 |   if (role === \"gff_operator\") {\n161 |     // Operator cannot access billing, settings, or users management\n162 |     return ![\"billing\", \"settings\", \"users\"].includes(sectionId);\n163 |   }\n164 |   \n165 |   if (role === \"finance_admin\") {\n166 |     // Finance can access dashboard, clients, billing, analytics, activity, settings\n167 |     return [\"dashboard\", \"clients\", \"billing\", \"analytics\", \"activity\", \"settings\"].includes(sectionId);\n168 |   }\n169 |   \n170 |   if (role === \"support_agent\") {\n171 |     // Support agent can access dashboard, clients, support, activity, users\n172 |     return [\"dashboard\", \"clients\", \"support\", \"activity\", \"users\"].includes(sectionId);\n173 |   }\n174 |   \n175 |   if (role === \"viewer\") {\n176 |     // Auditor can view dashboards, activity, governance read-only\n177 |     return [\"dashboard\", \"clients\", \"projects\", \"analytics\", \"governance\", \"activity\"].includes(sectionId);\n178 |   }\n179 |   \n180 |   // Clients (client_admin, client_member) cannot access admin section AT ALL\n181 |   return false;\n182 | }","success":true}],"durationMs":4}}
