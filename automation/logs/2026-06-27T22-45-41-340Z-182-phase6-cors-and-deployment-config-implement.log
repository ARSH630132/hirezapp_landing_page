d ret.name == \"TEST_CLIENT_ALPHA\"\n41 |     try:\n42 |         get_client(client_id=999999, db=db, current_user=usr)\n43 |         assert False, \"Should have raised 404\"\n44 |     except HTTPException as e:\n45 |         assert e.status_code == 404\n46 |         \n47 |     print(\"Testing list_clients and filtering...\")\n48 |     c2 = create_client(client_in=ClientAccountCreate(\n49 |         name=\"TEST_CLIENT_BETA\", industry=\"BioTech\", region=\"Asia\", status=\"pending\", account_owner=\"GFF Beta\"\n50 |     ), db=db, current_user=usr)\n51 |     \n52 |     assert len(list_clients(db=db, current_user=usr, limit=100, skip=0)) >= 2\n53 |     assert len(list_clients(search=\"BETA\", db=db, current_user=usr, limit=100, skip=0)) == 1\n54 |     assert all(c.status == \"pending\" for c in list_clients(status=\"pending\", db=db, current_user=usr, limit=100, skip=0))\n55 |     assert all(c.region == \"Europe\" for c in list_clients(region=\"Europe\", db=db, current_user=usr, limit=100, skip=0))\n56 |     \n57 |     print(\"Testing update_client...\")\n58 |     upd = update_client(client_id=c2.id, client_in=ClientAccountUpdate(\n59 |         region=\"North America\", status=\"active\"\n60 |     ), db=db, current_user=usr)\n61 |     assert upd.region == \"North America\" and upd.status == \"active\"\n62 |     \n63 |     print(\"Testing delete_client (soft archive)...\")\n64 |     soft = delete_client(client_id=c1.id, hard_delete=False, db=db, current_user=usr)\n65 |     assert soft.status == \"archived\"\n66 |     assert clients_repo.get_by_id(str(c1.id)).status == \"archived\"\n67 |     \n68 |     print(\"Testing delete_client (hard delete)...\")\n69 |     hard = delete_client(client_id=c1.id, hard_delete=True, db=db, current_user=usr)\n70 |     assert hard.status == \"deleted\"\n71 |     assert clients_repo.get_by_id(str(c1.id)) is None\n72 |     \n73 |     delete_client(client_id=c2.id, hard_delete=True, db=db, current_user=usr)\n74 |     db.close()\n75 |     print(\"All ClientAccount CRUD API tests completed successfully!\")\n76 | \n77 | if __name__ == \"__main__\":\n78 |     try:\n79 |         run_api_tests()\n80 |         sys.exit(0)\n81 |     except AssertionError:\n82 |         import traceback\n83 |         traceback.print_exc()\n84 |         sys.exit(1)\n85 |     except Exception as e:\n86 |         print(f\"Failed: {e}\")\n87 |         import traceback\n88 |         traceback.print_exc()\n89 |         sys.exit(1)\n90 | ","success":true}],"durationMs":9}}
