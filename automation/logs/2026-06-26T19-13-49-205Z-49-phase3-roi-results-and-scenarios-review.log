sName=\"text-white/40 font-mono text-[10px]\">$</span>\n287 |                   <input\n288 |                     type=\"number\"\n289 |                     value={initialInvestment}\n290 |                     onChange={(e) => setInitialInvestment(Math.max(0, parseInt(e.target.value) || 0))}\n291 |                     className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n292 |                   />\n293 |                 </div>\n294 |               </div>\n295 |               <p className=\"text-[10px] text-white/40 font-light leading-relaxed\">\n296 |                 Anticipated infrastructure setup cost, licensing fee, and engineering resource alignment for GFF enclaves.\n297 |               </p>\n298 |               <input\n299 |                 type=\"range\"\n300 |                 min=\"5000\"\n301 |                 max=\"1500000\"\n302 |                 step=\"5000\"\n303 |                 value={initialInvestment}\n304 |                 onChange={(e) => setInitialInvestment(parseInt(e.target.value))}\n305 |                 className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n306 |               />\n307 |             </div>\n308 | \n309 |             {/* Strategic Priorities Selection Grid */}\n310 |             <div className=\"space-y-3 pt-2\">\n311 |               <span className=\"text-white/60 font-mono text-[10px] uppercase block\">Strategic Core Objective</span>\n312 |               <div className=\"grid grid-cols-1 gap-2\">\n313 |                 {priorities.map((item) => {\n314 |                   const isActive = item.id === priority;\n315 |                   return (\n316 |                     <button\n317 |                       key={item.id}\n318 |                       onClick={() => setPriority(item.id)}\n319 |                       type=\"button\"\n320 |                       className={`text-left p-2.5 rounded-lg border transition-all text-xs flex items-start gap-3 ${\n321 |                         isActive\n322 |                           ? \"bg-white/[0.03] border-white/20 shadow-[0_0_15px_rgba(255,255,255,0.02)]\"\n323 |                           : \"bg-transparent border-white/5 hover:border-white/10 hover:bg-white/[0.01]\"\n324 |                       }`}\n325 |                     >\n326 |                       <div\n327 |                         className=\"w-2 h-2 rounded-full shrink-0 mt-1\"\n328 |                         style={{ backgroundColor: item.color }}\n329 |                       />\n330 |                       <div>\n331 |                         <span className={`font-semibold block text-[11px] ${isActive ? \"text-white\" : \"text-white/70\"}`}>\n332 |                           {item.title}\n333 |                         </span>\n334 |                         <span className=\"text-[9px] text-white/40 block leading-tight font-light mt-0.5\">\n335 |                           {item.desc}\n336 |                         </span>\n337 |                       </div>\n338 |                     </button>\n339 |                   );\n340 |                 })}\n341 |               </div>\n342 |             </div>\n343 |           </div>\n344 | \n345 |           {/* Footnote Compliance Panel */}\n346 |           <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/40 text-[10px] text-white/30 space-y-2 leading-relaxed\">\n347 |             <span className=\"font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">SECURE SHIELD COMPLIANCE</span>\n348 |             <p>\n349 |               This simulator processes data points purely inside local volatile browser memory. It adheres to the GFF AI zero-retention mandate. No telemetry is logged outside your sandboxed session.\n350 |             </p>\n351 |           </div>\n352 |         </div>\n353 | \n354 |         {/* RIGHT COLUMN: Results Console */}\n355 |         <div className=\"lg:col-span-8 space-y-8 text-white\">\n356 |           {/* Section A: Main Telemetry Summary Cards */}\n357 |           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n358 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n359 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#00FF9D]/30 to-transparent\" />\n360 |               <div>\n361 |                 <div className=\"flex items-center gap-1.5\">\n362 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">ANNUAL EFFICIENCY GAP</span>\n363 |                   <span className=\"text-[8px] font-mono font-bold bg-[#00FF9D]/10 text-[#00FF9D] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n364 |                 </div>\n365 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#00FF9D] block mt-2 font-mono tracking-tight\">\n366 |                   {formatCompactCurrency(expectedGrossSavings)}\n367 |                 </span>\n368 |               </div>\n369 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n370 |                 Illustrative recouped cost based on expected 85% workforce velocity optimization.\n371 |               </p>\n372 |             </div>\n373 | \n374 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n375 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/30 to-transparent\" />\n376 |               <div>\n377 |                 <div className=\"flex items-center gap-1.5\">\n378 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">RECLAIMED ANNUAL CAPACITY</span>\n379 |                   <span className=\"text-[8px] font-mono font-bold bg-[#009DFF]/10 text-[#009DFF] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n380 |                 </div>\n381 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#009DFF] block mt-2 font-mono tracking-tight\">\n382 |                   {expectedHoursSaved.toLocaleString()} Hrs\n383 |                 </span>\n384 |               </div>\n385 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n386 |                 Equivalent full-time hours returned to strategic initiatives rather than administrative friction.\n387 |               </p>\n388 |             </div>\n389 | \n390 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n391 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-amber-500/25 to-transparent\" />\n392 |               <div>\n393 |                 <div className=\"flex items-center gap-1.5\">\n394 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">CAPITAL AMORTIZATION</span>\n395 |                   <span className=\"text-[8px] font-mono font-bold bg-amber-500/10 text-amber-500 px-1 rounded uppercase tracking-widest\">MODELLED</span>\n396 |                 </div>\n397 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-amber-400 block mt-2 font-mono tracking-tight\">\n398 |                   {formatPayback(expectedPaybackMonths)}\n399 |                 </span>\n400 |               </div>\n401 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n402 |                 The computed timeframe before recouped hours balance the initial CapEx allocation.\n403 |               </p>\n404 |             </div>\n405 |           </div>\n406 | \n407 |           {/* Section B: Payback-Style Strategic Narrative */}\n408 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/80 backdrop-blur-sm space-y-4\">\n409 |             <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">EXECUTIVE EVALUATION SUMMARY // {currentPriorityObj.title.toUpperCase()} TARGET</span>\n410 |             <div className=\"space-y-3\">\n411 |               <p className=\"text-sm lg:text-base text-white/80 font-light leading-relaxed\">\n412 |                 By deploying the GFF sovereign agent network across your <span className=\"font-semibold text-white\">{teamSize} FTE</span> workforce footprint, the organization is projected to achieve an illustrative Net Sovereign Return of <span className=\"text-[#00FF9D] font-mono font-bold\">{expectedRoi}%</span>. The model indicates full amortization completes <span className=\"text-white font-semibold\">{formatPayback(expectedPaybackMonths).toLowerCase()}</span>, establishing an air-gapped margin optimization boundary.\n413 |               </p>\n414 |               <p className=\"text-xs text-white/50 font-light leading-relaxed\">\n415 |                 Under the strategic lens of <span className=\"font-semibold text-[#009DFF]\">{currentPriorityObj.title}</span>, GFF's multi-agent hierarchies eliminate repetitive operational loops to reclaim <span className=\"text-white font-semibold font-mono\">{expectedHoursSaved.toLocaleString()} hours</span> of analytical runway per year. Telemetry is securely validated on single-tenant enclaves, reducing audit and speed friction to zero.\n416 |               </p>\n417 |             </div>\n418 |           </div>\n419 | \n420 |           {/* Section C: Pure CSS/SVG Waterfall Chart */}\n421 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 relative\">\n422 |             <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/20 to-transparent\" />\n423 |             <div className=\"flex justify-between items-baseline border-b border-white/5 pb-4 mb-4\">\n424 |               <div>\n425 |                 <span className=\"text-[9px] font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">VALUE CONSTRUCT MATRIX</span>\n426 |                 <h3 className=\"text-sm font-bold text-white mt-1\">Sovereign Financial Value Waterfall Chart</h3>\n427 |               </div>\n428 |               <span className=\"text-[9px] font-mono text-white/30 hidden md:inline\">UNIT: USD ($) // ANNUALIZED MODEL</span>\n429 |             </div>\n430 |             <div className=\"w-full\">\n431 |               <svg viewBox=\"0 0 720 230\" className=\"w-full h-auto overflow-visible select-none\" fill=\"none\">\n432 |                 <line x1=\"30\" y1=\"20\" x2=\"690\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n433 |                 <line x1=\"30\" y1=\"70\" x2=\"690\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n434 |                 <line x1=\"30\" y1=\"120\" x2=\"690\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n435 |                 <line x1=\"30\" y1=\"170\" x2=\"690\" y2=\"170\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n436 |                 <line x1=\"30\" y1=\"200\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n437 |                 {(() => {\n438 |                   const maxAmt = Math.max(totalWastedCostPerYear, expectedGrossSavings, initialInvestment, expectedNetSavings, 1);\n439 |                   const getY = (v: number) => 200 - (v / maxAmt) * 160;\n440 |                   const getH = (v: number) => (v / maxAmt) * 160;\n441 |                   const b1Y = getY(totalWastedCostPerYear), b1H = getH(totalWastedCostPerYear);\n442 |                   const b2H = getH(expectedGrossSavings), b2Y = b1Y;\n443 |                   const b3H = getH(initialInvestment), b3Y = b2Y + b2H - b3H;\n444 |                   const b4Y = getY(expectedNetSavings), b4H = getH(expectedNetSavings);\n445 |                   return (\n446 |                     <>\n447 |                       <line x1=\"120\" y1={b1Y} x2=\"210\" y2={b2Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n448 |                       <line x1=\"290\" y1={b2Y+b2H} x2=\"380\" y2={b3Y+b3H} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n449 |                       <line x1=\"460\" y1={b3Y} x2=\"550\" y2={b4Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n450 |                       <g>\n451 |                         <rect x=\"50\" y={b1Y} width=\"70\" height={b1H} rx=\"3\" fill=\"url(#fG)\" stroke=\"rgba(255,255,255,0.05)\" />\n452 |                         <text x=\"85\" y={Math.max(b1Y-8,15)} textAnchor=\"middle\" className=\"fill-white/80 font-mono text-[10px] font-bold\">{formatCompactCurrency(totalWastedCostPerYear)}</text>\n453 |                       </g>\n454 |                       <g>\n455 |                         <rect x=\"220\" y={b2Y} width=\"70\" height={b2H} rx=\"3\" fill=\"url(#rG)\" stroke=\"rgba(0,255,157,0.15)\" />\n456 |                         <text x=\"255\" y={Math.max(b2Y-8,15)} textAnchor=\"middle\" className=\"fill-[#00FF9D] font-mono text-[10px] font-bold\">-{formatCompactCurrency(expectedGrossSavings)}</text>\n457 |                       </g>\n458 |                       <g>\n459 |                         <rect x=\"390\" y={b3Y} width=\"70\" height={b3H} rx=\"3\" fill=\"url(#cG)\" stroke=\"rgba(228,0,15,0.15)\" />\n460 |                         <text x=\"425\" y={Math.max(b3Y-8,15)} textAnchor=\"middle\" className=\"fill-[#E4000F] font-mono text-[10px] font-bold\">+{formatCompactCurrency(initialInvestment)}</text>\n461 |                       </g>\n462 |                       <g>\n463 |                         <rect x=\"560\" y={b4Y} width=\"70\" height={b4H} rx=\"3\" fill=\"url(#nG)\" stroke=\"rgba(0,255,157,0.3)\" />\n464 |                         <text x=\"595\" y={Math.max(b4Y-8,15)} textAnchor=\"middle\" className=\"fill-white font-mono text-[11px] font-extrabold\">{formatCompactCurrency(expectedNetSavings)}</text>\n465 |                       </g>\n466 |                     </>\n467 |                   );\n468 |                 })()}\n469 |                 <defs>\n470 |                   <linearGradient id=\"fG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#fff\" stopOpacity=\"0.2\"/><stop offset=\"100%\" stopColor=\"#fff\" stopOpacity=\"0.03\"/></linearGradient>\n471 |                   <linearGradient id=\"rG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#00FF9D\" stopOpacity=\"0.05\"/></linearGradient>\n472 |                   <linearGradient id=\"cG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#E4000F\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#E4000F\" stopOpacity=\"0.05\"/></linearGradient>\n473 |                   <linearGradient id=\"nG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\"><stop offset=\"0%\" stopColor=\"#00FF9D\" stopOpacity=\"0.55\"/><stop offset=\"50%\" stopColor=\"#009DFF\" stopOpacity=\"0.3\"/><stop offset=\"100%\" stopColor=\"#000\" stopOpacity=\"0\"/></linearGradient>\n474 |                 </defs>\n475 |               </svg>\n476 |               <div className=\"grid grid-cols-4 gap-2 pt-3 font-mono text-[9px] uppercase tracking-wider text-white/50 text-center border-t border-white/[0.03] mt-2\">\n477 |                 <div>01. Operational Friction</div>\n478 |                 <div>02. GFF Reclaim</div>\n479 |                 <div>03. Setup Expense</div>\n480 |                 <div className=\"text-white font-bold\">04. Sovereign Dividend</div>\n481 |               </div>\n482 |             </div>\n483 |             <p className=\"text-[9px] text-white/30 font-light italic mt-3 text-center\">* All metrics are illustrative based on mathematical models and not performance guarantees.</p>\n484 |           </div>\n485 | \n486 |           {/* Section D: Three Scenario Comparisons (Conservative, Expected, Aggressive) */}\n487 |           <div className=\"space-y-4\">\n488 |             <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">DEVIANCE RUNWAY // SCENARIO SIMULATION</span>\n489 |             <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n490 |               \n491 |               {/* Conservative Scenario Card */}\n492 |               <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 hover:border-white/10 transition flex flex-col justify-between h-full relative group\">\n493 |                 <div className=\"space-y-3\">\n494 |                   <div className=\"flex justify-between items-start\">\n495 |                     <span className=\"text-[9px] font-mono text-white/35 uppercase\">CONSERVATIVE CASE</span>\n496 |                     <span className=\"text-[8px] font-mono text-white/40 px-1.5 py-0.5 rounded bg-white/5 border border-white/5\">50% ADOPTION</span>\n497 |                   </div>\n498 |                   <div>\n499 |                     <span className=\"text-xl font-bold text-white/80 block font-mono\">{formatCompactCurrency(conservativeGrossSavings)}</span>\n500 |                     <span className=\"text-[9px] text-white/40 block mt-0.5\">Annual Illustrative Opportunity</span>\n501 |                   </div>\n502 |                   <div className=\"space-y-1 text-xs pt-2 border-t border-white/[0.03]\">\n503 |                     <div className=\"flex justify-between text-[11px]\">\n504 |                       <span className=\"text-white/40\">Saved Hours:</span>\n505 |                       <span className=