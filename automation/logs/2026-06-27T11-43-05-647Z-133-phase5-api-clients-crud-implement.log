{"ts":"2026-06-27T11:41:13.298Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"2oxdgq0v","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/app/test_clients_api.py","new_text":"import sys\nimport os\nfrom datetime import datetime\n\n# Add backend directory to path\nsys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))\n\nfrom fastapi import HTTPException\nfrom app.db.session import SessionLocal\nfrom app.models.client_account import ClientAccount\nfrom app.models.user import User\nfrom app.schemas.client_account import ClientAccountCreate, ClientAccountUpdate\nfrom app.api.routes.clients import (\n    list_clients,\n    get_client,\n    create_client,\n    update_client,\n    delete_client\n)\n\nclass MockUser:\n    def __init__(self, email=\"admin@gff.ai\", role=\"admin\"):\n        self.email = email\n        self.role = role\n        self.id = 1\n\ndef run_api_tests():\n    print(\"Initializing test session...\")\n    db = SessionLocal()\n    admin_user = MockUser()\n    \n    # Clean up any existing test clients to ensure test is repeatable and clean\n    db.query(ClientAccount).filter(ClientAccount.name.like(\"TEST_CLIENT_%\")).delete()\n    db.commit()\n    \n    print(\"\\n--- Starting ClientAccount API CRUD Tests ---\")\n    \n    # 1. Test Create Client\n    print(\"Testing create_client...\")\n    client_in = ClientAccountCreate(\n        name=\"TEST_CLIENT_ALPHA\",\n        industry=\"Sovereign AI Operations\",\n        region=\"Europe\",\n        status=\"active\",\n        account_owner=\"GFF Alpha Team\"\n    )\n    \n    created = create_client(client_in=client_in, db=db, current_user=admin_user)\n    assert created.id is not None\n    assert created.name == \"TEST_CLIENT_ALPHA\"\n    assert created.industry == \"Sovereign AI Operations\"\n    assert created.region == \"Europe\"\n    assert created.status == \"active\"\n    print(\"✓ create_client passed.\")\n    \n    # 2. Test Create Duplicate Name Client (should raise 400)\n    print(\"Testing create_client duplication check...\")\n    try:\n        create_client(client_in=client_in, db=db, current_user=admin_user)\n        assert False, \"Should have raised 400 BAD REQUEST\"\n    except HTTPException as e:\n        assert e.status_code == 400\n        assert \"already exists\" in e.detail\n    print(\"✓ duplication check passed.\")\n    \n    # 3. Test Get Client\n    print(\"Testing get_client by ID...\")\n    retrieved = get_client(client_id=created.id, db=db, current_user=admin_user)\n    assert retrieved.id == created.id\n    assert retrieved.name == \"TEST_CLIENT_ALPHA\"\n    \n    # Test non-existent ID (should raise 404)\n    try:\n        get_client(client_id=999999, db=db, current_user=admin_user)\n        assert False, \"Should have raised 404 NOT FOUND\"\n    except HTTPException as e:\n        assert e.status_code == 404\n        assert \"not found\" in e.detail\n    print(\"✓ get_client passed.\")\n    \n    # 4. Test List Clients and Filtering\n    print(\"Testing list_clients and advanced query filtering...\")\n    # Create a second test client\n    client_in_2 = ClientAccountCreate(\n        name=\"TEST_CLIENT_BETA\",\n        industry=\"BioTech Intelligence\",\n        region=\"Asia-Pacific\",\n        status=\"pending\",\n        account_owner=\"GFF Beta Team\"\n    )\n    created_2 = create_client(client_in=client_in_2, db=db, current_user=admin_user)\n    \n    # List all\n    all_clients = list_clients(db=db, current_user=admin_user)\n    assert len(all_clients) >= 2\n    \n    # Filter by search\n    filtered_search = list_clients(search=\"BETA\", db=db, current_user=admin_user)\n    assert len(filtered_search) == 1\n    assert filtered_search[0].name == \"TEST_CLIENT_BETA\"\n    \n    # Filter by status\n    filtered_status = list_clients(status=\"pending\", db=db, current_user=admin_user)\n    assert any(c.name == \"TEST_CLIENT_BETA\" for c in filtered_status)\n    assert all(c.status == \"pending\" for c in filtered_status)\n    \n    # Filter by region\n    filtered_region = list_clients(region=\"Europe\", db=db, current_user=admin_user)\n    assert any(c.name == \"TEST_CLIENT_ALPHA\" for c in filtered_region)\n    assert all(c.region == \"Europe\" for c in filtered_region)\n    print(\"✓ list_clients and filtering passed.\")\n    \n    # 5. Test Patch Update Client\n    print(\"Testing update_client...\")\n    update_in = ClientAccountUpdate(\n        region=\"North America\",\n        status=\"active\",\n        account_owner=\"GFF Elite Team\"\n    )\n    updated = update_client(client_id=created_2.id, client_in=update_in, db=db, current_user=admin_user)\n    assert updated.region == \"North America\"\n    assert updated.status == \"active\"\n    assert updated.account_owner == \"GFF Elite Team\"\n    # Ensure name remains untouched\n    assert updated.name == \"TEST_CLIENT_BETA\"\n    print(\"✓ update_client passed.\")\n    \n    # 6. Test Delete Client (Soft Archive)\n    print(\"Testing delete_client (soft archive)...\")\n    soft_deleted = delete_client(client_id=created.id, hard_delete=False, db=db, current_user=admin_user)\n    assert soft_deleted.id == created.id\n    assert soft_deleted.status == \"archived\"\n    \n    # Verify in DB that it is still there but status is 'archived'\n    db_record = db.query(ClientAccount).filter(ClientAccount.id == created.id).first()\n    assert db_record is not None\n    assert db_record.status == \"archived\"\n    print(\"✓ soft archive passed.\")\n    \n    # 7. Test Delete Client (Hard Delete)\n    print(\"Testing delete_client (hard delete)...\")\n    hard_deleted = delete_client(client_id=created.id, hard_delete=True, db=db, current_user=admin_user)\n    assert hard_deleted.id == created.id\n    assert hard_deleted.status == \"deleted\"\n    \n    # Verify in DB that it is physically removed\n    db_record_removed = db.query(ClientAccount).filter(ClientAccount.id == created.id).first()\n    assert db_record_removed is None\n    print(\"✓ hard delete passed.\")\n    \n    # Clean up client_2 as well\n    delete_client(client_id=created_2.id, hard_delete=True, db=db, current_user=admin_user)\n    db.close()\n    print(\"\\nAll ClientAccount CRUD API tests completed successfully with 100% assertions satisfied!\")\n\nif __name__ == \"__main__\":\n    try:\n        run_api_tests()\n        sys.exit(0)\n    except AssertionError as e:\n        print(\"\\nTest failed with assertion error:\")\n        import traceback\n        traceback.print_exc()\n        sys.exit(1)\n    except Exception as e:\n        print(f\"\\nTest failed with exception: {e}\")\n        import traceback\n        traceback.print_exc()\n        sys.exit(1)\n"}}}
