3 15.485V5.515a2 2 0 011.553-1.954l8.944-4.472a2 2 0 011.11 0l8.944 4.472A2 2 0 0121 5.515v9.97a2 2 0 01-1.553 1.954L15 20M9 20l3 1.5 3-1.5M9 20v-5m6 5v-5M12 2.25V15\" />\n571 |         </svg>\n572 |       </div>\n573 | \n574 |       <div className=\"space-y-2 max-w-sm\">\n575 |         <h4 className=\"text-sm font-bold text-white uppercase tracking-wider font-mono\">{title}</h4>\n576 |         <p className=\"text-white/40 text-xs font-light leading-relaxed\">{description}</p>\n577 |       </div>\n578 | \n579 |       {actionText && onAction && (\n580 |         <button\n581 |           onClick={onAction}\n582 |           className=\"px-5 py-2.5 rounded-lg text-xs font-semibold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 hover:bg-[#009DFF]/10 transition\"\n583 |         >\n584 |           {actionText}\n585 |         </button>\n586 |       )}\n587 |     </div>\n588 |   );\n589 | }\n590 | \n591 | // ==========================================\n592 | // 13. ToolTabs\n593 | // ==========================================\n594 | interface TabItem {\n595 |   id: string;\n596 |   label: string;\n597 | }\n598 | \n599 | interface ToolTabsProps {\n600 |   tabs: TabItem[];\n601 |   activeTabId: string;\n602 |   onChange: (id: string) => void;\n603 |   accentColor?: string;\n604 | }\n605 | \n606 | export function ToolTabs({ tabs, activeTabId, onChange, accentColor = \"#009DFF\" }: ToolTabsProps) {\n607 |   return (\n608 |     <div className=\"flex gap-1.5 p-1 rounded-xl bg-[#04060b] border border-white/5 self-start overflow-x-auto scrollbar-none w-full max-w-md\">\n609 |       {tabs.map((tab) => {\n610 |         const isActive = tab.id === activeTabId;\n611 | \n612 |         return (\n613 |           <button\n614 |             key={tab.id}\n615 |             onClick={() => onChange(tab.id)}\n616 |             type=\"button\"\n617 |             className=\"relative px-4 py-2 text-xs font-semibold rounded-lg uppercase tracking-wider transition-colors duration-200 cursor-pointer flex-1 text-center text-white/50 hover:text-white\"\n618 |           >\n619 |             {/* Sliding backdrop indicator */}\n620 |             {isActive && (\n621 |               <motion.div\n622 |                 layoutId=\"active-tool-tab\"\n623 |                 className=\"absolute inset-0 bg-white/[0.03] border border-white/5 rounded-lg shadow-sm\"\n624 |                 transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n625 |                 style={{\n626 |                   borderTopColor: `${accentColor}30`,\n627 |                   borderBottomColor: `${accentColor}30`\n628 |                 }}\n629 |               />\n630 |             )}\n631 |             \n632 |             <span className={`relative z-10 transition-colors ${isActive ? \"text-white font-bold\" : \"\"}`}>\n633 |               {tab.label}\n634 |             </span>\n635 |           </button>\n636 |         );\n637 |       })}\n638 |     </div>\n639 |   );\n640 | }\n641 | \n642 | \n643 | \n644 | // ==========================================\n645 | // 14. ToolComparisonRail\n646 | // ==========================================\n647 | interface ComparisonRow {\n648 |   feature: string;\n649 |   gffSpec: string;\n650 |   standardSpec: string;\n651 |   isGffBetter?: boolean;\n652 | }\n653 | \n654 | interface ToolComparisonRailProps {\n655 |   rows: ComparisonRow[];\n656 | }\n657 | \n658 | export function ToolComparisonRail({ rows }: ToolComparisonRailProps) {\n659 |   return (\n660 |     <div className=\"rounded-xl border border-white/5 overflow-hidden bg-white/[0.005]\">\n661 |       <div className=\"overflow-x-auto\">\n662 |         <table className=\"w-full border-collapse text-left text-xs min-w-[500px]\">\n663 |           <thead>\n664 |             <tr className=\"border-b border-white/5 bg-white/[0.01] text-[10px] font-mono uppercase tracking-wider text-white/40\">\n665 |               <th className=\"p-4 pl-6 font-medium\">Core Metric / Capability</th>\n666 |               <th className=\"p-4 font-medium text-white\">GFF Sovereign Nodes</th>\n667 |               <th className=\"p-4 font-medium\">Standard Cloud / SaaS</th>\n668 |             </tr>\n669 |           </thead>\n670 |           <tbody className=\"divide-y divide-white/5 font-light\">\n671 |             {rows.map((row, idx) => (\n672 |               <tr key={idx} className=\"hover:bg-white/[0.01] transition-colors group\">\n673 |                 <td className=\"p-4 pl-6 text-white/70 group-hover:text-white transition-colors\">{row.feature}</td>\n674 |                 <td className=\"p-4 font-mono font-bold text-[#00FF9D] flex items-center gap-2\">\n675 |                   <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n676 |                     <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={3} d=\"M5 13l4 4L19 7\" />\n677 |                   </svg>\n678 |                   <span>{row.gffSpec}</span>\n679 |                 </td>\n680 |                 <td className=\"p-4 text-white/40 font-mono\">{row.standardSpec}</td>\n681 |               </tr>\n682 |             ))}\n683 |           </tbody>\n684 |         </table>\n685 |       </div>\n686 |     </div>\n687 |   );\n688 | }\n689 | \n690 | // ==========================================\n691 | // 15. ToolDataCard\n692 | // ==========================================\n693 | interface ToolDataCardProps {\n694 |   label: string;\n695 |   value: string;\n696 |   status?: \"optimal\" | \"warning\" | \"error\" | \"neutral\";\n697 |   detail?: string;\n698 | }\n699 | \n700 | export function ToolDataCard({ label, value, status = \"neutral\", detail }: ToolDataCardProps) {\n701 |   const statusColors = {\n702 |     optimal: \"text-[#00FF9D]\",\n703 |     warning: \"text-amber-400\",\n704 |     error: \"text-[#E4000F]\",\n705 |     neutral: \"text-white/70\"\n706 |   };\n707 | \n708 |   return (\n709 |     <div className=\"p-4 rounded-xl border border-white/5 bg-[#030304]/60 flex flex-col justify-between hover:border-white/10 transition-colors\">\n710 |       <div className=\"space-y-1\">\n711 |         <span className=\"text-[9px] font-mono text-white/35 uppercase tracking-wider\">{label}</span>\n712 |         <div className=\"flex items-baseline justify-between gap-4\">\n713 |           <span className={`text-lg font-bold font-mono tracking-tight ${statusColors[status]}`}>{value}</span>\n714 |           \n715 |           {/* Miniature sparkline simulation */}\n716 |           <div className=\"w-12 h-6 overflow-hidden pointer-events-none opacity-40\">\n717 |             <svg className=\"w-full h-full\" viewBox=\"0 0 50 20\">\n718 |               <path\n719 |                 d=\"M 0 15 Q 12 5 25 12 T 50 8\"\n720 |                 fill=\"none\"\n721 |                 stroke={status === \"optimal\" ? \"#00FF9D\" : status === \"error\" ? \"#E4000F\" : \"#009DFF\"}\n722 |                 strokeWidth={1.5}\n723 |               />\n724 |             </svg>\n725 |           </div>\n726 |         </div>\n727 |       </div>\n728 |       {detail && <p className=\"text-[10px] text-white/30 font-light mt-2 leading-none font-mono\">{detail}</p>}\n729 |     </div>\n730 |   );\n731 | }\n732 | ","success":true}],"durationMs":3}}
