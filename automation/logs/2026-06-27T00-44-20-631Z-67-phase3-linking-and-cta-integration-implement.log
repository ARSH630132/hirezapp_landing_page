dePos {\n 244 |   x: number; // percentage 0-100\n 245 |   y: number; // percentage 0-100\n 246 | }\n 247 | \n 248 | function getNodePositions(pattern: string, stagesList: any[]): NodePos[] {\n 249 |   const N = stagesList.length;\n 250 |   if (N === 0) return [];\n 251 | \n 252 |   if (N === 1) {\n 253 |     return [{ x: 50, y: 50 }];\n 254 |   }\n 255 | \n 256 |   const positions: NodePos[] = [];\n 257 | \n 258 |   if (pattern === \"sequential\") {\n 259 |     // Linear pipeline\n 260 |     // Distribute evenly along the X axis from 14% to 86%\n 261 |     for (let i = 0; i < N; i++) {\n 262 |       const x = 14 + (i / (N - 1)) * 72;\n 263 |       // Alternate wave pattern if there are many nodes (to prevent vertical or horizontal crowding)\n 264 |       const y = N > 5 ? (i % 2 === 0 ? 38 : 62) : 50;\n 265 |       positions.push({ x, y });\n 266 |     }\n 267 |   } else if (pattern === \"hierarchical\") {\n 268 |     // Supervisor node (first reasoning node, or node 0)\n 269 |     // Put Supervisor at top center (50%, 22%)\n 270 |     // Put all other nodes (workers) in a horizontal row at (50% + offset, 72%)\n 271 |     let supervisorIdx = stagesList.findIndex(s => s.type === \"reasoning\");\n 272 |     if (supervisorIdx === -1) supervisorIdx = 0;\n 273 | \n 274 |     const workerCount = N - 1;\n 275 | \n 276 |     let workerJ = 0;\n 277 |     for (let i = 0; i < N; i++) {\n 278 |       if (i === supervisorIdx) {\n 279 |         positions.push({ x: 50, y: 22 });\n 280 |       } else {\n 281 |         const x = workerCount > 1 \n 282 |           ? 14 + (workerJ / (workerCount - 1)) * 72\n 283 |           : 50;\n 284 |         positions.push({ x, y: 72 });\n 285 |         workerJ++;\n 286 |       }\n 287 |     }\n 288 |   } else if (pattern === \"swarm\") {\n 289 |     // Arranged in an ellipse\n 290 |     const cx = 50;\n 291 |     const cy = 48;\n 292 |     const rx = 33;\n 293 |     const ry = 25;\n 294 | \n 295 |     for (let i = 0; i < N; i++) {\n 296 |       const angle = (i / N) * 2 * Math.PI - Math.PI / 2; // start top-center\n 297 |       const x = cx + rx * Math.cos(angle);\n 298 |       const y = cy + ry * Math.sin(angle);\n 299 |       positions.push({ x, y });\n 300 |     }\n 301 |   } else {\n 302 |     // Cognitive DAG: Parallel layers\n 303 |     const layers: { [key: number]: number[] } = { 0: [0], 1: [], 2: [], 3: [N - 1] };\n 304 |     \n 305 |     for (let i = 1; i < N - 1; i++) {\n 306 |       if (i % 2 === 1) {\n 307 |         layers[1].push(i);\n 308 |       } else {\n 309 |         layers[2].push(i);\n 310 |       }\n 311 |     }\n 312 | \n 313 |     const layerX = { 0: 14, 1: 38, 2: 62, 3: 86 };\n 314 |     const coordsMap = new Array<NodePos>(N);\n 315 | \n 316 |     // Position node index 0\n 317 |     coordsMap[0] = { x: layerX[0], y: 50 };\n 318 |     // Position last node\n 319 |     coordsMap[N - 1] = { x: layerX[3], y: 50 };\n 320 | \n 321 |     // Position mid layers\n 322 |     [1, 2].forEach((lNum) => {\n 323 |       const indices = layers[lNum];\n 324 |       const count = indices.length;\n 325 |       indices.forEach((nodeIdx, k) => {\n 326 |         const x = layerX[lNum as 1 | 2];\n 327 |         const y = count > 1\n 328 |           ? 50 + (k - (count - 1) / 2) * 28\n 329 |           : 50;\n 330 |         coordsMap[nodeIdx] = { x, y };\n 331 |       });\n 332 |     });\n 333 | \n 334 |     for (let i = 0; i < N; i++) {\n 335 |       positions.push(coordsMap[i]);\n 336 |     }\n 337 |   }\n 338 | \n 339 |   return positions;\n 340 | }\n 341 | \n 342 | export default function FoundryStudioPage() {\n 343 |   const [selectedPresetId, setSelectedPresetId] = useState<string>(\"banking\");\n 344 |   const [selectedPattern, setSelectedPattern] = useState<string>(\"hierarchical\");\n 345 |   const [stages, setStages] = useState<WorkflowStage[]>([]);\n 346 |   const [knowledgeSources, setKnowledgeSources] = useState<string[]>([]);\n 347 | \n 348 |   const [isHydrated, setIsHydrated] = useState(false);\n 349 | \n 350 |   // Load from GFF Workspace on mount\n 351 |   useEffect(() => {\n 352 |     const saved = getToolState(\"foundryStudio\");\n 353 |     if (saved) {\n 354 |       if (saved.selectedPresetId) setSelectedPresetId(saved.selectedPresetId);\n 355 |       if (saved.selectedPattern) setSelectedPattern(saved.selectedPattern);\n 356 |       if (Array.isArray(saved.stages)) setStages(saved.stages);\n 357 |       if (Array.isArray(saved.knowledgeSources)) setKnowledgeSources(saved.knowledgeSources);\n 358 |     }\n 359 |     setIsHydrated(true);\n 360 |   }, []);\n 361 | \n 362 |   // Save to GFF Workspace on changes\n 363 |   useEffect(() => {\n 364 |     if (isHydrated) {\n 365 |       saveToolState(\"foundryStudio\", {\n 366 |         selectedPresetId,\n 367 |         selectedPattern,\n 368 |         stages,\n 369 |         knowledgeSources\n 370 |       });\n 371 |     }\n 372 |   }, [isHydrated, selectedPresetId, selectedPattern, stages, knowledgeSources]);\n 373 |   const [newSourceInput, setNewSourceInput] = useState<string>(\"\");\n 374 |   const [selectedNodeId, setSelectedNodeId] = useState<string | null>(null);\n 375 |   const [nodeCounter, setNodeCounter] = useState<number>(10);\n 376 |   \n 377 |   // Custom Node Editor states (for editing the selected node)\n 378 |   const [nodeLabel, setNodeLabel] = useState(\"\");\n 379 |   const [nodeRole, setNodeRole] = useState(\"\");\n 380 |   const [nodeLatency, setNodeLatency] = useState(\"\");\n 381 | \n 382 |   // Simulation & Logs states\n 383 |   const [isSimulating, setIsSimulating] = useState(false);\n 384 |   const [simulationProgress, setSimulationProgress] = useState<number>(-1);\n 385 |   const [logs, setLogs] = useState<ConsoleLog[]>([]);\n 386 |   const [consoleTab, setConsoleTab] = useState<\"terminal\" | \"json\" | \"yaml\">(\"terminal\");\n 387 |   const [toastError, setToastError] = useState<string | null>(null);\n 388 | \n 389 |   const [copied, setCopied] = useState(false);\n 390 |   const [downloaded, setDownloaded] = useState(false);\n 391 | \n 392 |   const logsEndRef = useRef<HTMLDivElement>(null);\n 393 | \n 394 |   // Initialize preset on mount or change\n 395 |   useEffect(() => {\n 396 |     const preset = INDUSTRY_PRESETS.find((p) => p.id === selectedPresetId);\n 397 |     if (preset) {\n 398 |       const formattedStages = preset.stages.map((st, idx) => ({\n 399 |         id: `node-${idx}-${st.type}`,\n 400 |         type: st.type as ModuleType,\n 401 |         label: st.label,\n 402 |         role: st.role,\n 403 |         latency: st.latency,\n 404 |         isGated: idx === preset.approvalIndex,\n 405 |       }));\n 406 |       setStages(formattedStages);\n 407 |       setKnowledgeSources(preset.sources);\n 408 |       setSelectedPattern(preset.pattern);\n 409 |       setSelectedNodeId(formattedStages[0]?.id || null);\n 410 | \n 411 |       // Reset any active simulation\n 412 |       setIsSimulating(false);\n 413 |       setSimulationProgress(-1);\n 414 |       \n 415 |       // Load initial console log list\n 416 |       const timestamp = new Date().toLocaleTimeString();\n 417 |       setLogs([\n 418 |         { time: timestamp, type: \"system\", text: `Loaded sovereign preset configuration: \"${preset.title}\".` },\n 419 |         { time: timestamp, type: \"info\", text: `Enclave isolation set to AMD-SEV-SNP hardware boundary. Security parameters initialized.` }\n 420 |       ]);\n 421 |     }\n 422 |   }, [selectedPresetId]);\n 423 | \n 424 |   // Sync selected node's values into editor states\n 425 |   useEffect(() => {\n 426 |     if (selectedNodeId) {\n 427 |       const node = stages.find((s) => s.id === selectedNodeId);\n 428 |       if (node) {\n 429 |         setNodeLabel(node.label);\n 430 |         setNodeRole(node.role);\n 431 |         setNodeLatency(node.latency);\n 432 |       }\n 433 |     } else {\n 434 |       setNodeLabel(\"\");\n 435 |       setNodeRole(\"\");\n 436 |       setNodeLatency(\"\");\n 437 |     }\n 438 |   }, [selectedNodeId, stages]);\n 439 | \n 440 |   // Auto-scroll logs terminal\n 441 |   useEffect(() => {\n 442 |     if (logsEndRef.current) {\n 443 |       logsEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n 444 |     }\n 445 |   }, [logs]);\n 446 | \n 447 |   // Real-time live-typing synchronization handlers\n 448 |   const handleLabelChange = (newVal: string) => {\n 449 |     setNodeLabel(newVal);\n 450 |     if (selectedNodeId) {\n 451 |       setStages((prev) =>\n 452 |         prev.map((s) => (s.id === selectedNodeId ? { ...s, label: newVal } : s))\n 453 |       );\n 454 |     }\n 455 |   };\n 456 | \n 457 |   const handleRoleChange = (newVal: string) => {\n 458 |     setNodeRole(newVal);\n 459 |     if (selectedNodeId) {\n 460 |       setStages((prev) =>\n 461 |         prev.map((s) => (s.id === selectedNodeId ? { ...s, role: newVal } : s))\n 462 |       );\n 463 |     }\n 464 |   };\n 465 | \n 466 |   const handleLatencyChange = (newVal: string) => {\n 467 |     setNodeLatency(newVal);\n 468 |     if (selectedNodeId) {\n 469 |       setStages((prev) =>\n 470 |         prev.map((s) => (s.id === selectedNodeId ? { ...s, latency: newVal } : s))\n 471 |       );\n 472 |     }\n 473 |   };\n 474 | \n 475 |   // Helper functions for desktop spatial layout\n 476 |   const isSupervisorNode = (idx: number) => {\n 477 |     if (selectedPattern !== \"hierarchical\") return false;\n 478 |     let supervisorIdx = stages.findIndex((s) => s.type === \"reasoning\");\n 479 |     if (supervisorIdx === -1) supervisorIdx = 0;\n 480 |     return idx === supervisorIdx;\n 481 |   };\n 482 | \n 483 |   const getDesktopNodePos = (idx: number): { x: number; y: number } => {\n 484 |     const positions = getNodePositions(selectedPattern, stages);\n 485 |     return positions[idx] || { x: 50, y: 50 };\n 486 |   };\n 487 |   const renderDesktopConnections = () => {\n 488 |     const N = stages.length;\n 489 |     if (N <= 1) return null;\n 490 |     const positions = getNodePositions(selectedPattern, stages);\n 491 |     if (positions.length !== N) return null;\n 492 |     const paths: React.JSX.Element[] = [];\n 493 | \n 494 |     if (selectedPattern === \"sequential\") {\n 495 |       for (let i = 0; i < N - 1; i++) {\n 496 |         const pos1 = positions[i];\n 497 |         const pos2 = positions[i + 1];\n 498 |         const isCompleted = isSimulating && simulationProgress > i;\n 499 |         const isActive = isSimulating && simulationProgress === i;\n 500 |         const cx1 = pos1.x + (pos2.x - pos1.x) * 0.5;\n 501 |         const cy1 = pos1.y;\n 502 |         const cx2 = pos1.x + (pos2.x - pos1.x) * 0.5;\n 503 |         const cy2 = pos2.y;\n 504 |         const d = `M ${pos1.x} ${pos1.y} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${pos2.x} ${pos2.y}`;\n 505 |         paths.push(\n 506 |           <path\n 507 |             key={`seq-${i}`}\n 508 |             d={d}\n 509 |             fill=\"none\"\n 510 |             stroke={isCompleted ? \"#00FF9D\" : isActive ? \"#009DFF\" : \"rgba(255, 255, 255, 0.08)\"}\n 511 |             strokeWidth={isActive ? \"2.5\" : \"1.5\"}\n 512 |             strokeLinecap=\"round\"\n 513 |             className={isActive ? \"animate-flowDash\" : \"\"}\n 514 |             style={{\n 515 |               filter: isActive ? \"drop-shadow(0 0 3px rgba(0, 157, 255, 0.4))\" : \"\",\n 516 |               transition: \"stroke 0.3s, stroke-width 0.3s\",\n 517 |             }}\n 518 |           />\n 519 |         );\n 520 |       }\n 521 |     } else if (selectedPattern === \"hierarchical\") {\n 522 |       let supervisorIdx = stages.findIndex((s) => s.type === \"reasoning\");\n 523 |       if (supervisorIdx === -1) supervisorIdx = 0;\n 524 |       const posSup = positions[supervisorIdx];\n 525 |       for (let i = 0; i < N; i++) {\n 526 |         if (i === supervisorIdx) continue;\n 527 |         const posWorker = positions[i];\n 528 |         const isCompleted = isSimulating && simulationProgress > i;\n 529 |         const isActive = isSimulating && simulationProgress === i;\n 530 |         const cx1 = posSup.x;\n 531 |         const cy1 = posSup.y + (posWorker.y - posSup.y) * 0.5;\n 532 |         const cx2 = posWorker.x;\n 533 |         const cy2 = posSup.y + (posWorker.y - posSup.y) * 0.5;\n 534 |         const d = `M ${posSup.x} ${posSup.y} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${posWorker.x} ${posWorker.y}`;\n 535 |         paths.push(\n 536 |           <path\n 537 |             key={`hier-${i}`}\n 538 |             d={d}\n 539 |             fill=\"none\"\n 540 |             stroke={isCompleted ? \"#00FF9D\" : isActive ? \"#009DFF\" : \"rgba(255, 255, 255, 0.08)\"}\n 541 |             strokeWidth={isActive ? \"2.5\" : \"1.5\"}\n 542 |             strokeLinecap=\"round\"\n 543 |             className={isActive ? \"animate-flowDash\" : \"\"}\n 544 |             style={{\n 545 |               filter: isActive ? \"drop-shadow(0 0 3px rgba(0, 157, 255, 0.4))\" : \"\",\n 546 |               transition: \"stroke 0.3s, stroke-width 0.3s\",\n 547 |             }}\n 548 |           />\n 549 |         );\n 550 |       }\n 551 |     } else if (selectedPattern === \"swarm\") {\n 552 |       for (let i = 0; i < N; i++) {\n 553 |         for (let j = i + 2; j < N; j++) {\n 554 |           if (i === 0 && j === N - 1) continue;\n 555 |           const pos1 = positions[i];\n 556 |           const pos2 = positions[j];\n 557 |           paths.push(\n 558 |             <line\n 559 |               key={`mesh-${i}-${j}`}\n 560 |               x1={pos1.x}\n 561 |               y1={pos1.y}\n 562 |               x2={pos2.x}\n 563 |               y2={pos2.y}\n 564 |               stroke=\"rgba(255, 255, 255, 0.02)\"\n 565 |               strokeWidth=\"0.75\"\n 566 |               strokeDasharray=\"2 2\"\n 567 |             />\n 568 |           );\n 569 |         }\n 570 |       }\n 571 |       for (let i = 0; i < N; i++) {\n 572 |         const pos1 = positions[i];\n 573 |         const pos2 = positions[(i + 1) % N];\n 574 |         const isCompleted = isSimulating && simulationProgress > i;\n 575 |         const isActive = isSimulating && simulationProgress === i;\n 576 |         paths.push(\n 577 |           <path\n 578 |             key={`swarm-${i}`}\n 579 |             d={`M ${pos1.x} ${pos1.y} L ${pos2.x} ${pos2.y}`}\n 580 |             fill=\"none\"\n 581 |             stroke={isCompleted ? \"#00FF9D\" : isActive ? \"#009DFF\" : \"rgba(255, 255, 255, 0.08)\"}\n 582 |             strokeWidth={isActive ? \"2.5\" : \"1.5\"}\n 583 |             strokeLinecap=\"round\"\n 584 |             className={isActive ? \"animate-flowDash\" : \"\"}\n 585 |             style={{\n 586 |               filter: isActive ? \"drop-shadow(0 0 3px rgba(0, 157, 255, 0.4))\" : \"\",\n 587 |               transition: \"stroke 0.3s, stroke-width 0.3s\",\n 588 |             }}\n 589 |           />\n 590 |         );\n 591 |       }\n 592 |     } else {\n 593 |       const layers: { [key: number]: number[] } = { 0: [0], 1: [], 2: [], 3: [N - 1] };\n 594 |       for (let i = 1; i < N - 1; i++) {\n 595 |         if (i % 2 === 1) layers[1].push(i);\n 596 |         else layers[2].push(i);\n 597 |       }\n 598 |       const drawCurve = (u: number, v: number, key: string) => {\n 599 |         const pos1 = positions[u];\n 600 |         const pos2 = positions[v];\n 601 |         const isCompleted = isSimulating && simulationProgress > v;\n 602 |         const isActive = isSimulating && simulationProgress === v;\n 603 |         const cx1 = pos1.x + (pos2.x - pos1.x) * 0.5;\n 604 |         const cy1 = pos1.y;\n 605 |         const cx2 = pos1.x + (pos2.x - pos1.x) * 0.5;\n 606 |         const cy2 = pos2.y;\n 607 |         const d = `M ${pos1.x} ${pos1.y} C ${cx1} ${cy1}, ${cx2} ${cy2}, ${pos2.x} ${pos2.y}`;\n 608 |         return (\n 609 |           <path\n 610 |             key={key}\n 611 |             d={d}\n 612 |             fill=\"none\"\n 613 |             stroke={isCompleted ? \"#00FF9D\" : isActive ? \"#009DFF\" : \"rgba(255, 255, 255, 0.08)\"}\n 614 |             strokeWidth={isActive ? \"2.5\" : \"1.5\"}\n 615 |             strokeLinecap=\"round\"\n 616 |             className={isActive ? \"animate-flowDash\" : \"\"}\n 617 |             style={{\n 618 |               filter: isActive ? \"drop-shadow(0 0 3px rgba(0, 157, 255, 0.4))\" : \"\",\n 619 |               transition: \"stroke 0.3s, stroke-width 0.3s\",\n 620 |             }}\n 621 |           />\n 622 |         );\n 623 |       };\n 624 |       layers[0].forEach((u) => {\n 625 |         layers[1].forEach((v) => {\n 626 |           paths.push(drawCurve(u, v, `dag-0-1-${u}-${v}`));\n 627 |         });\n 628 |       });\n 629 |       layers[1].forEach((u) => {\n 630 |         layers[2].forEach((v) => {\n 631 |           paths.push(drawCurve(u, v, `dag-1-2-${u}-${v}`));\n 632 |         });\n 633 |       });\n 634 |       layers[2].forEach((u) => {\n 635 |         layers[3].forEach((v) => {\n 636 |           paths.push(drawCurve(u, v, `dag-2-3-${u}-${v}`));\n 637 |         });\n 638 |       });\n 639 |     }\n 640 |     return <>{paths}</>;\n 641 |   };\n 642 | \n 643 | \n 644 | \n 645 |   // Multi-step Simulation Execution logic\n 646 |   useEffect(() => {\n 647 |     if (!isSimulating) return;\n 648 | \n 649 |     if (simulationProgress === -1) {\n 650 |       // Begin simulation\n 651 |       const timestamp = new Date().toLocaleTimeString();\n 652 |       setLogs((prev) => [\n 653 |         ...prev,\n 654 |         { time: timestamp, type: \"system\", text: `==========================================================` },\n 655 |         { time: timestamp, type: \"system\", text: `INITIATING SOVEREIGN WORKFLOW GRAPH SIMULATION [PATTERN: ${selectedPattern.toUpperCase()}]` },\n 656 |         { time: timestamp, type: \"info\", text: `Bootstrapping secure memory registers... Sandbox initialized.` }\n 657 |       ]);\n 658 |       setSimulationProgress(0);\n 659 |       return;\n 660 | 