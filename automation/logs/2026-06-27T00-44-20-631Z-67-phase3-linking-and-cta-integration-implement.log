4 |                   <option value=\"public_sector\">Public Sector & Government</option>\n555 |                   <option value=\"retail_logistics\">Retail & Logistics</option>\n556 |                   <option value=\"technology_media\">Technology & Media</option>\n557 |                 </select>\n558 |               </div>\n559 | \n560 |               {/* Enterprise Scale (Company Size) */}\n561 |               <div className=\"space-y-1.5\">\n562 |                 <div className=\"flex justify-between items-center\">\n563 |                   <span className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider\">\n564 |                     Enterprise Scale\n565 |                   </span>\n566 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Determines Setup CapEx</span>\n567 |                 </div>\n568 |                 <div className=\"grid grid-cols-5 gap-1\" role=\"group\" aria-label=\"Enterprise Scale\">\n569 |                   {[\n570 |                     { id: \"smb\", label: \"<100\", title: \"SMB (<100 FTE)\" },\n571 |                     { id: \"mid\", label: \"100-500\", title: \"Mid-Market (100-500 FTE)\" },\n572 |                     { id: \"enterprise\", label: \"500-2K\", title: \"Enterprise (500-2,000 FTE)\" },\n573 |                     { id: \"large_enterprise\", label: \"2K-10K\", title: \"Large Enterprise (2,000-10,000 FTE)\" },\n574 |                     { id: \"global_corp\", label: \"10K+\", title: \"Global Corporation (10,000+ FTE)\" }\n575 |                   ].map((item) => (\n576 |                     <button\n577 |                       key={item.id}\n578 |                       type=\"button\"\n579 |                       onClick={() => setCompanySize(item.id)}\n580 |                       className={`h-8 rounded text-[9px] font-semibold transition-all border ${\n581 |                         companySize === item.id\n582 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n583 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n584 |                       }`}\n585 |                       title={item.title}\n586 |                     >\n587 |                       {item.label}\n588 |                     </button>\n589 |                   ))}\n590 |                 </div>\n591 |               </div>\n592 | \n593 |               {/* Operational Function */}\n594 |               <div className=\"space-y-1.5\">\n595 |                 <div className=\"flex justify-between items-center\">\n596 |                   <label htmlFor=\"function-select\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n597 |                     Operational Function\n598 |                   </label>\n599 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Labor Complexity Factor</span>\n600 |                 </div>\n601 |                 <select\n602 |                   id=\"function-select\"\n603 |                   value={opFunction}\n604 |                   onChange={(e) => setOpFunction(e.target.value)}\n605 |                   className=\"w-full h-9 bg-white/5 border border-white/10 rounded-lg px-2.5 text-xs text-white focus:outline-none focus:border-[#009DFF]/50 transition-colors cursor-pointer\"\n606 |                 >\n607 |                   <option value=\"customer_operations\">Customer Support & Operations</option>\n608 |                   <option value=\"legal_compliance\">Legal, Risk & Compliance</option>\n609 |                   <option value=\"supply_chain\">Supply Chain & Logistics</option>\n610 |                   <option value=\"finance_accounting\">Finance, Audit & Accounting</option>\n611 |                   <option value=\"it_engineering\">IT Service & Infrastructure</option>\n612 |                   <option value=\"hr_admin\">People & Administrative Services</option>\n613 |                 </select>\n614 |               </div>\n615 |             </div>\n616 | \n617 |             {/* SECTION 2: CURRENT WORKLOAD & COSTS */}\n618 |             <div className=\"space-y-4 border-b border-white/5 pb-5\">\n619 |               <div className=\"flex items-center gap-2\">\n620 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">02</span>\n621 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Friction & Baseline</span>\n622 |               </div>\n623 | \n624 |               {/* Annual Cost Baseline */}\n625 |               <div className=\"space-y-2\">\n626 |                 <div className=\"flex justify-between items-center\">\n627 |                   <label htmlFor=\"cost-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n628 |                     Annual Cost Baseline\n629 |                   </label>\n630 |                   <div className=\"flex items-center gap-1.5\">\n631 |                     <span className=\"text-white/40 font-mono text-[10px]\">$</span>\n632 |                     <input\n633 |                       id=\"cost-input\"\n634 |                       type=\"text\"\n635 |                       value={annualCostBaseline === 0 ? \"\" : annualCostBaseline.toLocaleString()}\n636 |                       onChange={(e) => handleBaselineChange(e.target.value)}\n637 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n638 |                     />\n639 |                   </div>\n640 |                 </div>\n641 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n642 |                   Annual expenses of targeted operational unit (labor + software tools).\n643 |                 </p>\n644 |                 <input\n645 |                   id=\"cost-slider\"\n646 |                   aria-label=\"Annual Cost Baseline range slider\"\n647 |                   type=\"range\"\n648 |                   min=\"50000\"\n649 |                   max=\"25000000\"\n650 |                   step=\"50000\"\n651 |                   value={annualCostBaseline}\n652 |                   onChange={(e) => setAnnualCostBaseline(parseInt(e.target.value))}\n653 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n654 |                 />\n655 |               </div>\n656 | \n657 |               {/* Process Volume */}\n658 |               <div className=\"space-y-2\">\n659 |                 <div className=\"flex justify-between items-center\">\n660 |                   <label htmlFor=\"volume-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n661 |                     Annual Process Volume\n662 |                   </label>\n663 |                   <div className=\"flex items-center gap-1.5\">\n664 |                     <input\n665 |                       id=\"volume-input\"\n666 |                       type=\"text\"\n667 |                       value={processVolume === 0 ? \"\" : processVolume.toLocaleString()}\n668 |                       onChange={(e) => handleVolumeChange(e.target.value)}\n669 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50\"\n670 |                     />\n671 |                   </div>\n672 |                 </div>\n673 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n674 |                   Annual requests, transactions, or tasks processed in this department.\n675 |                 </p>\n676 |                 <input\n677 |                   id=\"volume-slider\"\n678 |                   aria-label=\"Annual Process Volume range slider\"\n679 |                   type=\"range\"\n680 |                   min=\"1000\"\n681 |                   max=\"5000000\"\n682 |                   step=\"1000\"\n683 |                   value={processVolume}\n684 |                   onChange={(e) => setProcessVolume(parseInt(e.target.value))}\n685 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n686 |                 />\n687 |               </div>\n688 | \n689 |               {/* Average Handling Time */}\n690 |               <div className=\"space-y-2\">\n691 |                 <div className=\"flex justify-between items-center\">\n692 |                   <label htmlFor=\"aht-input\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n693 |                     Avg Handling Time (Mins)\n694 |                   </label>\n695 |                   <div className=\"flex items-center gap-2\">\n696 |                     <input\n697 |                       id=\"aht-input\"\n698 |                       type=\"text\"\n699 |                       placeholder=\"Sector Avg\"\n700 |                       value={avgHandlingTime}\n701 |                       onChange={(e) => handleHandlingTimeChange(e.target.value)}\n702 |                       className=\"w-24 h-7 bg-white/5 border border-white/10 rounded px-1.5 text-right font-mono font-bold text-xs text-white focus:outline-none focus:border-[#009DFF]/50 placeholder:text-white/20\"\n703 |                     />\n704 |                     <span className=\"text-[8px] font-mono text-white/30\">MIN</span>\n705 |                   </div>\n706 |                 </div>\n707 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n708 |                   Optional. Left blank, GFF models friction hours based on industry standards.\n709 |                 </p>\n710 |                 <input\n711 |                   id=\"aht-slider\"\n712 |                   aria-label=\"Avg Handling Time range slider\"\n713 |                   type=\"range\"\n714 |                   min=\"0\"\n715 |                   max=\"180\"\n716 |                   step=\"1\"\n717 |                   value={avgHandlingTime === \"\" ? 0 : avgHandlingTime}\n718 |                   onChange={(e) => setAvgHandlingTime(parseInt(e.target.value) || \"\")}\n719 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#009DFF] hover:accent-[#009DFF]\"\n720 |                 />\n721 |               </div>\n722 | \n723 |               {/* Manual Friction Index (Current Manual Effort Level) */}\n724 |               <div className=\"space-y-1.5\">\n725 |                 <div className=\"flex justify-between items-center\">\n726 |                   <span className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider\">\n727 |                     Manual Friction Index\n728 |                   </span>\n729 |                   <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest\">Wasted Effort Level</span>\n730 |                 </div>\n731 |                 <div className=\"grid grid-cols-4 gap-1\" role=\"group\" aria-label=\"Manual Friction Index\">\n732 |                   {[\n733 |                     { id: \"low\", label: \"Low\", desc: \"Highly standardized, minimal cognitive friction\" },\n734 |                     { id: \"medium\", label: \"Medium\", desc: \"Rule-based processing, minor exceptions\" },\n735 |                     { id: \"high\", label: \"High\", desc: \"Complex workflow, significant administrative drag\" },\n736 |                     { id: \"critical\", label: \"Critical\", desc: \"Severe operational bottleneck, data-heavy\" }\n737 |                   ].map((item) => (\n738 |                     <button\n739 |                       key={item.id}\n740 |                       type=\"button\"\n741 |                       onClick={() => setManualEffort(item.id)}\n742 |                       className={`py-1.5 rounded text-[10px] font-medium transition-all border flex flex-col items-center justify-center ${\n743 |                         manualEffort === item.id\n744 |                           ? \"bg-[#009DFF]/10 border-[#009DFF]/40 text-white\"\n745 |                           : \"bg-white/5 border-white/5 text-white/50 hover:bg-white/[0.08] hover:text-white/80\"\n746 |                       }`}\n747 |                       title={item.desc}\n748 |                     >\n749 |                       <span>{item.label}</span>\n750 |                     </button>\n751 |                   ))}\n752 |                 </div>\n753 |               </div>\n754 |             </div>\n755 | \n756 |             {/* SECTION 3: SOVEREIGN AMBITION */}\n757 |             <div className=\"space-y-4 pb-2\">\n758 |               <div className=\"flex items-center gap-2\">\n759 |                 <span className=\"text-[10px] font-mono bg-white/5 border border-white/10 text-[#009DFF] px-1.5 py-0.5 rounded\">03</span>\n760 |                 <span className=\"text-[10px] font-mono text-white/50 uppercase tracking-widest font-semibold\">Sovereign Automation Targets</span>\n761 |               </div>\n762 | \n763 |               {/* Automation Target Rate */}\n764 |               <div className=\"space-y-2\">\n765 |                 <div className=\"flex justify-between items-center\">\n766 |                   <label htmlFor=\"automation-slider\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n767 |                     Automation Target Rate\n768 |                   </label>\n769 |                   <span className=\"text-[#00FF9D] font-mono font-bold text-xs\">{automationTarget}%</span>\n770 |                 </div>\n771 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n772 |                   Target volume percentage delegated to secure multi-agent chains.\n773 |                 </p>\n774 |                 <input\n775 |                   id=\"automation-slider\"\n776 |                   aria-label=\"Automation Target Rate range slider\"\n777 |                   type=\"range\"\n778 |                   min=\"10\"\n779 |                   max=\"95\"\n780 |                   step=\"5\"\n781 |                   value={automationTarget}\n782 |                   onChange={(e) => setAutomationTarget(parseInt(e.target.value))}\n783 |                   className=\"w-full h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-[#00FF9D] hover:accent-[#00FF9D]\"\n784 |                 />\n785 |               </div>\n786 | \n787 |               {/* Target Productivity Boost */}\n788 |               <div className=\"space-y-2\">\n789 |                 <div className=\"flex justify-between items-center\">\n790 |                   <label htmlFor=\"productivity-slider\" className=\"text-white/60 font-mono text-[9px] uppercase tracking-wider cursor-pointer\">\n791 |                     Target Productivity Boost\n792 |                   </label>\n793 |                   <span className=\"text-white font-mono font-bold text-xs\">\n794 |                     {productivityImprovement}% <span className=\"text-white/30 text-[9px] font-light\">({Math.max(10, productivityImprovement - 15)}% - {Math.min(95, productivityImprovement + 15)}% model)</span>\n795 |                   </span>\n796 |                 </div>\n797 |                 <p className=\"text-[9px] text-white/30 leading-normal\">\n798 |                   Modelled efficiency multiplier of automated tasks. Bounds denote safety ranges.\n799 |                 </p>\n800 |                 <input\n801 |                   id=\"productivity-slider\"\n802 |                   aria-label=\"Target Productivity Boost range slider\"\n803 |                   type=\"range\"\n804 |                   min=\"10\"\