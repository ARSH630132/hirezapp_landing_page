Audit\",\n513 |         description: \"Queries localized warehouse systems to confirm critical replacement part counts.\",\n514 |         role: \"Inventory Audit Agent\"\n515 |       },\n516 |       {\n517 |         title: \"Work-Order Dispatch\",\n518 |         description: \"Generates preventative maintenance tickets and routes them to regional field crews.\",\n519 |         role: \"Maintenance Coordinator\"\n520 |       }\n521 |     ],\n522 |     challenge: \"Manufacturing plant operators struggle to predict equipment failure in industrial turbines, leading to catastrophic unscheduled downtime costing up to $500k per hour.\",\n523 |     interpretation: \"Polls vibrational and thermal sensors. Compiles deviation profiles against physics-based baseline models, and identifies structural wear metrics.\",\n524 |     knowledgeNeeded: [\n525 |       \"Vibration frequency baselines specifications\",\n526 |       \"Equipment manufacturing design sheets\",\n527 |       \"Turbine past maintenance log history\",\n528 |       \"Weather, ambient humidity, and load telemetry data\"\n529 |     ],\n530 |     humanApproval: \"Plant Director must manually sign off on the preventive maintenance dispatch order to shut down Turbine-3 for 2 hours.\",\n531 |     governanceCheck: \"Compliance check validates that all scheduled technicians have active safety certifications for High-Voltage Phase-3 equipment.\",\n532 |     outputPreview: \"{\\n  \\\"asset_id\\\": \\\"TURBINE-03\\\",\\n  \\\"anomaly_rating\\\": \\\"CRITICAL_92%\\\",\\n  \\\"wear_indicator\\\": \\\"Bearing-B radial oscillation is 1.8mm/s above design limits\\\",\\n  \\\"scheduled_maintenance\\\": \\\"Preventive maintenance recommended within 48 hours\\\",\\n  \\\"required_parts\\\": \\\"ISO-Bearing-883-X\\\"\\n}\",\n533 |     logs: [\n534 |       { timeOffset: 0.2, type: \"system\", text: \"Establishing physical communication with turbine IoT gateway buffer...\" },\n535 |       { timeOffset: 0.9, type: \"info\", text: \"Successfully connected. Collecting SCADA turbine telemetry stream...\" },\n536 |       { timeOffset: 1.6, type: \"agent\", text: \"[TelemetryIngestion] Pulled bearing vibration logs: 42Hz oscillations observed.\" },\n537 |       { timeOffset: 2.4, type: \"agent\", text: \"[AnomalyDetector] CRITICAL DEVIATION: Bearing radial displacement is 1.8mm over threshold limit.\" },\n538 |       { timeOffset: 3.2, type: \"warning\", text: \"[ManualRetriever] Retrieved maintenance file ISO-B-883-REPLACEMENT.pdf. Compiling instructions.\" },\n539 |       { timeOffset: 4.1, type: \"success\", text: \"SAP Work Order drafted. Routed to Plant Director dashboard. Dry-run complete.\" }\n540 |     ]\n541 |   }\n542 | ];\n543 | \n544 | // List of all filters available\n545 | const INDUSTRIES = [\n546 |   \"All Industries\",\n547 |   \"Energy & Utilities\",\n548 |   \"Retail & Supply Chain\",\n549 |   \"Professional Services\",\n550 |   \"Regulated / Legal\",\n551 |   \"Financial Services\",\n552 |   \"Government & Sovereign\",\n553 |   \"Telecom\",\n554 |   \"Heavy Industry & Mining\"\n555 | ];\n556 | \n557 | const FUNCTIONS = [\n558 |   \"All Functions\",\n559 |   \"Knowledge Search\",\n560 |   \"Procurement Copilot\",\n561 |   \"HR Assistant\",\n562 |   \"Contract Intelligence\",\n563 |   \"Executive Dashboard\",\n564 |   \"Compliance Assistant\",\n565 |   \"Customer Experience Agent\",\n566 |   \"Operations Copilot\"\n567 | ];\n568 | \n569 | const AGENT_TYPES = [\n570 |   \"All Agent Types\",\n571 |   \"Deep Reasoning / DAG\",\n572 |   \"Transactional / Actions\",\n573 |   \"Collaborative / HITL\",\n574 |   \"Analytical / Extraction\",\n575 |   \"Multi-Agent Synthesis\",\n576 |   \"Guardrail / Audit\",\n577 |   \"Real-time / Interactive\",\n578 |   \"Reactive / Hardware\"\n579 | ];\n580 | \n581 | export default function SandboxPage() {\n582 |   // Filter States\n583 |   const [selectedIndustry, setSelectedIndustry] = useState(\"All Industries\");\n584 |   const [selectedFunction, setSelectedFunction] = useState(\"All Functions\");\n585 |   const [selectedAgentType, setSelectedAgentType] = useState(\"All Agent Types\");\n586 |   const [searchQuery, setSearchQuery] = useState(\"\");\n587 | \n588 |   // Catalog Active Agent Selection\n589 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n590 | \n591 |   const [isHydrated, setIsHydrated] = useState(false);\n592 | \n593 |   // Load from GFF Workspace on mount\n594 |   useEffect(() => {\n595 |     const saved = getToolState(\"sandbox\");\n596 |     if (saved) {\n597 |       if (saved.selectedIndustry) setSelectedIndustry(saved.selectedIndustry);\n598 |       if (saved.selectedFunction) setSelectedFunction(saved.selectedFunction);\n599 |       if (saved.selectedAgentType) setSelectedAgentType(saved.selectedAgentType);\n600 |       if (typeof saved.searchQuery === \"string\") setSearchQuery(saved.searchQuery);\n601 |       if (saved.activeAgentId) setActiveAgentId(saved.activeAgentId);\n602 |     }\n603 |     setIsHydrated(true);\n604 |   }, []);\n605 | \n606 |   // Save to GFF Workspace on changes\n607 |   useEffect(() => {\n608 |     if (isHydrated) {\n609 |       saveToolState(\"sandbox\", {\n610 |         selectedIndustry,\n611 |         selectedFunction,\n612 |         selectedAgentType,\n613 |         searchQuery,\n614 |         activeAgentId\n615 |       });\n616 |     }\n617 |   }, [isHydrated, selectedIndustry, selectedFunction, selectedAgentType, searchQuery, activeAgentId]);\n618 | \n619 |   // Simulation Telemetry States\n620 |   const [isSimulating, setIsSimulating] = useState(false);\n621 |   const [simulationProgress, setSimulationProgress] = useState(0);\n622 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n623 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n624 |   const [isFlushingLogs, setIsFlushingLogs] = useState(false);\n625 | \n626 |   // Filter lists based on rules\n627 |   const filteredAgents = AGENTS.filter((agent) => {\n628 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n629 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n630 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n631 |     const matchSearch =\n632 |       searchQuery === \"\" ||\n633 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n634 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n635 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n636 | \n637 |     return matchIndustry && matchFunction && matchType && matchSearch;\n638 |   });\n639 | \n640 |   // Dynamically pull active agent object\n641 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n642 | \n643 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n644 |   useEffect(() => {\n645 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n646 |       setActiveAgentId(filteredAgents[0].id);\n647 |     }\n648 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n649 | \n650 |   // Reset simulation whenever active agent changes\n651 |   useEffect(() => {\n652 |     setIsSimulating(false);\n653 |     setSimulationProgress(0);\n654 |     setSimulatedLogs([]);\n655 |   }, [activeAgentId]);\n656 | \n657 |   // Handle dry-run simulation progress\n658 |   useEffect(() => {\n659 |     if (!isSimulating) return;\n660 | \n661 |     setSimulationProgress(0);\n662 |     setSimulatedLogs([]);\n663 | \n664 |     const totalDuration = 4800; // 4.8s simulation\n665 |     const intervalTime = 50; // update every 50ms\n666 |     let elapsed = 0;\n667 | \n668 |     const interval = setI