Ids, setCompareIds] = useState<string[]>([]);\n272 |   const [toastError, setToastError] = useState<string | null>(null);\n273 | \n274 |   const [isHydrated, setIsHydrated] = useState(false);\n275 | \n276 |   // Load from GFF Workspace on mount\n277 |   useEffect(() => {\n278 |     const saved = getToolState(\"marketplace\");\n279 |     if (saved) {\n280 |       if (saved.activeTab) setActiveTab(saved.activeTab);\n281 |       if (saved.industryFilter) setIndustryFilter(saved.industryFilter);\n282 |       if (saved.functionFilter) setFunctionFilter(saved.functionFilter);\n283 |       if (saved.maturityFilter) setMaturityFilter(saved.maturityFilter);\n284 |       if (saved.platformFilter) setPlatformFilter(saved.platformFilter);\n285 |       if (typeof saved.searchQuery === \"string\") setSearchQuery(saved.searchQuery);\n286 |       if (Array.isArray(saved.compareIds)) setCompareIds(saved.compareIds);\n287 |     }\n288 |     setIsHydrated(true);\n289 |   }, []);\n290 | \n291 |   // Save to GFF Workspace on changes\n292 |   useEffect(() => {\n293 |     if (isHydrated) {\n294 |       saveToolState(\"marketplace\", {\n295 |         activeTab,\n296 |         industryFilter,\n297 |         functionFilter,\n298 |         maturityFilter,\n299 |         platformFilter,\n300 |         searchQuery,\n301 |         compareIds\n302 |       });\n303 |     }\n304 |   }, [\n305 |     isHydrated,\n306 |     activeTab,\n307 |     industryFilter,\n308 |     functionFilter,\n309 |     maturityFilter,\n310 |     platformFilter,\n311 |     searchQuery,\n312 |     compareIds\n313 |   ]);\n314 | \n315 |   const [isCompareOpen, setIsCompareOpen] = useState<boolean>(false);\n316 | \n317 |   // Handle ?compare=true URL deep-action\n318 |   useEffect(() => {\n319 |     if (isHydrated && typeof window !== \"undefined\") {\n320 |       try {\n321 |         const params = new URLSearchParams(window.location.search);\n322 |         if (params.get(\"compare\") === \"true\") {\n323 |           setIsCompareOpen(true);\n324 |           setCompareIds(prev => {\n325 |             if (prev.length === 0) {\n326 |               return [\"sovereign-research-synth\", \"supply-chain-optimizer\"];\n327 |             }\n328 |             return prev;\n329 |           });\n330 |         }\n331 |       } catch (e) {\n332 |         console.error(\"Failed to parse compare param from URL:\", e);\n333 |       }\n334 |     }\n335 |   }, [isHydrated]);\n336 | \n337 |   const [sandboxId, setSandboxId] = useState<string | null>(null);\n338 |   const [sandboxLogs, setSandboxLogs] = useState<string[]>([]);\n339 |   const [sandboxInput, setSandboxInput] = useState<string>(\"\");\n340 |   const [sandboxIsBooting, setSandboxIsBooting] = useState<boolean>(false);\n341 |   const [sandboxIsSuccess, setSandboxIsSuccess] = useState<boolean>(false);\n342 |   \n343 |   const [chatId, setChatId] = useState<string | null>(null);\n344 |   const [chatMessages, setChatMessages] = useState<Array<{ sender: \"user\" | \"agent\"; text: string }>>([]);\n345 |   const [chatInput, setChatInput] = useState<string>(\"\");\n346 | \n347 |   const terminalEndRef = useRef<HTMLDivElement>(null);\n348 |   const chatEndRef = useRef<HTMLDivElement>(null);\n349 | \n350 |   const totalCertifiedCount = BLUEPRINTS.length;\n351 |   const prodReadyCount = BLUEPRINTS.filter(b => b.maturityStage === \"Production-Ready\").length;\n352 | \n353 | \n354 |   // Computed variables and filtering\n355 |   const filteredBlueprints = useMemo(() => {\n356 |     return BLUEPRINTS.filter((bp) => {\n357 |       if (activeTab !== \"All Patterns\" && bp.category !== activeTab) return false;\n358 |       if (industryFilter !== \"All Industries\" && bp.industry !== industryFilter) return false;\n359 |       if (functionFilter !== \"All Functions\" && bp.function !== functionFilter) return false;\n360 |       if (maturityFilter !== \"All Stages\" && bp.maturityStage !== maturityFilter) return false;\n361 |       if (platformFilter !== \"All Fits\" && bp.platformFit !== platformFilter) return false;\n362 | \n363 |       if (searchQuery.trim() !== \"\") {\n364 |         const query = searchQuery.toLowerCase();\n365 |         const matchesName = bp.name.toLowerCase().includes(query);\n366 |         const matchesDesc = bp.desc.toLowerCase().includes(query);\n367 |         const matchesUseCase = bp.useCase.toLowerCase().includes(query);\n368 |         const matchesCapabilities = bp.relatedCapabilities.some((cap) => cap.toLowerCase().includes(query));\n369 |         return matchesName || matchesDesc || matchesUseCase || matchesCapabilities;\n370 |       }\n371 | \n372 |       return true;\n373 |     });\n374 |   }, [activeTab, industryFilter, functionFilter, maturityFilter, platformFilter, searchQuery]);\n375 | \n376 |   const isFilterActive = useMemo(() => {\n377 |     return (\n378 |       activeTab !== \"All Patterns\" ||\n379 |       industryFilter !== \"All Industries\" ||\n380 |       functionFilter !== \"All Functions\" ||\n381 |       maturityFilter !== \"All Stages\" ||\n382 |       platformFilter !== \"All Fits\" ||\n383 |       searchQuery !== \"\"\n384 |     );\n385 |   }, [activeTab, industryFilter, functionFilter, maturityFilter, platformFilter, searchQuery]);\n386 | \n387 |   const resetAllFilters = () => {\n388 |     setActiveTab(\"All Patterns\");\n389 |     setIndustryFilter(\"All Industries\");\n390 |     setFunctionFilter(\"All Functions\");\n391 |     setMaturityFilter(\"All Stages\");\n392 |     setPlatformFilter(\"All Fits\");\n393 |     setSearchQuery(\"\");\n394 |   };\n395 | \n396 |   const comparedAgents = useMemo(() => {\n397 |     return BLUEPRINTS.filter((bp) => compareIds.includes(bp.id));\n398 |   }, [compareIds]);\n399 | \n400 | \n401 |   // Core handlers\n402 |   const toggleCompare = (id: string) => {\n403 |     if (compareIds.includes(id)) {\n404 |       setCompareIds((prev) => prev.filter((item) => item !== id));\n405 |     } else {\n406 |       if (compareIds.length >= 3) {\n407 |         setToastError(\"Maximum comparison limit reached. Please remove an agent before adding another.\");\n408 |         setTimeout(() => setToastError(null), 4000);\n409 |         return;\n410 |       }\n411 |       setCompareIds((prev) => [...prev, id]);\n412 |     }\n413 |   };\n414 | \n415 |   const clearComparison = () => {\n416 |     setCompareIds([]);\n417 |     setIsCompareOpen(false);\n418 |   };\n419 | \n420 |   useEffect(() => {\n421 |     if (terminalEndRef.current) {\n422 |       terminalEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n423 |     }\n424 |   }, [sandboxLogs, sandboxIsBooting]);\n425 | \n426 |   useEffect(() => {\n427 |     if (chatEndRef.current) {\n428 |       chatEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n429 |     }\n430 |   }, [chatMessages]);\n431 | \n432 |   const handleOpenSandbox = (id: string) => {\n433 |     const bp = BLUEPRINTS.find((b) => b.id === id);\n434 |     if (!bp) return;\n435 | \n436 |     setSandboxId(id);\n437 |     setSandboxIsBooting(true);\n438 |     setSandboxIsSuccess(false);\n439 |     setSandboxLogs([]);\n440 |     setSandboxInput(\"\");\n441 | \n442 |     const bootLogs = [\n443 |       `Initializing secure OCI container for ${bp.id}_v1.0...`,\n444 |       `Enforcing Context Boundary Spec (VPC: isolated-gff, RAM: 16GB, GPU Allocation: 2x Nvidia H100)...`,\n445 |       `Activating Safety Redaction filters (Zero-Trust eBPF Packet Inspector)...`,\n446 |       `Establishing cryptographic connections to local adapters: [${bp.datasources}]...`,\n447 |       `Injecting Sovereign System Directives into local context pipeline...`,\n448 |       `[SUCCESS] Safe containment boundaries established. Sandbox online.`\n449 |     ];\n450 | \n451 |     let timer = 0;\n452 |     bootLogs.forEach((log, index) => {\n453 |       setTimeout(() => {\n454 |         setSandboxLogs((prev) => [...prev, `> ${log}`]);\n455 |         if (index === bootLogs.length - 1) {\n456 |           setSandboxIsBooting(false);\n457 |           setSandboxIsSuccess(true);\n458 |         }\n459 |       }, timer);\n460 |       timer += 400;\n461 |     });\n462 |   };\n463 | \n464 |   const handleSandboxSubmit = (e?: React.FormEvent) => {\n465 |     if (e) e.preventDefault();\n466 |     if (!sandboxInput.trim() || !sandboxId) return;\n467 | \n468 |     const bp = BLUEPRINTS.find((b) => b.id === sandboxId);\n469 |     if (!bp) return;\n470 | \n471 |     const userPrompt = sandboxInput;\n472 |     setSandboxLogs((prev) => [...prev, `$ ${userPrompt}`]);\n473 |     setSandboxInput(\"\");\n474 | \n475 |     setTimeout(() => {\n476 |       const matchedQA = bp.sandboxResponse.find(\n477 |         (qa) => qa.prompt.toLowerCase().includes(userPrompt.toLowerCase()) || \n478 |                 userPrompt.toLowerCase().includes(qa.prompt.toLowerCase())\n479 |       );\n480 | \n481 |       if (matchedQA) {\n482 |         setSandboxLogs((prev) => [...prev, matchedQA.answer]);\n483 |       } else {\n484 |         setSandboxLogs((prev) => [\n485 |           ...prev, \n486 |           `[EVALUATING SEMANTIC GRAPH VECTOR... OK]\\n[MATCH CRITERIA MET WITH LOW THRESHOLD]\\n\\nReceived: \"${userPrompt}\"\\n\\n[COMPLIANCE GATE NOTICE] Standard safety instruction intercepts any raw query not predefined inside this demo terminal. To execute custom queries, deploy this blueprint inside GFF Foundry Studio or consult with an integration engineer.\\n\\nSovereign System Directives are active: Zero risk of data leaks.`\n487 |         ]);\n488 |       }\n489 |     }, 800);\n490 |   };\n491 | \n492 |   const handlePresetSandboxQuery = (queryText: string) => {\n493 |     setSandboxInput(queryText);\n494 |     setTimeout(() => {\n495 |       setSandboxLogs((prev) => [...prev, `$ ${queryText}`]);\n496 |       setSandboxInput(\"\");\n497 |       const bp = BLUEPRINTS.find((b) => b.id === sandboxId);\n498 |       if (!bp) return;\n499 |       const matchedQA = bp.sandboxResponse.find((qa) => qa.prompt === queryText);\n500 |       if (matchedQA) {\n501 |         setSandboxLogs((prev) => [...prev, matchedQA.answer]);\n502 |       }\n503 |     }, 200);\n504 |   };\n505 | \n506 |   const handleOpenChat = (id: string) => {\n507 |     const bp = BLUEPRINTS.find((b) => b.id === id);\n508 |     if (!bp) return;\n509 | \n510 |     setChatId(id);\n511 |     setChatInput(\"\");\n512 |     setChatMessages([\n513 |       {\n514 |         sender: \"agent\",\n515 |         text: `Secure connection established with ${bp.name} (ID: ${bp.id}_v1.0). I am running within a sovereign execution enclave. How can I assist you with your integration blueprint or structural architecture today?`\n516 |       }\n517 |     ]);\n518 |   };\n519 | \n520 |   const handleChatSubmit = (e?: React.FormEvent) => {\n521 |     if (e) e.preventDefault();\n522 |     if (!chatInput.trim() || !chatId) return;\n523 | \n524 |     const userMsg = chatInput;\n525 |     setChatMessages((prev) => [...prev, { sender: \"user\", text: userMsg }]);\n526 |     setChatInput(\"\");\n527 | \n528 |     setTimeout(() => {\n529 |       setChatMessages((prev) => [\n530 |         ...prev,\n531 |         {\n532 |           sender: \"agent\",\n533 |           text: `Understood. Your inquiry regarding \"${userMsg}\" relates directly to GFF ${\n534 |             BLUEPRINTS.find((b) => b.id === chatId)?.gffFit\n535 |           } deployment guidelines. Every transaction is governed by strict local context constraints. For detailed topology maps and integration templates, let's schedule a dedicated GFF Systems Engineer Sync.`\n536 |         }\n537 |       ]);\n538 |     }, 600);\n539 |   };\n540 | \n541 | \n542 |   return (\n543 |     <InnerPageShell>\n544 |       {/* Background Dots */}\n545 |       <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none\" />\n546 | \n547 |       <InnerPageHero\n548 |         category=\"Sovereign Assets\"\n549 |         title=\"Agent Blueprint Registry and Architecture Catalog\"\n550 |         highlightedWord=\"Registry\"\n551 |         highlightColor=\"blue\"\n552 |         description=\"Explore GFF's catalog of certified multi-agent patterns, workflows, and accelerators. Every blueprint is pre-engineered with strict input/output boundaries, static integration boundaries, and dedicated safety enclaves for secure, localized execution.\"\n553 |         breadcrumbs={[\n554 |           { label: \"Build Suite\", href: \"/build\" },\n555 |           { label: \"Blueprint Registry\" }\n556 |         ]}\n557 |       />\n558 | \n559 |       {/* REGISTRY TELEMETRY BANNERS */}\n560 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 -mt-8 mb-16\">\n561 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 bg-[#040405] border border-white/5 rounded-2xl p-6 relative overflow-hidden\">\n562 |           <div className=\"absolute top-0 right-0 w-[20%] h-[100%] bg-gradient-to-l from-blue-500/5 to-transparent blur-[40px] pointer-events-none\" />\n563 |           \n564 |           <div className=\"space-y-1\">\n565 |             <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">BLUEPRINTS ACTIVE</span>\n566 |             <div className=\"flex items-baseline gap-2\">\n567 |               <span className=\"text-3xl font-bold text-white font-mono\">{totalCertifiedCount}</span>\n568 |               <span className=\"text-[10px] text-green-400 font-mono flex items-center gap-0.5\">\n569 |                 <CheckCircle2 className=\"w-3 h-3 inline\" /> CERTIFIED\n570 |               </span>\n571 |             </div>\n572 |             <p className=\"text-xs text-white/50 font-light\">Verified sovereign standards</p>\n573 |           </div>\n574 | \n575 |           <div className=\"space-y-1 border-t sm:border-t-0 sm:border-l border-white/5 pt-4 sm:pt-0 sm:pl-6\">\n576 |             <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">DEPLOYMENT BASELINE</span>\n577 |             <div className=\"flex items-baseline gap-2\">\n578 |               <span className=\"text-3xl font-bold text-[#009DFF] font-mono\">OCI</span>\n579 |               <span className=\"text-[11px] text-white/70 font-mono font-semibold\">Containerized</span>\n580 |             </div>\n581 |             <p className=\"text-xs text-white/50 font-light\">Air-gapped VPC enclaves</p>\n582 |           </div>\n583 | \n584 |           <div className=\"space-y-1 border-t lg:border-t-0 lg:border-l border-white/5 pt-4 lg:pt-0 lg:pl-6\">\n585 |             <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">PRODUCTION READY</span>\n586 |             <div className=\"flex items-baseline gap-2\">\n587 |               <span className=\"text-3xl font-bold text-white font-mono\">{prodReadyCount}</span>\n588 |               <span className=\"text-[11px] text-white/50 font-semibold\">/ {totalCertifiedCount} Ready</span>\n589 |             </div>\n590 |             <p className=\"text-xs text-white/50 font-light\">Immediate node orchestration</p>\n591 |           </div>\n592 | \n593 |           <div className=\"space-y-1 border-t lg:border-t-0 lg:border-l border-white/5 pt-4 lg:pt-0 lg:pl-6\">\n594 |             <span className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">COMPLIANCE ASSURANCE</span>\n595 |             <div className=\"flex items-baseline gap-2\">\n596 |               <span className=\"text-3xl font-bold text-green-400 font-mono\">100%</span>\n597 |               <span className=\"text-[11px] text-green-400/80 font-mono font-bold\">REGULATED</span>\n598 |             </div>\n599 |             <p className=\"text-xs text-white/50 font-light\">Zero-data-leakage guarantee</p>\n600 |           </div>\n601 |         </div>\n602 |       </div>\n603 | \n604 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 space-y-12 pb-24 relative\">\n605 |         {/* INTERACTIVE FILTERS BLOCK */}\n606 |         <MotionReveal className=\"bg-[#030304]/80 backdrop-blur-md rounded-2xl border border-white/5 p-6 space-y-6\">\n607 |           <div className=\"flex flex-col md:flex-row items-center justify-between gap-4\">\n608 |             <div className=\"relative w-full md:max-w-md\">\n609 |               <Search className=\"w-4 h-4 text-white/40 absolute left-4 top-1/2 -translate-y-1/2\" />\n610 |               <input\n611 |                 id=\"marketplace-search-input\"\n612 |                 aria-label=\"Search blueprints, capabilities, keywords\"\n613 |                 type=\"text\"\n614 |                 value={searchQuery}\n615 |                 onChange={(e) => setSearchQuery(e.target.value)}\n616 |                 placeholder=\"Search blueprints, capabilities, keywords...\"\n617 |                 className=\"w-full bg-black/40 border border-white/10 rounded-xl py-3 pl-11 pr-4 text-sm text-white placeholder-white/30 focus:outline-none focus:border-[#009DFF]/50 focus:ring-1 focus:ring-[#009DFF]/20 transition-all font-light\"\n618 |               />\n619 |               {searchQuery && (\n620 |                 <button \n621 |                   onClick={() => setSearchQuery(\"\")}\n622 |                   className=\"absolute right-4 top-1/2 -translate-y-1/2 text-white/40 hover:text-white\"\n623 |                 >\n624 |                   <X className=\"w-4 h-4\" />\n625 |                 </button>\n626 |               )}\n627 |             </div>\n628 | \n629 |             <div className=\"flex items-center gap-3\">\n630 |               <span className=\"text-xs font-mono text-white/40 flex items-center gap-1.5 uppercase\">\n631 |                 <Filter className=\"w-3.5 h-3.5\" /> Parameters\n632 |               </span>\n633 |               {isFilterActive && (\n634 |                 <button\n635 |                   onClick={resetAllFilters}\n636 |                   className=\"text-xs font-semibold text-red-500 hover:text-red-400 transition-colors flex items-center gap-1 cursor-pointer bg-red-500/5 px-2.5 py-1 rounded border border-red-500/10\"\n637 |                 >\n638 |                   <RefreshCw className=\"w-3 h-3\" /> Reset Filters\n639 |                 </button>\n640 |               )}\n641 |             </div>\n642 |           </div>\n643 | \n644 |           {/* ADVANCED SELECTORS GRID */}\n645 |           <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 pt-2 border-t border-white/5\">\n646 |             {/* Industry */}\n647 |             <div className=\"space-y-1.5\">\n648 |               <label htmlFor=\"industry-filter\" className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold cursor-pointer\">Industry Scope</label>\n649 |               <select\n650 |                 id=\"industry-filter\"\n651 |                 value={industryFilter}\n652 |                 onChange={(e) => setIndustryFilter(e.target.value)}\n653 |                 className=\"w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white/80 focus:outline-none focus:border-[#009DFF]/50 transition-all cursor-pointer font-light font-sans\"\n654 |               >\n655 |                 {INDUSTRIES.map((ind) => (\n656 |                   <option key={ind} value={ind} className=\"bg-black text-white\">{ind}</option>\n657 |                 ))}\n658 |               </select>\n659 |             </div>\n660 | \n661 |             {/* Function */}\n662 |             <div className=\"space-y-1.5\">\n663 |               <label htmlFor=\"function-filter\" className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold cursor-pointer\">Operational Function</label>\n664 |               <select\n665 |                 id=\"function-filter\"\n666 |                 value={functionFilter}\n667 |                 onChange={(e) => setFunctionFilter(e.target.value)}\n668 |                 cla