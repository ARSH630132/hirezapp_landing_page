 \n 90 |   // Hydrate from GFF Local Workspace on mount\n 91 |   useEffect(() => {\n 92 |     const savedState = getToolState(\"assessment\");\n 93 |     if (savedState) {\n 94 |       if (savedState.answers) setAnswers(savedState.answers);\n 95 |       if (typeof savedState.activeDimensionIndex === \"number\") {\n 96 |         setActiveDimensionIndex(savedState.activeDimensionIndex);\n 97 |       }\n 98 |       if (typeof savedState.showResult === \"boolean\") {\n 99 |         setShowResult(savedState.showResult);\n100 |       }\n101 |     }\n102 |   }, []);\n103 | \n104 |   // Save changes to GFF Local Workspace\n105 |   useEffect(() => {\n106 |     if (Object.keys(answers).length > 0) {\n107 |       saveToolState(\"assessment\", { answers, activeDimensionIndex, showResult });\n108 |     }\n109 |   }, [answers, activeDimensionIndex, showResult]);\n110 | \n111 |   // Local interaction states for results\n112 |   const [copied, setCopied] = useState<boolean>(false);\n113 |   const [saved, setSaved] = useState<boolean>(false);\n114 |   const [hoveredRadarIdx, setHoveredRadarIdx] = useState<number | null>(null);\n115 | \n116 |   const activeDimension = DIMENSIONS[activeDimensionIndex];\n117 | \n118 |   // Scoring details\n119 |   const totalQuestions = DIMENSIONS.reduce((acc, dim) => acc + dim.questions.length, 0);\n120 |   const answeredQuestionsCount = Object.keys(answers).length;\n121 |   const progressPercent = Math.round((answeredQuestionsCount / totalQuestions) * 100);\n122 | \n123 |   const getDimensionAnsweredCount = (dim: Dimension) => {\n124 |     return dim.questions.filter(q => answers[q.id] !== undefined).length;\n125 |   };\n126 | \n127 |   const isDimensionComplete = (dim: Dimension) => {\n128 |     return getDimensionAnsweredCount(dim) === dim.questions.length;\n129 |   };\n130 | \n131 |   const getLiveLevelEstimate = () => {\n132 |     if (answeredQuestionsCount === 0) return { name: \"Awaiting Input\", color: \"text-white/40\" };\n133 |     \n134 |     const sum = Object.values(answers).reduce((acc, val) => acc + val, 0);\n135 |     const avg = sum / answeredQuestionsCount;\n136 |     \n137 |     if (avg >= 3.4) return { name: \"Sovereign Mesh (Level IV)\", color: \"text-[#00FF9D]\" };\n138 |     if (avg >= 2.5) return { name: \"Federated Mesh (Level III)\", color: \"text-[#3B82F6]\" };\n139 |     if (avg >= 1.7) return { name: \"Siloed Enclave (Level II)\", color: \"text-[#E5A93C]\" };\n140 |     return { name: \"Reactive Sandbox (Level I)\", color: \"text-[#E4000F]\" };\n141 |   };\n142 | \n143 |   useEffect(() => {\n144 |     if (!isCompiling) return;\n145 |     const interval = setInterval(() => {\n146 |       setCompilingStep((prev) => {\n147 |         if (prev < COMPILING_MESSAGES.length - 1) {\n148 |           return prev + 1;\n149 |         } else {\n150 |           clearInterval(interval);\n151 |           setIsCompiling(false);\n152 |           setShowResult(true);\n153 |           return prev;\n154 |         }\n155 |       });\n156 |     }, 350);\n157 |     return () => clearInterval(interval);\n158 |   }, [isCompiling]);\n159 | \n160 |   const handleSelectOption = (questionId: string, score: number) => {\n161 |     setValidationError(null);\n162 |     setAnswers(prev => ({ ...prev, [questionId]: score }));\n163 |   };\n164 | \n165 |   const handleCompileTrigger = () => {\n166 |     setValidationError(null);\n167 |     const incompleteDims: string[] = [];\n168 |     \n169 |     DIMENSIONS.forEach(dim => {\n170 |       if (!isDimensionComplete(dim)) {\n171 |         incompleteDims.push(dim.shortName);\n172 |       }\n173 |     });\n174 | \n175 |     if (incompleteDims.length > 0) {\n176 |       setValidationError(\n177 |         `VALIDATION ALERT: Please resolve all diagnostic segments before compiling. Incomplete categories: ${incompleteDims.join(\", \")}.`\n178 |       );\n179 |       return;\n180 |     }\n181 | \n182 |     setIsCompiling(true);\n183 |     setCompilingStep(0);\n184 |   };\n185 | \n186 |   const handleReset = () => {\n187 |     setIsFlushing(true);\n188 |     setTimeout(() => {\n189 |       setAnswers({});\n190 |       setActiveDimensionIndex(0);\n191 |       setValidationError(null);\n192 |       setIsCompiling(false);\n193 |       setShowResult(false);\n194 |       setCompilingStep(0);\n195 |       clearToolState(\"assessment\");\n196 |       setIsFlushing(false);\n197 |     }, 450);\n198 |   };\n199 | \n200 |   // Generate dynamic results\n201 |   const calculateResults = () => {\n202 |     const totalScore = Object.values(answers).reduce((acc, val) => acc + val, 0);\n203 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n204 | \n205 |     let tierName = \"\";\n206 |     let tierColor = \"\";\n207 |     let borderAccent = \"\";\n208 |     let commentary = \"\";\n209 | \n210 |     if (percentage >= 85) {\n211 |       tierName = \"Maturity Level IV: Sovereign Agentic Grid\";\n212 |       tierColor = \"text-[#00FF9D]\";\n213 |       borderAccent = \"border-[#00FF9D]/30 shadow-[0_0_20px_rgba(0,255,157,0.03)]\";\n214 |       commentary = \"Your organization exhibits world-class capabilities tailored to host autonomous multi-agent systems inside isolated network subnets. Your data pipelines feature semantic linking and real-time context ingestion. We recommend establishing custom local vector nodes and deploying sovereign supervisor enclaves to transition your pilot workflows into immediate production lines with zero data retention risks.\";\n215 |     } else if (percentage >= 60) {\n216 |       tierName = \"Maturity Level III: Strategic Federated Mesh\";\n217 |       tierColor = \"text-[#3B82F6]\";\n218 |       borderAccent = \"border-[#3B82F6]/30 shadow-[0_0_20px_rgba(59,130,246,0.03)]\";\n219 |       commentary = \"You have established strong structural foundations. Your private cloud setups and operational documentation are highly mature, but data pipelines lack clean semantic structure and legacy writebacks remain constrained by human latency. Implementing localized vector cache enclaves and a federated AI Center of Excellence can resolve these bottlenecks and compress deployment timelines down to 30 days.\";\n220 |     } else if (percentage >= 35) {\n221 |       tierName = \"Maturity Level II: Experimental Siloed Enclave\";\n222 |       tierColor = \"text-[#E5A93C]\";\n223 |       borderAccent = \"border-[#E5A93C]/30 shadow-[0_0_20px_rgba(229,169,60,0.03)]\";\n224 |       commentary = \"Your AI efforts are fragmented, relying on cloud endpoints with manual review workflows and isolated scripts. While individual talent exists, the lack of centralized governance and structured vector data pipelines limits your ability to scale. Establishing a standardized sandbox environment is an essential next gate to coordinate telemetry protocols and secure a dedicated capital runway.\";\n225 |     } else {\n226 |       tierName = \"Maturity Level I: Reactive Discovery Sandbox\";\n227 |       tierColor = \"text-[#E4000F]\";\n228 |       borderAccent = \"border-[#E4000F]/30 shadow-[0_0_20px_rgba(228,0,15,0.03)]\";\n229 |       commentary = \"Your systems are locked in legacy databases with siloed, undocumented processes and minimal in-house AI engineering capabilities. Running unstructured commercial chatbots introduces high data-leakage and regulatory risks. We strongly suggest launching a controlled GFF Labs sandbox trial to securely model your security schemas before attempting any cloud or on-premises deployments.\";\n230 |     }\n231 | \n232 |     const dimensionBreakdowns = DIMENSIONS.map(dim => {\n233 |       const qIds = dim.questions.map(q => q.id);\n234 |       const scores = qIds.map(id => answers[id] || 1);\n235 |       const avg = Number((scores.reduce((a, b) => a + b, 0) / qIds.length).toFixed(1));\n236 | \n237 |       let status = \"GAP IDENTIFIED\";\n238 |       let statusStyle = \"text-[#E5A93C] bg-[#E5A93C]/5 border-[#E5A93C]/15\";\n239 |       let rec = \"\";\n240 | \n241 |       if (avg >= 3.5) {\n242 |         status = \"OPTIMIZED\";\n243 |         statusStyle = \"text-[#00FF9D] bg-[#00FF9D]/5 border-[#00FF9D]/15\";\n244 |       } else if (avg >= 2.5) {\n245 |         status = \"STABLE\";\n246 |         statusStyle = \"text-[#3B82F6] bg-[#3B82F6]/5 border-[#3B82F6]/15\";\n247 |       }\n248 | \n249 |       if (dim.id === \"strategy\") {\n250 |         rec = avg >= 2.5 \n251 |           ? \"Establish continuous strategy discovery boards mapping specific business bottlenecks to complex Multi-Agent DAG blueprints.\"\n252 |           : \"Secure executive board-level sponsorship to align corporate multi-year capital directly with structured pilot outcomes.\";\n253 |       } else if (dim.id === \"data\") {\n254 |         rec = avg >= 2.5\n255 |           ? \"Integrate GFF Context Knowledge Graphs to feed your active local agent enclaves with synchronized contextual context mapping.\"\n256 |           : \"Construct automated data ingestion pipelines using semantic chunkers to process legacy PDFs, SOPs, and manual logs securely.\";\n257 |       } else if (dim.id === \"process\") {\n258 |         rec = avg >= 2.5\n259 |           ? \"Deploy passive supervisor nodes to constantly measure multi-agent DAG latency bottlenecks and optimize step executions.\"\n260 |           : \"Digitize core manual workflows and document decision state boundaries before modeling autonomous handoffs.\";\n261 |       } else if (dim.id === \"talent\") {\n262 |         rec = avg >= 2.5\n263 |           ? \"Adopt Platform-as-a-Product structures to let internal engineering teams spin up isolated, pre-governed agents independently.\"\n264 |           : \"Roll out GFF AI Academy modules across target divisions to improve prompt literacy and reduce digital-transition friction.\";\n265 |       } else if (dim.id === \"governance\") {\n266 |         rec = avg >= 2.5\n267 |           ? \"Implement zero-retention boundary policies and cryptographically sign execution steps for high-integrity regulatory audits.\"\n268 |           : \"Install automated input/output security middleware to detect and redact sensitive customer identifiers (PII) at the edge.\";\n269 |       } else if (dim.id === \"techstack\") {\n270 |         rec = avg >= 2.5\n271 |           ? \"Introduce GFF Orchestration Gateways to dynamically route model calls based on cost, latency thresholds, and residency rules.\"\n272 |           : \"Transition operational workloads from public cloud API keys to private cloud enclaves or local containerized serving structures.\";\n273 |       } else if (dim.id === \"leadership\") {\n274 |         rec = avg >= 2.5\n275 |           ? \"Co-develop custom proprietary model adapters and pioneer topologies in collaborative syncs with GFF Labs.\"\n276 |           : \"Secure protected, multi-year CAPEX reserves to insulate early-stage pilot models from short-term financial fluctuations.\";\n277 |       } else {\n278 |         rec = avg >= 2.5\n279 |           ? \"Design full-duplex human-agent queues allowing operators and active supervisor bots to collaboratively resolve complex tasks.\"\n280 |           : \"Adopt a federated Center of Excellence (CoE) to streamline compliance clearances and standardize deployable templates.\";\n281 |       }\n282 | \n283 |       return { ...dim, avg, status, statusStyle, rec };\n284 |     });\n285 | \n286 |     // Dynamic Strengths mapping based on actual scores\n287 |     const strengths = dimensionBreakdowns\n288 |       .filter(d => d.avg >= 2.5)\n289 |       .map(d => {\n290 |         let desc = \"\";\n291 |         if (d.id === \"strategy\") desc = \"High alignment ensures capital allocation tracks execution metrics closely.\";\n292 |         else if (d.id === \"data\") desc = \"Clean unstructured semantic storage structures simplify embedding enclaves.\";\n293 |         else if (d.id === \"process\") desc = \"Clear manual decision handoffs prevent deadlocks during agent execution loops.\";\n294 |         else if (d.id === \"talent\") desc = \"Internal prompt literacy minimizes transitional engineering blockages.\";\n295 |         else if (d.id === \"governance\") desc = \"Existing boundary structures satisfy core regulatory redaction standards.\";\n296 |         else if (d.id === \"techstack\") desc = \"Private server architectures support fully containerized local execution environments.\";\n297 |         else if (d.id === \"leadership\") desc = \"Calculated risk tolerance empowers engineering to pilot proprietary adaptors.\";\n298 |         else desc = \"Centralized templates standardise pipelines and facilitate sandbox promotion.\";\n299 |         \n300 |         return { name: d.name, desc };\n301 |       });\n302 | \n303 |     // Dynamic Risks mapping based on actual scores\n304 |     const risks = dimensionBreakdowns\n305 |       .filter(d => d.avg < 2.5)\n306 |       .map(d => {\n307 |         let desc = \"\";\n308 |         if (d.id === \"strategy\") desc = \"Fragmented ad-hoc prioritizing risks budget drift and redundant departmental tooling.\";\n309 |         else if (d.id === \"data\") desc = \"Legacy database structures introduce hallucination variables and slow context ingestion.\";\n310 |         else if (d.id === \"process\") desc = \"High manual latency and unmapped workflows choke autonomous multi-agent scaling.\";\n311 |         else if (d.id === \"talent\") desc = \"Lack of dedicated prompt modeling capacity slows platform integration.\";\n312 |         else if (d.id === \"governance\") desc = \"Standard API endpoints with open access keys risk accidental telemetry leaks.\";\n313 |         else if (d.id === \"techstack\") desc = \"Third-party model dependencies expose enterprise systems to latency fluctuations.\";\n314 |         else if (d.id === \"leadership\") desc = \"Risk-averse capital allocation parameters threaten competitive multi-year stagnation.\";\n315 |         else desc = \"Siloed delivery channels delay software deployment cycles past 6 months.\";\n316 | \n317 |         return { name: d.name, desc };\n318 |       });\n319 | \n320 |     // Recommended GFF pathway details\n321 |     let recommendedPath = {\n322 |       id: \"garage\",\n323 |       name: \"GFF Garage\",\n324 |       badge: \"Rapid Sandbox & Pilot Scaling\",\n325 |       color: \"text-[#E4000F]\",\n326 |       borderColor: \"border-[#E4000F]/30\",\n327 |       glowBg: \"bg-[#E4000F]/5\",\n328 |       desc: \"Perfect for organizations in early strategic stages. GFF Garage provides rapid, risk-insulated Web Sandboxes and prompt literacy modules. Start by modeling isolated workflows, validating key decision barriers, and securing dedicated executive sponsorship without extensive capital exposure.\",\n329 |       focus: \"Ideation, Pilot Scoping, Basic Sandboxing, and Executive Alignment.\"\n330 |     };\n331 | \n332 |     if (percentage >= 85) {\n333 |       recommendedPath = {\n334 |         id: \"operate\",\n335 |         name: \"GFF Operate\",\n336 |         badge: \"Continuous Symbiosis & Autonomy\",\n337 |         color: \"text-[#00FF9D]\",\n338 |         borderColor: \"border-[#00FF9D]/30\",\n339 |         glowBg: \"bg-[#00FF9D]/5\",\n340 |         desc: \"Designed for world-class digital grids. GFF Operate launches full-duplex human-agent collaborative queues, deploys active security supervisor nodes to constantly inspect schemas at runtime, and runs continuous model guardrails to prevent token drift at 99.9% telemetry success.\",\n341 |         focus: \"Full-Duplex Handoffs, Real-Time Guardrails, Dynamic Optimization, and Active Supervisors.\"\n342 |       };\n343 |     } else if (percentage >= 60) {\n344 |       recommendedPath = {\n345 |         id: \"factory\",\n346 |         name: \"GFF Factory\",\n347 |         badge: \"Production Scaling & Fleet Orchestration\",\n348 |         color: \"text-[#3B82F6]\",\n349 |         borderColor: \"border-[#3B82F6]/30\",\n350 |         glowBg: \"bg-[#3B82F6]/5\",\n351 |         desc: \"Tailored for organizations with proven data context and private cloud enclaves. GFF Factory coordinates high-velocity agent fleets, deploys advanced semantic orchestration gateways, and standardizes continuous deployment (CI/CD) of secure agentic microservices across systems.\",\n352 |         focus: \"Multi-Agent Fleet Coordination, Routing Gateways, and Continuous Compliance Integration.\"\n353 |       };\n354 |     } else if (percentage >= 35) {\n355 |       recommendedPath = {\n356 |         id: \"foundry\",\n357 |         name: \"GFF Foundry\",\n358 |         badge: \"Contextual Enclaves & Secure Ingestion\",\n359 |         color: \"text-[#E5A93C]\",\n360 |         borderColor: \"border-[#E5A93C]/30\",\n361 |         glowBg: \"bg-[#E5A93C]/5\",\n362 |         desc: \"Optimized for bridging the gap between isolated scripts and standardized platforms. GFF Foundry constructs enterprise-grade private cloud enclaves, implements Context Knowledge Graphs, and sets up secure vector cache servers to ingest legacy repositories cleanly.\",\n363 |         focus: \"Contextual Databases, Sovereign VPC Boundaries, Model Adapters, and Secure Gateways.\"\n364 |       };\n365 |     }\n366 | \n367 |     const nextActions = [\n368 |       \"Launch a local GFF Zero-Trust Sandbox session to safely trace sample multi-system agentic handoffs.\",\n369 |       \"Conduct a structured diagnostic scan of structured and unstructured context repositories to identify vector database prerequisites.\",\n370 |       \"Sync with GFF Labs to explore custom proprietary model adapters designed for strict local data retention rules.\",\n371 |       \"Generate an automated Topological Blueprint and draft an Algorithmic SOW to establish operational milestones.\"\n372 |     ];\n373 | \n374 |     return { percentage, tierName, tierColor, borderAccent, commentary, dimensionBreakdowns, strengths, risks, recommendedPath, nextActions };\n375 |   };\n376 | \n377 |   const report = showResult ? calculat