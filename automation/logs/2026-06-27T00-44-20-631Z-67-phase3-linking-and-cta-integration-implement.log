actNode;\n440 |   accentColor?: string;\n441 | }\n442 | \n443 | interface ToolOptionGridProps {\n444 |   options: OptionItem[];\n445 |   selectedId: string | string[];\n446 |   onChange: (id: string) => void;\n447 |   multiSelect?: boolean;\n448 | }\n449 | \n450 | export function ToolOptionGrid({ options, selectedId, onChange, multiSelect = false }: ToolOptionGridProps) {\n451 |   const isSelected = (id: string) => {\n452 |     if (multiSelect && Array.isArray(selectedId)) {\n453 |       return selectedId.includes(id);\n454 |     }\n455 |     return selectedId === id;\n456 |   };\n457 | \n458 |   return (\n459 |     <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n460 |       {options.map((opt) => {\n461 |         const selected = isSelected(opt.id);\n462 |         const accent = opt.accentColor || \"#009DFF\";\n463 | \n464 |         return (\n465 |           <motion.button\n466 |             key={opt.id}\n467 |             onClick={() => onChange(opt.id)}\n468 |             type=\"button\"\n469 |             whileHover={{ scale: 1.01, y: -1 }}\n470 |             whileTap={{ scale: 0.995 }}\n471 |             transition={{ duration: 0.15 }}\n472 |             className={`text-left p-5 rounded-xl border transition-all duration-300 relative group flex gap-4 cursor-pointer ${\n473 |               selected\n474 |                 ? \"bg-white/[0.03] border-white/15\"\n475 |                 : \"bg-white/[0.01] border-white/5 hover:border-white/10 hover:bg-white/[0.02]\"\n476 |             }`}\n477 |           >\n478 |             {/* Custom glowing accent border */}\n479 |             <div\n480 |               className={`absolute inset-x-0 top-0 h-[1.5px] transition-all duration-300 pointer-events-none ${\n481 |                 selected ? \"opacity-100\" : \"opacity-0 group-hover:opacity-35\"\n482 |               }`}\n483 |               style={{\n484 |                 background: `linear-gradient(90deg, transparent, ${accent}, transparent)`\n485 |               }}\n486 |             />\n487 | \n488 |             {opt.icon && (\n489 |               <div\n490 |                 className={`w-8 h-8 rounded-lg border flex items-center justify-center shrink-0 transition-all ${\n491 |                   selected\n492 |                     ? \"bg-white/5 border-white/10 text-white\"\n493 |                     : \"bg-white/[0.01] border-white/5 text-white/35 group-hover:text-white\"\n494 |                 }`}\n495 |                 style={selected ? { color: accent, borderColor: `${accent}25` } : {}}\n496 |               >\n497 |                 {opt.icon}\n498 |               </div>\n499 |             )}\n500 | \n501 |             <div className=\"space-y-1\">\n502 |               <span className={`text-xs font-bold transition-colors ${selected ? \"text-white\" : \"text-white/70 group-hover:text-white\"}`}>\n503 |                 {opt.title}\n504 |               </span>\n505 |               <p className=\"text-[11px] text-white/40 leading-relaxed font-light group-hover:text-white/50 transition\">\n506 |                 {opt.description}\n507 |               </p>\n508 |             </div>\n509 |           </motion.button>\n510 |         );\n511 |       })}\n512 |     </div>\n513 |   );\n514 | }\n515 | \n516 | // ==========================================\n517 | // 11. ToolSummaryCard\n518 | // ==========================================\n519 | interface ToolSummaryCardProps {\n520 |   label: string;\n521 |   value: string | number;\n522 |   description?: string;\n523 |   accentColor?: string;\n524 | }\n525 | \n526 | export function ToolSummaryCard({ label, value, description, accentColor = \"#009DFF\" }: ToolSummaryCardProps) {\n527 |   return (\n528 |     <div className=\"p-5 rounded-xl border border-white/5 bg-[#030305] flex flex-col justify-between hover:border-white/10 transition-all group relative\">\n529 |       {/* Light edge beam */}\n530 |       <div\n531 |         className=\"absolute top-0 left-1/4 right-1/4 h-[1px] opac