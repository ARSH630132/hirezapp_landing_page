/20 bg-[#009DFF]/5 flex items-center justify-between text-xs text-white animate-fadeIn\">\n491 |                   <div className=\"flex items-center gap-2\">\n492 |                     <span className=\"w-1.5 h-1.5 rounded-full bg-[#009DFF] animate-pulse\" />\n493 |                     <span>In-progress draft detected from your previous workspace session.</span>\n494 |                   </div>\n495 |                   <div className=\"flex gap-2\">\n496 |                     <button onClick={handleRestoreDraft} className=\"px-3 py-1.5 bg-[#009DFF]/20 border border-[#009DFF]/40 text-[#009DFF] text-[10px] font-mono hover:bg-[#009DFF]/40 transition uppercase font-bold rounded\">Restore Draft</button>\n497 |                     <button onClick={() => setHasSavedDraft(false)} className=\"px-2 py-1.5 text-white/40 text-[10px] font-mono hover:text-white uppercase\">Ignore</button>\n498 |                   </div>\n499 |                 </div>\n500 |               )}\n501 | \n502 |               {/* STEP TIMELINE GATE HEADER */}\n503 |               <div className=\"p-1 rounded-lg bg-black/45 border border-white/5 flex text-center text-[10px] font-mono\">\n504 |                 {[1, 2, 3].map((g) => (\n505 |                   <button\n506 |                     key={g}\n507 |                     type=\"button\"\n508 |                     onClick={() => { if (validateStep(1) && (g < 3 || validateStep(2))) setActiveStepGate(g as 1 | 2 | 3); }}\n509 |                     className={`flex-1 py-2 rounded transition font-semibold uppercase ${activeStepGate === g ? \"bg-white/5 text-[#009DFF] border border-white/10\" : \"text-white/40 hover:text-white\"}`}\n510 |                     disabled={g > activeStepGate && !validateStep(activeStepGate)}\n511 |                   >\n512 |                     <span>0{g}</span>\n513 |                     <span className=\"hidden sm:inline\"> {\"//\"} {g === 1 ? \"Baseline Profile\" : g === 2 ? \"Strategy & Outcomes\" : \"Deployment Pathway\"}</span>\n514 |                   </button>\n515 |                 ))}\n516 |               </div>\n517 | \n518 |               {/* FORM WRAPPER CARD */}\n519 |               <div className=\"p-6 lg:p-8 rounded-2xl border border-white/5 bg-[#030306]/95 relative overflow-hidden\">\n520 |                 <div className=\"absolute top-0 right-0 p-4 font-mono text-[8px] text-white/20\">\n521 |                   GFF_PROPOSAL_STUDIO // REV_2026\n522 |                 </div>\n523 | \n524 |                 {/* GATE 1: BASELINE */}\n525 |                 {activeStepGate === 1 && (\n526 |                   <div className=\"space-y-5 animate-fadeIn\">\n527 |                     <div className=\"border-b border-white/5 pb-3\">\n528 |                       <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider font-bold\">GATE 01 OF 03</span>\n529 |                       <h2 className=\"text-lg font-bold text-white mt-1\">Corporate Baseline Profile</h2>\n530 |                       <p className=\"text-white/40 text-[10px] font-light\">Specify your organization, vertical sector, operational scale, and target regional boundary constraints.</p>\n531 |                     </div>\n532 | \n533 |                     <div className=\"space-y-1.5\">\n534 |                       <label htmlFor=\"company-name-input\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block cursor-pointer\">Organization Name (Optional)</label>\n535 |                       <input\n536 |                         id=\"company-name-input\"\n537 |                         type=\"text\"\n538 |                         value={inputs.companyName}\n539 |                         onChange={(e) => setInputs({ ...inputs, companyName: e.target.value })}\n540 |                         placeholder=\"e.g. Sovereign Global Mainframes\"\n541 |                         className=\"w-full bg-black/40 border border-white/10 rounded-lg px-4 h-11 text-xs text-white placeholder-white/20 focus:outline-none focus:border-[#009DFF]/60 transition\"\n542 |                       />\n543 |                     </div>\n544 | \n545 |                     <div className=\"space-y-1.5\">\n546 |                       <div className=\"flex justify-between\">\n547 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Industry Vertical</label>\n548 |                         {validationErrors.industry && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.industry}</span>}\n549 |                       </div>\n550 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2.5\">\n551 |                         {INDUSTRIES.map((ind) => (\n552 |                           <button\n553 |                             key={ind.id}\n554 |                             type=\"button\"\n555 |                             onClick={() => { setInputs({ ...inputs, industry: ind.id }); setValidationErrors((prev) => ({ ...prev, industry: \"\" })); }}\n556 |                             className={`p-3 rounded-xl border text-left transition flex gap-3 items-start min-h-[60px] ${inputs.industry === ind.id ? \"border-[#009DFF] bg-[#009DFF]/5 shadow-[0_0_12px_rgba(0,157,255,0.1)]\" : \"border-white/5 bg-black/40 hover:border-white/10 hover:bg-black/60\"}`}\n557 |                           >\n558 |                             <span className=\"text-base mt-0.5\">{ind.icon}</span>\n559 |                             <div>\n560 |                               <h4 className=\"text-xs font-bold text-white leading-none\">{ind.label}</h4>\n561 |                               <p className=\"text-[9px] text-white/40 leading-snug font-light mt-1\">{ind.desc}</p>\n562 |                             </div>\n563 |                           </button>\n564 |                         ))}\n565 |                       </div>\n566 |                     </div>\n567 | \n568 |                     <div className=\"space-y-1.5\">\n569 |                       <div className=\"flex justify-between\">\n570 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block\">Enterprise Operational Scale</label>\n571 |                         {validationErrors.companySize && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.companySize}</span>}\n572 |                       </div>\n573 |                       <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-2.5\">\n574 |                         {COMPANY_SIZES.map((size) => (\n575 |                           <button\n576 |                             key={size.id}\n577 |                             type=\"button\"\n578 |                             onClick={() => { setInputs({ ...inputs, companySize: size.id }); setValidationErrors((prev) => ({ ...prev, companySize: \"\" })); }}\n579 |                             className={`p-3 rounded-xl border text-left transition flex flex-col justify-between min-h-[105px] ${inputs.companySize === size.id ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40 hover:border-white/10\"}`}\n580 |                           >\n581 |                             <div>\n582 |                               <h4 className=\"text-xs font-bold text-white leading-tight\">{size.label}</h4>\n583 |                               <span className=\"text-[8px] font-mono text-white/40 mt-0.5 block\">{size.range}</span>\n584 |                             </div>\n585 |                             <p className=\"text-[9px] text-white/30 leading-tight mt-1.5\">{size.desc}</p>\n586 |                           </button>\n587 |                         ))}\n588 |                       </div>\n589 |                     </div>\n590 | \n591 |                     <div className=\"space-y-1.5\">\n592 |                       <label htmlFor=\"geography-input\" className=\"text-[10px] font-mono text-white/50 uppercase tracking-wide block cursor-pointer\">Deployment Geography (Optional)</label>\n593 |                       <input\n594 |                         id=\"geography-input\"\n595 |                         type=\"text\"\n596 |                         value={inputs.geography}\n597 |                         onChange={(e) => setInputs({ ...inputs, geography: e.target.value })}\n598 |                         placeholder=\"e.g. EU Sovereign Boundary (VPC Frankfurt), AWS us-east-1 VPC\"\n599 |                         className=\"w-full bg-black/40 border border-white/10 rounded-lg px-4 h-11 text-xs text-white placeholder-white/20 focus:outline-none focus:border-[#009DFF]/60 transition\"\n600 |                       />\n601 |                     </div>\n602 |                   </div>\n603 |                 )}\n604 | \n605 |                 {/* GATE 2: STRATEGY & OUTCOMES */}\n606 |                 {activeStepGate === 2 && (\n607 |                   <div className=\"space-y-5 animate-fadeIn\">\n608 |                     <div className=\"border-b border-white/5 pb-3\">\n609 |                       <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider font-bold\">GATE 02 OF 03</span>\n610 |                       <h2 className=\"text-lg font-bold text-white mt-1\">Strategic Friction & Outcomes</h2>\n611 |                     </div>\n612 | \n613 |                     <div className=\"space-y-1.5\">\n614 |                       <div className=\"flex justify-between\">\n615 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Primary Obstacle</label>\n616 |                         {validationErrors.primaryChallenge && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.primaryChallenge}</span>}\n617 |                       </div>\n618 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n619 |                         {CHALLENGES.map((chal) => (\n620 |                           <button\n621 |                             key={chal.id}\n622 |                             type=\"button\"\n623 |                             onClick={() => { setInputs({ ...inputs, primaryChallenge: chal.id }); setValidationErrors((prev) => ({ ...prev, primaryChallenge: \"\" })); }}\n624 |                             className={`p-2 rounded-xl border text-left transition flex gap-2 items-start min-h-[60px] ${inputs.primaryChallenge === chal.id ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40\"}`}\n625 |                           >\n626 |                             <span className=\"text-sm mt-0.5\">{chal.icon}</span>\n627 |                             <div>\n628 |                               <h4 className=\"text-xs font-bold text-white leading-none\">{chal.label}</h4>\n629 |                               <p className=\"text-[8.5px] text-white/35 leading-tight mt-1 font-light\">{chal.desc}</p>\n630 |                             </div>\n631 |                           </button>\n632 |                         ))}\n633 |                       </div>\n634 |                     </div>\n635 | \n636 |                     {inputs.primaryChallenge === \"other\" && (\n637 |                       <div className=\"space-y-1.5\">\n638 |                         <label htmlFor=\"custom-challenge-textarea\" className=\"text-[10px] font-mono text-white/50 uppercase block cursor-pointer\">Specify Custom Obstacle</label>\n639 |                         <textarea\n640 |                           id=\"custom-challenge-textarea\"\n641 |                           rows={2}\n642 |                           value={inputs.customChallenge}\n643 |                           onChange={(e) => { setInputs({ ...inputs, customChallenge: e.target.value }); setValidationErrors((prev) => ({ ...prev, customChallenge: \"\" })); }}\n644 |                           placeholder=\"Describe the custom strategic obstacle...\"\n645 |                           className=\"w-full bg-black/40 border border-white/10 rounded-lg p-2.5 text-xs text-white focus:border-[#009DFF]\"\n646 |                         />\n647 |                       </div>\n648 |                     )}\n649 | \n650 |                     <div className=\"space-y-1.5\">\n651 |                       <div className=\"flex justify-between\">\n652 |                         <label className=\"text-[10px] font-mono text-white/50 uppercase block\">Priority Outcomes</label>\n653 |                         {validationErrors.priorityOutcomes && <span className=\"text-[9px] font-mono text-[#E4000F] font-bold\">{validationErrors.priorityOutcomes}</span>}\n654 |                       </div>\n655 |                       <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-2\">\n656 |                         {OUTCOMES.map((out) => {\n657 |                           const isSelected = inputs.priorityOutcomes.includes(out.id);\n658 |                           return (\n659 |                             <button\n660 |                               key={out.id}\n661 |                               type=\"button\"\n662 |                               onClick={() => {\n663 |                                 let list = [...inputs.priorityOutcomes];\n664 |                                 if (isSelected) list = list.filter((id) => id !== out.id);\n665 |                                 else list.push(out.id);\n666 |                                 setInputs({ ...inputs, priorityOutcomes: list });\n667 |                               }}\n668 |                               className={`p-2.5 rounded-xl border text-left transition flex items-center justify-between gap-4 ${isSelected ? \"border-[#009DFF] bg-[#009DFF]/5\" : \"border-white/5 bg-black/40\"}`}\n669 |                             >\n670 |                               <div>\n671 |                                 <h4 className=\"text-xs font-bold text-white leading-tight\">{out.label}</h4>\n672 |                                 <p className=\"text-[8.5px] text