{"ts":"2026-06-27T17:06:13.803Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7yxg1fmk","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  RefreshCw, Cpu, Activity, ShieldCheck, Layers, FileText, Lock, MessageSquare, AlertTriangle \n} from \"lucide-react\";\nimport { WorkspaceCard } from \"@/components/private-app\";\n\ninterface AnalyticsSummary {\n  projects: { totalCount: number; byStatus: Record<string, number>; byPhase: Record<string, number> };\n  aiOperations: { totalCount: number; byStatus: Record<string, number>; byHealth: Record<string, number> };\n  documents: { totalCount: number; byStatus: Record<string, number> };\n  invoices: { totalCount: number; byStatus: Record<string, number> };\n  support: { totalCount: number; byStatus: Record<string, number>; byPriority: Record<string, number> };\n  governance: { totalCount: number; byStatus: Record<string, number>; bySeverity: Record<string, number> };\n}\n\nexport default function ClientAnalyticsPage() {\n  const router = useRouter();\n  const [data, setData] = useState<{ summary: AnalyticsSummary } | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [dataPoints, setDataPoints] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n\n  const fetchAnalytics = useCallback(async () => {\n    setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n        router.push(\"/portal/login\");\n        return;\n      }\n      const res = await fetch(\"/api/v1/analytics/client\", {\n        headers: { \"Authorization\": `Bearer ${token}`, \"Content-Type\": \"application/json\" }\n      });\n      if (!res.ok) throw new Error(`Telemetry coupling failed. Status ${res.status}`);\n      const resData = await res.json();\n      if (resData.success && resData.summary) {\n        setData(resData);\n      } else {\n        throw new Error(\"Handshake returned malformed telemetry ledger.\");\n      }\n    } catch (err: any) {\n      console.error(\"Error fetching analytics:\", err);\n      setError(err.message || \"Decentralized telemetry coupling timed out.\");\n    } finally {\n      setLoading(false);\n    }\n  }, [router]);\n\n  useEffect(() => {\n    fetchAnalytics();\n    const interval = setInterval(() => {\n      setDataPoints(prev => {\n        const nextVal = Math.min(100, Math.max(20, prev[prev.length - 1] + (Math.floor(Math.random() * 14) - 7)));\n        return [...prev.slice(1), nextVal];\n      });\n    }, 1500);\n    return () => clearInterval(interval);\n  }, [fetchAnalytics]);\n\n  if (loading) {\n    return (\n      <div className=\"space-y-6 font-mono\">\n        <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n          <div>\n            <h2 className=\"text-xl font-bold text-white uppercase\">Telemetry Analytics</h2>\n            <p className=\"text-xs text-white/50\">Establishing handshakes with cloud enclave registers...</p>\n          </div>\n          <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin\" />\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n          {[1, 2, 3].map(n => (\n            <WorkspaceCard key={n} className=\"h-32 border border-white/5 bg-[#050505]/20 p-5 rounded-xl space-y-3 animate-pulse\" />\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (error) {\n    return (\n      <div className=\"space-y-6 font-mono\">\n        <WorkspaceCard className=\"p-8 border border-red-500/10 bg-red-950/5 rounded-2xl flex flex-col items-center justify-center text-center space-y-4 max-w-lg mx-auto my-12\">\n          <AlertTriangle className=\"w-8 h-8 text-red-400 animate-pulse\" />\n          <h4 className=\"text-white font-bold uppercase text-sm\">TELEMETRY SYNC ERROR</h4>\n          <p className=\"text-white/50 text-[11px] leading-relaxed\">{error}</p>\n          <button onClick={fetchAnalytics} className=\"h-9 px-6 rounded bg-white/5 hover:bg-white/10 border border-white/10 text-white font-bold text-[11px] uppercase flex items-center gap-2 cursor-pointer transition-all\">\n            <RefreshCw className=\"w-3.5 h-3.5\" />\n            <span>RE-ESTABLISH HANDSHAKE</span>\n          </button>\n        </WorkspaceCard>\n      </div>\n    );\n  }\n\n  const s = data?.summary;\n\n  return (\n    <div className=\"space-y-6 font-mono\">\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        <div className=\"flex items-center gap-3\">\n          <span className=\"text-[9px] text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-1 rounded uppercase tracking-wider animate-pulse flex items-center gap-1.5\">\n            <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400\" /> Live broadcast active\n          </span>\n          <button onClick={fetchAnalytics} className=\"h-8 px-3 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 transition-colors flex items-center gap-1.5\">\n            <RefreshCw className=\"w-3 h-3\" /> Sync Stats\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <Activity className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white uppercase\">Enclave CPU Load Stream</h3>\n            </div>\n            <span className=\"text-[9px] text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-0.5 rounded-full uppercase tracking-wider\">LIVE BROADCAST</span>\n          </div>\n          <div className=\"h-32 flex items-end justify-between gap-1 bg-black/40 border border-white/5 rounded-xl p-4 relative\">\n            <svg className=\"absolute inset-x-0 bottom-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path d={`M ${dataPoints.map((val, idx) => `${idx * 55}, ${112 - (val * 0.9)}`).join(\" L \")}`} fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"2.5\" className=\"transition-all duration-500\" />\n              <circle cx=\"500\" cy={112 - (dataPoints[dataPoints.length - 1] * 0.9)} r=\"4\" className=\"fill-[#009DFF]\" />\n            </svg>\n            <div className=\"absolute top-3 left-3 text-[10px] text-white/20 select-none\">Mean Sandbox CPU: {dataPoints[dataPoints.length - 1]}%</div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n            <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">Network Latencies</h3>\n          </div>\n          <div className=\"space-y-2 text-[11px] text-white/60\">\n            {[\n              { hash: \"f3a8b291c9\", label: \"Singapore Zone A\", ping: \"4ms\" },\n              { hash: \"e88d123880\", label: \"London Zone C\", ping: \"3ms\" },\n              { hash: \"a01fe99211\", label: \"Local Enclave Mesh\", ping: \"5ms\" }\n            ].map(node => (\n              <div key={node.hash} className=\"flex justify-between border-b border-white/5 pb-2 last:border-b-0 last:pb-0\">\n                <div>\n                  <span className=\"text-white block font-bold\">{node.label}</span>\n                  <span className=\"text-[9px] text-[#009DFF]/60 block\">{node.hash}</span>\n                </div>\n                <span className=\"text-emerald-400 font-bold text-xs\">{node.ping}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl flex flex-col justify-between h-[150px]\">\n          <div className=\"flex items-center justify-between\">\n            <div className=\"flex items-center gap-2\">\n              <Layers className=\"w-4 h-4 text-[#009DFF]\" />\n              <h4 className=\"text-xs font-bold text-white uppercase\">Sandbox Enclaves</h4>\n            </div>\n            <span className=\"text-[8px] text-[#009DFF] border border-[#009DFF]/20 px-1.5 py-0.2 rounded font-bold uppercase\">Online</span>\n          </div>\n          <div className=\"flex items-baseline gap-2 mt-2\">\n            <span className=\"text-3xl font-bold text-white\">{s?.projects?.totalCount || 0}</span>\n            <span className=\"text-[10px] text-white/45\">Total Clusters</span>\n          </div>\n          <div className=\"border-t border-white/5 pt-2 text-[10px] text-white/40 flex justify-between\">\n            <span>Operate Live: {s?.projects?.byStatus?.active || 0}</span>\n            <span>Pending Gate: {s?.projects?.byStatus?.pending || 0}</span>\n          </div>\n        </WorkspaceCard>\