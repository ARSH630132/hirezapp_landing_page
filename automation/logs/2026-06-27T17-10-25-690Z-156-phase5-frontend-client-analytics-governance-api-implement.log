{"ts":"2026-06-27T17:05:53.441Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7r45kp6r","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { \n  BarChart3, RefreshCw, Cpu, Activity, ShieldCheck, \n  Layers, FileText, CreditCard, MessageSquare, AlertTriangle, \n  ChevronRight, Sparkles, CheckCircle2, Lock, Landmark\n} from \"lucide-react\";\nimport { WorkspaceCard } from \"@/components/private-app\";\n\ninterface AnalyticsSummary {\n  projects: { totalCount: number; byStatus: Record<string, number>; byPhase: Record<string, number> };\n  aiOperations: { totalCount: number; byStatus: Record<string, number>; byHealth: Record<string, number> };\n  documents: { totalCount: number; byStatus: Record<string, number> };\n  invoices: { totalCount: number; byStatus: Record<string, number> };\n  support: { totalCount: number; byStatus: Record<string, number>; byPriority: Record<string, number> };\n  governance: { totalCount: number; byStatus: Record<string, number>; bySeverity: Record<string, number> };\n}\n\ninterface AnalyticsResponse {\n  success: boolean;\n  client_id: string;\n  summary: AnalyticsSummary;\n}\n\nexport default function ClientAnalyticsPage() {\n  const router = useRouter();\n  const [data, setData] = useState<AnalyticsResponse | null>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n\n  // Live CPU data points\n  const [dataPoints, setDataPoints] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n\n  const fetchAnalytics = useCallback(async () => {\n    setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        setError(\"AUTHENTICATION EXPIRED. PLEASE RE-LOG IN.\");\n        router.push(\"/portal/login\");\n        return;\n      }\n\n      const res = await fetch(\"/api/v1/analytics/client\", {\n        headers: {\n          \"Authorization\": `Bearer ${token}`,\n          \"Content-Type\": \"application/json\"\n        }\n      });\n\n      if (!res.ok) {\n        throw new Error(`Telemetry coupling failed. Status ${res.status}`);\n      }\n\n      const resData = await res.json();\n      if (resData.success && resData.summary) {\n        setData(resData);\n      } else {\n        throw new Error(\"Handshake returned malformed telemetry ledger.\");\n      }\n    } catch (err: any) {\n      console.error(\"Error fetching analytics:\", err);\n      setError(err.message || \"Decentralized telemetry coupling timed out.\");\n    } finally {\n      setLoading(false);\n    }\n  }, [router]);\n\n  useEffect(() => {\n    fetchAnalytics();\n  }, [fetchAnalytics]);\n\n  // Periodic updates to the live stream\n  useEffect(() => {\n    const interval = setInterval(() => {\n      setDataPoints(prev => {\n        const nextVal = Math.min(100, Math.max(20, prev[prev.length - 1] + (Math.floor(Math.random() * 14) - 7)));\n        return [...prev.slice(1), nextVal];\n      });\n    }, 1500);\n    return () => clearInterval(interval);\n  }, []);\n\n  if (loading) {\n    return (\n      <div className=\"space-y-6\">\n        <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n          <div>\n            <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n            <p className=\"text-xs text-white/50 mt-1\">Establishing handshakes with cloud enclave registers...</p>\n          </div>\n          <RefreshCw className=\"w-5 h-5 text-[#009DFF] animate-spin\" />\n        </div>\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {[1, 2, 3, 4, 5, 6].map((idx) => (\n            <WorkspaceCard key={idx} className=\"h-40 border border-white/5 bg-[#050505]/20 p-5 rounded-xl space-y-4 animate-pulse\">\n              <div className=\"h-4 bg-white/5 rounded w-1/3\" />\n              <div className=\"h-8 bg-white/5 rounded w-1/4\" />\n              <div className=\"space-y-2\">\n                <div className=\"h-3 bg-white/5 rounded w-full\" />\n                <div className=\"h-3 bg-white/5 rounded w-2/3\" />\n              </div>\n            </WorkspaceCard>\n          ))}\n        </div>\n      </div>\n    );\n  }\n\n  if (error) {\n    return (\n      <div className=\"space-y-6\">\n        <div className=\"border-b border-white/5 pb-4\">\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Workloads and decentralized performance tracing.</p>\n        </div>\n        <WorkspaceCard className=\"p-8 border border-red-500/10 bg-red-950/5 rounded-2xl flex flex-col items-center justify-center text-center space-y-4 max-w-lg mx-auto my-12\">\n          <div className=\"p-3 rounded-full bg-red-500/10 border border-red-500/20 text-red-400\">\n            <AlertTriangle className=\"w-8 h-8 animate-pulse\" />\n          </div>\n          <div className=\"space-y-1.5 font-mono\">\n            <h4 className=\"text-white font-bold uppercase text-[14px]\">TELEMETRY HANDSHAKE FAILED</h4>\n            <p className=\"text-white/50 text-[11px] leading-relaxed\">{error}</p>\n          </div>\n          <button\n            onClick={fetchAnalytics}\n            className=\"h-9 px-6 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white font-mono font-bold text-[11px] uppercase cursor-pointer flex items-center gap-2 transition-all\"\n          >\n            <RefreshCw className=\"w-3.5 h-3.5\" />\n            <span>RE-ESTABLISH COUPLING</span>\n          </button>\n        </WorkspaceCard>\n      </div>\n    );\n  }\n\n  const s = data?.summary;\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Page Header */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50 mt-1\">Real-time thread spends, hardware workloads, and eBPF network pings.</p>\n        </div>\n        <div className=\"flex items-center gap-3\">\n          <span className=\"text-[10px] font-mono text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-1 rounded uppercase tracking-wider animate-pulse flex items-center gap-1.5\">\n            <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400\" />\n            Live telemetry coupling active\n          </span>\n          <button \n            onClick={fetchAnalytics}\n            className=\"h-8 px-3 rounded bg-white/5 hover:bg-white/10 text-[10px] font-bold uppercase text-white border border-white/10 transition-all flex items-center gap-1.5 cursor-pointer\"\n          >\n            <RefreshCw className=\"w-3.5 h-3.5\" />\n            <span>Sync Stats</span>\n          </button>\n        </div>\n      </div>\n\n      {/* Top Section: Live CPU Stream & Latencies */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <Activity className=\"w-5 h-5 text-[#009DFF]\" />\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Enclave CPU Load Stream</h3>\n            </div>\n            <span className=\"text-[9px] font-mono text-emerald-400 font-bold bg-emerald-400/5 border border-emerald-400/20 px-2 py-0.5 rounded-full uppercase tracking-wider animate-pulse\">\n              LIVE BROADCAST\n            </span>\n          </div>\n\n          <div className=\"h-32 flex items-end justify-between gap-1 bg-black/40 border border-white/5 rounded-xl p-4 relative\">\n            <svg className=\"absolute inset-x-0 bottom-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path\n                d={`M ${dataPoints.map((val, idx) => `${idx * 55}, ${112 - (val * 0.9)}`).join(\" L \")}`}\n                fill=\"none\"\n                stroke=\"#009DFF\"\n                strokeWidth=\"2.5\"\n                className=\"transition-all duration-500 ease-in-out\"\n              />\n              <circle\n                cx=\"500\"\n                cy={112 - (dataPoints[dataPoints.length - 1] * 0.9)}\n                r=\"4\"\n                className=\"fill-[#009DFF]\"\n              />\n            </svg>\n            <div className=\"absolute top-3 left-3 text-[10px] font-mono text-white/20 select-none\">\n              Mean Sandbox CPU: {dataPoints[dataPoints.length - 1]}%\n            </div>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-1.5 border-b border-white/5 pb-2\">\n            <Cpu className=\"w-5 h-5 text-[#009DFF]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase tracking-wider\">Network Latencies</h3>\n          </div>\n          \n          <div className=\"space-y-2 font-mono text-[11px] text-white/60\">\n            {[\n              { hash: \"f3a8b291c9\", label: \"Singapore Zone A\", ping: \"4ms\" },\n              { hash: \"e88d123880\", label: \"London Zone C\", ping: \"3ms\" },\n              { hash: \"a01fe99211\", label: \"Local Enclave Mesh\", ping: \"5ms\" }\n            ].map((node) => (\n              <div key={node.hash} className=\"flex justify-between border-b border-white/5 pb-2 last:border-b-0 last:pb-0\">\n                <div>\n                  <span className=\"text-white block font-bold\">{node.label}</span>\n                  <span className=\"text-[9px] text-[#009DFF]/60 block\">{node.hash}</span>\n                </div>\n                <span className=\"text-emerald-400 font-bold text-xs\">{node.ping}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Sovereign Node Summary Bento Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        \n        {/* Enclave Sanboxes (Projects) */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-2\">\n                <Layers className=\"w-4 h-4 text-[#009DFF]\" />\n                <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">Sandbox Enclaves</h4>\n              </div>\n              <span className=\"text-[9px] font-mono text-[#009DFF] border border-[#009DFF]/20 bg-[#009DFF]/5 px-1.5 py-0.2 rounded font-bold uppercase\">Active</span>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">Dynamic secure containers partition registers.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono mt-2\">\n            <span className=\"text-3xl font-bold text-white\">{s?.projects?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Total Registered</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 space-y-2\">\n            <div className=\"flex justify-between text-[10px] font-mono text-white/40\">\n              <span>Phases Mapping</span>\n              <span className=\"text-white\">Garage / Foundry / Factory / Operate</span>\n            </div>\n            <div className=\"flex gap-1 h-1.5 w-full bg-white/5 rounded-full overflow-hidden\">\n              <div className=\"bg-[#009DFF] rounded-full\" style={{ width: `${((s?.projects?.byPhase?.planning || s?.projects?.byPhase?.Garage || 0) / (s?.projects?.totalCount || 1)) * 100}%` }} title=\"Garage Planning\" />\n              <div className=\"bg-purple-500 rounded-full\" style={{ width: `${((s?.projects?.byPhase?.provisioning || s?.projects?.byPhase?.Foundry || 0) / (s?.projects?.totalCount || 1)) * 100}%` }} title=\"Foundry Provisioning\" />\n              <div className=\"bg-pink-500 rounded-full\" style={{ width: `${((s?.projects?.byPhase?.alignment || s?.projects?.byPhase?.Factory || 0) / (s?.projects?.totalCount || 1)) * 100}%` }} title=\"Factory Alignment\" />\n              <div className=\"bg-[#00FFC2] rounded-full\" style={{ width: `${((s?.projects?.byPhase?.production || s?.projects?.byPhase?.Operate || 0) / (s?.projects?.totalCount || 1)) * 100}%` }} title=\"Operate Live\" />\n            </div>\n            <div className=\"flex justify-between text-[9px] font-mono text-white/30 pt-0.5\">\n              <span>Stable Core: {s?.projects?.byStatus?.active || 0}</span>\n              <span>Pending Hubs: {s?.projects?.byStatus?.pending || 0}</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        {/* AI Operations */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-2\">\n                <Cpu className=\"w-4 h-4 text-purple-400\" />\n                <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">AI Guardrail Operations</h4>\n              </div>\n              <span className=\"text-[9px] font-mono text-emerald-400 border border-emerald-400/20 bg-emerald-400/5 px-1.5 py-0.2 rounded font-bold uppercase\">Healthy</span>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">Running model streams and safety boundaries.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono mt-2\">\n            <span className=\"text-3xl font-bold text-white\">{s?.aiOperations?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Total Workloads</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 space-y-1 text-[10px] font-mono\">\n            <div className=\"flex justify-between border-b border-white/5 pb-1\">\n              <span className=\"text-white/40\">Healthy States:</span>\n              <span className=\"text-emerald-400 font-bold\">{s?.aiOperations?.byHealth?.healthy || s?.aiOperations?.byHealth?.Active || 0}</span>\n            </div>\n            <div className=\"flex justify-between pt-1\">\n              <span className=\"text-white/40\">Suspended / Alert:</span>\n              <span className=\"text-amber-400 font-bold\">{s?.aiOperations?.byHealth?.warning || s?.aiOperations?.byHealth?.Paused || 0}</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        {/* Governance & Risks */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center justify-between\">\n              <div className=\"flex items-center gap-2\">\n                <ShieldCheck className=\"w-4 h-4 text-[#00FFC2]\" />\n                <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">Compliance Guardrails</h4>\n              </div>\n              <span className=\"text-[9px] font-mono text-amber-500 border border-amber-500/20 bg-amber-500/5 px-1.5 py-0.2 rounded font-bold uppercase\">Audited</span>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">ISO-27001, SOC2, and custom policy rulesets.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono mt-2\">\n            <span className=\"text-3xl font-bold text-white\">{s?.governance?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Active Ledger Rules</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 space-y-1 text-[10px] font-mono\">\n            <div className=\"flex justify-between border-b border-white/5 pb-1\">\n              <span className=\"text-white/40\">Remediated / OK:</span>\n              <span className=\"text-emerald-400 font-bold\">{s?.governance?.byStatus?.remediated || s?.governance?.byStatus?.compliant || s?.governance?.byStatus?.Active || 0}</span>\n            </div>\n            <div className=\"flex justify-between pt-1\">\n              <span className=\"text-white/40\">Critical / High Severity:</span>\n              <span className=\"text-rose-500 font-bold\">{s?.governance?.bySeverity?.Critical || s?.governance?.bySeverity?.High || s?.governance?.bySeverity?.high || 0}</span>\n            </div>\n          </div>\n        </WorkspaceCard>\n\n        {/* Compliance Vault */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center gap-2\">\n              <Lock className=\"w-4 h-4 text-[#00FFC2]\" />\n              <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">Secure Vault Documents</h4>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">Cryptographically signed system blueprints & audits.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono\">\n            <span className=\"text-3xl font-bold text-white\">{s?.documents?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Verified Artifacts</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 flex justify-between text-[10px] font-mono\">\n            <span className=\"text-white/40\">Audit Cleared:</span>\n            <span className=\"text-emerald-400 font-bold\">{s?.documents?.byStatus?.Verified || s?.documents?.byStatus?.verified || s?.documents?.byStatus?.approved || 0} Active</span>\n          </div>\n        </WorkspaceCard>\n\n        {/* Financial Workloads */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center gap-2\">\n              <Landmark className=\"w-4 h-4 text-emerald-400\" />\n              <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">Financial Transactions</h4>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">Platform billing cycles & invoice registries.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono\">\n            <span className=\"text-3xl font-bold text-white\">{s?.invoices?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Active Ledgers</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 flex justify-between text-[10px] font-mono\">\n            <span className=\"text-white/40\">Paid status:</span>\n            <span className=\"text-emerald-400 font-bold\">{s?.invoices?.byStatus?.Paid || s?.invoices?.byStatus?.paid || 0} Complete</span>\n          </div>\n        </WorkspaceCard>\n\n        {/* Support Interlock */}\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl space-y-4 flex flex-col justify-between\">\n          <div className=\"space-y-1.5\">\n            <div className=\"flex items-center gap-2\">\n              <MessageSquare className=\"w-4 h-4 text-[#009DFF]\" />\n              <h4 className=\"text-xs font-mono font-bold text-white uppercase tracking-wider\">Sovereign Architect Support</h4>\n            </div>\n            <p className=\"text-[11px] text-white/50 font-mono\">Direct secure pipeline communication channels.</p>\n          </div>\n          <div className=\"flex items-baseline gap-2 font-mono\">\n            <span className=\"text-3xl font-bold text-white\">{s?.support?.totalCount || 0}</span>\n            <span className=\"text-[11px] text-white/40\">Active Inquiries</span>\n          </div>\n          <div className=\"pt-2 border-t border-white/5 mt-3 flex justify-between text-[10px] font-mono\">\n            <span className=\"text-white/40\">P1 Urgent Criticals:</span>\n            <span className=\"text-rose-500 font-bold\">{s?.support?.byPriority?.P1 || s?.support?.byPriority?.high || 0} Pending</span>\n          </div>\n        </WorkspaceCard>\n\n      </div>\n    </div>\n  );\n}"}}}
