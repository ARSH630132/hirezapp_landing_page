5\"><Cpu className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Zones</span>\n          <div className=\"space-y-1.5 text-[9px] text-white/60 mt-2\">\n            {[{ l: \"Singapore A\", p: \"4ms\" }, { l: \"London C\", p: \"3ms\" }].map((n, i) => (\n              <div key={i} className=\"flex justify-between border-b border-white/5 pb-1\"><span>{n.l}</span><span className=\"text-emerald-400 font-bold\">{n.p}</span></div>\n            ))}\n          </div>\n        </div>\n      </div>\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[100px]\">\n          <span className=\"text-[9px] font-bold uppercase flex items-center gap-1.5\"><Layers className=\"w-3 h-3 text-[#009DFF]\" /> Enclaves</span>\n          <span className=\"text-xl font-bold\">{data?.projects?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/40\">Active: {data?.projects?.byStatus?.active || 0}</span>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[100px]\">\n          <span className=\"text-[9px] font-bold uppercase flex items-center gap-1.5\"><Cpu className=\"w-3 h-3 text-purple-400\" /> AI Operations</span>\n          <span className=\"text-xl font-bold\">{data?.aiOperations?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/40\">Healthy: {data?.aiOperations?.byHealth?.healthy || 0}</span>\n        </WorkspaceCard>\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-4 rounded-xl flex flex-col justify-between h-[100px]\">\n          <span className=\"text-[9px] font-bold uppercase flex items-center gap-1.5\"><ShieldCheck className=\"w-3 h-3 text-[#00FFC2]\" /> Compliance</span>\n          <span className=\"text-xl font-bold\">{data?.governance?.totalCount || 0}</span>\n          <span className=\"text-[8px] text-white/40\">Active Rules</span>\n        </WorkspaceCard>\n      </div>\n    </div>\n  );\n}"}}}
