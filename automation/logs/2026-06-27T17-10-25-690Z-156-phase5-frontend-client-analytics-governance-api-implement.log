{"ts":"2026-06-27T17:06:40.073Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"znq9w437","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/analytics/page.tsx","new_text":"\"use client\";\nimport React, { useState, useEffect, useCallback } from \"react\";\nimport { useRouter } from \"next/navigation\";\nimport { RefreshCw, Cpu, Activity, ShieldCheck, Layers } from \"lucide-react\";\nimport { WorkspaceCard } from \"@/components/private-app\";\n\nexport default function ClientAnalyticsPage() {\n  const router = useRouter();\n  const [data, setData] = useState<any>(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState<string | null>(null);\n  const [pts, setPts] = useState([35, 42, 38, 48, 52, 45, 58, 62, 59, 64]);\n\n  const load = useCallback(async () => {\n    setLoading(true);\n    setError(null);\n    try {\n      const token = typeof window !== \"undefined\" ? localStorage.getItem(\"gff_ai_access_token\") : null;\n      if (!token) {\n        setError(\"AUTHENTICATION EXPIRED.\");\n        router.push(\"/portal/login\");\n        return;\n      }\n      const r = await fetch(\"/api/v1/analytics/client\", {\n        headers: { \"Authorization\": `Bearer ${token}` }\n      });\n      if (!r.ok) throw new Error(`Telemetry failed: ${r.status}`);\n      const d = await r.json();\n      if (d.success && d.summary) setData(d.summary);\n      else throw new Error(\"Malformed telemetry registry.\");\n    } catch (err: any) {\n      setError(err.message || \"Telemetry handshake failed.\");\n    } finally {\n      setLoading(false);\n    }\n  }, [router]);\n\n  useEffect(() => {\n    load();\n    const t = setInterval(() => {\n      setPts(prev => {\n        const next = Math.min(100, Math.max(20, prev[prev.length - 1] + Math.floor(Math.random() * 14) - 7));\n        return [...prev.slice(1), next];\n      });\n    }, 1500);\n    return () => clearInterval(t);\n  }, [load]);\n\n  if (loading) return (\n    <div className=\"space-y-6 font-mono p-4 text-white\">\n      <div className=\"flex justify-between items-center\"><span className=\"text-sm font-bold uppercase animate-pulse\">Coupling Telemetry...</span><RefreshCw className=\"w-4 h-4 animate-spin text-[#009DFF]\" /></div>\n    </div>\n  );\n\n  if (error) return (\n    <WorkspaceCard className=\"p-8 border border-red-500/10 bg-red-950/5 text-center max-w-md mx-auto my-12 font-mono\">\n      <h4 className=\"text-white font-bold uppercase text-xs\">Sync Failed</h4>\n      <p className=\"text-white/50 text-[10px] my-3\">{error}</p>\n      <button onClick={load} className=\"mx-auto h-8 px-4 rounded bg-white/5 text-white font-bold text-[10px] uppercase flex items-center gap-1.5\"><RefreshCw className=\"w-3 h-3\" /> Re-sync</button>\n    </WorkspaceCard>\n  );\n\n  return (\n    <div className=\"space-y-6 font-mono text-white\">\n      <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-lg font-bold uppercase\">Telemetry Analytics</h2>\n          <p className=\"text-xs text-white/50\">Real-time thread spends and hardware workloads.</p>\n        </div>\n        <button onClick={load} className=\"h-7 px-3 rounded bg-white/5 hover:bg-white/10 text-[10px] border border-white/10 flex items-center gap-1\"><RefreshCw className=\"w-3 h-3\" /> Sync</button>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 space-y-4\">\n          <div className=\"flex justify-between items-center pb-2 border-b border-white/5\">\n            <span className=\"text-xs font-bold uppercase flex items-center gap-1.5\"><Activity className=\"w-4 h-4 text-[#009DFF]\" /> Enclave CPU</span>\n            <span className=\"text-[8px] text-emerald-400 font-bold\">LIVE BROADCAST</span>\n          </div>\n          <div className=\"h-28 flex items-end justify-between bg-black/40 border border-white/5 rounded-lg p-3 relative\">\n            <svg className=\"absolute inset-x-0 bottom-0 h-full w-full pointer-events-none\" viewBox=\"0 0 500 120\" preserveAspectRatio=\"none\">\n              <path d={`M ${pts.map((v, i) => `${i * 55}, ${112 - (v * 0.9)}`).join(\" L \")}`} fill=\"none\" stroke=\"#009DFF\" strokeWidth=\"2\" />\n            </svg>\n            <span className=\"absolute top-2 left-2 text-[9px] text-white/30\">Mean: {pts[pts.length - 1]}%</span>\n          </div>\n        </div>\n\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n          <span className=\"text-xs font-bold uppercase flex items-center gap-1.5\"><Cpu className=\"w-4 h-4 text-[#009DFF]\" /> Latencies</span>\n          <div className=\"space-y-2 text-[10px] text-white/60\">\n            {[{ l: \"Singapore Zone A\", p: \"4ms\" }, { l: \"London Zone C\", p: \"3ms\" }, { l: \"Local Enclave\", p: \"5ms\" }].map((n, i) => (\n              <div key={i} className=\"flex justify-between border-b border-white/5 pb-1.5 last:pb-0 last:border-b-0\">\n                <span>{n.l}</span>\n                <span className=\"text-emerald-400 font-bold\">{n.p}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl flex flex-col justify-between h-[120px]\">\n          <span className=\"text-[10px] font-bold uppercase flex items-center gap-1.5\"><Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" /> Sandbox Enclaves</span>\n          <span className=\"text-2xl font-bold\">{data?.projects?.totalCount || 0}</span>\n          <span className=\"text-[9px] text-white/40\">Active: {data?.projects?.byStatus?.active || 0}</span>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl flex flex-col justify-between h-[120px]\">\n          <span className=\"text-[10px] font-bold uppercase flex items-center gap-1.5\"><Cpu className=\"w-3.5 h-3.5 text-purple-400\" /> AI Operations</span>\n          <span className=\"text-2xl font-bold\">{data?.aiOperations?.totalCount || 0}</span>\n          <span className=\"text-[9px] text-white/40\">Healthy: {data?.aiOperations?.byHealth?.healthy || data?.aiOperations?.byHealth?.Active || 0}</span>\n        </WorkspaceCard>\n\n        <WorkspaceCard className=\"border border-white/5 bg-[#050505]/30 p-5 rounded-xl flex flex-col justify-between h-[120px]\">\n          <span className=\"text-[10px] font-bold uppercase flex items-center gap-1.5\"><ShieldCheck className=\"w-3.5 h-3.5 text-[#00FFC2]\" /> Compliance Rules</span>\n          <span className=\"text-2xl font-bold\">{data?.governance?.totalCount || 0}</span>\n          <span className=\"text-[9px] text-white/40\">Compliant: {data?.governance?.byStatus?.remediated || data?.governance?.byStatus?.compliant || data?.governance?.byStatus?.Active || 0}</span>\n        </WorkspaceCard>\n      </div>\n    </div>\n  );\n}"}}}
