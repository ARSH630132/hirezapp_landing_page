{"ts":"2026-06-27T05:05:26.039Z","type":"agent_event","event":{"type":"content_end","contentType":"reasoning","reasoning":"**Investigating Character Count**\n\nOkay, so I got this warning about `new_text` being way over the recommended character limit. I thought it was around 21,000, but the tool says over 51,000! Time to dive back into the code and see where that character bloat is coming from. Something's clearly getting appended that shouldn't be.\n\n\n**Refining Draft Conciseness**\n\nI've made a crucial discovery: my initial draft was far too verbose. It ballooned to roughly 750 lines. The original file, when I replace or overwrite it, was 135 lines of code, or about 6000 characters. I'm now actively working on a significantly more concise version, aiming to keep it under that original file size, while still satisfying the two key requirements: a ticket list and a frontend-only form for ticket creation. The goal is maintain excellent layout.\n\n\n"}}
{"ts":"2026-06-27T05:05:26.044Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"e5mh54a1","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/portal/support/page.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useMemo } from \"react\";\nimport { \n  MessageSquare, Plus, Search, Filter, Calendar, Clock, Send, \n  CheckCircle, AlertTriangle, X, Terminal, Layers, Activity, ShieldCheck, \n  ShieldAlert, ArrowLeft, Cpu\n} from \"lucide-react\";\nimport { PrivatePageHeader } from \"@/components/private-app/page-header\";\nimport { previewProjects } from \"@/lib/mock-data-model\";\n\ninterface Ticket {\n  id: string;\n  title: string;\n  status: \"open\" | \"in_progress\" | \"resolved\";\n  priority: \"critical\" | \"high\" | \"medium\" | \"low\";\n  category: \"Project Delivery\" | \"AI Operations\" | \"Billing\" | \"Documents\" | \"Access\" | \"Governance\" | \"General\";\n  project: string;\n  createdAt: string;\n  desc: string;\n  replies: { sender: string; text: string; timestamp: string }[];\n}\n\nconst INITIAL_TICKETS: Ticket[] = [\n  {\n    id: \"SLA-9912\",\n    title: \"Secure HSM Key Rotation Interlock Delayed\",\n    status: \"open\",\n    priority: \"critical\",\n    category: \"AI Operations\",\n    project: \"Sovereign Core Sandbox 02\",\n    createdAt: \"2026-06-27T10:15:00Z\",\n    desc: \"Enclave hardware is reporting socket timeout while performing automatic HSM roll-key rotation with Sovereign Core Sandbox 02. Expected timeout in 45 minutes.\",\n    replies: [\n      { sender: \"Alexander Mercer\", text: \"Initiated automated rotation but the ledger remains uncommitted.\", timestamp: \"2026-06-27T10:15:00Z\" },\n      { sender: \"Dr. Sarah Vance (Admin)\", text: \"Analyzing cryptographic enclave stream. Standby, we will sign handshakes.\", timestamp: \"2026-06-27T10:25:00Z\" }\n    ]\n  },\n  {\n    id: \"SLA-9801\",\n    title: \"Thread Load Allocation Exceeding Normal Boundaries\",\n    status: \"in_progress\",\n    priority: \"high\",\n    category: \"AI Operations\",\n    project: \"Model Guardrail Sandbox 04\",\n    createdAt: \"2026-06-27T07:18:00Z\",\n    desc: \"Node MED-CLINIC-H9 CPU utilization hit 94.5% during diagnostic prompt scan lifecycle.\",\n    replies: [\n      { sender: \"Evelyn Carter\", text: \"The threat mapping thread is locked in an infinite evaluation state.\", timestamp: \"2026-06-27T07:18:00Z\" }\n    ]\n  },\n  {\n    id: \"SLA-9450\",\n    title: \"SOC2 Compliance Report Signoff Complete\",\n    status: \"resolved\",\n    priority: \"medium\",\n    category: \"Governance\",\n    project: \"Federal Ledger Enclave Alpha\",\n    createdAt: \"2026-06-25T11:40:00Z\",\n    desc: \"Audit check complete on all active sandbox namespaces. No policy violations detected across 10,000 transactions.\",\n    replies: []\n  }\n];\n\nexport default function ClientSupportPage() {\n  const [tickets, setTickets] = useState<Ticket[]>(INITIAL_TICKETS);\n  const [activeId, setActiveId] = useState(\"SLA-9912\");\n  const [search, setSearch] = useState(\"\");\n  const [filterPriority, setFilterPriority] = useState(\"All\");\n  const [filterCategory, setFilterCategory] = useState(\"All\");\n  const [filterProject, setFilterProject] = useState(\"All\");\n  const [filterStatus, setFilterStatus] = useState(\"All\");\n\n  const [isCreateMode, setIsCreateMode] = useState(false);\n  const [subject, setSubject] = useState(\"\");\n  const [desc, setDesc] = useState(\"\");\n  const [priority, setPriority] = useState<any>(\"high\");\n  const [category, setCategory] = useState<any>(\"AI Operations\");\n  const [project, setProject] = useState(\"Sovereign Core Sandbox 02\");\n  \n  const [replyText, setReplyText] = useState(\"\");\n  const [mobileTab, setMobileTab] = useState<\"list\" | \"detail\" | \"create\">(\"list\");\n  const [toast, setToast] = useState(\"\");\n\n  const filtered = useMemo(() => {\n    return tickets.filter(t => {\n      const matchesSearch = t.title.toLowerCase().includes(search.toLowerCase()) || t.id.toLowerCase().includes(search.toLowerCase());\n      const matchesPrio = filterPriority === \"All\" || t.priority === filterPriority.toLowerCase();\n      const matchesCat = filterCategory === \"All\" || t.category === filterCategory;\n      const matchesProj = filterProject === \"All\" || t.project === filterProject;\n      const matchesStat = filterStatus === \"All\" || t.status === filterStatus.toLowerCase();\n      return matchesSearch && matchesPrio && matchesCat && matchesProj && matchesStat;\n    });\n  }, [tickets, search, filterPriority, filterCategory, filterProject, filterStatus]);\n\n  const active = useMemo(() => {\n    return tickets.find(t => t.id === activeId) || filtered[0] || tickets[0] || null;\n  }, [tickets, activeId, filtered]);\n\n  const handleCreate = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!subject.trim() || !desc.trim()) return;\n    const newId = `SLA-${Math.floor(1000 + Math.random() * 9000)}`;\n    const newTkt: Ticket = {\n      id: newId, title: subject, status: \"open\", priority, category, project,\n      createdAt: new Date().toISOString(), desc, replies: []\n    };\n    setTickets([newTkt, ...tickets]);\n    setActiveId(newId);\n    setSubject(\"\"); setDesc(\"\"); setIsCreateMode(false);\n    setToast(`Wire channel ${newId} initialized successfully.`);\n    setMobileTab(\"detail\");\n    setTimeout(() => setToast(\"\"), 4000);\n  };\n\n  const handleAddReply = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!replyText.trim() || !active) return;\n    setTickets(tickets.map(t => t.id === active.id ? {\n      ...t, status: t.status === \"resolved\" ? \"in_progress\" : t.status,\n      replies: [...t.replies, { sender: \"Client Operator\", text: replyText, timestamp: new Date().toISOString() }]\n    } : t));\n    setReplyText(\"\");\n  };\n\n  return (\n    <div className=\"space-y-6 max-w-[1600px] mx-auto pb-10 select-none\">\n      <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl px-4 py-2.5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 font-mono text-[11px]\">\n        <div className=\"flex items-center gap-2 text-white/70\">\n          <ShieldAlert className=\"w-4 h-4 text-[#009DFF] shrink-0\" />\n          <span><strong className=\"text-white\">ENCLAVE DESK:</strong> Active telemetry interlock is cryptographically isolated and secure.</span>\n        </div>\n        <span className=\"text-[9px] text-emerald-400 font-bold bg-emerald-500/10 border border-emerald-500/20 px-2 py-0.5 rounded uppercase font-mono tracking-wider shrink-0\">\n          L3 SECURE SOCKET Active\n        </span>\n      </div>\n\n      <PrivatePageHeader\n        title=\"Secure Support Command\"\n        desc=\"Communicate directly with systems engineers through hardware-isolated zero-trust tunnels.\"\n        badgeLabel=\"SLA Active Desk\"\n        actions={\n          <button\n            onClick={() => { setIsCreateMode(!isCreateMode); setMobileTab(isCreateMode ? \"list\" : \"create\"); }}\n            className=\"inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 px-4 text-[11px] font-mono font-bold text-white transition-all cursor-pointer\"\n          >\n            {isCreateMode ? <><ArrowLeft className=\"w-3.5 h-3.5 text-[#009DFF]\" /><span>VIEW WIRE FEED</span></> : <><Plus className=\"w-3.5 h-3.5 text-[#009DFF]\" /><span>LAUNCH WIRE TUNNEL</span></>}\n          </button>\n        }\n      />\n\n      {/* METRIC TILES */}\n      <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4 font-mono\">\n        <div className=\"p-4 bg-[#050505]/40 border border-white/5 rounded-xl\">\n          <span className=\"text-[9.5px] text-white/40 uppercase block\">Active Channels</span>\n          <span className=\"text-xl font-bold text-white block mt-1\">{tickets.filter(t => t.status !== \"resolved\").length} Open</span>\n        </div>\n        <div className=\"p-4 bg-[#050505]/40 border border-white/5 rounded-xl\">\n          <span className=\"text-[9.5px] text-white/40 uppercase block\">Dispatch SLA Speed</span>\n          <span className=\"text-xl font-bold text-amber-400 block mt-1\">12.4 mins</span>\n        </div>\n        <div className=\"p-4 bg-[#050505]/40 border border-white/5 rounded-xl\">\n          <span className=\"text-[9.5px] text-white/40 uppercase block\">Tunnel Standards</span>\n          <span className=\"text-xl font-bold text-emerald-400 block mt-1\">ISO-27001</span>\n        </div>\n        <div className=\"p-4 bg-[#050505]/40 border border-white/5 rounded-xl\">\n          <span className=\"text-[9.5px] text-white/40 uppercase block\">Threat Index</span>\n          <span className=\"text-xl font-bold text-white block mt-1\">Nominal</span>\n        </div>\n      </div>\n\n      {toast && (\n        <div className=\"border border-emerald-500/20 bg-emerald-500/10 rounded-xl px-4 py-2.5 text-white font-mono text-xs text-left\">\n          ✔ {toast}\n        </div>\n      )}\n\n      {/* FILTER BAR */}\n      <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/20 space-y-3\">\n        <div className=\"flex items-center justify-between border-b border-white/5 pb-2 text-[10px] font-mono uppercase text-white/50 font-bold tracking-widest\">\n          <span>Diagnostic Filter Matrix</span>\n          <button onClick={() => { setSearch(\"\"); setFilterPriority(\"All\"); setFilterCategory(\"All\"); setFilterProject(\"All\"); setFilterStatus(\"All\"); }} className=\"text-[#009DFF] hover:underline normal-case font-normal\">Reset Filters</button>\n        </div>\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3\">\n          <input\n            type=\"text\"\n            placeholder=\"Search secure wire telemetry...\"\n            value={search}\n            onChange={(e) => setSearch(e.target.value)}\n            className=\"h-9 px-3 rounded-lg border border-white/10 bg-black/40 text-white text-[11.5px] font-mono focus:border-[#009DFF]/30 outline-none placeholder:text-white/20\"\n          />\n          <select value={filterPriority} onChange={(e) => setFilterPriority(e.target.value)} className=\"h-9 px-3 rounded-lg border border-white/10 bg-black/40 text-white text-[11.5px] font-mono focus:border-[#009DFF]/30 outline-none\">\n            <option value=\"All\">ALL PRIORITIES</option>\n            <option value=\"Critical\">CRITICAL</option>\n            <option value=\"High\">HIGH</option>\n            <option value=\"Medium\">MEDIUM</option>\n            <option value=\"Low\">LOW</option>\n          </select>\n          <select value={filterCategory} onChange={(e) => setFilterCategory(e.target.value)} className=\"h-9 px-3 rounded-lg border border-white/10 bg-black/40 text-white text-[11.5px] font-mono focus:border-[#009DFF]/30 outline-none\">\n            <option value=\"All\">ALL CATEGORIES</option>\n            <option value=\"Project Delivery\">Project Delivery</option>\n            <option value=\"AI Operations\">AI Operations</option>\n            <option value=\"Billing\">Billing</option>\n            <option value=\"Documents\">Documents</option>\n            <option value=\"Access\">Access</option>\n            <option value=\"Governance\">Governance</option>\n            <option value=\"General\">General</option>\n          </select>\n          <select value={filterProject} onChange={(e) => setFilterProject(e.target.value)} className=\"h-9 px-3 rounded-lg border border-white/10 bg-black/40 text-white text-[11.5px] font-mono focus:border-[#009DFF]/30 outline-none\">\n            <option value=\"All\">ALL PROJECTS</option>\n            <option value=\"Sovereign Core Sandbox 02\">Sovereign Core Sandbox 02</option>\n            <option value=\"Model Guardrail Sandbox 04\">Model Guardrail Sandbox 04</option>\n            <option value=\"Sovereign Mining Intel Loop\">Sovereign Mining Intel Loop</option>\n            <option value=\"Federal Ledger Enclave Alpha\">Federal Ledger Enclave Alpha</option>\n          </select>\n          <select value={filterStatus} onChange={(e) => setFilterStatus(e.target.value)} className=\"h-9 px-3 rounded-lg border border-white/10 bg-black/40 text-white text-[11.5px] font-mono focus:border-[#009DFF]/30 outline-none\">\n            <option value=\"All\">ALL STATUSES</option>\n            <option value=\"Open\">OPEN</option>\n            <option value=\"In Progress\">IN PROGRESS</option>\n            <option value=\"Resolved\">RESOLVED</option>\n          </select>\n        </div>\n      </div>\n\n      {/* MOBILE SEGMENT */}\n      <div className=\"flex lg:hidden bg-white/[0.02] border border-white/5 rounded-xl p-1 gap-1\">\n        <button onClick={() => { setMobileTab(\"list\"); setIsCreateMode(false); }} className={`flex-1 py-1.5 rounded-lg text-center font-mono text-[10px] font-bold uppercase ${mobileTab === \"list\" ? \"bg-white/10 text-white\" : \"text-white/40\"}`}>Feed ({filtered.length})</button>\n        <button onClick={() => { setMobileTab(\"detail\"); setIsCreateMode(false); }} disabled={!active} className={`flex-1 py-1.5 rounded-lg text-center font-mono text-[10px] font-bold uppercase ${mobileTab === \"detail\" ? \"bg-white/10 text-white\" : \"text-white/40 disabled:opacity-20\"}`}>Active Thread</button>\n        <button onClick={() => { setMobileTab(\"create\"); setIsCreateMode(true); }} className={`flex-1 py-1.5 rounded-lg text-center font-mono text-[10px] font-bold uppercase ${mobileTab === \"create\" ? \"bg-white/10 text-white\" : \"text-white/40\"}`}>Launch Wire</button>\n      </div>\n\n      {/* MAIN LAYOUT */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-start text-left\">\n        {/* LIST FEED */}\n        <div className={`lg:col-span-5 space-y-3 ${mobileTab === \"list\" ? \"block\" : \"hidden lg:block\"}`}>\n          <div className=\"text-xs font-mono font-bold text-white uppercase tracking-wider border-b border-white/5 pb-2\">Secured Wire Feed ({filtered.length})</div>\n          <div className=\"space-y-3.5 max-h-[600px] overflow-y-auto pr-1\">\n            {filtered.length === 0 ? (\n              <div className=\"p-8 text-center rounded-xl border border-white/5 bg-[#050505]/20 text-white/40 font-mono text-xs\">No active telemetry logs match filters.</div>\n            ) : (\n              filtered.map(t => {\n                const isSelected = t.id === activeId && !isCreateMode;\n                return (\n                  <div\n                    key={t.id}\n                    onClick={() => { setActiveId(t.id); setIsCreateMode(false); setMobileTab(\"detail\"); }}\n                    className={`p-4 rounded-xl border transition-all cursor-pointer font-mono text-[11.5px] relative ${isSelected ? \"bg-[#0c0c0c]/80 border-[#009DFF]/30 shadow-[0_0_15px_-3px_rgba(0,157,255,0.15)]\" : \"bg-[#050505]/40 border-white/5 hover:bg-[#0c0c0c]/40\"}`}\n                  >\n                    {isSelected && <div className=\"absolute left-0 top-0 bottom-0 w-1 bg-[#009DFF]\" />}\n                    <div className=\"flex justify-between items-start mb-2\">\n                      <span className=\"text-[9px] font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-1.5 py-0.5 rounded\">{t.id}</span>\n                      <span className={`text-[9px] font-bold uppercase px-1.5 py-0.5 rounded border ${t.priority === \"critical\" ? \"text-red-400 bg-red-400/10 border-red-400/20\" : t.priority === \"high\" ? \"text-amber-400 bg-amber-400/10 border-amber-400/20\" : \"text-blue-400 bg-blue-400/10 border-blue-400/20\"}`}>{t.priority}</span>\n                    </div>\n                    <h4 className=\"text-[12px] font-bold leading-snug mb-2 text-white\">{t.title}</h4>\n                    <div className=\"flex justify-between text-[9px] text-white/40 border-t border-white/5 pt-2\">\n                      <span className=\"truncate max-w-[150px]\">{t.project}</span>\n                      <span>● {t.status.toUpperCase()}</span>\n                    </div>\n                  </div>\n                );\n              })\n            )}\n          </div>\n        </div>\n\n        {/* DETAILS OR FORM */}\n        <div className={`lg:col-span-7 ${mobileTab !== \"list\" ? \"block\" : \"hidden lg:block\"}`}>\n          {isCreateMode ? (\n            <form onSubmit={handleCreate} className=\"p-5 md:p-6 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4 font-mono\">\n              <div className=\"flex justify-between border-b border-white/5 pb-3\">\n                <div>\n                  <h3 className=\"text-sm font-bold text-white uppercase tracking-wider\">Launch Support Wire</h3>\n                  <p className=\"text-[10px] text-white/40\">Secure hardware tunnel initialization</p>\n                </div>\n                <button type=\"button\" onClick={() => { setIsCreateMode(false); setMobileTab(\"list\"); }} className=\"p-1 hover:bg-white/5 rounded text-white/50\"><X className=\"w-4 h-4\" /></button>\n              </div>\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n                <div className=\"space-y-1\">\n                  <label className=\"text-[9px] text-white/40 uppercase\">Category</label>\n                  <select value={category} onChange={(e: any) => setCategory(e.target.value)} className=\"w-full h-9 rounded border border-white/10 bg-black text-[11px] outline-none\">\n                    <option value=\"Project Delivery\">Project Delivery</option>\n                    <option value=\"AI Operations\">AI Operations</option>\n                    <option value=\"Billing\">Billing</option>\n                    <option value=\"Documents\">Documents</option>\n                    <option value=\"Access\">Access</option>\n                    <option value=\"Governance\">Governance</option>\n                    <option value=\"General\">General</option>\n                  </select>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[9px] text-white/40 uppercase\">Priority Speed</label>\n                  <select value={priority} onChange={(e: any) => setPriority(e.target.value)} className=\"w-full h-9 rounded border border-white/10 bg-black text-[11px] outline-none\">\n                    <option value=\"critical\">P1 - Critical (15m)</option>\n                    <option value=\"high\">P2 - High (1h)</option>\n                    <option value=\"medium\">P3 - Medium (4h)</option>\n                    <option value=\"low\">P4 - Low (24h)</option>\n                  </select>\n                </div>\n                <div className=\"space-y-1\">\n                  <label className=\"text-[9px] text-white/40 uppercase\">Linked Enclave</label>\n                  <select value={project} onChange={(e) => setProject(e.target.value)} className=\"w-full h-9 rounded border border-white/10 bg-black text-[11px] outline-none\">\n                    <option value=\"Sovereign Core Sandbox 02\">Sovereign Core Sandbox 02</option>\n                    <option value=\"Model Guardrail Sandbox 04\">Model Guardrail Sandbox 04</option>\n                    <option value=\"Sovereign Mining Intel Loop\">Sovereign Mining Intel Loop</option>\n                    <option value=\"Federal Ledger Enclave Alpha\">Federal Ledger Enclave Alpha</option>\n                    <option value=\"General / Non-Project\">General / Non-Project</option>\n                  </select>\n                </div>\n              </div>\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] text-white/40 uppercase\">Subject Summary</label>\n                <input required placeholder=\"Enter diagnostic subject...\" value={subject} onChange={(e) => setSubject(e.target.value)} className=\"w-full h-9 px-3 rounded border border-white/10 bg-black text-[11.5px] outline-none text-white focus:border-[#009DFF]/30\" />\n              </div>\n              <div className=\"space-y-1\">\n                <label className=\"text-[9px] text-white/40 uppercase\">Detailed Diagnostics Telemetry Description</label>\n                <textarea required placeholder=\"Paste sandbox error codes or description...\" value={desc} onChange={(e) => setDesc(e.target.value)} className=\"w-full h-24 p-3 rounded border border-white/10 bg-black text-[11.5px] outline-none text-white resize-none focus:border-[#009DFF]/30\" />\n              </div>\n              <button type=\"submit\" className=\"w-full h-10 rounded bg-white text-black hover:bg-white/90 text-xs font-bold uppercase transition-all\">Establish Support Tunnel</button>\n            </form>\n          ) : active ? (\n            <div className=\"space-y-4 font-mono text-xs\">\n              <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 space-y-3\">\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-2.5\">\n                  <div>\n                    <span className=\"text-[9px] text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded\">{active.id}</span>\n                    <h3 className=\"text-sm font-bold text-white mt-1 leading-tight\">{active.title}</h3>\n                  </div>\n                  <span className={`text-[9px] font-bold uppercase px-2 py-0.5 rounded border ${active.status === \"open\" ? \"text-[#009DFF] border-[#009DFF]/20 bg-[#009DFF]/5\" : \"text-amber-400 border-amber-400/20\"}`}>{active.status}</span>\n                </div>\n                <div className=\"grid grid-cols-2 md:grid-cols-4 gap-2 text-[10.5px] text-white/70\">\n                  <div><span className=\"text-white/30 block text-[8px] uppercase\">Category</span><strong>{active.category}</strong></div>\n                  <div><span className=\"text-white/30 block text-[8px] uppercase\">Project</span><strong>{active.project}</strong></div>\n                  <div><span className=\"text-white/30 block text-[8px] uppercase\">TLS Security</span><strong className=\"text-emerald-400\">Secure TLS 1.3</strong></div>\n                  <div><span className=\"text-white/30 block text-[8px] uppercase\">Created</span><strong>{new Date(active.createdAt).toLocaleDateString()}</strong></div>\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <span className=\"text-[9px] text-white/30 uppercase font-bold tracking-widest block pl-1\">Diagnostics Telemetry Payload</span>\n                <div className=\"p-3.5 rounded-xl border border-white/5 bg-[#020202]/95 text-emerald-400 text-[11px] leading-relaxed whitespace-pre-wrap\">{active.desc}</div>\n              </div>\n\n              {/* HANDSHAKE TUNNEL METAPHOR */}\n              <div className=\"p-3 rounded-xl border border-white/5 bg-[#050505]/20 flex items-center justify-between text-[9px] text-white/40 select-none\">\n                <div className=\"flex items-center gap-1\"><Cpu className=\"w-3 h-3 text-[#009DFF]\" /><span>CLIENT NODE</span></div>\n                <div className=\"flex-1 border-t border-dashed border-white/10 mx-4 relative\"><span className=\"absolute -top-2 left-1/2 -translate-x-1/2 bg-black px-1.5 text-[8px] text-emerald-400 font-bold\">SECURE INTERLOCK ACTIVATED</span></div>\n                <div><span>GFF CORE DESK</span></div>\n              </div>\n\n              <div className=\"space-y-2\">\n                <span className=\"text-[9px] text-white/30 uppercase font-bold tracking-widest block pl-1\">Dialogue Logs</span>\n                <div className=\"space-y-2 max-h-[220px] overflow-y-auto pr-1\">\n                  {active.replies.length === 0 ? (\n                    <p className=\"text-[10px] text-white/20 italic p-3 border border-white/5 rounded-lg\">No message packets logged yet on this secure wire.</p>\n                  ) : (\n                    active.replies.map((r, i) => (\n                      <div key={i} className={`p-3 rounded-lg border text-[11px] ${r.sender.includes(\"Admin\") || r.sender.includes(\"Bot\") ? \"bg-[#0c0c0c]/90 border-[#009DFF]/10 ml-4\" : \"bg-[#050505]/40 border-white/5 mr-4\"}`}>\n                        <div className=\"flex justify-between text-[9.5px] text-white/40 mb-1\">\n                          <span className=\"font-bold text-[#009DFF]\">{r.sender}</span>\n                          <span>{new Date(r.timestamp).toLocaleTimeString([], { hour: \"2-digit\", minute: \"2-digit\" })}</span>\n                        </div>\n                        <p className=\"text-white/80 leading-relaxed\">{r.text}</p>\n                      </div>\n                    ))\n                  )}\n                </div>\n              </div>\n\n              <form onSubmit={handleAddReply} className=\"space-y-2\">\n                <textarea placeholder=\"Commit encrypted diagnostic message to systems thread...\" value={replyText} onChange={(e) => setReplyText(e.target.value)} className=\"w-full h-16 rounded-lg border border-white/10 bg-[#050505]/80 p-3 text-white text-[11px] outline-none focus:border-[#009DFF]/30 resize-none transition-all placeholder:text-white/20\" />\n                <div className=\"flex justify-between items-center text-[9px] text-white/30\">\n                  <span>AES-256 encrypted socket stream</span>\n                  <button type=\"submit\" disabled={!replyText.trim()} className=\"inline-flex h-8 items-center justify-center gap-1 rounded bg-white text-black px-3.5 font-bold hover:bg-white/90 disabled:opacity-30 transition-all\">\n                    <Send className=\"w-2.5 h-2.5 text-[#009DFF]\" /><span>SEND</span>\n                  </button>\n                </div>\n              </form>\n            </div>\n          ) : (\n            <div className=\"p-8 text-center rounded-xl border border-white/5 bg-[#050505]/20 text-white/40 font-mono text-xs\">Select a secure channel feed to view real-time operations.</div>\n          )}\n        </div>\n      </div>\n    </div>\n  );\n}\n"}}}
