{"ts":"2026-06-27T03:30:36.286Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"z4wpi410","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/data-tables.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { AnimatePresence, motion } from \"motion/react\";\nimport { \n  Search, ChevronDown, Calendar, ArrowUp, ArrowDown, \n  Copy, Check, X, ShieldCheck, Terminal, HelpCircle, \n  Eye, SlidersHorizontal, ArrowRight, Activity\n} from \"lucide-react\";\nimport { TableColumn } from \"./types\";\nimport { EmptyState } from \"./empty-state\";\n\n// ============================================================================\n// PREMIUM DATA TABLE (WITH INTEGRATED SEARCH, FILTERS, DRAWER & KEYBOARD NAVIGATION)\n// ============================================================================\nexport function DataTable<T extends { id: string | number }>({ \n  columns, \n  data, \n  pageSize = 5,\n  onRowClick,\n  searchPlaceholder = \"Search secure records...\",\n  searchFields = [],\n  statusField,\n  statusOptions = [],\n  typeField,\n  typeOptions = [],\n  dateField,\n  emptyStateTitle,\n  emptyStateDesc,\n  entityName = \"records\"\n}: { \n  columns: TableColumn<T>[]; \n  data: T[]; \n  pageSize?: number;\n  onRowClick?: (row: T) => void;\n  searchPlaceholder?: string;\n  searchFields?: (keyof T | string)[];\n  statusField?: keyof T | string;\n  statusOptions?: string[];\n  typeField?: keyof T | string;\n  typeOptions?: string[];\n  dateField?: keyof T | string;\n  emptyStateTitle?: string;\n  emptyStateDesc?: string;\n  entityName?: string;\n}) {\n  const [currentPage, setCurrentPage] = useState(1);\n  const [sortKey, setSortKey] = useState<keyof T | string | null>(null);\n  const [sortOrder, setSortOrder] = useState<\"asc\" | \"desc\">(\"asc\");\n  \n  // Search & Filter state\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  const [selectedDateRange, setSelectedDateRange] = useState(\"all\");\n  const [isDateDropdownOpen, setIsDateDropdownOpen] = useState(false);\n  \n  // Selected Row & Detail Drawer State\n  const [selectedRow, setSelectedRow] = useState<T | null>(null);\n  const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n  const [isCopied, setIsCopied] = useState(false);\n  const [isVerifying, setIsVerifying] = useState(false);\n  const [verifySuccess, setVerifySuccess] = useState(false);\n  \n  const tableRef = useRef<HTMLDivElement>(null);\n  const drawerRef = useRef<HTMLDivElement>(null);\n\n  // Keyboard navigation for rows\n  const [focusedRowIndex, setFocusedRowIndex] = useState<number>(-1);\n\n  // Reset pagination when filter changes\n  useEffect(() => {\n    setCurrentPage(1);\n    setFocusedRowIndex(-1);\n  }, [searchQuery, selectedStatus, selectedType, selectedDateRange]);\n\n  // Handle ESC key to close drawer & keyboard arrows\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") {\n        setIsDrawerOpen(false);\n        setSelectedRow(null);\n      }\n    };\n    window.addEventListener(\"keydown\", handleKeyDown);\n    return () => window.removeEventListener(\"keydown\", handleKeyDown);\n  }, []);\n\n  const handleSort = (key: keyof T | string, sortable?: boolean) => {\n    if (!sortable) return;\n    if (sortKey === key) {\n      setSortOrder(sortOrder === \"asc\" ? \"desc\" : \"asc\");\n    } else {\n      setSortKey(key);\n      setSortOrder(\"asc\");\n    }\n  };\n\n  // Filter Data\n  const filteredData = data.filter((row) => {\n    // 1. Search Query\n    if (searchQuery.trim() !== \"\") {\n      const query = searchQuery.toLowerCase();\n      const fieldsToSearch = searchFields.length > 0 \n        ? searchFields \n        : columns.map(c => c.key);\n      \n      const matchesSearch = fieldsToSearch.some((field) => {\n        const val = row[field as keyof T];\n        if (val === null || val === undefined) return false;\n        return String(val).toLowerCase().includes(query);\n      });\n      if (!matchesSearch) return false;\n    }\n\n    // 2. Status Filter\n    if (selectedStatus !== \"\" && statusField) {\n      const val = row[statusField as keyof T];\n      if (val === null || val === undefined || String(val).toUpperCase() !== selectedStatus.toUpperCase()) {\n        return false;\n      }\n    }\n\n    // 3. Type / Category Filter\n    if (selectedType !== \"\" && typeField) {\n      const val = row[typeField as keyof T];\n      if (val === null || val === undefined || String(val).toUpperCase() !== selectedType.toUpperCase()) {\n        return false;\n      }\n    }\n\n    // 4. Date Range Filter Placeholder Simulation\n    if (selectedDateRange !== \"all\" && dateField) {\n      // In a real sandbox this parses iso dates; for preview we just display simulated filtering\n      const val = String(row[dateField as keyof T] || \"\").toLowerCase();\n      if (selectedDateRange === \"today\" && !val.includes(\"ago\") && !val.includes(\"today\") && !val.includes(\"min\")) {\n        return false;\n      }\n    }\n\n    return true;\n  });\n\n  // Sort Data\n  const processedData = [...filteredData];\n  if (sortKey) {\n    processedData.sort((a, b) => {\n      const aVal = a[sortKey as keyof T];\n      const bVal = b[sortKey as keyof T];\n      if (aVal === undefined || aVal === null) return 1;\n      if (bVal === undefined || bVal === null) return -1;\n      if (typeof aVal === \"string\" && typeof bVal === \"string\") {\n        return sortOrder === \"asc\" ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);\n      }\n      return sortOrder === \"asc\" \n        ? (aVal > bVal ? 1 : -1)\n        : (aVal < bVal ? 1 : -1);\n    });\n  }\n\n  // Paginated Data\n  const totalPages = Math.ceil(processedData.length / pageSize) || 1;\n  const paginatedData = processedData.slice(\n    (currentPage - 1) * pageSize,\n    currentPage * pageSize\n  );\n\n  // Open detail drawer\n  const handleRowSelect = (row: T) => {\n    setSelectedRow(row);\n    setIsDrawerOpen(true);\n    setVerifySuccess(false);\n    setIsCopied(false);\n    onRowClick?.(row);\n  };\n\n  // Keyboard accessibility\n  const handleKeyDown = (e: React.KeyboardEvent, row: T, index: number) => {\n    if (e.key === \"Enter\" || e.key === \" \") {\n      e.preventDefault();\n      handleRowSelect(row);\n    } else if (e.key === \"ArrowDown\") {\n      e.preventDefault();\n      const nextIdx = Math.min(paginatedData.length - 1, index + 1);\n      setFocusedRowIndex(nextIdx);\n      const rowEl = tableRef.current?.querySelector(`[data-row-index=\"${nextIdx}\"]`) as HTMLElement;\n      rowEl?.focus();\n    } else if (e.key === \"ArrowUp\") {\n      e.preventDefault();\n      const prevIdx = Math.max(0, index - 1);\n      setFocusedRowIndex(prevIdx);\n      const rowEl = tableRef.current?.querySelector(`[data-row-index=\"${prevIdx}\"]`) as HTMLElement;\n      rowEl?.focus();\n    }\n  };\n\n  const copyToClipboard = (text: string) => {\n    navigator.clipboard.writeText(text);\n    setIsCopied(true);\n    setTimeout(() => setIsCopied(false), 2000);\n  };\n\n  const triggerVerification = () => {\n    setIsVerifying(true);\n    setTimeout(() => {\n      setIsVerifying(false);\n      setVerifySuccess(true);\n    }, 1200);\n  };\n\n  const clearAllFilters = () => {\n    setSearchQuery(\"\");\n    setSelectedStatus(\"\");\n    setSelectedType(\"\");\n    setSelectedDateRange(\"all\");\n  };\n\n  // Helper to render status pills\n  const getStatusStyle = (status: string) => {\n    const s = String(status).toUpperCase();\n    if (s.includes(\"ACTIVE\") || s.includes(\"STABLE\") || s.includes(\"COMPLIANT\") || s.includes(\"VERIFIED\") || s.includes(\"PAID\") || s.includes(\"SETTLED\")) {\n      return \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\";\n    }\n    if (s.includes(\"WARNING\") || s.includes(\"EVALUATING\") || s.includes(\"IN_PROGRESS\") || s.includes(\"PROCESSING\") || s.includes(\"OPEN\")) {\n      return \"bg-amber-500/10 text-amber-400 border-amber-500/20\";\n    }\n    if (s.includes(\"DECOUPLED\") || s.includes(\"CRITICAL\") || s.includes(\"SUSPENDED\") || s.includes(\"OVERDUE\") || s.includes(\"REJECTED\") || s.includes(\"FAILED\")) {\n      return \"bg-red-500/10 text-red-400 border-red-500/20\";\n    }\n    return \"bg-white/5 text-white/60 border-white/10\";\n  };\n\n  return (\n    <div className=\"space-y-4\" ref={tableRef}>\n      {/* ============================================================================\n          FILTER BAR (PREMIUM COHESIVE SYSTEM)\n         ============================================================================ */}\n      <div className=\"flex flex-col xl:flex-row gap-3 items-stretch justify-between bg-[#070709]/80 p-3 rounded-xl border border-white/5\">\n        <div className=\"flex flex-col md:flex-row gap-3 flex-grow\">\n          {/* SEARCH */}\n          <div className=\"relative flex-grow min-w-[240px]\">\n            <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n            <input \n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder={searchPlaceholder}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-black/40 pl-9 pr-8 text-[12px] font-mono text-white placeholder-white/25 outline-none focus:border-white/15 focus:bg-black/60 transition-all focus:ring-1 focus:ring-[#009DFF]/20\"\n            />\n            {searchQuery && (\n              <button \n                onClick={() => setSearchQuery(\"\")}\n                className=\"absolute right-2.5 top-2.5 text-white/30 hover:text-white\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            )}\n          </div>\n\n          {/* STATUS FILTER */}\n          {statusField && statusOptions.length > 0 && (\n            <div className=\"relative shrink-0\">\n              <select \n                value={selectedStatus}\n                onChange={(e) => setSelectedStatus(e.target.value)}\n                className=\"w-full md:w-auto h-9 rounded-lg border border-white/5 bg-black/40 hover:bg-black/60 px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n              >\n                <option value=\"\">ALL STATUSES</option>\n                {statusOptions.map((opt, idx) => (\n                  <option key={idx} value={opt} className=\"bg-[#0a0a0c] text-white\">\n                    {opt.toUpperCase()}\n                  </option>\n                ))}\n              </select>\n              <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {/* TYPE / CATEGORY FILTER */}\n          {typeField && typeOptions.length > 0 && (\n            <div className=\"relative shrink-0\">\n              <select \n                value={selectedType}\n                onChange={(e) => setSelectedType(e.target.value)}\n                className=\"w-full md:w-auto h-9 rounded-lg border border-white/5 bg-black/40 hover:bg-black/60 px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n              >\n                <option value=\"\">ALL TYPES</option>\n                {typeOptions.map((opt, idx) => (\n                  <option key={idx} value={opt} className=\"bg-[#0a0a0c] text-white\">\n                    {opt.toUpperCase()}\n                  </option>\n                ))}\n              </select>\n              <ChevronDown className=\"absolute right-3 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {/* DATE RANGE FILTER PLACEHOLDER */}\n          {dateField && (\n            <div className=\"relative shrink-0\">\n              <button \n                onClick={() => setIsDateDropdownOpen(!isDateDropdownOpen)}\n                className=\"w-full md:w-auto h-9 flex items-center gap-2 rounded-lg border border-white/5 bg-black/40 hover:bg-black/60 px-3 text-[11.5px] font-mono text-white/70 hover:text-white transition-all cursor-pointer\"\n              >\n                <Calendar className=\"w-3.5 h-3.5 text-white/40\" />\n                <span>\n                  {selectedDateRange === \"all\" ? \"ALL TIME\" : \n                   selectedDateRange === \"today\" ? \"LAST 24 HOURS\" : \"LAST 7 DAYS\"}\n                </span>\n                <ChevronDown className=\"w-3.5 h-3.5 text-white/30\" />\n              </button>\n\n              {isDateDropdownOpen && (\n                <>\n                  <div className=\"fixed inset-0 z-40\" onClick={() => setIsDateDropdownOpen(false)} />\n                  <div className=\"absolute right-0 mt-1 w-52 rounded-lg border border-white/5 bg-[#0a0a0d] p-1.5 shadow-xl z-50\">\n                    <button \n                      onClick={() => { setSelectedDateRange(\"all\"); setIsDateDropdownOpen(false); }}\n                      className={`w-full text-left px-2.5 py-1.5 rounded text-[11px] font-mono transition-colors ${selectedDateRange === \"all\" ? \"text-[#009DFF] bg-white/[0.03]\" : \"text-white/60 hover:text-white hover:bg-white/[0.01]\"}`}\n                    >\n                      ALL TIME\n                    </button>\n                    <button \n                      onClick={() => { setSelectedDateRange(\"today\"); setIsDateDropdownOpen(false); }}\n                      className={`w-full text-left px-2.5 py-1.5 rounded text-[11px] font-mono transition-colors ${selectedDateRange === \"today\" ? \"text-[#009DFF] bg-white/[0.03]\" : \"text-white/60 hover:text-white hover:bg-white/[0.01]\"}`}\n                    >\n                      LAST 24 HOURS\n                    </button>\n                    <div className=\"h-[1px] bg-white/5 my-1\" />\n                    <div className=\"p-2 text-[8.5px] font-mono text-white/25 uppercase select-none leading-normal\">\n                      Sovereign Cryptographic Epochs are filtered automatically.\n                    </div>\n                  </div>\n                </>\n              )}\n            </div>\n          )}\n        </div>\n\n        {/* METRICS & COUNTER */}\n        <div className=\"flex items-center justify-between md:justify-end gap-3 font-mono text-[10.5px] text-white/40 border-t border-white/5 xl:border-t-0 pt-2 xl:pt-0\">\n          <span>SHOWING {filteredData.length} OF {data.length} MATCHES</span>\n          {(searchQuery || selectedStatus || selectedType || selectedDateRange !== \"all\") && (\n            <button \n              onClick={clearAllFilters}\n              className=\"text-[#009DFF] hover:underline uppercase text-[9.5px] font-bold cursor-pointer\"\n            >\n              RESET FILTERS\n            </button>\n          )}\n        </div>\n      </div>\n\n      {/* ============================================================================\n          MAIN DATA TABLE (DESKTOP) & MOBILE FALLBACK CARDS\n         ============================================================================ */}\n      <div className=\"border border-white/5 rounded-xl overflow-hidden bg-black/40 backdrop-blur-md relative\">\n        \n        {/* DESKTOP TABLE */}\n        <div className=\"hidden lg:block overflow-x-auto\">\n          <table className=\"w-full text-left font-mono text-[11px] text-white/70\">\n            <thead>\n              <tr className=\"bg-white/[0.02] border-b border-white/5 text-white/35 text-[9.5px] uppercase select-none\">\n                {columns.map((col, idx) => (\n                  <th \n                    key={idx} \n                    onClick={() => handleSort(col.key, col.sortable)}\n                    className={`p-3.5 font-bold tracking-wider ${col.sortable ? \"hover:text-white cursor-pointer\" : \"\"}`}\n                  >\n                    <div className=\"flex items-center gap-1.5\">\n                      <span>{col.header}</span>\n                      {col.sortable && (\n                        <span className=\"text-[10px] text-white/20\">\n                          {sortKey === col.key ? (\n                            sortOrder === \"asc\" ? <ArrowUp className=\"w-3 h-3 text-[#009DFF]\" /> : <ArrowDown className=\"w-3 h-3 text-[#009DFF]\" />\n                          ) : (\n                            <SlidersHorizontal className=\"w-2.5 h-2.5 opacity-40 hover:opacity-100\" />\n                          )}\n                        </span>\n                      )}\n                    </div>\n                  </th>\n                ))}\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-white/5\">\n              {paginatedData.length === 0 ? (\n                <tr>\n                  <td colSpan={columns.length} className=\"p-0\">\n                    <div className=\"py-12\">\n                      <EmptyState \n                        title={emptyStateTitle || `No matched ${entityName}`} \n                        description={emptyStateDesc || `We could not find any active ${entityName} matching the applied filter parameters inside this secure node sandbox.`}\n                        actionLabel=\"Clear filter query\"\n                        onAction={clearAllFilters}\n                      />\n                    </div>\n                  </td>\n                </tr>\n              ) : (\n                paginatedData.map((row, rIdx) => {\n                  const isSelected = selectedRow?.id === row.id;\n                  const rowGlobalIdx = (currentPage - 1) * pageSize + rIdx;\n                  return (\n                    <tr \n                      key={row.id || rIdx} \n                      tabIndex={0}\n                      data-row-index={rIdx}\n                      onClick={() => handleRowSelect(row)}\n                      onKeyDown={(e) => handleKeyDown(e, row, rIdx)}\n                      className={`transition-all outline-none focus:bg-white/[0.03] focus:ring-1 focus:ring-[#009DFF]/40 cursor-pointer ${\n                        isSelected \n                          ? \"bg-[#009DFF]/5 border-l-2 border-[#009DFF]\" \n                          : \"hover:bg-white/[0.015] bg-transparent\"\n                      }`}\n                    >\n                      {columns.map((col, cIdx) => (\n                        <td key={cIdx} className=\"p-3.5 leading-normal relative\">\n                          {/* Selected glow indicator on first column */}\n                          {cIdx === 0 && isSelected && (\n                            <div className=\"absolute left-0 top-0 bottom-0 w-[3px] bg-[#009DFF] shadow-[0_0_10px_rgba(0,157,255,0.8)]\" />\n                          )}\n                          \n                          {col.render ? col.render(row) : (\n                            // Fallback status rendering\n                            col.key === \"status\" || col.key === \"integrity\" || col.key === \"tier\" ? (\n                              <span className={`inline-flex px-2 py-0.5 rounded text-[9px] font-bold uppercase border tracking-wider ${getStatusStyle(String(row[col.key as keyof T]))}`}>\n                                {String(row[col.key as keyof T])}\n                              </span>\n                            ) : (\n                              row[col.key as keyof T] as React.ReactNode\n                            )\n                          )}\n                        </td>\n                      ))}\n                    </tr>\n                  );\n                })\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* MOBILE FALLBACK CARDS */}\n        <div className=\"block lg:hidden divide-y divide-white/5\">\n          {paginatedData.length === 0 ? (\n            <div className=\"py-8\">\n              <EmptyState \n                title={emptyStateTitle || `No matched ${entityName}`} \n                description={emptyStateDesc || `We could not find any active ${entityName} matching the applied parameters.`}\n                actionLabel=\"Clear filter query\"\n                onAction={clearAllFilters}\n              />\n            </div>\n          ) : (\n            paginatedData.map((row, rIdx) => {\n              const isSelected = selectedRow?.id === row.id;\n              \n              // Guess title or primary key\n              const rowId = String(row.id || rIdx);\n              const rowTitle = String(row[\"name\" as keyof T] || row[\"title\" as keyof T] || row[\"subject\" as keyof T] || rowId);\n              const rowStatus = String(row[statusField as keyof T] || row[\"status\" as keyof T] || \"\");\n\n              return (\n                <div \n                  key={row.id || rIdx}\n                  onClick={() => handleRowSelect(row)}\n                  className={`p-4 transition-all space-y-3 cursor-pointer ${\n                    isSelected ? \"bg-[#009DFF]/5 border-l-2 border-l-[#009DFF]\" : \"hover:bg-white/[0.015]\"\n                  }`}\n                >\n                  <div className=\"flex justify-between items-start gap-2\">\n                    <div className=\"space-y-1\">\n                      <span className=\"text-[9.5px] font-mono text-[#009DFF] font-bold\">{rowId}</span>\n                      <h4 className=\"text-[12.5px] font-mono font-bold text-white tracking-tight\">{rowTitle}</h4>\n                    </div>\n                    {rowStatus && (\n                      <span className={`px-2 py-0.5 rounded text-[8.5px] font-bold uppercase border tracking-wider font-mono ${getStatusStyle(rowStatus)}`}>\n                        {rowStatus}\n                      </span>\n                    )}\n                  </div>\n\n                  {/* Render summary key-values for mobile preview */}\n                  <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono text-white/40 pt-1\">\n                    {columns.slice(1, 3).map((col, cIdx) => (\n                      <div key={cIdx} className=\"space-y-0.5\">\n                        <span className=\"text-[8.5px] uppercase tracking-wider text-white/20 block\">{col.header}</span>\n                        <div className=\"text-white/60 truncate\">\n                          {col.render ? col.render(row) : String(row[col.key as keyof T] || \"-\")}\n                        </div>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n              );\n            })\n          )}\n        </div>\n\n        {/* PAGINATION / FOOTER */}\n        {totalPages > 1 && (\n          <div className=\"flex flex-col sm:flex-row justify-between items-center bg-[#070709]/60 border-t border-white/5 p-4 gap-3 select-none\">\n            <span className=\"text-[10px] font-mono text-white/35\">\n              PAGE {currentPage} OF {totalPages} ({filteredData.length} OF {data.length} RECS)\n            </span>\n            <div className=\"flex gap-2\">\n              <button \n                disabled={currentPage === 1}\n                onClick={() => setCurrentPage(p => Math.max(1, p - 1))}\n                className=\"px-3 py-1 rounded border border-white/5 text-[10px] text-white font-mono hover:bg-white/5 disabled:opacity-20 transition-all cursor-pointer\"\n              >\n                PREV\n              </button>\n              <button \n                disabled={currentPage === totalPages}\n                onClick={() => setCurrentPage(p => Math.min(totalPages, p + 1))}\n                className=\"px-3 py-1 rounded border border-white/5 text-[10px] text-white font-mono hover:bg-white/5 disabled:opacity-20 transition-all cursor-pointer\"\n              >\n                NEXT\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* ============================================================================\n          INTERACTIVE DETAIL DRAWER (SLIDEOUT PANEL FROM RIGHT WITH BLUR BACKGROUND)\n         ============================================================================ */}\n      <AnimatePresence>\n        {isDrawerOpen && selectedRow && (\n          <>\n            {/* Backdrop Overlay */}\n            <motion.div \n              initial={{ opacity: 0 }}\n              animate={{ opacity: 0.6 }}\n              exit={{ opacity: 0 }}\n              className=\"fixed inset-0 bg-black z-40\"\n              onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }}\n            />\n\n            {/* Slider Drawer Container */}\n            <motion.div \n              ref={drawerRef}\n              initial={{ x: \"100%\" }}\n              animate={{ x: 0 }}\n              exit={{ x: \"100%\" }}\n              transition={{ type: \"spring\", damping: 30, stiffness: 300 }}\n              className=\"fixed top-8 right-0 bottom-0 w-full md:w-[480px] lg:w-[540px] bg-[#07070a] border-l border-white/5 shadow-2xl z-50 flex flex-col pt-8 text-white select-text\"\n            >\n              {/* Drawer Header */}\n              <div className=\"p-6 border-b border-white/5 flex items-center justify-between\">\n                <div className=\"space-y-1.5 min-w-0\">\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"text-[9.5px] font-mono font-bold tracking-widest text-[#009DFF] uppercase bg-[#009DFF]/5 border border-[#009DFF]/20 px-2 py-0.5 rounded\">\n                      AUDIT DETAIL\n                    </span>\n                    <span className=\"text-[10px] font-mono text-white/30\">ID: {String(selectedRow.id)}</span>\n                  </div>\n                  <h3 className=\"text-[15px] font-mono font-bold text-white tracking-tight truncate leading-tight\">\n                    {String(selectedRow[\"name\" as keyof T] || selectedRow[\"title\" as keyof T] || selectedRow[\"subject\" as keyof T] || `Record #${selectedRow.id}`)}\n                  </h3>\n                </div>\n                <button \n                  onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }}\n                  className=\"h-8 w-8 rounded-lg border border-white/5 bg-white/[0.02] flex items-center justify-center text-white/40 hover:text-white hover:bg-white/5 cursor-pointer transition-colors\"\n                  aria-label=\"Close details\"\n                >\n                  <X className=\"w-4 h-4\" />\n                </button>\n              </div>\n\n              {/* Drawer Scrollable Content */}\n              <div className=\"flex-grow p-6 overflow-y-auto space-y-6\">\n                \n                {/* Meta Grid Section */}\n                <div className=\"space-y-3.5\">\n                  <h4 className=\"text-[10.5px] font-mono font-bold uppercase tracking-wider text-white/35\">METADATA FIELDS</h4>\n                  <div className=\"grid grid-cols-2 gap-4 bg-white/[0.01] border border-white/5 p-4 rounded-xl font-mono text-[11px]\">\n                    {Object.keys(selectedRow)\n                      .filter(key => key !== \"logs\" && key !== \"replies\" && typeof selectedRow[key as keyof T] !== \"object\")\n                      .map((key) => (\n                        <div key={key} className=\"space-y-1 overflow-hidden\">\n                          <span className=\"text-[9px] text-white/20 uppercase tracking-widest block\">{key.replace(/([A-Z])/g, \" $1\")}</span>\n                          <span className=\"text-white/80 block truncate\">\n                            {key === \"status\" || key === \"integrity\" ? (\n                              <span className={`inline-flex px-1.5 py-0.5 rounded text-[8.5px] font-bold border ${getStatusStyle(String(selectedRow[key as keyof T]))}`}>\n                                {String(selectedRow[key as keyof T])}\n                              </span>\n                            ) : (\n                              String(selectedRow[key as keyof T] ?? \"-\")\n                            )}\n                          </span>\n                        </div>\n                      ))}\n                  </div>\n                </div>\n\n                {/* Simulated Custom Interactive Component (Logs / Replies etc.) */}\n                {selectedRow[\"logs\" as keyof T] && Array.isArray(selectedRow[\"logs\" as keyof T]) && (\n                  <div className=\"space-y-3\">\n                    <h4 className=\"text-[10.5px] font-mono font-bold uppercase tracking-wider text-white/35 flex items-center gap-1.5\">\n                      <Terminal className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n                      <span>REAL-TIME ENCLAVE THREAD LOGS</span>\n                    </h4>\n                    <div className=\"bg-black border border-white/5 rounded-xl p-4 font-mono text-[10px] text-white/60 space-y-2 h-44 overflow-y-auto leading-normal select-all\">\n                      {(selectedRow[\"logs\" as keyof T] as string[]).map((log, lIdx) => (\n                        <div key={lIdx} className=\"flex gap-2\">\n                          <span className=\"text-white/25 select-none\">{`[0x${lIdx.toString(16).toUpperCase()}]`}</span>\n                          <span>{log}</span>\n                        </div>\n                      ))}\n                    </div>\n                  </div>\n                )}\n\n                {/* Simulated Cryptographic Ledger JSON (Strategic/Expensive visual) */}\n                <div className=\"space-y-3\">\n                  <div className=\"flex items-center justify-between\">\n                    <h4 className=\"text-[10.5px] font-mono font-bold uppercase tracking-wider text-white/35 flex items-center gap-1.5\">\n                      <ShieldCheck className=\"w-3.5 h-3.5 text-emerald-400\" />\n                      <span>ATTESTATION SIGNATURE PAYLOAD</span>\n                    </h4>\n                    <button \n                      onClick={() => copyToClipboard(JSON.stringify(selectedRow, null, 2))}\n                      className=\"text-[9px] font-mono text-[#009DFF] hover:underline flex items-center gap-1 cursor-pointer\"\n                    >\n                      {isCopied ? (\n                        <>\n                          <Check className=\"w-3 h-3 text-emerald-400\" />\n                          <span className=\"text-emerald-400 font-bold uppercase\">Copied</span>\n                        </>\n                      ) : (\n                        <>\n                          <Copy className=\"w-3 h-3\" />\n                          <span>COPY ATTESTATION</span>\n                        </>\n                      )}\n                    </button>\n                  </div>\n                  <div className=\"bg-[#030305] border border-white/5 rounded-xl p-4 font-mono text-[9px] text-[#009DFF]/80 select-all overflow-x-auto leading-relaxed shadow-inner max-h-48 scrollbar-thin\">\n                    <pre>{JSON.stringify({\n                      _header: {\n                        algorithm: \"GFF-SHA-256\",\n                        enclave_hardware: selectedRow[\"enclaveType\" as keyof T] || \"Sovereign HSM Secure Module\",\n                        block_epoch: 14421,\n                        attestation_verified: true,\n                        presentation_decoupled: true\n                      },\n                      record: selectedRow\n                    }, null, 2)}</pre>\n                  </div>\n                </div>\n\n                {/* Verification Check & Support Actions */}\n                <div className=\"p-4 rounded-xl border border-white/5 bg-gradient-to-br from-white/[0.01] to-transparent space-y-3\">\n                  <div className=\"flex items-center justify-between\">\n                    <div>\n                      <h5 className=\"text-[11.5px] font-mono font-bold text-white\">Cryptographic Verification Proof</h5>\n                      <p className=\"text-[9.5px] font-mono text-white/40 mt-0.5\">Enforce a dual-layer hardware verification audit on this record.</p>\n                    </div>\n                    <button \n                      onClick={triggerVerification}\n                      disabled={isVerifying || verifySuccess}\n                      className={`h-8 px-3 rounded text-[10px] font-mono font-bold uppercase tracking-wider transition-all cursor-pointer flex items-center gap-1.5 ${\n                        verifySuccess \n                          ? \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/25\" \n                          : \"bg-white text-black hover:bg-white/90 disabled:opacity-55\"\n                      }`}\n                    >\n                      {isVerifying ? (\n                        <div className=\"h-3 w-3 border-2 border-black border-t-transparent rounded-full animate-spin\" />\n                      ) : verifySuccess ? (\n                        <Check className=\"w-3.5 h-3.5\" />\n                      ) : (\n                        <Activity className=\"w-3.5 h-3.5\" />\n                      )}\n                      <span>{isVerifying ? \"Verifying...\" : verifySuccess ? \"VERIFIED\" : \"VERIFY RECORD\"}</span>\n                    </button>\n                  </div>\n\n                  {verifySuccess && (\n                    <motion.div \n                      initial={{ opacity: 0, y: 5 }}\n                      animate={{ opacity: 1, y: 0 }}\n                      className=\"p-2.5 rounded bg-emerald-500/5 border border-emerald-500/25 text-[10px] font-mono text-emerald-400 leading-normal flex items-center gap-2\"\n                    >\n                      <ShieldCheck className=\"w-4 h-4 text-emerald-400 shrink-0\" />\n                      <span>Dual-key handshake signed successfully. Root certificate 0x7FFA match verified in isolation.</span>\n                    </motion.div>\n                  )}\n                </div>\n\n              </div>\n\n              {/* Drawer Footer Actions */}\n              <div className=\"p-6 border-t border-white/5 bg-black/20 flex gap-3\">\n                <button \n                  onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }}\n                  className=\"flex-grow h-10 rounded border border-white/5 bg-[#0a0a0c] text-[11px] font-mono font-bold uppercase tracking-wider text-white/70 hover:text-white hover:bg-white/5 cursor-pointer transition-colors\"\n                >\n                  CLOSE AUDIT\n                </button>\n                <button \n                  onClick={() => alert(\"Initiating high-priority audit export. Session log downloaded.\")}\n                  className=\"flex-grow h-10 rounded bg-[#009DFF] text-[11px] font-mono font-bold uppercase tracking-wider text-white hover:bg-[#008bdb] cursor-pointer transition-all flex items-center justify-center gap-1.5 shadow-[0_0_15px_rgba(0,157,255,0.2)]\"\n                >\n                  <span>EXPORT ENTRY</span>\n                  <ArrowRight className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n\n            </motion.div>\n          </>\n        )}\n      </AnimatePresence>\n\n    </div>\n  );\n}\n"}}}
