{"ts":"2026-06-27T03:31:38.377Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"5j7gnce5","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/data-tables.tsx","new_text":"\"use client\";\nimport React, { useState, useEffect } from \"react\";\nimport { AnimatePresence, motion } from \"motion/react\";\nimport { Search, ChevronDown, Calendar, ArrowUp, ArrowDown, X, Terminal, Activity, ArrowRight } from \"lucide-react\";\nimport { TableColumn } from \"./types\";\n\nexport function DataTable<T extends { id: string | number }>({ \n  columns, data, pageSize = 5, onRowClick, searchPlaceholder = \"Search secure records...\",\n  searchFields = [], statusField, statusOptions = [], typeField, typeOptions = [], dateField\n}: { \n  columns: TableColumn<T>[]; data: T[]; pageSize?: number; onRowClick?: (row: T) => void;\n  searchPlaceholder?: string; searchFields?: (keyof T | string)[]; statusField?: keyof T | string;\n  statusOptions?: string[]; typeField?: keyof T | string; typeOptions?: string[]; dateField?: keyof T | string;\n}) {\n  const [currentPage, setCurrentPage] = useState(1);\n  const [sortKey, setSortKey] = useState<keyof T | string | null>(null);\n  const [sortOrder, setSortOrder] = useState<\"asc\" | \"desc\">(\"asc\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  const [isDateOpen, setIsDateOpen] = useState(false);\n  const [selectedRow, setSelectedRow] = useState<T | null>(null);\n  const [isCopied, setIsCopied] = useState(false);\n  const [verifySuccess, setVerifySuccess] = useState(false);\n\n  useEffect(() => { setCurrentPage(1); }, [searchQuery, selectedStatus, selectedType]);\n  useEffect(() => {\n    const esc = (e: KeyboardEvent) => { if (e.key === \"Escape\") { setSelectedRow(null); } };\n    window.addEventListener(\"keydown\", esc);\n    return () => window.removeEventListener(\"keydown\", esc);\n  }, []);\n\n  const handleSort = (key: keyof T | string, sortable?: boolean) => {\n    if (!sortable) return;\n    if (sortKey === key) setSortOrder(sortOrder === \"asc\" ? \"desc\" : \"asc\");\n    else { setSortKey(key); setSortOrder(\"asc\"); }\n  };\n\n  const filtered = data.filter(row => {\n    if (searchQuery.trim()) {\n      const q = searchQuery.toLowerCase();\n      const fields = searchFields.length ? searchFields : columns.map(c => c.key);\n      if (!fields.some(f => String(row[f as keyof T] || \"\").toLowerCase().includes(q))) return false;\n    }\n    if (selectedStatus && statusField && String(row[statusField as keyof T] || \"\").toUpperCase() !== selectedStatus.toUpperCase()) return false;\n    if (selectedType && typeField && String(row[typeField as keyof T] || \"\").toUpperCase() !== selectedType.toUpperCase()) return false;\n    return true;\n  });\n\n  if (sortKey) {\n    filtered.sort((a, b) => {\n      const aVal = a[sortKey as keyof T];\n      const bVal = b[sortKey as keyof T];\n      if (aVal === undefined || aVal === null) return 1;\n      if (bVal === undefined || bVal === null) return -1;\n      return sortOrder === \"asc\" ? (aVal > bVal ? 1 : -1) : (aVal < bVal ? 1 : -1);\n    });\n  }\n\n  const totalPages = Math.ceil(filtered.length / pageSize) || 1;\n  const paginated = filtered.slice((currentPage - 1) * pageSize, currentPage * pageSize);\n\n  const getStatusStyle = (val: string) => {\n    const s = String(val).toUpperCase();\n    if (s.includes(\"ACTIVE\") || s.includes(\"STABLE\") || s.includes(\"COMPLIANT\") || s.includes(\"VERIFIED\") || s.includes(\"PAID\") || s.includes(\"SETTLED\")) {\n      return \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\";\n    }\n    if (s.includes(\"WARNING\") || s.includes(\"EVALUATING\") || s.includes(\"IN_PROGRESS\") || s.includes(\"PROCESSING\") || s.includes(\"OPEN\")) {\n      return \"bg-amber-500/10 text-amber-400 border-amber-500/20\";\n    }\n    return \"bg-red-500/10 text-red-400 border-red-500/20\";\n  };\n\n  return (\n    <div className=\"space-y-4\">\n      {/* FILTER BAR */}\n      <div className=\"flex flex-col md:flex-row gap-2.5 p-2.5 rounded-xl border border-white/5 bg-[#070709]/80 items-stretch md:items-center justify-between\">\n        <div className=\"flex flex-wrap gap-2 flex-grow\">\n          <div className=\"relative flex-grow max-w-xs\">\n            <Search className=\"absolute left-2.5 top-2 w-3.5 h-3.5 text-white/30\" />\n            <input \n              type=\"text\" value={searchQuery} onChange={e => setSearchQuery(e.target.value)} placeholder={searchPlaceholder}\n              className=\"w-full h-8 rounded-lg border border-white/5 bg-black/40 pl-8 pr-7 text-[11px] font-mono text-white placeholder-white/20 outline-none focus:border-white/15\"\n            />\n          </div>\n          {statusField && statusOptions.length > 0 && (\n            <div className=\"relative\">\n              <select value={selectedStatus} onChange={e => setSelectedStatus(e.target.value)} className=\"h-8 rounded-lg border border-white/5 bg-black/40 px-2.5 pr-7 text-[10.5px] font-mono text-white/70 appearance-none cursor-pointer\">\n                <option value=\"\">ALL STATUSES</option>\n                {statusOptions.map((opt, i) => <option key={i} value={opt} className=\"bg-[#0c0c0e]\">{opt.toUpperCase()}</option>)}\n              </select>\n              <ChevronDown className=\"absolute right-2 top-2.5 w-3 h-3 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n          {typeField && typeOptions.length > 0 && (\n            <div className=\"relative\">\n              <select value={selectedType} onChange={e => setSelectedType(e.target.value)} className=\"h-8 rounded-lg border border-white/5 bg-black/40 px-2.5 pr-7 text-[10.5px] font-mono text-white/70 appearance-none cursor-pointer\">\n                <option value=\"\">ALL TYPES</option>\n                {typeOptions.map((opt, i) => <option key={i} value={opt} className=\"bg-[#0c0c0e]\">{opt.toUpperCase()}</option>)}\n              </select>\n              <ChevronDown className=\"absolute right-2 top-2.5 w-3 h-3 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n          {dateField && (\n            <button onClick={() => setIsDateOpen(!isDateOpen)} className=\"h-8 flex items-center gap-1.5 rounded-lg border border-white/5 bg-black/40 px-2.5 text-[10.5px] font-mono text-white/70\">\n              <Calendar className=\"w-3 h-3\" />\n              <span>ALL EPOCHS</span>\n            </button>\n          )}\n        </div>\n        <div className=\"flex items-center gap-2 font-mono text-[9.5px] text-white/40 justify-between\">\n          <span>MATCHED {filtered.length} RECORDS</span>\n        </div>\n      </div>\n\n      {/* TABLE */}\n      <div className=\"border border-white/5 rounded-xl overflow-hidden bg-black/30\">\n        <div className=\"hidden lg:block overflow-x-auto\">\n          <table className=\"w-full text-left font-mono text-[10.5px] text-white/70\">\n            <thead>\n              <tr className=\"bg-white/[0.01] border-b border-white/5 text-white/35 text-[9px] uppercase select-none\">\n                {columns.map((col, idx) => (\n                  <th key={idx} onClick={() => handleSort(col.key, col.sortable)} className={`p-2.5 font-bold tracking-wider ${col.sortable ? \"hover:text-white cursor-pointer\" : \"\"}`}>\n                    <div className=\"flex items-center gap-1\">\n                      <span>{col.header}</span>\n                      {col.sortable && (sortKey === col.key ? (sortOrder === \"asc\" ? <ArrowUp className=\"w-2.5 h-2.5 text-[#009DFF]\" /> : <ArrowDown className=\"w-2.5 h-2.5 text-[#009DFF]\" />) : \"⇅\")}\n                    </div>\n                  </th>\n                ))}\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-white/5\">\n              {paginated.length === 0 ? (\n                <tr><td colSpan={columns.length} className=\"p-6 text-center text-white/30\">No matching enclave records.</td></tr>\n              ) : (\n                paginated.map((row, rIdx) => (\n                  <tr \n                    key={row.id || rIdx} tabIndex={0} onClick={() => handleRowSelect(row)}\n                    onKeyDown={e => { if (e.key === \"Enter\" || e.key === \" \") handleRowSelect(row); }}\n                    className={`transition-all outline-none cursor-pointer border-l-2 ${selectedRow?.id === row.id ? \"bg-[#009DFF]/5 border-l-[#009DFF]\" : \"hover:bg-white/[0.015] border-l-transparent\"}`}\n                  >\n                    {columns.map((col, cIdx) => (\n                      <td key={cIdx} className=\"p-2.5\">\n                        {col.render ? col.render(row) : (\n                          col.key === \"status\" || col.key === \"integrity\" || col.key === \"tier\" ? (\n                            <span className={`inline-flex px-1.5 py-0.5 rounded text-[8px] font-bold border tracking-wider uppercase ${getStatusStyle(String(row[col.key as keyof T]))}`}>{String(row[col.key as keyof T])}</span>\n                          ) : String(row[col.key as keyof T] || \"-\")\n                        )}\n                      </td>\n                    ))}\n                  </tr>\n                ))\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* MOBILE FALLBACK */}\n        <div className=\"block lg:hidden divide-y divide-white/5\">\n          {paginated.length === 0 ? (\n            <div className=\"p-6 text-center text-white/30 text-[10.5px]\">No matching records.</div>\n          ) : (\n            paginated.map((row, rIdx) => {\n              const title = String(row[\"name\" as keyof T] || row[\"title\" as keyof T] || row[\"subject\" as keyof T] || row.id);\n              const status = String(row[\"status\" as keyof T] || \"\");\n              return (\n                <div key={row.id || rIdx} onClick={() => handleRowSelect(row)} className={`p-3 space-y-1.5 cursor-pointer border-l-2 ${selectedRow?.id === row.id ? \"bg-[#009DFF]/5 border-l-[#009DFF]\" : \"border-l-transparent hover:bg-white/[0.01]\"}`}>\n                  <div className=\"flex justify-between items-start gap-1\">\n                    <div>\n                      <span className=\"text-[8px] font-mono text-[#009DFF] font-bold\">#{row.id}</span>\n                      <h4 className=\"text-[11.5px] font-bold text-white block leading-snug\">{title}</h4>\n                    </div>\n                    {status && <span className={`px-1 rounded text-[7.5px] font-bold border uppercase ${getStatusStyle(status)}`}>{status}</span>}\n                  </div>\n                </div>\n              );\n            })\n          )}\n        </div>\n\n        {/* PAGINATION */}\n        {totalPages > 1 && (\n          <div className=\"flex justify-between items-center bg-[#070709]/60 border-t border-white/5 p-2.5 select-none font-mono text-[9.5px]\">\n            <span className=\"text-white/35\">PAGE {currentPage} OF {totalPages}</span>\n            <div className=\"flex gap-1.5\">\n              <button disabled={currentPage === 1} onClick={() => setCurrentPage(p => Math.max(1, p - 1))} className=\"px-2 py-0.5 rounded border border-white/5 text-white hover:bg-white/5 disabled:opacity-20 cursor-pointer\">PREV</button>\n              <button disabled={currentPage === totalPages} onClick={() => setCurrentPage(p => Math.min(totalPages, p + 1))} className=\"px-2 py-0.5 rounded border border-white/5 text-white hover:bg-white/5 disabled:opacity-20 cursor-pointer\">NEXT</button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* DETAIL DRAWER */}\n      <AnimatePresence>\n        {selectedRow && (\n          <>\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 0.5 }} exit={{ opacity: 0 }} className=\"fixed inset-0 bg-black z-40\" onClick={() => setSelectedRow(null)} />\n            <motion.div \n              initial={{ x: \"100%\" }} animate={{ x: 0 }} exit={{ x: \"100%\" }} transition={{ type: \"spring\", damping: 30, stiffness: 300 }}\n              className=\"fixed top-8 right-0 bottom-0 w-full md:w-[420px] bg-[#070709] border-l border-white/5 shadow-2xl z-50 flex flex-col pt-8 text-white\"\n            >\n              <div className=\"p-4 border-b border-white/5 flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[8px] font-mono text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/25 px-1 rounded\">SECURE ATTESTATION</span>\n                  <h3 className=\"text-[12.5px] font-bold text-white mt-1.5 font-mono truncate max-w-[280px]\">{String(selectedRow[\"name\" as keyof T] || selectedRow[\"title\" as keyof T] || selectedRow[\"subject\" as keyof T] || selectedRow.id)}</h3>\n                </div>\n                <button onClick={() => setSelectedRow(null)} className=\"p-1 rounded border border-white/5 bg-white/[0.01] hover:bg-white/5 text-white/55 cursor-pointer\"><X className=\"w-3.5 h-3.5\" /></button>\n              </div>\n\n              <div className=\"flex-grow p-4 overflow-y-auto space-y-4\">\n                <div className=\"space-y-1.5\">\n                  <span className=\"text-[9px] font-mono text-white/30 uppercase block font-bold\">Metadata Fields</span>\n                  <div className=\"grid grid-cols-2 gap-2 bg-white/[0.01] border border-white/5 p-3 rounded-lg font-mono text-[10px]\">\n                    {Object.keys(selectedRow).filter(k => k !== \"logs\" && k !== \"replies\" && typeof selectedRow[k as keyof T] !== \"object\").map(k => (\n                      <div key={k} className=\"overflow-hidden\">\n                        <span className=\"text-[8px] text-white/20 uppercase block\">{k.replace(/([A-Z])/g, \" $1\")}</span>\n                        <span className=\"text-white/85 block truncate mt-0.5\">{k === \"status\" || k === \"integrity\" ? <span className={`inline-flex px-1 rounded text-[7.5px] font-bold border ${getStatusStyle(String(selectedRow[k as keyof T]))}`}>{String(selectedRow[k as keyof T])}</span> : String(selectedRow[k as keyof T] ?? \"-\")}</span>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n\n                <div className=\"space-y-1.5\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[9px] font-mono text-white/30 uppercase block font-bold\">Enclave Verification Payload</span>\n                    <button \n                      onClick={() => { navigator.clipboard.writeText(JSON.stringify(selectedRow, null, 2)); setIsCopied(true); setTimeout(() => setIsCopied(false), 2000); }}\n                      className=\"text-[9px] text-[#009DFF] hover:underline font-mono cursor-pointer\"\n                    >\n                      {isCopied ? <span className=\"text-emerald-400 font-bold\">COPIED</span> : <span>COPY JSON</span>}\n                    </button>\n                  </div>\n                  <div className=\"bg-[#030304] border border-white/5 rounded-lg p-2.5 font-mono text-[8.5px] text-[#009DFF]/80 max-h-40 overflow-y-auto\">\n                    <pre>{JSON.stringify({ _header: { hash: \"GFF-SHA-256\", active: true }, record: selectedRow }, null, 2)}</pre>\n                  </div>\n                </div>\n\n                <div className=\"p-3 rounded-lg border border-white/5 bg-gradient-to-br from-white/[0.01] to-transparent flex items-center justify-between\">\n                  <div>\n                    <h5 className=\"text-[10.5px] font-bold text-white font-mono\">Ledger Cryptographic Verification</h5>\n                    <p className=\"text-[8.5px] text-white/35 font-mono\">Verify signature and certificate chain.</p>\n                  </div>\n                  <button \n                    onClick={() => setVerifySuccess(true)} disabled={verifySuccess}\n                    className={`h-7 px-2 rounded text-[9px] font-mono font-bold uppercase cursor-pointer flex items-center gap-1 ${verifySuccess ? \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" : \"bg-white text-black hover:bg-white/90\"}`}\n                  >\n                    <Activity className=\"w-3 h-3\" />\n                    <span>{verifySuccess ? \"VERIFIED\" : \"VERIFY\"}</span>\n                  </button>\n                </div>\n              </div>\n\n              <div className=\"p-4 border-t border-white/5 bg-black/15 flex gap-2\">\n                <button onClick={() => setSelectedRow(null)} className=\"flex-grow h-8 rounded border border-white/5 text-[10px] font-mono font-bold uppercase text-white/70 hover:text-white cursor-pointer\">CLOSE</button>\n                <button onClick={() => alert(\"Cryptographically signed compliance record downloaded.\")} className=\"flex-grow h-8 rounded bg-[#009DFF] text-[10px] font-mono font-bold uppercase text-white hover:bg-[#008bdb] cursor-pointer flex items-center justify-center gap-1 shadow-[0_0_10px_rgba(0,157,255,0.2)]\">\n                  <span>EXPORT</span>\n                  <ArrowRight className=\"w-3 h-3\" />\n                </button>\n              </div>\n            </motion.div>\n          </>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"}}}
