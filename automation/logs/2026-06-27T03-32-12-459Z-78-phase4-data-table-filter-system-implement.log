{"ts":"2026-06-27T03:31:11.833Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"27raxtpr","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/private-app/data-tables.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { AnimatePresence, motion } from \"motion/react\";\nimport { \n  Search, ChevronDown, Calendar, ArrowUp, ArrowDown, \n  Copy, Check, X, ShieldCheck, Terminal, Activity, ArrowRight\n} from \"lucide-react\";\nimport { TableColumn } from \"./types\";\n\nexport function DataTable<T extends { id: string | number }>({ \n  columns, \n  data, \n  pageSize = 5,\n  onRowClick,\n  searchPlaceholder = \"Search secure records...\",\n  searchFields = [],\n  statusField,\n  statusOptions = [],\n  typeField,\n  typeOptions = [],\n  dateField,\n  entityName = \"records\"\n}: { \n  columns: TableColumn<T>[]; \n  data: T[]; \n  pageSize?: number;\n  onRowClick?: (row: T) => void;\n  searchPlaceholder?: string;\n  searchFields?: (keyof T | string)[];\n  statusField?: keyof T | string;\n  statusOptions?: string[];\n  typeField?: keyof T | string;\n  typeOptions?: string[];\n  dateField?: keyof T | string;\n  entityName?: string;\n}) {\n  const [currentPage, setCurrentPage] = useState(1);\n  const [sortKey, setSortKey] = useState<keyof T | string | null>(null);\n  const [sortOrder, setSortOrder] = useState<\"asc\" | \"desc\">(\"asc\");\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedStatus, setSelectedStatus] = useState(\"\");\n  const [selectedType, setSelectedType] = useState(\"\");\n  const [selectedDateRange, setSelectedDateRange] = useState(\"all\");\n  const [isDateDropdownOpen, setIsDateDropdownOpen] = useState(false);\n  const [selectedRow, setSelectedRow] = useState<T | null>(null);\n  const [isDrawerOpen, setIsDrawerOpen] = useState(false);\n  const [isCopied, setIsCopied] = useState(false);\n  const [verifySuccess, setVerifySuccess] = useState(false);\n  const [focusedIndex, setFocusedIndex] = useState(-1);\n\n  useEffect(() => {\n    setCurrentPage(1);\n    setFocusedIndex(-1);\n  }, [searchQuery, selectedStatus, selectedType, selectedDateRange]);\n\n  useEffect(() => {\n    const handleKeyDown = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") {\n        setIsDrawerOpen(false);\n        setSelectedRow(null);\n      }\n    };\n    window.addEventListener(\"keydown\", handleKeyDown);\n    return () => window.removeEventListener(\"keydown\", handleKeyDown);\n  }, []);\n\n  const handleSort = (key: keyof T | string, sortable?: boolean) => {\n    if (!sortable) return;\n    if (sortKey === key) {\n      setSortOrder(sortOrder === \"asc\" ? \"desc\" : \"asc\");\n    } else {\n      setSortKey(key);\n      setSortOrder(\"asc\");\n    }\n  };\n\n  const filtered = data.filter((row) => {\n    if (searchQuery.trim()) {\n      const q = searchQuery.toLowerCase();\n      const fields = searchFields.length ? searchFields : columns.map(c => c.key);\n      if (!fields.some(f => String(row[f as keyof T] || \"\").toLowerCase().includes(q))) return false;\n    }\n    if (selectedStatus && statusField) {\n      if (String(row[statusField as keyof T] || \"\").toUpperCase() !== selectedStatus.toUpperCase()) return false;\n    }\n    if (selectedType && typeField) {\n      if (String(row[typeField as keyof T] || \"\").toUpperCase() !== selectedType.toUpperCase()) return false;\n    }\n    return true;\n  });\n\n  if (sortKey) {\n    filtered.sort((a, b) => {\n      const aVal = a[sortKey as keyof T];\n      const bVal = b[sortKey as keyof T];\n      if (aVal === undefined || aVal === null) return 1;\n      if (bVal === undefined || bVal === null) return -1;\n      return sortOrder === \"asc\" ? (aVal > bVal ? 1 : -1) : (aVal < bVal ? 1 : -1);\n    });\n  }\n\n  const totalPages = Math.ceil(filtered.length / pageSize) || 1;\n  const paginated = filtered.slice((currentPage - 1) * pageSize, currentPage * pageSize);\n\n  const handleRowSelect = (row: T) => {\n    setSelectedRow(row);\n    setIsDrawerOpen(true);\n    setVerifySuccess(false);\n    setIsCopied(false);\n    onRowClick?.(row);\n  };\n\n  const handleKeyDown = (e: React.KeyboardEvent, row: T, idx: number) => {\n    if (e.key === \"Enter\" || e.key === \" \") {\n      e.preventDefault();\n      handleRowSelect(row);\n    } else if (e.key === \"ArrowDown\") {\n      e.preventDefault();\n      setFocusedIndex(Math.min(paginated.length - 1, idx + 1));\n    } else if (e.key === \"ArrowUp\") {\n      e.preventDefault();\n      setFocusedIndex(Math.max(0, idx - 1));\n    }\n  };\n\n  const getStatusStyle = (val: string) => {\n    const s = String(val).toUpperCase();\n    if (s.includes(\"ACTIVE\") || s.includes(\"STABLE\") || s.includes(\"COMPLIANT\") || s.includes(\"VERIFIED\") || s.includes(\"PAID\") || s.includes(\"SETTLED\")) {\n      return \"bg-emerald-500/10 text-emerald-400 border-emerald-500/20\";\n    }\n    if (s.includes(\"WARNING\") || s.includes(\"EVALUATING\") || s.includes(\"IN_PROGRESS\") || s.includes(\"PROCESSING\") || s.includes(\"OPEN\")) {\n      return \"bg-amber-500/10 text-amber-400 border-amber-500/20\";\n    }\n    return \"bg-red-500/10 text-red-400 border-red-500/20\";\n  };\n\n  return (\n    <div className=\"space-y-4\">\n      {/* FILTER SYSTEM */}\n      <div className=\"flex flex-col md:flex-row gap-3 p-3 rounded-xl border border-white/5 bg-[#070709]/80 items-stretch md:items-center justify-between\">\n        <div className=\"flex flex-wrap gap-2 flex-grow\">\n          <div className=\"relative flex-grow max-w-md\">\n            <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n            <input \n              type=\"text\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              placeholder={searchPlaceholder}\n              className=\"w-full h-9 rounded-lg border border-white/5 bg-black/40 pl-9 pr-8 text-[12px] font-mono text-white placeholder-white/25 outline-none focus:border-white/15 focus:ring-1 focus:ring-[#009DFF]/20 transition-all\"\n            />\n            {searchQuery && (\n              <button onClick={() => setSearchQuery(\"\")} className=\"absolute right-2.5 top-2.5 text-white/30 hover:text-white\">\n                <X className=\"w-4 h-4\" />\n              </button>\n            )}\n          </div>\n\n          {statusField && statusOptions.length > 0 && (\n            <div className=\"relative\">\n              <select \n                value={selectedStatus}\n                onChange={(e) => setSelectedStatus(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-black/40 px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n              >\n                <option value=\"\">ALL STATUSES</option>\n                {statusOptions.map((opt, idx) => (\n                  <option key={idx} value={opt} className=\"bg-[#0a0a0c]\">{opt.toUpperCase()}</option>\n                ))}\n              </select>\n              <ChevronDown className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {typeField && typeOptions.length > 0 && (\n            <div className=\"relative\">\n              <select \n                value={selectedType}\n                onChange={(e) => setSelectedType(e.target.value)}\n                className=\"h-9 rounded-lg border border-white/5 bg-black/40 px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n              >\n                <option value=\"\">ALL TYPES</option>\n                {typeOptions.map((opt, idx) => (\n                  <option key={idx} value={opt} className=\"bg-[#0a0a0c]\">{opt.toUpperCase()}</option>\n                ))}\n              </select>\n              <ChevronDown className=\"absolute right-2.5 top-2.5 w-3.5 h-3.5 text-white/40 pointer-events-none\" />\n            </div>\n          )}\n\n          {dateField && (\n            <div className=\"relative\">\n              <button \n                onClick={() => setIsDateDropdownOpen(!isDateDropdownOpen)}\n                className=\"h-9 flex items-center gap-2 rounded-lg border border-white/5 bg-black/40 px-3 text-[11px] font-mono text-white/70 hover:text-white transition-all cursor-pointer\"\n              >\n                <Calendar className=\"w-3.5 h-3.5 text-white/40\" />\n                <span>{selectedDateRange === \"all\" ? \"ALL EPOCHS\" : \"LATEST EPOCH\"}</span>\n                <ChevronDown className=\"w-3.5 h-3.5 text-white/30\" />\n              </button>\n              {isDateDropdownOpen && (\n                <>\n                  <div className=\"fixed inset-0 z-40\" onClick={() => setIsDateDropdownOpen(false)} />\n                  <div className=\"absolute right-0 mt-1 w-48 rounded-lg border border-white/5 bg-[#0a0a0d] p-1 shadow-xl z-50\">\n                    <button onClick={() => { setSelectedDateRange(\"all\"); setIsDateDropdownOpen(false); }} className=\"w-full text-left px-2 py-1.5 rounded text-[10.5px] font-mono text-white/70 hover:bg-white/5\">ALL EPOCHS</button>\n                    <button onClick={() => { setSelectedDateRange(\"today\"); setIsDateDropdownOpen(false); }} className=\"w-full text-left px-2 py-1.5 rounded text-[10.5px] font-mono text-[#009DFF] bg-white/[0.02]\">LATEST EPOCH (24H)</button>\n                  </div>\n                </>\n              )}\n            </div>\n          )}\n        </div>\n\n        <div className=\"flex items-center gap-3 font-mono text-[10px] text-white/40 justify-between md:justify-end border-t border-white/5 md:border-t-0 pt-2 md:pt-0\">\n          <span>MATCHED {filtered.length} RECORDS</span>\n          {(searchQuery || selectedStatus || selectedType) && (\n            <button onClick={() => { setSearchQuery(\"\"); setSelectedStatus(\"\"); setSelectedType(\"\"); }} className=\"text-[#009DFF] hover:underline uppercase text-[9px] font-bold\">RESET</button>\n          )}\n        </div>\n      </div>\n\n      {/* DESKTOP TABLE & MOBILE CARDS */}\n      <div className=\"border border-white/5 rounded-xl overflow-hidden bg-black/30 backdrop-blur-md\">\n        <div className=\"hidden lg:block overflow-x-auto\">\n          <table className=\"w-full text-left font-mono text-[11px] text-white/70\">\n            <thead>\n              <tr className=\"bg-white/[0.01] border-b border-white/5 text-white/35 text-[9.5px] uppercase select-none\">\n                {columns.map((col, idx) => (\n                  <th key={idx} onClick={() => handleSort(col.key, col.sortable)} className={`p-3 font-bold tracking-wider ${col.sortable ? \"hover:text-white cursor-pointer\" : \"\"}`}>\n                    <div className=\"flex items-center gap-1.5\">\n                      <span>{col.header}</span>\n                      {col.sortable && (sortKey === col.key ? (sortOrder === \"asc\" ? <ArrowUp className=\"w-3 h-3 text-[#009DFF]\" /> : <ArrowDown className=\"w-3 h-3 text-[#009DFF]\" />) : <span className=\"opacity-20\">⇅</span>)}\n                    </div>\n                  </th>\n                ))}\n              </tr>\n            </thead>\n            <tbody className=\"divide-y divide-white/5\">\n              {paginated.length === 0 ? (\n                <tr>\n                  <td colSpan={columns.length} className=\"p-8 text-center text-white/30 text-[11px]\">\n                    No matching sovereign audit logs inside secure enclave.\n                  </td>\n                </tr>\n              ) : (\n                paginated.map((row, rIdx) => {\n                  const isSelected = selectedRow?.id === row.id;\n                  const isFocused = focusedIndex === rIdx;\n                  return (\n                    <tr \n                      key={row.id || rIdx} \n                      tabIndex={0}\n                      onClick={() => handleRowSelect(row)}\n                      onKeyDown={(e) => handleKeyDown(e, row, rIdx)}\n                      className={`transition-all outline-none cursor-pointer border-l-2 ${\n                        isSelected \n                          ? \"bg-[#009DFF]/5 border-l-[#009DFF]\" \n                          : isFocused \n                            ? \"bg-white/[0.02] border-l-white/20\" \n                            : \"hover:bg-white/[0.01] border-l-transparent\"\n                      }`}\n                    >\n                      {columns.map((col, cIdx) => (\n                        <td key={cIdx} className=\"p-3 leading-normal\">\n                          {col.render ? col.render(row) : (\n                            col.key === \"status\" || col.key === \"integrity\" || col.key === \"tier\" ? (\n                              <span className={`inline-flex px-1.5 py-0.5 rounded text-[8.5px] font-bold border tracking-wider uppercase ${getStatusStyle(String(row[col.key as keyof T]))}`}>\n                                {String(row[col.key as keyof T])}\n                              </span>\n                            ) : (\n                              String(row[col.key as keyof T] || \"-\")\n                            )\n                          )}\n                        </td>\n                      ))}\n                    </tr>\n                  );\n                })\n              )}\n            </tbody>\n          </table>\n        </div>\n\n        {/* MOBILE FALLBACK */}\n        <div className=\"block lg:hidden divide-y divide-white/5\">\n          {paginated.length === 0 ? (\n            <div className=\"p-8 text-center text-white/30 text-[11px]\">No matching records found.</div>\n          ) : (\n            paginated.map((row, rIdx) => {\n              const isSelected = selectedRow?.id === row.id;\n              const title = String(row[\"name\" as keyof T] || row[\"title\" as keyof T] || row[\"subject\" as keyof T] || row.id);\n              const status = String(row[\"status\" as keyof T] || \"\");\n              return (\n                <div \n                  key={row.id || rIdx}\n                  onClick={() => handleRowSelect(row)}\n                  className={`p-4 space-y-2 cursor-pointer border-l-2 ${isSelected ? \"bg-[#009DFF]/5 border-l-[#009DFF]\" : \"border-l-transparent hover:bg-white/[0.01]\"}`}\n                >\n                  <div className=\"flex justify-between items-start gap-2\">\n                    <div>\n                      <span className=\"text-[9px] font-mono text-[#009DFF] font-bold\">#{row.id}</span>\n                      <h4 className=\"text-[12px] font-bold text-white block mt-0.5\">{title}</h4>\n                    </div>\n                    {status && (\n                      <span className={`px-1.5 py-0.5 rounded text-[8px] font-bold border uppercase tracking-wider ${getStatusStyle(status)}`}>\n                        {status}\n                      </span>\n                    )}\n                  </div>\n                  <div className=\"grid grid-cols-2 gap-2 text-[9.5px] font-mono text-white/40\">\n                    {columns.slice(1, 3).map((col, cIdx) => (\n                      <div key={cIdx}>\n                        <span className=\"text-[8px] text-white/20 block uppercase\">{col.header}</span>\n                        <span className=\"text-white/60 block truncate\">{col.render ? \"Custom Data\" : String(row[col.key as keyof T] || \"-\")}</span>\n                      </div>\n                    ))}\n                  </div>\n                </div>\n              );\n            })\n          )}\n        </div>\n\n        {/* PAGINATION */}\n        {totalPages > 1 && (\n          <div className=\"flex justify-between items-center bg-[#070709]/60 border-t border-white/5 p-3 select-none font-mono text-[10px]\">\n            <span className=\"text-white/35\">PAGE {currentPage} OF {totalPages}</span>\n            <div className=\"flex gap-2\">\n              <button disabled={currentPage === 1} onClick={() => setCurrentPage(p => Math.max(1, p - 1))} className=\"px-2 py-0.5 rounded border border-white/5 text-white hover:bg-white/5 disabled:opacity-20 cursor-pointer\">PREV</button>\n              <button disabled={currentPage === totalPages} onClick={() => setCurrentPage(p => Math.min(totalPages, p + 1))} className=\"px-2 py-0.5 rounded border border-white/5 text-white hover:bg-white/5 disabled:opacity-20 cursor-pointer\">NEXT</button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      {/* DETAIL DRAWER */}\n      <AnimatePresence>\n        {isDrawerOpen && selectedRow && (\n          <>\n            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 0.5 }} exit={{ opacity: 0 }} className=\"fixed inset-0 bg-black z-40\" onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }} />\n            <motion.div \n              initial={{ x: \"100%\" }} animate={{ x: 0 }} exit={{ x: \"100%\" }}\n              transition={{ type: \"spring\", damping: 30, stiffness: 300 }}\n              className=\"fixed top-8 right-0 bottom-0 w-full md:w-[460px] bg-[#070709] border-l border-white/5 shadow-2xl z-50 flex flex-col pt-8 text-white\"\n            >\n              <div className=\"p-5 border-b border-white/5 flex items-center justify-between\">\n                <div>\n                  <span className=\"text-[9px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/25 px-1.5 py-0.5 rounded\">SECURE AUDIT</span>\n                  <h3 className=\"text-[13.5px] font-bold text-white mt-2 font-mono truncate max-w-[300px]\">\n                    {String(selectedRow[\"name\" as keyof T] || selectedRow[\"title\" as keyof T] || selectedRow[\"subject\" as keyof T] || `ID: ${selectedRow.id}`)}\n                  </h3>\n                </div>\n                <button onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }} className=\"p-1 rounded border border-white/5 bg-white/[0.01] hover:bg-white/5 text-white/55 cursor-pointer\"><X className=\"w-4 h-4\" /></button>\n              </div>\n\n              <div className=\"flex-grow p-5 overflow-y-auto space-y-5\">\n                <div className=\"space-y-2\">\n                  <span className=\"text-[9.5px] font-mono text-white/30 uppercase tracking-widest block font-bold\">Metadata Ledger Fields</span>\n                  <div className=\"grid grid-cols-2 gap-3 bg-white/[0.01] border border-white/5 p-3.5 rounded-lg font-mono text-[10.5px]\">\n                    {Object.keys(selectedRow)\n                      .filter(k => k !== \"logs\" && k !== \"replies\" && typeof selectedRow[k as keyof T] !== \"object\")\n                      .map((k) => (\n                        <div key={k} className=\"overflow-hidden\">\n                          <span className=\"text-[8.5px] text-white/20 uppercase block\">{k.replace(/([A-Z])/g, \" $1\")}</span>\n                          <span className=\"text-white/80 block truncate mt-0.5\">\n                            {k === \"status\" || k === \"integrity\" ? (\n                              <span className={`inline-flex px-1 rounded text-[8px] font-bold border ${getStatusStyle(String(selectedRow[k as keyof T]))}`}>{String(selectedRow[k as keyof T])}</span>\n                            ) : (\n                              String(selectedRow[k as keyof T] ?? \"-\")\n                            )}\n                          </span>\n                        </div>\n                      ))}\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[9.5px] font-mono text-white/30 uppercase tracking-widest font-bold\">Ledger Attestation Payload</span>\n                    <button \n                      onClick={() => { navigator.clipboard.writeText(JSON.stringify(selectedRow, null, 2)); setIsCopied(true); setTimeout(() => setIsCopied(false), 2000); }}\n                      className=\"text-[9.5px] text-[#009DFF] hover:underline font-mono flex items-center gap-1 cursor-pointer\"\n                    >\n                      {isCopied ? <span className=\"text-emerald-400 font-bold uppercase\">Copied</span> : <span>COPY JSON</span>}\n                    </button>\n                  </div>\n                  <div className=\"bg-[#030304] border border-white/5 rounded-lg p-3 font-mono text-[9px] text-[#009DFF]/80 max-h-40 overflow-y-auto\">\n                    <pre>{JSON.stringify({ _header: { hash: \"GFF-SHA-256\", active: true }, record: selectedRow }, null, 2)}</pre>\n                  </div>\n                </div>\n\n                <div className=\"p-3.5 rounded-lg border border-white/5 bg-gradient-to-br from-white/[0.01] to-transparent flex items-center justify-between\">\n                  <div>\n                    <h5 className=\"text-[11px] font-bold text-white font-mono\">Verify Cryptographic Integrity</h5>\n                    <p className=\"text-[9px] text-white/35 font-mono mt-0.5\">Dual-signature sandbox ledger check.</p>\n                  </div>\n                  <button \n                    onClick={() => { setVerifySuccess(true); }}\n                    disabled={verifySuccess}\n                    className={`h-7 px-2.5 rounded text-[9.5px] font-mono font-bold uppercase cursor-pointer flex items-center gap-1.5 ${verifySuccess ? \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" : \"bg-white text-black hover:bg-white/90\"}`}\n                  >\n                    <Activity className=\"w-3.5 h-3.5\" />\n                    <span>{verifySuccess ? \"VERIFIED\" : \"VERIFY\"}</span>\n                  </button>\n                </div>\n              </div>\n\n              <div className=\"p-5 border-t border-white/5 bg-black/15 flex gap-3\">\n                <button onClick={() => { setIsDrawerOpen(false); setSelectedRow(null); }} className=\"flex-grow h-9 rounded border border-white/5 text-[10.5px] font-mono font-bold uppercase text-white/70 hover:text-white hover:bg-white/5 cursor-pointer\">CLOSE</button>\n                <button onClick={() => alert(\"Cryptographically signed compliance record downloaded.\")} className=\"flex-grow h-9 rounded bg-[#009DFF] text-[10.5px] font-mono font-bold uppercase text-white hover:bg-[#008bdb] cursor-pointer flex items-center justify-center gap-1.5 shadow-[0_0_12px_rgba(0,157,255,0.2)]\">\n                  <span>EXPORT</span>\n                  <ArrowRight className=\"w-3 h-3\" />\n                </button>\n              </div>\n            </motion.div>\n          </>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"}}}
