     print(\"--------------------------------------------------\")\n244 |     print(\"      SEEDING GFF PLATFORM SYSTEM DATA             \")\n245 |     print(\"--------------------------------------------------\")\n246 |     \n247 |     # 1. Seed SQLite Database\n248 |     print(\"Initializing SQLite database...\")\n249 |     init_db()\n250 |     db = SessionLocal()\n251 |     \n252 |     now = datetime.datetime.utcnow()\n253 |     \n254 |     try:\n255 |         if reset:\n256 |             print(\"Wiping existing SQLite tables for clean slate...\")\n257 |             for model in [SystemLog, SupportTicket, GovernanceItem, Invoice, DocumentItem, AgentOperation, User, Project, ClientAccount]:\n258 |                 db.query(model).delete()\n259 |             db.commit()\n260 | \n261 |         # Seed SQLite Clients\n262 |         clients_map = {}\n263 |         for c in SEED_CLIENTS:\n264 |             existing = db.query(ClientAccount).filter_by(id=c[\"id\"]).first()\n265 |             if not existing:\n266 |                 existing = ClientAccount(\n267 |                     id=c[\"id\"],\n268 |                     name=c[\"name\"],\n269 |                     industry=c[\"industry\"],\n270 |                     region=c[\"region\"],\n271 |                     account_owner=c[\"account_owner\"]\n272 |                 )\n273 |                 db.add(existing)\n274 |                 db.commit()\n275 |                 db.refresh(existing)\n276 |             clients_map[c[\"id\"]] = existing\n277 | \n278 |         # Seed SQLite Users\n279 |         for u in SEED_USERS:\n280 |             existing = db.query(User).filter_by(email=u[\"email\"]).first()\n281 |             if not existing:\n282 |                 print(f\"Creating SQLite User: {u['email']} ({u['role']})\")\n283 |                 AuthService.create_user(\n284 |                     db, \n285 |                     UserCreate(\n286 |                         email=u[\"email\"], \n287 |                         password=u[\"password\"], \n288 |                         full_name=u[\"full_name\"], \n289 |                         role=u[\"role\"], \n290 |                         client_id=u[\"client_id\"]\n291 |                     )\n292 |                 )\n293 |                 user = db.query(User).filter_by(email=u[\"email\"]).first()\n294 |                 user.client_id = u[\"client_id\"]\n295 |                 user.name = u[\"full_name\"]\n296 |                 db.add(user)\n297 |                 db.commit()\n298 |             else:\n299 |                 existing.hashed_password = hash_password(u[\"password\"])\n300 |                 existing.client_id = u[\"client_id\"]\n301 |                 existing.name = u[\"full_name\"]\n302 |                 existing.full_name = u[\"full_name\"]\n303 |                 existing.role = u[\"role\"]\n304 |                 db.add(existing)\n305 |                 db.commit()\n306 | \n307 |         # Seed SQLite Projects\n308 |         projects_map = {}\n309 |         for p in get_seed_projects(now):\n310 |             existing = db.query(Project).filter_by(id=p[\"id\"]).first()\n311 |             if not existing:\n312 |                 existing = Project(\n313 |                     id=p[\"id\"],\n314 |                     client_id=p[\"client_id\"],\n315 |                     name=p[\"name\"],\n316 |                     phase=p[\"phase\"],\n317 |                     status=p[\"status\"],\n318 |                     health=p[\"health\"],\n319 |                     owner=p[\"owner\"],\n320 |                     progress=p[\"progress\"],\n321 |                     description=p[\"description\"]\n322 |                 )\n323 |                 db.add(existing)\n324 |                 db.commit()\n325 |                 db.refresh(existing)\n326 |             projects_map[p[\"id\"]] = existing\n327 | \n328 |         # Seed SQLite AI Operations\n329 |         for o in get_seed_ops():\n330 |             existing = db.query(AgentOperation).filter_by(id=o[\"id\"]).first()\n331 |             if not existing:\n332 |                 db.add(AgentOperation(\n333 |                     id=o[\"id\"],\n334 |                     client_id=o[\"client_id\"],\n335 |                     project_id=o[\"project_id\"],\n336 |                     name=o[\"name\"],\n337 |                     agent_type=o[\"agent_type\"],\n338 |                     status=o[\"status\"],\n339 |                     health=o[\"health\"],\n340 |                     owner=o[\"owner\"],\n341 |                     governance_status=o[\"governance_status\"]\n342 |                 ))\n343 | \n344 |         # Seed SQLite Documents Metadata\n345 |         for d in get_seed_docs(now):\n346 |             existing = db.query(DocumentItem).filter_by(id=d[\"id\"]).first()\n347 |             if not existing:\n348 |                 db.add(DocumentItem(\n349 |                     id=d[\"id\"],\n350 |                     client_id=d[\"client_id\"],\n351 |                     project_id=d[\"project_id\"],\n352 |                     title=d[\"title\"],\n353 |                     filename=d[\"filename\"],\n354 |                     document_type=d[\"document_type\"],\n355 |                     visibility=d[\"visibility\"],\n356 |                     status=d[\"status\"],\n357 |                     version=d[\"version\"],\n358 |                     owner=d[\"owner\"]\n359 |                 ))\n360 | \n361 |         # Seed SQLite Invoices\n362 |         for i in get_seed_invoices(now):\n363 |             existing = db.query(Invoice).filter_by(id=i[\"id\"]).first()\n364 |             if not existing:\n365 |                 db.add(Invoice(\n366 |                     id=i[\"id\"],\n367 |                     client_id=i[\"client_id\"],\n368 |                     project_id=i[\"project_id\"],\n369 |                     invoice_number=i[\"invoice_number\"],\n370 |                     status=i[\"status\"],\n371 |                     amount=i[\"amount\"],\n372 |                     currency=i[\"currency\"],\n373 |                     due_date=now + datetime.timedelta(days=30)\n374 |                 ))\n375 | \n376 |         # Seed SQLite Support Tickets\n377 |         for t in get_seed_tickets():\n378 |             existing = db.query(SupportTicket).filter_by(id=t[\"id\"]).first()\n379 |             if not existing:\n380 |                 db.add(SupportTicket(\n381 |                     id=t[\"id\"],\n382 |                     client_id=t[\"client_id\"],\n383 |                     project_id=t[\"project_id\"],\n384 |                     title=t[\"title\"],\n385 |                     category=t[\"category\"],\n386 |                     priority=t[\"priority\"],\n387 |                     status=t[\"status\"],\n388 |                     assigned_to=t[\"assigned_to\"],\n389 |                     created_by=t[\"created_by\"],\n390 |                     description=t[\"description\"]\n391 |                 ))\n392 | \n393 |         # Seed SQLite Governance Items\n394 |         for g in get_seed_gov():\n395 |             existing = db.query(GovernanceItem).filter_by(id=g[\"id\"]).first()\n396 |             if not existing:\n397 |                 db.add(GovernanceItem(\n398 |                     id=g[\"id\"],\n399 |                     client_id=g[\"client_id\"],\n400 |                     project_id=g[\"project_id\"],\n401 |                     title=g[\"title\"],\n402 |                     severity=g[\"severity\"],\n403 |                     status=g[\"status\"],\n404 |                     owner=g[\"owner\"],\n405 |                     due_date=now + datetime.timedelta(days=15),\n406 |                     description=g[\"description\"]\n407 |                 ))\n408 | \n409 |         db.commit()\n410 |         \n411 |         SystemLoggerService.create_log(\n412 |             db,\n413 |             SystemLogCreate(\n414 |                 level=\"INFO\",\n415 |                 message=\"SQLite database seeded with compliant GFF representative entities.\",\n416 |                 module=\"system_init\"\n417 |             )\n418 |         )\n419 |         print(\"SQLite seeding completed successfully.\")\n420 |     except Exception as e:\n421 |         print(f\"Error seeding SQLite database: {e}\")\n422 |     finally:\n423 |         db.close()\n424 | \n425 |     # 2. Seed AWS DynamoDB Tables if Environment is Configured\n426 |     seed_aws_dynamodb()\n427 | \n428 | def seed_aws_dynamodb():\n429 |     print(\"--------------------------------------------------\")\n430 |     print(\"      SEEDING AWS DYNAMODB TABLES                 \")\n431 |     print(\"--------------------------------------------------\")\n432 |     \n433 |     # Run seed only if environment is configured\n434 |     aws_access_key = os.getenv(\"AWS_ACCESS_KEY_ID\") or getattr(settings, \"AWS_ACCESS_KEY_ID\", \"\")\n435 |     aws_secret_key = os.getenv(\"AWS_SECRET_ACCESS_KEY\") or getattr(settings, \"AWS_SECRET_ACCESS_KEY\", \"\")\n436 |     region = os.getenv(\"AWS_REGION\") or getattr(settings, \"AWS_REGION\", \"us-east-1\")\n437 |     \n438 |     is_configured = (\n439 |         aws_access_key and \"placeholder\" not in aws_access_key and len(aws_access_key.strip()) > 10 and\n440 |         aws_secret_key and \"placeholder\" not in aws_secret_key and len(aws_secret_key.strip()) > 10\n441 |     )\n442 |     \n443 |     if not is_configured:\n444 |         print(\"[DYNAMODB_SEED] AWS environment keys are not configured. Skipping AWS DynamoDB seeding.\")\n445 |         return False\n446 | \n447 |     print(f\"[DYNAMODB_SEED] Detected configured AWS environment in {region}. Checking DynamoDB connection...\")\n448 |     try:\n449 |         dynamodb = boto3.resource(\n450 |             \"dynamodb\",\n451 |             region_name=region,\n452 |             aws_access_key_id=aws_access_key,\n453 |             aws_secret_access_key=aws_secret_key\n454 |         )\n455 |         \n456 |         # Access tables specified in settings\n457 |         users_table = dynamodb.Table(settings.DYNAMODB_USERS_TABLE)\n458 |         clients_table = dynamodb.Table(settings.DYNAMODB_CLIENTS_TABLE)\n459 |         items_table = dynamodb.Table(settings.DYNAMODB_ITEMS_TABLE)\n460 |         \n461 |         # Verify connectivity by checking table status\n462 |         users_table.table_status\n463 |         clients_table.table_status\n464 |         items_table.table_status\n465 |         print(\"[DYNAMODB_SEED] Successfully connected to AWS DynamoDB.\")\n466 |     except Exception as e:\n467 |         print(f\"[DYNAMODB_SEED] Error connecting to AWS DynamoDB: {e}. Cannot perform AWS seeding.\")\n468 |         return False\n469 | \n470 |     now = datetime.datetime.utcnow()\n471 |     \n472 |     # A. Seed GFF_USERS Table\n473 |     print(f\"[DYNAMODB_SEED] Seeding GFF_USERS table ({settings.DYNAMODB_USERS_TABLE})...\")\n474 |     for u in SEED_USERS:\n475 |         hashed_pass = hash_password(u[\"password\"])\n476 |         item = {\n477 |             \"email\": u[\"email\"],\n478 |             \"hashed_password\": hashed_pass,\n479 |             \"full_name\": u[\"full_name\"],\n480 |             \"name\": u[\"full_name\"],\n481 |             \"role\": u[\"role\"],\n482 |             \"status\": \"active\",\n483 |             \"client_id\": str(u[\"client_id\"]) if u[\"client_id\"] is not None else None,\n484 |             \"is_active\": True,\n485 |             \"id\": u[\"client_id\"] or 1,\n486 |             \"created_at\": now.isoformat(),\n487 |             \"updated_at\": now.isoformat()\n488 |         }\n489 |         users_table.put_item(Item=convert_floats_to_decimals(item))\n490 |         print(f\"  -> Seeded User: {u['email']}\")\n491 | \n492 |     # B. Seed GFF_CLIENTS Table\n493 |     print(f\"[DYNAMODB_SEED] Seeding GFF_CLIENTS table ({settings.DYNAMODB_CLIENTS_TABLE})...\")\n494 |     for c in SEED_CLIENTS:\n495 |         item = {\n496 |             \"client_id\": str(c[\"id\"]),\n497 |             \"name\": c[\"name\"],\n498 |             \"company_name\": c[\"name\"],\n499 |             \"industry\": c[\"industry\"],\n500 |             \"region\": c[\"region\"],\n501 |             \"status\": c[\"status\"],\n502 |             \"account_owner\": c[\"account_owner\"],\n503 |             \"created_at\": now.isoformat()\n504 |         }\n505 |         clients_table.put_item(Item=convert_floats_to_decimals(item))\n506 |         print(f\"  -> Seeded Client: {c['name']}\")\n507 | \n508 |     # C. Seed GFF_PORTAL_ITEMS Table\n509 |     print(f\"[DYNAMODB_SEED] Seeding GFF_PORTAL_ITEMS single-table ({settings.DYNAMODB_ITEMS_TABLE})...\")\n510 |     \n511 |     # C1. Projects\n512 |     for p in get_seed_projects(now):\n513 |         item = {\n514 |             \"PK\": f\"CLIENT#{p['client_id']}\",\n515 |             \"SK\": f\"PROJ#{p['id']}\",\n516 |             \"GSI1PK\": f\"PROJ#{p['id']}\",\n517 |             \"GSI1SK\": \"METADATA\",\n518 |             \"id\": p[\"id\"],\n519 |             \"client_id\": str(p[\"client_id\"]),\n520 |             \"name\": p[\"name\"],\n521 |             \"phase\": p[\"phase\"],\n522 |             \"status\": p[\"status\"],\n523 |             \"health\": p[\"health\"],\n524 |             \"owner\": p[\"owner\"],\n525 |             \"progress\": p[\"progress\"],\n526 |             \"description\": p[\"description\"],\n527 |             \"entity_type\": \"PROJECT\",\n528 |             \"created_at\": now.isoformat()\n529 |         }\n530 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n531 |         print(f\"  -> Seeded Project: {p['name']}\")\n532 | \n533 |     # C2. AI Operations\n534 |     for o in get_seed_ops():\n535 |         item = {\n536 |             \"PK\": f\"CLIENT#{o['client_id']}\",\n537 |             \"SK\": f\"AIOPS#{o['id']}\",\n538 |             \"GSI1PK\": f\"PROJ#{o['project_id']}\",\n539 |             \"GSI1SK\": f\"AIOPS#{o['id']}\",\n540 |             \"id\": o[\"id\"],\n541 |             \"client_id\": str(o[\"client_id\"]),\n542 |             \"project_id\": str(o[\"project_id\"]),\n543 |             \"name\": o[\"name\"],\n544 |             \"agent_type\": o[\"agent_type\"],\n545 |             \"status\": o[\"status\"],\n546 |             \"health\": o[\"health\"],\n547 |             \"owner\": o[\"owner\"],\n548 |             \"governance_status\": o[\"governance_status\"],\n549 |             \"entity_type\": \"AI_OPERATION\",\n550 |             \"created_at\": now.isoformat()\n551 |         }\n552 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n553 |         print(f\"  -> Seeded AI Operation: {o['name']}\")\n554 | \n555 |     # C3. Document Metadata\n556 |     for d in get_seed_docs(now):\n557 |         item = {\n558 |             \"PK\": f\"CLIENT#{d['client_id']}\",\n559 |             \"SK\": f\"DOC#{d['id']}\",\n560 |             \"GSI1PK\": f\"PROJ#{d['project_id']}\",\n561 |             \"GSI1SK\": f\"DOC#{d['id']}\",\n562 |             \"id\": d[\"id\"],\n563 |             \"client_id\": str(d[\"client_id\"]),\n564 |             \"project_id\": str(d[\"project_id\"]),\n565 |             \"title\": d[\"title\"],\n566 |             \"filename\": d[\"filename\"],\n567 |             \"document_type\": d[\"document_type\"],\n568 |             \"visibility\": d[\"visibility\"],\n569 |             \"status\": d[\"status\"],\n570 |             \"version\": d[\"version\"],\n571 |             \"owner\": d[\"owner\"],\n572 |             \"sha256\": d[\"sha256\"],\n573 |             \"fileSize\": d[\"fileSize\"],\n574 |             \"description\": d[\"description\"],\n575 |             \"lastUpdated\": d[\"lastUpdated\"],\n576 |             \"entity_type\": \"DOCUMENT\",\n577 |             \"created_at\": now.isoformat()\n578 |         }\n579 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n580 |         print(f\"  -> Seeded Document: {d['title']}\")\n581 | \n582 |     # C4. Invoices\n583 |     for i in get_seed_invoices(now):\n584 |         item = {\n585 |             \"PK\": f\"CLIENT#{i['client_id']}\",\n586 |             \"SK\": f\"INV#{i['id']}\",\n587 |             \"GSI1PK\": \"BILLING_PERIOD#2026_06\",\n588 |             \"GSI1SK\": f\"INV#{i['id']}\",\n589 |             \"id\": i[\"id\"],\n590 |             \"client_id\": str(i[\"client_id\"]),\n591 |             \"project_id\": str(i[\"project_id\"]),\n592 |             \"invoice_number\": i[\"invoice_number\"],\n593 |             \"status\": i[\"status\"],\n594 |             \"amount\": i[\"amount\"],\n595 |             \"currency\": i[\"currency\"],\n596 |             \"entity_type\": \"INVOICE\",\n597 |             \"created_at\": now.isoformat()\n598 |         }\n599 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n600 |         print(f\"  -> Seeded Invoice: {i['invoice_number']}\")\n601 | \n602 |     # C5. Support Tickets\n603 |     for t in get_seed_tickets():\n604 |         item = {\n605 |             \"PK\": f\"CLIENT#{t['client_id']}\",\n606 |             \"SK\": f\"TICKET#{t['id']}\",\n607 |             \"GSI1PK\": f\"STATUS#{t['status'].upper()}\",\n608 |             \"GSI1SK\": f\"TICKET#{t['id']}\",\n609 |             \"id\": t[\"id\"],\n610 |             \"client_id\": str(t[\"client_id\"]),\n611 |             \"project_id\": str(t[\"project_id\"]),\n612 |             \"title\": t[\"title\"],\n613 |             \"category\": t[\"category\"],\n614 |             \"priority\": t[\"priority\"],\n615 |             \"status\": t[\"status\"],\n616 |             \"assigned_to\": t[\"assigned_to\"],\n617 |             \"created_by\": t[\"created_by\"],\n618 |             \"description\": t[\"description\"],\n619 |             \"entity_type\": \"SUPPORT\",\n620 |             \"created_at\": now.isoformat()\n621 |         }\n622 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n623 |         print(f\"  -> Seeded Support Ticket: {t['title']}\")\n624 | \n625 |     # C6. Governance Items\n626 |     for g in get_seed_gov():\n627 |         item = {\n628 |             \"PK\": f\"CLIENT#{g['client_id']}\",\n629 |             \"SK\": f\"GOV#{g['id']}\",\n630 |             \"GSI1PK\": \"STANDARD#EXTERNAL\",\n631 |             \"GSI1SK\": f\"GOV#{g['id']}\",\n632 |             \"id\": g[\"id\"],\n633 |             \"client_id\": str(g[\"client_id\"]),\n634 |             \"project_id\": str(g[\"project_id\"]),\n635 |             \"title\": g[\"title\"],\n636 |             \"severity\": g[\"severity\"],\n637 |             \"status\": g[\"status\"],\n638 |             \"owner\": g[\"owner\"],\n639 |             \"description\": g[\"description\"],\n640 |             \"entity_type\": \"GOVERNANCE\",\n641 |             \"created_at\": now.isoformat()\n642 |         }\n643 |         items_table.put_item(Item=convert_floats_to_decimals(item))\n644 |         print(f\"  -> Seeded Governance Item: {g['title']}\")\n645 | \n646 |     print(\"[DYNAMODB_SEED] AWS DynamoDB seeding completed successfully.\")\n647 |     return True\n648 | \n649 | if __name__ == \"__main__\":\n650 |     parser = argparse.ArgumentParser(description=\"Seed GFF AI Platform Datasets.\")\n651 |     parser.add_argument(\"--reset\", action=\"store_true\", help=\"Reset SQLite database before seeding.\")\n652 |     args = parser.parse_args()\n653 |     seed_db(reset=args.reset)","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/docs/PHASE_6_AWS_FINAL_SETUP.md:1-EOF","result":"  1 | # GFF AI Platform: Phase 6 AWS Production Deployment & Data Modeling Guide\n  2 | \n  3 | This document defines the enterprise AWS cloud migration strategy for the **GFF AI Platform** from the local Phase 5 sandbox. It specifies the exact schemas for three required DynamoDB tables, an S3 storage bucket, and the required environment parameters.\n  4 | \n  5 | ---\n  6 | \n  7 | ## 1. Cloud-Native Serverless Architecture\n  8 | \n  9 | ```\n 10 | +------------------------------------------------------------------------------------------------+\n 11 | |                               PHASE 6 ENTERPRISE AWS TOPOLOGY                                  |\n 12 | |  [ SECURE CLIENTS ] ==( HTTPS / TLS 1.3 )==> [ API GATEWAY ] ==> [ FASTAPI ON AWS LAMBDA ]    |\n 13 | |                                                                          |                     |\n 14 | |  [ S3 STORAGE BUCKET ] <--(Presigned URLs)-------------------------------+                     |\n 15 | |  (gff-portal-documents)                                                  v                     |\n 16 | |                                                                 [ AMAZON DYNAMODB ]            |\n 17 | |                                                                 - GFF_USERS                    |\n 18 | |                                                                 - GFF_CLIENTS                  |\n 19 | |                                                                 - GFF_PORTAL_ITEMS             |\n 20 | +------------------------------------------------------------------------------------------------+\n 21 | ```\n 22 | \n 23 | ---\n 24 | \n 25 | ## 2. Production DynamoDB Data Modeling\n 26 | \n 27 | Exactly **three** DynamoDB tables are used. Complex workspace and transactional entities are modeled inside a single-table architecture (`GFF_PORTAL_ITEMS`) using custom Partition Keys (`PK`) and Sort Keys (`SK`).\n 28 | \n 29 | ### 2.1. Table Map Overview\n 30 | | Table Name | Partition Key (PK) | Sort Key (SK) | Global Secondary Index (GSI) | Purpose |\n 31 | | :--- | :--- | :--- | :--- | :--- |\n 32 | | **`GFF_USERS`** | `email` (String) | *None* | *None* | Global user registry and access credentials. |\n 33 | | **`GFF_CLIENTS`** | `client_id` (String) | *None* | *None* | Enterprise customer accounts. |\n 34 | | **`GFF_PORTAL_ITEMS`** | `PK` (String) | `SK` (String) | `GSI1` (using `GSI1PK` & `GSI1SK`) | Multi-tenant workspace record store. |\n 35 | \n 36 | ### 2.2. Table Definition: `GFF_USERS`\n 37 | *   **Table Name**: `GFF_USERS`\n 38 | *   **Primary Key**: `email` (String)\n 39 | *   **Example Item**: `{\"email\": \"admin@client.com\", \"role\": \"admin\", \"client_id\": \"client_gff_01\"}`\n 40 | \n 41 | ### 2.3. Table Definition: `GFF_CLIENTS`\n 42 | *   **Table Name**: `GFF_CLIENTS`\n 43 | *   **Primary Key**: `client_id` (String)\n 44 | *   **Example Item**: `{\"client_id\": \"client_gff_01\", \"company_name\": \"Sovereign Logistics Corp\", \"tier\": \"ENTERPRISE\"}`\n 45 | \n 46 | ### 2.4. Single-Table Definition: `GFF_PORTAL_ITEMS`\n 47 | *   **Table Name**: `GFF_PORTAL_ITEMS`\n 48 | *   **Primary Key**: `PK` (String), `SK` (String)\n 49 | *   **GSI Name**: `GSI1` (using `GSI1PK` and `GSI1SK`)\n 50 | *   **Purpose**: Single-table design housing the 6 core operational models of the GFF AI Portal.\n 51 | \n 52 | #### Entity Mappings & Storage Patterns\n 53 | \n 54 | 1. **Projects**\n 55 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `PROJ#<project_id>`\n 56 |    - **`GSI1PK`**: `PROJ#<project_id>` | **`GSI1SK`**: `METADATA`\n 57 |    - **Attributes**: `name`, `status`, `progress`, `budget`, `created_at`\n 58 | \n 59 | 2. **AI Operations**\n 60 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `AIOPS#<ops_id>`\n 61 |    - **`GSI1PK`**: `PROJ#<project_id>` (links to project) | **`GSI1SK`**: `AIOPS#<ops_id>`\n 62 |    - **Attributes**: `name`, `status`, `agent_count`, `runtime_seconds`, `cpu_usage`, `memory_usage`\n 63 | \n 64 | 3. **Documents Metadata**\n 65 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `DOC#<doc_id>`\n 66 |    - **`GSI1PK`**: `PROJ#<project_id>` (retrieves files by project) | **`GSI1SK`**: `DOC#<doc_id>`\n 67 |    - **Attributes**: `title`, `s3_key`, `file_size`, `category`, `uploaded_by`, `uploaded_at`\n 68 | \n 69 | 4. **Invoices Metadata**\n 70 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `INV#<invoice_id>`\n 71 |    - **`GSI1PK`**: `BILLING_PERIOD#<year_month>` | **`GSI1SK`**: `INV#<invoice_id>`\n 72 |    - **Attributes**: `amount_usd`, `status`, `due_date`, `epochs_consumed`, `created_at`\n 73 | \n 74 | 5. **Support Tickets**\n 75 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `TICKET#<ticket_id>`\n 76 |    - **`GSI1PK`**: `STATUS#<status_code>` (supports dashboard queues) | **`GSI1SK`**: `TICKET#<ticket_id>`\n 77 |    - **Attributes**: `subject`, `priority`, `status_text`, `assigned_to`, `created_at`\n 78 | \n 79 | 6. **Governance Items**\n 80 |    - **`PK`**: `CLIENT#<client_id>` | **`SK`**: `GOV#<gov_id>`\n 81 |    - **`GSI1PK`**: `STANDARD#<compliance_standard>` | **`GSI1SK`**: `GOV#<gov_id>`\n 82 |    - **Attributes**: `control_name`, `status`, `remediation_notes`, `assessed_at`\n 83 | \n 84 | ---\n 85 | \n 86 | ## 3. Cloud Object Storage Setup (Amazon S3)\n 87 | \n 88 | *   **Bucket Reference**: `gff-portal-documents-prod`\n 89 | *   **Security Configurations**:\n 90 |     *   **Block Public Access**: Enabled.\n 91 |     *   **Encryption at Rest**: Enforced using KMS customer-managed keys (SSE-KMS).\n 92 |     *   **Secure Transport**: Restricts transport to TLS 1.3/HTTPS.\n 93 |     *   **Presigned Access**: Frontend uploads/downloads via short-lived pre-signed URLs generated by Lambda (valid for 15 minutes).\n 94 | \n 95 | ---\n 96 | \n 97 | ## 4. Required Deployment Environment Keys\n 98 | \n 99 | ### 4.1. Next.js Frontend Keys (`.env.production`)\n100 | ```env\n101 | NEXT_PUBLIC_API_BASE_URL=https://api.gff.ai/v1\n102 | NEXT_PUBLIC_APP_ENV=production\n103 | NEXT_PUBLIC_PORTAL_UPLOADS_ENABLED=true\n104 | NEXT_PUBLIC_S3_BUCKET_NAME=gff-portal-documents-prod\n105 | ```\n106 | \n107 | ### 4.2. FastAPI AWS Backend Keys (`backend/prod.env` / Lambda Variables)\n108 | ```env\n109 | PROJECT_NAME=\"GFF AI Enterprise Cloud Engine\"\n110 | API_V1_STR=\"/api/v1\"\n111 | ENVIRONMENT=\"production\"\n112 | CORS_ORIGINS=\"https://portal.gff.ai,https://admin.gff.ai\"\n113 | FRONTEND_BASE_URL=\"https://portal.gff.ai\"\n114 | AWS_REGION=us-east-1\n115 | AWS_ACCESS_KEY_ID=production_aws_access_key_id\n116 | AWS_SECRET_ACCESS_KEY=production_aws_secret_access_key\n117 | DYNAMODB_USERS_TABLE=GFF_USERS\n118 | DYNAMODB_CLIENTS_TABLE=GFF_CLIENTS\n119 | DYNAMODB_ITEMS_TABLE=GFF_PORTAL_ITEMS\n120 | DYNAMODB_ITEMS_TYPE_INDEX=GSI1\n121 | S3_DOCUMENTS_BUCKET=gff-portal-documents-prod\n122 | S3_DOCUMENTS_PREFIX=clients\n123 | JWT_SECRET=production_cryptographically_secure_256_bit_signature_key_2026\n124 | ACCESS_TOKEN_EXPIRE_MINUTES=1440\n125 | ```\n126 | \n127 | \n128 | ---\n129 | \n130 | ## 5. Seeded User Credentials (Final MVP Data)\n131 | \n132 | The system contains exactly **four** seeded user accounts covering the three standard RBAC roles (`gff_admin`, `client_admin`, `client_member`). All passwords, roles, and client associations are modeled to enable immediate high-fidelity secure testing.\n133 | \n134 | | Role | Email | Password | Associated Client | Notes |\n135 | | :--- | :--- | :--- | :--- | :--- |\n136 | | **`gff_admin`** | `gff_admin@gff.ai` | `password123` | *None* | Global platform administrator. Accesses the GFF Admin Panel. |\n137 | | **`client_admin`** | `client_admin@apex.com` | `password123` | `Apex Global Solutions` (ID: 1) | Enterprise client administrator. Full workspace management for Client 1. |\n138 | | **`client_member`** | `client_member@apex.com` | `password123` | `Apex Global Solutions` (ID: 1) | Client 1 standard user. Limited operational access inside Client 1 workspace. |\n139 | | **`client_member`** | `client@chevron.com` | `chevron_secure_pass_2026` | `Sovereign Logistics Corp` (ID: 2) | Client 2 standard user. Used to verify cross-tenant security and upload/download boundaries in smoke tests. |\n140 | \n141 | These credentials can be used both locally (via SQLite/mock fallbacks) and in the production cloud (AWS DynamoDB) once the environment is initialized and seeded using:\n142 | ```bash\n143 | npm run backend:seed\n144 | ```\n145 | ","success":true}],"durationMs":8}}
