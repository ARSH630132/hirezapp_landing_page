id = 1\n39 | \n40 |     projects_count = db.query(Project).filter(Project.client_id == target_client_id).count()\n41 |     tickets_count = db.query(SupportTicket).filter(SupportTicket.client_id == target_client_id).count()\n42 | \n43 |     return {\n44 |         \"success\": True,\n45 |         \"client_id\": target_client_id,\n46 |         \"summary\": {\n47 |             \"projects_count\": projects_count,\n48 |             \"tickets_count\": tickets_count\n49 |         }\n50 |     }","success":true}],"durationMs":1}}
