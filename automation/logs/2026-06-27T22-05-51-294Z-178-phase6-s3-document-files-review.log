elative group\">\n107 |               <div className=\"absolute top-0 right-0 w-3 h-3 border-t border-r border-white/20 rounded-tr-2xl\" />\n108 |               <div className=\"flex items-center gap-3 mb-4\">\n109 |                 <div className=\"h-8 w-8 rounded-lg bg-[#E4000F]/5 border border-[#E4000F]/20 flex items-center justify-center\">\n110 |                   <Server className=\"w-4 h-4 text-[#E4000F]\" />\n111 |                 </div>\n112 |                 <div>\n113 |                   <h4 className=\"text-[14px] font-bold uppercase tracking-wider text-white\">Sovereign Model Enclaves</h4>\n114 |                   <span className=\"text-[9px] font-mono text-[#E4000F]\">HYPERVISOR REINFORCED / eBPF</span>\n115 |                 </div>\n116 |               </div>\n117 |               <p className=\"text-[12.5px] text-white/50 leading-relaxed font-light font-sans\">\n118 |                 The actual agent brains and workflows. Active model parameters, memory maps, and tool executables run in isolated enclaves protected by hardware seed security boundaries.\n119 |               </p>\n120 |             </div>\n121 | \n122 |           </div>\n123 |         </div>\n124 |       </section>\n125 | \n126 |       {/* 3. INTERACTIVE MODULE PREVIEW SYSTEM */}\n127 |       <section id=\"workspace-suite\" className=\"relative w-full px-6 lg:px-16 py-20 lg:py-28 overflow-hidden\">\n128 |         <div className=\"max-w-[1795px] mx-auto space-y-16\">\n129 |           \n130 |           {/* Section Heading */}\n131 |           <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-end border-b border-white/5 pb-8\">\n132 |             <div className=\"lg:col-span-8 space-y-4\">\n133 |               <span className=\"text-[11px] font-bold tracking-[0.15em] text-[#009DFF] uppercase\">\n134 |                 Interactive Suite Overview\n135 |               </span>\n136 |               <h2 className=\"text-[32px] sm:text-[44px] font-bold text-white tracking-tight leading-