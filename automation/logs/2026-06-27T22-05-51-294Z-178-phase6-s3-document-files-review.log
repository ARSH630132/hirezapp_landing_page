ole not in [\"admin\", \"gff_admin\"]:\n 91 |         if current_user.client_id is None or current_user.client_id != client_id:\n 92 |             raise HTTPException(\n 93 |                 status_code=status.HTTP_403_FORBIDDEN,\n 94 |                 detail=\"You do not have permission to upload documents for this client.\"\n 95 |             )\n 96 | \n 97 |     # Read file content\n 98 |     file_content = await file.read()\n 99 |     if not file_content:\n100 |         raise HTTPException(\n101 |             status_code=status.HTTP_400_BAD_REQUEST,\n102 |             detail=\"Uploaded file is empty.\"\n103 |         )\n104 | \n105 |     # Format filesize\n106 |     size_kb = len(file_content) / 1024\n107 |     if size_kb > 1024:\n108 |         file_size_str = f\"{size_kb / 1024:.1f} MB\"\n109 |     else:\n110 |         file_size_str = f\"{size_kb:.1f} KB\"\n111 | \n112 |     # Calculate SHA-256 for cryptographic ledger sealing\n113 |     sha256_hash = f\"0x{hashlib.sha256(file_content).hexdigest().upper()}\"\n114 | \n115 |     # Determine unique document ID\n116 |     document_id = portal_items_repo._get_next_id(\"DOCUMENT\")\n117 | \n118 |     # Upload to S3 storage manager\n119 |     s3_uri = s3_storage.upload_file(file_content, str(client_id), str(document_id), file.filename)\n120 | \n121 |     # 1. Store in SQLite for persistence\n122 |     db_doc = DocumentItem(\n123 |         id=document_id,\n124 |         client_id=client_id,\n125 |         project_id=project_id,\n126 |         title=title or file.filename,\n127 |         filename=file.filename,\n128 |         document_type=document_type or \"PDF\",\n129 |         status=\"active\",\n130 |         version=version,\n131 |         owner=current_user.full_name or current_user.email,\n132 |         visibility=visibility,\n133 |         sha256=sha256_hash,\n134 |         file_size=file_size_str,\n135 |         description=description or \"Cryptographically secured enclave system documentation.\",\n136 |         s3_uri=s3_uri\n137 |     )\n138 |     db.add(db_doc)\n139 |     db.commit()\n140 |     db.refresh(db_doc)\n141 | \n142 |     # 2. Store metadata in GFF_PORTAL_ITEMS as DOCUMENT record (DynamoDB mock)\n143 |     # This keeps our DynamoDB emulator table synchronized immediately.\n144 |     item_data = {\n145 |         \"id\": document_id,\n146 |         \"project_id\": project_id,\n147 |         \"title\": title or file.filename,\n148 |         \"filename\": file.filename,\n149 |         \"document_type\": document_type or \"PDF\",\n150 |         \"status\": \"active\",\n151 |         \"version\": version,\n152 |         \"owner\": current_user.full_name or current_user.email,\n153 |         \"visibility\": visibility,\n154 |         \"sha256\": sha256_hash,\n155 |         \"fileSize\": file_size_str,\n156 |         \"description\": description or \"Cryptographically secured enclave system documentation.\",\n157 |         \"lastUpdated\": datetime.datetime.utcnow().isoformat(),\n158 |         \"s3_uri\": s3_uri\n159 |     }\n160 |     portal_item = portal_items_repo.create_item(\"DOCUMENT\", str(client_id), item_data)\n161 | \n162 |     return {\n163 |         \"success\": True,\n164 |         \"message\": \"Document uploaded successfully.\",\n165 |         \"document\": portal_item.to_dict()\n166 |     }\n167 | \n168 | \n169 | @router.get(\"/download/{id}\")\n170 | def download_document(\n171 |     id: int,\n172 |     db = Depends(get_db),\n173 |     current_user: User = Depends(get_current_user)\n174 | ):\n175 |     \"\"\"\n176 |     Downloads file from S3 bucket with strict boundary permissions.\n177 |     \"\"\"\n178 |     documents = portal_items_repo.list_items(\"DOCUMENT\")\n179 |     doc = next((d for d in documents if str(d.id) == str(id)), None)\n180 |     if not doc:\n181 |         raise HTTPException(\n182 |             status_code=status.HTTP_404_NOT_FOUND,\n183 |             detail=\"Document not found.\"\n184 |         )\n185 | \n186 |     # Non-admin boundary validation\n187 |     if current_user.role not in [\"admin\", \"gff_admin\"]:\n188 |         if str(doc.client_id) != str(current_user.client_id):\n189 |             raise HTTPException(\n190 |                 status_code=status.HTTP_403_FORBIDDEN,\n191 |                 detail=\"Access denied. You do not have permission to download this document.\"\n192 |             )\n193 | \n194 |     # Fetch filename safely\n195 |     filename_val = getattr(doc, \"filename\", None) or getattr(doc, \"title\", \"document\")\n196 | \n197 |     try:\n198 |         # Fetch actual bytes from S3/mock store\n199 |         file_content = s3_storage.download_file(str(doc.client_id), str(doc.id), filename_val)\n200 |     except FileNotFoundError:\n201 |         raise HTTPException(\n202 |             status_code=status.HTTP_404_NOT_FOUND,\n203 |             detail=\"Document file not found in storage.\"\n204 |         )\n205 |     except Exception as e:\n206 |         raise HTTPException(\n207 |             status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n208 |             detail=f\"Storage driver exception: {str(e)}\"\n209 |         )\n210 | \n211 |     return Response(\n212 |         content=file_content,\n213 |         media_type=\"application/octet-stream\",\n214 |         headers={\"Content-Disposition\": f\"attachment; filename={filename_val}\"}\n215 |     )\n216 | ","success":true},{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/backend/app/services/s3_storage.py","result":" 1 | import os\n 2 | import boto3\n 3 | import logging\n 4 | from ..core.config import settings, BASE_DIR\n 5 | \n 6 | logger = logging.getLogger(__name__)\n 7 | \n 8 | class S3StorageManager:\n 9 |     def __init__(self):\n10 |         self.use_mock = True\n11 |         self.s3_client = None\n12 |         \n13 |         # Check if we should use real S3\n14 |         if settings.ENVIRONMENT == \"production\" or (\n15 |             os.getenv(\"AWS_ACCESS_KEY_ID\") and \n16 |     