          logger.info(f\"[S3] Uploaded file to s3://{settings.S3_DOCUMENTS_BUCKET}/{s3_key}\")\n55 |                 return f\"s3://{settings.S3_DOCUMENTS_BUCKET}/{s3_key}\"\n56 |             except Exception as e:\n57 |                 logger.error(f\"[S3] Real S3 upload failed: {e}. Falling back to mock local write.\")\n58 |                 # Fallback to mock behavior on failure\n59 |         \n60 |         # Mock behavior\n61 |         local_path = os.path.join(self.mock_dir, client_id, \"documents\", document_id, filename)\n62 |         os.makedirs(os.path.dirname(local_path), exist_ok=True)\n63 |         with open(local_path, \"wb\") as f:\n64 |             f.write(file_content)\n65 |         logger.info(f\"[S3 Mock] Uploaded file to local path {local_path}\")\n66 |         return f\"s3://{settings.S3_DOCUMENTS_BUCKET}/{s3_key}\"\n67 | \n68 |     def download_file(self, client_id: str, document_id: str, filename: str) -> bytes:\n69 |         \"\"\"\n70 |         Downloads file from S3.\n71 |         \"\"\"\n72 |         s3_key = f\"clients/{client_id}/documents/{document_id}/{filename}\"\n73 |         if not self.use_mock:\n74 |             try:\n75 |                 response = self.s3_client.get_object(\n76 |                     Bucket=settings.S3_DOCUMENTS_BUCKET,\n77 |                     Key=s3_key\n78 |                 )\n79 |                 return response[\"Body\"].read()\n80 |             except Exception as e:\n81 |                 logger.error(f\"[S3] Real S3 download failed: {e}. Falling back to mock local read.\")\n82 |                 # Fallback to mock behavior on failure\n83 |         \n84 |         # Mock behavior\n85 |         local_path = os.path.join(self.mock_dir, client_id, \"documents\", document_id, filename)\n86 |         if not os.path.exists(local_path):\n87 |             raise FileNotFoundError(f\"File not found in S3 storage (mock): {s3_key}\")\n88 |         with open(local_path, \"rb\") as f:\n89 |             return f.read()\n90 |