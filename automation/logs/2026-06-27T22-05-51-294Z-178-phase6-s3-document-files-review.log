catch (err: any) {\n      console.error(\"Error downloading document:\", err);\n      showToast(`Download failed: ${err.message}`);\n    } finally {\n      setDownloadingDocId(null);\n    }\n  };\n\n  const handleSimulatedDownload = (docId: string, title: string) => {\n    handleRealDownload(docId, title);\n  };"}}}
