      </button>\n457 |             )}\n458 |           </div>\n459 | \n460 |           {/* Controls Right Alignment: Layout Switch & Clear */}\n461 |           <div className=\"flex flex-wrap items-center gap-3 self-end xl:self-auto\">\n462 |             {hasActiveFilters && (\n463 |               <button \n464 |                 onClick={handleResetFilters}\n465 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-[11px] font-mono font-bold text-red-400 uppercase transition-all flex items-center gap-1.5 cursor-pointer\"\n466 |               >\n467 |                 <X className=\"w-3.5 h-3.5\" />\n468 |                 <span>Reset Filters</span>\n469 |               </button>\n470 |             )}\n471 | \n472 |             {/* Layout Toggler (Segmented Control style) */}\n473 |             <div className=\"flex items-center rounded-lg border border-white/5 p-1 bg-black/40\">\n474 |               <button \n475 |                 onClick={() => setLayoutMode(\"grid\")}\n476 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n477 |                   layoutMode === \"grid\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n478 |                 }`}\n479 |               >\n480 |                 <LayoutGrid className=\"w-3.5 h-3.5\" />\n481 |                 <span className=\"hidden sm:inline\">Bento Grid</span>\n482 |               </button>\n483 |               <button \n484 |                 onClick={() => setLayoutMode(\"list\")}\n485 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n486 |                   layoutMode === \"list\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n487 |                 }`}\n488 |               >\n489 |                 <List className=\"w-3.5 h-3.5\" />\n490 |                 <span className=\"hidden sm:inline\">Sovereign Ledger</span>\n491 |               </button>\n492 |             </div>\n493 | \n494 |           </div>\n495 |         </div>\n496 | \n497 |         {/* Dropdown Filters row */}\n498 |         <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 border-t border-white/5 pt-4\">\n499 |           \n500 |           {/* Category Dropdown */}\n501 |           <div className=\"space-y-1.5\">\n502 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Category</span>\n503 |             <div className=\"relative\">\n504 |               <select \n505 |                 value={selectedCategory} \n506 |                 onChange={(e) => setSelectedCategory(e.target.value)} \n507 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n508 |               >\n509 |                 <option value=\"\">ALL CATEGORIES</option>\n510 |                 {CATEGORIES.map(cat => <option key={cat} value={cat}>{cat}</option>)}\n511 |               </select>\n512 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n513 |             </div>\n514 |           </div>\n515 | \n516 |           {/* Project Dropdown */}\n517 |           <div className=\"space-y-1.5\">\n518 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Related Project</span>\n519 |             <div className=\"relative\">\n520 |               <select \n521 |                 value={selectedProject} \n522 |                 onChange={(e) => setSelectedProject(e.target.value)} \n523 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n524 |               >\n525 |                 <option value=\"\">ALL PROJECTS</option>\n526 |                 {PROJECTS.map(proj => <option key={proj} value={proj}>{proj}</option>)}\n527 |               </select>\n528 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n529 |             </div>\n530 |           </div>\n531 | \n532 |           {/* Format Dropdown */}\n533 |           <div className=\"space-y-1.5\">\n534 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Type / Format</span>\n535 |             <div className=\"relative\">\n536 |               <select \n537 |                 value={selectedFormat} \n538 |                 onChange={(e) => setSelectedFormat(e.target.value)} \n539 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n540 |               >\n541 |                 <option value=\"\">ALL FORMATS</option>\n542 |                 {FORMATS.map(fmt => <option key={fmt} value={fmt}>{fmt}</option>)}\n543 |               </select>\n544 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n545 |             </div>\n546 |           </div>\n547 | \n548 |           {/* Status Dropdown */}\n549 |           <div className=\"space-y-1.5\">\n550 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Approval Status</span>\n551 |             <div className=\"relative\">\n552 |               <select \n553 |                 value={selectedStatus} \n554 |                 onChange={(e) => setSelectedStatus(e.target.value)} \n555 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n556 |               >\n557 |                 <option value=\"\">ALL STATUSES</option>\n558 |                 {STATUSES.map(st => <option key={st} value={st}>{st}</option>)}\n559 |               </select>\n560 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n561 |             </div>\n562 |           </div>\n563 | \n564 |         </div>\n565 |       </div>\n566 | \n567 |       {/* 6. CONTENT VIEWS (CARD OR TABLE) */}\n568 |       {filteredDocuments.length === 0 ? (\n569 |         \n570 |         /* Empty Search Results state */\n571 |         <div className=\"p-12 text-center rounded-2xl border border-white/5 bg-[#050505]/20 backdrop-blur-sm max-w-xl mx-auto space-y-4\">\n572 |           <div className=\"p-4 rounded-full bg-white/[0.02] border border-white/5 inline-flex text-white/30\">\n573 |             <FolderOpen className=\"w-8 h-8\" />\n574 |           </div>\n575 |           <div className=\"space-y-1\">\n576 |             <h3 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">No Cryptographic Seals Found</h3>\n577 |             <p className=\"text-[12.5px] text-white/40 max-w-sm mx-auto font-sans leading-relaxed\">\n578 |               Your multidimensional filter query did not match any active ledger documents or system architecture plans.\n579 |             </p>\n580 |           </div>\n581 |           <button \n582 |             onClick={handleResetFilters}\n583 |             className=\"h-9 px-4 rounded-lg bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase text-white transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.15)] inline-flex items-center gap-1.5\"\n584 |           >\n585 |             <RefreshCw className=\"w-3.5 h-3.5 animate-pulse\" />\n586 |             <span>Restore Master View</span>\n587 |           </button>\n588 |         </div>\n589 | \n590 |       ) : layoutMode === \"grid\" ? (\n591 |         \n592 |         /* A: BENTO GRID VIEW */\n593 |         <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5\">\n594 |           {filteredDocuments.map((doc) => (\n595 |             <WorkspaceCard key={doc.id} className=\"flex flex-col h-[280px] justify-between border-white/[0.03] relative group hover:border-[#009DFF]/20 transition-all duration-300\">\n596 |               \n597 |               {/* Document Header details inside card */}\n598 |               <div className=\"space-y-3\">\n599 |                 <div className=\"flex justify-between items-start\">\n600 |                   <div className=\"flex items-center gap-2\">\n601 |                     <span className=\"text-[9px] font-mono font-bold bg-[#009DFF]/5 border border-[#009DFF]/20 text-[#009DFF] rounded px-1.5 py-0.5 uppercase\">\n602 |                       {doc.category}\n603 |                     </span>\n604 |                     <span className={`text-[9px] font-mono font-bold border rounded px-1.5 py-0.5 uppercase ${getStatusColor(doc.status)}`}>\n605 |                       {doc.status}\n606 |                     </span>\n607 |                   </div>\n608 |                   <span className={`text-[9px] font-mono font-bold border rounded px-1.5 py-0.5 ${getFormatBadgeColor(doc.format)}`}>\n609 |                     {doc.format}\n610 |                   </span>\n611 |                 </div>\n612 | \n613 |                 <div className=\"space-y-1\">\n614 |                   <h4 className=\"text-[13.5px] font-bold text-white tracking-tight group-hover:text-[#009DFF] transition-colors leading-snug line-clamp-2\">\n615 |                     {doc.name}\n