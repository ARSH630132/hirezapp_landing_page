       (project as any)[key] = typeof body[key] === \"string\" ? body[key].trim() : body[key];\n64 |         }\n65 |       }\n66 |     }\n67 |     project.lastUpdated = new Date().toISOString();\n68 |     (API_MOCK_PROJECTS as Record<string, ApiProject>)[id] = project;\n69 |     return NextResponse.json({ success: true, project });\n70 |   } catch (err) {\n71 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n72 |   }\n73 | }\n74 | \n75 | export async function DELETE(req: Request, { params }: { params: any }) {\n76 |   try {\n77 |     const caller = getAuthCaller(req);\n78 |     if (!caller) return NextResponse.json({ success: false, error: \"Unauthorized\" }, { status: 401 });\n79 |     if (caller.role !== \"gff_admin\") return NextResponse.json({ success: false, error: \"Forbidden\" }, { status: 403 });\n80 |     const { id } = await params;\n81 |     if (!(API_MOCK_PROJECTS as Record<string, ApiProject>)[id]) {\n82 |       return NextResponse.json({ success: false, error: \"Not Found\" }, { status: 404 });\n83 |     }\n84 |     delete (API_MOCK_PROJECTS as Record<string, ApiProject>)[id];\n85 |     return NextResponse.json({ success: true, message: \"Project deleted.\" });\n86 |   } catch (err) {\n87 |     return NextResponse.json({ success: false, error: \"Internal Server Error\" }, { status: 500 });\n88 |   }\n89 | }","success":true}],"durationMs":7}}
