06 |       consoleBottomRef.current.scrollIntoView({ behavior: \"smooth\" });\n107 |     }\n108 |   }, [telemetryLogs]);\n109 | \n110 |   const handleAuthenticate = async () => {\n111 |     setScanning(true);\n112 |     setScanStep(0);\n113 |     \n114 |     const stepIntervals = [250, 300, 350, 400];\n115 |     for (let i = 0; i < stepIntervals.length; i++) {\n116 |       await new Promise(r => setTimeout(r, stepIntervals[i]));\n117 |       setScanStep(prev => prev + 1);\n118 |     }\n119 |     \n120 |     await new Promise(r => setTimeout(r, 400));\n121 |     setScanning(false);\n122 |     setPreviewSession(selectedRole);\n123 |     \n124 |     const isGffStaff = !selectedRole.startsWith(\"client_\");\n125 |     router.push(isGffStaff ? \"/admin/dashboard\" : \"/portal/dashboard\");\n126 |   };\n127 | \n128 |   const handleSubmit = (e: React.FormEvent) => {\n129 |     e.preventDefault();\n130 |     if (authMethod === \"otp\") {\n131 |       const sanitized = otpCode.trim();\n132 |       if (!/^\\d{6}$/.test(sanitized)) {\n133 |         setError(\"MFA Validation Error: Code must be a 6-digit numeric sequence (e.g. 102486) for sandbox validation.\");\n134 |         logTelemetry(\"[ERROR] Handshake aborted: OTP code invalid or incomplete.\");\n135 |         return;\n136 |       }\n137 |     }\n138 |     setError(\"\");\n139 |     handleAuthenticate();\n140 |   };\n141 | \n142 |   const currentMockUser = MOCK_PREVIEW_USERS[selectedRole];\n143 |   const activeRoleObj = rolesList.find(r => r.id === selectedRole) || rolesList[0];\n144 | \n145 |   const scanMessages = [\n146 |     \"Establishing zero-trust gateway handshake protocol...\",\n147 |     \"Isolating browser session within local memory sandbox container...\",\n148 |     \"Exchanging SHA-256 secure tokens with crypt node gateway...\",\n149 |     \"Provisioning administrative clearance keys in sovereign database...\",\n150 |     \"Clearance successfully decrypted. Granting portal dashboard access...\"\n151 |   ];