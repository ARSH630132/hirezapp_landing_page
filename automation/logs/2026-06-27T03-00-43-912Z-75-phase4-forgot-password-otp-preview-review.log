ween\"><span className=\"uppercase\">Notice:</span> <span className=\"text-[#009DFF] font-semibold text-right\">Connected in backend phase</span></div>\n749 |                   <div className=\"flex justify-between\"><span className=\"uppercase\">Ref Hash:</span> <span className=\"text-zinc-400\">0x{getDeterministicHash(forgotEmail, 8)}</span></div>\n750 |                 </div>\n751 |                 <p className=\"text-[10px] text-zinc-500 leading-relaxed font-sans\"><span className=\"font-bold\">Honest Disclaimer:</span> This is a frontend-only design preview. Password resets and automated email alerts will be configured during the backend integration phase.</p>\n752 |                 <div className=\"flex justify-end pt-1\">\n753 |                   <button type=\"button\" onClick={() => { setShowForgot(false); setForgotSubmitted(false); setForgotEmail(\"\"); }} className=\"px-4 h-9 bg-zinc-800 hover:bg-zinc-700 text-white font-bold text-xs uppercase tracking-wider rounded-lg\">Return to Login</button>\n754 |                 </div>\n755 |               </div>\n756 |             )}\n757 |           </div>\n758 |         </div>\n759 |       )}\n760 | \n761 |       {showSupport && (\n762 |         <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/85 backdrop-blur-md p-4 animate-fade-in\" role=\"dialog\" aria-modal=\"true\">\n763 |           <div className=\"bg-zinc-950 border border-zinc-800 rounded-2xl max-w-md w-full p-6 space-y-4 shadow-2xl relative\">\n764 |             <div className=\"flex justify-between items-start\">\n765 |               <div className=\"flex items-center gap-2.5 text-zinc-200\">\n766 |                 <div className=\"p-1.5 rounded-lg bg-[#009DFF]/10 text-[#009DFF]\">\n767 |                   <HelpCircle className=\"w-5 h-5\" />\n768 |                 </div>\n769 |                 <h3 className=\"font-mono font-bold text-xs uppercase tracking-wider\">Secure Support Relay</h3>\n770 |               </div>","succe