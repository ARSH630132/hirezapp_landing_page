t(r, 1200));\n                setForgotLoading(false);\n                setForgotSubmitted(true);\n                logTelemetry(`[RECOVERY] Dispatched isolated recovery simulation to ${forgotEmail}.`);\n              }} className=\"space-y-4\">\n                <p className=\"text-xs text-zinc-400 leading-relaxed font-sans text-left\">\n                  GFF AI Zero-Trust Enclaves enforce rigorous identity safeguards. Connect to the simulation matrix and dispatch an out-of-band recovery token.\n                </p>\n                \n                <div className=\"space-y-1.5 text-left font-mono\">\n                  <label htmlFor=\"forgot-email\" className=\"text-[9.5px] text-zinc-400 uppercase tracking-widest block font-bold\">Registered Enterprise Email</label>\n                  <input \n                    id=\"forgot-email\" \n                    type=\"email\" \n                    value={forgotEmail} \n                    onChange={(e) => setForgotEmail(e.target.value)} \n                    placeholder=\"employee@gff.ai\" \n                    className=\"w-full h-11 px-3 rounded-lg bg-zinc-950 border border-zinc-800 text-zinc-200 text-xs placeholder-zinc-700 outline-none focus:border-[#009DFF] transition-all font-mono\" \n                    required \n                  />\n                </div>\n                \n                {forgotError && (\n                  <div className=\"p-2.5 bg-rose-950/20 border border-rose-900/35 text-rose-400 rounded-lg text-[11px] flex items-center gap-2 font-sans\">\n                    <AlertCircle className=\"w-4 h-4 shrink-0\" />\n                    <span>{forgotError}</span>\n                  </div>\n                )}\n                \n                <div className=\"flex justify-between items-center pt-2 gap-3 font-sans\">\n                  <button \n                    type=\"button\" \n                    onClick={() => { \n                      setShowForgot(false); \n                      setForgotSubmitted(false); \n                      setForgotEmail(\"\"); \n                    }} \n                    className=\"flex-1 h-10 bg-transparent hover:bg-zinc-900 border border-zinc-800 text-zinc-400 hover:text-white font-bold text-xs uppercase tracking-wider rounded-lg transition-colors cursor-pointer\"\n                  >\n                    Cancel\n                  </button>\n                  <button \n                    type=\"submit\" \n                    disabled={forgotLoading} \n                    className=\"flex-1 h-10 bg-[#009DFF] hover:bg-[#0086db] text-black font-bold text-xs uppercase tracking-wider rounded-lg flex items-center justify-center gap-1.5 transition-all hover:shadow-[0_0_15px_rgba(0,157,255,0.25)] active:scale-[0.98] disabled:opacity-50 disabled:pointer-events-none cursor-pointer\"\n                  >\n                    {forgotLoading ? (\n                      <>\n                        <RefreshCw className=\"w-3.5 h-3.5 animate-spin\" /> Verifying...\n                      </>\n                    ) : (\n                      <>\n                        Request Reset\n                      </>\n                    )}\n                  </button>\n                </div>\n              </form>\n            ) : (\n              <div className=\"space-y-4 text-left font-sans animate-fade-in\">\n                <div className=\"p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl text-xs flex items-start gap-3\">\n                  <CheckCircle className=\"w-5 h-5 shrink-0 mt-0.5 text-emerald-400\" />\n                  <div>\n                    <span className=\"font-bold block uppercase tracking-wider text-[10px] mb-1\">Enclave Recovery Dispatched</span>\n                    <p className=\"leading-relaxed text-zinc-300\">\n                      An out-of-band reset vector has been securely provisioned for: <span className=\"font-bold text-white select-all\">{forgotEmail}</span>\n                    </p>\n                  </div>\n                </div>\n\n                <div className=\"bg-zinc-950 p-3 rounded-xl border border-zinc-900 font-mono text-[10px] text-zinc-500 space-y-1.5\">\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"uppercase\">Notice context:</span> \n                    <span className=\"text-[#009DFF] font-semibold tracking-wider\">SANDBOX HANDSHAKE</span>\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"uppercase\">Isolated Hash:</span> \n                    <span className=\"text-zinc-400 font-mono\">0x{getDeterministicHash(forgotEmail, 8)}</span>\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"uppercase\">Active Queue:</span> \n                    <span className=\"text-emerald-400 font-bold uppercase\">Sovereign-P1</span>\n                  </div>\n                </div>\n\n                <p className=\"text-[9.5px] text-zinc-500 leading-relaxed font-sans text-left\">\n                  <span className=\"font-bold text-zinc-400\">Honest Disclaimer:</span> This interface represents a frontend-only design preview of GFF AI's secure identity recovery pipeline. No real email notifications or permanent modifications are made.\n                </p>\n\n                <div className=\"flex justify-end pt-2\">\n                  <button \n                    type=\"button\" \n                    onClick={() => { \n                      setShowForgot(false); \n                      setForgotSubmitted(false); \n                      setForgotEmail(\"\"); \n                    }} \n                    className=\"px-5 h-9 bg-zinc-900 border border-zinc-800 hover:bg-zinc-850 hover:text-white text-zinc-300 font-bold text-xs uppercase tracking-wider rounded-lg transition-colors cursor-pointer\"\n                  >\n                    Return to Login\n                  </button>\n                </div>\n              </div>\n            )}"}}}
