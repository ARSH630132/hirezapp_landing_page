400\" />\n550 |                           </>\n551 |                         )}\n552 |                       </div>\n553 |                     </button>\n554 |                   );\n555 |                 })}\n556 |               </div>\n557 |             </div>\n558 |           </div>\n559 |         </div>\n560 |       </div>\n561 |     );\n562 |   }\n563 | \n564 |   // SCREEN 2: Clearance Insufficient / Restricted Boundary (Split-Panel Layout)\n565 |   if (!hasAccess) {\n566 |     const authorizedRoles = getAuthorizedRoles();\n567 | \n568 |     return (\n569 |       <div className=\"min-h-screen grid grid-cols-1 lg:grid-cols-12 bg-[#030303] text-white font-sans antialiased selection:bg-red-500/20 selection:text-red-300\">\n570 |         \n571 |         {/* Left Side: Real-time interactive access matrix visual timeline & logs (Desktop only) */}\n572 |         <div className=\"hidden lg:flex lg:col-span-5 border-r border-white/5 bg-[#050505]/60 flex-col justify-between p-10 font-mono\">\n573 |           <div className=\"space-y-6\">\n574 |             <div className=\"flex items-center gap-2 text-white/30 text-[9px] uppercase tracking-widest font-bold\">\n575 |               <Shield className=\"w-3.5 h-3.5 text-red-500\" />\n576 |               <span>GFF Cryptographic Firewall</span>\n577 |             </div>\n578 |             \n579 |             {/* Visual Timeline of Clearance levels */}\n580 |             <div className=\"space-y-4\">\n581 |               <div className=\"text-zinc-400 text-xs font-mono font-bold tracking-wider uppercase mb-3 flex items-center gap-2\">\n582 |                 <Shield className=\"w-4 h-4 text-zinc-400\" />\n583 |                 Active Access Matrix\n584 |               </div>\n585 |               \n586 |               <div className=\"space-y-3 relative before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[1px] before:bg-white/10\">\n587 |                 {CLEARANCE_TIERS.map((tier) => {\n588 |                   const isCurrent = tier.roles.includes(session.role);\n589 |                   const isRouteAllowed = tier.roles.some(r => \n590 |                     type === \"portal\" \n591 |                       ? canAccessPortalSection(r as PreviewRole, activeSec) \n592 |                       : canAccessAdminSection(r as PreviewRole, activeSec)\n593 |                   );\n594 | \n595 |                   return (\n596 |                     <div key={tier.level} className={`flex gap-4 relative transition-all duration-300 ${isCurrent ? \"scale-[1.01] translate-x-0.5\" : \"\"}`}>\n597 |                       <div className=\"relative z-10 flex items-center justify-center\">\n598 |                         {isCurrent ? (\n599 |                           <div className=\"w-6 h-6 rounded-full bg-red-950/80 border border-red-500 flex items-center justify-center animate-pulse shadow-[0_0_12px_rgba(239,68,68,0.4)]\">\n600 |                             <span className=\"w-2 h-2 rounded-full bg-red-500\" />\n601 |                           </div>\n602 |                         ) : isRouteAllowed ? (\n603 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-900 border border-emerald-500/30 flex items-center justify-center\">\n604 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" />\n605 |                           </div>\n606 |                         ) : (\n607 |                           <div className=\"w-6 h-6 rounded-full bg-zinc-950 border border-white/10 flex items-center justify-center\">\n608 |                             <span className=\"w-1.5 h-1.5 rounded-full bg-zinc-700\" />\n609 |                           </div>\n610 |                         )}\n611 |                       </div>\n612 | \n613 |                       <div className={`flex-1 p-3.5 rounded-xl border transition-all ${\n614 |                         isCurrent \n615 |                           ? \"bg-red-500/[0.02] border-red-500/20 shadow-[0_4px_2