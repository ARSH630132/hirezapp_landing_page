 focus-visible:outline-2 focus-visible:outline-white\"\n492 |                 >\n493 |                   <Fingerprint className=\"w-3.5 h-3.5\" />\n494 |                   <span>Authenticate Manually</span>\n495 |                 </button>\n496 |               </div>\n497 |             </div>\n498 | \n499 |             {/* Simulated Workspace Quick Launch Grid */}\n500 |             <div className=\"space-y-4\">\n501 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n502 |                 <span className=\"text-[9px] font-mono text-zinc-500 font-bold uppercase tracking-widest\">\n503 |                   Quick-Authenticate Sandbox Simulation\n504 |                 </span>\n505 |                 <span className=\"text-[8px] font-mono text-cyan-400/60 font-semibold select-none\">\n506 |                   DEVELOPER BYPASS\n507 |                 </span>\n508 |               </div>\n509 |               <p className=\"text-[10px] text-zinc-500 leading-relaxed\">\n510 |                 Skip full credential checks and force-bind a mock clearance identity to instantly traverse this portal sector:\n511 |               </p>\n512 | \n513 |               <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n514 |                 {simProfiles.map((roleId) => {\n515 |                   const meta = ROLE_METADATA[roleId];\n516 |                   const isNegotiating = negotiating === roleId;\n517 | \n518 |                   return (\n519 |                     <button\n520 |                       key={roleId}\n521 |                       onClick={() => handleBypass(roleId)}\n522 |                       disabled={negotiating !== null}\n523 |                       className=\"text-left p-4 rounded-xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all duration-300 group relative overflow-hidden flex flex-col justify-between h-36 cursor-pointer hover:border-white/15 focus-visible:outline focus-visible:outline-1