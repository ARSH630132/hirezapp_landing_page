st id = `PROJ-${Math.floor(206 + Math.random() * 700)}`;\n197 |     const created: AdminProject = {\n198 |       id,\n199 |       name: newProject.name,\n200 |       client: newProject.client,\n201 |       phase: newProject.phase,\n202 |       status: newProject.status,\n203 |       owner: newProject.owner,\n204 |       nodesCount: Number(newProject.nodesCount) || 4,\n205 |       enclaveType: newProject.enclaveType,\n206 |       desc: newProject.desc,\n207 |       lastUpdated: new Date().toISOString()\n208 |     };\n209 | \n210 |     setProjects(prev => [created, ...prev]);\n211 |     setIsCreateModalOpen(false);\n212 |     \n213 |     // Reset Form\n214 |     setNewProject({\n215 |       name: \"\",\n216 |       client: AVAILABLE_CLIENTS[0],\n217 |       phase: AVAILABLE_PHASES[0],\n218 |       status: AVAILABLE_STATUSES[0],\n219 |       owner: AVAILABLE_OWNERS[0],\n220 |       nodesCount: 4,\n221 |       enclaveType: ENCLAVE_TYPES[0],\n222 |       desc: \"\"\n223 |     });\n224 | \n225 |     showToast(`Successfully registered and isolated enclave ${id}`);\n226 |   };\n227 | \n228 |   const handleEditProjectSubmit = (e: React.FormEvent) => {\n229 |     e.preventDefault();\n230 |     if (!editForm) return;\n231 | \n232 |     setProjects(prev => prev.map(p => p.id === editForm.id ? { ...editForm, lastUpdated: new Date().toISOString() } : p));\n233 |     setIsEditModalOpen(false);\n234 |     setEditForm(null);\n235 |     showToast(`Updated enclave parameter mappings for project ${editForm.id}`);\n236 |   };\n237 | \n238 |   // Memoized Filtered Projects List\n239 |   const filteredProjects = useMemo(() => {\n240 |     return projects.filter(p => {\n241 |       const query = searchQuery.trim().toLowerCase();\n242 |       const matchesSearch = query === \"\" ||\n243 |         p.name.toLowerCase().includes(query) ||\n244 |         p.id.toLowerCase().includes(query) ||\n245 |         p.owner.toLowerCase().includes(query) ||\n246 |         p.desc.toLowerCase().includes(query);\n247 | \n248 |       const matchesClient = selectedClient === \"\" || p.client === selectedClient;\n249 |       const matchesPhase = selectedPhase === \"\" || p.phase === selectedPhase;\n250 |       const matchesStatus = selectedStatus === \"\" || p.status === selectedStatus;\n251 |       const matchesOwner = selectedOwner === \"\" || p.owner === selectedOwner;\n252 | \n253 |       return matchesSearch && matchesClient && matchesPhase && matchesStatus && matchesOwner;\n254 |     });\n255 |   }, [projects, searchQuery, selectedClient, selectedPhase, selectedStatus, selectedOwner]);\n256 | \n257 |   const getStatusStyle = (status: string) => {\n258 |     switch (status) {\n259 |       case \"On Track\":\n260 |         return \"bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/15\";\n261 |       case \"At Risk\":\n262 |         return \"bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500/15\";\n263 |       case \"Delayed\":\n264 |         return \"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/15\";\n265 |       case \"Paused\":\n266 |         return \"bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/15\";\n267 |       default:\n268 |         return \"bg-white/5 border border-white/10 text-white/60 hover:bg-white/10\";\n269 |     }\n270 |   };\n271 | \n272 |   const getPhaseColor = (phase: string) => {\n273 |     switch (phase) {\n274 |       case \"Phase I: Planning\":\n275 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.6)\" };\n276 |       case \"Phase II: Sandbox Provisioning\":\n277 |         return { border: \"rgba(59, 130, 246, 0.2)\", dot: \"rgb(59, 130, 246)\" };\n278 |       case \"Phase III: Agent Alignment\":\n279 |         return { border: \"rgba(0, 157, 255, 0.3)\", dot: \"rgb(0, 157, 255)\" };\n280 |       case \"Phase IV: User Acceptance Testing\":\n281 |         return { border: \"rgba(99, 102, 241, 0.3)\", dot: \"rgb(99, 102, 241)\" };\n282 |       case \"Phase V: Production-Live\":\n283 |         return { border: \"rgba(0, 255, 194, 0.3)\", dot: \"rgb(0, 255, 194)\" };\n284 |       default:\n285 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.4)\" };\n286 |     }\n287 |   };\n288 | \n289 |   return (\n290 |     <div className=\"space-y-6\">\n291 |       {/* 1. Page Header */}\n292 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n293 |         <div>\n294 |           <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2 py-0.5 rounded uppercase tracking-wider\">\n295 |             Sovereign Admin Panel\n296 |           </span>\n297 |           <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase mt-1.5\">\n298 |             Internal Project Delivery\n299 |           </h2>\n300 |           <p className=\"text-xs text-white/50 mt-1 max-w-2xl font-mono leading-relaxed\">\n301 |             Administrative flight deck for auditing multi-agent alignment phases, cluster isolated nodes, and deployment owners across global sovereign client tenants.\n302 |           </p>\n303 |         </div>\n304 |         <div className=\"shrink-0\">\n305 |           <button\n306 |             onClick={() => setIsCreateModalOpen(true)}\n307 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n308 |           >\n309 |             <Plus className=\"w-4 h-4\" />\n310 |             <span>Create Sandbox Preview</span>\n311 |           </button>\n312 |         </div>\n313 |       </div>\n314 | \n315 |       {/* 2. Metrics Ribbon */}\n316 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 g