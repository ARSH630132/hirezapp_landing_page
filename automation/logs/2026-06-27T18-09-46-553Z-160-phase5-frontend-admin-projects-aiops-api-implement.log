Name=\"flex items-center justify-between border-b border-white/5 pb-2 select-none\">\n701 |                 <span className=\"text-[9px] font-mono text-zinc-500 font-bold uppercase tracking-widest\">\n702 |                   Resolve Access Exception\n703 |                 </span>\n704 |                 <span className=\"text-[8px] font-mono text-emerald-400 font-semibold font-bold\">\n705 |                   AVAILABLE CLEARANCES\n706 |                 </span>\n707 |               </div>\n708 |               \n709 |               <p className=\"text-[10px] text-zinc-500 leading-relaxed\">\n710 |                 Step back to segment safety, or temporarily elevate your simulated token using one of the authorized profiles for this route segment:\n711 |               </p>\n712 | \n713 |               <div className=\"space-y-2\">\n714 |                 {authorizedRoles.length > 0 ? (\n715 |                   authorizedRoles.map((roleId) => {\n716 |                     const meta = ROLE_METADATA[roleId];\n717 |                     const isNegotiating = negotiating === roleId;\n718 | \n719 |                     return (\n720 |                       <button\n721 |                         key={roleId}\n722 |                         onClick={() => handleBypass(roleId)}\n723 |                         disabled={negotiating !== null}\n724 |                         className=\"w-full text-left p-3.5 rounded-xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all duration-300 group flex items-center justify-between cursor-pointer hover:border-white/12 disabled:opacity-45 focus-visible:outline focus-visible:outline-1 focus-visible:outline-cyan-500\"\n725 |                         style={{\n726 |                           boxShadow: isNegotiating ? `0 0 20px ${meta.glowColor}` : \"none\",\n727 |                         }}\n728 |                       >\n729 |                         <div className=\"space-y-1 max-w-[70%]\">\n730 |                           <div