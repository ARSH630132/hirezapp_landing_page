{"ts":"2026-06-26T07:05:27.915Z","type":"agent_event","event":{"type":"content_end","contentType":"tool","toolName":"read_files","toolCallId":"zo0eod0e","output":[{"query":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/runtime-governance/page.tsx:100-300","result":"100 |       <InnerPageHero\n101 |         category=\"Platforms & Modules\"\n102 |         title=\"Continuous Runtime Governance and Risk Firewalls\"\n103 |         highlightedWord=\"Governance\"\n104 |         highlightColor=\"gradient\"\n105 |         description=\"Enforce strict operational boundaries, deterministic human-in-the-loop oversight, and immutable cryptographic ledgers over multi-agent workflows.\"\n106 |         breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"Runtime Governance\" }]}\n107 |       />\n108 | \n109 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n110 |         \n111 |         {/* Board Alignment Editorial Banner */}\n112 |         <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-12 border-y border-white/5 items-center bg-white/[0.01] px-8 rounded-2xl relative overflow-hidden\">\n113 |           <div className=\"absolute top-0 right-0 w-[30%] h-full bg-gradient-to-l from-[#E4000F]/5 to-transparent pointer-events-none\" />\n114 |           <div className=\"lg:col-span-5\">\n115 |             <span className=\"text-xs font-mono text-red-500 uppercase tracking-widest font-bold\">The Boardroom Challenge</span>\n116 |             <h2 className=\"text-3xl font-semibold text-white tracking-tight mt-2\">Guarding Enterprise Integrity</h2>\n117 |           </div>\n118 |           <div className=\"lg:col-span-7\">\n119 |             <p className=\"text-white/70 font-light text-sm sm:text-base leading-relaxed\">\n120 |               True corporate automation requires rigorous risk mitigation. Rather than hoping that foundational models remain safe, GFF enforces a <strong className=\"text-white font-medium\">governance-first paradigm</strong>. By isolating cognitive modeling inside secure containers and intercepting prompts and tools at the network level, we isolate threats, preserve system integrity, and provide auditability—without guaranteeing compliance or offering fake legal checklists.\n121 |             </p>\n122 |           </div>\n123 |         </MotionReveal>\n124 | \n125 |         {/* Section 1: Interactive Governance Shield Diagram */}\n126 |         <MotionReveal className=\"space-y-10\">\n127 |           <div className=\"text-center max-w-2xl mx-auto space-y-2\">\n128 |             <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">The Gatekeeper Stack</span>\n129 |             <h2 className=\"text-2xl sm:text-3xl font-bold text-white tracking-tight\">Active Sequence Flow</h2>\n130 |             <p className=\"text-white/50 text-sm font-light\">Trace the life of an execution payload from ingress interception to cryptographic archival.</p>\n131 |           </div>\n132 | \n133 |           <div className=\"bg-[#050505]/60 border border-white/5 p-6 lg:p-8 rounded-2xl shadow-xl relative overflow-hidden\">\n134 |             <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-[60%] h-[1px] bg-gradient-to-r from-transparent via-[#E4000F]/30 to-transparent\" />\n135 |             \n136 |             {/* Horizontal Timeline Graph for Desktop, Stacking on Mobile */}\n137 |             <div className=\"grid grid-cols-1 md:grid-cols-5 gap-4 relative z-10 pb-8 border-b border-white/5\">\n138 |               {GOVERNANCE_STEPS.map((step) => {\n139 |                 const isActive = step.id === activeStep;\n140 |                 return (\n141 |                   <div\n142 |                     key={step.id}\n143 |                     onClick={() => setActiveStep(step.id)}\n144 |                     className={`p-4 rounded-xl border transition-all cursor-pointer text-center group ${\n145 |                       isActive \n146 |                         ? \"border-[#E4000F] bg-[#E4000F]/5\" \n147 |                         : \"border-white/5 bg-black hover:border-white/10\"\n148 |                     }`}\n149 |                   >\n150 |                     <div className={`w-8 h-8 rounded-full mx-auto flex items-center justify-center text-xs font-bold font-mono transition-colors ${\n151 |                       isActive ? \"bg-[#E4000F] text-white\" : \"bg-white/5 text-white/50 group-hover:text-white\"\n152 |                     }`}>\n153 |                       {step.id === \"ingress\" && \"1\"}\n154 |                       {step.id === \"guardrails\" && \"2\"}\n155 |                       {step.id === \"human-loop\" && \"3\"}\n156 |                       {step.id === \"execution\" && \"4\"}\n157 |                       {step.id === \"ledger\" && \"5\"}\n158 |                     </div>\n159 |                     <h3 className=\"text-xs font-bold text-white mt-3 uppercase tracking-wider\">{step.subtitle}</h3>\n160 |                     <span className=\"text-[10px] font-mono text-white/30 block mt-1\">{step.title}</span>\n161 |                   </div>\n162 |                 );\n163 |               })}\n164 |             </div>\n165 | \n166 |             {/* Selected Step Inspector Panel */}\n167 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center pt-8 relative z-10 min-h-[160px]\">\n168 |               <div className=\"lg:col-span-8 space-y-3\">\n169 |                 <div className=\"flex items-center gap-2\">\n170 |                   <span className=\"px-2 py-0.5 rounded text-[9px] bg-[#E4000F]/15 text-[#E4000F] font-mono font-bold uppercase tracking-widest border border-[#E4000F]/20\">\n171 |                     Active Step Inspector\n172 |                   </span>\n173 |                   <span className=\"text-xs font-mono text-white/40\">{\"// SYSTEM_FLOW_\"}{activeStep.toUpperCase()}</span>\n174 |                 </div>\n175 |                 <h4 className=\"text-xl font-bold text-white tracking-tight\">{currentStepData.title} — {currentStepData.subtitle}</h4>\n176 |                 <p className=\"text-sm text-white/70 font-light leading-relaxed max-w-3xl\">{currentStepData.desc}</p>\n177 |               </div>\n178 | \n179 |               <div className=\"lg:col-span-4 flex justify-end\">\n180 |                 <div className=\"border border-white/5 bg-black/60 rounded-xl p-4 w-full max-w-[320px] font-mono text-[10px] text-white/60 space-y-1.5 shadow-inner\">\n181 |                   <div className=\"flex justify-between border-b border-white/5 pb-1\"><span className=\"text-white/40\">GATEWAY_STATUS</span><span className=\"text-emerald-400 font-bold\">SECURED</span></div>\n182 |                   <div className=\"flex justify-between\"><span className=\"text-white/40\">OVERHEAD_LATENCY</span><span className=\"text-white font-semibold\">1.8ms</span></div>\n183 |                   <div className=\"flex justify-between\"><span className=\"text-white/40\">INTERCEPT_HOOK</span><span className=\"text-[#009DFF] font-semibold\">eBPF_probe</span></div>\n184 |                   <div className=\"flex justify-between\"><span className=\"text-white/40\">INTEGRITY_SHIELD</span><span className=\"text-[#E4000F] font-semibold\">GFF_Shield_v4</span></div>\n185 |                 </div>\n186 |               </div>\n187 |             </div>\n188 |           </div>\n189 |         </MotionReveal>\n190 | \n191 |         {/* Section 2: Interactive Operational Console Tabs */}\n192 |         <MotionReveal className=\"space-y-10\">\n193 |           <div className=\"flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-white/5 pb-6\">\n194 |             <div>\n195 |               <span className=\"text-xs font-mono text-red-500 uppercase tracking-widest font-bold\">Dynamic Console</span>\n196 |               <h2 className=\"text-2xl sm:text-3xl font-bold text-white tracking-tight mt-1\">Operational Governance Centre</h2>\n197 |               <p className=\"text-white/50 text-xs sm:text-sm font-light mt-1.5 font-sans\">Simulate policy configurations, authorize pending actions, and inspect live blockchain-style hashes.</p>\n198 |             </div>\n199 | \n200 |             {/* Tab Selectors */}\n201 |             <div className=\"flex gap-1 p-1 bg-white/5 rounded-xl border border-white/10 w-full md:w-auto overflow-x-auto\">\n202 |               {[\n203 |                 { id: \"firewalls\", label: \"Risk Firewalls\", icon: <Sliders className=\"w-3.5 h-3.5\" /> },\n204 |                 { id: \"oversight\", label: \"Human Oversight\", icon: <UserCheck className=\"w-3.5 h-3.5\" /> },\n205 |                 { id: \"ledger\", label: \"Audit Ledger\", icon: <History className=\"w-3.5 h-3.5\" /> }\n206 |               ].map((t) => (\n207 |                 <button\n208 |                   key={t.id}\n209 |                   onClick={() => setActiveTab(t.id as any)}\n210 |                   className={`px-3 py-2 text-xs font-semibold rounded-lg transition-all flex items-center gap-1.5 cursor-pointer whitespace-nowrap ${\n211 |                     activeTab === t.id \n212 |                       ? \"bg-white/10 text-white shadow-sm border border-white/10\" \n213 |                       : \"text-white/50 hover:text-white\"\n214 |                   }`}\n215 |                 >\n216 |                   {t.icon}\n217 |                   {t.label}\n218 |                 </button>\n219 |               ))}\n220 |             </div>\n221 |           </div>\n222 | \n223 |           <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\">\n224 |             \n225 |             {/* Left Box: Active Tool Surface */}\n226 |             <div className=\"lg:col-span-8 bg-[#04060b] rounded-xl border border-white/10 p-6 shadow-2xl relative min-h-[360px] flex flex-col justify-between\">\n227 |               \n228 |               {/* TAB 1: RISK FIREWALLS */}\n229 |               {activeTab === \"firewalls\" && (\n230 |                 <div className=\"space-y-6\">\n231 |                   <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n232 |                     <h4 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">Active Policy Firewalls</h4>\n233 |                     <span className=\"text-[10px] font-mono text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded border border-emerald-500/20\">ACTIVE</span>\n234 |                   </div>\n235 | \n236 |                   <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n237 |                     {[\n238 |                       { id: \"pii\", title: \"PII Obfuscation Shield\", desc: \"Redacts SSNs, client names, and keys prior to prompt serialization.\", val: policies.pii },\n239 |                       { id: \"injection\", title: \"Prompt Injection Filter\", desc: \"Intercepts recursive system instruction overrides.\", val: policies.injection },\n240 |                       { id: \"boundary\", title: \"Payload Data Isolation\", desc: \"Clamps database reads to regional subnets.\", val: policies.boundary },\n241 |                       { id: \"toxicity\", title: \"Automated Toxicity Filter\", desc: \"Blocks non-professional vocabulary and tone slips.\", val: policies.toxicity }\n242 |                     ].map((p) => (\n243 |                       <div key={p.id} className=\"p-4 rounded-lg bg-black border border-white/5 flex items-start justify-between gap-4\">\n244 |                         <div className=\"space-y-1\">\n245 |                           <h5 className=\"text-xs font-semibold text-white\">{p.title}</h5>\n246 |                           <p className=\"text-[10px] text-white/40 leading-relaxed font-light\">{p.desc}</p>\n247 |                         </div>\n248 |                         <button\n249 |                           onClick={() => setPolicies(prev => ({ ...prev, [p.id]: !p.val as any }))}\n250 |                           className={`w-8 h-5 rounded-full p-0.5 relative transition-colors shrink-0 cursor-pointer ${p.val ? \"bg-[#E4000F]\" : \"bg-white/10\"}`}\n251 |                         >\n252 |                           <div className={`w-4 h-4 rounded-full bg-white transform transition-transform ${p.val ? \"translate-x-3\" : \"translate-x-0\"}`} />\n253 |                         </button>\n254 |                       </div>\n255 |                     ))}\n256 |                   </div>\n257 |                 </div>\n258 |               )}\n259 | \n260 |               {/* TAB 2: HUMAN OVERSIGHT */}\n261 |               {activeTab === \"oversight\" && (\n262 |                 <div className=\"space-y-6\">\n263 |                   <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n264 |                     <h4 className=\"text-sm font-bold text-white font-mono uppercase tracking-wider\">Pending Action Approvals</h4>\n265 |                     <span className=\"text-[10px] font-mono text-amber-400 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20\">AWAITING DECISION</span>\n266 |                   </div>\n267 | \n268 |                   <div className=\"space-y-4\">\n269 |                     {pendingActions.map((act) => (\n270 |                       <div key={act.id} className=\"p-4 rounded-lg bg-black border border-white/5 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n271 |                         <div className=\"space-y-1.5 max-w-xl\">\n272 |                           <div className=\"flex items-center gap-2\">\n273 |                             <span className=\"text-[9px] font-mono text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20 uppercase font-semibold\">{act.agent}</span>\n274 |                             <span className=\"text-[10px] font-mono text-white/30\">{act.id}</span>\n275 |                             {act.severity === \"high\" && <span className=\"text-[8px] font-mono text-red-400 bg-red-400/10 px-1 rounded uppercase border border-red-400/20\">Critical</span>}\n276 |                           </div>\n277 |                           <p className=\"text-xs text-white/80 leading-relaxed\">{act.action}</p>\n278 |                         </div>\n279 | \n280 |                         <div className=\"flex gap-2 shrink-0\">\n281 |                           {act.status === \"pending\" ? (\n282 |                             <>\n283 |                               <button\n284 |                                 onClick={() => handleAction(act.id, false)}\n285 |                                 className=\"px-2.5 py-1 text-[10px] font-bold text-red-400 border border-red-500/20 hover:bg-red-500/10 rounded cursor-pointer transition-all\"\n286 |                               >\n287 |                                 Reject\n288 |                               </button>\n289 |                               <button\n290 |                                 onClick={() => handleAction(act.id, true)}\n291 |                                 className=\"px-3 py-1 text-[10px] font-bold text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/10 rounded cursor-pointer transition-all\"\n292 |                               >\n293 |                                 Approve\n294 |                               </button>\n295 |                             </>\n296 |                           ) : (\n297 |                             <span className={`text-[10px] font-mono font-bold flex items-center gap-1 px-2 py-1 rounded ${\n298 |                               act.status === \"approved\" ? \"text-emerald-400 bg-emerald-500/5 border border-emerald-500/15\" : \"text-red-400 bg-red-500/5 border border-red-500/15\"\n299 |                             }`}>\n300 |                               {act.status === \"approved\" ? \"✓ APPROVED\" : \"✗ REJECTED\"}","success":true}],"durationMs":4}}
