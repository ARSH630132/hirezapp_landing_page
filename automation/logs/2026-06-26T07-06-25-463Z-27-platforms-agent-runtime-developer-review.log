ndboxActive((prev) => ({ ...prev, [id]: true }));\n116 |       setDeployingId(null);\n117 |     }, 1500);\n118 |   };\n119 | \n120 |   return (\n121 |     <InnerPageShell>\n122 |       <InnerPageHero\n123 |         category=\"Platforms & Modules\"\n124 |         title=\"Agent Marketplace and Enterprise Blueprint Registry\"\n125 |         highlightedWord=\"Marketplace\"\n126 |         highlightColor=\"blue\"\n127 |         description=\"Deploy verified, pre-scoped sovereign agent patterns designed for secure, autonomous operations across knowledge synthesis, deep regulatory auditing, complex supply chains, and executive decision-making.\"\n128 |         breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"Agent Marketplace\" }]}\n129 |       />\n130 | \n131 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-24\">\n132 |         \n133 |         {/* Editorial Strategy Narrative */}\n134 |         <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-12 border-y border-white/5 items-center bg-white/[0.01] px-8 rounded-2xl relative overflow-hidden\">\n135 |           <div className=\"absolute top-0 left-0 w-[30%] h-full bg-gradient-to-r from-[#009DFF]/5 to-transparent pointer-events-none\" />\n136 |           <div className=\"lg:col-span-5 relative z-10\">\n137 |             <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Standardized Autonomy</span>\n138 |             <h2 className=\"text-3xl font-semibold text-white tracking-tight mt-2\">Zero-Trust Deterministic Blueprints</h2>\n139 |           </div>\n140 |           <div className=\"lg:col-span-7 relative z-10\">\n141 |             <p className=\"text-white/70 font-light text-sm sm:text-base leading-relaxed\">\n142 |               Autonomous digital labor shouldn't be built from chaotic, unguided models. The GFF Agent Marketplace delivers certified multi-agent blueprints engineered with strict input/output schemas, static tool bindings, and integrated system-level guardrails. This eliminates hallucination risk, sandbox jailbreaks, and configuration drift, enabling immediate integration into sovereign enterprise environments.\n143 |             </p>\n144 |           </div>\n145 |         </MotionReveal>\n146 | \n147 |         {/* Core Registry Explorer Section */}\n148 |         <MotionReveal className=\"space-y-8\">\n149 |           <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-end gap-6 border-b border-white/5 pb-6\">\n150 |             <div>\n151 |               <div className=\"flex items-center gap-2 text-white/40 text-[11px] font-mono uppercase tracking-widest\">\n152 |                 <Compass className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n153 |                 Interactive Registry Explorer\n154 |               </div>\n155 |               <h2 className=\"text-2xl sm:text-3xl font-bold text-white tracking-tight mt-1\">Sovereign Patterns</h2>\n156 |               <p className=\"text-white/50 text-xs sm:text-sm font-light mt-1.5\">Select and inspect verified architectures ready for containerized sandbox deployments.</p>\n157 |             </div>\n158 |             \n159 |             {/* Horizontal Scrollable Categories Filter */}\n160 |             <div className=\"flex gap-1.5 p-1 bg-white/5 rounded-xl border border-white/10 overflow-x-auto w-full lg:w-auto scrollbar-none\">\n161 |               {CATEGORIES.map((cat) => (\n162 |                 <button\n163 |                   key={cat}\n164 |                   onClick={() => {\n165 |                     setActiveCat(cat);\n166 |                     const firstOfCat = AGENT_PATTERNS.find(a => cat === \"All\" || a.category === cat);\n167 |                     if (firstOfCat) setSelectedId(firstOfCat.id);\n168 |                   }}\n169 |                   className={`px-3 py-1.5 text-[11px] font-semibold rounded-lg transition-all cursor-pointer whitespace-nowrap ${\n170 |                     activeCat === cat \n171 |                       ? \"bg-white/10 text-white shadow-sm border border-white/10\" \n172 |                       : \"text-white/50 hover:text-white border border-transparent\"\n173 |                   }`}\n174 |                 >\n175 |                   {cat}\n176 |                 </button>\n177 |               ))}\n178 |             </div>\n179 |           </div>\n180 | \n181 |           <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch\">\n182 |             \n183 |             {/* Left side: Grid of Filtered Cards */}\n184 |             <div className=\"lg:col-span-6 grid grid-cols-1 sm:grid-cols-2 gap-4 h-fit\">\n185 |               {filtered.map((acc) => {\n186 |                 const isSelected = acc.id === selectedId;\n187 |                 const isStaged = sandboxActive[acc.id];\n188 |                 return (\n189 |                   <div\n190 |                     key={acc.id}\n191 |                     onClick={() => setSelectedId(acc.id)}\n192 |                     className={`p-6 rounded-xl border flex flex-col justify-between min-h-[220px] transition-all cursor-pointer relative group ${\n193 |                       isSelected \n194 |                         ? \"border-[#009DFF] bg-[#009DFF]/5 shadow-[0_0_20px_rgba(0,157,255,0.05)]\" \n195 |                         : \"border-white/5 bg-black/40 hover:border-white/15\"\n196 |                     }`}\n197 |                   >\n198 |                     <div>\n199 |                       <div className=\"flex justify-between items-start gap-2\">\n200 |                         <span className=\"px-2 py-0.5 rounded text-[8px] bg-white/5 text-white/50 border border-white/10 uppercase font-mono tracking-widest\">\n201 |                           {acc.category}\n202 |                         </span>\n203 |                         {isStaged ? (\n204 |                           <span className=\"text-[9px] font-mono font-bold text-green-400 flex items-center gap-1\