ient?client_id=${encodeURIComponent(clientId)}` : \"/dashboard/client\";\n200 |     return request<any>(path);\n201 |   },\n202 | };\n203 | \n204 | export const clients = {\n205 |   list: async (): Promise<{ success: boolean; clients: ClientAccount[] }> => {\n206 |     try { return await request<{ success: boolean; clients: ClientAccount[] }>(\"/clients\"); } catch {\n207 |       return {\n208 |         success: true,\n209 |         clients: [\n210 |           { id: \"client-001\", name: \"Apex Sovereign Group [Preview Client]\", status: \"active\", tier: \"Sovereign\", region: \"London\", createdAt: \"2026-01-15T08:00:00Z\" },\n211 |           { id: \"client-002\", name: \"Global Retail Enclave [Preview Client]\", status: \"active\", tier: \"Enterprise\", region: \"New York\", createdAt: \"2026-02-10T10:30:00Z\" },\n212 |           { id: \"client-003\", name: \"Sovereign Logistics Unit [Preview Client]\", status: \"active\", tier: \"Standard\", region: \"Frankfurt\", createdAt: \"2026-03-01T09:00:00Z\" },\n213 |           { id: \"client-004\", name: \"Federal Treasury Division [Preview Client]\", status: \"active\", tier: \"Sovereign\", region: \"Washington D.C.\", createdAt: \"2026-04-18T14:15:00Z\" }\n214 |         ],\n215 |       };\n216 |     }\n217 |   },\n218 |   get: async (id: string): Promise<{ success: boolean; client: ClientAccount }> => {\n219 |     try { return await request<{ success: boolean; client: ClientAccount }>(`/clients/${encodeURIComponent(id)}`); } catch {\n220 |       const res = await clients.list();","success":true}],"durationMs":1}}
