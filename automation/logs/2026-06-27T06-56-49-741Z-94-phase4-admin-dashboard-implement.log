{"ts":"2026-06-27T06:52:18.671Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"i1kr92xf","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/dashboard/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { OversightDeckTab } from \"../admin-tabs\";\n\nexport default function AdminDashboardPage() {\n  return <OversightDeckTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { Server, Activity, Clock, ShieldCheck, Search, Key, Shield, RefreshCw, Layers, Bot, MessageSquare, CreditCard, ArrowUpRight } from \"lucide-react\";\nimport { previewClientAccounts, previewProjects, previewSupportTickets, previewInvoices, previewGovernanceItems } from \"@/lib/mock-data-model\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\nexport default function AdminDashboardPage() {\n  const [q, setQ] = useState(\"\");\n  const [ack, setAck] = useState<Record<string, boolean>>({});\n  const [gov, setGov] = useState<Record<string, boolean>>({});\n  const [gpu, setGpu] = useState(78);\n  const [shell, setShell] = useState<string[]>([\n    \"SECURE CLOCK: System telemetry online. eBPF active on 18 sandbox nodes.\",\n    \"AWAITING INPUT: Command console in idle state...\"\n  ]);\n\n  const runCmd = (cmd: string, logs: string[]) => {\n    setShell([`COMMAND: ${cmd}`, ...logs]);\n  };\n\n  const filteredClients = previewClientAccounts.filter(c => c.name.toLowerCase().includes(q.toLowerCase()));\n\n  return (\n    <div className=\"space-y-6 font-mono text-[11px] text-white\">\n      {/* HEADER */}\n      <PrivatePageHeader \n        title=\"OVERSIGHT AND DELIVERY DECK\" \n        desc=\"Global delivery console for GFF internal operations. Monitor sandboxes, audit compliant ledgers, and manage SLA wires.\"\n        actions={\n          <div className=\"flex gap-2\">\n            <button onClick={() => runCmd(\"Probe Fleet\", [\"[PROBE] Client 'Sovereign Retail Group'... Verified.\", \"[PROBE] Client 'National Health'... Warn (Thread load 94%).\", \"STATUS: Complete.\"])} className=\"h-9 px-3.5 rounded border border-white/10 bg-white/[0.01] hover:bg-white/[0.03] text-[10px] font-bold uppercase transition-all cursor-pointer flex items-center gap-1\">\n              <RefreshCw className=\"w-3.5 h-3.5 text-sky-400\" /> Probe Fleet\n            </button>\n            <button onClick={() => runCmd(\"Deploy Enclave\", [\"[HSM] Generating signed hardware keys...\", \"[SGX] Provisioning Intel SGX memory...\", \"STATUS: Enclave deployed CLUSTER-GFF-099 [Active]\"])} className=\"h-9 px-3.5 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-bold uppercase flex items-center gap-1 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.2)]\">\n              Provision Node <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        }\n      />\n\n      {/* KPI STRIP */}\n      <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Active Sandboxes\", val: `${previewClientAccounts.length} Clusters`, sub: \"100% Online\", color: \"text-emerald-400\", icon: Server },\n          { label: \"eBPF Telemetry\", val: \"48 Core Loops\", sub: \"14.2ms Latency\", color: \"text-sky-400\", icon: Activity },\n          { label: \"Pending SLA\", val: `${previewSupportTickets.filter(t => !ack[t.id]).length} Wires`, sub: \"Critical countdown\", color: \"text-rose-400\", icon: Clock },\n          { label: \"ISO Governance\", val: \"100% Secure\", sub: \"0 Policy Breaches\", color: \"text-emerald-400\", icon: ShieldCheck }\n        ].map((k, idx) => {\n          const Icon = k.icon;\n          return (\n            <div key={idx} className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 flex items-center justify-between\">\n              <div className=\"space-y-0.5\">\n                <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">{k.label}</span>\n                <div className=\"text-[17px] font-bold tracking-tight\">{k.val}</div>\n                <div className={`text-[9.5px] font-bold ${k.color}`}>{k.sub}</div>\n              </div>\n              <div className=\"p-2 bg-white/[0.01] border border-white/5 text-white/30 rounded\"><Icon className=\"w-4 h-4\" /></div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* BENTO GRID */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n        \n        {/* 1. CLIENTS OVERVIEW */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><Users className=\"w-4 h-4 text-[#009DFF]\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">Clients Overview</h3></div>\n            <div className=\"relative\">\n              <Search className=\"absolute left-2 top-2 w-3 h-3 text-white/35\" />\n              <input type=\"text\" placeholder=\"Filter...\" value={q} onChange={(e) => setQ(e.target.value)} className=\"w-24 h-7 pl-6 pr-2 rounded border border-white/5 bg-black/40 text-[9.5px] focus:outline-none\" />\n            </div>\n          </div>\n          <div className=\"space-y-2.5 max-h-[190px] overflow-y-auto pr-1\">\n            {filteredClients.map(c => (\n              <div key={c.id} className=\"flex justify-between items-center p-2 rounded bg-white/[0.01] border border-white/5 hover:border-white/10 transition-all\">\n                <div>\n                  <span className=\"font-bold text-white block truncate max-w-[140px]\">{c.name}</span>\n                  <span className=\"text-[9px] text-white/30\">{c.region}</span>\n                </div>\n                <span className=\"text-[9px] text-[#009DFF] border border-[#009DFF]/20 px-1.5 py-0.5 rounded bg-[#009DFF]/5 font-bold uppercase\">{c.tier}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* 2. ACTIVE PROJECTS */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><Layers className=\"w-4 h-4 text-purple-400\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">Active Projects</h3></div>\n            <span className=\"text-[9px] text-white/35\">LATTICE</span>\n          </div>\n          <div className=\"space-y-2.5 max-h-[190px] overflow-y-auto pr-1\">\n            {previewProjects.slice(0, 3).map(p => (\n              <div key={p.id} className=\"p-2.5 rounded bg-white/[0.01] border border-white/5 space-y-1\">\n                <div className=\"flex justify-between items-center\"><span className=\"font-bold text-white truncate max-w-[150px]\">{p.name}</span><span className=\"text-[8.5px] text-[#00FFC2] font-semibold\">{p.nodesCount} Nodes</span></div>\n                <div className=\"flex justify-between text-[8.5px] text-white/40\"><span>{p.enclaveType}</span><span className=\"text-emerald-400 font-bold uppercase\">{p.status}</span></div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* 3. AI OPERATIONS */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><Bot className=\"w-4 h-4 text-emerald-400\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">AI Operations</h3></div>\n            <span className=\"text-emerald-400 text-[9px] font-bold\">LATTICE UP</span>\n          </div>\n          <div className=\"space-y-2.5 text-[10px]\">\n            <div className=\"p-2.5 rounded bg-black/20 border border-white/5 flex justify-between\">\n              <div><span className=\"text-white/35 block text-[8px] uppercase\">Active model</span><span className=\"text-white font-bold\">GFF-Llama-70B-Gov</span></div>\n              <div className=\"text-right\"><span className=\"text-white/35 block text-[8px] uppercase\">Allocated GPU</span><span className=\"text-[#009DFF] font-bold\">{gpu}%</span></div>\n            </div>\n            <div className=\"grid grid-cols-2 gap-2\">\n              <button onClick={() => { setGpu(42); runCmd(\"Purge Cache\", [\"Context memory cleared.\", \"Reduced GPU allocation index to 42%.\"]); }} className=\"h-7.5 text-[9px] font-bold uppercase rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all cursor-pointer\">Wipe Cache</button>\n              <button onClick={() => runCmd(\"Recalibrate Model\", [\"Optimized GPU neural parameters.\", \"Set model temperature line to 0.00.\"])} className=\"h-7.5 text-[9px] font-bold uppercase rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 hover:bg-[#009DFF]/15 transition-all cursor-pointer\">Calibrate</button>\n            </div>\n          </div>\n        </div>\n\n        {/* 4. PENDING SUPPORT TICKETS */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><MessageSquare className=\"w-4 h-4 text-rose-400\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">Priority SLA Wires</h3></div>\n            <span className=\"text-rose-400 text-[9px] animate-pulse\">SLA ACTIVE</span>\n          </div>\n          <div className=\"space-y-2.5\">\n            {previewSupportTickets.slice(0, 2).map(t => {\n              const isAck = ack[t.id];\n              return (\n                <div key={t.id} className={`p-2.5 rounded border ${isAck ? \"border-white/5 opacity-60\" : \"bg-rose-500/5 border-rose-500/10\"} space-y-1`}>\n                  <div className=\"flex justify-between text-[8.5px]\"><span className=\"text-white/40\">{t.id}</span><span className=\"text-rose-400 font-bold\">{isAck ? \"ACKED\" : \"00h:14m:22s\"}</span></div>\n                  <h4 className=\"font-bold text-white uppercase leading-tight truncate\">{t.title}</h4>\n                  {!isAck && <button onClick={() => { setAck(p => ({ ...p, [t.id]: true })); runCmd(\"Ack Ticket\", [`SLA wire ticket ${t.id} has been acknowledged.`]); }} className=\"h-5 px-2 mt-1 rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 hover:bg-[#009DFF]/20 text-[8.5px] font-bold uppercase cursor-pointer\">Ack SLA</button>}\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* 5. BILLING STATUS */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><CreditCard className=\"w-4 h-4 text-[#009DFF]\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">Cryptographic Ledger</h3></div>\n            <span className=\"text-white/35 text-[9px]\">GFF_FIN</span>\n          </div>\n          <div className=\"space-y-2 max-h-[160px] overflow-y-auto\">\n            {previewInvoices.slice(0, 3).map(inv => (\n              <div key={inv.id} className=\"p-2 rounded border border-white/5 bg-black/10 space-y-1 text-[9.5px]\">\n                <div className=\"flex justify-between font-bold text-white\"><span>{inv.id}</span><span className=\"text-[#009DFF]\">{inv.amount}</span></div>\n                <div className=\"flex justify-between text-[8px] text-white/30 truncate\">SEAL: {inv.hash.substring(0, 16)}...</div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* 6. GOVERNANCE ALERTS */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <div className=\"flex items-center gap-1.5\"><Shield className=\"w-4 h-4 text-red-400 animate-pulse\" /> <h3 className=\"text-xs font-bold uppercase tracking-wider\">Governance Alerts</h3></div>\n            <span className=\"text-red-400 text-[8px] font-bold\">ALARM</span>\n          </div>\n          <div className=\"space-y-2\">\n            {previewGovernanceItems.slice(0, 2).map((item, idx) => {\n              const isWarning = idx === 1;\n              const isResolved = gov[item.id];\n              return (\n                <div key={item.id} className={`p-2.5 rounded border ${isResolved ? \"opacity-50\" : isWarning ? \"bg-amber-500/5 border-amber-500/15\" : \"bg-red-500/5 border-red-500/10\"}`}>\n                  <div className=\"flex justify-between items-start gap-1\">\n                    <div className=\"space-y-0.5\">\n                      <span className=\"font-bold text-white text-[9.5px] block\">{item.standard}</span>\n                      <p className=\"text-[9px] text-white/60 leading-tight\">{item.name}</p>\n                    </div>\n                    {!isResolved && (\n                      <button onClick={() => { setGov(p => ({ ...p, [item.id]: true })); runCmd(\"Verify Policy\", [`ISO check manual override confirmed for ${item.standard}.`]); }} className=\"h-5 px-1.5 rounded bg-white/5 border border-white/10 hover:border-sky-500 text-[8.5px] cursor-pointer\">Verify</button>\n                    )}\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </div>\n\n      </div>\n\n      {/* OPERATIONS CONSOLE TERMINAL OUTPUT */}\n      <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-5 space-y-3\">\n        <div className=\"flex justify-between border-b border-white/5 pb-2\">\n          <h3 className=\"text-xs font-bold uppercase tracking-wider text-white\">Operations Console Shell</h3>\n          <button onClick={() => runCmd(\"System Lockdown\", [\"⚠️ EMERGENCY LOCKDOWN PROTOCOLS TRIGGERED.\", \"[SHIELD] Severing external API routes...\", \"STATUS:local enclaves isolated.\"])} className=\"h-6 px-3.5 rounded bg-rose-500/10 hover:bg-rose-500/20 text-red-400 border border-red-500/20 text-[9px] font-bold uppercase cursor-pointer\">Lockdown Enclaves</button>\n        </div>\n        <div className=\"p-3 bg-zinc-950 border border-zinc-900 rounded-lg space-y-1 h-[90px] overflow-y-auto leading-relaxed select-text\">\n          {shell.map((log, idx) => (\n            <div key={idx} className=\"flex gap-1.5 items-start font-mono text-zinc-400 text-[9.5px]\">\n              <CornerDownRight className=\"w-3.5 h-3.5 text-[#009DFF] shrink-0 mt-0.5\" />\n              <span>{log}</span>\n            </div>\n          ))}\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
