{"ts":"2026-06-27T06:51:50.423Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"rrc1z34p","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/admin/dashboard/page.tsx","old_text":"\"use client\";\n\nimport React from \"react\";\nimport { OversightDeckTab } from \"../admin-tabs\";\n\nexport default function AdminDashboardPage() {\n  return <OversightDeckTab />;\n}","new_text":"\"use client\";\n\nimport React, { useState } from \"react\";\nimport { \n  Activity, Shield, Users, Layers, Bot, MessageSquare, CreditCard, \n  ShieldCheck, ArrowUpRight, Check, AlertCircle, RefreshCw, Server, \n  Clock, Lock, CornerDownRight, Zap, Key, Eye, X\n} from \"lucide-react\";\nimport Link from \"next/link\";\nimport { \n  previewClientAccounts, \n  previewProjects, \n  previewSupportTickets, \n  previewInvoices, \n  previewGovernanceItems,\n  ClientAccount\n} from \"@/lib/mock-data-model\";\nimport { PrivatePageHeader } from \"@/components/private-app\";\n\nexport default function AdminDashboardPage() {\n  // 1. STATE INITIALIZATION\n  const [searchQuery, setSearchQuery] = useState(\"\");\n  const [selectedClient, setSelectedClient] = useState<ClientAccount | null>(null);\n  const [ackTickets, setAckTickets] = useState<Record<string, boolean>>({});\n  const [resolvedGov, setResolvedGov] = useState<Record<string, boolean>>({});\n  const [gpuLoad, setGpuLoad] = useState(78);\n  const [isCalibrating, setIsCalibrating] = useState(false);\n  const [terminalLogs, setTerminalLogs] = useState<string[]>([\n    \"SECURE DECK: Multi-enclave telemetry stream online.\",\n    \"eBPF KERNEL: Continuous compliance tracking active on 18 nodes.\",\n    \"AWAITING INPUT: Command console in idle state...\"\n  ]);\n  const [isTerminalRunning, setIsTerminalRunning] = useState(false);\n\n  // Helper for dynamic terminal logging\n  const runSimulatedTask = (cmd: string, stepLogs: string[]) => {\n    if (isTerminalRunning) return;\n    setIsTerminalRunning(true);\n    setTerminalLogs([`COMMAND INITIATED: ${cmd}`, \"INITIALIZING ZERO-TRUST HANDSHAKE...\"]);\n    \n    stepLogs.forEach((log, index) => {\n      setTimeout(() => {\n        setTerminalLogs(prev => [...prev, log]);\n        if (index === stepLogs.length - 1) {\n          setIsTerminalRunning(false);\n        }\n      }, (index + 1) * 400);\n    });\n  };\n\n  const handleProbeFleet = () => {\n    runSimulatedTask(\"Fleet-Wide Telemetry Scan\", [\n      \"[PROBE] Scanning client 'Sovereign Retail Group'... Verified.\",\n      \"[PROBE] Scanning client 'National Health Enclave'... Thread warning (94%).\",\n      \"[PROBE] eBPF virtual telemetry stream synchronized (14.2ms).\",\n      \"STATUS: Diagnostic check complete. Fleet is stable.\"\n    ]);\n  };\n\n  const handleProvisionNode = () => {\n    runSimulatedTask(\"Provision Ephemeral Enclave\", [\n      \"[HSM] Generating hardware crypt keys signed via root seal...\",\n      \"[SGX] Reserving Intel SGX physical partition memory blocks...\",\n      \"[NET] Direct multi-socket TLS 1.3 tunnels established.\",\n      \"STATUS: Ephemeral enclave deployed successfully: CLUSTER-GFF-099 [Active]\"\n    ]);\n  };\n\n  const handleLockdown = () => {\n    runSimulatedTask(\"EMERGENCY LOCKED BLOCK\", [\n      \"⚠️ EXECUTING ENCLAVE ISOLATION PROCESSES...\",\n      \"[SHIELD] Decoupling client sandbox virtual instances...\",\n      \"[SHIELD] Erasing active GPU model thread weights...\",\n      \"⚠️ STATUS: Lockout complete. local nodes in safe read-only backup state.\"\n    ]);\n  };\n\n  // Filter clients\n  const filteredClients = previewClientAccounts.filter(c => \n    c.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n    c.region.toLowerCase().includes(searchQuery.toLowerCase())\n  );\n\n  return (\n    <div className=\"space-y-6 select-none relative font-mono text-[11px] text-white\">\n      {/* HEADER */}\n      <PrivatePageHeader \n        title=\"OVERSIGHT AND DELIVERY PORTAL\" \n        desc=\"Centralized oversight panel for verifying isolated enclaves, auditing compliance ledgers, and answering technical wires.\"\n        actions={\n          <div className=\"flex items-center gap-2\">\n            <button \n              onClick={handleProbeFleet}\n              disabled={isTerminalRunning}\n              className=\"h-9 px-3.5 rounded border border-white/10 bg-white/[0.01] text-[10px] font-bold uppercase hover:bg-white/[0.03] active:scale-95 transition-all flex items-center gap-1.5 cursor-pointer disabled:opacity-40\"\n            >\n              <RefreshCw className={`w-3.5 h-3.5 ${isTerminalRunning ? \"animate-spin text-sky-400\" : \"\"}`} />\n              <span>Probe Fleet</span>\n            </button>\n            <button \n              onClick={handleProvisionNode}\n              disabled={isTerminalRunning}\n              className=\"h-9 px-3.5 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[10px] font-bold uppercase text-white flex items-center gap-1.5 active:scale-95 transition-all cursor-pointer shadow-[0_0_15px_rgba(0,157,255,0.2)] disabled:opacity-40\"\n            >\n              <span>Provision Node</span>\n              <ArrowUpRight className=\"w-3.5 h-3.5\" />\n            </button>\n          </div>\n        }\n      />\n\n      {/* KPI STRIP */}\n      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n        {[\n          { label: \"Active Sandboxes\", val: `${previewClientAccounts.length} Clusters`, sub: \"100% ONLINE\", color: \"text-emerald-400\", icon: Server },\n          { label: \"eBPF Telemetry\", val: \"48 Active Loops\", sub: \"14.2ms Latency\", color: \"text-sky-400\", icon: Activity },\n          { label: \"Pending SLA\", val: `${previewSupportTickets.filter(t => !ackTickets[t.id]).length} Wires`, sub: \"Critical Countdown\", color: \"text-rose-400\", icon: Clock },\n          { label: \"ISO Compliance\", val: \"100% AUDITED\", sub: \"Zero Breaches\", color: \"text-emerald-400\", icon: ShieldCheck }\n        ].map((kpi, idx) => {\n          const Icon = kpi.icon;\n          return (\n            <div key={idx} className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-4 flex items-center justify-between\">\n              <div className=\"space-y-0.5\">\n                <span className=\"text-[9px] text-white/35 uppercase tracking-wider block\">{kpi.label}</span>\n                <div className=\"text-[18px] font-bold tracking-tight text-white\">{kpi.val}</div>\n                <div className={`text-[10px] font-bold ${kpi.color}`}>{kpi.sub}</div>\n              </div>\n              <div className=\"p-2.5 rounded-lg bg-white/[0.02] border border-white/5 text-white/40\">\n                <Icon className=\"w-4.5 h-4.5\" />\n              </div>\n            </div>\n          );\n        })}\n      </div>\n\n      {/* BENTO GRID */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* LEFT COLUMN (2/3 col span) */}\n        <div className=\"lg:col-span-2 space-y-6\">\n          \n          {/* CLIENTS OVERVIEW PANEL */}\n          <div className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-4\">\n            <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-white/5 pb-3\">\n              <div>\n                <h3 className=\"text-xs font-bold uppercase tracking-wider text-white\">Enterprise Clients & Nodes</h3>\n                <p className=\"text-[10px] text-white/40 mt-0.5\">Hardware isolation mode parameters and active node telemetry.</p>\n              </div>\n              <div className=\"relative\">\n                <Search className=\"absolute left-2.5 top-2 w-3.5 h-3.5 text-white/35\" />\n                <input \n                  type=\"text\" \n                  placeholder=\"Filter client...\" \n                  value={searchQuery}\n                  onChange={(e) => setSearchQuery(e.target.value)}\n                  className=\"w-full sm:w-44 h-7.5 pl-8 pr-3 rounded border border-white/5 bg-black/40 text-[10.5px] text-white focus:outline-none focus:border-[#009DFF]/30 transition-colors\"\n                />\n              </div>\n            </div>\n\n            <div className=\"overflow-x-auto\">\n              <table className=\"w-full text-left border-collapse text-[10.5px]\">\n                <thead>\n                  <tr className=\"border-b border-white/5 text-[9px] text-white/30 uppercase tracking-widest font-semibold\">\n                    <th className=\"pb-2\">Client Enclave</th>\n                    <th className=\"pb-2\">Active Sandboxes</th>\n                    <th className=\"pb-2\">Security Tier</th>\n                    <th className=\"pb-2 text-right\">Action</th>\n                  </tr>\n                </thead>\n                <tbody className=\"divide-y divide-white/[0.02]\">\n                  {filteredClients.map(client => {\n                    const projs = previewProjects.filter(p => p.clientAccountId === client.id);\n                    return (\n                      <tr key={client.id} className=\"hover:bg-white/[0.01] transition-all\">\n                        <td className=\"py-2.5\">\n                          <span className=\"font-bold text-white block text-[11px]\">{client.name}</span>\n                          <span className=\"text-[9.5px] text-white/35\">{client.domain}</span>\n                        </td>\n                        <td className=\"py-2.5\">\n                          <span className=\"inline-flex h-4 px-1.5 items-center justify-center rounded bg-sky-500/10 border border-sky-500/20 text-[9px] font-bold text-[#009DFF]\">\n                            {projs.length} Nodes\n                          </span>\n                        </td>\n                        <td className=\"py-2.5\">\n                          <span className=\"text-[10px] text-purple-400 font-bold\">{client.tier}</span>\n                        </td>\n                        <td className=\"py-2.5 text-right\">\n                          <button \n                            onClick={() => setSelectedClient(client)}\n                            className=\"h-6.5 px-2 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] text-white/60 transition-colors cursor-pointer\"\n                          >\n                            Inspect\n                          </button>\n                        </td>\n                      </tr>\n                    );\n                  })}\n                </tbody>\n              </table>\n            </div>\n          </div>\n\n          {/* AI OPERATIONS OVERVIEW PANEL */}\n          <div className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-4\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n              <div>\n                <h3 className=\"text-xs font-bold uppercase tracking-wider text-white\">Sovereign AI Operations Monitor</h3>\n                <p className=\"text-[10px] text-white/40 mt-0.5\">Calibrate parameter parameters and clean isolated context memory.</p>\n              </div>\n              <span className=\"text-emerald-400 text-[9px] font-bold flex items-center gap-1\">\n                <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n                LATTICE UP\n              </span>\n            </div>\n\n            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n              <div className=\"p-3.5 rounded bg-black/20 border border-white/5 space-y-2\">\n                <span className=\"text-[9px] text-white/35 uppercase tracking-wider block font-bold\">Dynamic Weight</span>\n                <div className=\"space-y-1 text-[10.5px]\">\n                  <div className=\"flex justify-between\"><span>Inference Temp:</span><span className=\"text-[#00FFC2] font-bold\">0.15</span></div>\n                  <div className=\"flex justify-between\"><span>Core Threading:</span><span className=\"text-white font-bold\">12 Cores</span></div>\n                  <div className=\"flex justify-between\"><span>Memory Cap:</span><span className=\"text-white font-bold\">6.2 GB</span></div>\n                </div>\n              </div>\n\n              <div className=\"p-3.5 rounded bg-black/20 border border-white/5 space-y-2\">\n                <div className=\"flex justify-between items-center\">\n                  <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-bold\">GPU Allocate</span>\n                  <span className=\"text-[#009DFF] font-bold\">{gpuLoad}%</span>\n                </div>\n                <div className=\"h-1.5 w-full bg-black/40 rounded overflow-hidden border border-white/5\">\n                  <div className=\"h-full bg-gradient-to-r from-[#009DFF] to-cyan-400 transition-all duration-500\" style={{ width: `${gpuLoad}%` }} />\n                </div>\n                <span className=\"text-[8px] text-white/20 block\">Sandbox isolated context ceiling.</span>\n              </div>\n\n              <div className=\"p-3.5 rounded bg-black/20 border border-white/5 flex flex-col justify-between\">\n                <span className=\"text-[9px] text-white/35 uppercase tracking-wider font-bold block\">Enclave Actions</span>\n                <div className=\"grid grid-cols-2 gap-2 mt-2\">\n                  <button \n                    onClick={() => {\n                      setGpuLoad(42);\n                      setTerminalLogs(prev => [...prev, \"[gff-ops] Context memory cache successfully wiped. Load reduced to 42%.\"]);\n                    }}\n                    className=\"h-7 text-[9px] font-bold uppercase rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all cursor-pointer\"\n                  >\n                    Wipe cache\n                  </button>\n                  <button \n                    onClick={() => {\n                      setIsCalibrating(true);\n                      setTimeout(() => {\n                        setIsCalibrating(false);\n                        setTerminalLogs(prev => [...prev, \"[gff-ops] Recalibrated GFF weights. Deterministic temp aligned.\"]);\n                      }, 1000);\n                    }}\n                    disabled={isCalibrating}\n                    className=\"h-7 text-[9px] font-bold uppercase rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 hover:bg-[#009DFF]/20 transition-all cursor-pointer disabled:opacity-40\"\n                  >\n                    {isCalibrating ? \"Aligning...\" : \"Calibrate\"}\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* RIGHT COLUMN (1/3 col span) */}\n        <div className=\"space-y-6\">\n          \n          {/* GOVERNANCE ALERTS */}\n          <div className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-3\">\n            <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n              <h3 className=\"text-xs font-bold uppercase tracking-wider text-white\">Governance Alerts</h3>\n              <span className=\"h-4.5 px-1.5 rounded bg-red-500/10 border border-red-500/20 text-[8.5px] font-bold text-red-400 flex items-center justify-center animate-pulse\">\n                ALARM\n              </span>\n            </div>\n\n            <div className=\"space-y-2.5\">\n              {previewGovernanceItems.slice(0, 3).map((item, idx) => {\n                const isWarning = idx === 1;\n                const isResolved = resolvedGov[item.id];\n                \n                return (\n                  <div key={item.id} className={`p-3 rounded border transition-all ${isResolved ? \"border-white/5 opacity-50 bg-black/10\" : isWarning ? \"bg-amber-500/5 border-amber-500/15\" : \"bg-red-500/5 border-red-500/10\"}`}>\n                    <div className=\"flex items-start justify-between gap-2\">\n                      <div className=\"space-y-0.5\">\n                        <span className={`h-1 w-1 rounded-full inline-block mr-1 ${isResolved ? \"bg-emerald-500\" : isWarning ? \"bg-amber-400\" : \"bg-red-500\"}`} />\n                        <span className=\"font-bold text-white text-[10px]\">{item.standard}</span>\n                        <p className=\"text-[9.5px] text-white/60 leading-tight\">{item.name}</p>\n                      </div>\n                      {!isResolved && (\n                        <button \n                          onClick={() => {\n                            setResolvedGov(prev => ({ ...prev, [item.id]: true }));\n                            setTerminalLogs(prev => [...prev, `[GOV] Policy check manually verified: ${item.standard}`]);\n                          }}\n                          className=\"h-5 px-1.5 rounded bg-white/5 border border-white/10 hover:border-sky-500/30 text-[9px] transition-colors cursor-pointer\"\n                        >\n                          Verify\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n\n          {/* SLA WIRES SUPPORT */}\n          <div className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-3\">\n            <h3 className=\"text-xs font-bold uppercase tracking-wider text-white border-b border-white/5 pb-2\">Priority SLA Support Wires</h3>\n            <div className=\"space-y-2.5\">\n              {previewSupportTickets.slice(0, 2).map((ticket) => {\n                const isAck = ackTickets[ticket.id];\n                return (\n                  <div key={ticket.id} className={`p-3 rounded border transition-all ${isAck ? \"border-white/5 opacity-60 bg-black/10\" : \"bg-rose-500/5 border-rose-500/10\"} space-y-1.5`}>\n                    <div className=\"flex items-center justify-between text-[9px]\">\n                      <span className=\"text-[#009DFF] font-bold\">{ticket.id}</span>\n                      <span className=\"text-rose-400 font-bold\">{isAck ? \"ACKNOWLEDGED\" : \"00h:14m:22s\"}</span>\n                    </div>\n                    <h4 className=\"text-[10.5px] font-bold text-white uppercase leading-tight line-clamp-1\">{ticket.title}</h4>\n                    <p className=\"text-[9.5px] text-white/50 line-clamp-1\">{ticket.desc}</p>\n                    <div className=\"flex justify-end pt-1\">\n                      {!isAck && (\n                        <button \n                          onClick={() => {\n                            setAckTickets(prev => ({ ...prev, [ticket.id]: true }));\n                            setTerminalLogs(prev => [...prev, `[SLA] Ticket wire acknowledged: ${ticket.id}`]);\n                          }}\n                          className=\"h-5.5 px-2 rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 text-[9px] hover:bg-[#009DFF]/20 transition-all cursor-pointer\"\n                        >\n                          Ack SLA\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                );\n              })}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* LOWER GRID: BILLING LEDGERS + INTERACTIVE COMMAND CONSOLE */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* CRYPTO BILLING LEDGER */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-4\">\n          <h3 className=\"text-xs font-bold uppercase tracking-wider text-white border-b border-white/5 pb-2\">Cryptographic Billing Ledger</h3>\n          <div className=\"space-y-2.5\">\n            {previewInvoices.slice(0, 3).map((inv) => (\n              <div key={inv.id} className=\"p-2.5 rounded border border-white/5 bg-black/10 space-y-1 text-[10px]\">\n                <div className=\"flex justify-between font-bold text-white\"><span>{inv.id}</span><span className=\"text-[#009DFF]\">{inv.amount}</span></div>\n                <div className=\"flex justify-between text-[8.5px] text-white/35\"><span>{inv.category}</span><span>{inv.dueDate}</span></div>\n                <div className=\"pt-1 border-t border-white/[0.03] text-[8px] text-white/20 truncate\">SEAL: {inv.hash.substring(0, 16)}...</div>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* INTERACTIVE COMMAND ACTIONS & TELEMETRY SHELL */}\n        <div className=\"lg:col-span-2 rounded-xl border border-white/5 bg-[#050505]/30 backdrop-blur-sm p-5 space-y-4\">\n          <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n            <h3 className=\"text-xs font-bold uppercase tracking-wider text-white\">Internal Operations Command Center</h3>\n            <span className=\"text-[9px] text-white/30 tracking-widest uppercase\">Console v1.42</span>\n          </div>\n\n          <div className=\"grid grid-cols-3 gap-2 font-mono\">\n            <button \n              onClick={handleProbeFleet} \n              disabled={isTerminalRunning} \n              className=\"h-8 text-[9px] font-bold uppercase rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-white transition-all cursor-pointer disabled:opacity-40\"\n            >\n              Probe Fleet\n            </button>\n            <button \n              onClick={handleProvisionNode} \n              disabled={isTerminalRunning} \n              className=\"h-8 text-[9px] font-bold uppercase rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-white transition-all cursor-pointer disabled:opacity-40\"\n            >\n              Provision Node\n            </button>\n            <button \n              onClick={handleLockdown} \n              disabled={isTerminalRunning} \n              className=\"h-8 text-[9px] font-bold uppercase rounded border border-red-500/20 bg-red-500/5 text-red-400 hover:bg-[#E4000F]/10 transition-all cursor-pointer disabled:opacity-40\"\n            >\n              Lockdown\n            </button>\n          </div>\n\n          <div className=\"space-y-1 text-left\">\n            <span className=\"text-[8px] text-white/30 uppercase tracking-widest font-bold block\">Simulated Shell Output</span>\n            <div className=\"p-3 bg-zinc-950 border border-zinc-900 rounded-lg space-y-1 text-[9.5px] text-zinc-400 h-[100px] overflow-y-auto leading-relaxed select-text font-mono\">\n              {terminalLogs.map((log, index) => (\n                <div key={index} className=\"flex gap-1.5 items-start\">\n                  <CornerDownRight className=\"w-3 h-3 text-[#009DFF] shrink-0 mt-0.5\" />\n                  <span className={index === terminalLogs.length - 1 && isTerminalRunning ? \"text-[#009DFF] font-bold animate-pulse\" : \"\"}>\n                    {log}\n                  </span>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* INSPECTION DRAWER */}\n      {selectedClient && (\n        <div className=\"fixed inset-0 z-50 flex justify-end\">\n          <div onClick={() => setSelectedClient(null)} className=\"absolute inset-0 bg-black/70 backdrop-blur-sm transition-opacity\" />\n          \n          <div className=\"relative w-full max-w-sm h-full bg-[#030303] border-l border-white/5 p-6 flex flex-col justify-between overflow-y-auto z-10 shadow-2xl\">\n            <div className=\"space-y-5\">\n              <div className=\"flex items-center justify-between border-b border-white/5 pb-3\">\n                <div className=\"space-y-0.5\">\n                  <span className=\"text-[8.5px] text-[#009DFF] uppercase font-bold\">OVERSIGHT STREAM</span>\n                  <h3 className=\"text-xs font-bold text-white uppercase tracking-wider\">{selectedClient.name}</h3>\n                </div>\n                <button onClick={() => setSelectedClient(null)} className=\"h-6 w-6 rounded-full border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-white flex items-center justify-center cursor-pointer\">\n                  <X className=\"w-3.5 h-3.5\" />\n                </button>\n              </div>\n\n              <div className=\"space-y-4 text-[10.5px]\">\n                <div className=\"p-3 rounded border border-white/5 bg-black/40 space-y-2\">\n                  <span className=\"text-[8.5px] text-white/35 uppercase tracking-wider font-bold block\">Sandbox Profile</span>\n                  <div className=\"space-y-1.5\">\n                    <div className=\"flex justify-between\"><span className=\"text-white/45\">Region:</span><span className=\"text-white font-bold\">{selectedClient.region}</span></div>\n                    <div className=\"flex justify-between\"><span className=\"text-white/45\">Status:</span><span className=\"text-emerald-400 font-bold\">100% COMPLIANT</span></div>\n                    <div className=\"flex justify-between\"><span className=\"text-white/45\">Owner:</span><span className=\"text-white font-bold\">Dr. Sarah Vance</span></div>\n                  </div>\n                </div>\n\n                <div className=\"space-y-2\">\n                  <span className=\"text-[8.5px] text-white/35 uppercase tracking-wider font-bold block\">Active Sandbox Projects</span>\n                  {previewProjects.filter(p => p.clientAccountId === selectedClient.id).map(proj => (\n                    <div key={proj.id} className=\"p-2.5 rounded border border-white/5 bg-[#050505]/80 flex justify-between items-center text-[10px]\">\n                      <div>\n                        <span className=\"text-white font-bold block truncate max-w-[150px]\">{proj.name}</span>\n                        <span className=\"text-[8.5px] text-white/30\">{proj.id} • {proj.enclaveType}</span>\n                      </div>\n                      <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse\" />\n                    </div>\n                  ))}\n                </div>\n              </div>\n            </div>\n\n            <div className=\"pt-4 border-t border-white/5 grid grid-cols-2 gap-2\">\n              <button \n                onClick={() => {\n                  setSelectedClient(null);\n                  setTerminalLogs(prev => [...prev, `[PROBE] Manual trace verification executed for client: ${selectedClient.name}`]);\n                }}\n                className=\"h-8 rounded border border-white/10 hover:border-[#009DFF]/30 hover:bg-[#009DFF]/5 hover:text-[#009DFF] text-[9px] font-bold uppercase transition-all cursor-pointer\"\n              >\n                Trace Core\n              </button>\n              <Link \n                href=\"/admin/clients\"\n                className=\"h-8 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[9px] font-bold uppercase text-white transition-all flex items-center justify-center gap-1\"\n              >\n                <span>Full Info</span>\n                <ArrowUpRight className=\"w-3 h-3\" />\n              </Link>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}"}}}
