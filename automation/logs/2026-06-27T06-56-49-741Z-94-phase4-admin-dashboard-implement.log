</span><div className=\"text-base font-bold\">48 Loops</div></div>\n          <Activity className=\"w-4 h-4 text-sky-400\" />\n        </div>\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between\">\n          <div><span className=\"text-[9px] text-white/35 uppercase\">Pending SLA</span><div className=\"text-base font-bold\">{previewSupportTickets.filter(t => !ack[t.id]).length} Tickets</div></div>\n          <Clock className=\"w-4 h-4 text-rose-400 animate-pulse\" />\n        </div>\n        <div className=\"p-4 rounded-xl border border-white/5 bg-[#050505]/40 flex justify-between\">\n          <div><span className=\"text-[9px] text-white/35 uppercase\">ISO Status</span><div className=\"text-base font-bold\">100% SECURE</div></div>\n          <ShieldCheck className=\"w-4 h-4 text-emerald-400\" />\n        </div>\n      </div>\n\n      {/* 2. BENTO MAIN GRID */}\n      <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n        {/* Clients & Projects Overview */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-3\">\n          <span className=\"text-xs font-bold uppercase tracking-wider block border-b border-white/5 pb-2\">Clients & Projects</span>\n          <div className=\"space-y-2 max-h-[140px] overflow-y-auto\">\n            {previewClientAccounts.slice(0, 3).map(c => (\n              <div key={c.id} className=\"flex justify-between items-center text-[10px] p-2 rounded bg-white/[0.01] border border-white/5\">\n                <span>{c.name}</span>\n                <span className=\"text-[8.5px] text-[#009DFF] border border-[#009DFF]/25 px-1 py-0.5 rounded\">{c.region}</span>\n              </div>\n            ))}\n          </div>\n          <div className=\"pt-2 border-t border-white/5 space-y-1.5 text-[9.5px]\">\n            {previewProjects.slice(0, 1).map(p => (\n              <div key={p.id} className=\"flex justify-between text-white/55\"><span>{p.name}</span><span className=\"text-emerald-400 font-bold\">{p.status}</span></div>\n            ))}\n          </div>\n        </div>\n\n        {/* AI Operations */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-3\">\n          <span className=\"text-xs font-bold uppercase tracking-wider block border-b border-white/5 pb-2\">AI Operations</span>\n          <div className=\"p-2 rounded bg-black/20 border border-white/5 flex justify-between text-[10px]\">\n            <div><span className=\"text-white/30 block text-[8px] uppercase\">Active model</span><span className=\"font-bold\">GFF-Llama-70B-Gov</span></div>\n            <span className=\"text-[#009DFF] font-bold text-right\">78% GPU</span>\n          </div>\n          <div className=\"flex gap-2\">\n            <button onClick={() => log(\"Wiped volatile memory cache pools.\")} className=\"flex-1 h-7 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] font-bold uppercase cursor-pointer\">Purge Memory</button>\n            <button onClick={() => log(\"Recalibrated model temperature and weight alignments.\")} className=\"flex-1 h-7 rounded bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/20 text-[9.5px] font-bold uppercase cursor-pointer\">Calibrate</button>\n          </div>\n        </div>\n\n        {/* SLA Tickets & Governance Alerts */}\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-3\">\n          <span className=\"text-xs font-bold uppercase tracking-wider block border-b border-white/5 pb-2\">Wires & Governance</span>\n          <div className=\"space-y-2 text-[10px]\">\n            {previewSupportTickets.slice(0, 1).map(t => (\n              <div key={t.id} className={`p-2 rounded border ${ack[t.id] ? \"border-white/5 opacity-50\" : \"bg-rose-500/5 border-rose-500/10\"} flex justify-between items-center`}>\n                <span className=\"truncate max-w-[120px] font-bold\">{t.title}</span>\n                {!ack[t.id] && <button onClick={() => { setAck(p => ({ ...p, [t.id]: true })); log(`Ack support SLA wire: ${t.id}`); }} className=\"h-5 px-1.5 rounded bg-rose-500/10 text-rose-400 border border-rose-500/25 text-[8.5px] font-bold uppercase cursor-pointer\">Ack</button>}\n              </div>\n            ))}\n            {previewGovernanceItems.slice(0, 1).map(g => (\n              <div key={g.id} className={`p-2 rounded border ${gov[g.id] ? \"border-white/5 opacity-50\" : \"bg-red-500/5 border-red-500/10\"} flex justify-between items-center`}>\n                <span className=\"truncate max-w-[120px] font-bold\">{g.standard}</span>\n                {!gov[g.id] && <button onClick={() => { setGov(p => ({ ...p, [g.id]: true })); log(`Verify compliance policy: ${g.standard}`); }} className=\"h-5 px-1.5 rounded bg-white/5 border border-white/10 text-[8.5px] cursor-pointer\">Verify</button>}\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* LOWER STRIP: BILLING LEDGER & COMMAND CONSOLE */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-2\">\n          <span className=\"text-xs font-bold uppercase tracking-wider block border-b border-white/5 pb-2\">Financial Ledger</span>\n          <div className=\"space-y-2\">\n            {previewInvoices.slice(0, 2).map(inv => (\n              <div key={inv.id} className=\"p-2 rounded bg-black/10 border border-white/5 text-[9.5px] flex justify-between\">\n                <span>{inv.id}</span>\n                <span className=\"text-[#009DFF] font-bold\">{inv.amount}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        <div className=\"lg:col-span-2 rounded-xl border border-white/5 bg-[#050505]/40 p-4 space-y-3\">\n          <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n            <span className=\"text-xs font-bold uppercase tracking-wider\">Internal Operations Shell</span>\n            <div className=\"flex gap-2\">\n              <button onClick={() => log(\"Initiated diagnostic core scan across all clusters.\")} className=\"h-6 px-2.5 rounded border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] text-[9.5px] cursor-pointer\">Probe Fleet</button>\n              <button onClick={() => log(\"⚠️ Emergency lockdown activated. Local namespaces isolated.\")} className=\"h-6 px-2.5 rounded bg-rose-500/10 text-rose-400 border border-rose-500/20 text-[9.5px] cursor-pointer\">Lockdown</button>\n            </div>\n          </div>\n          <div className=\"p-3 bg-zinc-950 border border-zinc-900 rounded-lg text-[9.5px] text-zinc-400 h-[65px] overflow-y-auto leading-relaxed\">\n            {shell.map((s, i) => (\n              <div key={i} className=\"flex gap-1.5 items-start font-mono text-zinc-400\">\n                <CornerDownRight className=\"w-3.5 h-3.5 text-[#009DFF] shrink-0 mt-0.5\" />\n                <span>{s}</span>\n              </div>\n            ))}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"}}}
