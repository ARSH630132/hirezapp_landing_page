30 |     if (!editForm) return;\n231 | \n232 |     setProjects(prev => prev.map(p => p.id === editForm.id ? { ...editForm, lastUpdated: new Date().toISOString() } : p));\n233 |     setIsEditModalOpen(false);\n234 |     setEditForm(null);\n235 |     showToast(`Updated enclave parameter mappings for project ${editForm.id}`);\n236 |   };\n237 | \n238 |   // Memoized Filtered Projects List\n239 |   const filteredProjects = useMemo(() => {\n240 |     return projects.filter(p => {\n241 |       const query = searchQuery.trim().toLowerCase();\n242 |       const matchesSearch = query === \"\" ||\n243 |         p.name.toLowerCase().includes(query) ||\n244 |         p.id.toLowerCase().includes(query) ||\n245 |         p.owner.toLowerCase().includes(query) ||\n246 |         p.desc.toLowerCase().includes(query);\n247 | \n248 |       const matchesClient = selectedClient === \"\" || p.client === selectedClient;\n249 |       const matchesPhase = selectedPhase === \"\" || p.phase === selectedPhase;\n250 |       const matchesStatus = selectedStatus === \"\" || p.status === selectedStatus;\n251 |       const matchesOwner = selectedOwner === \"\" || p.owner === selectedOwner;\n252 | \n253 |       return matchesSearch && matchesClient && matchesPhase && matchesStatus && matchesOwner;\n254 |     });\n255 |   }, [projects, searchQuery, selectedClient, selectedPhase, selectedStatus, selectedOwner]);\n256 | \n257 |   const getStatusStyle = (status: string) => {\n258 |     switch (status) {\n259 |       case \"On Track\":\n260 |         return \"bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 hover:bg-emerald-500/15\";\n261 |       case \"At Risk\":\n262 |         return \"bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500/15\";\n263 |       case \"Delayed\":\n264 |         return \"bg-rose-500/10 border border-rose-500/20 text-rose-400 hover:bg-rose-500/15\";\n265 |       case \"Paused\":\n266 |         return \"bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/15\";\n267 |       default:\n268 |         return \"bg-white/5 border border-white/10 text-white/60 hover:bg-white/10\";\n269 |     }\n270 |   };\n271 | \n272 |   const getPhaseColor = (phase: string) => {\n273 |     switch (phase) {\n274 |       case \"Phase I: Planning\":\n275 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.6)\" };\n276 |       case \"Phase II: Sandbox Provisioning\":\n277 |         return { border: \"rgba(59, 130, 246, 0.2)\", dot: \"rgb(59, 130, 246)\" };\n278 |       case \"Phase III: Agent Alignment\":\n279 |         return { border: \"rgba(0, 157, 255, 0.3)\", dot: \"rgb(0, 157, 255)\" };\n280 |       case \"Phase IV: User Acceptance Testing\":\n281 |         return { border: \"rgba(99, 102, 241, 0.3)\", dot: \"rgb(99, 102, 241)\" };\n282 |       case \"Phase V: Production-Live\":\n283 |         return { border: \"rgba(0, 255, 194, 0.3)\", dot: \"rgb(0, 255, 194)\" };\n284 |       default:\n285 |         return { border: \"rgba(255, 255, 255, 0.1)\", dot: \"rgba(255, 255, 255, 0.4)\" };\n286 |     }\n287 |   };\n288 | \n289 |   return (\n290 |     <div className=\"space-y-6\">\n291 |       {/* 1. Page Header */}\n292 |       <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-white/5 pb-5\">\n293 |         <div>\n294 |           <span className=\"text-[10px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/15 px-2 py-0.5 rounded uppercase tracking-wider\">\n295 |             Sovereign Admin Panel\n296 |           </span>\n297 |           <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercase mt-1.5\">\n298 |             Internal Project Delivery\n299 |           </h2>\n300 |           <p className=\"text-xs text-white/50 mt-1 max-w-2xl font-mono leading-relaxed\">\n301 |             Administrative flight deck for auditing multi-agent alignment phases, cluster isolated nodes, and deployment owners across global sovereign client tenants.\n302 |           </p>\n303 |         </div>\n304 |         <div className=\"shrink-0\">\n305 |           <button\n306 |             onClick={() => setIsCreateModalOpen(true)}\n307 |             className=\"h-9 px-4 rounded bg-[#009DFF] hover:bg-[#0082d4] text-[11px] font-mono font-bold uppercase tracking-wider text-white flex items-center gap-1.5 transition-all cursor-pointer shadow-[0_0_20px_rgba(0,157,255,0.2)]\"\n308 |           >\n309 |             <Plus className=\"w-4 h-4\" />\n310 |             <span>Create Sandbox Preview</span>\n311 |           </button>\n312 |         </div>\n313 |       </div>\n314 | \n315 |       {/* 2. Metrics Ribbon */}\n316 |       <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5\">\n317 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n318 |           <div className=\"flex items-center justify-between\">\n319 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Active Enclaves</span>\n320 |             <Layers className=\"w-4 h-4 text-[#009DFF] opacity-80\" />\n321 |           </div>\n322 |           <div className=\"flex items-baseline gap-2\">\n323 |             <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">{projects.length}</span>\n324 |             <span className=\"text-[10px] font-mono text-emerald-400 font-bold\">LIVE TELEMETRY</span>\n325 |           </div>\n326 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Isolated client lattices monitored</div>\n327 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#009DFF]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n328 |         </div>\n329 | \n330 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n331 |           <div className=\"flex items-center justify-between\">\n332 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Live Deployments</span>\n333 |             <CheckCircle2 className=\"w-4 h-4 text-[#00FFC2] opacity-80\" />\n334 |           </div>\n335 |           <div className=\"flex items-baseline gap-2\">\n336 |             <span className=\"text-2xl font-mono font-bold text-[#00FFC2] tracking-tight\">\n337 |               {projects.filter(p => p.phase === \"Phase V: Production-Live\").length}\n338 |             </span>\n339 |             <span className=\"text-[10px] font-mono text-[#00FFC2]/75 font-semibold\">PHASE V STATE</span>\n340 |           </div>\n341 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Enclaves in full production delivery</div>\n342 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-[#00FFC2]/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n343 |         </div>\n344 | \n345 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n346 |           <div className=\"flex items-center justify-between\">\n347 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">Active Delivery Risks</span>\n348 |             <ShieldAlert className=\"w-4 h-4 text-rose-400 opacity-80\" />\n349 |           </div>\n350 |           <div className=\"flex items-baseline gap-2\">\n351 |             <span className={`text-2xl font-mono font-bold tracking-tight ${projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"text-rose-400\" : \"text-white\"}`}>\n352 |               {projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length}\n353 |             </span>\n354 |             <span className={`text-[10px] font-mono font-bold ${projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"text-rose-400/80\" : \"text-white/40\"}`}>\n355 |               {projects.filter(p => p.status === \"At Risk\" || p.status === \"Delayed\").length > 0 ? \"SLA BREACH RISK\" : \"NOMINAL\"}\n356 |             </span>\n357 |           </div>\n358 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">At-risk and delayed projects active</div>\n359 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-rose-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n360 |         </div>\n361 | \n362 |         <div className=\"border border-white/5 rounded-xl bg-[#050505]/40 backdrop-blur-sm p-4.5 space-y-2 relative overflow-hidden group shadow-[0_0_15px_rgba(0,157,255,0.01)] hover:border-white/10 transition-all\">\n363 |           <div className=\"flex items-center justify-between\">\n364 |             <span className=\"text-[10px] font-mono font-bold text-white/40 tracking-wider uppercase\">SLA Owners Active</span>\n365 |             <User className=\"w-4 h-4 text-purple-400 opacity-80\" />\n366 |           </div>\n367 |           <div className=\"flex items-baseline gap-2\">\n368 |             <span className=\"text-2xl font-mono font-bold text-white tracking-tight\">\n369 |               {new Set(projects.map(p => p.owner)).size}\n370 |             </span>\n371 |             <span className=\"text-[10px] font-mono text-purple-400 font-bold\">ON DUTY</span>\n372 |           </div>\n373 |           <div className=\"text-[9.5px] font-mono text-white/30 truncate\">Sovereign engineering delivery staff</div>\n374 |           <div className=\"absolute bottom-0 left-0 right-0 h-[1.5px] bg-gradient-to-r from-transparent via-purple-500/35 to-transparent opacity-0 group-hover:opacity-100 transition-opacity\" />\n375 |         </div>\n376 |       </div>\n377 | \n378 |       {/* 3. Search and Dynamic Filtering Control Deck */}\n379 |       <div className=\"p-4 rounded-xl border border-white/5 bg-[#030303]/40 space-y-4 shadow-[inset_0_1px_1px_rgba(255,255,255,0.02)]\">\n380 |         <div className=\"grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-3\">\n381 |           {/* Text search */}\n382 |           <div className=\"relative md:col-span-1\">\n383 |             <Search className=\"absolute left-3 top-2.5 w-4 h-4 text-white/30\" />\n384 |             <input\n385 |               type=\"text\"\n386 |               placeholder=\"Search registry...\"\n387 |               value={searchQuery}\n388 |               onChange={(e) => setSearchQuery(e.target.value)}\n389 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-white/[0.02] pl-9 pr-4 text-[12px] font-mono text-white placeholder-white/30 outline-none focus:border-white/15 focus:bg-white/[0.04] transition-all\"\n390 |             />\n391 |           </div>\n392 | \n393 |           {/* Client filter */}\n394 |           <div className=\"relative\">\n395 |             <select\n396 |               value={selectedClient}\n397 |               onChange={(e) => setSelectedClient(e.target.value)}\n398 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-[#030303] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n399 |             >\n400 |               <option value=\"\" className=\"text-white/50\">ALL CLIENTS</option>\n401 |               {AVAILABLE_CLIENTS.map((c) => (\n402 |                 <option key={c} value={c} className=\"text-white\">\n403 |                   {c.replace(\" [Preview Client]\", \"\").toUpperCase()}\n404 |                 </option>\n405 |               ))}\n406 |             </select>\n407 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n408 |           </div>\n409 | \n410 |           {/* Phase filter */}\n411 |           <div className=\"relative\">\n412 |             <select\n413 |               value={selectedPhase}\n414 |               onChange={(e) => setSelectedPhase(e.target.value)}\n415 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-[#030303] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n416 |             >\n417 |               <option value=\"\" className=\"text-white/50\">ALL PHASES</option>\n418 |               {AVAILABLE_PHASES.map((p) => (\n419 |                 <option key={p} value={p} className=\"text-white\">\n420 |                   {p.toUpperCase()}\n421 |                 </option>\n422 |               ))}\n423 |             </select>\n424 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n425 |           </div>\n426 | \n427 |           {/* Status filter */}\n428 |           <div className=\"relative\">\n429 |             <select\n430 |               value={selectedStatus}\n431 |               onChange={(e) => setSelectedStatus(e.target.value)}\n432 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-[#030303] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n433 |             >\n434 |               <option value=\"\" className=\"text-white/50\">ALL STATUSES</option>\n435 |               {AVAILABLE_STATUSES.map((s) => (\n436 |                 <option key={s} value={s} className=\"text-white\">\n437 |                   {s.toUpperCase()}\n438 |                 </option>\n439 |               ))}\n440 |             </select>\n441 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n442 |           </div>\n443 | \n444 |           {/* Owner filter */}\n445 |           <div className=\"relative\">\n446 |             <select\n447 |               value={selectedOwner}\n448 |               onChange={(e) => setSelectedOwner(e.target.value)}\n449 |               className=\"w-full h-9 rounded-lg border border-white/5 bg-[#030303] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none transition-all cursor-pointer appearance-none\"\n450 |             >\n451 |               <option value=\"\" className=\"text-white/50\">ALL OWNERS</option>\n452 |               {AVAILABLE_OWNERS.map((o) => (\n453 |                 <option key={o} value={o} className=\"text-white\">\n454 |                   {o.toUpperCase()}\n455 |                 </option>\n456 |               ))}\n457 |             </select>\n458 |             <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/40 pointer-events-none\" />\n459 |           </div>\n460 |         </div>\n461 | \n462 |         {/* Filters Active Pill Indicator */}\n463 |         {(searchQuery || selectedClient || selectedPhase || selectedStatus || selectedOwner) && (\n464 |           <div className=\"flex items-center justify-between px-3.5 py-2 rounded-lg border border-dashed border-white/10 bg-white/[0.01] text-[10.5px] font-mono text-white/50 animate-in fade-in duration-200\">\n465 |             <div className=\"flex items-center gap-2\">\n466 |               <SlidersHorizontal className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n467 |               <span className=\"truncate\">\n468 |                 Active filters applied:{\" \"}\n469 |                 {[\n470 |                   searchQuery && `\"${searchQuery}\"`,\n471 |                   selectedClient && `Client: ${selectedClient.replace(\" [Preview Client]\", \"\")}`,\n472 |                   selectedPhase && `Phase: ${selectedPhase}`,\n473 |                   selectedStatus && `Status: ${selectedStatus}`,\n474 |                   selectedOwner && `Owner: ${selectedOwner}`\n475 |                 ].filter(Boolean).join(\" | \")}\n476 |               </span>\n477 |             </div>\n478 |             <button\n479 |               onClick={handleResetFilters}\n480 |               className=\"text-[#009DFF] hover:text-[#0082d4] font-bold uppercase transition-colors shrink-0 outline-none\"\n481 |             >\n482 |               Reset Filters\n483 |             </button>\n484 |           </div>\n485 |         )}\n486 |       </div>\n487 | \n488 |       {/* 4. Desktop Table View */}\n489 |       <div className=\"hidden lg:block overflow-x-auto rounded-xl border border-white/5 bg-[#020202]/40 backdrop-blur-sm shadow-[0_4px_30px_rgba(0,0,0,0.4)]\">\n490 |         <table className=\"w-full border-collapse text-left text-xs font-mono\">\n491 |           <thead>\n492 |             <tr className=\"border-b border-white/10 bg-white/[0.01] text-[10.5px] uppercase text-white/40 tracking-wider\">\n493 |               <th className=\"py-3 px-4 font-semibold\">Project & ID</th>\n494 |               <th className=\"py-3 px-4 font-semibold\">Tenant Client</th>\n495 |               <th className=\"py-3 px-4 font-semibold\">Delivery Phase</th>\n496 |               <th className=\"py-3 px-4 font-semibold\">SLA Status</th>\n497 |               <th className=\"py-3 px-4 font-semibold\">Owner</th>\n498 |               <th className=\"py-3 px-4 font-semibold\">Cluster Nodes</th>\n499 |               <th className=\"py-3 px-4 font-semibold text-right\">Actions</th>\n500 |             </tr>\n501 |           </thead>\n502 |           <tbody>\n503 |             {filteredProjects.map((project) => (\n504 |               <tr key={project.id} className=\"border-b border-white/5 hover:bg-white/[0.01] transition-colors group\">\n