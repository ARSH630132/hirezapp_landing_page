{"ts":"2026-06-25T23:28:06.837Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"22k3xkm2","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/GlobalPresenceSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\nimport WorldMap from \"@/components/ui/world-map\";\n\n// Connection dots from Singapore Global HQ to all other nodes\nconst presenceDots = [\n  {\n    start: { lat: 1.3521, lng: 103.8198, label: \"Singapore\" },\n    end: { lat: 51.5074, lng: -0.1278, label: \"London, UK\" },\n  },\n  {\n    start: { lat: 1.3521, lng: 103.8198, label: \"Singapore\" },\n    end: { lat: 12.9716, lng: 77.5946, label: \"India\" },\n  },\n  {\n    start: { lat: 1.3521, lng: 103.8198, label: \"Singapore\" },\n    end: { lat: 40.7128, lng: -74.0060, label: \"USA\" },\n  },\n  {\n    start: { lat: 1.3521, lng: 103.8198, label: \"Singapore\" },\n    end: { lat: 25.2048, lng: 55.2708, label: \"Middle East\" },\n  },\n  {\n    start: { lat: 1.3521, lng: 103.8198, label: \"Singapore\" },\n    end: { lat: -33.8688, lng: 151.2093, label: \"Australia\" },\n  },\n];\n\nconst primaryHubs = [\n  {\n    id: \"singapore\",\n    name: \"Singapore\",\n    role: \"Global Headquarters\",\n    desc: \"Central business coordination, corporate governance, intellectual property custody, and core platform architectural steering.\",\n    specialty: \"Strategic Orchestration & Core IP\",\n    color: \"#F74539\",\n    status: \"Operational\",\n    badge: \"GLOBAL HQ\",\n    latency: \"Sub-10ms Routing\",\n    coords: { lat: 1.3521, lng: 103.8198 },\n  },\n  {\n    id: \"london\",\n    name: \"London, UK\",\n    role: \"Client Innovation Centre\",\n    desc: \"Dedicated sandbox co-innovation, secure local enterprise solution architecture design, and strategic executive advisory.\",\n    specialty: \"Co-Innovation & Advisory\",\n    color: \"#E98828\",\n    status: \"Operational\",\n    badge: \"CLIENT CENTER\",\n    latency: \"Sub-50ms Sync\",\n    coords: { lat: 51.5074, lng: -0.1278 },\n  },\n  {\n    id: \"india\",\n    name: \"India\",\n    role: \"AI Engineering Factory\",\n    desc: \"Industrialized continuous model training, fine-tuning evaluation loops, automated pipeline delivery, and localized build shop operations.\",\n    specialty: \"Automated Build Shop & Dev\",\n    color: \"#0186E4\",\n    status: \"Operational\",\n    badge: \"BUILD FACTORY\",\n    latency: \"Sub-80ms Build\",\n    coords: { lat: 12.9716, lng: 77.5946 },\n  },\n];\n\nconst futureRegions = [\n  {\n    name: \"United States\",\n    role: \"Future Expansion Node\",\n    desc: \"Strategic expansion path for secure high-performance localized sovereign cloud clusters and North American model compliance.\",\n    specialty: \"Local Compliance & Scaling\",\n    color: \"#9D00FF\",\n    status: \"In Planning\",\n    coords: { lat: 40.7128, lng: -74.0060 },\n  },\n  {\n    name: \"Middle East\",\n    role: \"Future Expansion Node\",\n    desc: \"Architecting regional secure clusters addressing GCC sovereign computing compliance and high-performance safety standards.\",\n    specialty: \"Sovereign AI Infrastructure\",\n    color: \"#10B981\",\n    status: \"In Planning\",\n    coords: { lat: 25.2048, lng: 55.2708 },\n  },\n  {\n    name: \"Australia\",\n    role: \"Future Expansion Node\",\n    desc: \"Planned edge gateway node supporting low-latency local inference executions and partner training ecosystems.\",\n    specialty: \"Secure Edge Operations\",\n    color: \"#EC4899\",\n    status: \"In Planning\",\n    coords: { lat: -33.8688, lng: 151.2093 },\n  },\n];\n\nexport default function GlobalPresenceSection() {\n  const [activeHub, setActiveHub] = useState<string>(\"singapore\");\n\n  // Get active coordinates for selected primary hub to focus on map if desired\n  const selectedHubData = primaryHubs.find((h) => h.id === activeHub) || primaryHubs[0];\n\n  return (\n    <motion.section\n      initial={{ opacity: 0, y: 30 }}\n      whileInView={{ opacity: 1, y: 0 }}\n      viewport={{ once: true }}\n      transition={{ duration: 0.8 }}\n      className=\"w-full bg-[#010101] px-6 lg:px-16 lg:py-28 py-16 relative overflow-hidden\"\n    >\n      {/* Background glow effects */}\n      <div className=\"absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[300px] bg-gradient-to-r from-[#009DFF]/5 to-transparent blur-[120px] pointer-events-none rounded-full\" />\n      <div className=\"absolute bottom-10 right-10 w-[400px] h-[200px] bg-gradient-to-r from-[#F74539]/5 to-transparent blur-[120px] pointer-events-none rounded-full\" />\n\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        <SectionHeading\n          title={\n            <h2 className=\"text-[28px] sm:text-[36px] leading-none font-semibold text-center uppercase text-white tracking-wide\">\n              GLOBAL <span className=\"text-[#009DFF]\">PRESENCE</span>\n            </h2>\n          }\n          titleClassName=\"text-center\"\n          dividerWidthClassName=\"w-[200px]\"\n        />\n\n        <p className=\"mt-4 text-center text-xs sm:text-sm text-white/45 max-w-2xl mx-auto font-medium uppercase tracking-[0.2em] mb-16\">\n          SECURE BORDERLESS ENTERPRISE AI ARCHITECTURE & CO-INNOVATION\n        </p>\n\n        {/* Dashboard Grid */}\n        <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-10 items-stretch\">\n          \n          {/* Left Column: Interactive World Network Map (HUD Style) */}\n          <div className=\"xl:col-span-7 flex flex-col justify-between rounded-[24px] border border-white/5 bg-[#030303]/40 backdrop-blur-[12px] p-6 relative overflow-hidden min-h-[450px] lg:min-h-[550px] shadow-2xl\">\n            \n            {/* HUD Header */}\n            <div className=\"flex items-center justify-between z-10 border-b border-white/5 pb-4 mb-4\">\n              <div className=\"flex items-center gap-2.5\">\n                <span className=\"relative flex h-2.5 w-2.5\">\n                  <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75\"></span>\n                  <span className=\"relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500\"></span>\n                </span>\n                <span className=\"text-[10px] font-mono tracking-widest text-emerald-400 font-bold uppercase\">\n                  SYSTEM STATUS: OPERATIONAL\n                </span>\n              </div>\n              <div className=\"text-[10px] font-mono tracking-widest text-white/40 uppercase\">\n                TUNNEL PROTOCOL: TLS 1.3 / CHACHA20\n              </div>\n            </div>\n\n            {/* World Map Container */}\n            <div className=\"relative flex-1 w-full min-h-[300px] flex items-center justify-center opacity-85 hover:opacity-100 transition-opacity duration-500\">\n              <WorldMap dots={presenceDots} lineColor=\"#009DFF\" />\n              \n              {/* Custom SVG pulse overlays on top of specific lat/lng projected points */}\n              {/* Since the WorldMap uses static map projection, let's keep visual markers centered and high-tech */}\n              <div className=\"absolute inset-0 pointer-events-none z-20\">\n                {/* Tech grid lines overlay */}\n                <div className=\"absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.01)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.01)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none\" />\n              </div>\n            </div>\n\n            {/* HUD Footer Info */}\n            <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-4 border-t border-white/5 pt-4 mt-4 z-10 text-[10px] font-mono\">\n              <div>\n                <span className=\"text-white/30 block uppercase tracking-wider mb-0.5\">Primary Sync Core</span>\n                <span className=\"text-white font-semibold uppercase\">{selectedHubData.name}</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block uppercase tracking-wider mb-0.5\">Latency Threshold</span>\n                <span className=\"text-[#009DFF] font-semibold\">{selectedHubData.latency}</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block uppercase tracking-wider mb-0.5\">Secure Transit</span>\n                <span className=\"text-white/70 font-semibold\">AES-256-GCM</span>\n              </div>\n              <div>\n                <span className=\"text-white/30 block uppercase tracking-wider mb-0.5\">Global Topology</span>\n                <span className=\"text-emerald-400 font-semibold uppercase\">ACTIVE PEER GRID</span>\n              </div>\n            </div>\n          </div>\n\n          {/* Right Column: Information Control Hub & Interactive cards */}\n          <div className=\"xl:col-span-5 flex flex-col justify-between gap-8\">\n            \n            {/* Primary Hubs Section */}\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between pb-1 border-b border-white/5\">\n                <h3 className=\"text-xs font-semibold tracking-[0.2em] uppercase text-white/50\">\n                  PRIMARY OPERATIONAL HUBS\n                </h3>\n                <span className=\"text-[10px] font-mono text-[#009DFF] bg-[#009DFF]/10 px-2 py-0.5 rounded-md font-bold uppercase\">\n                  ACTIVE\n                </span>\n              </div>\n\n              <div className=\"space-y-3.5\">\n                {primaryHubs.map((hub) => {\n                  const isActive = activeHub === hub.id;\n                  return (\n                    <motion.div\n                      key={hub.id}\n                      onClick={() => setActiveHub(hub.id)}\n                      onMouseEnter={() => setActiveHub(hub.id)}\n                      className={`cursor-pointer rounded-[20px] p-[1px] transition-all duration-300 ${\n                        isActive\n                          ? \"bg-gradient-to-r from-white/15 to-white/5 shadow-lg\"\n                          : \"bg-transparent\"\n                      }`}\n                    >\n                      <div\n                        className={`rounded-[19px] p-5 transition-all duration-500 relative overflow-hidden ${\n                          isActive\n                            ? \"bg-[#060606]\"\n                            : \"bg-[#030303]/40 border border-white/5 hover:border-white/10 hover:bg-[#040404]\"\n                        }`}\n                      >\n                        {/* Status bar left border */}\n                        <div\n                          className=\"absolute left-0 top-0 bottom-0 w-[3px] transition-all duration-500\"\n                          style={{\n                            backgroundColor: isActive ? hub.color : \"transparent\",\n                          }}\n                        />\n\n                        <div className=\"flex items-start justify-between gap-4\">\n                          <div className=\"space-y-1 pl-1\">\n                            <div className=\"flex items-center gap-2\">\n                              <h4 className=\"text-base font-bold text-white tracking-wide\">\n                                {hub.name}\n                              </h4>\n                              <span\n                                className=\"text-[9px] font-bold tracking-widest px-2 py-0.5 rounded-full border\"\n                                style={{\n                                  color: hub.color,\n                                  borderColor: `${hub.color}25`,\n                                  backgroundColor: `${hub.color}05`,\n                                }}\n                              >\n                                {hub.badge}\n                              </span>\n                            </div>\n                            <p className=\"text-[11px] font-medium uppercase tracking-wider text-white/40\">\n                              {hub.role}\n                            </p>\n                          </div>\n                          \n                          {/* Pulsing indicator */}\n                          <div className=\"flex items-center justify-center pt-1.5\">\n                            <span className=\"relative flex h-2 w-2\">\n                              <span\n                                className=\"animate-ping absolute inline-flex h-full w-full rounded-full opacity-75\"\n                                style={{ backgroundColor: hub.color }}\n                              ></span>\n                              <span\n                                className=\"relative inline-flex rounded-full h-2 w-2\"\n                                style={{ backgroundColor: hub.color }}\n                              ></span>\n                            </span>\n                          </div>\n                        </div>\n\n                        {/* Expandable details when active */}\n                        <AnimatePresence initial={false}>\n                          {isActive && (\n                            <motion.div\n                              initial={{ height: 0, opacity: 0 }}\n                              animate={{ height: \"auto\", opacity: 1 }}\n                              exit={{ height: 0, opacity: 0 }}\n                              transition={{ duration: 0.3 }}\n                              className=\"overflow-hidden\"\n                            >\n                              <p className=\"mt-3.5 text-xs text-white/60 leading-relaxed font-normal pl-1 border-l border-white/5\">\n                                {hub.desc}\n                              </p>\n                              \n                              <div className=\"mt-4 flex items-center justify-between text-[10px] font-mono pl-1 text-white/50 pt-3 border-t border-white/[0.03]\">\n                                <span className=\"flex items-center gap-1.5\">\n                                  <span\n                                    className=\"w-1.5 h-1.5 rounded-full\"\n                                    style={{ backgroundColor: hub.color }}\n                                  />\n                                  {hub.specialty}\n                                </span>\n                                <span className=\"text-[#009DFF] font-semibold\">\n                                  {hub.latency}\n                                </span>\n                              </div>\n                            </motion.div>\n                          )}\n                        </AnimatePresence>\n                      </div>\n                    </motion.div>\n                  );\n                })}\n              </div>\n            </div>\n\n            {/* Future Expansion Nodes */}\n            <div className=\"space-y-4\">\n              <div className=\"flex items-center justify-between pb-1 border-b border-white/5\">\n                <h3 className=\"text-xs font-semibold tracking-[0.2em] uppercase text-white/40\">\n                  FUTURE EXPANSION & LOCALIZATION\n                </h3>\n                <span className=\"text-[10px] font-mono text-[#9D00FF] bg-[#9D00FF]/10 px-2 py-0.5 rounded-md font-bold uppercase\">\n                  PLANNING\n                </span>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n                {futureRegions.map((region) => (\n                  <div\n                    key={region.name}\n                    className=\"group relative rounded-[18px] border border-white/5 bg-[#030303]/20 hover:bg-[#030303]/60 hover:border-white/10 p-4 transition-all duration-300 flex flex-col justify-between min-h-[130px]\"\n                  >\n                    <div>\n                      <div className=\"flex items-center justify-between mb-2\">\n                        <h4 className=\"text-xs font-bold text-white group-hover:text-[#009DFF] transition-colors duration-300\">\n                          {region.name}\n                        </h4>\n                        <span className=\"w-1.5 h-1.5 rounded-full bg-white/20 group-hover:bg-[#9D00FF] transition-colors duration-300\" />\n                      </div>\n                      <p className=\"text-[10px] font-mono text-white/30 group-hover:text-white/50 transition-colors mb-2\">\n                        {region.specialty}\n                      </p>\n                    </div>\n                    <p className=\"text-[10px] text-white/40 leading-relaxed font-light group-hover:text-white/60 transition-colors\">\n                      {region.desc}\n                    </p>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n    </motion.section>\n  );\n}"}}}
