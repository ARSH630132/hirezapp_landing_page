-transform:uppercase;font-weight:700;opacity:0.92;\">\n 40 |               GFF AI\n 41 |             </div>\n 42 |             <div style=\"margin-top:10px;font-size:26px;line-height:1.15;font-weight:700;\">\n 43 |               New Contact Form Submission\n 44 |             </div>\n 45 |             <div style=\"margin-top:10px;font-size:14px;line-height:1.6;opacity:0.95;\">\n 46 |               A new visitor has submitted the website contact form.\n 47 |             </div>\n 48 |           </div>\n 49 | \n 50 |           <div style=\"padding:28px;\">\n 51 |             <div style=\"margin-bottom:18px;padding:16px 18px;border-radius:16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:#e5eefc;\">\n 52 |               <div style=\"font-size:12px;line-height:1.5;letter-spacing:0.12em;text-transform:uppercase;color:#7ea6ff;font-weight:700;\">\n 53 |                 Submission details\n 54 |               </div>\n 55 |               <div style=\"margin-top:8px;font-size:14px;line-height:1.7;\">\n 56 |                 Submitted at ${escapeHtml(payload.submittedAt)}\n 57 |               </div>\n 58 |             </div>\n 59 | \n 60 |             <table role=\"presentation\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\" style=\"border-collapse:collapse;\">\n 61 |               ${rows\n 62 |                 .map(\n 63 |                   ([label, value]) => `\n 64 |                 <tr>\n 65 |                   <td style=\"padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.08);vertical-align:top;\">\n 66 |                     <div style=\"font-size:12px;line-height:1.4;text-transform:uppercase;letter-spacing:0.08em;color:#7d8aa7;font-weight:700;\">\n 67 |                       ${escapeHtml(label)}\n 68 |                     </div>\n 69 |                     <div style=\"margin-top:5px;font-size:15px;line-height:1.7;color:#ffffff;font-weight:600;word-break:break-word;\">\n 70 |                       ${value}\n 71 |                     </div>\n 72 |                   </td>\n 73 |                 </tr>`,\n 74 |                 )\n 75 |                 .join(\"\")}\n 76 |             </table>\n 77 |           </div>\n 78 |         </div>\n 79 |       </div>\n 80 |     </div>\n 81 |   `;\n 82 | }\n 83 | \n 84 | export async function POST(req: Request) {\n 85 |   try {\n 86 |     const body = (await req.json()) as ContactPayload;\n 87 | \n 88 |     const fullName = body.fullName?.trim() ?? \"\";\n 89 |     const fullNameDetail = body.fullNameDetail?.trim() ?? \"\";\n 90 |     const company = body.company?.trim() ?? \"\";\n 91 |     const companyDetail = body.companyDetail?.trim() ?? \"\";\n 92 |     const businessEmail = body.businessEmail?.trim() ?? \"\";\n 93 |     const businessEmailDetail = body.businessEmailDetail?.trim() ?? \"\";\n 94 | \n 95 |     if (\n 96 |       !fullName ||\n 97 |       !fullNameDetail ||\n 98 |       !company ||\n 99 |       !companyDetail ||\n100 |       !businessEmail ||\n101 |       !businessEmailDetail\n102 |     ) {\n103 |       return NextResponse.json(\n104 |         { success: false, message: \"All form fields are required.\" },\n105 |         { status: 400 },\n106 |       );\n107 |     }\n108 | \n109 |     const smtpHost = process.env.SMTP_HOST;\n110 |     const smtpPort = Number(process.env.SMTP_PORT);\n111 |     const smtpUser = process.env.SMTP_USER;\n112 |     const smtpPassword = process.env.SMTP_PASSWORD ?? process.env.SMTP_PASS;\n113 |     const recipientEmail = process.env.CONTACT_RECEIVER_EMAIL ?? \"ceohirezapp@gmail.com\";\n114 | \n115 |     if (!smtpHost || !smtpPort || !smtpUser || !smtpPassword) {\n116 |       return NextResponse.json(\n117 |         { success: false, message: \"Mail service is not configured.\" },\n118 |         { status: 500 },\n119 |       );\n120 |     }\n121 | \n122 |     const transporter = nodemailer.createTransport({\n123 |       host: smtpHost,\n124 |       port: smtpPort,\n125 |       secure: smtpPort === 465,\n126 |       auth: {\n127 |         user: smtpUser,\n128 |         pass: smtpPassword,\n129 |       },\n130 |     });\n131 | \n132 |     const submittedAt = new Date().toLocaleString(\"en-IN\", {\n133 |       dateStyle: \"medium\",\n134 |       timeStyle: \"medium\",\n135 |       timeZone: \"Asia/Kolkata\",\n136 |     });\n137 | \n138 |     const subject = `New Contact Form Submission - ${fullName}`;\n139 |     const html = buildEmailHtml({\n140 |       fullName: escapeHtml(fullName),\n141 |       fullNameDetail: escapeHtml(fullNameDetail),\n142 |       company: escapeHtml(company),\n143 |       companyDetail: escapeHtml(companyDetail),\n144 |       businessEmail: escapeHtml(businessEmail),\n145 |       businessEmailDetail: escapeHtml(businessEmailDetail),\n146 |       submittedAt: escapeHtml(submittedAt),\n147 |     });\n148 | \n149 |     const text = [\n150 |       \"New Contact Form Submission\",\n151 |       \"\",\n152 |       `Full Name: ${fullName}`,\n153 |       `Enter your full name: ${fullNameDetail}`,\n154 |       `Company / Organization: ${company}`,\n155 |       `Enter company name: ${companyDetail}`,\n156 |       `Business Email: ${businessEmail}`,\n157 |       `Enter official email address: ${businessEmailDetail}`,\n158 |       `Submitted at: ${submittedAt}`,\n159 |     ].join(\"\\n\");\n160 | \n161 |     await transporter.sendMail({\n162 |       from: `GFF AI <${smtpUser}>`,\n163 |       to: recipientEmail,\n164 |       replyTo: businessEmail,\n165 |       subject,\n166 |       text,\n167 |       html,\n168 |     });\n169 | \n170 |     return NextResponse.json({ success: true });\n171 |   } catch (error) {\n172 |     console.error(\"Contact form email failed:\", error);\n173 |     return NextResponse.json(\n174 |       { success: false, message: \"Failed to send message.\" },\n175 |       { status: 500 },\n176 |     );\n177 |   }\n178 | }","success":true}],"durationMs":2}}
