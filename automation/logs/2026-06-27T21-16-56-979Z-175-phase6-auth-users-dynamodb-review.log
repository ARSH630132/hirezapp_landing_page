 try {\n 41 |     fn();\n 42 |     console.log(`  \\x1b[32m✔\\x1b[0m ${name}`);\n 43 |     passed++;\n 44 |   } catch (error) {\n 45 |     console.log(`  \\x1b[31m✖\\x1b[0m ${name}`);\n 46 |     console.error(`    \\x1b[31mError:\\x1b[0m ${error.message}`);\n 47 |     failed++;\n 48 |   }\n 49 | }\n 50 | \n 51 | function assert(cond, msg) {\n 52 |   if (!cond) throw new Error(msg || \"Assertion failed\");\n 53 | }\n 54 | \n 55 | try {\n 56 |   console.log(\"\\n\\x1b[36m--- Test Group 1: Cryptographic JWT Operations ---\\x1b[0m\");\n 57 | \n 58 |   test(\"signJwt & verifyJwt - success path with valid payload\", () => {\n 59 |     const payload = { sub: \"usr-001\", email: \"s.vance@governance.gff.ai\", role: \"gff_admin\" };\n 60 |     const token = apiAuth.signJwt(payload);\n 61 |     assert(token && token.split('.').length === 3, \"Token must have exactly 3 parts\");\n 62 |     \n 63 |     const decoded = apiAuth.verifyJwt(token);\n 64 |     assert(decoded !== null, \"Decoded token must not be null\");\n 65 |     assert(decoded.sub === \"usr-001\", \"Sub match failed\");\n 66 |     assert(decoded.email === \"s.vance@governance.gff.ai\", \"Email match failed\");\n 67 |     assert(decoded.role === \"gff_admin\", \"Role match failed\");\n 68 |   });\n 69 | \n 70 |   test(\"verifyJwt - reject modified signature\", () => {\n 71 |     const token = apiAuth.signJwt({ sub: \"usr-001\" });\n 72 |     const parts = token.split('.');\n 73 |     parts[2] = parts[2].substring(0, parts[2].length - 3) + \"XYZ\";\n 74 |     assert(apiAuth.verifyJwt(parts.join('.')) === null, \"Tampered signature should fail\");\n 75 |   });\n 76 | \n 77 |   test(\"verifyJwt - reject modified payload\", () => {\n 78 |     const token = apiAuth.signJwt({ sub: \"usr-001\" });\n 79 |     const parts = token.split('.');\n 80 |     const pl = JSON.parse(apiAuth.base64UrlDecode(parts[1]));\n 81 |     pl.sub = \"usr-002\";\n 82 |     parts[1] = apiAuth.base64UrlEncode(JSON.stringify(pl));\n 83 |     assert(apiAuth.verifyJwt(parts.join('.')) === null, \"Tampered payload should fail\");\n 84 |   });\n 85 | \n 86 |   test(\"verifyJwt - reject expired token\", () => {\n 87 |     const token = apiAuth.signJwt({ sub: \"usr-001\" }, undefined, -10);\n 88 |     assert(apiAuth.verifyJwt(token) === null, \"Expired token should fail\");\n 89 |   });\n 90 | \n 91 |   console.log(\"\\n\\x1b[36m--- Test Group 2: User Lookup and Password Verifications ---\\x1b[0m\");\n 92 | \n 93 |   test(\"verifyUserPassword - correct passwords\", () => {\n 94 |     assert(apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"VanceSecure2026!\"), \"Vance custom pass failed\");\n 95 |     assert(apiAuth.verifyUserPassword(\"a.mercer@apex-sovereign.gff.ai\", \"MercerSecure2026!\"), \"Mercer custom pass failed\");\n 96 |     assert(apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"gff-secure-2026!\"), \"Vance dev pass failed\");\n 97 |   });\n 98 | \n 99 |   test(\"verifyUserPassword - incorrect password or unknown email\", () => {\n100 |     assert(!apiAuth.verifyUserPassword(\"s.vance@governance.gff.ai\", \"wrong\"), \"Incorrect pass should fail\");\n101 |     assert(!apiAuth.verifyUserPassword(\"unknown@gff.ai\", \"password123\"), \"Unknown email should fail\");\n102 |   });\n103 | \n104 |   test(\"verifyUserStatus - inactive flag validation\", () => {\n105 |     const user = apiAuth.API_MOCK_USERS[\"m.vance@sovereign-logistics.gff.ai\"];\n106 |     assert(user && user.status === \"inactive\", \"Marcus Vance should be inactive\");\n107 |   });\n108 | \n109 |   console.log(\"\\n\\x1b[35m========================================================\\x1b[0m\");\n110 |   console.log(`  Total Passed: \\x1b[32m${passed}\\x1b[0m | Failed: \\x1b[31m${failed}\\x1b[0m`);\n111 |   \n112 |   if (failed > 0) {\n113 |     console.log(\"\\x1b[41m\\x1b[37m VERIFICATION FAILED \\x1b[0m\");\n114 |     cleanup();\n115 |     process.exit(1);\n116 |   } else {\n117 |     console.log(\"\\x1b[42m\\x1b[30m VERIFICATION SUCCESSFUL: Auth logic verified! \\x1b[0m\");\n118 |   }\n119 | } catch (e) {\n120 |   console.error(\"Crash during tests:\", e);\n121 |   cleanup();\n122 |   process.exit(1);\n123 | }\n124 | \n125 | cleanup();","success":true}],"durationMs":5}}
