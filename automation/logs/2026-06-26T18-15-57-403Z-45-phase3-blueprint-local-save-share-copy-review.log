-xs font-bold uppercase tracking-wider font-mono text-white\">Local Blueprint Vault</h2>\n                </div>\n                <button\n                  type=\"button\"\n                  onClick={() => setIsHistoryOpen(false)}\n                  className=\"rounded-lg p-1.5 border border-white/10 hover:border-white/20 text-white/50 hover:text-white transition duration-200\"\n                >\n                  <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"2\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M6 18L18 6M6 6l12 12\" /></svg>\n                </button>\n              </div>\n\n              {/* List */}\n              <div className=\"flex-1 overflow-y-auto p-6 space-y-4\">\n                <p className=\"text-[11px] text-white/40 leading-relaxed font-light\">\n                  Confidential history of generated blueprints cached strictly in this browser context. Clearing browser data will delete these records.\n                </p>\n\n                {history.length === 0 ? (\n                  <div className=\"py-12 text-center space-y-3\">\n                    <span className=\"text-xs text-white/30 block\">[EMPTY]</span>\n                    <p className=\"text-[10px] text-white/40 max-w-[200px] mx-auto text-center leading-normal\">Complete the assessment and click \"Save Locally\" to archive previews here.</p>\n                  </div>\n                ) : (\n                  <div className=\"space-y-3\">\n                    {history.map((item) => {\n                      const dateObj = new Date(item.timestamp);\n                      const formattedDate = dateObj.toLocaleDateString(undefined, { month: \"short\", day: \"numeric\", hour: \"2-digit\", minute: \"2-digit\" });\n                      return (\n                        <div\n                          key={item.id}\n                          onClick={() => handleLoadSavedItem(item)}\n                          className=\"group p-4 rounded-xl border border-white/5 bg-white/[0.01] hover:border-[#087DF3]/30 hover:bg-[#087DF3]/5 transition duration-200 cursor-pointer text-left space-y-2 relative\"\n                        >\n                          <div className=\"flex justify-between items-start gap-2\">\n                            <div>\n                              <span className=\"text-[9px] font-mono text-white/45 block\">{formattedDate}</span>\n                              <h4 className=\"text-xs font-bold text-white group-hover:text-[#087DF3] transition duration-200 mt-0.5 line-clamp-1\">{item.solutionTitle}</h4>\n                            </div>\n                            <span className=\"text-[11px] font-mono font-black text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.5 rounded shrink-0\">\n                              {item.score}\n                            </span>\n                          </div>\n\n                          <div className=\"flex justify-between items-center text-[10px] text-white/50 pt-2 border-t border-white/[0.03]\">\n                            <span className=\"truncate max-w-[150px] font-mono\">{item.email}</span>\n                            <button\n                              type=\"button\"\n                              onClick={(e) => handleDeleteSavedItem(item.id, e)}\n                              className=\"text-white/30 hover:text-[#E4000F] p-1 rounded hover:bg-white/5 transition duration-200 font-mono text-[9px] uppercase tracking-wider flex items-center gap-1\"\n                              title=\"Delete record\"\n                            >\n                              <svg className=\"w-3.5 h-3.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth=\"1.5\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2