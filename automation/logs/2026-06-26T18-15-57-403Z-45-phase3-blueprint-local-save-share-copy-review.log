a.leadershipCommitment,\n      };\n\n      const base64 = window.btoa(unescape(encodeURIComponent(JSON.stringify(shareState))));\n      const shareUrl = `${window.location.origin}${window.location.pathname}?share=${base64}`;\n\n      navigator.clipboard.writeText(shareUrl).then(() => {\n        setShareSuccess(true);\n        setTimeout(() => setShareSuccess(false), 3000);\n      });\n    } catch (e) {\n      console.error(\"Failed to generate and copy share link\", e);\n    }\n  };\n\n  const handleDeleteSavedItem = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    const updated = history.filter(item => item.id !== id);\n    setHistory(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updated));\n    }\n  };\n\n  const handleLoadSavedItem = (item: any) => {\n    setLoadedState({\n      data: item.data,\n      result: item.result,\n      showResult: true,\n      currentStepIndex: 5\n    });\n    setIsHistoryOpen(false);\n  };\n\n  const handleResetExternal = () => {\n    setLoadedState(null);\n  };\n\n  const steps: WizardStep<WizardData>[] = ["}}}
