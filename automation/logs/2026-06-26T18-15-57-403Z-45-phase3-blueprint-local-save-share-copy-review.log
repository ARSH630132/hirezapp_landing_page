te a shareable URL, and using `navigator.clipboard.writeText` to copy it. I am working on the success messaging for the copy function, including error handling for local storage and clipboard operations.\n\n\n"}}
{"ts":"2026-06-26T18:09:34.341Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"ehq9cbin","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/BlueprintGenerator.tsx","old_text":"    otpSent: false,\n    enteredOtp: \"\"\n  };\n\n  const steps: WizardStep<WizardData>[] = [","new_text":"    otpSent: false,\n    enteredOtp: \"\"\n  };\n\n  const [history, setHistory] = useState<any[]>([]);\n  const [loadedState, setLoadedState] = useState<any>(null);\n  const [isHistoryOpen, setIsHistoryOpen] = useState(false);\n  const [copySuccess, setCopySuccess] = useState(false);\n  const [saveSuccess, setSaveSuccess] = useState(false);\n  const [shareSuccess, setShareSuccess] = useState(false);\n\n  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      // 1. Load blueprint history\n      try {\n        const stored = localStorage.getItem(\"gff_blueprint_history\");\n        if (stored) {\n          setHistory(JSON.parse(stored));\n        }\n      } catch (e) {\n        console.error(\"Failed to parse GFF blueprint history\", e);\n      }\n\n      // 2. Parse shared parameters\n      try {\n        const urlParams = new URLSearchParams(window.location.search);\n        const shareParam = urlParams.get(\"share\");\n        if (shareParam) {\n          const decodedStr = decodeURIComponent(escape(window.atob(shareParam)));\n          const decodedData = JSON.parse(decodedStr);\n          if (decodedData && decodedData.industry) {\n            // Recompile results on-the-fly\n            const compiledResult = compileBlueprint(decodedData);\n            setLoadedState({\n              data: {\n                ...initialData,\n                ...decodedData\n              },\n              result: compiledResult,\n              showResult: true,\n              currentStepIndex: 5\n            });\n            // Clean up url parameters for a clean and pristine address bar\n            window.history.replaceState({}, document.title, window.location.pathname);\n          }\n        }\n      } catch (e) {\n        console.error(\"Failed to load shared GFF blueprint state\", e);\n      }\n    }\n  }, []);\n\n  const handleCopyToClipboard = (data: WizardData, result: any) => {\n    const dateStr = new Date().toLocaleString();\n    \n    const text = `============================================================\nGFF AI SOVEREIGN ENTERPRISE ARCHITECTURE BLUEPRINT SUMMARY\n============================================================\nGenerated: ${dateStr}\nStatus: DECRYPTED_SANDBOX_PREVIEW\n\n1. ORGANIZATIONAL PROFILE:\n- Vertical: ${data.industry || \"N/A\"}\n- Scale: ${data.companySize || \"N/A\"}\n- Budget Range: ${data.budget || \"N/A\"}\n- Region/Geography: ${data.geography || \"N/A\"}\n- Enterprise Email: ${data.email || \"N/A\"}\n\n2. ASSESSMENTS & SCORES:\n- Sovereign AI Readiness Score: ${result.score} / 100 (${result.category})\n- Dimension Breakdown:\n  * AI Maturity Index: ${result.dimensions?.aiMaturity ?? 0}/100\n  * Business Need Alignment: ${result.dimensions?.businessNeed ?? 0}/100\n  * Enterprise Data Readiness: ${result.dimensions?.dataReadiness ?? 0}/100\n  * Process Complexity: ${result.dimensions?.processComplexity ?? 0}/100\n  * Transformation Readiness: ${result.dimensions?.transformationReadiness ?? 0}/100\n\n3. TARGET GFF AI ARCHITECTURE OVERVIEW:\n- Recommended Solution: ${result.solution.title}\n- Expected Business Impact: ${result.impact.metric}\n\n4. SYNTHESIZED OPPORTUNITY NODES:\n${result.opportunities.map((opp: string, idx: number) => `  * NODE_0${idx + 1}: ${opp}`).join(\"\\n\")}\n\n============================================================\nCONFIDENTIALITY NOTE: Local browser preview only.\nThis report is encrypted in your local session. No server\nsubmissions were made during this assessment phase.\n============================================================`;\n\n    navigator.clipboard.writeText(text).then(() => {\n      setCopySuccess(true);\n      setTimeout(() => setCopySuccess(false), 2000);\n    }).catch(err => {\n      console.error(\"Could not copy text to clipboard: \", err);\n    });\n  };\n\n  const handleSaveLocally = (data: WizardData, result: any) => {\n    if (typeof window === \"undefined\") return;\n    try {\n      const newSavedItem = {\n        id: `gff_bp_${Date.now()}`,\n        timestamp: Date.now(),\n        email: data.email || \"anonymous@enterprise.local\",\n        industry: data.industry || \"General\",\n        score: result.score,\n        category: result.category,\n        solutionTitle: result.solution.title,\n        data,\n        result\n      };\n\n      const updatedHistory = [newSavedItem, ...history].slice(0, 10);\n      setHistory(updatedHistory);\n      localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updatedHistory));\n      \n      setSaveSuccess(true);\n      setTimeout(() => setSaveSuccess(false), 3000);\n    } catch (e) {\n      console.error(\"Failed to save blueprint locally\", e);\n    }\n  };\n\n  const handleShareLink = (data: WizardData) => {\n    if (typeof window === \"undefined\") return;\n    try {\n      // Serialize only user's form responses to keep URL short and clean\n      const shareState = {\n        industry: data.industry,\n        companySize: data.companySize,\n        budget: data.budget,\n        geography: data.geography,\n        email: data.email,\n        biggestChallenge: data.biggestChallenge,\n        customChallengeText: data.customChallengeText,\n        topPriorities: data.topPriorities,\n        aiJourney: data.aiJourney,\n        dataReadiness: data.dataReadiness,\n        leadershipCommitment: data.leadershipCommitment,\n      };\n\n      const base64 = window.btoa(unescape(encodeURIComponent(JSON.stringify(shareState))));\n      const shareUrl = `${window.location.origin}${window.location.pathname}?share=${base64}`;\n\n      navigator.clipboard.writeText(shareUrl).then(() => {\n        setShareSuccess(true);\n        setTimeout(() => setShareSuccess(false), 3000);\n      });\n    } catch (e) {\n      console.error(\"Failed to generate and copy share link\", e);\n    }\n  };\n\n  const handleDeleteSavedItem = (id: string, e: React.MouseEvent) => {\n    e.stopPropagation();\n    const updated = history.filter(item => item.id !== id);\n    setHistory(updated);\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(updated));\n    }\n  };\n\n  const handleLoadSavedItem = (item: any) => {\n    setLoadedState({\n      data: item.data,\n      result: item.result,\n      showResult: true,\n      currentStepIndex: 5\n    });\n    setIsHistoryOpen(false);\n  };\n\n  const handleResetExternal = () => {\n    setLoadedState(null);\n  };\n\n  const steps: WizardStep<WizardData>[] = ["}}}
