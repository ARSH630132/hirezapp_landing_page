t();\n 941 |     const ext = consoleTab === \"json\" ? \"json\" : \"yaml\";\n 942 |     const blob = new Blob([text], { type: \"text/plain\" });\n 943 |     const url = URL.createObjectURL(blob);\n 944 |     const link = document.createElement(\"a\");\n 945 |     link.href = url;\n 946 |     link.download = `foundry-workflow-${selectedPresetId}.${ext}`;\n 947 |     document.body.appendChild(link);\n 948 |     link.click();\n 949 |     document.body.removeChild(link);\n 950 |     setDownloaded(true);\n 951 |     setTimeout(() => setDownloaded(false), 2500);\n 952 |   };\n 953 | \n 954 | \n 955 |   return (\n 956 |     <ToolPageShell>\n 957 |       {/* CSS Animation Injector for custom dynamic SVG flow lines */}\n 958 |       <style dangerouslySetInnerHTML={{ __html: `\n 959 |         @keyframes flowDash {\n 960 |           to {\n 961 |             stroke-dashoffset: -20;\n 962 |           }\n 963 |         }\n 964 |         .animate-flowDash {\n 965 |           stroke-dasharray: 6 4;\n 966 |           animation: flowDash 0.8s linear infinite;\n 967 |         }\n 968 |       `}} />\n 969 | \n 970 |       {/* Tool Hero Intro Section */}\n 971 |       <ToolHero\n 972 |         category=\"WORKSPACE WORKBENCH\"\n 973 |         title=\"GFF Foundry Studio DAG Architect\"\n 974 |         highlightedWord=\"Foundry Studio\"\n 975 |         description=\"Configure and compile enterprise-grade multi-stage Directed Acyclic Graph (DAG) pipelines for sovereign cognitive agents. Shape sandboxed workflows with real-time SVG connection previews.\"\n 976 |         metricLabel=\"PLATFORM MODE\"\n 977 |         metricValue=\"SIMULATION ACTIVE\"\n 978 |       />\n 979 | \n 980 |       <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-10 items-start\">\n 981 |         {/* ==========================================\n 982 |             LEFT COLUMN: Studio Configurator Panel (4 cols)\n 983 |             ========================================== */}\n 984 |         <div className=\"xl:col-span-4 space-y-6\">\n 985 |           \n 986 |           {/* Preset Selector */}\n 987 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#04060b]/80 backdrop-blur-sm space-y-4\">\n 988 |             <div>\n 989 |               <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block mb-1\">\n 990 |                 PRESET TEMPLATES\n 991 |               </span>\n 992 |               <h2 className=\"text-lg font-bold text-white tracking-tight\">Select Industry Domain</h2>\n 993 |               <p className=\"text-white/40 text-xs font-light\">Loading a preset instantly configures realistic domain workflow nodes.</p>\n 994 |             </div>\n 995 | \n 996 |             <div className=\"flex flex-wrap gap-2 pt-2\">\n 997 |               {INDUSTRY_PRESETS.map((p) => (\n 998 |                 <button\n 999 |                   key={p.id}\n1000 |                   onClick={() => setSelectedPresetId(p.id)}\n1001 |                   className={`px-3 py-2 rounded-xl text-xs font-semibold flex items-center gap-2 transition-all border ${\n1002 |                     selectedPresetId === p.id\n1003 |                       ? \"bg-[#009DFF]/10 border-[#009DFF] text-white cursor-pointer\"\n1004 |                       : \"bg-white/[0.02] border-white/5 text-white/50 hover:bg-white/[0.04] hover:text-white cursor-pointer\"\n1005 |                   }`}\n1006 |                 >\n1007 |                   <span>{p.icon}</span>\n1008 |                   <span>{p.label}</span>\n1009 |                 </button>\n1010 |               ))}\n1011 |             </div>\n1012 | \n1013 |             {/* Display active preset description */}\n1014 |             {INDUSTRY_PRESETS.map((p) => {\n1015 |               if (p.id !== selectedPresetId) return null;\n1016 |               return (\n1017 |                 <div key={p.id} className=\"pt-2 border-t border-white/5 mt-2 animate-fadeIn\">\n1018 |                   <h4 className=\"text-xs font-bold text-white/80 mb-1\">{p.title}</h4>\n1019 |                   <p className=\"text-[11px] text-white/50 leading-relaxed font-light\">{p.description}</p>\n1020 |                 </div>\n1021 |               );\n1022 |             })}\n1023 |           </div>\n1024 | \n1025 | \n1026 |           {/* Cognitive Topology Selector */}\n1027 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#04060b]/80 backdrop-blur-sm space-y-4\">\n1028 |             <div>\n1029 |               <span className=\"text-[10px] font-mono text-[#9D00FF] font-bold uppercase tracking-widest block mb-1\">\n1030 |                 AGENT TOPOLOGY\n1031 |               </span>\n1032 |               <h2 className=\"text-lg font-bold text-white tracking-tight\">Select Agent Pattern</h2>\n1033 |               <p className=\"text-white/40 text-xs font-light\">Determines routing and consensus mechanics across isolated nodes.</p>\n1034 |             </div>\n1035 | \n1036 |             <div className=\"grid grid-cols-2 gap-2 pt-2\">\n1037 |               {AGENT_PATTERNS.map((p) => (\n1038 |                 <button\n1039 |                   key={p.id}\n1040 |                   onClick={() => {\n1041 |                     setSelectedPattern(p.id);\n1042 |                     const timestamp = new Date().toLocaleTimeString();\n1043 |                     setLogs((prev) => [\n1044 |                       ...prev,\n1045 |                       { time: timestamp, type: \"info\", text: `Switched topological schema routing pattern to: [${p.label.toUpperCase()}].` }\n1046 |                     ]);\n1047 |                   }}\n1048 |                   className={`p-3 rounded-xl text-left transition-all border cursor-pointer ${\n1049 |                     selectedPattern === p.id\n1050 |                       ? \"bg-[#9D00FF]/15 border-[#9D00FF] text-white\"","success":true}],"durationMs":2}}
