/div>\n123 |       <div className=\"lg:col-span-8 order-1 lg:order-2\">\n124 |         {content}\n125 |       </div>\n126 |     </div>\n127 |   );\n128 | }\n129 | \n130 | \n131 | // ==========================================\n132 | // 4. ToolSidebarProgress\n133 | // ==========================================\n134 | interface Step {\n135 |   id: string;\n136 |   label: string;\n137 |   description?: string;\n138 |   duration?: string;\n139 | }\n140 | \n141 | interface ToolSidebarProgressProps {\n142 |   steps: Step[];\n143 |   currentStepIndex: number;\n144 |   onStepClick?: (index: number) => void;\n145 | }\n146 | \n147 | export function ToolSidebarProgress({ steps, currentStepIndex, onStepClick }: ToolSidebarProgressProps) {\n148 |   const percentage = Math.round((currentStepIndex / (steps.length - 1)) * 100);\n149 | \n150 |   return (\n151 |     <div className=\"p-6 rounded-2xl border border-white/5 bg-[#04060b]/80 backdrop-blur-sm space-y-6\">\n152 |       <div className=\"flex justify-between items-center border-b border-white/5 pb-4\">\n153 |         <span className=\"text-xs font-bold text-white uppercase tracking-wider font-mono\">CONSTRUCT PIPELINE</span>\n154 |         <span className=\"text-xs font-mono text-white/40\">{percentage}% COMPLETED</span>\n155 |       </div>\n156 | \n157 |       {/* Progress Track */}\n158 |       <div className=\"w-full h-1 bg-white/5 rounded-full overflow-hidden\">\n159 |         <div\n160 |           className=\"h-full bg-gradient-to-r from-[#009DFF] to-[#00FF9D] transition-all duration-500 ease-out\"\n161 |           style={{ width: `${percentage}%` }}\n162 |         />\n163 |       </div>\n164 | \n165 |       {/* Steps List */}\n166 |       <div className=\"space-y-4 pt-2 relative\">\n167 |         {steps.map((step, idx) => {\n168 |           const isActive = idx === currentStepIndex;\n169 |           const isCompleted = idx < currentStepIndex;\n170 | \n171 |           return (\n172 |             <motion.button\n173 |               key={step.id}\n174 |               onClick={() => onStepClick && onStepClick(idx)}\n175 |               disabled={!onStepClick || (!isCompleted && !isActive)}\n176 |               whileHover={isCompleted || isActive ? { x: 3 } : {}}\n177 |               transition={{ duration: 0.2 }}\n178 |               className={`w-full text-left flex gap-4 p-3 rounded-xl transition border text-xs group relative ${\n179 |                 isActive\n180 |                   ? \"text-white border-white/10\"\n181 |                   : isCompleted\n182 |                   ? \"bg-transparent border-transparent text-white/50 hover:text-white\"\n183 |                   : \"bg-transparent border-transparent text-white/20 cursor-not-allowed\"\n184 |               }`}\n185 |             >\n186 |               {isActive && (\n187 |                 <motion.div\n188 |                   layoutId=\"sidebarActiveBg\"\n189 |                   className=\"absolute inset-0 bg-white/[0.03] border border-white/10 rounded-xl -z-10\"\n190 |                   transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n191 |                 />\n192 |               )}\n193 | \n194 |               {/* Step Marker */}\n195 |               <div className=\"mt-0.5 shrink-0 relative z-10\">\n196 |                 <div\n197 |                   className={`w-5 h-5 rounded-full flex items-center justify-center font-mono text-[9px] border transition ${\n198 |                     isActive\n199 |                       ? \"border-[#009DFF] text-[#009DFF] bg-[#009DFF]/10\"\n200 |                       : isCompleted\n201 |                       ? \"border-[#00FF9D] text-[#00FF9D] bg-[#00FF9D]/5\"\n202 |                       : \"border-white/10 text-white/20\"\n203 |                   }`}\n204 |                 >\n205 |                   {isCompleted ? (\n206 |                     <svg className=\"w-2.5 h-2.5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n207 |                       <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={3} d=\"M5 13l4 4L19 7\" />\n208 |                     </svg>\n209 |                   ) : (\n210 |                     idx + 1\n211 |                   )}\n212 |                 </div>\n213 |               </div>\n214 | \n215 |               {/* Step Info */}\n216 |               <div className=\"space-y-1 relative z-10\">\n217 |                 <div className=\"flex items-center gap-2\">\n218 |                   <span className={`font-semibold ${isActive ? \"text-[#009DFF]\" : \"\"}`}>{step.label}</span>\n219 |                   {step.duration && (\n220 |                     <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 border border-white/5 text-white/30 uppercase\">\n221 |                       {step.duration}\n222 |                     </span>\n223 |                   )}\n224 |                 </div>\n225 |                 {step.description && (\n226 |                   <p className=\"text-[11px] text-white/40 font-light leading-relaxed group-hover:text-white/60 transition\">\n227 |                     {step.description}\n228 |                   </p>\n229 |                 )}\n230 |               </div>\n231 |             </motion.button>\n232 |           );\n233 |         })}\n234 |       </div>\n235 |     </div>\n236 |   );\n237 | }\n238 | \n239 | \n240 | \n241 | // ==========================================\n242 | // 5. ToolPreviewNotice\n243 | // ==========================================\n244 | export function ToolPreviewNotice() {\n245 |   return (\n246 |     <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex items-start gap-3.5 text-xs\">\n247 |       <div className=\"p-2 rounded bg-white/5 border border-white/10 shrink-0 mt-0.5 text-[#009DFF]\">\n248 |         <svg className=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n249 |           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.8} d=\"M12 15