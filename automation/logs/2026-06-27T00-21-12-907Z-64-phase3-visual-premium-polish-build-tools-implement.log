rs: \"CIO\"\n270 |         },\n271 |         talk: {\n272 |           currentStep: 2,\n273 |           data: {\n274 |             desc: \"Legacy core banking orchestration with autonomous risk compliance nodes\",\n275 |             ind: \"Finance\",\n276 |             size: \"100-1000\",\n277 |             geography: \"North America\",\n278 |             urgency: \"immediate\",\n279 |             functionTeam: \"Compliance Auditing\",\n280 |             aiStage: \"Exploring\"\n281 |           },\n282 |           showResults: false\n283 |         },\n284 |         sandbox: {\n285 |           selectedIndustry: \"Banking\",\n286 |           selectedFunction: \"Knowledge Search\",\n287 |           selectedAgentType: \"Deep Reasoning / DAG\",\n288 |           searchQuery: \"reconciliation\",\n289 |           activeAgentId: \"knowledge-search\"\n290 |         },\n291 |         marketplace: {\n292 |           activeTab: \"All Patterns\",\n293 |           industryFilter: \"All Industries\",\n294 |           functionFilter: \"All Functions\",\n295 |           maturityFilter: \"All Stages\",\n296 |           platformFilter: \"All Fits\",\n297 |           searchQuery: \"Watchdog\",\n298 |           compareIds: [\"agent-01\", \"agent-02\"]\n299 |         },\n300 |         foundryStudio: {\n301 |           selectedPresetId: \"banking\",\n302 |           selectedPattern: \"hierarchical\",\n303 |           stages: [\n304 |             { id: \"node-0\", type: \"trigger\", label: \"Consensus Ledger Hook\", role: \"Sovereign Ingress\", latency: \"2ms\", isGated: false },\n305 |             { id: \"node-1\", type: \"reasoning\", label: \"Audit Verification Agent\", role: \"Verification Node\", latency: \"45ms\", isGated: false }\n306 |           ],\n307 |           knowledgeSources: [\"ledger_rules.pdf\", \"compliance_framework.txt\"]\n308 |         }\n309 |       };\n310 | \n311 |       localStorage.setItem(\"gff_local_workspace_continuity\", JSON.stringify(mockWorkspace));\n312 |       localStorage.setItem(\"gff_proposal_draft_intake\", JSON.stringify(mockWorkspace.proposal));\n313 | \n314 |       const mockBlueprintHistory = [\n315 |         {\n316 |           id: \"bp-mock-2026\",\n317 |           score: 84,\n318 |           timestamp: new Date().toLocaleTimeString(),\n319 |           category: \"Maturity Level III: Strategic Federated Mesh\",\n320 |           data: {\n321 |             email: \"architect@vanguard.io\",\n322 |             company: \"Enterprise Vanguard Corp\",\n323 |             cloud: \"hybrid\",\n324 |             agentsCount: \"50-100 Autonomous Agents\",\n325 |             urgency: \"immediate\"\n326 |           }\n327 |         }\n328 |       ];\n329 |       localStorage.setItem(\"gff_blueprint_history\", JSON.stringify(mockBlueprintHistory));\n330 | \n331 |       refreshWorkspace();\n332 |     }\n333 |   };\n334 | \n335 |   const handleClearSessions = () => {\n336 |     purgeAllWorkspace();\n337 |     refreshWorkspace();\n338 |   };\n339 | \n340 | \n341 |   return (\n342 |     <InnerPageShell>\n343 |       {/* Premium Hero Area */}\n344 |       <InnerPageHero\n345 |         category=\"Build With GFF Hub\"\n346 |         title=\"Sovereign Co-Engineering Workshop\"\n347 |         highlightedWord=\"Sovereign\"\n348 |         description=\"Construct, simulate, validate, and launch custom multi-agent execution systems using our self-service diagnostic suite, roadmap engines, and commercial scoping nodes.\"\n349 |       />\n350 | \n351 |       <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n352 |         \n353 |         {/* Sovereign Workspace Continuity Control Panel */}\n354 |         <WorkspaceContinuityPanel />\n355 | \n356 |         {/* SECTION 1: Sovereign Journey Timeline */}\n357 |         <section className=\"p-6 lg:p-10 rounded-[24px] border border-white/5 bg-[#04060b] relative overflow-hidden\">\n358 |           <div className=\"absolute top-0 right-0 w-[30%] h-[30%] bg-[#E4000F]/5 blur-3xl pointer-events-none\" />\n359 |           \n360 |           <div className=\"relative z-10 max-w-[1400px] mx-auto space-y-8\">\n361 |             <div className=\"flex flex-col lg:flex-row justify-between lg:items-end gap-4\">\n362 |               <div>\n363 |                 <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block mb-1\">\n364 |                   ENTERPRISE PROTOCOL PIPELINE\n365 |                 </span>\n366 |                 <h2 className=\"text-2xl lg:text-3xl font-bold text-white tracking-tight\">\n367 |                   The 9-Stage Sovereign Flow\n368 |                 </h2>\n369 |                 <p className=\"text-white/60 text-xs mt-1 max-w-[600px] font-light\">\n370 |                   Inspect the structured deployment milestones GFF AI utilizes to scope, configure, and operate air-gapped cognitive fleets.\n371 |                 </p>\n372 |               </div>\n373 |               <div className=\"text-xs font-mono text-[#009DFF] bg-[#009DFF]/10 px-3 py-1.5 rounded-full border border-[#009DFF]/20 self-start font-semibold\">\n374 |                 PHASE 0{activeStage.n}: {activeStage.name.toUpperCase()}\n375 |               </div>\n376 |             </div>\n377 | \n378 |             {/* Scrollable Timeline Row */}\n379 |             <div className=\"relative overflow-x-auto pb-4 scrollbar-none border-b border-white/5\">\n380 |               <div className=\"min-w-[940px] flex items-center justify-between relative px-2 py-4\">\n381 |                 <div className=\"absolute top-[38px] left-8 right-8 h-[2px] bg-white/5 z-0\" />\n382 |                 <div \n383 |                   className=\"absolute top-[38px] left-8 h-[2px] bg-gradient-to-r from-[#E4000F] to-[#009DFF] z-0 transition-all duration-500\" \n384 |                   style={{ width: `${((activeStage.n - 1) / 8) * 100}%` }} \n385 |                 />\n386 |                 \n387 |                 {JOURNEY.map((stg) => {\n388 |                   const act = activeStage.n === stg.n;\n389 |                   return (\n390 |                     <button \n391 |                       key={stg.n} \n392 |                       onClick={() => setActiveStage(stg)} \n393 |                       className=\"flex flex-col items-center relative z-10 group focus:outline-none w-[95px] shrink-0\"\n394 |                     >\n395 |                       <div className={`w-11 h-11 rounded-full border-2 flex items-center justify-center text-xs font-mono font-bold transition-all duration-300 ${\n396 |                         act \n397 |                           ? \"bg-black border-[#009DFF] text-[#009DFF] shadow-[0_0_15px_rgba(0,157,255,0.4)] scale-110\" \n398 |                           : stg.n < activeStage.n \n399 |                             ? \"bg-gradient-to-r from-[#E4000F] to-[#009DFF] border-transparent text-white\" \n400 |                             : \"bg-[#020202] border-white/10 text-white/40 group-hover:border-white/30\"\n401 |                       }`}>\n402 |                         {stg.n}\n403 |                       </div>\n404 |                       <span className={`text-[10px] mt-2.5 font-bold tracking-tight truncate w-full text-center transition-colors ${\n405 |                         act ? \"text-[#009DFF]\" : \"text-white/60 group-hover:text-white\"\n406 |                       }`}>\n407 |                         {stg.name}\n408 |                       </span>\n409 |                     </button>\n410 |                   );\n411 |                 })}\n412 |               </div>\n413 |             </div>\n414 | \n415 |             {/* Active Stage Details Panel */}\n416 |             <div className=\"min-h-[200px] relative\">\n417 |               <AnimatePresence mode=\"wait\">\n418 |                 <motion.div\n419 |                   key={activeStage.n}\n420 |                   initial={{ opacity: 0, x: 15 }}\n421 |                   animate={{ opacity: 1, x: 0 }}\n422 |                   exit={{ opacity: 0, x: -15 }}\n423 |                   transition={{ duration: 0.25, ease: \"easeInOut\" }}\n424 |                   className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 pt-4 w-full\"\n425 |                 >\n426 |                   <div className=\"lg:col-span-8 space-y-4\">\n427 |                     <div className=\"flex items-center gap-2 text-[11px] font-mono text-white/50\">\n428 |                       <span className=\"text-[#E4000F] font-bold\">PHASE 0{activeStage.n}</span>\n429 |                       <span>|</span>\n430 |                       <span className=\"text-[#00FF9D] font-semibold\">{activeStage.metric}</span>\n431 |                     </div>\n432 |                     <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">\n433 |                       {activeStage.name} Milestone Target\n434 |                     </h3>\n435 |                     <p className=\"text-white/70 text-xs leading-relaxed max-w-[720px] font-light\">\n436 |                       {activeStage.desc}\n437 |                     </p>\n438 |                     <div className=\"pt-2\">\n439 |                       <Link \n440 |                         href={activeStage.tool} \n441 |                         className=\"inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-xs font-semibold text-white bg-white/5 border border-white/10 hover:bg-white/10 hover:border-[#009DFF]/30 transition group\"\n442 |                       >\n443 |                         <span>Launch {activeStage.btn} Helper</span>\n444 |                         <svg className=\"w-3 h-3 group-hover:translate-x-1 transition-transform text-[#009DFF]\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n445 |                           <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2.5} d=\"M9 5l7 7-7 7\" />\n446 |                         </svg>\n447 |                       </Link>\n448 |                     </div>\n449 |                   </div>\n450 |                   \n451 |                   <div className=\"lg:col-span-4 p-5 rounded-2xl bg-white/[0.01] border border-white/5 flex flex-col justify-between\">\n452 |                     <div>\n453 |                       <h4 className=\"text-[10px] font-mono text-white/40 uppercase tracking-wider mb-2\">EXPECTED PIPELINE OUTCOME</h4>\n454 |                       <p className=\"text-xs text-white/80 font-light leading-relaxed\">\n455 |                         {activeStage.artifact}\n456 |                       </p>\n457 |                     </div>\n458 |                     <div className=\"text-[9px] font-mono text-white/30 pt-4 mt-4 border-t border-white/5 flex justify-between items-center\">\n459 |                       <span>DEPLOYMENT REGULATION</span>\n460 |                       <span className=\"text-[#00FF9D] font-bold flex items-center gap-1\">\n461 |                         <span className=\"w-1.5 h-1.5 rounded-full bg-[#00FF9D]\" />\n462 |                         GUARANTEED SOVEREIGN\n463 |                       </span>\n464 |                     </div>\n465 |                   </div>\n466 |                 </motion.div>\n467 |               </AnimatePresence>\n468 |             </div>\n469 |           </div>\n470 |         </section>\n471 | \n472 | \n473 |         {/* Interactive Decision Guide: \"Which tool should you use next?\" */}\n474 |         <section className=\"p-6 lg:p-8 rounded-[24px] border border-white/5 bg-[#030305] relative overflow-hidden\">\n475 |           <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[50%] h-[50%] rounded-full blur-[100px] pointer-events-none opacity-5 transition-all duration-700\" style={{ backgroundColor: SCENARIOS[activeScenarioIdx].badgeColor }} />\n476 |           \n477 |           <div className=\"relative z-10 max-w-[1400px] mx-auto space-y-6\">\n478 |             <div className=\"space-y-1\">\n479 |               <span className=\"text-xs font-mono text-[#009DFF] font-semibold uppercase tracking-wider block\">INTELLIGENT NAVIGATOR</span>\n480 |               <h2 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">Which Tool Should You Use Next?</h2>\n481 |               <p className=\"text-white/60 text-xs max-w-[650px] font-light\">Select your primary operational objective to receive an instant co-engineering diagnostic recommendation.</p>\n482 |             </div>\n483 | \n484 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n485 |               <div className=\"lg:col-span-6 flex flex-col gap-2.5\">\n486 |                 {SCENARIOS.map((sc, idx) => {\n487 |                   const isActive = activeScenarioIdx === idx;\n488 |                   return (\n489 |                     <motion.button\n490 |                       key={sc.id}\n491 |                       onClick={() => setActiveScenarioIdx(idx)}\n492 |                       whileHover={{ scale: 1.008, y: -0.5 }}\n493 |                       whileTap={{ scale: 0.995 }}\n494 |                       transition={{ duration: 0.15 }}\n495 |                       className={`w-full p-3.5 text-left rounded-xl border transition-all duration-300 flex items-center justify-between gap-4 group relative overflow-hidden focus:outline-none cursor-pointer ${\n496 |                         isActive ? \"bg-white/[0.03] border-white/15\" : \"bg-[#010102] border-white/5 hover:border-white/10\"\n497 |                       }`}\n498 |                     >\n499 |                       <div className=\"absolute left-0 top-0 bottom-0 w-[3px]\" style={{ backgroundColor: sc.badgeColor, opacity: isActive ? 1 : 0 }} />\n500 |                       <div className=\"flex-1 space-y-1 pl-1\">\n501 |                         <h4 className=\"text-xs font-semibold text-white tracking-tight group-hover:text-white/95 transition-colors\">{sc.title}</h4>\n502 |                         <p className=\"text-[10px] text-white/50 font-light leading