ents-none\" />\n287 | \n288 |       <div className=\"space-y-3 max-w-2xl relative z-10 text-center md:text-left\">\n289 |         <span className=\"text-[9px] font-mono text-[#00FF9D] font-bold uppercase tracking-widest block\">\n290 |           SOVEREIGN ENCLAVE ELEVATION\n291 |         </span>\n292 |         <h3 className=\"text-xl lg:text-2xl font-bold text-white tracking-tight\">{title}</h3>\n293 |         <p className=\"text-white/50 text-xs font-light leading-relaxed max-w-lg\">{description}</p>\n294 |       </div>\n295 | \n296 |       <div className=\"relative z-10 shrink-0\">\n297 |         {onAction ? (\n298 |           <button\n299 |             onClick={onAction}\n300 |             className=\"px-6 py-3 rounded-xl text-xs font-bold text-black bg-[#009DFF] hover:bg-[#009DFF]/90 transition uppercase tracking-wider flex items-center gap-2 group/btn shadow-[0_0_20px_rgba(0,157,255,0.2)]\"","success":true}],"durationMs":3}}
