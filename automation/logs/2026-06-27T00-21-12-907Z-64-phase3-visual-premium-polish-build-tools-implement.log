);\n359 |     setTimeout(() => setCopied(false), 2000);\n360 |   };\n361 | \n362 |   // 6. RESET ACTION\n363 |   const handleReset = () => {\n364 |     setIsFlushing(true);\n365 |     setTimeout(() => {\n366 |       setIndustry(\"financial_services\");\n367 |       setCompanySize(\"enterprise\");\n368 |       setOpFunction(\"customer_operations\");\n369 |       setAnnualCostBaseline(1500000);\n370 |       setProcessVolume(250000);\n371 |       setAvgHandlingTime(15);\n372 |       setAutomationTarget(65);\n373 |       setManualEffort(\"high\");\n374 |       setProductivityImprovement(50);\n375 |       setImplementationHorizon(\"6_months\");\n376 |       setPriority(\"cost_reduction\");\n377 |       setIsFlushing(false);\n378 |     }, 450);\n379 |   };\n380 | \n381 |   // 6.5 PREFLIGHT ADVISORIES & VALIDATION FOR INPUT FIELDS\n382 |   const getPreflightAdvisories = () => {\n383 |     const list: { type: \"info\" | \"warning\" | \"optimal\"; title: string; message: string }[] = [];\n384 | \n385 |     if (annualCostBaseline === 0) {\n386 |       list.push({\n387 |         type: \"warning\",\n388 |         title: \"Baseline Operational Cost Erased\",\n389 |         message: \"Please enter a non-zero Annual Cost Baseline to model return-on-investment trajectories.\"\n390 |       });\n391 |     } else if (annualCostBaseline < 100000) {\n392 |       list.push({\n393 |         type: \"info\",\n394 |         title: \"Localized Prototype Scaling Scale\",\n395 |         message: `An operating baseline of ${annualCostBaseline.toLocaleString()} indicates a localized sandbox process. Return multipliers yield peak performance at standard mid-market or corporate scale (> $250,000).`\n396 |       });\n397 |     }\n398 | \n399 |     if (processVolume === 0) {\n400 |       list.push({\n401 |         type: \"warning\",\n402 |         title: \"Annual Process Volume is Zero\",\n403 |         message: \"Erase-to-zero transaction frequency bypasses cognitive labor-hour reduction modeling. P