\n625 |                 <X className=\"w-4 h-4\" />\n626 |               </button>\n627 |             )}\n628 |           </div>\n629 | \n630 |           {/* Controls Right Alignment: Layout Switch & Clear */}\n631 |           <div className=\"flex flex-wrap items-center gap-3 self-end xl:self-auto\">\n632 |             {hasActiveFilters && (\n633 |               <button \n634 |                 onClick={handleResetFilters}\n635 |                 className=\"h-9 px-3 rounded-lg border border-red-500/20 bg-red-500/5 hover:bg-red-500/10 text-[11px] font-mono font-bold text-red-400 uppercase transition-all flex items-center gap-1.5 cursor-pointer\"\n636 |               >\n637 |                 <X className=\"w-3.5 h-3.5\" />\n638 |                 <span>Reset Filters</span>\n639 |               </button>\n640 |             )}\n641 | \n642 |             {/* Layout Toggler (Segmented Control style) */}\n643 |             <div className=\"flex items-center rounded-lg border border-white/5 p-1 bg-black/40\">\n644 |               <button \n645 |                 onClick={() => setLayoutMode(\"grid\")}\n646 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n647 |                   layoutMode === \"grid\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n648 |                 }`}\n649 |               >\n650 |                 <LayoutGrid className=\"w-3.5 h-3.5\" />\n651 |                 <span className=\"hidden sm:inline\">Bento Grid</span>\n652 |               </button>\n653 |               <button \n654 |                 onClick={() => setLayoutMode(\"list\")}\n655 |                 className={`h-7 px-3.5 rounded-md text-[10.5px] font-mono font-bold flex items-center gap-1.5 transition-all uppercase ${\n656 |                   layoutMode === \"list\" ? \"bg-[#009DFF]/10 text-[#009DFF] border border-[#009DFF]/25\" : \"text-white/40 hover:text-white\"\n657 |                 }`}\n658 |               >\n659 |                 <List className=\"w-3.5 h-3.5\" />\n660 |                 <span className=\"hidden sm:inline\">Sovereign Ledger</span>\n661 |               </button>\n662 |             </div>\n663 | \n664 |           </div>\n665 |         </div>\n666 | \n667 |         {/* Dropdown Filters row */}\n668 |         <div className=\"grid grid-cols-2 md:grid-cols-4 gap-3 border-t border-white/5 pt-4\">\n669 |           \n670 |           {/* Category Dropdown */}\n671 |           <div className=\"space-y-1.5\">\n672 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Document Category</span>\n673 |             <div className=\"relative\">\n674 |               <select \n675 |                 value={selectedCategory} \n676 |                 onChange={(e) => setSelectedCategory(e.target.value)} \n677 |                 className=\"w-full h-9 rounded-lg border border-white/5 bg-[#0a0a0a] px-3 pr-8 text-[11.5px] font-mono text-white/70 focus:text-white focus:border-white/15 outline-none transition-all cursor-pointer appearance-none uppercase\"\n678 |               >\n679 |                 <option value=\"\">ALL CATEGORIES</option>\n680 |                 {CATEGORIES.map(cat => <option key={cat} value={cat}>{cat}</option>)}\n681 |               </select>\n682 |               <SlidersHorizontal className=\"absolute right-3 top-3 w-3 h-3 text-white/30 pointer-events-none\" />\n683 |             </div>\n684 |           </div>\n685 | \n686 |           {/* Project Dropdown */}\n687 |           <div className=\"space-y-1.5\">\n688 |             <span className=\"text-[9px] font-mono text-white/30 uppercase font-semibold block tracking-wider\">Related Project</span>\n689 |             <div className=\"relative\">\n690 |               <select \n691 |                 value={selectedProject} \n692 |                 onChange={(e) => setSelectedProject(e.target