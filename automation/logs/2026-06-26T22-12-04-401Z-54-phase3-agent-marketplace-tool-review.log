value={ind} className=\"bg-black text-white\">{ind}</option>\n586 |                 ))}\n587 |               </select>\n588 |             </div>\n589 | \n590 |             {/* Function */}\n591 |             <div className=\"space-y-1.5\">\n592 |               <label className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">Operational Function</label>\n593 |               <select\n594 |                 value={functionFilter}\n595 |                 onChange={(e) => setFunctionFilter(e.target.value)}\n596 |                 className=\"w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white/80 focus:outline-none focus:border-[#009DFF]/50 transition-all cursor-pointer font-light font-sans\"\n597 |               >\n598 |                 {FUNCTIONS.map((f) => (\n599 |                   <option key={f} value={f} className=\"bg-black text-white\">{f}</option>\n600 |                 ))}\n601 |               </select>\n602 |             </div>\n603 | \n604 |             {/* Maturity */}\n605 |             <div className=\"space-y-1.5\">\n606 |               <label className=\"text-[10px] font-mono text-white/40 uppercase tracking-widest font-bold\">Maturity Stage</label>\n607 |               <select\n608 |                 value={maturityFilter}\n609 |                 onChange={(e) => setMaturityFilter(e.target.value)}\n610 |                 className=\"w-full bg-black/40 border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white/80 focus:outline-none focus:border-[#009DFF]/50 transition-all cursor-pointer font-light font-sans\"\n611 |               >\n612 |                 {MATURITIES.map((m) => (\n613 |                   <option key={m} value={m} className=\"bg-black text-white\">{m}</option>\n614 |                 ))}\n615 |               </select>\n616 |             </div>\n617 | \n618 |             {/* Platform Fit */}\n619 |             <div className=\"space-y-1.5\">\n620 |               <label className=\"t