{"ts":"2026-06-25T23:34:20.317Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"os4rnxnr","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/components/sections/ClientSuccessSection.tsx","old_text":null,"new_text":"\"use client\";\n\nimport React, { useState, useEffect, useRef } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport SectionHeading from \"@/components/SectionHeading\";\n\n// Definition of Representative Patterns\ninterface Layer {\n  name: string;\n  desc: string;\n  tech: string[];\n}\n\ninterface Outcome {\n  theme: string;\n  detail: string;\n}\n\ninterface Pattern {\n  id: string;\n  name: string;\n  label: string;\n  color: string;\n  tags: string[];\n  desc: string;\n  longDesc: string;\n  outcomes: Outcome[];\n  layers: Layer[];\n  logs: string[];\n}\n\nconst PATTERNS: Pattern[] = [\n  {\n    id: \"banking\",\n    name: \"Global Banking\",\n    label: \"Representative Pattern: Financial Compliance & Risk Ops\",\n    color: \"#0186E4\",\n    tags: [\"Financial Compliance\", \"Risk Operations\"],\n    desc: \"Automated regulatory checking and secure audit logging.\",\n    longDesc: \"This representative pattern shows how enterprise agentic routing coordinates multi-tier security evaluations for transaction audit logs. By placing compliance checks directly in the flow of data ingestion, financial networks can inspect and flag high-risk transactions in real-time.\",\n    outcomes: [\n      {\n        theme: \"improved compliance workflows\",\n        detail: \"Automated semantic parsing of local and international compliance standards to flag non-conforming terms instantly.\"\n      },\n      {\n        theme: \"faster decision making\",\n        detail: \"Reducing human escalation review times from hours to seconds by summarizing complex flag justifications automatically.\"\n      }\n    ],\n    layers: [\n      {\n        name: \"Secure API Gateway\",\n        desc: \"Ingests transaction payloads via encrypted TLS 1.3 tunnels and validates endpoint authorization.\",\n        tech: [\"TLS 1.3\", \"JWT Gateway\", \"gRPC Broker\"]\n      },\n      {\n        name: \"Compliance Router\",\n        desc: \"Cognitive orchestrator evaluating payload metadata and routing to specialized validation pipelines.\",\n        tech: [\"GFF Custom Router\", \"vLLM Cognitive Model\"]\n      },\n      {\n        name: \"Verification Guardrail\",\n        desc: \"Executes localized regulatory rule checking and redacts all sensitive client-identifiable PII data.\",\n        tech: [\"Guardrails SDK\", \"PII Redaction Engine\"]\n      },\n      {\n        name: \"Secure Audit Ledger\",\n        desc: \"Commits finalized ledger entries to a highly durable, immutable backup state system.\",\n        tech: [\"Temporal Workflows\", \"Cold Ledger Backup\"]\n      }\n    ],\n    logs: [\n      \"[00:01] SECURE INGESTION: Payload received via TLS 1.3 gateway.\",\n      \"[00:04] COMPLIANCE ROUTER: Parsing regulatory guidelines for cross-border rules.\",\n      \"[00:07] SEMANTIC EVALUATION: Triggered Rule 104-B (Capital Flows checks).\",\n      \"[00:10] COMPLIANCE GUARDRAIL: Passed integrity checks. Personal PII Redacted.\",\n      \"[00:13] AUDIT TRAIL: Completed state committed to secure offline ledger.\"\n    ]\n  },\n  {\n    id: \"healthcare\",\n    name: \"Clinical Intel\",\n    label: \"Representative Pattern: Clinical Intelligence Hub\",\n    color: \"#E98828\",\n    tags: [\"Clinical Intelligence\", \"Knowledge Operations\"],\n    desc: \"Deep indexing of medical guidelines and records.\",\n    longDesc: \"This representative pattern maps the ingestion of multi-format patient data and medical documentation into a single, cohesive knowledge graph. It allows authorized healthcare professionals to securely query vast medical databases with high clinical accuracy.\",\n    outcomes: [\n      {\n        theme: \"better knowledge access\",\n        detail: \"Democratizing access to clinical research archives, institutional policies, and patient histories via unified semantic indexes.\"\n      },\n      {\n        theme: \"faster decision making\",\n        detail: \"Enabling rapid cross-referencing of diagnostic patterns to assist medical personnel with research-backed options.\"\n      }\n    ],\n    layers: [\n      {\n        name: \"Document Ingestion\",\n        desc: \"Secure intake engine parsing multi-format clinical charts, FHIR schedules, and medical PDFs.\",\n        tech: [\"FHIR Parser\", \"Apache Kafka\", \"OCR Engine\"]\n      },\n      {\n        name: \"Embedding Generator\",\n        desc: \"Transforms unstructured medical texts into dense, high-dimensional coordinate embeddings.\",\n        tech: [\"vLLM Embeddings\", \"eBPF Analytics\"]\n      },\n      {\n        name: \"Hybrid Memory Search\",\n        desc: \"Performs combined database search, traversing Neo4j relational graph edges alongside pgvector similarity indexes.\",\n        tech: [\"Neo4j Graph Database\", \"pgvector\"]\n      },\n      {\n        name: \"Secure Clinical Portal\",\n        desc: \"Synthesizes final research material alongside strict medical citations onto clinicians' portal screens.\",\n        tech: [\"React Engine\", \"HIPAA Compliance Gateway\"]\n      }\n    ],\n    logs: [\n      \"[00:01] INGESTION: Parsing unstructured FHIR clinical history files.\",\n      \"[00:04] EMBEDDING LAYER: Generating vector projections for medical annotations.\",\n      \"[00:07] KNOWLEDGE GRAPH: Merging medical corpus node relations in Neo4j database.\",\n      \"[00:10] RETRIEVAL COGNITION: Executing hybrid semantic graph-vector search.\",\n      \"[00:13] PORTAL RENDER: Rendering synthesized information with source footnotes.\"\n    ]\n  },\n  {\n    id: \"manufacturing\",\n    name: \"SCADA Edge\",\n    label: \"Representative Pattern: Factory Floor Telemetry\",\n    color: \"#E4000F\",\n    tags: [\"SCADA Edge\", \"Supply Chain\"],\n    desc: \"Live SCADA streaming and predictive edge maintenance scheduling.\",\n    longDesc: \"This representative pattern outlines the deployment of edge-based AI orchestrators directly connected to factory floor systems. It monitors vibration, temperature, and cyclic tolerances, automatically scheduling preventative technician interventions before outages occur.\",\n    outcomes: [\n      {\n        theme: \"reduced manual effort\",\n        detail: \"Transitioning from scheduled/manual inspections to real-time, automated threshold alerting.\"\n      },\n      {\n        theme: \"faster decision making\",\n        detail: \"Immediately routing precise parts manifests and repair blueprints to maintenance teams.\"\n      }\n    ],\n    layers: [\n      {\n        name: \"SCADA Gateway\",\n        desc: \"Pipes live machinery telemetry metrics into secure cloud message structures.\",\n        tech: [\"gRPC Edge Broker\", \"Industrial Gateway\"]\n      },\n      {\n        name: \"Telemetry Processor\",\n        desc: \"High-frequency signal processing, smoothing sensor noise and analyzing wave anomalies.\",\n        tech: [\"Redis Stream\", \"K8s Cluster Edge\"]\n      },\n      {\n        name: \"Predictive Scheduler\",\n        desc: \"Forecasts mechanical health degradation vectors and triggers repair work allocations.\",\n        tech: [\"Custom Forecaster\", \"vLLM Model Agent\"]\n      },\n      {\n        name: \"Action Dispatch\",\n        desc: \"Constructs required replacement parts lists and pushes workorders to enterprise inventory systems.\",\n        tech: [\"Temporal Workflows\", \"Fulfillment ERP Webhook\"]\n      }\n    ],\n    logs: [\n      \"[00:01] TELEMETRY STREAM: Edge broker connected via gRPC pipeline.\",\n      \"[00:03] DIAGNOSTIC: Cycle-deviation detected in hydraulic assembly.\",\n      \"[00:06] ANALYSIS: Predictive degradation curve projects replacement in 48h.\",\n      \"[00:09] ORCHESTRATION: Compiling required parts list from inventory database.\",\n      \"[00:12] ACTION GATEWAY: Dispatched parts reservation request to ERP.\"\n    ]\n  },\n  {\n    id: \"retail\",\n    name: \"Retail Journeys\",\n    label: \"Representative Pattern: Autonomous Customer Journeys\",\n    color: \"#009DFF\",\n    tags: [\"Conversational AI\", \"Fulfillment Operations\"],\n    desc: \"Federated multi-agent checkout and support orchestration.\",\n    longDesc: \"This representative pattern highlights multi-agent coordination during high-volume consumer traffic. Dynamic routing directs customer needs (orders, returns, sizing) to autonomous specialized agents, maintaining state and ensuring human-in-the-loop escalation.\",\n    outcomes: [\n      {\n        theme: \"improved employee experience\",\n        detail: \"Deflecting high-volume basic order tracing to let human staff focus on high-touch VIP support issues.\"\n      },\n      {\n        theme: \"reduced manual effort\",\n        detail: \"Seamlessly connecting transactional APIs to perform secure order lookups and refunds in sandbox environments.\"\n      }\n    ],\n    layers: [\n      {\n        name: \"Conversational Ingest\",\n        desc: \"Unifies client dialogue records across chat and voice pipelines into structured JSON queries.\",\n        tech: [\"Secure WebSockets\", \"API Gateway\"]\n      },\n      {\n        name: \"Intent Router\",\n        desc: \"Discovers user intent vectors, routing complex service requirements to specific AI sub-agents.\",\n        tech: [\"GFF Custom Router\", \"vLLM Intent Parser\"]\n      },\n      {\n        name: \"Agent Orchestrator\",\n        desc: \"Monitors conversational turns, handles backends lookups, and runs safety and token constraints.\",\n        tech: [\"Agentic SDK Core\", \"Guardrails Framework\"]\n      },\n      {\n        name: \"CRM Synchronizer\",\n        desc: \"Saves verified conversation outcomes and transaction metrics to corporate databases.\",\n        tech: [\"CRM Connector Webhook\", \"OAuth 2.0 Client\"]\n      }\n    ],\n    logs: [\n      \"[00:01] CONVERSATIONAL CHANNEL: Inbound support query received via API.\",\n      \"[00:03] ROUTING DETERMINATION: Identified request intent as 'Order Return Modification'.\",\n      \"[00:06] INVENTORY AGENT: Querying database for fulfillment status.\",\n      \"[00:09] RESOLUTION ENGINE: Validated return eligibility. Generated return shipping label.\",\n      \"[00:12] CRM COMMIT: CRM ticket updated with return details. Active session closed.\"\n    ]\n  }\n];\n\n// Inline SVG Icon Helper for Outcome Themes\nfunction OutcomeIcon({ theme, className = \"w-5 h-5\" }: { theme: string; className?: string }) {\n  if (theme.includes(\"compliance\")) {\n    return (\n      <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z\" />\n      </svg>\n    );\n  }\n  if (theme.includes(\"decision\")) {\n    return (\n      <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" />\n      </svg>\n    );\n  }\n  if (theme.includes(\"manual\")) {\n    return (\n      <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\" />\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n      </svg>\n    );\n  }\n  if (theme.includes(\"knowledge\")) {\n    return (\n      <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\" />\n      </svg>\n    );\n  }\n  if (theme.includes(\"employee\")) {\n    return (\n      <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n        <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n      </svg>\n    );\n  }\n  return (\n    <svg className={className} fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" strokeWidth={1.5}>\n      <path strokeLinecap=\"round\" strokeLinejoin=\"round\" d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n    </svg>\n  );\n}\n\nexport default function ClientSuccessSection() {\n  const [activeTab, setActiveTab] = useState<string>(\"banking\");\n  const [isPlaying, setIsPlaying] = useState<boolean>(true);\n  const [progress, setProgress] = useState<number>(0);\n  const timelineRef = useRef<HTMLDivElement>(null);\n\n  const activePattern = PATTERNS.find((p) => p.id === activeTab) || PATTERNS[0];\n\n  // Sync animation progress\n  useEffect(() => {\n    let interval: any = null;\n    if (isPlaying) {\n      interval = setInterval(() => {\n        setProgress((prev) => {\n          if (prev >= 100) {\n            return 0; // loop back to start\n          }\n          return prev + 1;\n        });\n      }, 120);\n    }\n    return () => {\n      if (interval) clearInterval(interval);\n    };\n  }, [isPlaying]);\n\n  // Derive which structural node is active\n  const activeStep = Math.min(3, Math.floor(progress / 25));\n  const activeLayer = activePattern.layers[activeStep];\n\n  // Handle clicking on the manual seek timeline\n  const handleTimelineClick = (e: React.MouseEvent<HTMLDivElement>) => {\n    if (!timelineRef.current) return;\n    const rect = timelineRef.current.getBoundingClientRect();\n    const clickX = e.clientX - rect.left;\n    const percentage = Math.max(0, Math.min(100, (clickX / rect.width) * 100));\n    setProgress(percentage);\n  };\n\n  // Switch tabs and reset player progress\n  const selectTab = (id: string) => {\n    setActiveTab(id);\n    setProgress(0);\n    setIsPlaying(true);\n  };\n\n  // Jump to a specific logical layer\n  const jumpToLayer = (index: number) => {\n    setProgress(index * 25 + 5);\n  };\n\n  return (\n    <motion.section\n      initial={{ opacity: 0 }}\n      whileInView={{ opacity: 1 }}\n      viewport={{ once: true }}\n      transition={{ duration: 0.8 }}\n      className=\"w-full bg-[#020202] px-4 sm:px-6 lg:px-16 lg:py-32 py-20 relative overflow-hidden border-t border-white/5\"\n      id=\"client-success\"\n    >\n      <div\n        className=\"absolute inset-0 pointer-events-none\"\n        style={{\n          backgroundImage: `radial-gradient(circle at 50% 10%, ${activePattern.color}15 0%, transparent 60%)`,\n        }}\n      />\n\n      <div className=\"max-w-[1795px] mx-auto relative z-10\">\n        <SectionHeading\n          title={\n            <h2 className=\"text-[32px] sm:text-[44px] leading-none font-bold text-center uppercase text-white tracking-widest\">\n              CLIENT <span style={{ color: activePattern.color }} className=\"transition-colors duration-500\">SUCCESS</span>\n            </h2>\n          }\n          titleClassName=\"text-center\"\n          dividerWidthClassName=\"w-[300px]\"\n        />\n\n        <p className=\"mt-6 text-center text-[15px] sm:text-[17px] text-[#A0A0A0] max-w-2xl mx-auto\">\n          We don't just build POCs. We forge intelligent enterprise infrastructure. Explore the architectural blueprints and active telemetry behind our representative patterns.\n        </p>\n\n        {/* Disclaimer banner */}\n        <div className=\"mt-8 max-w-xl mx-auto bg-white/5 border border-white/10 rounded-xl px-4 py-2.5 text-center\">\n          <span className=\"text-[10px] tracking-widest font-bold uppercase text-white/50 block mb-0.5\">\n            Representative Pattern Specification\n          </span>\n          <p className=\"text-[12px] text-white/80 leading-relaxed font-mono\">\n            Anonymized blueprints of large-scale transformations. No fake numbers or identities.\n          </p>\n        </div>\n\n        {/* Tab Selection Dock */}\n        <div className=\"mt-14 flex justify-center\">\n          <div className=\"inline-flex flex-wrap md:flex-nowrap gap-1.5 p-1.5 rounded-2xl bg-white/[0.03] border border-white/10 max-w-full overflow-x-auto no-scrollbar justify-center\">\n            {PATTERNS.map((p) => {\n              const isActive = p.id === activeTab;\n              return (\n                <button\n                  key={p.id}\n                  onClick={() => selectTab(p.id)}\n                  className={`relative flex items-center gap-3 px-5 py-3 rounded-xl text-[13px] font-bold tracking-wide transition-all uppercase whitespace-nowrap ${\n                    isActive ? \"text-white\" : \"text-white/40 hover:text-white/75\"\n                  }`}\n                >\n                  {isActive && (\n                    <motion.div\n                      layoutId=\"activeTabGlow\"\n                      className=\"absolute inset-0 rounded-xl border\"\n                      style={{\n                        borderColor: p.color,\n                        background: `${p.color}08`,\n                      }}\n                      transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n                    />\n                  )}\n                  <span\n                    className=\"text-[10px] font-mono px-1.5 py-0.5 rounded bg-white/5\"\n                    style={{ color: isActive ? p.color : \"inherit\" }}\n                  >\n                    PATTERN\n                  </span>\n                  {p.name}\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Main Content Layout */}\n        <div className=\"mt-12 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n          \n          {/* Left Panel: Overview and Outcome Themes */}\n          <div className=\"lg:col-span-5 flex flex-col gap-6\">\n            <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-md p-6 sm:p-8\">\n              <span className=\"text-[10px] font-bold tracking-[0.2em] uppercase text-white/40 block mb-2 font-mono\">\n                {activePattern.label}\n              </span>\n              <h3 className=\"text-2xl sm:text-3xl font-extrabold text-white tracking-tight\">\n                {activePattern.name} Transformation\n              </h3>\n              <p className=\"mt-4 text-[14px] leading-relaxed text-[#A0A0A0]\">\n                {activePattern.longDesc}\n              </p>\n            </div>\n\n            {/* Outcome Themes Cards */}\n            <div className=\"flex flex-col gap-4\">\n              <span className=\"text-[10px] font-bold tracking-[0.15em] uppercase text-white/50 px-2 font-mono\">\n                Systemic Business Outcomes\n              </span>\n              \n              <div className=\"grid grid-cols-1 gap-4\">\n                {activePattern.outcomes.map((outcome, idx) => (\n                  <div\n                    key={idx}\n                    className=\"group relative rounded-2xl border border-white/5 bg-[#050505]/30 hover:bg-white/[0.03] transition-all p-5 flex gap-4 items-start\"\n                  >\n                    <div\n                      className=\"absolute inset-y-0 left-0 w-[3px] rounded-l-2xl transition-colors duration-500\"\n                      style={{ backgroundColor: activePattern.color }}\n                    />\n                    <div\n                      className=\"p-2.5 rounded-lg border border-white/5 bg-white/5 flex-shrink-0\"\n                      style={{ color: activePattern.color }}\n                    >\n                      <OutcomeIcon theme={outcome.theme} />\n                    </div>\n                    <div>\n                      <span className=\"text-[11px] font-mono uppercase tracking-wider text-white/40 block mb-1\">\n                        Outcome Theme\n                      </span>\n                      <h4 className=\"text-[15px] font-bold text-white capitalize\">\n                        {outcome.theme}\n                      </h4>\n                      <p className=\"mt-1.5 text-[13px] text-[#A0A0A0] leading-relaxed\">\n                        {outcome.detail}\n                      </p>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n          </div>\n\n          {/* Right Panel: Blueprint Pipeline & Video Walkthrough Console */}\n          <div className=\"lg:col-span-7 flex flex-col gap-6 w-full\">\n            \n            {/* Part 1: Interactive System Blueprint */}\n            <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-md p-6 sm:p-8\">\n              <div className=\"flex flex-wrap justify-between items-center gap-2 mb-6 border-b border-white/5 pb-4\">\n                <div>\n                  <span className=\"text-[10px] font-mono tracking-widest text-white/40 block uppercase\">\n                    Interactive System Architecture Blueprint\n                  </span>\n                  <h4 className=\"text-[15px] font-bold text-white uppercase tracking-wider mt-0.5\">\n                    Process Flow Pipeline\n                  </h4>\n                </div>\n                <span className=\"text-[10px] font-mono px-2 py-1 rounded-full border border-white/10 bg-white/5 text-white/70\">\n                  Select stage below to scrub\n                </span>\n              </div>\n\n              {/* Blueprint Pipeline Nodes */}\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n                {activePattern.layers.map((layer, idx) => {\n                  const isActive = idx === activeStep;\n                  return (\n                    <button\n                      key={idx}\n                      onClick={() => jumpToLayer(idx)}\n                      className={`relative flex flex-col text-left p-3.5 rounded-xl border transition-all ${\n                        isActive\n                          ? \"bg-white/[0.04]\"\n                          : \"bg-white/[0.01] hover:bg-white/[0.03] border-white/5\"\n                      }`}\n                      style={{\n                        borderColor: isActive ? activePattern.color : \"rgba(255, 255, 255, 0.05)\",\n                        boxShadow: isActive ? `${activePattern.color}15 0px 4px 20px` : \"none\",\n                      }}\n                    >\n                      <div className=\"flex items-center justify-between gap-1 w-full\">\n                        <span className=\"text-[10px] font-mono text-white/30\">0{idx + 1}</span>\n                        {isActive && (\n                          <span className=\"relative flex h-2 w-2\">\n                            <span\n                              className=\"animate-ping absolute inline-flex h-full w-full rounded-full opacity-75\"\n                              style={{ backgroundColor: activePattern.color }}\n                            />\n                            <span\n                              className=\"relative inline-flex rounded-full h-2 w-2\"\n                              style={{ backgroundColor: activePattern.color }}\n                            />\n                          </span>\n                        )}\n                      </div>\n                      <h5 className=\"text-[12px] font-bold text-white mt-2 truncate w-full\">\n                        {layer.name}\n                      </h5>\n                    </button>\n                  );\n                })}\n              </div>\n\n              {/* Dynamic Blueprint Inspector details */}\n              <div className=\"mt-5 p-4 rounded-xl border border-white/5 bg-white/[0.01] min-h-[110px]\">\n                <div className=\"flex flex-wrap items-center justify-between gap-2 mb-1\">\n                  <span className=\"text-[9px] font-mono uppercase tracking-widest text-white/30\">\n                    Active Layer Inspector\n                  </span>\n                  <div className=\"flex flex-wrap gap-1\">\n                    {activeLayer.tech.map((t) => (\n                      <span\n                        key={t}\n                        className=\"text-[9px] font-mono px-1.5 py-0.5 rounded bg-white/5 border border-white/10 text-white/60\"\n                      >\n                        {t}\n                      </span>\n                    ))}\n                  </div>\n                </div>\n                <h5 className=\"text-[14px] font-bold text-white mt-1\">\n                  {activeLayer.name}\n                </h5>\n                <p className=\"text-[12px] text-[#A0A0A0] mt-1.5 leading-relaxed\">\n                  {activeLayer.desc}\n                </p>\n              </div>\n            </div>\n\n            {/* Part 2: Simulated Telemetry Video Console */}\n            <div className=\"rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-md overflow-hidden flex flex-col\">\n              \n              {/* Header */}\n              <div className=\"px-5 py-4 border-b border-white/5 flex items-center justify-between bg-white/[0.01]\">\n                <div className=\"flex items-center gap-3\">\n                  <span className=\"relative flex h-2 w-2\">\n                    {isPlaying ? (\n                      <>\n                        <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75\" />\n                        <span className=\"relative inline-flex rounded-full h-2 w-2 bg-green-500\" />\n                      </>\n                    ) : (\n                      <span className=\"relative inline-flex rounded-full h-2 w-2 bg-white/40\" />\n                    )}\n                  </span>\n                  <span className=\"text-[11px] font-mono text-white/70 uppercase tracking-widest\">\n                    SYSTEM WALKTHROUGH SIMULATOR (VIDEO FEED)\n                  </span>\n                </div>\n                <span className=\"text-[9px] font-mono px-1.5 py-0.5 rounded border border-white/10 bg-white/5 text-white/50\">\n                  1080P TELEMETRY\n                </span>\n              </div>\n\n              {/* Video Console Body / Screen */}\n              <div className=\"p-5 bg-black min-h-[190px] font-mono text-[11px] sm:text-[12px] flex flex-col justify-between relative group/screen\">\n                {/* Visual grid background */}\n                <div className=\"absolute inset-0 bg-[radial-gradient(#ffffff03_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none\" />\n\n                {/* Simulated play overlay overlay when paused */}\n                {!isPlaying && (\n                  <div\n                    onClick={() => setIsPlaying(true)}\n                    className=\"absolute inset-0 bg-black/70 flex flex-col items-center justify-center gap-2 cursor-pointer z-20 backdrop-blur-[1px] transition-all\"\n                  >\n                    <div className=\"w-12 h-12 rounded-full border border-white/20 bg-white/5 flex items-center justify-center hover:bg-white/10 hover:border-white/40 transition-all\">\n                      <span className=\"text-[16px] text-white pl-0.5\">▶</span>\n                    </div>\n                    <span className=\"text-[10px] uppercase text-white/50 tracking-wider\">\n                      Click to Resume Simulation\n                    </span>\n                  </div>\n                )}\n\n                {/* Console logs */}\n                <div className=\"relative z-10 flex flex-col gap-2.5\">\n                  <AnimatePresence>\n                    {activePattern.logs.map((log, idx) => {\n                      const shows = idx <= activeStep;\n                      if (!shows) return null;\n                      return (\n                        <motion.div\n                          key={idx}\n                          initial={{ opacity: 0, x: -5 }}\n                          animate={{ opacity: 1, x: 0 }}\n                          exit={{ opacity: 0 }}\n                          transition={{ duration: 0.3 }}\n                          className=\"flex items-start gap-2 text-white/80\"\n                        >\n                          <span\n                            style={{ color: activePattern.color }}\n                            className=\"font-bold flex-shrink-0 select-none\"\n                          >\n                            ▶\n                          </span>\n                          <span className=\"leading-relaxed whitespace-pre-wrap\">{log}</span>\n                        </motion.div>\n                      );\n                    })}\n                  </AnimatePresence>\n                </div>\n\n                {/* Blinking cursor / Processing indicator */}\n                <div className=\"relative z-10 mt-4 flex items-center justify-between text-white/30 text-[10px] pt-4 border-t border-white/5\">\n                  <div className=\"flex items-center gap-1.5\">\n                    <span\n                      className=\"inline-block w-1.5 h-3 animate-pulse\"\n                      style={{ backgroundColor: activePattern.color }}\n                    />\n                    <span>SYSTEM IDLE & MONITORING PIPELINE...</span>\n                  </div>\n                  <div>\n                    <span>STEP {activeStep + 1} OF 4</span>\n                  </div>\n                </div>\n              </div>\n\n              {/* Video Player Control Bar */}\n              <div className=\"px-5 py-4 border-t border-white/5 bg-white/[0.02] flex flex-col gap-3\">\n                \n                {/* Seek Bar / Timeline Track */}\n                <div className=\"flex items-center gap-3 w-full\">\n                  <span className=\"text-[10px] font-mono text-white/40 select-none\">\n                    00:0{Math.floor(progress / 7).toString()}\n                  </span>\n                  \n                  <div\n                    ref={timelineRef}\n                    onClick={handleTimelineClick}\n                    className=\"h-1.5 flex-1 bg-white/10 rounded-full overflow-hidden cursor-pointer relative group\"\n                  >\n                    <div\n                      className=\"absolute inset-y-0 left-0 transition-all rounded-full\"\n                      style={{\n                        width: `${progress}%`,\n                        backgroundColor: activePattern.color,\n                      }}\n                    />\n                    {/* Hover dot */}\n                    <div\n                      className=\"absolute top-1/2 -translate-y-1/2 w-3 h-3 rounded-full opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none\"\n                      style={{\n                        left: `calc(${progress}% - 6px)`,\n                        backgroundColor: \"#ffffff\",\n                        boxShadow: \"0px 0px 8px rgba(255,255,255,0.8)\",\n                      }}\n                    />\n                  </div>\n\n                  <span className=\"text-[10px] font-mono text-white/40 select-none\">00:15</span>\n                </div>\n\n                {/* Control Actions */}\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex items-center gap-4\">\n                    <button\n                      onClick={() => setIsPlaying(!isPlaying)}\n                      className=\"p-1.5 rounded-lg border border-white/10 bg-white/5 hover:bg-white/10 text-white transition-all text-xs flex items-center justify-center min-w-[65px] font-bold\"\n                    >\n                      {isPlaying ? \"⏸ PAUSE\" : \"▶ PLAY\"}\n                    </button>\n                    <button\n                      onClick={() => setProgress(0)}\n                      className=\"p-1.5 rounded-lg border border-white/5 hover:border-white/15 bg-transparent text-white/50 hover:text-white transition-all text-[10px]\"\n                    >\n                      RESET FEED\n                    </button>\n                  </div>\n\n                  <div className=\"flex items-center gap-2\">\n                    <span className=\"inline-block w-1.5 h-1.5 rounded-full bg-green-500\" />\n                    <span className=\"text-[9px] font-mono tracking-widest text-white/40 uppercase\">\n                      TELEMETRY LINK SECURED\n                    </span>\n                  </div>\n                </div>\n\n              </div>\n\n            </div>\n\n          </div>\n\n        </div>\n\n      </div>\n    </motion.section>\n  );\n}\n"}}}
