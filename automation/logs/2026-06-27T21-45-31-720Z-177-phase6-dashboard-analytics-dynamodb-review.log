} else if (cid === \"3\" || cid.toLowerCase().includes(\"logistics\") || cid.toLowerCase().includes(\"client-003\")) {\n135 |         clientAssociation = \"Sovereign Logistics Unit [Preview Client]\";\n136 |       } else if (cid === \"4\" || cid.toLowerCase().includes(\"treasury\") || cid.toLowerCase().includes(\"fed-treasury\") || cid.toLowerCase().includes(\"client-004\")) {\n137 |         clientAssociation = \"Federal Treasury Division [Preview Client]\";\n138 |       } else {\n139 |         clientAssociation = dbUser.clientAssociation || `Enterprise Tenant #${cid}`;\n140 |       }\n141 |     } else if (dbUser.clientAssociation) {\n142 |       clientAssociation = dbUser.clientAssociation;\n143 |     }\n144 |   }\n145 | \n146 |   const status = (dbUser.is_active === false || dbUser.status === \"inactive\") ? \"inactive\" : \"active\";\n147 | \n148 |   const email = dbUser.email.toLowerCase().trim();\n149 | \n150 |   // Deterministic user id generation based on email if not provided\n151 |   let id = dbUser.id;\n152 |   if (!id) {\n153 |     let hash = 0;\n154 |     for (let i = 0; i < email.length; i++) {\n155 |       hash = email.charCodeAt(i) + ((hash << 5) - hash);\n156 |     }\n157 |     id = `usr-${Math.abs(hash).toString().substring(0, 6)}`;\n158 |   }\n159 | \n160 |   return {\n161 |     id: String(id),\n162 |     name: dbUser.full_name || dbUser.name || email,\n163 |     email,\n164 |     role,\n165 |     clientAssociation,\n166 |     status,\n167 |     clearance,\n168 |     permissions,\n169 |   };\n170 | }\n171 | \n172 | const ENTITY_PREFIXES: Record<string, string> = { PROJECT: \"PROJ#\", AI_OPERATION: \"AIOPS#\", DOCUMENT: \"DOC#\", INVOICE: \"INV#\", SUPPORT: \"TICKET#\", GOVERNANCE: \"GOV#\" };\n173 | const DYNAMODB_CLIENTS_TABLE = process.env.DYNAMODB_CLIENTS_TABLE || \"GFF_CLIENTS\";\n174 | const DYNAMODB_ITEMS_TABLE = process.env.DYNAMODB_ITEMS_TABLE || \"GFF_PORTAL_ITEMS\";\n175 | \n176 | export async function dynamoDbGetClient(clientId: string): Promise<any> {\n177 |   if (docClient) {\n178 |     try {\n179 |       const res = await docClient.send(new GetCommand({ TableName: DYNAMODB_CLIENTS_TABLE, Key: { client_id: clientId } }));\n180 |       return res.Item || null;\n181 |     } catch (err) { return null; }\n182 |   }\n183 |   return ((global as any)._apiMockClients || {})[clientId] || null;\n184 | }\n185 | \n186 | export async function dynamoDbListClients(): Promise<any[]> {\n187 |   if (docClient) {\n188 |     try {\n189 |       const res = await docClient.send(new ScanCommand({ TableName: DYNAMODB_CLIENTS_TABLE }));\n190 |       return res.Items || [];\n191 |     } catch (err) { return []; }\n192 |   }\n193 |   return Object.values((global as any)._apiMockClients || {});\n194 | }\n195 | \n196 | export async function dynamoDbPutClient(client: any): Promise<any> {\n197 |   if (docClient) {\n198 |     try {\n199 |       await docClient.send(new PutCommand({ TableName: DYNAMODB_CLIENTS_TABLE, Item: client }));\n200 |       return client;\n201 |     } catch (err) { return null; }\n202 |   }\n203 |   ((global as any)._apiMockClients || {})[client.id || client.client_id] = client;\n204 |   return client;\n205 | }\n206 | \n207 | export async function dynamoDbDeleteClient(clientId: string): Promise<boolean> {\n208 |   if (docClient) {\n209 |     try {\n210 |       await docClient.send(new DeleteCommand({ TableName: DYNAMODB_CLIENTS_TABLE, Key: { client_id: clientId } }));\n211 |       return true;\n212 |     } catch (err) { return false; }\n213 |   }\n214 |   const mock = (global as any)._apiMockClients || {};\n215 |   if (mock[clientId]) { delete mock[clientId]; return true; }\n216 |   return false;\n217 | }\n218 | \n219 | export async function dynamoDbGetPortalItem(clientId: string, itemId: string, entityType: string): Promise<any> {\n220 |   const pk = `CLIENT#${clientId}`, sk = `${ENTITY_PREFIXES[entityType] || \"\"}${itemId}`;\n221 |   if (docClient) {\n222 |     try {\n223 |       const res = await docClient.send(new GetCommand({ TableName: DYNAMODB_ITEMS_TABLE, Key: { PK: pk, SK: sk } }));\n224 |       return res.Item || null;\n225 |     } catch (err) { return null; }\n226 |   }\n227 |   return getMockStore(entityType)[itemId] || null;\n228 | }\n229 | \n230 | export async function dynamoDbListPortalItems(entityType: string, clientId?: string): Promise<any[]> {\n231 |   if (docClient) {\n232 |     try {\n233 |       if (clientId) {\n234 |         const res = await docClient.send(new QueryCommand({\n235 |           TableName: DYNAMODB_ITEMS_TABLE,\n236 |           KeyConditionExpression: \"PK = :pk AND begins_with(SK, :sk_prefix)\",\n237 |           ExpressionAttributeValues: { \":pk\": `CLIENT#${clientId}`, \":sk_prefix\": ENTITY_PREFIXES[entityType] || \"\" }\n238 |         }));\n239 |         return res.Items || [];\n240 |       } else {\n241 |         const res = await docClient.send(new ScanCommand({\n242 |           TableName: DYNAMODB_ITEMS_TABLE,\n243 |           FilterExpression: \"entity_type = :entity_type\",\n244 |           ExpressionAttributeValues: { \":entity_type\": entityType }\n245 |         }));\n246 |         return res.Items || [];\n247 |       }\n248 |     } catch (err) { return []; }\n249 |   }\n250 |   const items = Object.values(getMockStore(entityType));\n251 |   return clientId ? items.filter((item: any) => item.client_id === clientId) : items;\n252 | }\n253 | \n254 | export async function dynamoDbPutPortalItem(entityType: string, clientId: string, item: any): Promise<any> {\n255 |   const pk = `CLIENT#${clientId}`, sk = `${ENTITY_PREFIXES[entityType] || \"\"}${item.id}`;\n256 |   const dbItem = { ...item, PK: pk, SK: sk, entity_type: entityType, client_id: clientId };\n257 |   if (docClient) {\n258 |     try {\n259 |       await docClient.send(new PutCommand({ TableName: DYNAMODB_ITEMS_TABLE, Item: dbItem }));\n260 |       return item;\n261 |     } catch (err) { return null; }\n262 |   }\n263 |   getMockStore(entityType)[item.id] = item;\n264 |   return item;\n265 | }\n266 | \n267 | export async function dynamoDbDeletePortalItem(entityType: string, clientId: string, itemId: string): Promise<boolean> {\n268 |   const pk = `CLIENT#${clientId}`, sk = `${ENTITY_PREFIXES[entityType] || \"\"}${itemId}`;\n269 |   if (docClient) {\n270 |     try {\n271 |       await docClient.send(new DeleteCommand({ TableName: DYNAMODB_ITEMS_TABLE, Key: { PK: pk, SK: sk } }));\n272 |       return true;\n273 |     } catch (err) { return false; }\n274 |   }\n275 |   const store = getMockStore(entityType);\n276 |   if (store[itemId]) { delete store[itemId]; return true; }\n277 |   return false;\n278 | }\n279 | \n280 | function getMockStore(entityType: string): any {\n281 |   switch (entityType) {\n282 |     case \"PROJECT\": return (global as any)._apiMockProjects || {};\n283 |     case \"AI_OPERATION\": return (global as any)._apiMockAiOperations || {};\n284 |     case \"DOCUMENT\": return (global as any)._apiMockDocuments || {};\n285 |     case \"INVOICE\": return (global as any)._apiMockInvoices || {};\n286 |     case \"SUPPORT\": return (global as any)._apiMockSupportTickets || {};\n287 |     case \"GOVERNANCE\": return (global as any)._apiMockGovernance || {};\n288 |     default: return {};\n289 |   }\n290 | }\n291 | ","success":true}],"durationMs":2}}
