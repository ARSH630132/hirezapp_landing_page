{"ts":"2026-06-26T06:35:51.283Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"8bmpd65d","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/oremesh/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport { Activity, Cpu, Network, Server, Database, Zap, Compass, Shield } from \"lucide-react\";\nimport {\n  InnerPageShell,\n  InnerPageHero,\n  MotionReveal,\n  BentoGrid,\n  BentoCard,\n  Carousel,\n  RelatedPagesGrid,\n  PremiumCTA\n} from \"@/components/inner-pages\";\n\nconst MODULES = [\n  { title: \"Field Ingest Gateway\", tag: \"Edge Ingest\", desc: \"Collects high-frequency sensor streams from extraction faces.\", metric: \"Offline-First\" },\n  { title: \"Low-Bandwidth Router\", tag: \"Cognitive Routing\", desc: \"Lightweight compression to sync queries over satellites.\", metric: \"99% Ratio\" },\n  { title: \"Sovereign Safety Hub\", tag: \"Compliance Ledger\", desc: \"Cryptographic verification for machinery dispatches and shift reports.\", metric: \"Immutable\" }\n];\n\nexport default function OREMeshPlatformPage() {\n  const [node, setNode] = useState(\"shaft-4\");\n  const [tab, setTab] = useState<\"telemetry\" | \"safety\">(\"telemetry\");\n  const [log, setLog] = useState(\"System ready. Select a subterranean node above.\");\n\n  const runSim = (n: string, t: \"telemetry\" | \"safety\") => {\n    setNode(n);\n    if (t === \"telemetry\") {\n      setLog(`[${n.toUpperCase()}] SCADA: Vibration 4.2mm/s (Normal) // Temp: 82°C // Pressure: 185 bar.\\n[Status] Sandboxed telemetry verified.`);\n    } else {\n      setLog(`[${n.toUpperCase()}] Ventilation: 350 m³/min.\\n[Bylaws] Complies with Standard 104-D.\\n[Status] Safety policies validated.`);\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Industrial Mesh • Edge Layer\"\n        title=\"OREMesh Edge Platform\"\n        highlightedWord=\"OREMesh\"\n        description=\"A ruggedized, low-bandwidth, sovereign edge mesh engineered to coordinate multi-agent operations, machinery telemetry, and safety compliance across remote mining sites.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"OREMesh\" }]}\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-8 border-y border-white/5 bg-white/[0.01] px-6 rounded-xl\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Offline-First Autonomy</span>\n            <h2 className=\"text-2xl font-bold text-white mt-1\">Ruggedized Edge Execution</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light text-sm leading-relaxed\">\n              Subterranean environments require highly resilient systems. OREMesh functions as an edge-native execution layer, orchestrating safety agents, filtering SCADA streams, and compressing satellite synchronizations for uninterrupted site decision-making.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Interactive Workspace */}\n        <MotionReveal className=\"space-y-6\">\n          <h2 className=\"text-xl font-bold text-white text-center\">Interactive Low-Bandwidth Edge Simulator</h2>\n          <div className=\"max-w-4xl mx-auto rounded-xl border border-white/10 bg-[#04060b] overflow-hidden flex flex-col md:flex-row\">\n            <div className=\"flex-grow p-6 bg-black/40 border-r border-white/5 flex flex-col items-center justify-center min-h-[200px] relative\">\n              <span className=\"absolute top-3 left-3 text-[9px] font-mono text-white/30 tracking-widest uppercase\">OREMesh Node Topology</span>\n              <div className=\"flex gap-4 mt-6\">\n                {[\"shaft-4\", \"haul-truck-9\", \"shovel-12\"].map((n) => (\n                  <button\n                    key={n} onClick={() => runSim(n, tab)}\n                    className={`p-3 rounded-lg border text-xs capitalize transition-all ${node === n ? \"border-[#009DFF] bg-[#009DFF]/5 text-[#009DFF]\" : \"border-white/5 bg-black text-white/60\"}`}\n                  >\n                    <Compass className=\"w-4 h-4 mx-auto mb-1 text-[#009DFF]\" />\n                    {n.replace(\"-\", \" \")}\n                  </button>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"w-full md:w-[280px] p-5 flex flex-col justify-between bg-black/20 text-xs\">\n              <div className=\"space-y-3\">\n                <span className=\"text-[10px] font-mono text-white/30 uppercase tracking-wider block\">Verify Mode</span>\n                <div className=\"flex gap-2\">\n                  <button onClick={() => { setTab(\"telemetry\"); runSim(node, \"telemetry\"); }} className={`px-2.5 py-1 text-xs border rounded ${tab === \"telemetry\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Telemetry</button>\n                  <button onClick={() => { setTab(\"safety\"); runSim(node, \"safety\"); }} className={`px-2.5 py-1 text-xs border rounded ${tab === \"safety\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Safety</button>\n                </div>\n              </div>\n              <div className=\"mt-4 pt-3 border-t border-white/5\">\n                <pre className=\"p-2.5 rounded bg-black text-[10px] font-mono text-emerald-400 border border-white/5 h-[80px] overflow-y-auto whitespace-pre-wrap\">{log}</pre>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        <Carousel items={MODULES} />\n\n        {/* Bento Grid */}\n        <BentoGrid className=\"max-w-5xl mx-auto\">\n          <BentoCard title=\"AES-256 Crypto\" description=\"Local signature on telemetry streams before satellite replication.\" badge=\"Security\" icon={<Shield className=\"w-5 h-5\" />} />\n          <BentoCard title=\"99% Compression\" description=\"Differential syncing engine limits metadata overhead on satellite links.\" badge=\"Bandwidth\" icon={<Zap className=\"w-5 h-5\" />} />\n          <BentoCard title=\"12ms Local Dispatch\" description=\"Immediate task scaling when machine tolerance triggers alerts.\" badge=\"Latency\" icon={<Activity className=\"w-5 h-5\" />} />\n        </BentoGrid>\n\n        <RelatedPagesGrid links={[\n          { title: \"Extraction & Mining Solutions\", tag: \"Industry Core\", desc: \"Discover GFF's multi-agent architectures for mining operations.\", href: \"/industries/mining\" },\n          { title: \"Unified Control Center\", tag: \"Cockpit Console\", desc: \"Monitor edge swarm health, compute spend, and rule audit logs.\", href: \"/platforms/control-center\" }\n        ]} />\n\n        <PremiumCTA\n          title=\"Deploy Ruggedized Agent Intelligence to Your Extraction Sites\"\n          description=\"Schedule a technical engineering assessment with our mining systems leads to secure your low-bandwidth remote-site links.\"\n          primaryLabel=\"Connect with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
