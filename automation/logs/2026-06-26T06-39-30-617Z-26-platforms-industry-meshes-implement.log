{"ts":"2026-06-26T06:35:23.942Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"n71wu8yk","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/oremesh/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport { Activity, Cpu, Network, Server, Database, Zap, Compass, Shield } from \"lucide-react\";\nimport {\n  InnerPageShell,\n  InnerPageHero,\n  MotionReveal,\n  BentoGrid,\n  BentoCard,\n  Carousel,\n  RelatedPagesGrid,\n  PremiumCTA\n} from \"@/components/inner-pages\";\n\nconst MODULES = [\n  {\n    title: \"Field Ingest Gateway\",\n    tag: \"Edge Ingest\",\n    desc: \"Collects high-frequency sensor streams and autonomous truck telemetry directly from the extraction face.\",\n    metric: \"Offline-First\"\n  },\n  {\n    title: \"Low-Bandwidth Router\",\n    tag: \"Cognitive Routing\",\n    desc: \"Uses lightweight payload compression to sync agent searches through low-capacity satellite links.\",\n    metric: \"99% Compression\"\n  },\n  {\n    title: \"Sovereign Safety Hub\",\n    tag: \"Compliance Ledger\",\n    desc: \"Guarantees all machinery dispatches and shift reports undergo local cryptographic verification.\",\n    metric: \"Immutable\"\n  },\n  {\n    title: \"Geotechnical Intelligence Core\",\n    tag: \"Sub-surface Core\",\n    desc: \"Automates parsing of seismic reports, core-sample files, and drill logs to update subterranean maps.\",\n    metric: \"Automated Maps\"\n  }\n];\n\nconst AGENT_CARDS = [\n  {\n    title: \"Field Operations Agent\",\n    tag: \"Task Coordinator\",\n    desc: \"Unifies work orders, matches haul truck routes to shovel capacity, and coordinates shift transitions securely.\"\n  },\n  {\n    title: \"Safety Knowledge Agent\",\n    tag: \"Regulatory Oracle\",\n    desc: \"Answers complex mining compliance queries, retrieves local ventilation formulas, and formats safety checklists.\"\n  },\n  {\n    title: \"Executive Visibility Dashboard\",\n    tag: \"Centralized Audit\",\n    desc: \"Aggregates ore grade estimates, machine downtime reports, and site incident lists into a single dashboard.\"\n  }\n];\n\nconst RELATED_LINKS = [\n  {\n    title: \"Extraction & Mining Solutions\",\n    tag: \"Industry Core\",\n    desc: \"Explore how GFF's multi-agent architectures are applied across modern heavy industries.\",\n    href: \"/industries/mining\"\n  },\n  {\n    title: \"Unified Control Center\",\n    tag: \"Cockpit Console\",\n    desc: \"Enforce compliance rules, audit execution tokens, and monitor edge swarm status from one secure panel.\",\n    href: \"/platforms/control-center\"\n  }\n];\n\nexport default function OREMeshPlatformPage() {\n  const [activeTab, setActiveTab] = useState<\"telemetry\" | \"safety\" | \"routing\">(\"telemetry\");\n  const [selectedNode, setSelectedNode] = useState<string>(\"shaft-4\");\n  const [isSimulating, setIsSimulating] = useState(false);\n  const [simOutput, setSimOutput] = useState(\"System ready. Click on an extraction node or select a monitoring rule to trigger verification.\");\n\n  const runSimulation = (nodeId: string, type: \"telemetry\" | \"safety\" | \"routing\") => {\n    setIsSimulating(true);\n    setSimOutput(`[OREMesh] Handshaking with edge node ${nodeId.toUpperCase()}...`);\n    \n    setTimeout(() => {\n      if (type === \"telemetry\") {\n        setSimOutput(\n          `[Gateway] Node: ${nodeId.toUpperCase()}\\n` +\n          `[SCADA] Vibration: 4.2mm/s (Normal) // Temp: 82°C // Pressure: 185 bar\\n` +\n          `[OREMesh Core] Telemetry hashes verified against local sandbox. Status: OPTIMAL.`\n        );\n      } else if (type === \"safety\") {\n        setSimOutput(\n          `[Knowledge Engine] Analyzing ventilation guidelines for ${nodeId.toUpperCase()}...\\n` +\n          `[Bylaws] Verifying local standard 104-D. Air flow: 350 m³/min.\\n` +\n          `[OREMesh Core] Safety rules validated. No anomalies flagged.`\n        );\n      } else {\n        setSimOutput(\n          `[Packet Router] Satellite compression completed.\\n` +\n          `[Bandwidth] Compressed payloads from 4.2MB to 38KB (99.1% savings).\\n` +\n          `[Routing] Handshake resolved in 184ms.`\n        );\n      }\n      setIsSimulating(false);\n    }, 400);\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Industrial Mesh • Edge Layer\"\n        title=\"OREMesh Edge Platform\"\n        highlightedWord=\"OREMesh\"\n        description=\"A ruggedized, low-bandwidth, sovereign edge mesh engineered to coordinate multi-agent operations, machinery telemetry, and safety compliance across remote mining sites.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"OREMesh\" }]}\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-20\">\n        \n        {/* Narrative Banner */}\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-10 border-y border-white/5 items-center bg-white/[0.01] px-6 rounded-2xl\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Offline-First Autonomy</span>\n            <h2 className=\"text-2xl font-bold text-white mt-2\">Ruggedized Edge Execution</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light text-sm leading-relaxed\">\n              Subterranean environments and open-pit mining operations require highly reliable infrastructure that cannot rely on constant gigabit links. OREMesh functions as a highly sandboxed, edge-native execution layer. It orchestrates local safety agents, filters machine telemetry streams, and compresses satellite synchronization payloads, guaranteeing uninterrupted decisioning even when entirely cut off from cloud servers.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Interactive Mesh Diagram & Simulator */}\n        <MotionReveal className=\"space-y-8\">\n          <div className=\"text-center max-w-2xl mx-auto\">\n            <h2 className=\"text-xl sm:text-2xl font-bold text-white tracking-tight\">Interactive Low-Bandwidth Edge Simulator</h2>\n            <p className=\"text-white/50 text-xs mt-2 font-light\">\n              Select a subterranean extraction node or monitoring category below to execute edge-agent validation scripts over our virtual OREMesh topology.\n            </p>\n          </div>\n\n          <div className=\"max-w-4xl mx-auto rounded-2xl border border-white/10 bg-[#04060b] overflow-hidden shadow-2xl flex flex-col md:flex-row items-stretch\">\n            {/* Visual Map */}\n            <div className=\"flex-grow p-6 bg-black/40 border-r border-white/5 flex flex-col items-center justify-center min-h-[300px] relative\">\n              <span className=\"absolute top-4 left-4 text-[9px] font-mono text-white/30 tracking-widest uppercase\">OREMesh Topological Node Map</span>\n              \n              <div className=\"w-full max-w-[320px] aspect-square relative flex items-center justify-center\">\n                <svg className=\"absolute inset-0 w-full h-full pointer-events-none\" viewBox=\"0 0 320 320\">\n                  <line x1=\"160\" y1=\"50\" x2=\"80\" y2=\"150\" stroke=\"rgba(0,157,255,0.2)\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" />\n                  <line x1=\"160\" y1=\"50\" x2=\"240\" y2=\"150\" stroke=\"rgba(0,157,255,0.2)\" strokeWidth=\"1.5\" strokeDasharray=\"4 4\" />\n                  <line x1=\"80\" y1=\"150\" x2=\"240\" y2=\"150\" stroke=\"rgba(0,157,255,0.1)\" strokeWidth=\"1\" />\n                  <line x1=\"80\" y1=\"150\" x2=\"60\" y2=\"250\" stroke={selectedNode === \"shaft-4\" ? \"#009DFF\" : \"rgba(0,157,255,0.15)\"} strokeWidth=\"1.5\" />\n                  <line x1=\"80\" y1=\"150\" x2=\"160\" y2=\"250\" stroke={selectedNode === \"haul-truck-9\" ? \"#009DFF\" : \"rgba(0,157,255,0.15)\"} strokeWidth=\"1.5\" />\n                  <line x1=\"240\" y1=\"150\" x2=\"260\" y2=\"250\" stroke={selectedNode === \"shovel-12\" ? \"#009DFF\" : \"rgba(0,157,255,0.15)\"} strokeWidth=\"1.5\" />\n                </svg>\n\n                {/* Surface Gateway */}\n                <div className=\"absolute top-[20px] left-1/2 -translate-x-1/2 flex flex-col items-center\">\n                  <div className=\"w-10 h-10 rounded-lg bg-black border border-white/20 flex items-center justify-center text-[#009DFF]\">\n                    <Server className=\"w-4 h-4\" />\n                  </div>\n                  <span className=\"text-[8px] font-mono font-bold text-white mt-1 uppercase\">Surface Gateway</span>\n                </div>\n\n                {/* Left Router */}\n                <div className=\"absolute top-[130px] left-[55px] flex flex-col items-center\">\n                  <div className=\"w-7 h-7 rounded bg-black border border-white/10 flex items-center justify-center text-white/50\">\n                    <Network className=\"w-3.5 h-3.5\" />\n                  </div>\n                </div>\n                {/* Right Router */}\n                <div className=\"absolute top-[130px] right-[55px] flex flex-col items-center\">\n                  <div className=\"w-7 h-7 rounded bg-black border border-white/10 flex items-center justify-center text-white/50\">\n                    <Network className=\"w-3.5 h-3.5\" />\n                  </div>\n                </div>\n\n                {/* Deep Active Nodes */}\n                <div className=\"absolute bottom-[30px] left-[30px] flex flex-col items-center\">\n                  <button \n                    onClick={() => { setSelectedNode(\"shaft-4\"); runSimulation(\"shaft-4\", activeTab); }}\n                    className={`w-9 h-9 rounded-full border flex items-center justify-center transition-all ${selectedNode === \"shaft-4\" ? \"border-[#009DFF] bg-[#009DFF]/10 text-[#009DFF] scale-110\" : \"border-white/10 bg-black text-white/60\"}`}\n                  >\n                    <Compass className=\"w-4 h-4\" />\n                  </button>\n                  <span className=\"text-[8px] font-mono text-white/50 mt-1 uppercase\">Shaft #4</span>\n                </div>\n\n                <div className=\"absolute bottom-[30px] left-[135px] flex flex-col items-center\">\n                  <button \n                    onClick={() => { setSelectedNode(\"haul-truck-9\"); runSimulation(\"haul-truck-9\", activeTab); }}\n                    className={`w-9 h-9 rounded-full border flex items-center justify-center transition-all ${selectedNode === \"haul-truck-9\" ? \"border-[#009DFF] bg-[#009DFF]/10 text-[#009DFF] scale-110\" : \"border-white/10 bg-black text-white/60\"}`}\n                  >\n                    <Activity className=\"w-4 h-4\" />\n                  </button>\n                  <span className=\"text-[8px] font-mono text-white/50 mt-1 uppercase\">Haul Truck</span>\n                </div>\n\n                <div className=\"absolute bottom-[30px] right-[30px] flex flex-col items-center\">\n                  <button \n                    onClick={() => { setSelectedNode(\"shovel-12\"); runSimulation(\"shovel-12\", activeTab); }}\n                    className={`w-9 h-9 rounded-full border flex items-center justify-center transition-all ${selectedNode === \"shovel-12\" ? \"border-[#009DFF] bg-[#009DFF]/10 text-[#009DFF] scale-110\" : \"border-white/10 bg-black text-white/60\"}`}\n                  >\n                    <Cpu className=\"w-4 h-4\" />\n                  </button>\n                  <span className=\"text-[8px] font-mono text-white/50 mt-1 uppercase\">Shovel #12</span>\n                </div>\n              </div>\n            </div>\n\n            {/* Simulated Workspace Controls */}\n            <div className=\"w-full md:w-[280px] p-5 flex flex-col justify-between shrink-0 bg-black/20\">\n              <div className=\"space-y-4\">\n                <span className=\"text-[10px] font-mono font-bold text-white/30 uppercase tracking-wider block\">Simulator Parameters</span>\n                \n                <div className=\"flex flex-col gap-2\">\n                  {[\n                    { id: \"telemetry\", label: \"Edge Telemetry\", icon: Activity },\n                    { id: \"safety\", label: \"Safety Compliance\", icon: Shield },\n                    { id: \"routing\", label: \"Satellite Sync\", icon: Zap }\n                  ].map((tab) => {\n                    const Icon = tab.icon;\n                    return (\n                      <button\n                        key={tab.id}\n                        onClick={() => { setActiveTab(tab.id as any); runSimulation(selectedNode, tab.id as any); }}\n                        className={`p-2.5 rounded-lg text-left transition-all border flex items-center gap-2 cursor-pointer text-xs ${\n                          activeTab === tab.id \n                            ? \"bg-[#009DFF]/10 border-[#009DFF] text-white\" \n                            : \"border-white/5 bg-white/[0.01] text-white/50 hover:text-white\"\n                        }`}\n                      >\n                        <Icon className=\"w-3.5 h-3.5 shrink-0 text-[#009DFF]\" />\n                        <span className=\"font-semibold\">{tab.label}</span>\n                      </button>\n                    );\n                  })}\n                </div>\n              </div>\n\n              {/* Console log outputs */}\n              <div className=\"mt-4 pt-4 border-t border-white/5 space-y-2\">\n                <span className=\"text-[8px] font-mono text-white/30 uppercase tracking-widest block font-bold\">OREMesh Active Controller Log</span>\n                <div className=\"p-2.5 rounded bg-black text-[10px] font-mono text-emerald-400 border border-white/5 h-[100px] overflow-y-auto whitespace-pre-wrap leading-relaxed\">\n                  {simOutput}\n                </div>\n                <button\n                  disabled={isSimulating}\n                  onClick={() => runSimulation(selectedNode, activeTab)}\n                  className=\"w-full py-1.5 bg-[#009DFF]/20 hover:bg-[#009DFF]/30 border border-[#009DFF]/40 text-white font-semibold text-[11px] rounded transition-all cursor-pointer\"\n                >\n                  {isSimulating ? \"Processing...\" : `Verify ${selectedNode.toUpperCase()}`}\n                </button>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        {/* Modules Carousel */}\n        <MotionReveal className=\"space-y-6\">\n          <div className=\"text-center max-w-2xl mx-auto\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Industrial Modules</span>\n            <h2 className=\"text-2xl font-bold text-white mt-2\">OREMesh System Components</h2>\n          </div>\n          <Carousel items={MODULES} />\n        </MotionReveal>\n\n        {/* Specialized Agent Grid */}\n        <MotionReveal className=\"space-y-8\">\n          <div className=\"text-center max-w-2xl mx-auto\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Targeted Specialists</span>\n            <h2 className=\"text-2xl font-bold text-white mt-2\">Autonomous Extraction Agents</h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto\">\n            {AGENT_CARDS.map((agent) => (\n              <div \n                key={agent.title}\n                className=\"p-6 rounded-[20px] border border-white/5 bg-[#050505]/70 backdrop-blur-md flex flex-col justify-between hover:border-white/12 transition-all duration-300 group\"\n              >\n                <div>\n                  <span className=\"text-[10px] font-mono text-[#009DFF] tracking-widest uppercase font-semibold\">\n                    {agent.tag}\n                  </span>\n                  <h4 className=\"text-[16px] font-semibold text-white tracking-tight mt-2 group-hover:text-[#009DFF] transition-colors\">\n                    {agent.title}\n                  </h4>\n                  <p className=\"mt-2 text-[12px] leading-relaxed text-white/60 font-light\">\n                    {agent.desc}\n                  </p>\n                </div>\n                <div className=\"mt-6 pt-4 border-t border-white/5 flex items-center justify-between text-[9px] font-mono text-white/30 uppercase\">\n                  <span>Isolated Sandbox</span>\n                  <div className=\"w-1.5 h-1.5 rounded-full bg-emerald-400\" />\n                </div>\n              </div>\n            ))}\n          </div>\n        </MotionReveal>\n\n        {/* Bento Grid: Architecture Highlights */}\n        <MotionReveal className=\"space-y-8\">\n          <div className=\"text-center max-w-2xl mx-auto\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Hardened Infrastructure</span>\n            <h2 className=\"text-2xl font-bold text-white mt-2\">Why Enterprise Extractors Run on OREMesh</h2>\n          </div>\n\n          <BentoGrid className=\"max-w-5xl mx-auto\">\n            <BentoCard\n              title=\"Military-Grade Local Cryptography\"\n              description=\"Every sensor ingestion telemetry file, machinery log, and supervisor request is locally signed inside the sandbox container before replication.\"\n              badge=\"Security\"\n              metric={{ value: \"AES-256\", label: \"Local Encryption\" }}\n              icon={<Shield className=\"w-5 h-5 text-white/50\" />}\n              glowColor=\"blue\"\n            />\n            <BentoCard\n              title=\"State Compression Engine\"\n              description=\"A custom differential syncing engine reduces metadata payloads, avoiding high carrier expenses over expensive standard satellite paths.\"\n              badge=\"Efficiency\"\n              metric={{ value: \"99.1%\", label: \"Bandwidth Compression\" }}\n              icon={<Zap className=\"w-5 h-5 text-white/50\" />}\n              glowColor=\"blue\"\n            />\n            <BentoCard\n              title=\"SCADA Device Mapping\"\n              description=\"Direct integration with standard mining controller layers ensures quick telemetry parsing, zero middleware, and immediate hazard detection.\"\n              badge=\"Integration\"\n              metric={{ value: \"12ms\", label: \"Anomaly Response Time\" }}\n              icon={<Activity className=\"w-5 h-5 text-white/50\" />}\n              glowColor=\"blue\"\n            />\n          </BentoGrid>\n        </MotionReveal>\n\n        {/* References Links */}\n        <MotionReveal className=\"border-t border-white/5 pt-12\">\n          <RelatedPagesGrid links={RELATED_LINKS} />\n        </MotionReveal>\n\n        {/* Premium CTA */}\n        <div className=\"pt-8\">\n          <PremiumCTA\n            title=\"Deploy Ruggedized Agent Intelligence to Your Extraction Sites\"\n            description=\"Consult GFF engineering specialists to configure a high-availability, offline-first OREMesh edge setup for your remote assets and subterranean networks.\"\n            primaryLabel=\"Contact GFF Systems Architects\"\n            primaryHref=\"/contact\"\n          />\n        </div>\n\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
