{"ts":"2026-06-26T06:38:31.134Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"7j7qn6uv","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/telecomverse/page.tsx","old_text":"export default function TelecomVersePlatformPage() {\n  const [node, setNode] = useState(\"node-alpha\");\n  const [log, setLog] = useState(\"System ready.\");\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Sovereign Network Mesh • Carrier Layer\"\n        title=\"TelecomVerse Core\"\n        highlightedWord=\"TelecomVerse\"\n        description=\"A high-throughput, carrier-grade network orchestration mesh enabling telecom providers to optimize network workloads, dispatch field dispatches, and secure client operations.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"TelecomVerse\" }]}\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <Carousel items={MODULES} />\n        <PremiumCTA\n          title=\"Scale Carrier Network Operations Securely\"\n          description=\"Schedule a technical workspace review with our telecom systems engineers to secure telemetry streams and deploy sovereign airgaps.\"\n          primaryLabel=\"Connect with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}","new_text":"export default function TelecomVersePlatformPage() {\n  const [node, setNode] = useState(\"node-alpha\");\n  const [tab, setTab] = useState<\"network\" | \"dispatch\">(\"network\");\n  const [log, setLog] = useState(\"System ready. Select a carrier network node above.\");\n\n  const runSim = (n: string, t: \"network\" | \"dispatch\") => {\n    setNode(n);\n    if (t === \"network\") {\n      setLog(`[${n.toUpperCase()}] Analyzing peak loads... 84% Capacity\\nStatus: Rerouting signal packets via fiber transport ring. Congestion cleared.`);\n    } else {\n      setLog(`[${n.toUpperCase()}] Fiber degradation alert detected at Sector 4.\\nAction: Scheduled Field Dispatch. Ticket ID: TK-3901 generated.\\nStatus: Dispatch queued.`);\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Sovereign Network Mesh • Carrier Layer\"\n        title=\"TelecomVerse Core\"\n        highlightedWord=\"TelecomVerse\"\n        description=\"A high-throughput, carrier-grade network orchestration mesh enabling telecom providers to optimize network workloads, dispatch field dispatches, and secure client operations.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"TelecomVerse\" }]}\n      />\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-8 border-y border-white/5 bg-white/[0.01] px-6 rounded-xl\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Carrier-Grade Operations</span>\n            <h2 className=\"text-2xl font-bold text-white mt-1\">High-Throughput Orchestration</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light text-sm leading-relaxed\">\n              Managing millions of real-time network interactions demands absolute stability. TelecomVerse coordinates continuous carrier telemetry and customer support intent streams, executing predictive rerouting and dispatching field teams with high accuracy.\n            </p>\n          </div>\n        </MotionReveal>\n\n        <MotionReveal className=\"space-y-6\">\n          <h2 className=\"text-xl font-bold text-white text-center\">Interactive Telecom Core Simulator</h2>\n          <div className=\"max-w-4xl mx-auto rounded-xl border border-white/10 bg-[#04060b] overflow-hidden flex flex-col md:flex-row\">\n            <div className=\"flex-grow p-6 bg-black/40 border-r border-white/5 flex flex-col items-center justify-center min-h-[160px] relative\">\n              <span className=\"absolute top-3 left-3 text-[9px] font-mono text-white/30 tracking-widest uppercase\">TelecomVerse Optical Topology</span>\n              <div className=\"flex gap-4 mt-6\">\n                {[\"node-alpha\", \"node-beta\", \"node-gamma\"].map((n) => (\n                  <button\n                    key={n} onClick={() => runSim(n, tab)}\n                    className={`p-3 rounded-lg border text-xs capitalize transition-all ${node === n ? \"border-[#009DFF] bg-[#009DFF]/5 text-[#009DFF]\" : \"border-white/5 bg-black text-white/60\"}`}\n                  >\n                    <Radio className=\"w-4 h-4 mx-auto mb-1 text-[#009DFF]\" />\n                    {n.replace(\"-\", \" \")}\n                  </button>\n                ))}\n              </div>\n            </div>\n            <div className=\"w-full md:w-[280px] p-5 flex flex-col justify-between bg-black/20 text-xs\">\n              <div className=\"space-y-3\">\n                <span className=\"text-[10px] font-mono text-white/30 uppercase tracking-wider block\">Simulator Mode</span>\n                <div className=\"flex gap-2\">\n                  <button onClick={() => { setTab(\"network\"); runSim(node, \"network\"); }} className={`px-2.5 py-1 text-xs border rounded ${tab === \"network\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Network Load</button>\n                  <button onClick={() => { setTab(\"dispatch\"); runSim(node, \"dispatch\"); }} className={`px-2.5 py-1 text-xs border rounded ${tab === \"dispatch\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Field Dispatch</button>\n                </div>\n              </div>\n              <div className=\"mt-4 pt-3 border-t border-white/5\">\n                <pre className=\"p-2.5 rounded bg-black text-[10px] font-mono text-emerald-400 border border-white/5 h-[80px] overflow-y-auto whitespace-pre-wrap\">{log}</pre>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        <Carousel items={MODULES} />\n\n        <BentoGrid className=\"max-w-5xl mx-auto\">\n          <BentoCard title=\"Sovereign Sandbox\" description=\"Locks out untrusted execution pools, keeping data streams within private network corridors.\" badge=\"Security\" icon={<Shield className=\"w-5 h-5\" />} />\n          <BentoCard title=\"Dynamic Traffic Rerouting\" description=\"Auto-adjusts load routes during high density bursts or fiber faults.\" badge=\"Reliability\" icon={<Zap className=\"w-5 h-5\" />} />\n          <BentoCard title=\"Microsecond Telemetry Logs\" description=\"Continuous ingestion layer monitors 1.2M logs/sec under 10ms overhead.\" badge=\"Latency\" icon={<Activity className=\"w-5 h-5\" />} />\n        </BentoGrid>\n\n        <RelatedPagesGrid links={[\n          { title: \"Telecom Solutions\", tag: \"Industry Core\", desc: \"Discover how GFF's carrier-grade agent architectures optimize network loads.\", href: \"/industries/telecom\" },\n          { title: \"Control Center\", tag: \"Cockpit Console\", desc: \"Monitor edge swarm health, compute spend, and rule audit logs.\", href: \"/platforms/control-center\" }\n        ]} />\n\n        <PremiumCTA\n          title=\"Scale Carrier Network Operations Securely\"\n          description=\"Schedule a technical workspace review with our telecom systems engineers to secure telemetry streams and deploy sovereign airgaps.\"\n          primaryLabel=\"Connect with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
