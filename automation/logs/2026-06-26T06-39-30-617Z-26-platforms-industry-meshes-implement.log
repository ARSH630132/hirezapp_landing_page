{"ts":"2026-06-26T06:35:39.293Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"qg4a3xft","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/platforms/oremesh/page.tsx","new_text":"\"use client\";\n\nimport { useState } from \"react\";\nimport { Activity, Cpu, Network, Server, Database, Zap, Compass, Shield } from \"lucide-react\";\nimport {\n  InnerPageShell,\n  InnerPageHero,\n  MotionReveal,\n  BentoGrid,\n  BentoCard,\n  Carousel,\n  RelatedPagesGrid,\n  PremiumCTA\n} from \"@/components/inner-pages\";\n\nconst MODULES = [\n  { title: \"Field Ingest Gateway\", tag: \"Edge Ingest\", desc: \"Collects high-frequency sensor streams from the extraction face.\", metric: \"Offline-First\" },\n  { title: \"Low-Bandwidth Router\", tag: \"Cognitive Routing\", desc: \"Lightweight payload compression to sync queries over satellite links.\", metric: \"99% Compression\" },\n  { title: \"Sovereign Safety Hub\", tag: \"Compliance Ledger\", desc: \"Local cryptographic verification for machinery dispatches and shift reports.\", metric: \"Immutable\" }\n];\n\nconst AGENTS = [\n  { title: \"Field Operations Agent\", tag: \"Task Coordinator\", desc: \"Unifies work orders, matches haul truck routes to capacity, and coordinates shift transitions.\" },\n  { title: \"Safety Knowledge Agent\", tag: \"Regulatory Oracle\", desc: \"Retrieves local ventilation formulas and formats compliance checklists over offline vector storage.\" },\n  { title: \"Executive Visibility Dashboard\", tag: \"Centralized Audit\", desc: \"Aggregates production volumes, machine downtime, and incident lists into a secure audit view.\" }\n];\n\nexport default function OREMeshPlatformPage() {\n  const [selectedNode, setSelectedNode] = useState(\"shaft-4\");\n  const [activeTab, setActiveTab] = useState<\"telemetry\" | \"safety\">(\"telemetry\");\n  const [simOutput, setSimOutput] = useState(\"System ready. Click on an extraction node above to trigger local verification.\");\n\n  const runSimulation = (nodeId: string, type: \"telemetry\" | \"safety\") => {\n    setSelectedNode(nodeId);\n    if (type === \"telemetry\") {\n      setSimOutput(`[OREMesh] Node: ${nodeId.toUpperCase()}\\n[SCADA] Vibration: 4.2mm/s (Normal) // Temp: 82°C // Pressure: 185 bar\\n[Status] Handshake verified against secure local sandbox. Optimal.`);\n    } else {\n      setSimOutput(`[Knowledge Engine] Analyzing guidelines for ${nodeId.toUpperCase()}...\\n[Bylaws] Air flow: 350 m³/min (Compliance Lock: 104-D).\\n[Status] Safety rules validated.`);\n    }\n  };\n\n  return (\n    <InnerPageShell>\n      <InnerPageHero\n        category=\"Industrial Mesh • Edge Layer\"\n        title=\"OREMesh Edge Platform\"\n        highlightedWord=\"OREMesh\"\n        description=\"A ruggedized, low-bandwidth, sovereign edge mesh engineered to coordinate multi-agent operations, machinery telemetry, and safety compliance across remote mining sites.\"\n        breadcrumbs={[{ label: \"Platforms\", href: \"/platforms\" }, { label: \"OREMesh\" }]}\n      />\n\n      <div className=\"max-w-[1795px] mx-auto px-6 lg:px-16 pb-24 space-y-16\">\n        <MotionReveal className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 py-8 border-y border-white/5 items-center bg-white/[0.01] px-6 rounded-xl\">\n          <div className=\"lg:col-span-5\">\n            <span className=\"text-xs font-mono text-[#009DFF] uppercase tracking-widest font-bold\">Offline-First Autonomy</span>\n            <h2 className=\"text-2xl font-bold text-white mt-1\">Ruggedized Edge Execution</h2>\n          </div>\n          <div className=\"lg:col-span-7\">\n            <p className=\"text-white/70 font-light text-xs sm:text-sm leading-relaxed\">\n              Subterranean environments require highly resilient systems. OREMesh functions as an edge-native execution layer, orchestrating safety agents, filtering SCADA streams, and compressing satellite synchronizations for uninterrupted site decision-making.\n            </p>\n          </div>\n        </MotionReveal>\n\n        {/* Interactive Workspace */}\n        <MotionReveal className=\"space-y-6\">\n          <h2 className=\"text-xl font-bold text-white text-center\">Interactive Low-Bandwidth Edge Simulator</h2>\n          <div className=\"max-w-4xl mx-auto rounded-xl border border-white/10 bg-[#04060b] overflow-hidden flex flex-col md:flex-row items-stretch\">\n            <div className=\"flex-grow p-6 bg-black/40 border-r border-white/5 flex flex-col items-center justify-center min-h-[260px] relative\">\n              <span className=\"absolute top-3 left-3 text-[9px] font-mono text-white/30 tracking-widest uppercase\">OREMesh Node Topology</span>\n              <div className=\"flex gap-4 mt-4\">\n                {[\"shaft-4\", \"haul-truck-9\", \"shovel-12\"].map((node) => (\n                  <button\n                    key={node}\n                    onClick={() => runSimulation(node, activeTab)}\n                    className={`p-3 rounded-lg border text-xs capitalize transition-all ${selectedNode === node ? \"border-[#009DFF] bg-[#009DFF]/5 text-[#009DFF]\" : \"border-white/5 bg-black hover:border-white/20 text-white/60\"}`}\n                  >\n                    <Compass className=\"w-4 h-4 mx-auto mb-1 text-[#009DFF]\" />\n                    {node.replace(\"-\", \" \")}\n                  </button>\n                ))}\n              </div>\n            </div>\n\n            <div className=\"w-full md:w-[280px] p-5 flex flex-col justify-between bg-black/20 text-xs\">\n              <div className=\"space-y-3\">\n                <span className=\"text-[10px] font-mono text-white/30 uppercase tracking-wider block\">Verify Mode</span>\n                <div className=\"flex gap-2\">\n                  <button onClick={() => { setActiveTab(\"telemetry\"); runSimulation(selectedNode, \"telemetry\"); }} className={`px-2.5 py-1.5 rounded text-xs border ${activeTab === \"telemetry\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Telemetry</button>\n                  <button onClick={() => { setActiveTab(\"safety\"); runSimulation(selectedNode, \"safety\"); }} className={`px-2.5 py-1.5 rounded text-xs border ${activeTab === \"safety\" ? \"border-[#009DFF] bg-[#009DFF]/5 text-white\" : \"border-white/5 text-white/50\"}`}>Safety Check</button>\n                </div>\n              </div>\n              <div className=\"mt-4 pt-3 border-t border-white/5 space-y-2\">\n                <pre className=\"p-2.5 rounded bg-black text-[10px] font-mono text-emerald-400 border border-white/5 h-[90px] overflow-y-auto whitespace-pre-wrap\">{simOutput}</pre>\n              </div>\n            </div>\n          </div>\n        </MotionReveal>\n\n        {/* Modules Carousel */}\n        <Carousel items={MODULES} />\n\n        {/* Specialized Agent Grid */}\n        <div className=\"space-y-6\">\n          <h2 className=\"text-xl font-bold text-white text-center\">Autonomous Extraction Agents</h2>\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto\">\n            {AGENTS.map((agent) => (\n              <div key={agent.title} className=\"p-5 rounded-xl border border-white/5 bg-black/40 hover:border-[#009DFF]/20 transition-all\">\n                <span className=\"text-[9px] font-mono text-[#009DFF] uppercase tracking-wider font-bold\">{agent.tag}</span>\n                <h3 className=\"font-bold text-white text-sm mt-2\">{agent.title}</h3>\n                <p className=\"text-xs text-white/50 leading-relaxed font-light mt-1\">{agent.desc}</p>\n              </div>\n            ))}\n          </div>\n        </div>\n\n        {/* Bento Grid */}\n        <BentoGrid className=\"max-w-5xl mx-auto\">\n          <BentoCard title=\"AES-256 Cryptography\" description=\"Local signature on sensor ingestion files before satellite sync.\" badge=\"Security\" icon={<Shield className=\"w-5 h-5\" />} />\n          <BentoCard title=\"99.1% Compression\" description=\"Differential syncing engine limits metadata overhead on expensive satellite routes.\" badge=\"Bandwidth\" icon={<Zap className=\"w-5 h-5\" />} />\n          <BentoCard title=\"12ms Local Dispatch\" description=\"Immediate automated task escalation when machine tolerance limits breach thresholds.\" badge=\"Latency\" icon={<Activity className=\"w-5 h-5\" />} />\n        </BentoGrid>\n\n        {/* Links & CTA */}\n        <RelatedPagesGrid links={[\n          { title: \"Extraction & Mining Solutions\", tag: \"Industry Core\", desc: \"Discover GFF's multi-agent architectures for mining operations.\", href: \"/industries/mining\" },\n          { title: \"Unified Control Center\", tag: \"Cockpit Console\", desc: \"Monitor edge swarm health, compute spend, and rule audit logs.\", href: \"/platforms/control-center\" }\n        ]} />\n\n        <PremiumCTA\n          title=\"Deploy Ruggedized Agent Intelligence to Your Extraction Sites\"\n          description=\"Schedule a technical engineering assessment with our mining systems leads to secure your low-bandwidth remote-site links.\"\n          primaryLabel=\"Connect with GFF AI\"\n          primaryHref=\"/contact\"\n        />\n      </div>\n    </InnerPageShell>\n  );\n}"}}}
