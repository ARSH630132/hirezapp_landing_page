4 | \n 85 |   if (score >= 80) {\n 86 |     level = \"Sovereign Production Ready\";\n 87 |     color = \"#00FF9D\";\n 88 |     description =\n 89 |       \"Your network edge nodes and unified vector caches are fully optimized for autonomous agent deployment in hardened private subnets.\";\n 90 |   } else if (score >= 55) {\n 91 |     level = \"Strategic Incubation Required\";\n 92 |     color = \"#3B82F6\";\n 93 |     description =\n 94 |       \"Solid infrastructural foundations exist, but real-time audit logs and single-tenant hardware isolation policies require further alignment.\";\n 95 |   }\n 96 | \n 97 |   const dimensionScores = [\n 98 |     {\n 99 |       label: \"Data Pipeline Integration\",\n100 |       score: dataIntegration,\n101 |       description: dataIntegration >= 4 ? \"Excellent vectorized caching\" : \"Legacy relational bottlenecks present\",\n102 |       recommendation:\n103 |         dataIntegration >= 4\n104 |           ? \"Maintain secure local cache structures.\"\n105 |           : \"Introduce GFF OmniMesh connectors to bridge relational mainframes directly.\"\n106 |     },\n107 |     {\n108 |       label: \"VPC Network Isolation\",\n109 |       score: vpcIsolation,\n110 |       description: vpcIsolation >= 4 ? \"Hardened private enclave isolated\" : \"Shared ingress pathways vulnerable\",\n111 |       recommendation:\n112 |         vpcIsolation >= 4\n113 |           ? \"Execute quarterly zero-trust dry runs.\"\n114 |           : \"Enforce single-tenant subnets with GFF dedicated edge nodes.\"\n115 |     },\n116 |     {\n117 |       label: \"Compliance Telemetry\",\n118 |       score: complianceTelemetry,\n119 |       description: complianceTelemetry >= 4 ? \"Continuous real-time SOC2 telemetry\" : \"Periodic audit checks only\",\n120 |       recommendation:\n121 |         complianceTelemetry >= 4\n122 |           ? \"Automate policy reporting outputs.\"\n123 |           : \"Deploy GFF Policy Watchdog nodes to catch configuration drift instantly.\"\n124 |     },\n125 |     {\n126 |       label: \"Multi-Agent Fleet Strategy\",\n127 |       score: fleetStrategy,\n128 |       description: fleetStrategy >= 4 ? \"Orchestrated DAG topology active\" : \"Ad-hoc task execution\",\n129 |       recommendation:\n130 |         fleetStrategy >= 4\n131 |           ? \"Scale to cross-department supervisor nodes.\"\n132 |           : \"Model multi-agent hierarchies using GFF Foundry Studio DAG designers.\"\n133 |     }\n134 |   ];\n135 | \n136 |   return {\n137 |     score,\n138 |     level,\n139 |     color,\n140 |     description,\n141 |     dimensionScores,\n142 |     strategicPriority:\n143 |       score >= 80\n144 |         ? \"Hardened production deployment & scale\"\n145 |         : score >= 55\n146 |         ? \"Isolation architecture validation\"\n147 |         : \"VPC topology design & basic sandboxing\",\n148 |     securityClearance: score >= 80 ? \"Sovereign Level 3\" : score >= 55 ? \"Strategic Level 2\" : \"Sandbox Level 1\"\n149 |   };\n150 | }\n151 | \n152 | export function calculateROIEstimate(inputs: ROIInputs): ROIResult {\n153 |   const { teamSize, avgHourlyRate, inefficientHoursPerWeek, initialInvestment, priority } = inputs;\n154 | \n155 |   const annualHoursSaved = Math.round(teamSize * inefficientHoursPerWeek * 52 * 0.85);\n156 |   const grossSavings = annualHoursSaved * avgHourlyRate;\n157 |   const netSavings = Math.max(0, grossSavings - initialInvestment);\n158 |   const roiPercentage = initialInvestment > 0 ? Math.round((netSavings / initialInvestment) * 100) : 0;\n159 | \n160 |   const monthlySavings = grossSavings / 12;\n161 |   const paybackMonths = monthlySavings > 0 ? Math.max(1, Math.round((initialInvestment / monthlySavings) * 10) / 10) : 12;\n162 | \n163 |   let computeCostPct = 15;\n164 |   let complianceCostPct = 20;\n165 | \n166 |   if (priority === \"compliance_security\") {\n167 |     complianceCostPct = 40;\n168 |     computeCostPct = 10;\n169 |   } else if (priority === \"cost_reduction\") {\n170 |     complianceCostPct = 15;\n171 |     computeCostPct = 25;\n172 |   } else if (priority === \"operational_speed\") {\n173 |     computeCostPct = 30;\n174 |   }\n175 | \n176 |   const laborSavedPct = 100 - (computeCostPct + complianceCostPct);\n177 | \n178 |   const costAllocations = [\n179 |     {\n180 |       label: \"Compute Node Infrastructure\",\n181 |       percentage: computeCostPct,\n182 |       amount: Math.round((initialInvestment * computeCostPct) / 100),\n183 |       color: \"#009DFF\"\n184 |     },\n185 |     {\n186 |       label: \"Sovereign Audit Pipelines\",\n187 |       percentage: complianceCostPct,\n188 |       amount: Math.round((initialInvestment * complianceCostPct) / 100),\n189 |       color: \"#E4000F\"\n190 |     },\n191 |     {\n192 |       label: \"Workforce Amplification Layer\",\n193 |       percentage: laborSavedPct,\n194 |       amount: Math.round((initialInvestment * laborSavedPct) / 100),\n195 |       color: \"#00FF9D\"\n196 |     }\n197 |   ];\n198 | \n199 |   let efficiencyMultiplier = \"1.8x Speedup\";\n200 |   if (teamSize > 500) efficiencyMultiplier = \"3.2x Scale\";\n201 |   else if (teamSize > 100) efficiencyMultiplier = \"2.4x Speedup\";\n202 | \n203 |   return {\n204 |     annualHoursSaved,\n205 |     grossSavings,\n206 |     netSavings,\n207 |     roiPercentage,\n208 |     paybackMonths,\n209 |     costAllocations,\n210 |     efficiencyMultiplier\n211 |   };\n212 | }\n213 | \n214 | \n215 | export function generateProposalBlueprint(inputs: ProposalInputs): ProposalResult {\n216 |   const { companyName, industry, companySize, dataReadiness, priorities } = inputs;\n217 | \n218 |   const resolvedName = companyName.trim() || \"Enterprise Client\";\n219 | \n220 |   let baseWeeks = 12;\n221 |   if (companySize === \"small\") baseWeeks = 6;\n222 |   else if (companySize === \"medium\") baseWeeks = 8;\n223 |   else if (companySize === \"global-conglomerate\") baseWeeks = 16;\n224 | \n225 |   if (dataReadiness === \"raw\") baseWeeks += 3;\n226 |   else if (dataReadiness === \"vectorized\") baseWeeks -= 2;\n227 |   else if (dataReadiness === \"fully-governed\") baseWeeks -= 3;\n228 | \n229 |   const implementationWeeks = Math.max(4, baseWeeks);\n230 | \n231 |   const p1 = Math.max(1, Math.round(implementationWeeks * 0.15));\n232 |   const p2 = Math.max(1, Math.round(implementationWeeks * 0.25));\n233 |   const p3 = Math.max(1, Math.round(implementationWeeks * 0.40));\n234 |   const p4 = implementationWeeks - (p1 + p2 + p3);\n235 | \n236 |   const architecturePhases = [\n237 |     {\n238 |       name: \"Phase 1: Local Enclave Discovery & Topology Layout\",\n239 |       weeks: p1,\n240 |       objectives: [\n241 |         `Audit legacy data endpoints for ${industry} compliance.`,\n242 |         \"Establish single-tenant secure networking perimeter within GFF virtual enclaves.\",\n243 |         \"Assess relational schemas for real-time vector capability.\"\n244 |       ],\n245 |       deliverables: [\"Isolated VPC configuration manifest\", \"Static DAG reference topology layout\"]\n246 |     },\n247 |     {\n248 |       name: \"Phase 2: OmniMesh Integration & Vector Pipeline Setup\",\n249 |       weeks: p2,\n250 |       objectives: [\n251 |         `Connect GFF OmniMesh drivers to source infrastructure.`,\n252 |         \"Initialize zero-retention embeddings stream with local token isolation.\",\n253 |         \"Perform initial policy scan checks on simulated transaction records.\"\n254 |       ],\n255 |       deliverables: [\"Unified Vector mesh connection keys\", \"Encryption policy baseline document\"]\n256 |     },\n257 |     {\n258 |       name: \"Phase 3: Multi-Agent Topology Compilation & Validation\",\n259 |       weeks: p3,\n260 |       objectives: [\n261 |         \"Synthesize custom supervisor nodes mapped to departmental rules.\",\n262 |         \"Execute high-throughput benchmark runs (up to 5,000 simulated tx/min).\",\n263 |         \"Verify consensus validation