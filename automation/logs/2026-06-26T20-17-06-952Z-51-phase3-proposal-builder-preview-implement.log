null);\n 90 | \n 91 |   const activeDimension = DIMENSIONS[activeDimensionIndex];\n 92 | \n 93 |   // Scoring details\n 94 |   const totalQuestions = DIMENSIONS.reduce((acc, dim) => acc + dim.questions.length, 0);\n 95 |   const answeredQuestionsCount = Object.keys(answers).length;\n 96 |   const progressPercent = Math.round((answeredQuestionsCount / totalQuestions) * 100);\n 97 | \n 98 |   const getDimensionAnsweredCount = (dim: Dimension) => {\n 99 |     return dim.questions.filter(q => answers[q.id] !== undefined).length;\n100 |   };\n101 | \n102 |   const isDimensionComplete = (dim: Dimension) => {\n103 |     return getDimensionAnsweredCount(dim) === dim.questions.length;\n104 |   };\n105 | \n106 |   const getLiveLevelEstimate = () => {\n107 |     if (answeredQuestionsCount === 0) return { name: \"Awaiting Input\", color: \"text-white/40\" };\n108 |     \n109 |     const sum = Object.values(answers).reduce((acc, val) => acc + val, 0);\n110 |     const avg = sum / answeredQuestionsCount;\n111 |     \n112 |     if (avg >= 3.4) return { name: \"Sovereign Mesh (Level IV)\", color: \"text-[#00FF9D]\" };\n113 |     if (avg >= 2.5) return { name: \"Federated Mesh (Level III)\", color: \"text-[#3B82F6]\" };\n114 |     if (avg >= 1.7) return { name: \"Siloed Enclave (Level II)\", color: \"text-[#E5A93C]\" };\n115 |     return { name: \"Reactive Sandbox (Level I)\", color: \"text-[#E4000F]\" };\n116 |   };\n117 | \n118 |   useEffect(() => {\n119 |     if (!isCompiling) return;\n120 |     const interval = setInterval(() => {\n121 |       setCompilingStep((prev) => {\n122 |         if (prev < COMPILING_MESSAGES.length - 1) {\n123 |           return prev + 1;\n124 |         } else {\n125 |           clearInterval(interval);\n126 |           setIsCompiling(false);\n127 |           setShowResult(true);\n128 |           return prev;\n129 |         }\n130 |       });\n131 |     }, 350);\n132 |     return () => clearInterval(interval);\n133 |   }, [isCompiling]);\n134 | \n135 |  