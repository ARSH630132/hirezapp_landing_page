{"ts":"2026-06-26T19:57:42.640Z","type":"agent_event","event":{"type":"content_start","contentType":"tool","toolName":"editor","toolCallId":"utmh0u3n","input":{"path":"/Users/ayushbansal/Documents/GitHub/hirezapp_landing_page/app/build/proposal/page.tsx","old_text":"  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const draft = localStorage.getItem(\"gff_proposal_draft\");\n      if (draft) setHasSavedDraft(true);\n    }\n  }, []);\n\n  const handleReset = () => {\n    setInputs(INITIAL_INPUTS);\n    setStep(\"configure\");\n    setActiveStepGate(1);\n    setIsSigned(false);\n    setSignName(\"\");\n  };","new_text":"  useEffect(() => {\n    if (typeof window !== \"undefined\") {\n      const draft = localStorage.getItem(\"gff_proposal_draft\");\n      if (draft) setHasSavedDraft(true);\n    }\n  }, []);\n\n  const compilingMessages = [\n    \"Establishing secure local compiler enclave...\",\n    \"Analyzing industry taxonomy and telemetry guidelines...\",\n    \"Querying OmniMesh reference connector catalog...\",\n    \"Structuring custom 90-Day sovereign deployment timeline...\",\n    \"Calculating GFF Squad allocation algorithms...\",\n    \"Enforcing strict zero-retention compliance policies...\",\n    \"Synthesizing Strategic SOW Dossier...\"\n  ];\n\n  const handleCompile = () => {\n    if (!inputs.companyName.trim()) {\n      alert(\"Please provide your Organization Name to generate a custom proposal.\");\n      return;\n    }\n    setStep(\"compiling\");\n    setCompilingStepIndex(0);\n  };\n\n  useEffect(() => {\n    if (step !== \"compiling\") return;\n    const interval = setInterval(() => {\n      setCompilingStepIndex((prev) => {\n        if (prev < compilingMessages.length - 1) {\n          return prev + 1;\n        } else {\n          clearInterval(interval);\n          setStep(\"preview\");\n          return prev;\n        }\n      });\n    }, 450);\n    return () => clearInterval(interval);\n  }, [step]);\n\n  const handleSaveDraft = () => {\n    if (typeof window !== \"undefined\") {\n      localStorage.setItem(\"gff_proposal_draft\", JSON.stringify(inputs));\n      setSaved(true);\n      setHasSavedDraft(true);\n      setTimeout(() => setSaved(false), 2000);\n    }\n  };\n\n  const handleRestoreDraft = () => {\n    if (typeof window !== \"undefined\") {\n      const draft = localStorage.getItem(\"gff_proposal_draft\");\n      if (draft) {\n        setInputs(JSON.parse(draft));\n        setHasSavedDraft(false);\n      }\n    }\n  };\n\n  const handleReset = () => {\n    setInputs(INITIAL_INPUTS);\n    setStep(\"configure\");\n    setActiveStepGate(1);\n    setIsSigned(false);\n    setSignName(\"\");\n    if (typeof window !== \"undefined\") {\n      localStorage.removeItem(\"gff_proposal_draft\");\n      setHasSavedDraft(false);\n    }\n  };\n\n  const handlePrint = () => {\n    if (typeof window !== \"undefined\") window.print();\n  };\n\n  const getSelectedPrioritiesLabels = () => {\n    return inputs.priorities\n      .map((p) => PRIORITIES.find((item) => item.id === p)?.label || p)\n      .join(\", \");\n  };\n\n  const generateProposalData = () => {\n    const org = inputs.companyName.trim() || \"Enterprise Client\";\n    const indObj = INDUSTRIES.find((i) => i.id === inputs.industry) || INDUSTRIES[0];\n    const sizeObj = COMPANY_SIZES.find((s) => s.id === inputs.companySize) || COMPANY_SIZES[2];\n    const readObj = DATA_READINESS.find((d) => d.id === inputs.dataReadiness) || DATA_READINESS[2];\n\n    let baseWeeks = 12;\n    if (sizeObj.id === \"small\") baseWeeks = 6;\n    else if (sizeObj.id === \"medium\") baseWeeks = 8;\n    else if (sizeObj.id === \"global-conglomerate\") baseWeeks = 16;\n\n    if (readObj.id === \"raw\") baseWeeks += 3;\n    else if (readObj.id === \"vectorized\") baseWeeks -= 2;\n    else if (readObj.id === \"fully-governed\") baseWeeks -= 3;\n\n    const totalWeeks = Math.max(4, baseWeeks);\n    const p1 = Math.max(1, Math.round(totalWeeks * 0.15));\n    const p2 = Math.max(1, Math.round(totalWeeks * 0.25));\n    const p3 = Math.max(1, Math.round(totalWeeks * 0.40));\n    const p4 = totalWeeks - (p1 + p2 + p3);\n\n    let licenseCost = \"$45,000 / Year\";\n    if (sizeObj.id === \"global-conglomerate\") licenseCost = \"$120,000 / Year (Sovereign Core)\";\n    else if (sizeObj.id === \"small\") licenseCost = \"$15,000 / Year (Sandbox Dev)\";\n    else if (sizeObj.id === \"medium\") licenseCost = \"$30,000 / Year (Foundry Standard)\";\n\n    const squadSize = sizeObj.id === \"small\" ? 2 : sizeObj.id === \"medium\" ? 3 : sizeObj.id === \"enterprise\" ? 4 : 5;\n\n    return { org, industry: indObj.label, industryId: indObj.id, industryDesc: indObj.desc, companyScale: sizeObj.label, dataReadiness: readObj.label, dataReadinessId: readObj.id, totalWeeks, p1, p2, p3, p4, licenseCost, squadSize };\n  };\n\n  const pData = generateProposalData();\n\n  const rawOutlineText = `\nGFF AI SOVEREIGN ENGAGEMENT PROPOSAL OUTLINE\nOrganization: \\${pData.org}\nIndustry: \\${pData.industry}\nScale: \\${pData.companyScale}\nData Ingestion Status: \\${pData.dataReadiness}\nImplementation Horizon: \\${pData.totalWeeks} Weeks\nLicense Plan: \\${pData.licenseCost}\n\nI. EXECUTIVE SUMMARY: Establish single-tenant VPC enclaves inside local bounds with GFF Sovereign nodes.\nII. CHALLENGE STATEMENT: Solve high-latency manual workflow bottlenecks and cloud-sharing IP liabilities.\nIII. RECOMMENDED GFF PATH: Deploy custom GFF multi-agent topologies (Policy Watchdog, AS-09 Auditor, OmniMesh Connectors).\nIV. PROPOSED WORKSTREAMS:\n  - Workstream A: Secure VPC Inception (Weeks 1 to \\${pData.p1})\n  - Workstream B: In-Memory OmniMesh Data Connectors (Weeks \\${pData.p1 + 1} to \\dots)\n  - Workstream C: Custom DAG Topology Configuration (Weeks \\${pData.p1 + pData.p2 + 1} to \\dots)\n  - Workstream D: Client Handoff and Telemetry Auditing (Weeks \\${pData.p1 + pData.p2 + pData.p3 + 1} to \\${pData.totalWeeks})\nV. 90-DAY ROADMAP: Day 1-30 Sandboxing, Day 31-60 Data Pipeline setup, Day 61-90 Core production promotion.\nVI. SUGGESTED SQUAD: Strike Team containing \\${pData.squadSize} engineers.\nVII. GOVERNANCE APPROACH: In-Memory zero-retention schemas, secure supervisor telemetry, and manual overrides.\nVIII. SUCCESS MEASURES: >99.9% Task Success, <150ms execution latency, zero client-data leakage.\nIX. ASSUMPTIONS: Infrastructure setup permissions, read-only local API access pathways, internal coordinator alignment.\nX. RISKS: Ingestion performance friction, agent coordination drift.\nXI. NEXT STEPS: Schedule principal technical review, boot sandbox lab enclaves, mutual authorization of SOW tokens.\n  `.trim();\n\n  const handleCopyOutline = () => {\n    navigator.clipboard.writeText(rawOutlineText);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  const handleScrollToSection = (id: string) => {\n    setActivePreviewSection(id);\n    const element = document.getElementById(id);\n    if (element) {\n      element.scrollIntoView({ behavior: \"smooth\", block: \"start\" });\n    }\n  };\n"}}}
