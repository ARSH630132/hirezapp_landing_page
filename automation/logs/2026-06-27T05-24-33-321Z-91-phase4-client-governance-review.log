|     if (selSeverity && d.clearanceLevel !== selSeverity) return false;\n278 |     if (search && !d.name.toLowerCase().includes(search.toLowerCase())) return false;\n279 |     return true;\n280 |   });\n281 | \n282 |   // Extract select options dynamically\n283 |   const projectOptions = Array.from(new Set([\n284 |     ...policies.map(p => JSON.stringify({ id: p.projectId, name: p.projectName })),\n285 |     ...oversights.map(a => JSON.stringify({ id: a.projectId, name: a.project })),\n286 |     ...documents.map(d => JSON.stringify({ id: d.projectId, name: d.projectName }))\n287 |   ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n288 | \n289 |   const agentOptions = Array.from(new Set([\n290 |     ...policies.map(p => JSON.stringify({ id: p.agentId, name: p.agentName })),\n291 |     ...oversights.map(a => JSON.stringify({ id: a.agentId, name: a.agent })),\n292 |     ...documents.map(d => JSON.stringify({ id: d.agentId, name: d.agentName }))\n293 |   ])).map(str => JSON.parse(str)) as { id: string; name: string }[];\n294 | \n295 |   // Calculate dynamic trust index in real time\n296 |   const criticalCount = policies.filter(p => p.status === \"critical\").length;\n297 |   const warningCount = policies.filter(p => p.status === \"warning\").length;\n298 |   const pendingCount = oversights.filter(o => o.status === \"pending\").length;\n299 |   const approvedCount = oversights.filter(o => o.status === \"approved\").length;\n300 |   const trustScore = Math.min(100, Math.max(0, 99 - (criticalCount * 7.5) - (warningCount * 3) - (pendingCount * 1.5) + (approvedCount * 0.8))).toFixed(1);\n301 | \n302 |   const resetAll = () => {\n303 |     setSelProj(\"\"); setSelAgent(\"\"); setSelStatus(\"\"); setSelSeverity(\"\"); setSearch(\"\");\n304 |     triggerToast(\"Filters cleared\", \"info\");\n305 |   };\n306 | \n307 |   // Enclave Handshake Simulations\n308 |   const handleVerify = (id: string) => {\n309 |     if (verId) return;\n310 |     setVerId(id);\n311 |     triggerToast(`Cryptographic handshake check running for ${id}...`, \"info\");\n312 |     setTimeout(() => {\n313 |       setPolicies(prev => prev.map(p => p.id === id ? { ...p, status: \"compliant\", logs: [`[${new Date().toLocaleTimeString()}] RE-VERIFIED: Validated via hardware proof.`, ...p.logs] } : p));\n314 |       setVerId(null);\n315 |       triggerToast(`Boundary verified: ${id} is locked and fully compliant.`, \"success\");\n316 |     }, 1200);\n317 |   };\n318 | \n319 |   const handleResolveOversight = (id: string, state: \"approved\" | \"rejected\") => {\n320 |     setOversights(prev => prev.map(o => o.id === id ? { ...o, status: state } : o));\n321 |     if (state === \"approved\") triggerToast(`Signature committed. Interlock ${id} approved.`, \"success\");\n322 |     else triggerToast(`Interlock request ${id} rejected by client keys.`, \"warning\");\n323 |   };\n324 | \n325 |   const handleDocExport = (id: string) => {\n326 |     if (expIdDoc) return;\n327 |     setExpIdDoc(id);\n328 |     triggerToast(`Compiling signed attestation file for ${id}...`, \"info\");\n329 |     setTimeout(() => {\n330 |       setExpIdDoc(null);\n331 |       triggerToast(`Certified file package compiled and downloaded successfully.`, \"success\");\n332 |     }, 1500);\n333 |   };\n334 | \n335 |   const steps = [\n336 |     { id: \"step-1\", title: \"1. Prompt Ingress Node\", val: \"0.4ms latency\", desc: \"Inference transaction streams are parsed inside localized secure process loops.\" },\n337 |     { id: \"step-2\", title: \"2. Guardrail Interceptor\", val: \"99.8% pass rate\", desc: \"Validates payload streams against active compliance rulesets and redacts PII.\" },\n338 |     { id: \"step-3\", title: \"3. Isolated Secure Enclave\", val: \"AMD SEV Locked\", desc: \"Executes model operations inside physically decoupled memory enclaves.\" },\n339 |     { id: \"step-4\", title: \"4. Human Oversight Interlock\", val: `${pendingCount} Pending Sign`, desc: \"Sensitive boundary actions pause at hardware layer awaiting administrator credentials.\" },\n340 |     { id: \"step-5\", title: \"5. Sealed State Ledger\", val: \"SHA-256 Verified\", desc: \"Logs physical transactions into an immutable, client-managed auditing ledger.\" }\n341 |   ];\n342 | \n343 |   return (\n344 |     <div className=\"space-y-6 max-w-[1700px] mx-auto pb-16 animate-slide-up select-none\">\n345 |       \n346 |       {/* Disclaimer Notice */}\n347 |       <div className=\"border border-[#009DFF]/20 bg-[#009DFF]/5 rounded-xl p-4 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 font-mono text-[11px] leading-relaxed\">\n348 |         <div className=\"flex items-start gap-2.5 text-white/80\">\n349 |           <ShieldAlert className=\"w-5 h-5 text-[#009DFF] shrink-0 mt-0.5\" />\n350 |           <span>\n351 |             <strong className=\"text-white\">WORKFLOW COMPANION SYSTEM:</strong> This interface is <strong className=\"text-[#009DFF]\">designed to support governance workflows</strong>. All assertions, guardrails, and compliance logs are simulated sandbox boundaries built to assist your auditing processes, and do not constitute formal legal or regulatory guarantees.\n352 |           </span>\n353 |         </div>\n354 |         <span className=\"text-[9px] text-[#009DFF]/90 font-bold bg-[#009DFF]/15 border border-[#009DFF]/30 px-2 py-0.5 rounded uppercase tracking-wider shrink-0 font-mono\">\n355 |           SUPPORT ACTIVE\n356 |         </span>\n357 |       </div>\n358 | \n359 |       {/* Page Header */}\n360 |       <div className=\"flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 border-b border-white/5 pb-5 select-none font-mono\">\n361 |         <div>\n362 |           <div className=\"flex items-center gap-2\">\n363 |             <h1 className=\"text-xl md:text-2xl font-bold tracking-tight text-white uppercase\">Sovereign Governance</h1>\n364 |             <span className=\"inline-flex rounded bg-[#00FFC2]/10 border border-[#00FFC2]/20 px-1.5 py-0.5 text-[9px] font-bold uppercase text-[#00FFC2]\">\n365 |               LOCKED STATE\n366 |             </span>\n367 |           </div>\n368 |           <p className=\"text-[12px] text-white/50 mt-1\">\n369 |             Real-time telemetry, automated guardrail verification blocks, human interlock points, and certified document audit records.\n370 |           </p>\n371 |         </div>\n372 |         <div className=\"text-[10px] text-white/45 bg-white/[0.01] border border-white/5 px-2.5 py-1.5 rounded-lg\">\n373 |           Enclave Epoch: <span className=\"text-white font-bold font-mono\">2026.E3</span>\n374 |         </div>\n375 |       </div>\n376 | \n377 |       {/* Bento Grid: Metrics and Interceptor Diagram */}\n378 |       <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n379 |         \n380 |         {/* Metric Cards */}\n381 |         <div className=\"flex flex-col gap-4\">\n382 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px] border-[#00FFC2]/10\">\n383 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n384 |               <span className=\"text-white/45 uppercase tracking-wider\">Dynamic Trust Index</span>\n385 |               <StatusBadge state=\"active\" label=\"continuous check\" />\n386 |             </div>\n387 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n388 |               <div className=\"text-3xl font-bold text-white font-mono\">{trustScore}%</div>\n389 |               <span className=\"text-[9.5px] text-emerald-400 flex items-center gap-1\">\n390 |                 Optimized <span className=\"w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse\" />\n391 |               </span>\n392 |             </div>\n393 |           </WorkspaceCard>\n394 | \n395 |           <WorkspaceCard className=\"flex flex-col justify-between h-[105px]\">\n396 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n397 |               <span className=\"text-white/45 uppercase tracking-wider\">AI Guardrails & Policies</span>\n398 |               <span className=\"text-[#009DFF] bg-[#009DFF]/10 px-1.5 py-0.5 rounded border border-[#009DFF]/20\">ACTIVE</span>\n399 |             </div>\n400 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n401 |               <div className=\"text-3xl font-bold text-white\">{policies.length}</div>\n402 |               <span className=\"text-[9.5px] text-white/40\">\n403 |                 {policies.filter(p => p.status === \"compliant\").length} Safe • {policies.filter(p => p.status !== \"compliant\").length} Alerts\n404 |               </span>\n405 |             </div>\n406 |           </WorkspaceCard>\n407 | \n408 |           <WorkspaceCard className={`flex flex-col justify-between h-[105px] transition-all ${pendingCount > 0 ? \"border-amber-500/20 bg-amber-500/[0.01]\" : \"\"}`}>\n409 |             <div className=\"flex justify-between items-start font-mono text-[10px]\">\n410 |               <span className=\"text-white/45 uppercase tracking-wider\">Pending Interlocks</span>\n411 |               {pendingCount > 0 ? (\n412 |                 <span className=\"text-amber-400 bg-amber-400/10 px-1.5 py-0.5 rounded border border-amber-400/20 animate-pulse\">SIGN REQUIRED</span>\n413 |               ) : (\n414 |                 <span className=\"text-white/30\">ALL SIGNED</span>\n415 |               )}\n416 |             </div>\n417 |             <div className=\"flex items-end justify-between mt-1 font-mono\">\n418 |               <div className=\"text-3xl font-bold text-white\">{pendingCount}</div>\n419 |               <span className=\"text-[9.5px] text-white/40\">Awaiting client credentials</span>\n420 |             </div>\n421 |           </WorkspaceCard>\n422 |         </div>\n423 | \n424 |         {/* Dynamic Topology Flow Diagram */}\n425 |         <div className=\"lg:col-span-2\">\n426 |           <div className=\"p-5 rounded-2xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col md:flex-row gap-5 items-stretch h-full\">\n427 |             <style dangerouslySetInnerHTML={{ __html: `\n428 |               @keyframes flow { to { stroke-dashoffset: -20; } }\n429 |               .animate-flow-line { stroke-dasharray: 6, 4; animation: flow 1.1s linear infinite; }\n430 |             `}} />\n431 | \n432 |             <div className=\"flex-grow flex flex-col justify-between gap-4\">\n433 |               <div className=\"flex items-center justify-between border-b border-white/5 pb-2\">\n434 |                 <div className=\"flex items-center gap-1.5 font-mono text-[11px]\">\n435 |                   <Layers className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n436 |                   <span className=\"font-bold text-white uppercase tracking-wider\">Enclave Interceptor Pipeline</span>\n437 |                 </div>\n438 |                 <span className=\"text-[9px] font-mono text-white/30 uppercase\">Topology</span>\n439 |               </div>\n440 | \n441 |               <div className=\"grid grid-cols-5 gap-2 relative py-4 select-none\">\n442 |                 <div className=\"absolute top-[34px] left-[10%] right-[10%] h-[2px] z-0 hidden sm:block\">\n443 |                   <svg className=\"w-full h-[2px] overflow-visible\">\n444 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"rgba(255,255,255,0.06)\" strokeWidth=\"2\" />\n445 |                     <line x1=\"0\" y1=\"1\" x2=\"100%\" y2=\"1\" stroke=\"#00FFC2\" strokeWidth=\"1.5\" className=\"animate-flow-line opacity-25\" />\n446 |                   </svg>\n447 |                 </div>\n448 | \n449 |                 {steps.map((st, idx) => {\n450 |                   const isActive = step === st.id;\n451 |                   const clr = \n452 |                     st.id === \"step-1\" ? \"border-sky-500/10 text-sky-400\" :\n453 |                     st.id === \"step-2\" ? \"border-cyan-500/10 text-cyan-400\" :\n454 |                     st.id === \"step-3\" ? \"border-violet-500/10 text-violet-400\" :\n455 |                     st.id === \"step-4\" ? \"border-amber-500/10 text-amber-400\" : \"border-emerald-500/10 text-emerald-400\";\n456 |                   \n457 |                   const activeStyle = isActive \n458 |                     ? \"shadow-[0_0_12px_rgba(255,255,255,0.02)] border-white/20 bg-white/[0.02] scale-102\" \n459 |                     : \"bg-black/45 hover:border-white/10\";\n460 | \n461 |                   return (\n462 |                     <button \n463 |                       key={st.id} \n464 |                       onClick={() => setStep(st.id)}\n465 |                       className={`z-10 flex flex-col items-center gap-1.5 p-1.5 rounded-xl border transition-all cursor-pointer ${clr} ${activeStyle}`}\n466 |                     >\n467 |                       <div className={`w-8.5 h-8.5 rounded-full flex items-center justify-center border transition-all ${isActive ? \"border-current bg-white/[0.01]\" : \"border-white/5\"}`}>\n468 |                         {st.id === \"step-1\" && <Cpu className=\"w-3.5 h-3.5\" />}\n469 |                         {st.id === \"step-2\" && <ShieldCheck className=\"w-3.5 h-3.5\" />}\n470 |                         {st.id === \"step-3\" && <Lock className=\"w-3.5 h-3.5\" />}\n471 |                         {st.id === \"step-4\" && <UserCheck className=\"w-3.5 h-3.5\" />}\n472 |                         {st.id === \"step-5\" && <FileText className=\"w-3.5 h-3.5\" />}\n473 |                       </div>\n474 |                       <div className=\"text-center font-mono select-none\">\n475 |                         <span className=\"block text-[7.5px] uppercase text-white/30\">Node 0{idx+1}</span>\n476 |                         <span className=\"hidden sm:inline-block font-bold text-[8.5px] mt-0.5 truncate max-w-[60px] text-white/80\">{st.id === \"step-1\" ? \"Ingress\" : st.id === \"step-2\" ? \"Guardrail\" : st.id === \"step-3\" ? \"Enclave\" : st.id === \"step-4\" ? \"Oversight\" : \"Ledger\"}</span>\n477 |                       </div>\n478 |                     </button>\n479 |                   );\n480 |                 })}\n481 |               </div>\n482 |             </div>\n483 | \n484 |             {/* Node Telemetry Details card */}\n485 |             <div className=\"w-full md:w-[240px] shrink-0 p-3.5 rounded-xl border border-white/5 bg-[#020202]/80 flex flex-col justify-between font-mono text-xs select-text\">\n486 |               {(() => {\n487 |                 const info = steps.find(s => s.id === step) || steps[0];\n488 |                 return (\n489 |                   <div className=\"space-y-3 h-full flex flex-col justify-between\">\n490 |                     <div className=\"space-y-1.5\">\n491 |                       <span className=\"text-[8px] text-[#009DFF] font-bold tracking-wider uppercase\">REALTIME METRICS</span>\n492 |                       <p className=\"text-white font-bold text-[11px] leading-tight\">{info.title}</p>\n493 |                       \n494 |                       <div className=\"flex items-center gap-1.5 py-0.5 px-2 rounded bg-white/[0.02] border border-white/5 text-[9px]\">\n495 |                         <span className={`w-1 h-1 rounded-full ${step === \"step-4\" && pendingCount > 0 ? \"bg-amber-400\" : \"bg-green-400\"}`} />\n496 |                         <span className=\"text-white/40\">Status:</span>\n497 |                         <span className={`font-bold ${step === \"step-4\" && pendingCount > 0 ? \"text-amber-400\" : \"text-green-400\"}`}>{info.val}</span>\n498 |                       </div>\n499 |                       <p className=\"text-[10px] text-white/50 leading-normal pt-1\">{info.desc}</p>\n500 |                     </div>\n501 |                     \n502 |                     <div className=\"text-[8px] text-white/30 border-t border-white/5 pt-1.5 flex items-center gap-1 