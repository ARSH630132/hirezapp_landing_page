).length;\n 91 |   const progressPercent = Math.round((answeredQuestionsCount / totalQuestions) * 100);\n 92 | \n 93 |   const getDimensionAnsweredCount = (dim: Dimension) => {\n 94 |     return dim.questions.filter(q => answers[q.id] !== undefined).length;\n 95 |   };\n 96 | \n 97 |   const isDimensionComplete = (dim: Dimension) => {\n 98 |     return getDimensionAnsweredCount(dim) === dim.questions.length;\n 99 |   };\n100 | \n101 |   const getLiveLevelEstimate = () => {\n102 |     if (answeredQuestionsCount === 0) return { name: \"Awaiting Input\", color: \"text-white/40\" };\n103 |     \n104 |     const sum = Object.values(answers).reduce((acc, val) => acc + val, 0);\n105 |     const avg = sum / answeredQuestionsCount;\n106 |     \n107 |     if (avg >= 3.4) return { name: \"Sovereign Mesh (Level IV)\", color: \"text-[#00FF9D]\" };\n108 |     if (avg >= 2.5) return { name: \"Federated Mesh (Level III)\", color: \"text-[#3B82F6]\" };\n109 |     if (avg >= 1.7) return { name: \"Siloed Enclave (Level II)\", color: \"text-[#E5A93C]\" };\n110 |     return { name: \"Reactive Sandbox (Level I)\", color: \"text-[#E4000F]\" };\n111 |   };\n112 | \n113 |   useEffect(() => {\n114 |     if (!isCompiling) return;\n115 |     const interval = setInterval(() => {\n116 |       setCompilingStep((prev) => {\n117 |         if (prev < COMPILING_MESSAGES.length - 1) {\n118 |           return prev + 1;\n119 |         } else {\n120 |           clearInterval(interval);\n121 |           setIsCompiling(false);\n122 |           setShowResult(true);\n123 |           return prev;\n124 |         }\n125 |       });\n126 |     }, 350);\n127 |     return () => clearInterval(interval);\n128 |   }, [isCompiling]);\n129 | \n130 |   const handleSelectOption = (questionId: string, score: number) => {\n131 |     setValidationError(null);\n132 |     setAnswers(prev => ({ ...prev, [questionId]: score }));\n133 |   };\n134 | \n135 |   const handleCompileTrigger = () => {\n136 |     setValidationError(null);\n137 |     const incompleteDims: string[] = [];\n138 |     \n139 |     DIMENSIONS.forEach(dim => {\n140 |       if (!isDimensionComplete(dim)) {\n141 |         incompleteDims.push(dim.shortName);\n142 |       }\n143 |     });\n144 | \n145 |     if (incompleteDims.length > 0) {\n146 |       setValidationError(\n147 |         `VALIDATION ALERT: Please resolve all diagnostic segments before compiling. Incomplete categories: ${incompleteDims.join(\", \")}.`\n148 |       );\n149 |       return;\n150 |     }\n151 | \n152 |     setIsCompiling(true);\n153 |     setCompilingStep(0);\n154 |   };\n155 | \n156 |   const handleReset = () => {\n157 |     setAnswers({});\n158 |     setActiveDimensionIndex(0);\n159 |     setValidationError(null);\n160 |     setIsCompiling(false);\n161 |     setShowResult(false);\n162 |     setCompilingStep(0);\n163 |   };\n164 | \n165 |   // Generate dynamic results\n166 |   const calculateResults = () => {\n167 |     const totalScore = Object.values(answers).reduce((acc, val) => acc + val, 0);\n168 |     const percentage = Math.round(((totalScore - 24) / (96 - 24)) * 100);\n169 | \n170 |     let tierName = \"\";\n171 |     let tierColor = \"\";\n172 |     let borderAccent = \"\";\n173 |     let commentary = \"\";\n174 | \n175 |     if (percentage >= 85) {\n176 |       tierName = \"Maturity Level IV: Sovereign Agentic Grid\";\n177 |       tierColor = \"text-[#00FF9D]\";\n178 |       borderAccent = \"border-[#00FF9D]/30 shadow-[0_0_20px_rgba(0,255,157,0.03)]\";\n179 |       commentary = \"Your organization exhibits world-class capabilities tailored to host autonomous multi-agent systems inside isolated network subnets. Your data pipelines feature semantic linking and real-time context ingestion. We recommend establishing custom local vector nodes and deploying sovereign supervisor enclaves to transition your pilot workflows into immediate production lines with zero data retention risks.\";\n180 |     } else if (percentage >= 60) {\n181 |       tierName = \"Maturity Level III: Strategic Federated Mesh\";\n182 |       tierColor = \"text-[#3B82F6]\";\n183 |       borderAccent = \"border-[#3B82F6]/30 shadow-[0_0_20px_rgba(59,130,246,0.03)]\";\n184 |       commentary = \"You have established strong structural foundations. Your private cloud setups and operational documentation are highly mature, but data pipelines lack clean semantic structure and legacy writebacks remain constrained by human latency. Implementing localized vector cache enclaves and a federated AI Center of Excellence can resolve these bottlenecks and compress deployment timelines down to 30 days.\";\n185 |     } else if (percentage >= 35) {\n186 |       tierName = \"Maturity Level II: Experimental Siloed Enclave\";\n187 |       tierColor = \"text-[#E5A93C]\";\n188 |       borderAccent = \"border-[#E5A93C]/30 shadow-[0_0_20px_rgba(229,169,60,0.03)]\";\n189 |       commentary = \"Your AI efforts are fragmented, relying on cloud endpoints with manual review workflows and isolated scripts. While individual talent exists, the lack of centralized governance and structured vector data pipelines limits your ability to scale. Establishing a standardized sandbox environment is an essential next gate to coordinate telemetry protocols and secure a dedicated capital runway.\";\n190 |     } else {\n191 |       tierName = \"Maturity Level I: Reactive Discovery Sandbox\";\n192 |       tierColor = \"text-[#E4000F]\";\n193 |       borderAccent = \"border-[#E4000F]/30 shadow-[0_0_20px_rgba(228,0,15,0.03)]\";\n194 |       commentary = \"Your systems are locked in legacy databases with siloed, undocumented processes and minimal in-house AI engineering capabilities. Running unstructured commercial chatbots introduces high data-leakage and regulatory risks. We strongly suggest launching a controlled GFF Labs sandbox trial to securely model your security schemas before attempting any cloud or on-premises deployments.\";\n195 |     }\n196 | \n197 |     const dimensionBreakdowns = DIMENSIONS.map(dim => {\n198 |       const qIds = dim.questions.map(q => q.id);\n199 |       const scores = qIds.map(id => answers[id] || 1);\n200 |       const avg = Number((scores.reduce((a, b) => a + b, 0) / qIds.length).toFixed(1));\n201 | \n202 |       let status = \"GAP IDENTIFIED\";\n203 |       let statusStyle = \"text-[#E5A93C] bg-[#E5A93C]/5 border-[#E5A93C]/15\";\n204 |       let rec = \"\";\n205 | \n206 |       if (avg >= 3.5) {\n207 |         status = \"OPTIMIZED\";\n208 |         statusStyle = \"text-[#00FF9D] bg-[#00FF9D]/5 border-[#00FF9D]/15\";\n209 |       } else if (avg >= 2.5) {\n210 |         status = \"STABLE\";\n211 |         statusStyle = \"text-[#3B82F6] bg-[#3B82F6]/5 border-[#3B82F6]/15\";\n212 |       }\n213 | \n214 |       if (dim.id === \"strategy\") {\n215 |         rec = avg >= 2.5 \n216 |           ? \"Establish continuous strategy discovery boards mapping specific business bottlenecks to complex Multi-Agent DAG blueprints.\"\n217 |           : \"Secure executive board-level sponsorship to align corporate multi-year capital directly with structured pilot outcomes.\";\n218 |       } else if (dim.id === \"data\") {\n219 |         rec = avg >= 2.5\n220 |           ? \"Integrate GFF Context Knowledge Graphs to feed your active local agent enclaves with synchronized contextual context mapping.\"\n221 |           : \"Construct automated data ingestion pipelines using semantic chunkers to process legacy PDFs, SOPs, and manual logs securely.\";\n222 |       } else if (dim.id === \"process\") {\n223 |         rec = avg >= 2.5\n224 |           ? \"Deploy passive supervisor nodes to constantly measure multi-agent DAG latency bottlenecks and optimize step executions.\"\n225 |           : \"Digitize core manual workflows and document decision state boundaries before modeling autonomous handoffs.\";\n226 |       } else if (dim.id === \"talent\") {\n227 |         rec = avg >= 2.5\n228 |           ? \"Adopt Platform-as-a-Product structures to let internal engineering teams spin up isolated, pre-governed agents independently.\"\n229 |           : \"Roll out GFF AI Academy modules across target divisions to improve prompt literacy and reduce digital-transition friction.\";\n230 |       } else if (dim.id === \"governance\") {\n231 |         rec = avg >= 2.5\n232 |           ? \"Implement zero-retention boundary policies and cryptographically sign execution steps for high-integrity regulatory audits.\"\n233 |           : \"Install automated input/output security middleware to detect and redact sensitive customer identifiers (PII) at the edge.\";\n234 |       } else if (dim.id === \"techstack\") {\n235 |         rec = avg >= 2.5\n236 |           ? \"Introduce GFF Orchestration Gateways to dynamically route model calls based on cost, latency thresholds, and residency rules.\"\n237 |           : \"Transition operational workloads from public cloud API keys to private cloud enclaves or local containerized serving structures.\";\n238 |       } else if (dim.id === \"leadership\") {\n239 |         rec = avg >= 2.5\n240 |           ? \"Co-develop custom proprietary model adapters and pioneer topologies in collaborative syncs with GFF Labs.\"\n241 |           : \"Secure protected, multi-year CAPEX reserves to insulate early-stage pilot models from short-term financial fluctuations.\";\n242 |       } else {\n243 |         rec = avg >= 2.5\n244 |           ? \"Design full-duplex human-agent queues allowing operators and active supervisor bots to collaboratively resolve complex tasks.\"\n245 |           : \"Adopt a federated Center of Excellence (CoE) to streamline compliance clearances and standardize deployable templates.\";\n246 |       }\n247 | \n248 |       return { ...dim, avg, status, statusStyle, rec };\n249 |     });\n250 | \n251 |     return { percentage, tierName, tierColor, borderAccent, commentary, dimensionBreakdowns };\n252 |   };\n253 | \n254 |   const report = showResult ? calculateResults() : null;\n255 | \n256 |   return (\n257 |     <ToolPageShell showContact={!showResult}>\n258 |       <AnimatePresence mode=\"wait\">\n259 |         {/* COMPILED LOADING SCREEN */}\n260 |         {isCompiling && (\n261 |           <motion.div\n262 |             key=\"compiling\"\n263 |             initial={{ opacity: 0 }}\n264 |             animate={{ opacity: 1 }}\n265 |             exit={{ opacity: 0 }}\n266 |             className=\"min-h-[550px] flex flex-col items-center justify-center py-16 text-center space-y-8\"\n267 |           >\n268 |             <div className=\"relative w-24 h-24 flex items-center justify-center\">\n269 |               <div className=\"absolute inset-0 rounded-full border-2 border-[#009DFF]/20 animate-ping\" />\n270 |               <div className=\"absolute inset-2 rounded-full border border-[#00FF9D]/30 animate-pulse\" />\n271 |               <div className=\"w-12 h-12 rounded-full bg-[#030306] border border-white/10 flex items-center justify-center shadow-lg\">\n272 |                 <svg className=\"w-6 h-6 text-[#009DFF] animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n273 |                   <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n274 |                   <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\" />\n275 |                 </svg>\n276 |               </div>\n277 |             </div>\n278 |             <div className=\"space-y-2 max-w-lg\">\n279 |               <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">TELEMETRY SECURE SCAN</span>\n280 |               <p className=\"text-white text-base font-semibold h-12 flex items-center justify-center leading-relaxed\">\n281 |                 {COMPILING_MESSAGES[compilingStep]}\n282 |               </p>\n283 |             </div>\n284 |             <div className=\"w-64 h-1 bg-white/5 rounded-full overflow-hidden relative\">\n285 |               <div \n286 |                 className=\"h-full bg-gradient-to-r from-[#009DFF] to-[#00FF9D] transition-all duration-300\"\n287 |                 style={{ width: `${((compilingStep + 1) / COMPILING_MESSAGES.length) * 100}%` }}\n288 |               />\n289 |             </div>\n290 |           </motion.div>\n291 |         )}\n292 | \n293 |         {/* ACTIVE DIAGNOSTIC RUNNER */}\n294 |         {!isCompiling && !showResult && (\n295 |           <motion.div\n296 |             key=\"diagnostics\"\n297 |             initial={{ opacity: 0, y: 15 }}\n298 |             animate={{ opacity: 1, y: 0 }}\n299 |             exit={{ opacity: 0, y: -15 }}\n300 |             className=\"space-y-8\"\n301 |           >\n302 |             {/* Header section */}\n303 |             <div className=\"border-b border-white/5 pb-6 flex flex-col md:flex-row md:items-end justify-between gap-6\">\n304 |               <div className=\"space-y-2 max-w-3xl\">\n305 |                 <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block\">\n306 |                   BUILD-WITH-GFF // INTERACTIVE DIAGNOSTIC\n307 |                 </span>\n308 |                 <h1 className=\"text-3xl lg:text-5xl font-extrabold text-white tracking-tight leading-none\">\n309 |                   Sovereign AI <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-[#009DFF] via-white to-[#00FF9D]\">Readiness Assessor</span>\n310 |                 </h1>\n311 |                 <p className=\"text-white/50 text-xs font-light leading-relaxed\">\n312 |                   Evaluate your organization’s strategic alignments, data pipeline security, process bottlenecks, governance compliance, and technology parameters. Establish a certified maturity baseline before scheduling agentic deployments.\n313 |                 </p>\n314 |               </div>\n315 |               <div className=\"p-4 rounded-xl border border-white/5 bg-[#030306]/90 min-w-[200px] flex items-center justify-between gap-4 font-mono\">\n316 |                 <div>\n317 |                   <span className=\"text-[9px] text-white/40 block uppercase\">BUFFER SYNC</span>\n318 |                   <span className=\"text-xs font-bold text-[#00FF9D]\">GATEWAY {answeredQuestionsCount} / {totalQuestions} READY</span>\n319 |                 </div>\n320 |                 <div className=\"text-xl font-extrabold text-white\">\n321 |                   {progressPercent}%\n322 |                 </div>\n323 |               </div>\n324 |             </div>\n325 | \n326 |             {/* Main panel layout */}\n327 |             <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-start\">\n328 |               {/* Left Column: Nav list of dimensions */}\n329 |               <div className=\"lg:col-span-3 space-y-4\">\n330 |                 <div className=\"p-4 rounded-xl border border-white/5 bg-[#030306]/90 space-y-3\">\n331 |                   <div className=\"border-b border-white/5 pb-2\">\n332 |                     <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">SEGMENT GATEWAYS</span>\n333 |                   </div>\n334 |                   <div className=\"space-y-1.5\">\n335 |                     {DIMENSIONS.map((dim, idx) => {\n336 |                       const done = isDimensionComplete(dim);\n337 |                       const count = getDimensionAnsweredCount(dim);\n338 |                       const isCurrent = idx === activeDimensionIndex;\n339 |                       \n340 |                       return (\n341 |                         <button\n342 |                           key={dim.id}\n343 |                           type=\"button\"\n344 |                           onClick={() => {\n345 |                             setValidationError(null);\n346 |                             setActiveDimensionIndex(idx);\n347 |                           }}\n348 |                           className={`w-full p-2.5 rounded-lg border text-left flex items-center justify-between transition-all ${\n349 |                             isCurrent \n350 |                               ? \"bg-white/[0.03] border-white/10 text-white\" \n351 |                               : \"bg-transparent border-transparent text-white/50 hover:text-white/90 hover:bg-white/[0.01]\"\n352 |                           }`}\n353 |                         >\n354 |                           <div className=\"flex items-center gap-2.5 min-w-0\">\n355 |                             <span \n356 |                               className=\"p-1 rounded-md border flex-shrink-0\" \n357 |                               style={{ \n358 |                                 color: isCurrent ? dim.color : \"inherit\", \n359 |                                 borderColor: isCurrent ? `${dim.color}35` : \"rgba(255,255,255,0.05)\"\n360 |                               }}\n361 |                             >\n362 |                               {getDimensionIcon(dim.id)}\n363 |                             </span>\n364 |                             <span className=\"text-xs font-bold truncate tracking-tight\">{dim.name}</span>\n365 |                           </div>\n366 |                           <div className=\"font-mono text-[9px] flex-shrink-0 text-white/40\">\n367 |                             {done ? (\n368 |                               <span className=\"text-[#00FF9D] font-bold\">✓</span>\n369 |                             ) : count > 0 ? (\n370 |                               <span>{count}/3</span>\n371 |                             ) : (\n372 |                               <span className=\"w-1.5 h-1.5 rounded-full bg-white/10\" />\n373 |                             )}\n374 |                           </div>\n375 |                         </button>\n376 |                       );\n377 |                     })}\n378 |                   </div>\n379 |                 </div>\n380 | \n381 |                 <div className=\"p-4 rounded-xl border border-white/5 bg-[#030306]/80 text-xs text-white/50 space-y-2\">\n382 |                   <div className=\"h-1 bg-white/5 rounded-full overflow-hidden\">\n383 |                     <div className=\"h-full bg-[#009DFF] transition-all duration-300\" style={{ width: `${progressPercent}%` }} />\n384 |                   </div>\n385 |                   <div className=\"flex justify-between text-[9px] font-mono\">\n386 |                     <span>OVERALL COMPILATION STATUS</span>\n387 |                     <span className=\"text-white font-bold\">{progressPercent}%</span>\n388 |                   </div>\n389 |                 </div>\n390 |               </div>\n391 | \n392 |               {/* Center Column: Questions form */}\n393 |               <div className=\"lg:col-span-6 space-y-6\">\n394 |                 <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 space-y-6\">\n395 |                   <div className=\"border-b border-white/5 pb-4\">\n396 |                     <div className=\"flex items-center gap-2\">\n397 |                       <span className=\"text-[9px] font-mono px-2 py-0.5 rounded bg-white/5 text-[#009DFF] border border-white/10 uppercase tracking-wider font-bold\">\n398 |                         SECTOR {activeDimensionIndex + 1} OF {DIMENSIONS.length}\n399 |                       </span>\n400 |                       {isDimensionComplete(activeDimension) && (\n401 |                         <span className=\"text-[9px] font-mono px-2 py-0.5 rounded bg-[#00FF9D]/10 text-[#00FF9D] border border-[#00FF9D]/20 uppercase tracking-wider font-bold\">\n402 |                           GATE COMPLETE\n403 |                         </span>\n404 |                       )}\n405 |                     </div>\n406 |                     <h2 className=\"text-xl font-bold tracking-tight mt-2 text-white\" style={{ color: activeDimension.color }}>\n407 |                       {activeDimension.name}\n408 |                     </h2>\n409 |                     <p className=\"text-white/50 text-xs mt-1.5 font-light leading-relaxed\">\n410 |                       {activeDimension.description}\n411 |                     </p>\n412 |                   </div>\n413 | \n414 |                   <div className=\"space-y-6\">\n415 |                     {activeDimension.questions.map((q, qIdx) => {\n416 |                       const selectedScore = answers[q.id];\n417 |                       return (\n418 |                         <div key={q.id} className=\"space-y-3\">\n419 |                           <h3 className=\"text-xs font-bold text-white tracking-tight flex gap-2\">\n420 |                             <span className=\"text-white/30 font-mono\">{qIdx + 1}.</span>\n421 |                             <span>{q.text}</span>\n422 |                           </h3>\n423 |                           <div className=\"grid grid-cols-1 gap-2\">\n424 |                             {q.options.map((opt) => {\n425 |                               const selected = selectedScore === opt.score;\n426 |                               return (\n427 |                                 <button\n428 |                                   key={opt.score}\n429 |                                   type=\"button\"\n430 |                                   onClick={() => handleSelectOption(q.id, opt.score)}\n431 |                                   className={`p-3 rounded-xl border text-left transition-all flex items-start gap-3 group relative ${\n432 |                                     selected \n433 |                                       ? \"bg-white/[0.02] text-white\" \n434 |                                       : \"bg-[#040609] border-white/5 text-white/60 hover:text-white/95 hover:bg-white/[0.005] hover:border-white/10\"\n435 |                                   }`}\n436 |                                   style={selected ? { borderColor: `${activeDimension.color}40` } : undefined}\n437 |                                 >\n438 |                                   <div \n439 |                                     className={`w-5 h-5 rounded-md border flex items-center justify-center font-mono text-[10px] font-bold flex-shrink-0 transition-all ${\n440 |                                       selected ? \"text-black\" : \"border-white/10 text-white/30 group-hover:border-white/20\"\n441 |                                     }`}\n442 |                                     style={selected ? { backgroundColor: activeDimension.color, borderColor: activeDimension.color } : undefined}\n443 |                                   >\n444 |                                     {opt.score}\n445 |                                   </div>\n446 |                                   <div className=\"space-y-0.5 min-w-0\">\n447 |                                     <span className=\"text-xs font-bold tracking-tight block\">{opt.label}</span>\n448 |                                     <span className=\"text-[11px] text-white/40 block leading-relaxed font-light\">{opt.description}</span>\n449 |                                   </div>\n450 |                                   {selected && (\n451 |                                     <div className=\"absolute left-0 top-3 bottom-3 w-[2px] rounded-r\" style={{ backgroundColor: activeDimension.color }} />\n452 |                                   )}\n453 |                                 </button>\n454 |                               );\n455 |                             })}\n456 |                           </div>\n457 |                         </div>\n458 |                       );\n459 |                     })}\n460 |                   </div>\n461 | \n462 |                   <div className=\"border-t border-white/5 pt-4 flex items-center justify-between\">\n463 |                     <button\n464 |                       type=\"button\"\n465 |                       disabled={activeDimensionIndex === 0}\n466 |                   