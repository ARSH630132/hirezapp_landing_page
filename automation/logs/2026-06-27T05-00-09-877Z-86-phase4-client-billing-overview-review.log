lassName=\"text-white\">4 Active Enclaves</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Card 2: Ledger Summary */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n            <Briefcase className=\"w-4 h-4 text-[#00FFC2]\" />\n            <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Summary</h3>\n          </div>\n          <div className=\"space-y-2.5 font-mono text-[11px] text-white/70\">\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Total Committed:</span>\n              <span className=\"text-[#009DFF] font-bold\">$51,470.00 USD</span>\n            </div>\n            <div className=\"flex justify-between border-b border-white/[0.02] pb-1.5\">\n              <span className=\"text-white/40\">Settled (Paid):</span>\n              <span className=\"text-emerald-400 font-bold\">$18,320.00 USD</span>\n            </div>\n            <div className=\"flex justify-between\">\n              <span className=\"text-white/40\">Pending Clearance:</span>\n              <span className=\"text-amber-400 font-bold\">$33,150.00 USD</span>\n            </div>\n          </div>\n        </div>\n\n        {/* Card 3: Ledger Integrity */}\n        <div className=\"p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm flex flex-col justify-between space-y-3\">\n          <div className=\"space-y-2\">\n            <div className=\"flex items-center gap-2 border-b border-white/5 pb-2\">\n              <ShieldCheck className=\"w-4 h-4 text-[#00FFC2]\" />\n              <h3 className=\"text-xs font-bold text-white font-mono uppercase\">Ledger Integrity</h3>\n            </div>\n            <p className=\"text-[10px] text-white/50 leading-relaxed font-mono\">\n              Invoices are cryptographically co-signed under isolated hardware security. Instant zero-knowledge verification status.\n            </p>\n          </div>\n          <button \n            onClick={() => {\n              setVerifying(true);\n              setTimeout(() => setVerifying(false), 1200);\n            }}\n            disabled={verifying}\n            className=\"w-full h-8.5 flex items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.02] text-[10px] font-mono font-bold text-white hover:bg-white/[0.05] hover:border-white/20 transition-all cursor-pointer disabled:opacity-50\"\n          >\n            {verifying ? (\n              <RefreshCw className=\"w-3.5 h-3.5 animate-spin text-[#009DFF]\" />\n            ) : (\n              <ShieldCheck className=\"w-3.5 h-3.5 text-[#00FFC2]\" />\n            )}\n            <span>{verifying ? \"VERIFYING SEALS...\" : \"LEDGER COVENANT VERIFIED\"}</span>\n          </button>\n        </div>\n      </div>\n\n      {/* Main Section */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        \n        {/* Left column: Dynamic Telemetry selector and Graph */}\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-5\">\n          <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-3 border-b border-white/5 pb-3\">\n            <div>\n              <h3 className=\"text-sm font-bold text-white font-mono uppercase flex items-center gap-2\">\n                <Activity className=\"w-4 h-4 text-[#009DFF]\" />\n                <span>Compute Telemetry Monitor</span>\n              </h3>\n              <p className=\"text-xs text-white/40 mt-0.5\">Select a secure project node to query live billing cycle CPU/SLA parameters.</p>\n            </div>\n            {/* Project Selector pill items */}\n            <div className=\"flex flex-wrap gap-1\">\n              {Object.keys(PROJECTS_DATA).map((key) => (\n                <button\n                  key={key}\n                  onClick={() => setSelProjectKey(key)}\n                  className={`px-2.5 py-1 text-[9.5px] font-mono font-bold rounded-md border transition-all cursor-pointer ${\n                    selProjectKey === key\n                      ? \"bg-white/5 text-white border-white/20\"\n                      : \"text-white/40 border-transparent hover:text-white/70\"\n                  }`}\n                >\n                  {key.split(\"-\")[2]}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Current selected telemetry card metadata */}\n          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-4 p-4 rounded-lg bg-black/60 border border-white/[0.03] font-mono text-xs\">\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">PROJECT LAYER</span>\n              <span className=\"text-white font-semibold block truncate mt-0.5\">{selectedProj.name}</span>\n            </div>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">SLA CORES</span>\n              <span className=\"text-white font-semibold block mt-0.5\">{selectedProj.cores} Cores Dedicated</span>\n            </div>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">COMPUTE SPEND</span>\n              <span className=\"text-[#009DFF] font-bold block mt-0.5\">{selectedProj.spend}</span>\n            </div>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">QUOTA BURNDOWN</span>\n              <span className=\"text-white font-semibold block mt-0.5\">{selectedProj.quotaUsed}</span>\n            </div>\n          </div>\n\n          {/* Live SVG Graph */}\n          <div className=\"relative pt-4 pb-2 bg-black/40 rounded-lg border border-white/[0.02] overflow-hidden\">\n            <div className=\"absolute top-3 left-3 flex items-center gap-1.5 text-[9px] font-mono text-white/30 uppercase\">\n              <Cpu className=\"w-3 h-3 text-white/40\" />\n              <span>Real-time Compute Threads (June 2026)</span>\n            </div>\n            \n            <div className=\"h-[140px] w-full px-2\">\n              <svg \n                viewBox=\"0 0 500 120\" \n                className=\"w-full h-full overflow-visible\" \n                preserveAspectRatio=\"none\"\n              >\n                <defs>\n                  <linearGradient id={`grad-${selProjectKey}`} x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor={selectedProj.graphColor} stopOpacity=\"0.25\" />\n                    <stop offset=\"100%\" stopColor={selectedProj.graphColor} stopOpacity=\"0.0\" />\n                  </linearGradient>\n                </defs>\n                \n                {/* Horizontal reference grid lines */}\n                <line x1=\"0\" y1=\"30\" x2=\"500\" y2=\"30\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n                <line x1=\"0\" y1=\"60\" x2=\"500\" y2=\"60\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n                <line x1=\"0\" y1=\"90\" x2=\"500\" y2=\"90\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n\n                {/* Graph Fill Area */}\n                <path \n                  d={areaPathString} \n                  fill={`url(#grad-${selProjectKey})`} \n                  className=\"transition-all duration-500 ease-in-out\"\n                />\n\n                {/* Graph Line */}\n                <path \n                  d={pathString} \n                  fill=\"none\" \n                  stroke={selectedProj.graphColor} \n                  strokeWidth=\"2\" \n                  strokeLinecap=\"round\"\n                  className=\"transition-all duration-500 ease-in-out\"\n                />\n\n                {/* Interactive Node circles */}\n                {selectedProj.points.map((pt, idx) => {\n                  const width = 500;\n                  const height = 120;\n                  const step = width / (selectedProj.points.length - 1);\n                  const scale = height / 100;\n                  const cx = idx * step;\n                  const cy = height - pt * scale;\n                  return (\n                    <g key={idx} className=\"group/node cursor-pointer\">\n                      <circle \n                        cx={cx} \n                        cy={cy} \n                        r=\"6\" \n                        fill=\"black\" \n                        stroke={selectedProj.graphColor} \n                        strokeWidth=\"1.5\"\n                      />\n                      <circle \n                        cx={cx} \n                        cy={cy} \n                        r=\"12\" \n                        fill={selectedProj.graphColor} \n                        className=\"opacity-0 group-hover/node:opacity-10 transition-opacity\"\n                      />\n                    </g>\n                  );\n                })}\n              </svg>\n            </div>\n\n            {/* X-Axis dates */}\n            <div className=\"flex justify-between px-4 text-[9px] font-mono text-white/30 border-t border-white/[0.03] pt-2\">\n              {selectedProj.dates.map((d, i) => (\n                <span key={i}>{d}</span>\n              ))}\n            </div>\n          </div>\n\n          <p className=\"text-[10px] text-white/40 font-mono flex items-start gap-1.5 leading-relaxed bg-white/[0.01] p-3 rounded border border-white/[0.03]\">\n            <Info className=\"w-3.5 h-3.5 text-[#009DFF] shrink-0 mt-0.5\" />\n            <span>\n              <strong>Billing Monitor Reference:</strong> {selectedProj.description} Costs are derived directly from eBPF container telemetry probes.\n            </span>\n          </p>\n        </div>"}}}
