YING SEALS...\" : \"LEDGER SEAL VALID\"}</span>\n          </button>\n        </div>\n      </div>\n\n      {/* Invoice Ledger Section */}\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n        <div className=\"lg:col-span-2 p-5 rounded-xl border border-white/5 bg-[#050505]/40 backdrop-blur-sm space-y-4\">\n          <div>\n            <h3 className=\"text-sm font-bold text-white font-mono uppercase\">Recent Certified Invoices</h3>\n            <p className=\"text-xs text-white/40 mt-0.5 font-mono\">Verified statements and corresponding localized project mappings.</p>\n          </div>\n\n          <div className=\"space-y-3\">","new_text":"  const [selProjectKey, setSelProjectKey] = useState<string>(\"GFF-2026-0899\");\n\n  const selectedProj = PROJECTS_DATA[selProjectKey];\n\n  // Helper to generate SVG path\n  const generatePathData = (pts: number[]) => {\n    const width = 500;\n    const height = 120;\n    const step = width / (pts.length - 1);\n    const scale = height / 100;\n    \n    let path = `M 0,${height - pts[0] * scale}`;\n    for (let i = 1; i < pts.length; i++) {\n      const x = i * step;\n      const y = height - pts[i] * scale;\n      // Use smooth bezier lines\n      const prevX = (i - 1) * step;\n      const prevY = height - pts[i - 1] * scale;\n      const cpX1 = prevX + step / 2;\n      const cpY1 = prevY;\n      const cpX2 = prevX + step / 2;\n      const cpY2 = y;\n      path += ` C ${cpX1},${cpY1} ${cpX2},${cpY2} ${x},${y}`;\n    }\n    return path;\n  };\n\n  const pathString = generatePathData(selectedProj.points);\n  \n  // Create solid filled path for gradient area\n  const areaPathString = `${pathString} L 500,120 L 0,120 Z`;\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Header */}\n      <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-white/5 pb-4\">\n        <div>\n          <h2 className=\"text-xl font-bold text-white tracking-tight font-mono uppercas