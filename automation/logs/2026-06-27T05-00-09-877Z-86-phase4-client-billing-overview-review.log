v>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">SLA CORES</span>\n              <span className=\"text-white font-semibold block mt-0.5\">{selectedProj.cores} Cores Dedicated</span>\n            </div>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">COMPUTE SPEND</span>\n              <span className=\"text-[#009DFF] font-bold block mt-0.5\">{selectedProj.spend}</span>\n            </div>\n            <div>\n              <span className=\"text-white/30 text-[9px] block uppercase\">QUOTA BURNDOWN</span>\n              <span className=\"text-white font-semibold block mt-0.5\">{selectedProj.quotaUsed}</span>\n            </div>\n          </div>\n\n          {/* Live SVG Graph */}\n          <div className=\"relative pt-4 pb-2 bg-black/40 rounded-lg border border-white/[0.02] overflow-hidden\">\n            <div className=\"absolute top-3 left-3 flex items-center gap-1.5 text-[9px] font-mono text-white/30 uppercase\">\n              <Cpu className=\"w-3 h-3 text-white/40\" />\n              <span>Real-time Compute Threads (June 2026)</span>\n            </div>\n            \n            <div className=\"h-[140px] w-full px-2\">\n              <svg \n                viewBox=\"0 0 500 120\" \n                className=\"w-full h-full overflow-visible\" \n                preserveAspectRatio=\"none\"\n              >\n                <defs>\n                  <linearGradient id={`grad-${selProjectKey}`} x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                    <stop offset=\"0%\" stopColor={selectedProj.graphColor} stopOpacity=\"0.25\" />\n                    <stop offset=\"100%\" stopColor={selectedProj.graphColor} stopOpacity=\"0.0\" />\n                  </linearGradient>\n                </defs>\n                \n                {/* Horizontal reference grid lines */}\n                <line x1=\"0\" y1=\"30\" x2=\"500\" y2=\"30\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n                <line x1=\"0\" y1=\"60\" x2=\"500\" y2=\"60\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n                <line x1=\"0\" y1=\"90\" x2=\"500\" y2=\"90\" stroke=\"rgba(255,255,255,0.02)\" strokeDasharray=\"2 4\" />\n\n                {/* Graph Fill Area */}\n                <path \n                  d={areaPathString} \n                  fill={`url(#grad-${selProjectKey})`} \n                  className=\"transition-all duration-500 ease-in-out\"\n                />\n\n                {/* Graph Line */}\n                <path \n                  d={pathString} \n                  fill=\"none\" \n                  stroke={selectedProj.graphColor} \n                  strokeWidth=\"2\" \n                  strokeLinecap=\"round\"\n                  className=\"transition-all duration-500 ease-in-out\"\n                />\n\n                {/* Interactive Node circles */}\n                {selectedProj.points.map((pt, idx) => {\n                  const width = 500;\n                  const height = 120;\n                  const step = width / (selectedProj.points.length - 1);\n                  const scale = height / 100;\n                  const cx = idx * step;\n                  const cy = height - pt * scale;\n                  return (\n                    <g key={idx} className=\"group/node cursor-pointer\">\n                      <circle \n                        cx={cx} \n                        cy={cy} \n                        r=\"6\" \n                        fill=\"black\" \n                        stroke={selectedProj.graphColor} \n                        strokeWidth=\"1.5\"\n                      />\n                      <circle \n                        cx={cx} \n                        cy={cy} \n                        r=\"12\" \n                        fill={selectedProj.graphColor} \n                        className=\"opacity-0 group-hover/node:opacity-10 transition-opacity\"\n                      