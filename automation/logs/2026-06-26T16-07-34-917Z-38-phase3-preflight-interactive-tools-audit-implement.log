\n286 | \n287 |               <div className=\"space-y-2\">\n288 |                 <label className=\"text-sm font-semibold text-white/80 block\">Biggest Challenge <span className=\"text-red-500\">*</span></label>\n289 |                 <select\n290 |                   value={answers.biggestChallenge}\n291 |                   onChange={(e) => setAnswers({ ...answers, biggestChallenge: e.target.value })}\n292 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition\"\n293 |                 >\n294 |                   <option value=\"\">-- Select Challenge --</option>\n295 |                   {challengeOptions.map((o) => (\n296 |                     <option key={o.value} value={o.value}>{o.label}</option>\n297 |                   ))}\n298 |                 </select>\n299 |               </div>\n300 |             </div>\n301 |           </div>\n302 |         )}\n303 | \n304 | \n305 |         {/* Step 3: Top Priorities (Max 3) */}\n306 |         {step === 3 && (\n307 |           <div className=\"space-y-4 animate-fadeIn\">\n308 |             <p className=\"text-sm font-semibold text-white/80\">Select Top Priorities (Max 3) <span className=\"text-red-500\">*</span></p>\n309 |             <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3\">\n310 |               {priorityOptions.map((o) => {\n311 |                 const isSelected = answers.topPriorities.includes(o.value);\n312 |                 return (\n313 |                   <button\n314 |                     key={o.value}\n315 |                     type=\"button\"\n316 |                     onClick={() => handlePriorityToggle(o.value)}\n317 |                     className={`p-4 rounded-xl border text-left transition duration-200 group flex justify-between items-center ${\n318 |                       isSelected\n319 |                         ? \"border-[#087DF3] bg-[#087DF3]/15 text-white\"\n320 |                         : \"border-white/10 bg-black/40 text-white/70 hover:border-white/20 hover:bg-black/60\"\n321 |                     }`}\n322 |                   >\n323 |                     <span className=\"text-xs md:text-sm font-medium\">{o.label}</span>\n324 |                     <span className={`w-4 h-4 rounded-full border flex items-center justify-center shrink-0 ml-2 ${\n325 |                       isSelected ? \"border-[#087DF3] bg-[#087DF3]\" : \"border-white/30\"\n326 |                     }`}>\n327 |                       {isSelected && <span className=\"text-[10px] text-white\">вң“</span>}\n328 |                     </span>\n329 |                   </button>\n330 |                 );\n331 |               })}\n332 |             </div>\n333 |           </div>\n334 |         )}\n335 | \n336 |         {/* Step 4: Verification Flow */}\n337 |         {step === 4 && (\n338 |           <div className=\"space-y-6 max-w-[500px] mx-auto w-full animate-fadeIn py-4\">\n339 |             <h3 className=\"text-lg font-bold text-white text-center\">Secure Verification Check</h3>\n340 |             <p className=\"text-xs text-white/50 text-center\">\n341 |               Enter your enterprise email to verify instant delivery and view your interactive roadmap.\n342 |             </p>\n343 | \n344 |             <div className=\"space-y-4\">\n345 |               <div className=\"space-y-2\">\n346 |                 <label className=\"text-xs font-semibold text-white/70 block\">Enterprise Email</label>\n347 |                 <input\n348 |                   type=\"email\"\n349 |                   disabled={otpSent}\n350 |                   value={answers.email}\n351 |                   onChange={(e) => setAnswers({ ...answers, email: e.target.value })}\n352 |                   placeholder=\"name@company.com\"\n353 |                   className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-white focus:border-[#087DF3] outline-none transition disabled:opacity-50\"\n354 |                 />\n355 |               </div>\n356 | \n357 |               {!otpSent ? (\n358 |                 <button\n359 |                   type=\"button\"\n360 |                   onClick={requestOtp}\n361 |                   className=\"w-full h-[46px] rounded-lg bg-[#087DF3] text-sm font-bold text-white hover:bg-[#087DF3]/80 transition mt-4\"\n362 |                 >\n363 |                   Generate Free Blueprint\n364 |                 </button>\n365 |               ) : (\n366 |                 <div className=\"space-y-4 animate-fadeIn\">\n367 |                   <div className=\"space-y-2\">\n368 |                     <div className=\"flex justify-between items-center\">\n369 |                       <label className=\"text-xs font-semibold text-white/70 block\">Enter One-Time PIN (OTP)</label>\n370 |                       <span className=\"text-[10px] text-[#087DF3] font-mono font-bold\">Suggested Code: 123456</span>\n371 |                     </div>\n372 |                     <input\n373 |                       type=\"text\"\n374 |                       maxLength={6}\n375 |                       value={enteredOtp}\n376 |                       onChange={(e) => setEnteredOtp(e.target.value.replace(/\\D/g, \"\"))}\n377 |                       placeholder=\"Enter 6-digit code\"\n378 |                       className=\"w-full h-[46px] rounded-lg border border-white/10 bg-black/50 px-4 text-sm text-center tracking-[0.5em] text-white focus:border-[#087DF3] outline-none transition\"\n379 |                     />\n380 |                     {otpError && <p className=\"text-xs text-red-400 font-semibold\">{otpError}</p>}\n381 |                   </div>\n382 | \n383 |                   <button\n384 |                     type=\"button\"\n385 |                     onClick={verifyOtpAndGenerate}\n386 |                     className=\"w-full h-[46px] rounded-lg bg-[#E98828] text-sm font-bold text-white hover:bg-[#E98828]/80 transition\"\n387 |                   >\n388 |                     Verify & Build Blueprint\n389 |                   </button>\n390 |                 </div>\n391 |               )}\n392 |             </div>\n393 |           </div>\n394 |         )}\n395 | \n396 | \n397 |         {/* Compile Loading Screen */}\n398 |         {isCompiling && (\n399 |           <div className=\"fixed inset-0 z-[10000] bg-black/95 backdrop-blur-md flex flex-col justify-center items-center text-center p-4 animate-fadeIn\">\n400 |             <div className=\"relative w-20 h-20 mb-6\">\n401 |               <div className=\"absolute inset-0 rounded-full border-4 border-white/10\"></div>\n402 |               <div className=\"absolute inset-0 rounded-full border-4 border-t-[#087DF3] animate-spin\"></div>\n403 |             </div>\n404 |             <h4 className=\"text-lg font-bold text-white mb-2\">Compiling Custom AI Blueprint</h4>\n405 |             <p className=\"text-sm font-semibold text-[#087DF3] h-6 transition-all animate-pulse\">\n406 |               {compilingMessages[compilingStep]}\n407 |             </p>\n408 |           </div>\n409 |         )}\n410 | \n411 |         {/* Bottom Wizard Controls */}\n412 |         {step < 4 && (\n413 |           <div className=\"mt-8 pt-4 border-t border-white/5 flex justify-between items-center\">\n414 |             {error && <p className=\"text-xs md:text-sm text-red-400 font-semibold max-w-[70%]\">{error}</p>}\n415 |             <div className=\"flex gap-4 ml-auto\">\n416 |               {step > 1 && (\n417 |                 <button\n418 |                   type=\"button\"\n419 |                   onClick={() => setStep(step - 1)}\n420 |                   className=\"px-5 h-[42px] rounded-lg border border-white/15 text-xs font-semibold text-white hover:bg-white/5 transition\"\n421 |                 >\n422 |                   Back\n423 |                 </button>\n424 |               )}\n425 |               <button\n426 |                 type=\"butt