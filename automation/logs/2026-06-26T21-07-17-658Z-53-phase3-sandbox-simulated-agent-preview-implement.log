Type] = useState(\"All Agent Types\");\n491 |   const [searchQuery, setSearchQuery] = useState(\"\");\n492 | \n493 |   // Catalog Active Agent Selection\n494 |   const [activeAgentId, setActiveAgentId] = useState(AGENTS[0].id);\n495 | \n496 |   // Simulation Telemetry States\n497 |   const [isSimulating, setIsSimulating] = useState(false);\n498 |   const [simulationProgress, setSimulationProgress] = useState(0);\n499 |   const [simulatedLogs, setSimulatedLogs] = useState<typeof AGENTS[0][\"logs\"]>([]);\n500 |   const [activeTab, setActiveTab] = useState<\"blueprint\" | \"architecture\" | \"security\">(\"blueprint\");\n501 | \n502 |   // Filter lists based on rules\n503 |   const filteredAgents = AGENTS.filter((agent) => {\n504 |     const matchIndustry = selectedIndustry === \"All Industries\" || agent.recommendedIndustry === selectedIndustry;\n505 |     const matchFunction = selectedFunction === \"All Functions\" || agent.category === selectedFunction;\n506 |     const matchType = selectedAgentType === \"All Agent Types\" || agent.agentType === selectedAgentType;\n507 |     const matchSearch =\n508 |       searchQuery === \"\" ||\n509 |       agent.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n510 |       agent.purpose.toLowerCase().includes(searchQuery.toLowerCase()) ||\n511 |       agent.category.toLowerCase().includes(searchQuery.toLowerCase());\n512 | \n513 |     return matchIndustry && matchFunction && matchType && matchSearch;\n514 |   });\n515 | \n516 |   // Dynamically pull active agent object\n517 |   const activeAgent = AGENTS.find((a) => a.id === activeAgentId) || AGENTS[0];\n518 | \n519 |   // If filtered agents changed and current active isn't in filtered, select the first filtered one\n520 |   useEffect(() => {\n521 |     if (filteredAgents.length > 0 && !filteredAgents.find((a) => a.id === activeAgentId)) {\n522 |       setActiveAgentId(filteredAgents[0].id);\n523 |     }\n524 |   }, [selectedIndustry, selectedFunction, selectedAgentType, searchQuery, filteredAgents, activeAgentId]);\n525 | \n526 |   // Reset simulation whenever active agent changes\n527 |   useEffect(() => {\n528 |     setIsSimulating(false);\n529 |     setSimulationProgress(0);\n530 |     setSimulatedLogs([]);\n531 |   }, [activeAgentId]);\n532 | \n533 |   // Handle dry-run simulation progress\n534 |   useEffect(() => {\n535 |     if (!isSimulating) return;\n536 | \n537 |     setSimulationProgress(0);\n538 |     setSimulatedLogs([]);\n539 | \n540 |     const totalDuration = 4800; // 4.8s simulation\n541 |     const intervalTime = 50; // update every 50ms\n542 |     let elapsed = 0;\n543 | \n544 |     const interval = setInterval(() => {\n545 |       elapsed += intervalTime;\n546 |       const progress = Math.min((elapsed / totalDuration) * 100, 100);\n547 |       setSimulationProgress(Math.round(progress));\n548 | \n549 |       // Stream logs matching current timeline progress\n550 |       const secondsElapsed = elapsed / 1000;\n551 |       const activeLogs = activeAgent.logs.filter((log) => log.timeOffset <= secondsElapsed);\n552 |       setSimulatedLogs(activeLogs);\n553 | \n554 |       if (elapsed >= totalDuration) {\n555 |         clearInterval(interval);\n556 |         setIsSimulating(false);\n557 |       }\n558 |     }, intervalTime);\n559 | \n560 |     return () => clearInterval(interval);\n561 |   }, [isSimulating, activeAgent]);\n562 | \n563 |   // Dynamic count generators for UI indicators\n564 |   const getIndustryCount = (ind: string) => {\n565 |     if (ind === \"All Industries\") return AGENTS.length;\n566 |     return AGENTS.filter((a) => a.recommendedIndustry === ind).length;\n567 |   };\n568 | \n569 |   const getFunctionCount = (func: string) => {\n570 |     if (func === \"All Functions\") return AGENTS.length;\n571 |     return AGENTS.filter((a) => a.category === func).length;\n572 |   };\n573 | \n574 |   const getAgentTypeCount = (type: string) => {\n575 |     if (type === \"All Agent Types\") return AGENTS.le