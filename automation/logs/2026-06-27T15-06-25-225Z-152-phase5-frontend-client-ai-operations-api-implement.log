 |                   onChange={(e) => setSelectedType(e.target.value)}\n506 |                   aria-label=\"Filter by Agent Type\"\n507 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n508 |                 >\n509 |                   <option value=\"all\">ALL AGENT TYPES</option>\n510 |                   <option value=\"Core Telemetry\">Core Telemetry</option>\n511 |                   <option value=\"Alignment Guard\">Alignment Guard</option>\n512 |                   <option value=\"Seismic Processing\">Seismic Processing</option>\n513 |                   <option value=\"Medical Enclave\">Medical Enclave</option>\n514 |                   <option value=\"Transport Node\">Transport Node</option>\n515 |                 </select>\n516 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n517 |               </div>\n518 |               <div className=\"relative\">\n519 |                 <select \n520 |                   value={selectedStatus}\n521 |                   onChange={(e) => setSelectedStatus(e.target.value)}\n522 |                   aria-label=\"Filter by Status\"\n523 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n524 |                 >\n525 |                   <option value=\"all\">ALL PULSE STATES</option>\n526 |                   <option value=\"active\">Active</option>\n527 |                   <option value=\"evaluating\">Evaluating</option>\n528 |                   <option value=\"warning\">Warning</option>\n529 |                   <option value=\"decoupled\">Decoupled</option>\n530 |                 </select>\n531 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n532 |               </div>\n533 |               <div className=\"relative\">\n534 |                 <select \n535 |                   value={selectedStage}\n536 |                   onChange={(e) => setSelectedStage(e.target.value)}\n537 |                   aria-label=\"Filter by Operating Stage\"\n538 |                   className=\"w-full h-9 rounded-lg border border-white/5 bg-[#080808] px-3 pr-8 text-[11px] font-mono text-white/70 focus:text-white outline-none cursor-pointer appearance-none\"\n539 |                 >\n540 |                   <option value=\"all\">ALL SECURE STAGES</option>\n541 |                   <option value=\"Sandbox Emulation\">Sandbox Emulation</option>\n542 |                   <option value=\"Staging Enclave\">Staging Enclave</option>\n543 |                   <option value=\"Production Guardrail\">Production Guardrail</option>\n544 |                 </select>\n545 |                 <ChevronDown className=\"absolute right-3 top-2.5 w-4 h-4 text-white/40 pointer-events-none\" />\n546 |               </div>\n547 |             </div>\n548 |             {(search || selectedProject !== \"all\" || selectedType !== \"all\" || selectedStatus !== \"all\" || selectedStage !== \"all\") && (\n549 |               <div className=\"flex justify-between items-center text-[10px] font-mono text-white/45 bg-white/[0.01] border border-white/5 px-3 py-1.5 rounded\">\n550 |                 <span>\n551 |                   Filtering active sandbox ledger: found <strong className=\"text-white\">{filteredAgents.length}</strong> matching agent nodes.\n552 |                 </span>\n553 |                 <button onClick={resetFilters} className=\"text-[#009DFF] hover:underline uppercase font-bold cursor-pointer\">\n554 |                   Reset Active Filters\n555 |                 </button>\n556 |               </div>\n557 |             )}\n558 |           </WorkspaceCard>\n559 | \n560 | \n561 |           {filteredAgents.length > 0 ? (\n562 |             <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n563 |               {filteredAgents.map((agent) => {\n564 |                 const isRebooting = rebootingMap[agent.id];\n565 |                 const badgeState = isRebooting ? \"warning\" : agent.status === \"active\" ? \"active\" : agent.status === \"evaluating\" ? \"warning\" : agent.status === \"warning\" ? \"error\" : \"decoupled\";\n566 |                 const badgeLabel = isRebooting ? \"RECYCLING\" : agent.status;\n567 | \n568 |                 return (\n569 |                   <WorkspaceCard key={agent.id} className=\"space-y-4\">\n570 |                     <div className=\"flex justify-between items-start border-b border-white/5 pb-3\">\n571 |                       <div>\n572 |                         <span className=\"text-[8.5px] font-mono font-bold text-[#009DFF] bg-[#009DFF]/5 border border-[#009DFF]/20 px-1.5 py-0.5 rounded\">\n573 |                           {agent.id.toUpperCase()} • {agent.type.toUpperCase()}\n574 |                         </span>\n575 |                         <h4 className=\"text-[13.5px] font-bold text-white font-mono mt-1.5 tracking-tight\">\n576 |                           {agent.name}\n577 |                         </h4>\n578 |                       </div>\n579 |                       <StatusBadge state={badgeState} label={badgeLabel} />\n580 |                     </div>\n581 | \n582 |                     <div className=\"grid grid-cols-2 gap-2 text-[10px] font-mono\">\n583 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n584 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Project Bounds</span>\n585 |                         <span className=\"text-white font-medium truncate block mt-1\">{agent.projectName}</span>\n586 |                       </div>\n587 |                       <div className=\"p-2 border border-white/5 rounded bg-white/[0.01]\">\n588 |                         <span className=\"text-white/30 block uppercase text-[8.5px]\">Enclave Stage</span>\n589 |                         <span className=\"text-white font-medium block mt-1\">{agent.stage}</span>\n590 |                       </div>\n591 |                     </div>\n592 | \n593 |                     <div className=\"grid grid-cols-3 gap-2 text-[10px] font-mono text-center select-none\">\n594 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n595 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Alloc CPU</span>\n596 |                         <span className=\"text-white font-bold block mt-0.5\">\n597 |                           {isRebooting ? \"--\" : `${agent.cpu}%`}\n598 |                         </span>\n599 |                       </div>\n600 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n601 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Memory State</span>\n602 |                         <span className=\"text-white font-bold block mt-0.5\">\n603 |                           {isRebooting ? \"--\" : agent.memory.split(\" / \")[0]}\n604 |                         </span>\n605 |                       </div>\n606 |                       <div className=\"py-1.5 border border-white/5 rounded bg-black/40\">\n607 |                         <span className=\"text-white/35 block text-[8px] uppercase\">Core Threads</span>\n608 |                         <span className=\"text-[#009DFF] font-bold block mt-0.5\">\n609 |                           {isRebooting ? \"0\" : `${agent.threads}`}\n610 |                         </span>\n611 |                       </div>\n612 |                     </div>\n613 | \n614 |                     <div className=\"border border-white/5 rounded-lg overflow-hidden bg-black/70 p-3 h-28 overflow-y-auto font-mono text-[9px] text-white/50 space-y-1\">\n615 |                       {agent.logs.map((log, index) => (\n616 |                         <div key={index} className=\"leading-normal flex\">\n617 |                           <span className=\"text-white/20 mr-1 shrink-0\">&gt;</span>\n618 |                           <span className={\n619 |                             log.includes(\"REBOOT\") || log.includes(\"CRITICAL\") ? \"text-[#009DFF]\" :\n620 |                             log.includes(\"Attestation\") || log.includes(\"successfully\") || log.includes(\"OK\") ? \"text-emerald-400 font-semibold\" : \n621 |                             log.includes(\"Warning\") ? \"text-amber-400\" : \"\"\n622 |                           }>\n623 |                             {log}\n624 |                           </span>\n625 |                         </div>\n626 |                       ))}\n627 |                     </div>\n628 | \n629 |                     <div className=\"flex gap-2 font-mono\">\n630 |                       <button\n631 |                         onClick={() => handleRecycleEnclave(agent.id)}\n632 |                         disabled={isRebooting}\n633 |                         className=\"flex-grow inline-flex h-8 items-center justify-center gap-1.5 rounded border border-white/10 bg-white/[0.01] hover:bg-white/[0.04] text-[10px] font-bold text-white transition-all cursor-pointer disabled:opacity-50\"\n634 |                       >\n635 |                         {isRebooting ? (\n636 |                           <>\n637 |                             <RefreshCw className=\"w-3 h-3 animate-spin text-[#009DFF]\" />\n638 |                             <span>CYCLING...</span>\n639 |                           </>\n640 |                         ) : (\n641 |                           <>\n642 |                             <RefreshCw className=\"w-3 h-3\" />\n643 |                             <span>RECYCLE CORE</span>\n644 |                           </>\n645 |                         )}\n646 |                       </button>\n647 |                       <Link\n648 |                         href={`/portal/ai-operations/${agent.id}`}\n649 |                         className=\"inline-flex h-8 w-10 items-center justify-center rounded border border-white/10 bg-[#009DFF]/10 text-white hover:bg-[#009DFF]/20 transition-all\"\n650 |                         title=\"Inspect Telemetry Details\"\n651 |                       >\n652 |                         <Eye className=\"w-3.5 h-3.5 text-[#009DFF]\" />\n653 |                       </Link>\n654 |                     </div>\n655 |                   </WorkspaceCard>\n656 |                 );\n657 |               })}\n658 |             </div>\n659 | \n660 | \n661 |           ) : (\n662 |             <div className=\"border border-white/5 rounded-2xl bg-white/[0.01] p-12 text-center max-w-xl mx-auto space-y-4\">\n663 |               <div className=\"h-10 w-10 rounded-full border border-white/10 flex items-center justify-center mx-auto bg-black\">\n664 |                 <SlidersHorizontal className=\"w-4 h-4 text-white/30\" />\n665 |               </div>\n666 |               <div className=\"space-y-1 font-mono\">\n667 |                 <h4 className=\"text-[13px] font-bold text-white\">No Sandboxes Match Active Filters</h4>\n668 |                 <p className=\"text-[11px] text-white/40\">Adjust filter values above to find active enclaves.</p>\n669 |               </div>\n670 |               <button\n671 |                 onClick={resetFilters}\n672 |                 className=\"inline-flex h-8 px-4 items-center justify-center rounded bg-white/5 border border-white/10 hover:bg-white/10 text-white font-mono text-[10.5px] uppercase transition-all\"\n673 |               >\n674 |                 Clear Active Filters\n675 |               </button>\n676 |             </div>\n677 |           )}\n678 |         </div>\n679 |       )}\n680 | \n681 |       {/* ==========================================\n682 |           TAB 2: HARDWARE & ENCLAVE ARCHITECTURE\n683 |     