en ${\n 891 |                         isActive\n 892 |                           ? \"border-white/20 text-white\"\n 893 |                           : \"border-white/5 bg-transparent text-white/70 hover:border-white/10 hover:bg-white/[0.01]\"\n 894 |                       }`}\n 895 |                     >\n 896 |                       {isActive && (\n 897 |                         <motion.div\n 898 |                           layoutId=\"activePriorityBg\"\n 899 |                           className=\"absolute inset-0 bg-white/[0.03] -z-10\"\n 900 |                           transition={{ type: \"spring\", stiffness: 380, damping: 30 }}\n 901 |                         />\n 902 |                       )}\n 903 |                       <div\n 904 |                         className=\"w-2 h-2 rounded-full shrink-0 mt-1\"\n 905 |                         style={{ backgroundColor: item.color }}\n 906 |                       />\n 907 |                       <div className=\"relative z-10\">\n 908 |                         <span className={`font-semibold block text-[11px] ${isActive ? \"text-white\" : \"text-white/70\"}`}>\n 909 |                           {item.title}\n 910 |                         </span>\n 911 |                         <span className=\"text-[9px] text-white/40 block leading-tight font-light mt-0.5\">\n 912 |                           {item.desc}\n 913 |                         </span>\n 914 |                       </div>\n 915 |                     </button>\n 916 |                   );\n 917 |                 })}\n 918 |               </div>\n 919 |             </div>\n 920 |           </div>\n 921 | \n 922 |           {/* Dynamic Sovereign Telemetry Preflight Advisory / Input Validation Panel */}\n 923 |           <div className=\"p-4.5 rounded-xl border border-white/5 bg-[#030306]/80 space-y-3 relative overflow-hidden\">\n 924 |             <div className=\"border-b border-white/5 pb-2 flex items-center justify-between\">\n 925 |               <span className=\"text-[9px] font-mono text-white/45 block uppercase tracking-wider\">PREFLIGHT VALIDATION</span>\n 926 |               <span className=\"text-[8px] font-mono px-1.5 py-0.5 rounded bg-white/5 text-white/50 border border-white/10 uppercase tracking-widest font-semibold\">SOVEREIGN ADVISORY</span>\n 927 |             </div>\n 928 |             \n 929 |             <div className=\"space-y-2.5\">\n 930 |               {getPreflightAdvisories().map((item, idx) => {\n 931 |                 const borderColors = {\n 932 |                   warning: \"border-amber-500/20 bg-amber-500/[0.02]\",\n 933 |                   info: \"border-[#009DFF]/20 bg-[#009DFF]/[0.01]\",\n 934 |                   optimal: \"border-[#00FF9D]/20 bg-[#00FF9D]/[0.02]\"\n 935 |                 }[item.type];\n 936 |                 \n 937 |                 const titleColors = {\n 938 |                   warning: \"text-amber-400\",\n 939 |                   info: \"text-[#009DFF]\",\n 940 |                   optimal: \"text-[#00FF9D]\"\n 941 |                 }[item.type];\n 942 | \n 943 |                 const pills = {\n 944 |                   warning: \"bg-amber-500 animate-pulse\",\n 945 |                   info: \"bg-[#009DFF]\",\n 946 |                   optimal: \"bg-[#00FF9D]\"\n 947 |                 }[item.type];\n 948 | \n 949 |                 return (\n 950 |                   <div key={idx} className={`p-3 rounded-lg border text-xs leading-normal font-light transition-all ${borderColors}`}>\n 951 |                     <div className=\"flex items-center gap-2 mb-1.5 font-semibold font-mono tracking-wide text-[9px] uppercase\">\n 952 |                       <span className={`w-1.5 h-1.5 rounded-full ${pills}`} />\n 953 |                       <span className={titleColors}>{item.title}</span>\n 954 |                     </div>\n 955 |                     <p className=\"text-white/60 text-[10px] leading-relaxed font-light\">{item.message}</p>\n 956 |                   </div>\n 957 |                 );\n 958 |               })}\n 959 |             </div>\n 960 |           </div>\n 961 | \n 962 |           {/* Footnote Compliance Panel */}\n 963 |           <div className=\"p-4 rounded-xl border border-white/5 bg-[#030305]/40 text-[10px] text-white/30 space-y-2 leading-relaxed\">\n 964 |             <span className=\"font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">SECURE SHIELD COMPLIANCE</span>\n 965 |             <p>\n 966 |               This simulator processes data points purely inside local volatile browser memory, aligning with the GFF AI zero-retention mandate. No telemetry is logged outside your sandboxed session.\n 967 |             </p>\n 968 |           </div>\n 969 |         </div>\n 970 | \n 971 |         {/* RIGHT COLUMN: Results Console */}\n 972 |         <div className=\"lg:col-span-7 space-y-8 text-white\">\n 973 |           {/* Section A: Main Telemetry Summary Cards */}\n 974 |           <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n 975 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n 976 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#00FF9D]/30 to-transparent\" />\n 977 |               <div>\n 978 |                 <div className=\"flex items-center gap-1.5\">\n 979 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">RECLAIMED ANNUAL VALUE</span>\n 980 |                   <span className=\"text-[8px] font-mono font-bold bg-[#00FF9D]/10 text-[#00FF9D] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n 981 |                 </div>\n 982 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#00FF9D] block mt-2 font-mono tracking-tight\">\n 983 |                   {formatCompactCurrency(expectedGrossSavings)}\n 984 |                 </span>\n 985 |               </div>\n 986 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n 987 |                 Illustrative annual budget returned from manual operations to executive reserves.\n 988 |               </p>\n 989 |             </div>\n 990 | \n 991 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n 992 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/30 to-transparent\" />\n 993 |               <div>\n 994 |                 <div className=\"flex items-center gap-1.5\">\n 995 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">PRODUCTIVE HOURS RECLAIMED</span>\n 996 |                   <span className=\"text-[8px] font-mono font-bold bg-[#009DFF]/10 text-[#009DFF] px-1 rounded uppercase tracking-widest\">MODELLED</span>\n 997 |                 </div>\n 998 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-[#009DFF] block mt-2 font-mono tracking-tight\">\n 999 |                   {expectedHoursSaved.toLocaleString()} Hrs\n1000 |                 </span>\n1001 |               </div>\n1002 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n1003 |                 Equivalent labor hours returned to strategic initiatives rather than manual loops.\n1004 |               </p>\n1005 |             </div>\n1006 | \n1007 |             <div className=\"p-5 rounded-2xl border border-white/5 bg-[#030306]/95 flex flex-col justify-between relative overflow-hidden group\">\n1008 |               <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-amber-500/25 to-transparent\" />\n1009 |               <div>\n1010 |                 <div className=\"flex items-center gap-1.5\">\n1011 |                   <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-wider block\">CAPITAL AMORTIZATION</span>\n1012 |                   <span className=\"text-[8px] font-mono font-bold bg-amber-500/10 text-amber-500 px-1 rounded uppercase tracking-widest\">MODELLED</span>\n1013 |                 </div>\n1014 |                 <span className=\"text-2xl lg:text-3xl font-extrabold text-amber-400 block mt-2 font-mono tracking-tight\">\n1015 |                   {formatPayback(expectedPaybackMonths)}\n1016 |                 </span>\n1017 |               </div>\n1018 |               <p className=\"text-[10px] text-white/40 font-light mt-4 border-t border-white/5 pt-2\">\n1019 |                 The computed timeframe before recouped hours balance the initial CapEx allocation.\n1020 |               </p>\n1021 |             </div>\n1022 |           </div>\n1023 | \n1024 |           {/* Section B: Payback-Style Strategic Narrative */}\n1025 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/80 backdrop-blur-sm space-y-4\">\n1026 |             <span className=\"text-[9px] font-mono text-white/40 uppercase tracking-widest block\">EXECUTIVE SIMULATION DIALOGUE // {currentPriorityObj.title.toUpperCase()}</span>\n1027 |             \n1028 |             <div className=\"space-y-4 text-xs md:text-sm font-light leading-relaxed text-white/80\">\n1029 |               <p>\n1030 |                 For an enterprise operating in <span className=\"text-white font-medium\">{indName}</span>, manual bottlenecks inside <span className=\"text-white font-medium\">{funcName}</span> represent a significant drain on organizational momentum. With an annual baseline of <span className=\"text-white font-mono font-medium\">${annualCostBaseline.toLocaleString()}</span> and a manual friction index of <span className=\"text-white font-medium\">{manualEffort.toUpperCase()}</span>, approximately <span className=\"text-amber-400 font-mono font-medium\">${addressableCostBaseline.toLocaleString()}</span> is consumed by repetitive manual workflows.\n1031 |               </p>\n1032 |               <p>\n1033 |                 Deploying the GFF secure sovereign agent network over a <span className=\"text-white font-medium\">{implementationHorizon.replace(\"_\", \" \")}</span> horizon is modelled to automate up to <span className=\"text-[#00FF9D] font-mono font-bold\">{automationTarget}%</span> of standardized tasks. Achieving a target productivity boost of <span className=\"text-white font-mono font-medium\">{productivityImprovement}%</span> is projected to unlock an illustrative annual reclaimed value of <span className=\"text-[#00FF9D] font-mono font-bold\">${expectedGrossSavings.toLocaleString()}</span>, returning <span className=\"text-white font-mono font-semibold\">{expectedHoursSaved.toLocaleString()} productive hours</span> to high-leverage strategic initiatives.\n1034 |               </p>\n1035 |               <p className=\"text-white/50 text-[11px] leading-relaxed border-t border-white/5 pt-3\">\n1036 |                 Under single-tenant private enclaves with a CapEx allocation of <span className=\"text-white font-mono\">${initialInvestment.toLocaleString()}</span>, the model indicates the system completes its capital amortization within <span className=\"text-[#009DFF] font-semibold\">{formatPayback(expectedPaybackMonths).toLowerCase()}</span>, yielding an estimated net sovereign return (ROI) of <span className=\"text-[#00FF9D] font-mono font-bold\">{expectedRoi}%</span> over the initial operational cycle.\n1037 |               </p>\n1038 |             </div>\n1039 |           </div>\n1040 | \n1041 |           {/* Section C: Pure CSS/SVG Waterfall Chart */}\n1042 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 relative\">\n1043 |             <div className=\"absolute top-0 left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#009DFF]/20 to-transparent\" />\n1044 |             <div className=\"flex justify-between items-baseline border-b border-white/5 pb-4 mb-4\">\n1045 |               <div>\n1046 |                 <span className=\"text-[9px] font-mono text-[#009DFF] font-bold block uppercase tracking-wider\">VALUE CONSTRUCT MATRIX</span>\n1047 |                 <h3 className=\"text-sm font-bold text-white mt-1\">Sovereign Financial Value Waterfall Chart</h3>\n1048 |               </div>\n1049 |               <span className=\"text-[9px] font-mono text-white/30 hidden md:inline\">UNIT: USD ($) // ANNUALIZED MODEL</span>\n1050 |             </div>\n1051 |             <div className=\"w-full overflow-x-auto scrollbar-none\">\n1052 |               <svg viewBox=\"0 0 720 230\" className=\"w-full min-w-[580px] h-auto overflow-visible select-none\" fill=\"none\">\n1053 |                 <line x1=\"30\" y1=\"20\" x2=\"690\" y2=\"20\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" />\n1054 |                 <line x1=\"30\" y1=\"70\" x2=\"690\" y2=\"70\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1055 |                 <line x1=\"30\" y1=\"120\" x2=\"690\" y2=\"120\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1056 |                 <line x1=\"30\" y1=\"170\" x2=\"690\" y2=\"170\" stroke=\"rgba(255,255,255,0.03)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1057 |                 <line x1=\"30\" y1=\"200\" x2=\"690\" y2=\"200\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1.5\" />\n1058 |                 {(() => {\n1059 |                   const maxAmt = Math.max(addressableCostBaseline, expectedGrossSavings, initialInvestment, expectedNetSavings, 1);\n1060 |                   const getY = (v: number) => 200 - (v / maxAmt) * 160;\n1061 |                   const getH = (v: number) => (v / maxAmt) * 160;\n1062 |                   const b1Y = getY(addressableCostBaseline), b1H = getH(addressableCostBaseline);\n1063 |                   const b2H = getH(expectedGrossSavings), b2Y = b1Y;\n1064 |                   const b3H = getH(initialInvestment), b3Y = b2Y + b2H - b3H;\n1065 |                   const b4Y = getY(expectedNetSavings), b4H = getH(expectedNetSavings);\n1066 |                   return (\n1067 |                     <>\n1068 |                       <line x1=\"120\" y1={b1Y} x2=\"210\" y2={b2Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1069 |                       <line x1=\"290\" y1={b2Y+b2H} x2=\"380\" y2={b3Y+b3H} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1070 |                       <line x1=\"460\" y1={b3Y} x2=\"550\" y2={b4Y} stroke=\"rgba(255,255,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"3,3\" />\n1071 |                       <g>\n1072 |                         <rect x=\"50\" y={b1Y} width=\"70\" height={b1H} rx=\"3\" fill=\"url(#fG)\" stroke=\"rgba(255,255,255,0.05)\" />\n1073 |                         <text x=\"85\" y={Math.max(b1Y-8,15)} textAnchor=\"middle\" className=\"fill-white/80 font-mono text-[10px] font-bold\">{formatCompactCurrency(addressableCostBaseline)}</text>\n1074 |                       </g>\n1075 |                       <g>\n1076 |                         <rect x=\"220\" y={b2Y} width=\"70\" height={b2H} rx=\"3\" fill=\"url(#rG)\" stroke=\"rgba(0,255,157,0.15)\" />\n1077 |                         <text x=\"255\" y={Math.max(b2Y-8,15)} textAnchor=\"middle\" className=\"fill-[#00FF9D] font-mono text-[10px] font-bold\">-{formatCompactCurrency(expectedGrossSavings)}</text>\n1078 |                       </g>\n1079 |                       <g>\n1080 |                         <rect x=\"390\" y={b3Y} width=\"70\" height={b3H} rx=\"3\" fill=\"url(#cG)\" stroke=\"rgba(228,0,15,0.15)\" />\n1081 |                         <text x=\"425\" y={Math.max(b3Y-8,15)} textAnchor=\"middle\" className=\"fill-[#E4000F] font-mono text-[10px] font-bold\">+{formatCompactCurrency(initialInvestment)}</text>\n1082 |                       </g>\n1083 |                       <g>\n1084 |                         <rect x=\"560\" y={b4Y} width=\"70\" height={b4H} rx=\"3\" fill=\"url(#nG)\" stroke=\"rgba(0,255,157,0.3)\" />\n1085 |                         <text x=\"595\" y={Math.max(b4Y-8,15)} textAnchor=\"middle\" className=\"fill-[#00FF9D] font-mono text-[10px] font-bold\">{formatCompactCurrency(expectedNetSavings)}</text>\n1086 |                       </g>\n1087 |                     </>\n1088 |                   );\n1089 |                 })()}\n1090 |                 <text x=\"85\" y=\"220\" textAnchor=\"middle\" className=\"fill-white/30 font-mono text-[8px] uppercase tracking-wider\">Manual Loss</text>\n1091 |                 <text x=\"255\" y=\"220\" textAnchor=\"middle\" className=\"fill-white/30 font-mono text-[8px] uppercase tracking-wider\">GFF Reclaimed</text>\n1092 |                 <text x=\"425\" y=\"220\" textAnchor=\"middle\" className=\"fill-white/30 font-mono text-[8px] uppercase tracking-wider\">CapEx Enclave</text>\n1093 |                 <text x=\"595\" y=\"220\" textAnchor=\"middle\" className=\"fill-white/30 font-mono text-[8px] uppercase tracking-wider\">Net Dividend</text>\n1094 |                 <defs>\n1095 |                   <linearGradient id=\"fG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n1096 |                     <stop offset=\"0%\" stopColor=\"rgba(255,255,255,0.15)\" />\n1097 |                     <stop offset=\"100%\" stopColor=\"rgba(255,255,255,0.01)\" />\n1098 |                   </linearGradient>\n1099 |                   <linearGradient id=\"rG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n1100 |                     <stop offset=\"0%\" stopColor=\"rgba(0,255,157,0.25)\" />\n1101 |                     <stop offset=\"100%\" stopColor=\"rgba(0,255,157,0.02)\" />\n1102 |                   </linearGradient>\n1103 |                   <linearGradient id=\"cG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n1104 |                     <stop offset=\"0%\" stopColor=\"rgba(228,0,15,0.25)\" />\n1105 |                     <stop offset=\"100%\" stopColor=\"rgba(228,0,15,0.02)\" />\n1106 |                   </linearGradient>\n1107 |                   <linearGradient id=\"nG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n1108 |                     <stop offset=\"0%\" stopColor=\"rgba(0,255,157,0.45)\" />\n1109 |                     <stop offset=\"100%\" stopColor=\"rgba(0,255,157,0.05)\" />\n1110 |                   </linearGradient>\n1111 |                 </defs>\n1112 |               </svg>\n1113 |             </div>\n1114 |             <div className=\"grid grid-cols-2 md:grid-cols-4 gap-4 mt-6 pt-4 border-t border-white/5 font-mono text-[10px] text-white/50\">\n1115 |               <div>\n1116 |                 <span className=\"block text-white/30 text-[8px] uppercase\">Loaded Labor Rate</span>\n1117 |                 <span className=\"text-white font-bold\">${loadedHourlyRate}/hr</span>\n1118 |               </div>\n1119 |               <div>\n1120 |                 <span className=\"block text-white/30 text-[8px] uppercase\">Friction Factor</span>\n1121 |                 <span className=\"text-white font-bold\">{Math.round(manualEffortFactor * 100)}%</span>\n1122 |               </div>\n1123 |               <div>\n1124 |                 <span className=\"block text-white/30 text-[8px] uppercase\">Automation Rate</span>\n1125 |                 <span className=\"text-white font-bold\">{automationTarget}%</span>\n1126 |               </div>\n1127 |               <div>\n1128 |                 <span className=\"block text-white/30 text-[8px] uppercase\">Modelled Efficiency</span>\n1129 |                 <span className=\"text-white font-bold\">+{productivityImprovement}%</span>\n1130 |               </div>\n1131 |             </div>\n1132 |           </div>\n1133 | \n1134 |           {/* Section D: Comparative Scenario Matrices */}\n1135 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#030306]/95 space-y-4\">\n1136 |             <div className=\"border-b border-white/5 pb-3\">\n1137 |               <span className=\"text-[9px] font-mono text-white/40 block uppercase tracking-wider\">AMORTIZATION MATRIX</span>\n1138 |               <h3 className=\"text-sm font-bold text-white mt-1\">Multi-Scenario Sovereign Performance Matrix</h3>\n1139 |             </div>\n1140 |             \n1141 |             <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">\n1142 |               {/* Scenario 1: Conservative */}\n1143 |               <div className=\"p-4 rounded-xl border border-white/5 bg-white/[0.01] flex flex-col justify-between space-y-3 relative group\">\n1144 |                 <div className=\"space-y-1\">\n1145 |                   <div className=\"flex justify-between items-center\">\n1146 |                     <span className=\"text-[10px] font-bold text-white/70\">Conservative</span>\n1147 |                     <span className=\"text-[8px] font-mono bg-white/5 text-white/40 px-1 rounded uppercase tracking-wider\">Risk-Adjusted</span>\n1148 |                   </div>\n1149 |                   <span className=\"text-[9px] font-mono text-white/30 block\">75% of Adoption Target</span>\n1150 |                 </div>\n1151 |                 <div className=\"space-y-2\">\n1152 |                   <div className=\"flex justify-between text-xs\">\n1153 |                     <span className=\"text-white/40\">Value:</span>\n1154 |                     <span className=\"font-mono text-white/80 font-bold\">{formatCompactCurrency(conservativeGrossSavings)}</span>\n1155 |                   </div>\n1156 |                   <div className=\"flex justify-between text-xs\">\n1157 |                     <span className=\"text-white/40\">Payback:</span>\n1158 |                     <span className=\"font-mono text-white/80\">{formatPayback(conservativePaybackMonths).replace(\" Amortization\", \"\")}</span>\n1159 |                   </div>\n1160 |                   <div className=\"flex justify-between text-xs\">\n1161 |        