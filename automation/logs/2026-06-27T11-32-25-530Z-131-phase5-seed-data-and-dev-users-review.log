ormat\n242 |     req_invalid = MockRequest(path_params={\"client_id\": \"abc\"})\n243 |     try:\n244 |         require_client_access(req_invalid, client_admin_user)\n245 |         assert False, \"Should raise 400\"\n246 |     except HTTPException as e:\n247 |         assert e.status_code == 400\n248 |         assert \"Invalid client_id format\" in e.detail\n249 |         \n250 |     print(\"✓ test_require_client_access_dependency passed.\")\n251 | \n252 | def test_require_same_client_or_admin_dependency():\n253 |     print(\"Running test_require_same_client_or_admin_dependency...\")\n254 |     \n255 |     gff_user = MockUser(role=\"gff_admin\", client_id=None)\n256 |     client_admin_user = MockUser(role=\"client_admin\", client_id=42)\n257 |     other_client_user = MockUser(role=\"client_admin\", client_id=99)\n258 |     \n259 |     req1 = MockRequest(path_params={\"client_id\": \"42\"})\n260 |     \n261 |     # Admin is bypassed\n262 |     assert require_same_client_or_admin(req1, gff_user) == gff_user\n263 |     \n264 |     # Same client is allowed\n265 |     assert require_same_client_or_admin(req1, client_admin_user) == client_admin_user\n266 |     \n267 |     # Other client is rejected\n268 |     try:\n269 |         require_same_client_or_admin(req1, other_client_user)\n270 |         assert False, \"Should raise 403\"\n271 |     except HTTPException as e:\n272 |         assert e.status_code == 403\n273 |         assert \"You can only access data belonging to your own client account\" in e.detail\n274 |         \n275 |     # Missing parameter\n276 |     req_missing = MockRequest()\n277 |     try:\n278 |         require_same_client_or_admin(req_missing, other_client_user)\n279 |         assert False, \"Should raise 400\"\n280 |     except HTTPException as e:\n281 |         assert e.status_code == 400\n282 |         assert \"client_id parameter is required\" in e.detail\n283 |         \n284 |     print(\"✓ test_require_same_client_or_admin_dependency passed.\")\n285 | \n286 | def test_require_permission_dependency():\n287 |     print(\"Running test_require_permission_dependency...\")\n288 |     \n289 |     gff_user = MockUser(role=\"gff_admin\")\n290 |     client_admin_user = MockUser(role=\"client_admin\")\n291 |     client_member_user = MockUser(role=\"client_member\")\n292 |     \n293 |     dep_manage_clients = require_permission(PermissionGroup.MANAGE_CLIENTS)\n294 |     dep_manage_users = require_permission(PermissionGroup.MANAGE_USERS)\n295 |     dep_portal = require_permission(PermissionGroup.CLIENT_PORTAL_ACCESS)\n296 |     \n297 |     # GFF Admin has all permissions\n298 |     assert dep_manage_clients(gff_user) == gff_user\n299 |     assert dep_manage_users(gff_user) == gff_user\n300 |     assert dep_portal(gff_user) == gff_user\n301 |     \n302 |     # Client Admin\n303 |     assert dep_manage_users(client_admin_user) == client_admin_user\n304 |     assert dep_portal(client_admin_user) == client_admin_user\n305 |     try:\n306 |         dep_manage_clients(client_admin_user)\n307 |         assert False, \"Should raise 403\"\n308 |     except HTTPException as e:\n309 |         assert e.status_code == 403\n310 |         assert \"Missing permission\" in e.detail\n311 |         \n312 |     # Client Member\n313 |     assert dep_portal(client_member_user) == client_member_user\n314 |     try:\n315 |         dep_manage_users(client_member_user)\n316 |         assert False, \"Should raise 403\"\n317 |     except HTTPException as e:\n318 |         assert e.status_code == 403\n319 |         \n320 |     print(\"✓ test_require_permission_dependency passed.\")\n321 | \n322 | if __name__ == \"__main__\":\n323 |     try:\n324 |         test_password_hashing()\n325 |         test_jwt_utilities()\n326 |         test_rbac_roles_and_permissions()\n327 |         test_role_checker()\n328 |         test_require_roles_dependency()\n329 |         test_require_admin_dependency()\n330 |         test_require_client_access_dependency()\n331 |         test_require_same_client_or_admin_dependency()\n332 |         test_require_permission_dependency()\n333 |         print(\"\\nAll backend security and RBAC dependency tests passed successfully!\")\n334 |         sys.exit(0)\n335 |     except AssertionError as e:\n336 |         print(\"\\nAssertion error occurred during tests:\")\n337 |         import traceback\n338 |         traceback.print_exc()\n339 |         sys.exit(1)\n340 |     except Exception as e:\n341 |         print(f\"\\nAn error occurred: {e}\")\n342 |         import traceback\n343 |         traceback.print_exc()\n344 |         sys.exit(1)","success":true}],"durationMs":4}}
