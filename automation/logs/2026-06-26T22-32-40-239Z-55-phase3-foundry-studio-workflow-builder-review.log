sitions.push(coordsMap[i]);\n334 |     }\n335 |   }\n336 | \n337 |   return positions;\n338 | }\n339 | \n340 | export default function FoundryStudioPage() {\n341 |   const [selectedPresetId, setSelectedPresetId] = useState<string>(\"banking\");\n342 |   const [selectedPattern, setSelectedPattern] = useState<string>(\"hierarchical\");\n343 |   const [stages, setStages] = useState<WorkflowStage[]>([]);\n344 |   const [knowledgeSources, setKnowledgeSources] = useState<string[]>([]);\n345 |   const [newSourceInput, setNewSourceInput] = useState<string>(\"\");\n346 |   const [selectedNodeId, setSelectedNodeId] = useState<string | null>(null);\n347 |   const [nodeCounter, setNodeCounter] = useState<number>(10);\n348 |   \n349 |   // Custom Node Editor states (for editing the selected node)\n350 |   const [nodeLabel, setNodeLabel] = useState(\"\");\n351 |   const [nodeRole, setNodeRole] = useState(\"\");\n352 |   const [nodeLatency, setNodeLatency] = useState(\"\");\n353 | \n354 |   // Simulation & Logs states\n355 |   const [isSimulating, setIsSimulating] = useState(false);\n356 |   const [simulationProgress, setSimulationProgress] = useState<number>(-1);\n357 |   const [logs, setLogs] = useState<ConsoleLog[]>([]);\n358 |   const [consoleTab, setConsoleTab] = useState<\"terminal\" | \"json\" | \"yaml\">(\"terminal\");\n359 | \n360 |   const [copied, setCopied] = useState(false);\n361 |   const [downloaded, setDownloaded] = useState(false);\n362 | \n363 |   const logsEndRef = useRef<HTMLDivElement>(null);\n364 | \n365 |   // Initialize preset on mount or change\n366 |   useEffect(() => {\n367 |     const preset = INDUSTRY_PRESETS.find((p) => p.id === selectedPresetId);\n368 |     if (preset) {\n369 |       const formattedStages = preset.stages.map((st, idx) => ({\n370 |         id: `node-${idx}-${st.type}`,\n371 |         type: st.type as ModuleType,\n372 |         label: st.label,\n373 |         role: st.role,\n374 |         latency: st.latency,\n375 |         isGated: idx === preset.approvalIndex,\n376 |       }));\n377 |       setStages(formattedStages);\n378 |       setKnowledgeSources(preset.sources);\n379 |       setSelectedPattern(preset.pattern);\n380 |       setSelectedNodeId(formattedStages[0]?.id || null);\n381 | \n382 |       // Reset any active simulation\n383 |       setIsSimulating(false);\n384 |       setSimulationProgress(-1);\n385 |       \n386 |       // Load initial console log list\n387 |       const timestamp = new Date().toLocaleTimeString();\n388 |       setLogs([\n389 |         { time: timestamp, type: \"system\", text: `Loaded sovereign preset configuration: \"${preset.title}\".` },\n390 |         { time: timestamp, type: \"info\", text: `Enclave isolation set to AMD-SEV-SNP hardware boundary. Security parameters initialized.` }\n391 |       ]);\n392 |     }\n393 |   }, [selectedPresetId]);\n394 | \n395 |   // Sync selected node's values into editor states\n396 |   useEffect(() => {\n397 |     if (selectedNodeId) {\n398 |       const node = stages.find((s) => s.id === selectedNodeId);\n399 |       if (node) {\n400 |         setNodeLabel(node.label);\n401 |         setNodeRole(node.role);\n402 |         setNodeLatency(node.latency);\n403 |       }\n404 |     } else {\n405 |       setNodeLabel(\"\");\n406 |       setNodeRole(\"\");\n407 |       setNodeLatency(\"\");\n408 |     }\n409 |   }, [selectedNodeId, stages]);\n410 | \n411 |   // Auto-scroll logs terminal\n412 |   useEffect(() => {\n413 |     if (logsEndRef.current) {\n414 |       logsEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n415 |     }\n416 |   }, [logs]);\n417 | \n418 | \n419 |   // Multi-step Simulation Execution logic\n420 |   useEffect(() => {\n421 |     if (!isSimulating) return;\n422 | \n423 |     if (simulationProgress === -1) {\n424 |       // Begin simulation\n425 |       const timestamp = new Date().toLocaleTimeString();\n426 |       setLogs((prev) => [\n427 |         ...prev,\n428 |         { time: timestamp, type: \"system\", text: `==========================================================` },\n429 |         { time: timestamp, type: \"system\", text: `INITIATING SOVEREIGN WORKFLOW GRAPH SIMULATION [PATTERN: ${selectedPattern.toUpperCase()}]` },\n430 |         { time: timestamp, type: \"info\", text: `Bootstrapping secure memory registers... Sandbox initialized.` }\n431 |       ]);\n432 |       setSimulationProgress(0);\n433 |       return;\n434 |     }\n435 | \n436 |     if (simulationProgress < stages.length) {\n437 |       const stage = stages[simulationProgress];\n438 |       const timer = setTimeout(() => {\n439 |         const timestamp = new Date().toLocaleTimeString();\n440 |         \n441 |         // Dynamic logs corresponding to active node execution\n442 |         const logEntries: ConsoleLog[] = [\n443 |           {\n444 |             time: timestamp,\n445 |             type: stage.type === \"governance\" ? \"warning\" : stage.type === \"review\" ? \"info\" : \"agent\",\n446 |             text: `[EXEC] [STAGE ${simulationProgress + 1}/${stages.length}] executing node: \"${stage.label}\" (${stage.role})`\n447 |           }\n448 |         ];\n449 | \n450 |         // Specific detailed log lines to simulate deep operations","success":true}],"durationMs":2}}
