 \"Supplier Master Agreements DB\",\n208 |       \"SAP ERP Vendor Database ledger\",\n209 |       \"Global Shipping Port Logs\"\n210 |     ],\n211 |     approvalIndex: 4,\n212 |     stages: [\n213 |       { type: \"trigger\", label: \"Vendor PDF Invoice Ingress\", role: \"Sovereign File Inbound Hook\", latency: \"4ms\" },\n214 |       { type: \"reasoning\", label: \"Multimodal Invoice Parser\", role: \"VLM Layout Context Model\", latency: \"80ms\" },\n215 |       { type: \"knowledge\", label: \"SLA Pricing Rate Lookup\", role: \"Sovereign Contract Catalog\", latency: \"12ms\" },\n216 |       { type: \"governance\", label: \"Rate Variance Auditor\", role: \"Finance Variance Guard\", latency: \"6ms\" },\n217 |       { type: \"review\", label: \"Procurement Director Audit\", role: \"Finance Executive Gateway\", latency: \"Pending\" },\n218 |       { type: \"action\", label: \"Adjust SAP ERP Balances\", role: \"Direct SAP Ledger Connector\", latency: \"25ms\" }\n219 |     ]\n220 |   }\n221 | ];\n222 | \n223 | const AGENT_PATTERNS = [\n224 |   { id: \"sequential\", label: \"Sequential Chain\", desc: \"Linear workflow where each stage executes in a hard order.\" },\n225 |   { id: \"hierarchical\", label: \"Hierarchical Supervisor\", desc: \"Central supervisor delegates tasks to isolated sub-agents.\" },\n226 |   { id: \"swarm\", label: \"Federated Swarm\", desc: \"De-centralized sub-agents negotiate routing without a supervisor.\" },\n227 |   { id: \"dag\", label: \"Cognitive DAG\", desc: \"Parallel branching paths connected dynamically based on conditions.\" },\n228 | ];\n229 | \n230 | interface ConsoleLog {\n231 |   time: string;\n232 |   type: \"system\" | \"info\" | \"agent\" | \"success\" | \"warning\";\n233 |   text: string;\n234 | }\n235 | \n236 | \n237 | // ==========================================\n238 | // 2. Component Implementation\n239 | // ==========================================\n240 | \n241 | export default function FoundryStudioPage() {\n242 |   const [selectedPresetId, setSelectedPresetId] = useState<string>(\"banking\");\n243 |   const [selectedPattern, setSelectedPattern] = useState<string>(\"hierarchical\");\n244 |   const [stages, setStages] = useState<WorkflowStage[]>([]);\n245 |   const [knowledgeSources, setKnowledgeSources] = useState<string[]>([]);\n246 |   const [newSourceInput, setNewSourceInput] = useState<string>(\"\");\n247 |   const [selectedNodeId, setSelectedNodeId] = useState<string | null>(null);\n248 |   const [nodeCounter, setNodeCounter] = useState<number>(10);\n249 |   \n250 |   // Custom Node Editor states (for editing the selected node)\n251 |   const [nodeLabel, setNodeLabel] = useState(\"\");\n252 |   const [nodeRole, setNodeRole] = useState(\"\");\n253 |   const [nodeLatency, setNodeLatency] = useState(\"\");\n254 | \n255 |   // Simulation & Logs states\n256 |   const [isSimulating, setIsSimulating] = useState(false);\n257 |   const [simulationProgress, setSimulationProgress] = useState<number>(-1);\n258 |   const [logs, setLogs] = useState<ConsoleLog[]>([]);\n259 |   const [consoleTab, setConsoleTab] = useState<\"terminal\" | \"json\" | \"yaml\">(\"terminal\");\n260 | \n261 |   const [copied, setCopied] = useState(false);\n262 |   const [downloaded, setDownloaded] = useState(false);\n263 | \n264 |   const logsEndRef = useRef<HTMLDivElement>(null);\n265 | \n266 |   // Initialize preset on mount or change\n267 |   useEffect(() => {\n268 |     const preset = INDUSTRY_PRESETS.find((p) => p.id === selectedPresetId);\n269 |     if (preset) {\n270 |       const formattedStages = preset.stages.map((st, idx) => ({\n271 |         id: `node-${idx}-${st.type}`,\n272 |         type: st.type as ModuleType,\n273 |         label: st.label,\n274 |         role: st.role,\n275 |         latency: st.latency,\n276 |         isGated: idx === preset.approvalIndex,\n277 |       }));\n278 |       setStages(formattedStages);\n279 |       setKnowledgeSources(preset.sources);\n280 |       setSelectedPattern(preset.pattern);\n281 |       setSelectedNodeId(formattedStages[0]?.id || null);\n282 | \n283 |       // Reset any active simulation\n284 |       setIsSimulating(false);\n285 |       setSimulationProgress(-1);\n286 |       \n287 |       // Load initial console log list\n288 |       const timestamp = new Date().toLocaleTimeString();\n289 |       setLogs([\n290 |         { time: timestamp, type: \"system\", text: `Loaded sovereign preset configuration: \"${preset.title}\".` },\n291 |         { time: timestamp, type: \"info\", text: `Enclave isolation set to AMD-SEV-SNP hardware boundary. Security parameters initialized.` }\n292 |       ]);\n293 |     }\n294 |   }, [selectedPresetId]);\n295 | \n296 |   // Sync selected node's values into editor states\n297 |   useEffect(() => {\n298 |     if (selectedNodeId) {\n299 |       const node = stages.find((s) => s.id === selectedNodeId);\n300 |       if (node) {\n301 |         setNodeLabel(node.label);\n302 |         setNodeRole(node.role);\n303 |         setNodeLatency(node.latency);\n304 |       }\n305 |     } else {\n306 |       setNodeLabel(\"\");\n307 |       setNodeRole(\"\");\n308 |       setNodeLatency(\"\");\n309 |     }\n310 |   }, [selectedNodeId, stages]);\n311 | \n312 |   // Auto-scroll logs terminal\n313 |   useEffect(() => {\n314 |     if (logsEndRef.current) {\n315 |       logsEndRef.current.scrollIntoView({ behavior: \"smooth\" });\n316 |     }\n317 |   }, [logs]);\n318 | \n319 | \n320 |   // Multi-step Simulation Execution logic\n321 |   useEffect(() => {\n322 |     if (!isSimulating) return;\n323 | \n324 |     if (simulationProgress === -1) {\n325 |       // Begin simulation\n326 |       const timestamp = new Date().toLocaleTimeString();\n327 |       setLogs((prev) => [\n328 |         ...prev,\n329 |         { time: timestamp, type: \"system\", text: `==========================================================` },\n330 |         { time: timestamp, type: \"system\", text: `INITIATING SOVEREIGN WORKFLOW GRAPH SIMULATION [PATTERN: ${selectedPattern.toUpperCase()}]` },\n331 |         { time: timestamp, type: \"info\", text: `Bootstrapping secure memory registers... Sandbox initialized.` }\n332 |       ]);\n333 |       setSimulationProgress(0);\n334 |       return;\n335 |     }\n336 | \n337 |     if (simulationProgress < stages.length) {\n338 |       const stage = stages[simulationProgress];\n339 |       const timer = setTimeout(() => {\n340 |         const timestamp = new Date().toLocaleTimeString();\n341 |         \n342 |         // Dynamic logs corresponding to active node execution\n343 |         const logEntries: ConsoleLog[] = [\n344 |           {\n345 |             time: timestamp,\n346 |             type: stage.type === \"governance\" ? \"warning\" : stage.type === \"review\" ? \"info\" : \"agent\",\n347 |             text: `[EXEC] [STAGE ${simulationProgress + 1}/${stages.length}] executing node: \"${stage.label}\" (${stage.role})`\n348 |           }\n349 |         ];\n350 | \n351 |         // Specific detailed log lines to simulate deep operations\n352 |         if (stage.type === \"trigger\") {\n353 |           logEntries.push({\n354 |             time: timestamp,\n355 |             type: \"system\",\n356 |             text: `>> Listener captured inbound telemetry payload. Routing token streams internally.`\n357 |           });\n358 |         } else if (stage.type === \"reasoning\") {\n359 |           logEntries.push({\n360 |             time: timestamp,\n361 |             type: \"agent\",\n362 |             text: `>> Model evaluating context vectors. Context dimension: 1536. Anomaly score: 0.12 (Within healthy threshold).`\n363 |           });\n364 |         } else if (stage.type === \"knowledge\") {\n365 |           logEntries.push({\n366 |             time: timestamp,\n367 |             type: \"info\",\n368 |             text: `>> Querying Sovereign Knowledge database... Resolved 3 relative entities and 14 relational bounds. No data leaked.`\n369 |           });\n370 |         } else if (stage.type === \"governance\") {\n371 |           logEntries.push({\n372 |             time: timestamp,\n373 |             type: \"warning\",\n374 |             text: `>> HIPAA/SOC2 strict scrub triggered. Mapped 2 items containing proprietary codes. Masking in RAM.`\n375 |           });\n376 |         } else if (stage.type === \"review\") {\n377 |           logEntries.push({\n378 |             time: timestamp,\n379 |             type: \"info\",\n380 |             text: `>> Gated human approval breakpoint found. Stall verification ticket issued... Digital authority sign-off successfully bypass-simulated.`\n381 |           });\n382 |         } else if (stage.type === \"action\") {\n383 |           logEntries.push({\n384 |             time: timestamp,\n385 |             type: \"agent\",\n386 |             text: `>> Dispatched RPC transaction block to single-tenant ERP Ledger. Target server responded Code 200.`\n387 |           });\n388 |         } else if (stage.type === \"output\") {\n389 |           logEntries.push({\n390 |             time: timestamp,\n391 |             type: \"success\",\n392 |             text: `>> Document output specifications compiled. Writing cryptographically verified receipt JSON payload.`\n393 |           });\n394 |         } else if (stage.type === \"monitoring\") {\n395 |           logEntries.push({\n396 |             time: timestamp,\n397 |             type: \"success\",\n398 |             text: `>> Heartbeat verified. Active token latency: 142ms. SLA performance threshold: 100% compliant.`\n399 |           });\n400 |         }\n401 | \n402 |         setLogs((prev) => [...prev, ...logEntries]);\n403 |         setSimulationProgress((prev) => prev + 1);\n404 |       }, 1500);\n405 | \n406 |       return () => clearTimeout(timer);\n407 |     } else {\n408 |       // Completed simulation\n409 |       const timer = setTimeout(() => {\n410 |         const timestamp = new Date().toLocaleTimeString();\n411 |         setLogs((prev) => [\n412 |           ...prev,\n413 |           { time: timestamp, type: \"success\", text: `GRAPH SIMULATION COMPLETED SUCCESSFULLY.` },\n414 |           { time: timestamp, type: \"success\", text: `Result output certified SHA-256: 0x8a92f03f7a8b... Transient memory arrays scrubbed clean.` },\n415 |           { time: timestamp, type: \"system\", text: `==========================================================` }\n416 |         ]);\n417 |         setIsSimulating(false);\n418 |       }, 800);\n419 | \n420 |       return () => clearTimeout(timer);\n421 |     }\n422 |   }, [isSimulating, simulationProgress, stages, selectedPattern]);\n423 | \n424 |   // Start / Cancel Simulation triggers\n425 |   const handleStartSimulation = () => {\n426 |     if (isSimulating) {\n427 |       setIsSimulating(false);\n428 |       setSimulationProgress(-1);\n429 |     } else {\n430 |       setSimulationProgress(-1);\n431 |       setIsSimulating(true);\n432 |     }\n433 |   };\n434 | \n435 |   const handleResetSimulation = () => {\n436 |     setIsSimulating(false);\n437 |     setSimulationProgress(-1);\n438 |     setLogs([]);\n439 |     const timestamp = new Date().toLocaleTimeString();\n440 |     setLogs([\n441 |       { time: timestamp, type: \"system\", text: \"Simulation logs flushed clean.\" },\n442 |       { time: timestamp, type: \"info\", text: \"Ready for next diagnostic pipeline trigger.\" }\n443 |     ]);\n444 |   };\n445 | \n446 | \n447 |   // Node array modifications\n448 |   const handleAddModule = (type: ModuleType) => {\n449 |     const defaults = MODULE_DEFAULTS[type];\n450 |     const newStage: WorkflowStage = {\n451 |       id: `node-${nodeCounter}-${type}`,\n452 |       type,\n453 |       label: defaults.label,\n454 |       role: defaults.role,\n455 |       latency: defaults.latency,\n456 |       isGated: false,\n457 |     };\n458 |     setStages((prev) => [...prev, newStage]);\n459 |     setSelectedNodeId(newStage.id);\n460 |     setNodeCounter((prev) => prev + 1);\n461 |     \n462 |     const timestamp = new Date().toLocaleTimeString();\n463 |     setLogs((prev) => [\n464 |       ...prev,\n465 |       { time: timestamp, type: \"system\", text: `Appended pipeline node stage: \"${defaults.label}\" of type [${type.toUpperCase()}].` }\n466 |     ]);\n467 |   };\n468 | \n469 |   const handleDeleteStage = (id: string, label: string) => {\n470 |     if (stages.length <= 1) {\n471 |       alert(\"Sovereign architectures must retain at least 1 functional pipeline node.\");\n472 |       return;\n473 |     }\n474 |     setStages((prev) => prev.filter((s) => s.id !== id));\n475 |     if (selectedNodeId === id) {\n476 |       setSelectedNodeId(null);\n477 |     }\n478 |     const timestamp = new Date().toLocaleTimeString();\n479 |     setLogs((prev) => [\n480 |       ...prev,\n481 |       { time: timestamp, type: \"system\", text: `Removed node stage: \"${label}\". Adjusted topology.` }\n482 |     ]);\n483 |   };\n484 | \n485 |   const handleMoveStage = (index: number, direction: \"left\" | \"right\") => {\n486 |     const newStages = [...stages];\n487 |     const targetIdx = direction === \"left\" ? index - 1 : index + 1;\n488 |     if (targetIdx < 0 || targetIdx >= stages.length) return;\n489 | \n490 |     // Swap stages\n491 |     const temp = newStages[index];\n492 |     newStages[index] = newStages[targetIdx];\n493 |     newStages[targetIdx] = temp;\n494 |     setStages(newStages);\n495 |   };\n496 | \n497 |   // Node form updates\n498 |   const handleSaveNodeChanges = () => {\n499 |     if (!selectedNodeId) return;\n500 |     setStages((prev) =>\n501 |       prev.map((s) =>\n502 |         s.id === selectedNodeId\n503 |           ? { ...s, label: nodeLabel, role: nodeRole, latency: nodeLatency }\n504 |           : s\n505 |       )\n506 |     );\n507 |     const timestamp = new Date().toLocaleTimeString();\n508 |     setLogs((prev) => [\n509 |       ...prev,\n510 |       { time: timestamp, type: \"system\", text: `Updated node parameter configuration: \"${nodeLabel}\" successfully.` }\n511 |     ]);\n512 |   };\n513 | \n514 |   const handleToggleGate = (id: string) => {\n515 |     setStages((prev) =>\n516 |       prev.map((s) => (s.id === id ? { ...s, isGated: !s.isGated } : s))\n517 |     );\n518 |     const node = stages.find((s) => s.id === id);\n519 |     if (node) {\n520 |       const timestamp = new Date().toLocaleTimeString();\n521 |       setLogs((prev) => [\n522 |         ...prev,\n523 |         { time: timestamp, type: \"info\", text: `Toggled Human-in-the-Loop gate status for node: \"${node.label}\" (Active: ${!node.isGated}).` }\n524 |       ]);\n525 |     }\n526 |   };\n527 | \n528 |   // Knowledge source tag additions\n529 |   const handleAddSource = (e: React.FormEvent) => {\n530 |     e.preventDefault();\n531 |     if (!newSourceInput.trim()) return;\n532 |     if (knowledgeSources.includes(newSourceInput.trim())) return;\n533 | \n534 |     setKnowledgeSources((prev) => [...prev, newSourceInput.trim()]);\n535 |     const timestamp = new Date().toLocaleTimeString();\n536 |     setLogs((prev) => [\n537 |       ...prev,\n538 |       { time: timestamp, type: \"info\", text: `Added custom vector/ontology knowledge label: \"${newSourceInput.trim()}\".` }\n539 |     ]);\n540 |     setNewSourceInput(\"\");\n541 |   };\n542 | \n543 |   const handleRemoveSource = (source: string) => {\n544 |     setKnowledgeSources((prev) => prev.filter((s) => s !== source));\n545 |     const timestamp = new Date().toLocaleTimeString();\n546 |     setLogs((prev) => [\n547 |       ...prev,\n548 |       { time: timestamp, type: \"info\", text: `Removed knowledge reference source: \"${source}\".` }\n549 |     ]);\n550 |   };\n551 | \n552 |   // Real-time generated Schemas formatting\n553 |   const generateJSONSchema = () => {\n554 |     const schemaObj = {\n555 |       $schema: \"https://gff.ai/schemas/foundry-studio-v3.json\",\n556 |       pipelineId: `gff-pipeline-${selectedPresetId}`,\n557 |       industry: selectedPresetId,\n558 |       topologyPattern: selectedPattern,\n559 |       knowledgeSovereignty: {\n560 |         zeroEgressEnforced: true,\n561 |         enclaveType: \"AMD-SEV-SNP\",\n562 |         localSources: knowledgeSources,\n563 |       },\n564 |       stages: stages.map((s, idx) => ({\n565 |         index: idx,\n566 |         type: s.type,\n567 |         label: s.label,\n568 |         role: s.role,\n569 |         latencyTarget: s.latency,\n570 |         humanGated: s.isGated,\n571 |       })),\n572 |     };\n573 |     return JSON.stringify(schemaObj, null, 2);\n574 |   };\n575 | \n576 |   const generateYAMLManifest = () => {\n577 |     return `apiVersion: gff.ai/v1alpha1\n578 | kind: SovereignCognitiveDAG\n579 | metadata:\n580 |   name: ${selectedPresetId}-intelligence-pipeline\n581 |   namespace: sovereign-enclave-prod\n582 | spec:\n583 |   pattern: ${selectedPattern}\n584 |   isolationLevel: AMD-SEV-SNP\n585 |   telemetryStream: enabled\n586 |   knowledgeBases:\n587 | ${knowledgeSources.map((s) => `    - name: \"${s}\"\\n      isolation: EncryptedMemoryMapped`).join(\"\\n\")}\n588 |   pipeline:\n589 | ${stages\n590 |   .map(\n591 |     (s, idx) => `    - step: ${idx + 1}\n592 |       type: ${s.type}\n593 |       label: \"${s.label}\"\n594 |       handler: \"enclave://${s.type}/${s.id}\"\n595 |       humanGated: ${s.isGated}`\n596 |   )\n597 |   .join(\"\\n\")}`;\n598 |   };\n599 | \n600 |   // Clipboard copies & simulated downloads\n601 |   const handleCopyToClipboard = () => {\n602 |     const text = consoleTab === \"json\" ? generateJSONSchema() : generateYAMLManifest();\n603 |     navigator.clipboard.writeText(text);\n604 |     setCopied(true);\n605 |     setTimeout(() => setCopied(false), 2000);\n606 |   };\n607 | \n608 |   const handleDownloadSpec = () => {\n609 |     const text = consoleTab === \"json\" ? generateJSONSchema() : generateYAMLManifest();\n610 |     const ext = consoleTab === \"json\" ? \"json\" : \"yaml\";\n611 |     const blob = new Blob([text], { type: \"text/plain\" });\n612 |     const url = URL.createObjectURL(blob);\n613 |     const link = document.createElement(\"a\");\n614 |     link.href = url;\n615 |     link.download = `foundry-workflow-${selectedPresetId}.${ext}`;\n616 |     document.body.appendChild(link);\n617 |     link.click();\n618 |     document.body.removeChild(link);\n619 |     setDownloaded(true);\n620 |     setTimeout(() => setDownloaded(false), 2500);\n621 |   };\n622 | \n623 | \n624 |   return (\n625 |     <ToolPageShell>\n626 |       {/* CSS Animation Injector for custom dynamic SVG flow lines */}\n627 |       <style dangerouslySetInnerHTML={{ __html: `\n628 |         @keyframes flowDash {\n629 |           to {\n630 |             stroke-dashoffset: -20;\n631 |           }\n632 |         }\n633 |         .animate-flowDash {\n634 |           stroke-dasharray: 6 4;\n635 |           animation: flowDash 0.8s linear infinite;\n636 |         }\n637 |       `}} />\n638 | \n639 |       {/* Tool Hero Intro Section */}\n640 |       <ToolHero\n641 |         category=\"WORKSPACE WORKBENCH\"\n642 |         title=\"GFF Foundry Studio DAG Architect\"\n643 |         highlightedWord=\"Foundry Studio\"\n644 |         description=\"Configure and compile enterprise-grade multi-stage Directed Acyclic Graph (DAG) pipelines for sovereign cognitive agents. Shape sandboxed workflows with real-time SVG connection previews.\"\n645 |         metricLabel=\"PLATFORM MODE\"\n646 |         metricValue=\"SIMULATION ACTIVE\"\n647 |       />\n648 | \n649 |       <div className=\"grid grid-cols-1 xl:grid-cols-12 gap-10 items-start\">\n650 |         {/* ==========================================\n651 |             LEFT COLUMN: Studio Configurator Panel (4 cols)\n652 |             ========================================== */}\n653 |         <div className=\"xl:col-span-4 space-y-6\">\n654 |           \n655 |           {/* Preset Selector */}\n656 |           <div className=\"p-6 rounded-2xl border border-white/5 bg-[#04060b]/80 backdrop-blur-sm space-y-4\">\n657 |             <div>\n658 |               <span className=\"text-[10px] font-mono text-[#009DFF] font-bold uppercase tracking-widest block mb-1\">\n659 |                 PRESET TEMPLATES\n660 |               </span>\n661 |               <h2 className=\"text-lg font-bold text-white tracking-tight\">Select Industry Domain</h2>\n662 |               <p className=\"text-white/40 text-xs font-light\">Loading a preset instantly configures realistic domain workflow nodes.</p>\n663 |             </div>\n664 | \n665 |             <div className=\"flex flex-wrap gap-2 pt-2\">\n666 |               {INDUSTRY_PRESETS.map((p) => (\n667 |                 <button\n668 |                   key={p.id}\n669 |                   onClick={() => setSelectedPresetId(p.id)}\n670 |                   className={`px-3 py-2 rounded-xl text-xs font-semibold flex items-center gap-2 transition-all border ${\n671 |                     selectedPresetId === p.id\n672 |                       ? \"bg-[#009DFF]/10 border-[#009DFF] text-white cursor-pointer\"\n673 |                       : \"bg-white/[0.02] border-white/5 text-white/50 hover:bg-white/[0.04] hover:text-white cursor-pointer\"\n674 |                   }`}\n675 |                 >\n676 |                   <span>{p.icon}</span>\n677 |                   <span>{p.label}</span>\n678 |                 </button>\n679 |               ))}\n680 |             </div>\n681 | \n682 |             {/* Display active preset description */}\n683 |             {INDUSTRY_PRESETS.map((p) => {\n684 |               if (p.id !== selectedPresetId) return null;\n685 |               return (\n686 |                 <div key={p.id} className=\"pt-2 border-t border-white/5 mt-2 animate-fadeIn\">\n687 |                   <h4 className=\"text-xs font-bold text-white/80 mb-1\">{p.title}</h4>\n688 |                   <p className=\"text-[11px] text-white/50 leading-relaxed font-light\">{p.description}</p>\n